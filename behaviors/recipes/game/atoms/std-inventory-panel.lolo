app std-inventory-panel "1.0.0"
"std-inventory-panel as a Function"

orbital InventorySlotOrbital {
  entity InventorySlot [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    items : [string]
  }

  type InventorySlotLoaded     = Event InventorySlot                  "Fired when InventorySlot finishes loading"
  type InventorySlotLoadFailed = Event { message : string } "Fired when InventorySlot fails to load"
  type InventorySlotDeleted = Event { id : string }
  type InventorySlotDeleteFailed = Event { error : string, code : string }
  trait InventorySlotInventoryPanel -> InventorySlot [interaction, instance] {
    state idle {
      INIT -> idle
        (fetch InventorySlot { emit: { success: "InventorySlotLoaded", failure: "InventorySlotLoadFailed" } })
        (render-ui main { type: "inventory-panel", items: "@entity.items", slots: 16, columns: 4, selectSlotEvent: "SELECT_SLOT", useItemEvent: "USE_ITEM", dropItemEvent: "DROP_ITEM", showTooltips: true })
      InventorySlotLoaded -> idle
        (set @entity.items @payload.items)
      SELECT_SLOT -> idle
        (render-ui main { type: "inventory-panel", items: "@entity.items", slots: 16, columns: 4, selectSlotEvent: "SELECT_SLOT", useItemEvent: "USE_ITEM", dropItemEvent: "DROP_ITEM", showTooltips: true })
      USE_ITEM -> idle
        (fetch InventorySlot { emit: { success: "InventorySlotLoaded", failure: "InventorySlotLoadFailed" } })
        (render-ui main { type: "inventory-panel", items: "@entity.items", slots: 16, columns: 4, selectSlotEvent: "SELECT_SLOT", useItemEvent: "USE_ITEM", dropItemEvent: "DROP_ITEM", showTooltips: true })
      DROP_ITEM -> idle
        (persist delete InventorySlot @payload.item.id { emit: { success: "InventorySlotDeleted", failure: "InventorySlotDeleteFailed" } })
        (fetch InventorySlot { emit: { success: "InventorySlotLoaded", failure: "InventorySlotLoadFailed" } })
        (render-ui main { type: "inventory-panel", items: "@entity.items", slots: 16, columns: 4, selectSlotEvent: "SELECT_SLOT", useItemEvent: "USE_ITEM", dropItemEvent: "DROP_ITEM", showTooltips: true })
    }
    listens {
      SELECT_SLOT { index : number! }
      USE_ITEM { item : object! }
      DROP_ITEM { item : object! }
          InventorySlotLoadFailed { message : string }
    
      InventorySlotDeleteFailed { error : string, code : string }
    }
    emits {
      InventorySlotLoaded
      InventorySlotLoadFailed
      InventorySlotDeleted
      InventorySlotDeleteFailed
    }
  }
  page "/inventoryslots" as InventorySlotInventoryPage -> InventorySlotInventoryPanel
}