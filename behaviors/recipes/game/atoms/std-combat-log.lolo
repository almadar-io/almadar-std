app std-combat-log "1.0.0"
"std-combat-log as a Function"

orbital CombatLogEntryOrbital {
  entity CombatLogEntry [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    type : "attack" | "defend" | "heal" | "move" | "special" | "death" | "spawn" = "attack"
    message : string
    timestamp : number = 0
    actorName : string
    targetName : string
    value : number = 0
    turn : number = 1
  }

  type CombatLogEntryLoaded     = Event CombatLogEntry                  "Fired when CombatLogEntry finishes loading"
  type CombatLogEntryLoadFailed = Event { message : string } "Fired when CombatLogEntry fails to load"
  trait CombatLogEntryCombatLog -> CombatLogEntry [interaction, instance] {
    state idle {
      INIT -> idle
        (fetch CombatLogEntry { emit: { success: "CombatLogEntryLoaded", failure: "CombatLogEntryLoadFailed" } })
        (render-ui main { type: "combat-log", events: "@CombatLogEntry", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" })
      LOG_EVENT -> idle
        (render-ui main { type: "combat-log", events: "@CombatLogEntry", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" })
      CLEAR -> idle
        (render-ui main { type: "combat-log", events: "@CombatLogEntry", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" })
    }
    listens {
      LOG_EVENT { data : object! }
          CombatLogEntryLoadFailed { message : string }
    }
    emits {
      CombatLogEntryLoaded
      CombatLogEntryLoadFailed
    }
  }
  page "/combatlogentrys" as CombatLogEntryLogPage -> CombatLogEntryCombatLog
}