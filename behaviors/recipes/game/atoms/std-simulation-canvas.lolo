app std-simulation-canvas "1.0.0"
"std-simulation-canvas as a Function"

orbital SimulationWorldOrbital {
  entity SimulationWorld [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type SimulationWorldLoaded     = Event SimulationWorld                  "Fired when SimulationWorld finishes loading"
  type SimulationWorldLoadFailed = Event { message : string } "Fired when SimulationWorld fails to load"
  trait SimulationWorldSimulationCanvas -> SimulationWorld [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch SimulationWorld { emit: { success: "SimulationWorldLoaded", failure: "SimulationWorldLoadFailed" } })
        (render-ui main { type: "simulation-canvas", preset: "pendulum", width: 800, height: 400, running: false, speed: 1 })
      START -> running
        (render-ui main { type: "simulation-canvas", preset: "pendulum", width: 800, height: 400, running: true, speed: 1 })
      RESET -> idle
        (render-ui main { type: "simulation-canvas", preset: "pendulum", width: 800, height: 400, running: false, speed: 1 })
    }
    state running {
      STOP -> idle
        (render-ui main { type: "simulation-canvas", preset: "pendulum", width: 800, height: 400, running: false, speed: 1 })
      RESET -> running
        (render-ui main { type: "simulation-canvas", preset: "pendulum", width: 800, height: 400, running: true, speed: 1 })
    }
    emits: [SimulationWorldLoaded, SimulationWorldLoadFailed]
    listens {
      SimulationWorldLoadFailed { message : string }
    }
  }
  page "/simulationworlds" as SimulationWorldSimulationPage -> SimulationWorldSimulationCanvas
}