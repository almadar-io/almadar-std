app std-game-audio "1.0.0"
"std-game-audio as a Function"

orbital AudioTrackOrbital {
  entity AudioTrack [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type AudioTrackLoaded     = Event AudioTrack                  "Fired when AudioTrack finishes loading"
  type AudioTrackLoadFailed = Event { message : string } "Fired when AudioTrack fails to load"
  trait AudioTrackGameAudio -> AudioTrack [interaction, instance] {
    state idle {
      INIT -> idle
        (fetch AudioTrack { emit: { success: "AudioTrackLoaded", failure: "AudioTrackLoadFailed" } })
        (render-ui main { type: "game-audio-provider", manifest: { click: "https://almadar-kflow-assets.web.app/shared/audio/sfx/close_001.ogg", confirm: "https://almadar-kflow-assets.web.app/shared/audio/sfx/confirmation_001.ogg", drop: "https://almadar-kflow-assets.web.app/shared/audio/sfx/drop_001.ogg" }, baseUrl: "https://almadar-kflow-assets.web.app/shared/audio", initialMuted: false, children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-md mx-auto", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "volume-2" }, { type: "typography", content: "Audio Controls", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Audio Active", variant: "h4" }, { type: "typography", content: "Toggle mute to control game audio playback.", variant: "body", color: "muted" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Toggle Mute", icon: "volume-2", action: "TOGGLE_MUTE", variant: "primary" }] }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Sound Effects", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Play Click", icon: "play", variant: "ghost" , action: "PLAY_CLICK"}, { type: "button", label: "Play Confirm", icon: "play", variant: "ghost" , action: "PLAY_CONFIRM"}, { type: "button", label: "Play Drop", icon: "play", variant: "ghost" , action: "PLAY_DROP"}] }] }] }] }] })
      TOGGLE_MUTE -> idle
        (render-ui main { type: "game-audio-provider", manifest: { click: "https://almadar-kflow-assets.web.app/shared/audio/sfx/close_001.ogg", confirm: "https://almadar-kflow-assets.web.app/shared/audio/sfx/confirmation_001.ogg", drop: "https://almadar-kflow-assets.web.app/shared/audio/sfx/drop_001.ogg" }, baseUrl: "https://almadar-kflow-assets.web.app/shared/audio", initialMuted: false, children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-md mx-auto", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "volume-2" }, { type: "typography", content: "Audio Controls", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Audio Active", variant: "h4" }, { type: "typography", content: "Toggle mute to control game audio playback.", variant: "body", color: "muted" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Toggle Mute", icon: "volume-2", action: "TOGGLE_MUTE", variant: "primary" }] }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Sound Effects", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Play Click", icon: "play", variant: "ghost" , action: "PLAY_CLICK"}, { type: "button", label: "Play Confirm", icon: "play", variant: "ghost" , action: "PLAY_CONFIRM"}, { type: "button", label: "Play Drop", icon: "play", variant: "ghost" , action: "PLAY_DROP"}] }] }] }] }] })
      PLAY_CLICK -> idle
      PLAY_CONFIRM -> idle
      PLAY_DROP -> idle
    }
    emits {
      AudioTrackLoaded
      AudioTrackLoadFailed
    }
    listens {
      AudioTrackLoadFailed { message : string }
    }
  }
  page "/audiotracks" as AudioTrackAudioPage -> AudioTrackGameAudio
}