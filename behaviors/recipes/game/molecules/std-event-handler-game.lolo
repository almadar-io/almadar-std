app std-event-handler-game "1.0.0"
"std-event-handler-game as a Function"

orbital EventHandlerGameOrbital {
  entity EventHandlerGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number @intrinsic = 0
    level : number @intrinsic = 1
  }

  type EventHandlerGameLoaded     = Event EventHandlerGame                  "Fired when EventHandlerGame finishes loading"
  type EventHandlerGameLoadFailed = Event { message : string } "Fired when EventHandlerGame fails to load"
  trait EventHandlerGameEventHandlerGame -> EventHandlerGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch EventHandlerGame { emit: { success: "EventHandlerGameLoaded", failure: "EventHandlerGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Event Handler", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "event-handler-board", entity: "EventHandlerGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Event Handler", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits {
      EventHandlerGameLoaded
      EventHandlerGameLoadFailed
    }
    listens {
      EventHandlerGameLoadFailed { message : string }
    }
  }
  page "/eventhandlergames" as EventHandlerGamePage -> EventHandlerGameEventHandlerGame
}