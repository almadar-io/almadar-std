app std-debugger-game "1.0.0"
"std-debugger-game as a Function"

orbital DebuggerGameOrbital {
  entity DebuggerGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type DebuggerGameLoaded     = Event DebuggerGame                  "Fired when DebuggerGame finishes loading"
  type DebuggerGameLoadFailed = Event { message : string } "Fired when DebuggerGame fails to load"
  trait DebuggerGameDebuggerGame -> DebuggerGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch DebuggerGame { emit: { success: "DebuggerGameLoaded", failure: "DebuggerGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Bug Hunter", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "debugger-board", entity: "DebuggerGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Bug Hunter", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [DebuggerGameLoaded, DebuggerGameLoadFailed]
    listens {
      DebuggerGameLoadFailed { message : string }
    }
  }
  page "/debuggergames" as DebuggerGamePage -> DebuggerGameDebuggerGame
}