app std-service-notification-hub "1.0.0"
"std-service-notification-hub as a Function"

orbital ServiceNotificationHubOrbital {
  entity ServiceNotificationHub [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    recipient : string
    subject : string
    messageBody : string
    channel : string = "email"
    sendStatus : string = "idle"
    error : string
  }

  type ServiceNotificationHubLoaded     = Event ServiceNotificationHub                  "Fired when ServiceNotificationHub finishes loading"
  type ServiceNotificationHubLoadFailed = Event { message : string } "Fired when ServiceNotificationHub fails to load"
  type ServiceNotificationHubEmailCompleted = Event { result : object }
  type ServiceNotificationHubEmailFailed = Event { error : string, code : string }
  type ServiceNotificationHubTwilioCompleted = Event { result : object }
  type ServiceNotificationHubTwilioFailed = Event { error : string, code : string }
  trait ServiceNotificationHubNotificationHub -> ServiceNotificationHub [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceNotificationHub { emit: { success: "ServiceNotificationHubLoaded", failure: "ServiceNotificationHubLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "bell" }, { type: "typography", content: "ServiceNotificationHub Notification Hub", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "Email or phone number" }, { type: "input", placeholder: "Notification subject" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Email", action: "SEND_EMAIL", variant: "primary", icon: "mail" }, { type: "button", label: "SMS", action: "SEND_SMS", variant: "secondary", icon: "message-circle" }, { type: "button", label: "WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
      SEND_EMAIL -> sending
        (set @entity.channel email)
        (render-ui main { type: "loading-state", title: "Sending notification...", message: "Delivering servicenotificationhub notification..." })
        (call-service email send { to: "@entity.recipient", subject: "@entity.subject", body: "@entity.messageBody" } { emit: { success: "ServiceNotificationHubEmailCompleted", failure: "ServiceNotificationHubEmailFailed" } })
      SEND_SMS -> sending
        (set @entity.channel sms)
        (render-ui main { type: "loading-state", title: "Sending notification...", message: "Delivering servicenotificationhub notification..." })
        (call-service twilio "sendSMS" { to: "@entity.recipient", body: "@entity.messageBody" } { emit: { success: "ServiceNotificationHubTwilioCompleted", failure: "ServiceNotificationHubTwilioFailed" } })
      SEND_WHATSAPP -> sending
        (set @entity.channel whatsapp)
        (render-ui main { type: "loading-state", title: "Sending notification...", message: "Delivering servicenotificationhub notification..." })
        (call-service twilio "sendWhatsApp" { to: "@entity.recipient", body: "@entity.messageBody" } { emit: { success: "ServiceNotificationHubTwilioCompleted", failure: "ServiceNotificationHubTwilioFailed" } })
    }
    state sending {
      SENT -> sent
        (set @entity.sendStatus sent)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Notification sent successfully" }, { type: "button", label: "Send Another", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.sendStatus error)
        (set @entity.error @payload.error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "error-state", title: "Send Failed", message: "Could not deliver the notification.", onRetry: "RETRY" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Retry", action: "RETRY", variant: "primary", icon: "refresh-cw" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state sent {
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "bell" }, { type: "typography", content: "ServiceNotificationHub Notification Hub", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "Email or phone number" }, { type: "input", placeholder: "Notification subject" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Email", action: "SEND_EMAIL", variant: "primary", icon: "mail" }, { type: "button", label: "SMS", action: "SEND_SMS", variant: "secondary", icon: "message-circle" }, { type: "button", label: "WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "bell" }, { type: "typography", content: "ServiceNotificationHub Notification Hub", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "Email or phone number" }, { type: "input", placeholder: "Notification subject" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Email", action: "SEND_EMAIL", variant: "primary", icon: "mail" }, { type: "button", label: "SMS", action: "SEND_SMS", variant: "secondary", icon: "message-circle" }, { type: "button", label: "WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "bell" }, { type: "typography", content: "ServiceNotificationHub Notification Hub", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "Email or phone number" }, { type: "input", placeholder: "Notification subject" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Email", action: "SEND_EMAIL", variant: "primary", icon: "mail" }, { type: "button", label: "SMS", action: "SEND_SMS", variant: "secondary", icon: "message-circle" }, { type: "button", label: "WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
    }
    listens {
      FAILED { error : string! }
          ServiceNotificationHubLoadFailed { message : string }
    
      ServiceNotificationHubEmailFailed { error : string, code : string }
      ServiceNotificationHubTwilioFailed { error : string, code : string }
    }
    emits: [ServiceNotificationHubLoaded, ServiceNotificationHubLoadFailed, ServiceNotificationHubEmailCompleted, ServiceNotificationHubEmailFailed, ServiceNotificationHubTwilioCompleted, ServiceNotificationHubTwilioFailed]
  }
  page "/servicenotificationhubs" as ServiceNotificationHubPage -> ServiceNotificationHubNotificationHub
}