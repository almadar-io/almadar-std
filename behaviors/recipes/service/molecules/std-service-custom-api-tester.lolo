app std-service-custom-api-tester "1.0.0"
"std-service-custom-api-tester as a Function"

orbital ServiceCustomApiTesterOrbital {
  entity ServiceCustomApiTester [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    endpoint : string
    method : string = "GET"
    requestBody : string
    responseData : string
    statusCode : number = 0
    authType : string = "header"
    callStatus : string = "idle"
    error : string
  }

  type ServiceCustomApiTesterLoaded     = Event ServiceCustomApiTester                  "Fired when ServiceCustomApiTester finishes loading"
  type ServiceCustomApiTesterLoadFailed = Event { message : string } "Fired when ServiceCustomApiTester fails to load"
  type ServiceCustomApiTesterCustomHeaderApiCompleted = Event { result : object }
  type ServiceCustomApiTesterCustomHeaderApiFailed = Event { error : string, code : string }
  type ServiceCustomApiTesterCustomBearerApiCompleted = Event { result : object }
  type ServiceCustomApiTesterCustomBearerApiFailed = Event { error : string, code : string }
  type ServiceCustomApiTesterCustomQueryApiCompleted = Event { result : object }
  type ServiceCustomApiTesterCustomQueryApiFailed = Event { error : string, code : string }
  type ServiceCustomApiTesterCustomNoauthApiCompleted = Event { result : object }
  type ServiceCustomApiTesterCustomNoauthApiFailed = Event { error : string, code : string }
  trait ServiceCustomApiTesterApiTester -> ServiceCustomApiTester [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceCustomApiTester { emit: { success: "ServiceCustomApiTesterLoaded", failure: "ServiceCustomApiTesterLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "Unified API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "Request body (JSON)" }, { type: "divider" }, { type: "typography", content: "Select Auth Type", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Header API Key", action: "CALL_HEADER_API", variant: "primary", icon: "key" }, { type: "button", label: "Bearer Token", action: "CALL_BEARER_API", variant: "primary", icon: "shield" }, { type: "button", label: "Query Param", action: "CALL_QUERY_API", variant: "primary", icon: "search" }, { type: "button", label: "No Auth", action: "CALL_NOAUTH_API", variant: "primary", icon: "unlock" }] }] })
      ServiceCustomApiTesterLoaded -> idle
        (set @entity.endpoint @payload.endpoint)
        (set @entity.method @payload.method)
        (set @entity.requestBody @payload.requestBody)
      CALL_HEADER_API -> calling
        (set @entity.authType header)
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomapitester endpoint..." })
        (call-service custom-header-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ServiceCustomApiTesterCustomHeaderApiCompleted", failure: "ServiceCustomApiTesterCustomHeaderApiFailed" } })
      CALL_BEARER_API -> calling
        (set @entity.authType bearer)
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomapitester endpoint..." })
        (call-service custom-bearer-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ServiceCustomApiTesterCustomBearerApiCompleted", failure: "ServiceCustomApiTesterCustomBearerApiFailed" } })
      CALL_QUERY_API -> calling
        (set @entity.authType query)
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomapitester endpoint..." })
        (call-service custom-query-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ServiceCustomApiTesterCustomQueryApiCompleted", failure: "ServiceCustomApiTesterCustomQueryApiFailed" } })
      CALL_NOAUTH_API -> calling
        (set @entity.authType noauth)
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomapitester endpoint..." })
        (call-service custom-noauth-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ServiceCustomApiTesterCustomNoauthApiCompleted", failure: "ServiceCustomApiTesterCustomNoauthApiFailed" } })
    }
    state calling {
      API_RESPONSE -> complete
        (set @entity.responseData @payload.data)
        (set @entity.statusCode @payload.statusCode)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Response", variant: "h2" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "badge", label: "@entity.authType", variant: "info" }, { type: "badge", label: "@entity.statusCode", variant: "info" }] }, { type: "code-block", code: "@entity.responseData", language: "json" }, { type: "button", label: "New Request", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Request Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "Unified API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "Request body (JSON)" }, { type: "divider" }, { type: "typography", content: "Select Auth Type", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Header API Key", action: "CALL_HEADER_API", variant: "primary", icon: "key" }, { type: "button", label: "Bearer Token", action: "CALL_BEARER_API", variant: "primary", icon: "shield" }, { type: "button", label: "Query Param", action: "CALL_QUERY_API", variant: "primary", icon: "search" }, { type: "button", label: "No Auth", action: "CALL_NOAUTH_API", variant: "primary", icon: "unlock" }] }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "Unified API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "Request body (JSON)" }, { type: "divider" }, { type: "typography", content: "Select Auth Type", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Header API Key", action: "CALL_HEADER_API", variant: "primary", icon: "key" }, { type: "button", label: "Bearer Token", action: "CALL_BEARER_API", variant: "primary", icon: "shield" }, { type: "button", label: "Query Param", action: "CALL_QUERY_API", variant: "primary", icon: "search" }, { type: "button", label: "No Auth", action: "CALL_NOAUTH_API", variant: "primary", icon: "unlock" }] }] })
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "Unified API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "Request body (JSON)" }, { type: "divider" }, { type: "typography", content: "Select Auth Type", variant: "h4" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Header API Key", action: "CALL_HEADER_API", variant: "primary", icon: "key" }, { type: "button", label: "Bearer Token", action: "CALL_BEARER_API", variant: "primary", icon: "shield" }, { type: "button", label: "Query Param", action: "CALL_QUERY_API", variant: "primary", icon: "search" }, { type: "button", label: "No Auth", action: "CALL_NOAUTH_API", variant: "primary", icon: "unlock" }] }] })
    }
    listens {
      API_RESPONSE { data : string!, statusCode : number! }
      FAILED { error : string! }
          ServiceCustomApiTesterLoadFailed { message : string }
    
      ServiceCustomApiTesterCustomHeaderApiFailed { error : string, code : string }
      ServiceCustomApiTesterCustomBearerApiFailed { error : string, code : string }
      ServiceCustomApiTesterCustomQueryApiFailed { error : string, code : string }
      ServiceCustomApiTesterCustomNoauthApiFailed { error : string, code : string }
    }
    emits {
      ServiceCustomApiTesterLoaded
      ServiceCustomApiTesterLoadFailed
      ServiceCustomApiTesterCustomHeaderApiCompleted
      ServiceCustomApiTesterCustomHeaderApiFailed
      ServiceCustomApiTesterCustomBearerApiCompleted
      ServiceCustomApiTesterCustomBearerApiFailed
      ServiceCustomApiTesterCustomQueryApiCompleted
      ServiceCustomApiTesterCustomQueryApiFailed
      ServiceCustomApiTesterCustomNoauthApiCompleted
      ServiceCustomApiTesterCustomNoauthApiFailed
    }
  }
  page "/servicecustomapitesters" as ServiceCustomApiTesterPage -> ServiceCustomApiTesterApiTester
}