app std-push-activity-log "1.0.0"
"std-push-activity-log as a Function"
;;
;; The canonical @trait.X showcase for the new std-push atom:
;; PushIndicator live status on top, ActivityLog below listing received
;; messages. Push emits PUSH_RECEIVED; ActivityLog listens and appends.

orbital PushActivityLogOrbital {
  uses Push        from "std/behaviors/std-push"
  uses ActivityLog from "std/behaviors/std-agent-activity-log"

  entity PushActivityItem [persistent: pushactivityitems] {
    id : string!
    event : string
    receivedAt : string
    payload : string
  }
  type PushActivityItemLoaded = Event { data : [PushActivityItem] }
  type PushActivityItemLoadFailed = Event { error : string, code : string }

  trait PushActivityPush = Push.traits.PushSubscriberIndicator    -> PushActivityItem {}
  trait PushActivityLog  = ActivityLog.traits.AgentActivityLogLog -> PushActivityItem {
    listens {
      PushActivityPush PUSH_RECEIVED     -> LOG_ENTRY
      PushActivityPush PUSH_DISCONNECTED -> LOG_ENTRY
    
      PushActivityItemLoadFailed { error : string, code : string }
    }
  }

  trait PushActivityLayout -> PushActivityItem [interaction, instance] {
    state composing {
      INIT -> composing
        (fetch PushActivityItem { emit: { success: "PushActivityItemLoaded", failure: "PushActivityItemLoadFailed" } })
        (render-ui main {
          type: "stack",
          direction: "vertical",
          gap: "md",
          children: [
            "@trait.PushActivityPush",
            "@trait.PushActivityLog"
          ]
        })
    }
    emits: [PushActivityItemLoadFailed, PushActivityItemLoaded]
  }

  page "/push-activity" as PushActivity -> PushActivityLayout
}
