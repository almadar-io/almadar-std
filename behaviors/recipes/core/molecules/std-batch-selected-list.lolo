app std-batch-selected-list "1.0.0"
"std-batch-selected-list as a Function"
;;
;; Browse + Selection + Confirmation with a batch-action toolbar. Selection
;; fires BATCH_SELECTED when items are toggled; the layout's render-ui has
;; the toolbar inline and Browse below. Confirmation renders into its own
;; modal slot (not via @trait.X).

orbital BatchListItemOrbital {
  uses Browse       from "std/behaviors/std-browse"
  uses Selection    from "std/behaviors/std-selection"
  uses Confirmation from "std/behaviors/std-confirmation"

  entity BatchListItem [persistent: batchlistitems] {
    id : string!
    name : string
    description : string
    status : string
  }
  type BatchListItemLoaded = Event { data : [BatchListItem] }
  type BatchListItemLoadFailed = Event { error : string, code : string }

  trait BatchItemBrowse       = Browse.traits.BrowseItemBrowse             -> BatchListItem {
    listens {
      BatchItemConfirmation.CONFIRM -> INIT
    
      BatchListItemLoadFailed { error : string, code : string }
    }
  }
  trait BatchItemSelection    = Selection.traits.SelectableItemSelection   -> BatchListItem {}
  trait BatchItemConfirmation = Confirmation.traits.ConfirmActionConfirmation -> BatchListItem {
    listens {
      BatchListLayout.REQUEST -> REQUEST
    }
  }

  trait BatchListLayout -> BatchListItem [interaction, instance] {
    state composing {
      INIT -> composing
        (fetch BatchListItem { emit: { success: "BatchListItemLoaded", failure: "BatchListItemLoadFailed" } })
        (render-ui main {
          type: "stack",
          direction: "vertical",
          gap: "md",
          children: [
            {
              type: "stack",
              direction: "horizontal",
              gap: "sm",
              justify: "end",
              children: [
                { type: "button", label: "Delete selected", action: "REQUEST", variant: "danger", icon: "trash-2" }
              ]
            },
            "@trait.BatchItemSelection",
            "@trait.BatchItemBrowse"
          ]
        })
    }
    emits {
      REQUEST
      BatchListItemLoadFailed
      BatchListItemLoaded
    }
  }

  page "/batch-list" as BatchList -> BatchListLayout
}
