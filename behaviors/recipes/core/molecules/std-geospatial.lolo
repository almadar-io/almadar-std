app std-geospatial "1.0.0"
"std-geospatial as a Function"
;;
;; Location picker: browse → detail → confirm → selection emitted.
;; Select is an own-trait (detail view, not form), ConfirmSelect refs
;; std-confirmation. No create/update/delete — picker only.

orbital LocationOrbital {
  uses Confirmation from "std/behaviors/std-confirmation"

  entity Location [persistent: locations] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
    pendingId   : string = ""
  }

  type LocationLoaded     = Event { data : [Location] }            "Fired when the Location collection finishes loading"
  type LocationLoadFailed = Event { error : string, code : string } "Fired when the Location collection fails to load"
  type LocationSelected   = Event { id : string }                  "Fired once the user confirms a location pick"

  trait LocationBrowse -> Location [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch Location { emit: { success: "LocationLoaded", failure: "LocationLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading locations…" }] })
      LocationLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "map-pin" }, { type: "typography", content: "Locations", variant: "h2" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Select", event: "SELECT", variant: "ghost" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "map-pin" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }] }] })
      LocationLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load locations" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch Location { emit: { success: "LocationLoaded", failure: "LocationLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch Location { emit: { success: "LocationLoaded", failure: "LocationLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits: [LocationLoaded, LocationLoadFailed]
    listens {
      LocationLoadFailed { error : string, code : string }
      LocationConfirmSelect CONFIRMED -> INIT
      LocationSelectionFlow LocationSelected -> INIT
    }
  }

  ;; Select: detail modal showing the candidate location before user confirms.
  trait LocationSelect -> Location [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Location { emit: { success: "LocationLoaded", failure: "LocationLoadFailed" } })
      SELECT -> open
        (set @entity.id @payload.id)
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CLOSE", variant: "ghost" }, { type: "button", label: "Confirm Selection", action: "CONFIRM_SELECT", actionPayload: { id: "@entity.id" }, variant: "primary", icon: "check" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
      CONFIRM_SELECT -> closed
        (render-ui modal null)
    }
    emits {
      CONFIRM_SELECT external { id : string! }
    }

    emits: [LocationLoadFailed, LocationLoaded]
    listens {
      SELECT { id : string! }
    }
  }

  ;; ConfirmSelect: final confirmation, refs std-confirmation.
  trait LocationConfirmSelect = Confirmation.traits.ConfirmActionConfirmation -> Location {
    config: {
      icon:         "alert-triangle",
      title:        "Confirm Location",
      alertMessage: "Are you sure you want to select this location?",
      confirmLabel: "Confirm"
    }
    events {
      REQUEST: CONFIRM_SELECT
      CONFIRM: CONFIRMED
    }
  }

  ;; Coordinator: emits LocationSelected after confirmation. No persist side-effect.
  trait LocationSelectionFlow -> Location [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_EMIT_SELECTED -> idle
        (emit LocationSelected { id: "@payload.id" })
    }
    emits {
      LocationSelected external { id : string! }
    }
    listens {
      DO_EMIT_SELECTED { id : string! }
      LocationConfirmSelect CONFIRMED -> DO_EMIT_SELECTED
    }
  }

  page "/locations" as LocationPage -> LocationBrowse, LocationSelect, LocationConfirmSelect, LocationSelectionFlow
}
