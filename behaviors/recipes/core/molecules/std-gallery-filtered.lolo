app std-gallery-filtered "1.0.0"
"std-gallery-filtered as a Function"
;;
;; Gallery view with Search + Filter above it, stacked via @trait.X.

orbital GalleryFilteredOrbital {
  uses Gallery from "std/behaviors/std-gallery"
  uses Filter  from "std/behaviors/std-filter"
  uses Search  from "std/behaviors/std-search"

  entity GalleryFilteredItem [runtime] {
    id : string!
    name : string
    imageUrl : string
    tags : string
  }
  type GalleryFilteredItemLoaded = Event { data : [GalleryFilteredItem] }
  type GalleryFilteredItemLoadFailed = Event { error : string, code : string }

  trait GalleryFilteredSearch  = Search.traits.SearchResultSearch   -> GalleryFilteredItem {}
  trait GalleryFilteredFilter  = Filter.traits.FilterTargetFilter   -> GalleryFilteredItem {}
  trait GalleryFilteredGallery = Gallery.traits.GalleryItemGallery  -> GalleryFilteredItem {}

  trait GalleryFilteredLayout -> GalleryFilteredItem [interaction, instance] {
    state composing {
      INIT -> composing
        (fetch GalleryFilteredItem { emit: { success: "GalleryFilteredItemLoaded", failure: "GalleryFilteredItemLoadFailed" } })
        (render-ui main {
          type: "stack",
          direction: "vertical",
          gap: "md",
          children: [
            {
              type: "stack",
              direction: "horizontal",
              gap: "sm",
              children: [
                "@trait.GalleryFilteredSearch",
                "@trait.GalleryFilteredFilter"
              ]
            },
            "@trait.GalleryFilteredGallery"
          ]
        })
    }
    emits {
      GalleryFilteredItemLoadFailed
      GalleryFilteredItemLoaded
    }
  }

  page "/gallery" as Gallery -> GalleryFilteredLayout
}
