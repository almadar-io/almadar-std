app std-backoff-retry "0.1.0"
"std-backoff-retry — wrapper that re-attempts with jittered exponential delay"
;;
;; RECIPE-ONLY (proposed). Distinct from std-circuit-breaker: the breaker
;; decides WHETHER to call, retry decides WHEN to call again. Most call
;; sites want both, layered.
;;
;; Usage idea:
;;   trait FlakyServiceRetry = Retry.traits.Backoff -> Result {
;;     config: { maxTries: 5, initialMs: 100, jitter: 0.2 }
;;   }

orbital BackoffRetryOrbital {
  entity RetryAttempt [runtime] {
    id        : string
    tries     : number = 0
    maxTries  : number = 5
    nextDelayMs: number = 100
  }

  type RetryExhausted = Event { tries : number, lastError : string }
  type RetrySucceeded = Event { tries : number }

  trait Backoff -> RetryAttempt [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      CALL -> pending
    }
    state pending {
      OK   -> done
        (emit RetrySucceeded { tries: "@payload.tries" })
      FAIL -> waiting
        ;; consumer schedules wakeup at nextDelayMs * 2 + jitter
    }
    state waiting {
      ELAPSE     -> pending
      MAX_TRIES  -> failed
        (emit RetryExhausted { tries: "@payload.tries", lastError: "@payload.lastError" })
    }
    state done {
      RESET -> idle
    }
    state failed {
      RESET -> idle
    }
    listens {
      OK {
        tries : number
      }
      MAX_TRIES {
        tries     : number
        lastError : string
      }
    }
    emits {
      RetrySucceeded -> external { tries : number }
      RetryExhausted -> external { tries : number, lastError : string }
    }
  }

  page "/backoff-retry" -> Backoff
}
