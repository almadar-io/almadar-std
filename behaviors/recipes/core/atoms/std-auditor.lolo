app std-auditor "0.1.0"
"std-auditor — coordinator that writes an immutable log row for every transition it sees"
;;
;; RECIPE-ONLY (proposed). Subscribes to a wildcard transition stream on its
;; host orbital and persists each frame to an append-only AuditEntry log.
;; Compliance and debugging fall out of one trait.
;;
;; Usage idea:
;;   trait AuditTap = Auditor.traits.WildcardLog -> AuditEntry {
;;     config: { sinks: ["audit_log"] }
;;   }

orbital AuditorOrbital {
  entity AuditEntry [persistent: audit_log] {
    id        : string!
    trait     : string!
    event     : string!
    actorId   : string
    payload   : string = ""
    timestamp : datetime!
  }

  type AuditEntrySaved = Event { id : string }
  type AuditEntrySaveFailed = Event { error : string, code : string }

  trait WildcardLog -> AuditEntry [lifecycle, collection] {
    initial: listening
    state listening {
      INIT -> listening
      RECORD -> listening
        (persist create AuditEntry {
           trait: "@payload.trait",
           event: "@payload.event",
           actorId: "@payload.actorId",
           payload: "@payload.payload",
           timestamp: "@payload.timestamp"
         })
    }
    listens {
      RECORD {
        trait : string!
        event : string!
        actorId : string
        payload : string
        timestamp : datetime!
      }
    }
    emits {
      AuditEntrySaved      -> external { id : string }
      AuditEntrySaveFailed -> external { error : string, code : string }
    }
  }

  page "/auditor" -> WildcardLog
}
