app std-lock "0.1.0"
"std-lock — wrapper that serializes writes via a per-entity lease"
;;
;; RECIPE-ONLY (proposed). Two siblings on different tabs both clicking SAVE
;; on the same entity: the lock serializes them so only one persists. Lease
;; has a TTL to avoid deadlocks on a crashed holder.
;;
;; Usage idea:
;;   trait CartLock = Lock.traits.EntityMutex -> CartItem {
;;     config: { ttlMs: 30000, keyPath: "@row.id" }
;;   }

orbital LockOrbital {
  entity Lease [persistent: locks] {
    id          : string!
    keyValue    : string!
    ownerId     : string
    acquiredAt  : datetime
    expiresAt   : datetime
  }

  type LockAcquired = Event { keyValue : string, ownerId : string }
  type LockDenied   = Event { keyValue : string, ownerId : string }
  type LockReleased = Event { keyValue : string }

  trait EntityMutex -> Lease [lifecycle, collection] {
    initial: unlocked
    state unlocked {
      INIT    -> unlocked
      ACQUIRE -> locked
        (emit LockAcquired { keyValue: "@payload.keyValue", ownerId: "@payload.ownerId" })
    }
    state locked {
      ACQUIRE -> locked
        (emit LockDenied { keyValue: "@payload.keyValue", ownerId: "@payload.ownerId" })
      RELEASE -> unlocked
        (emit LockReleased { keyValue: "@payload.keyValue" })
      EXPIRE  -> unlocked
        (emit LockReleased { keyValue: "@payload.keyValue" })
    }
    listens {
      ACQUIRE {
        keyValue : string!
        ownerId  : string
      }
      RELEASE {
        keyValue : string!
      }
      EXPIRE {
        keyValue : string!
      }
    }
    emits {
      LockAcquired -> external { keyValue : string, ownerId : string }
      LockDenied   -> external { keyValue : string, ownerId : string }
      LockReleased -> external { keyValue : string }
    }
  }

  page "/lock" -> EntityMutex
}
