app std-flip-card "1.0.0"
"std-flip-card as a Function"

orbital FlashcardOrbital {
  entity Flashcard [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    question : string = ""
    answer : string = ""
  }

  type FlashcardLoaded     = Event Flashcard                  "Fired when Flashcard finishes loading"
  type FlashcardLoadFailed = Event { message : string } "Fired when Flashcard fails to load"
  trait FlashcardFlipCard -> Flashcard [interaction, instance] {
    initial: front
    state front {
      INIT -> front
        (fetch Flashcard { emit: { success: "FlashcardLoaded", failure: "FlashcardLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "rotate-3d" }, { type: "typography", content: "Flashcards Flashcards", variant: "h2" }] }, { type: "divider" }, { type: "flip-card", front: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: "@entity.name" }, { type: "typography", variant: "caption", color: "muted", content: "Tap to reveal answer" }] }, back: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "lightbulb" }, { type: "typography", variant: "h3", content: "@entity.description" }, { type: "badge", label: "Answer" }] }, flipped: false }, { type: "button", label: "Flip", action: "FLIP", variant: "primary", icon: "rotate-3d" }] })
      FlashcardLoaded -> front
        (set @entity.name @payload.name)
        (set @entity.description @payload.description)
      FLIP -> back
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "rotate-3d" }, { type: "typography", content: "Flashcards Flashcards", variant: "h2" }] }, { type: "divider" }, { type: "flip-card", front: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: "@entity.name" }, { type: "typography", variant: "caption", color: "muted", content: "Tap to reveal answer" }] }, back: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "lightbulb" }, { type: "typography", variant: "h3", content: "@entity.description" }, { type: "badge", label: "Answer" }] }, flipped: true }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Flip Back", action: "FLIP_BACK", variant: "ghost", icon: "rotate-3d" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] })
    }
    state back {
      FLIP_BACK -> front
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "rotate-3d" }, { type: "typography", content: "Flashcards Flashcards", variant: "h2" }] }, { type: "divider" }, { type: "flip-card", front: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: "@entity.name" }, { type: "typography", variant: "caption", color: "muted", content: "Tap to reveal answer" }] }, back: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "lightbulb" }, { type: "typography", variant: "h3", content: "@entity.description" }, { type: "badge", label: "Answer" }] }, flipped: false }, { type: "button", label: "Flip", action: "FLIP", variant: "primary", icon: "rotate-3d" }] })
      NEXT -> front
        (fetch Flashcard { emit: { success: "FlashcardLoaded", failure: "FlashcardLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "rotate-3d" }, { type: "typography", content: "Flashcards Flashcards", variant: "h2" }] }, { type: "divider" }, { type: "flip-card", front: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: "@entity.name" }, { type: "typography", variant: "caption", color: "muted", content: "Tap to reveal answer" }] }, back: { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "lightbulb" }, { type: "typography", variant: "h3", content: "@entity.description" }, { type: "badge", label: "Answer" }] }, flipped: false }, { type: "button", label: "Flip", action: "FLIP", variant: "primary", icon: "rotate-3d" }] })
    }
    emits {
      FlashcardLoaded
      FlashcardLoadFailed
    }
    listens {
      FlashcardLoadFailed { message : string }
    }
  }
  page "/flashcards/flashcards" as FlashcardFlipCardPage -> FlashcardFlipCard
}