app std-theme "1.0.0"
"std-theme as a Function"

orbital ThemePreferenceOrbital {
  entity ThemePreference [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    mode : string = "light"
    colorScheme : string = "default"
  }

  type ThemePreferenceLoaded     = Event ThemePreference                  "Fired when ThemePreference finishes loading"
  type ThemePreferenceLoadFailed = Event { message : string } "Fired when ThemePreference fails to load"
  trait ThemePreferenceTheme -> ThemePreference [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch ThemePreference { emit: { success: "ThemePreferenceLoaded", failure: "ThemePreferenceLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "palette" }, { type: "typography", content: "Theme Settings", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Quick Toggle" }, { type: "typography", variant: "caption", color: "muted", content: "Switch between light and dark mode" }, { type: "theme-toggle" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Theme Palette" }, { type: "typography", variant: "caption", color: "muted", content: "Choose from available color schemes" }, { type: "simple-grid", cols: 3, children: [{ type: "button", label: "Almadar", action: "SELECT", variant: "secondary" }, { type: "button", label: "Ocean", action: "SELECT", variant: "secondary" }, { type: "button", label: "Forest", action: "SELECT", variant: "secondary" }] }] }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current mode:" }, { type: "badge", label: "@entity.mode" }, { type: "typography", variant: "caption", content: "Scheme:" }, { type: "badge", label: "@entity.colorScheme" }] }] })
      ThemePreferenceLoaded -> idle
        (set @entity.mode @payload.mode)
        (set @entity.colorScheme @payload.colorScheme)
      TOGGLE -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "palette" }, { type: "typography", content: "Theme Settings", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Quick Toggle" }, { type: "typography", variant: "caption", color: "muted", content: "Switch between light and dark mode" }, { type: "theme-toggle" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Theme Palette" }, { type: "typography", variant: "caption", color: "muted", content: "Choose from available color schemes" }, { type: "simple-grid", cols: 3, children: [{ type: "button", label: "Almadar", action: "SELECT", variant: "secondary" }, { type: "button", label: "Ocean", action: "SELECT", variant: "secondary" }, { type: "button", label: "Forest", action: "SELECT", variant: "secondary" }] }] }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current mode:" }, { type: "badge", label: "@entity.mode" }, { type: "typography", variant: "caption", content: "Scheme:" }, { type: "badge", label: "@entity.colorScheme" }] }] })
      SELECT -> idle
        (set @entity.colorScheme @payload.theme)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "palette" }, { type: "typography", content: "Theme Settings", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Quick Toggle" }, { type: "typography", variant: "caption", color: "muted", content: "Switch between light and dark mode" }, { type: "theme-toggle" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Theme Palette" }, { type: "typography", variant: "caption", color: "muted", content: "Choose from available color schemes" }, { type: "simple-grid", cols: 3, children: [{ type: "button", label: "Almadar", action: "SELECT", variant: "secondary" }, { type: "button", label: "Ocean", action: "SELECT", variant: "secondary" }, { type: "button", label: "Forest", action: "SELECT", variant: "secondary" }] }] }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current mode:" }, { type: "badge", label: "@entity.mode" }, { type: "typography", variant: "caption", content: "Scheme:" }, { type: "badge", label: "@entity.colorScheme" }] }] })
    }
    listens {
      SELECT { theme : string! }
          ThemePreferenceLoadFailed { message : string }
    }
    emits {
      ThemePreferenceLoaded
      ThemePreferenceLoadFailed
    }
  }
  page "/themepreferences/theme" as ThemePreferenceThemePage -> ThemePreferenceTheme
}