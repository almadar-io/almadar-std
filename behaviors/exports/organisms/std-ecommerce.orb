                                      "type": "button",
                                      "label": "Next",
                                      "event": "NEXT",
                                      "variant": "primary",
                                      "icon": "arrow-right"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "listens": [
            {
              "event": "CHECKOUT_STARTED",
              "triggers": "INIT",
              "scope": "external"
            }
          ],
          "emits": [
            {
              "event": "ORDER_PLACED",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ],
              "scope": "external"
            }
          ]
        }
      ],
