                                  "type": "typography",
                                  "content": "Customer Info",
                                  "variant": "h3"
                                },
                                {
                                  "type": "form-section",
                                  "entity": "Checkout",
                                  "mode": "create",
                                  "submitEvent": "NEXT",
                                  "cancelEvent": "INIT",
