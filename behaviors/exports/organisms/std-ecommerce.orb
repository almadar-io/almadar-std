                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "type": "progress-dots",
                                  "count": 3,
                                  "currentIndex": 0
                                },
                                {
                                  "type": "wizard-progress",
                                  "steps": [
