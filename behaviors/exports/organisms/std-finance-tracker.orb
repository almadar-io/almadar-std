                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "FinanceReport",
                    "@payload.data"
                  ],
                  [
                    "fetch",
                    "FinanceReport"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SAVE"
                  ],
                  [
                    "notify",
                    "FinanceReport created successfully"
                  ]
                ]
              }
