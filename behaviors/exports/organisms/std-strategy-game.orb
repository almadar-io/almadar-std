          },
          {
            "name": "defense",
            "type": "number",
            "default": 0
          },
          {
            "name": "explored",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "TerritoryNavigation",
          "linkedEntity": "Territory",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "exploring",
                "isInitial": true
              },
              {
                "name": "transitioning"
              },
              {
                "name": "entered"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
