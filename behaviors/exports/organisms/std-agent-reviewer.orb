          "linkedEntity": "ReviewRag",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "SEARCH"
              },
              {
                "key": "CLEAR",
                "name": "CLEAR"
              },
              {
                "key": "VIEW",
                "name": "VIEW",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "SEARCHED",
                "name": "SEARCHED",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ReviewRag"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
