            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StudentProgress"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "scaled-diagram",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "breadcrumb",
                              "items": [
                                {
                                  "label": "Home",
                                  "href": "/"
                                },
                                {
                                  "label": "Progress"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "space-between",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "trending-up",
                                      "size": "lg"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Progress",
                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "type": "button",
                                  "label": "Refresh",
                                  "event": "REFRESH",
                                  "variant": "secondary",
                                  "icon": "refresh-cw"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "box",
                              "padding": "md",
                              "children": [
                                {
                                  "type": "simple-grid",
                                  "columns": 3,
                                  "children": [
                                    {
                                      "type": "stat-display",
                                      "label": "TotalLessons",
                                      "value": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "totalLessons"
                                      ]
                                    },
                                    {
                                      "type": "stat-display",
                                      "label": "CompletedLessons",
                                      "value": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "completedLessons"
