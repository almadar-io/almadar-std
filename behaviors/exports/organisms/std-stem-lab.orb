{
  "name": "STEM Lab",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "ExperimentOrbital",
      "entity": {
        "name": "Experiment",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "hypothesis",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0
          },
          {
            "name": "completed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "ExperimentSimulatorGame",
          "linkedEntity": "Experiment",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Experiment"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-menu",
                      "title": "Experiment Simulator",
                      "menuItems": [
                        {
                          "label": "Start",
                          "event": "START",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "simulator-board",
                      "entity": "Experiment",
                      "completeEvent": "COMPLETE"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE",
                "effects": []
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-over-screen",
                      "title": "Well Done!",
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "event": "RESTART",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-menu",
                      "title": "Experiment Simulator",
                      "menuItems": [
                        {
                          "label": "Start",
                          "event": "START",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "SimulatorPage",
          "path": "/simulator",
          "isInitial": true,
          "traits": [
            {
              "ref": "ExperimentSimulatorGame"
            }
          ]
        }
      ]
    },
