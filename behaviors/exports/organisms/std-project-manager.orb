      "pages": [
        {
          "name": "TasksPage",
          "path": "/tasks",
          "isInitial": true,
          "traits": [
            {
              "ref": "TaskBrowse"
            },
            {
              "ref": "TaskCreate"
            },
            {
              "ref": "TaskEdit"
            },
            {
              "ref": "TaskView"
            }
          ]
        }
      ]
    },
    {
      "name": "SprintOrbital",
      "entity": {
        "name": "Sprint",
        "persistence": "persistent",
        "collection": "sprints",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "endDate",
            "type": "string",
            "required": true
          },
          {
            "name": "goal",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "planning"
          },
          {
            "name": "taskCount",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "SprintBrowse",
          "linkedEntity": "Sprint",
          "category": "interaction",
          "listens": [
            {
              "event": "SPRINT_CREATED",
              "triggers": "SPRINT_CREATED"
            },
            {
              "event": "SPRINT_UPDATED",
              "triggers": "SPRINT_UPDATED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "deleting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "CREATE"
              },
              {
                "key": "VIEW",
                "name": "VIEW",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "EDIT",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "DELETE",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SPRINT_CREATED",
                "name": "SPRINT_CREATED",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SPRINT_UPDATED",
                "name": "SPRINT_UPDATED",
                "payload": [
                  {
