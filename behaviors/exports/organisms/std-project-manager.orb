{
  "name": "ProjectManagerApp",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "TaskOrbital",
      "entity": {
        "name": "Task",
        "persistence": "persistent",
        "collection": "tasks",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "assignee",
            "type": "string"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "in-progress",
              "review",
              "done"
            ]
          },
          {
            "name": "storyPoints",
            "type": "number",
            "default": 0
          },
          {
            "name": "dueDate",
            "type": "date"
          }
        ]
      },
      "traits": [
        {
          "name": "TaskBrowse",
          "linkedEntity": "Task",
          "category": "interaction",
          "listens": [
            {
              "event": "TASK_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "TASK_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "TASK_DELETED",
              "triggers": "INIT"
            },
            {
              "event": "ASSIGN_TASK",
              "triggers": "INIT",
              "scope": "external"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "CREATE"
              },
              {
                "key": "VIEW",
                "name": "VIEW",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "EDIT",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "DELETE",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "ProjectManagerApp",
                      "navItems": [
                        {
                          "label": "Tasks",
                          "href": "/tasks",
                          "icon": "check-square"
                        },
                        {
                          "label": "Sprints",
                          "href": "/sprints",
                          "icon": "zap"
                        },
                        {
                          "label": "Burndown",
                          "href": "/burndown",
                          "icon": "layout-list"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "space-between",
                              "align": "center",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-square",
                                      "size": "lg"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Tasks",
                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "button",
                                      "label": "Create Task",
                                      "event": "CREATE",
                                      "variant": "primary",
                                      "icon": "plus"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "simple-grid",
                              "columns": 1,
                              "children": [
                                {
                                  "type": "stat-display",
                                  "label": "Total Tasks",
                                  "value": [
                                    "array/len",
                                    "@entity"
                                  ],
                                  "icon": "check-square"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "data-grid",
                              "entity": "Task",
                              "emptyIcon": "inbox",
                              "emptyTitle": "No tasks yet",
                              "emptyDescription": "Create tasks to plan your sprint.",
                              "itemActions": [
                                {
                                  "label": "View",
                                  "event": "VIEW",
                                  "variant": "ghost",
                                  "size": "sm"
                                },
                                {
                                  "label": "Edit",
                                  "event": "EDIT",
                                  "variant": "ghost",
                                  "size": "sm"
                                },
                                {
                                  "label": "Delete",
                                  "event": "DELETE",
                                  "variant": "danger",
                                  "size": "sm"
                                }
                              ],
                              "columns": [
                                {
                                  "name": "title",
                                  "variant": "h3",
                                  "icon": "check-square"
                                },
                                {
                                  "name": "priority",
                                  "variant": "badge"
                                },
                                {
                                  "name": "status",
                                  "variant": "badge"
                                },
                                {
                                  "name": "assignee",
                                  "variant": "body"
                                },
                                {
                                  "name": "storyPoints",
                                  "label": "Points",
                                  "variant": "body",
                                  "format": "number"
                                },
                                {
                                  "name": "dueDate",
                                  "label": "Due",
                                  "variant": "caption",
                                  "format": "date"
                                }
                              ],
                              "cols": 2,
                              "gap": "md"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "TaskCreate",
          "linkedEntity": "Task",
          "category": "interaction",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "TASK_CREATED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Open"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Create Task",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Task",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "title",
                            "description",
                            "assignee",
                            "priority",
                            "status",
                            "storyPoints",
                            "dueDate"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "TASK_CREATED"
                  ],
                  [
                    "notify",
                    "Task created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "TaskEdit",
          "linkedEntity": "Task",
          "category": "interaction",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "TASK_UPDATED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Open",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Edit Task",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Task",
                          "mode": "edit",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "title",
                            "description",
                            "assignee",
                            "priority",
                            "status",
                            "storyPoints",
                            "dueDate"
                          ],
                          "entityId": "@entity.id"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "TASK_UPDATED"
                  ],
                  [
                    "notify",
                    "Task updated successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "TaskView",
          "linkedEntity": "Task",
          "category": "interaction",
          "emits": [
            {
              "event": "SAVE"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "Open",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.title"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Title"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.title"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Description"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.description"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Assignee"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.assignee"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Priority"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.priority"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Status"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Story Points"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.storyPoints"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Due Date"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.dueDate"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "primary",
                              "icon": "edit"
                            },
                            {
                              "type": "button",
                              "label": "Close",
                              "event": "CLOSE",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "TaskDelete",
          "linkedEntity": "Task",
          "category": "interaction",
          "emits": [
            {
              "event": "CONFIRM_DELETE"
            },
            {
              "event": "TASK_DELETED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Request Confirmation",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Delete Task",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "danger",
                          "message": "This action cannot be undone."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "emit",
                    "TASK_DELETED"
                  ],
                  [
                    "notify",
                    "Task deleted successfully"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "TasksPage",
          "path": "/tasks",
          "isInitial": true,
          "traits": [
            {
              "ref": "TaskBrowse"
            },
            {
              "ref": "TaskCreate"
            },
            {
              "ref": "TaskEdit"
            },
            {
              "ref": "TaskView"
            },
            {
              "ref": "TaskDelete"
            }
          ]
        }
      ]
    },
