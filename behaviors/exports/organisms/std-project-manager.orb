                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Request Confirmation",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Sprint"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
