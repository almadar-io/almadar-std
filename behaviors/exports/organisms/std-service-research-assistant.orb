            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CALL_API",
                "name": "Call API"
              },
              {
                "key": "API_RESPONSE",
                "name": "API Response",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "statusCode",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
