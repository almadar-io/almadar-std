            "required": true
          },
          {
            "name": "endpoint",
            "type": "string"
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "requestBody",
            "type": "string"
          },
          {
            "name": "responseData",
            "type": "string"
          },
          {
            "name": "statusCode",
            "type": "number",
            "default": 0
          },
          {
            "name": "callStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "KnowledgeQueryCustomBearer",
          "linkedEntity": "KnowledgeQuery",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
