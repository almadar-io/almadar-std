                                  ]
                                }
                              ]
                            },
                            {
                              "type": "form-section",
                              "title": "Compose Message",
                              "children": [
                                {
                                  "type": "textarea",
                                  "label": "Message",
                                  "bind": "@entity.content",
                                  "placeholder": "Type your message..."
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "button",
                                      "label": "Send",
                                      "event": "SEND",
                                      "variant": "primary",
                                      "icon": "send"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.role",
                    "user"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "persist",
                    "create",
                    "Assistant",
                    {
                      "role": "user",
                      "content": "@payload.content",
                      "timestamp": "@now",
                      "status": "sent"
                    }
                  ],
                  [
                    "emit",
                    "SEND_MESSAGE"
                  ],
                  [
                    "fetch",
                    "Assistant"
                  ],
                  [
