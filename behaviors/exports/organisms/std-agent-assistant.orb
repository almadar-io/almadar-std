            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Token Count"
              },
              {
                "key": "COMPACT",
                "name": "Compact Context"
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
