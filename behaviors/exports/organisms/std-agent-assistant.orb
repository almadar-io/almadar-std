                              "content": "Listening...",
                              "variant": "h3"
                            },
                            {
                              "type": "spinner",
                              "size": "lg"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "responding",
                "to": "listening",
                "event": "SEND",
