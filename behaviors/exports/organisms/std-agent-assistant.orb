                              "align": "center",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "message-circle",
                                      "size": "lg"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Assistant Thread",
                                      "variant": "h2"
