        {
          "name": "AssistantContextAgent",
          "linkedEntity": "AssistantContext",
          "category": "interaction",
          "emits": [
            {
              "event": "SHOW",
              "scope": "internal",
              "payload": [
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                }
              ]
            },
            {
              "event": "UPDATE",
              "scope": "internal",
              "payload": [
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
