                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Commit"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.commit"
