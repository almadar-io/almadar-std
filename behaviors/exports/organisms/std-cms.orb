                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.name"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Slug"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.slug"
                            }
