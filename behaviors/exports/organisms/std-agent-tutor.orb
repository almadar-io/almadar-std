                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "help-circle",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Quiz",
                                  "variant": "h2"
