{
  "name": "SearchResultOrbital",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "linkedEntity": "SearchResult",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payload": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Search SearchResults",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "search-input",
                          "placeholder": "Search...",
                          "event": "SEARCH"
                        },
                        {
                          "type": "empty-state",
                          "icon": "search",
                          "title": "Search to find results",
                          "description": "Type a query to search across searchresults."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    "@payload.query"
                  ],
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": [
                                    "concat",
                                    "Results for \"",
                                    "@entity.query",
                                    "\""
                                  ],
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Clear",
                              "event": "CLEAR",
                              "variant": "ghost",
                              "icon": "x"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "SearchResult",
                          "emptyIcon": "search",
                          "emptyTitle": "No results found",
                          "emptyDescription": "Try a different search term.",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    "@payload.query"
                  ],
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": [
                                    "concat",
                                    "Results for \"",
                                    "@entity.query",
                                    "\""
                                  ],
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Clear",
                              "event": "CLEAR",
                              "variant": "ghost",
                              "icon": "x"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "SearchResult",
                          "emptyIcon": "search",
                          "emptyTitle": "No results found",
                          "emptyDescription": "Try a different search term.",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    ""
                  ],
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Search SearchResults",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "search-input",
                          "placeholder": "Search...",
                          "event": "SEARCH"
                        },
                        {
                          "type": "empty-state",
                          "icon": "search",
                          "title": "Search to find results",
                          "description": "Type a query to search across searchresults."
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ],
  "description": "Search behavior parameterized for any domain. Provides a search input that filters entity data by query string. The state machine structure is fixed. The caller controls data and presentation."
}