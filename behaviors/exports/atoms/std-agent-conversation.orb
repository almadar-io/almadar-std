                                  "type": "button",
                                  "label": "Send",
                                  "event": "SEND",
                                  "variant": "primary",
                                  "icon": "send"
                                }
                              ]
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "type": "string"
                            },
                            {
                              "name": "description",
                              "type": "string"
                            },
                            {
                              "name": "status",
                              "type": "string",
                              "values": [
                                "active",
                                "inactive",
                                "pending"
