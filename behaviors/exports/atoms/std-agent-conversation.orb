                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "xs",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.role"
                                    },
                                    {
                                      "type": "badge",
                                      "label": "@item.status",
                                      "variant": "outline"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted",
                                      "content": "@item.timestamp"
                                    }
                                  ]
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@item.content"
                                }
