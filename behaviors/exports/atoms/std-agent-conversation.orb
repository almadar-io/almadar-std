                            },
                            {
                              "name": "createdAt",
                              "type": "string"
                            },
                            {
                              "name": "messages",
                              "type": "array"
                            },
                            {
                              "name": "turnCount",
                              "type": "number"
                            },
                            {
                              "name": "lastMessage",
                              "type": "string"
                            },
                            {
                              "name": "tokenCount",
                              "type": "number"
                            },
                            {
                              "name": "role",
                              "type": "string"
                            },
                            {
                              "name": "content",
                              "type": "string"
                            },
                            {
                              "name": "timestamp",
                              "type": "string"
                            },
                            {
                              "name": "toolName",
                              "type": "string"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
