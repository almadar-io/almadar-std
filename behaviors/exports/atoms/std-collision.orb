            "default": 0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0
          },
          {
            "name": "collisionStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "targetId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CollidableBodyCollision",
          "linkedEntity": "CollidableBody",
