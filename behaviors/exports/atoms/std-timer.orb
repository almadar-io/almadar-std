                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "clock",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Timer",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "animated-counter",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "remaining"
                              ],
                              "suffix": "s",
                              "duration": 500
                            },
                            {
                              "type": "stat-display",
                              "label": "Time Remaining",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "remaining"
                              ],
                              "max": 60
