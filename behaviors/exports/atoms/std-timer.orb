{
  "name": "TimerSessionOrbital",
  "orbitals": [
    {
      "name": "TimerSessionOrbital",
      "entity": {
        "name": "TimerSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "remaining",
            "type": "number",
            "default": 0
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "TimerSessionTimer",
          "linkedEntity": "TimerSession",
          "category": "interaction",
          "ticks": [
            {
              "name": "countdown",
              "interval": 1000,
              "appliesTo": [
                "running"
              ],
              "guard": [
                ">",
                "@entity.remaining",
                0
              ],
              "effects": [
                [
                  "set",
                  "@entity.remaining",
                  [
                    "-",
                    "@entity.remaining",
                    1
                  ]
                ]
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "paused"
              },
              {
                "name": "expired"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "EXPIRE",
                "name": "Expire"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
