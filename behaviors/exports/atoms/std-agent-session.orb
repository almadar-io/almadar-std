                            {
                              "type": "typography",
                              "content": "AgentSession",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "label": "Active",
                              "variant": "success"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Session ID:"
