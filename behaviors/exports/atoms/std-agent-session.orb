                          "children": [
                            {
                              "type": "icon",
                              "name": "git-branch",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentSession (Forked)",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "label": "Forked",
