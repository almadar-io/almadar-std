                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Name"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "name"
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "justify": "space-between",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Description"
                                    },
