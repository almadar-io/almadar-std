                                      "type": "typography",
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "status"
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "justify": "space-between",
                                  "children": [
