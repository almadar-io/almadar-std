                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@item.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
