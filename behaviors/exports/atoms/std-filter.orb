{
  "name": "ItemOrbital",
  "orbitals": [
    {
      "name": "ItemOrbital",
      "entity": {
        "name": "Item",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ItemFilter",
          "linkedEntity": "Item",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "filtered"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER",
                "name": "Filter"
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Item"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "badge",
                              "label": "All"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "badge",
                          "label": "No filter fields defined"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "Item",
                          "emptyIcon": "inbox",
                          "emptyTitle": "No items yet",
                          "emptyDescription": "Add items to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "filtered",
                "event": "FILTER",
                "effects": [
                  [
                    "fetch",
                    "Item"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "Filtered",
                                  "variant": "primary"
                                },
                                {
                                  "type": "button",
                                  "label": "Clear",
                                  "event": "CLEAR_FILTERS",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "Item",
                          "emptyIcon": "inbox",
                          "emptyTitle": "No items yet",
                          "emptyDescription": "Add items to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "filtered",
                "to": "filtered",
                "event": "FILTER",
                "effects": [
                  [
                    "fetch",
                    "Item"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "Filtered",
                                  "variant": "primary"
                                },
                                {
                                  "type": "button",
                                  "label": "Clear",
                                  "event": "CLEAR_FILTERS",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "Item",
                          "emptyIcon": "inbox",
                          "emptyTitle": "No items yet",
                          "emptyDescription": "Add items to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "filtered",
                "to": "browsing",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "fetch",
                    "Item"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "badge",
                              "label": "All"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "badge",
                          "label": "No filter fields defined"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "Item",
                          "emptyIcon": "inbox",
                          "emptyTitle": "No items yet",
                          "emptyDescription": "Add items to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.name"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ItemFilterPage",
          "path": "/items",
          "traits": [
            {
              "ref": "ItemFilter"
            }
          ]
        }
      ]
    }
  ],
  "description": "Filter atom. Shows filter buttons per field with predefined values. Clicking a filter value transitions to filtered state. Clear resets."
}