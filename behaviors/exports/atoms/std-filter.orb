                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "FilterTargets",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "Filtered",
                                  "variant": "primary"
                                },
                                {
                                  "type": "button",
                                  "label": "Clear All",
                                  "event": "CLEAR_FILTERS",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "filter",
