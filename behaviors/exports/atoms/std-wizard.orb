{
  "name": "WizardEntryOrbital",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "WizardEntryOrbital",
      "entity": {
        "name": "WizardEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WizardEntryWizard",
          "linkedEntity": "WizardEntry",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "step1",
                "isInitial": true
              },
              {
                "name": "step2"
              },
              {
                "name": "step3"
              },
              {
                "name": "review"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NEXT",
                "name": "Next Step",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PREV",
                "name": "Previous Step"
              },
              {
                "key": "COMPLETE",
                "name": "Complete Wizard",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart Wizard"
              }
            ],
            "transitions": [
