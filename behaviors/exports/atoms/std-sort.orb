                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Clear sort",
                              "event": "INIT",
                              "variant": "ghost",
                              "icon": "x"
                            }
