{
  "name": "AgentContextWindowOrbital",
  "orbitals": [
    {
      "name": "AgentContextWindowOrbital",
      "entity": {
        "name": "AgentContextWindow",
        "persistence": "persistent",
        "collection": "agentcontextwindows",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 200000
          },
          {
            "name": "usage",
            "type": "number",
            "default": 0
          },
          {
            "name": "lastCompactedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentContextWindowManager",
          "linkedEntity": "AgentContextWindow",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
              },
              {
                "name": "approaching_limit"
              },
              {
                "name": "at_limit"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Token Count"
              },
              {
                "key": "COMPACT",
                "name": "Compact Context"
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentContextWindow"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layers",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.tokenCount",
                              "variant": "default"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "/"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxTokens",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "button",
                          "label": "Update Tokens",
                          "event": "UPDATE_TOKENS",
                          "variant": "secondary",
                          "icon": "refresh-cw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "normal",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "<",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  0.85
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layers",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.tokenCount",
                              "variant": "default"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "/"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxTokens",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "button",
                          "label": "Update Tokens",
                          "event": "UPDATE_TOKENS",
                          "variant": "secondary",
                          "icon": "refresh-cw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow (Warning)",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "warning",
                          "message": "Context window approaching limit."
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Compact",
                              "event": "COMPACT",
                              "variant": "primary",
                              "icon": "minimize-2"
                            },
                            {
                              "type": "button",
                              "label": "Update",
                              "event": "UPDATE_TOKENS",
                              "variant": "secondary",
                              "icon": "refresh-cw"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "at_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  ">=",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  1
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    100
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-octagon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow (At Limit)",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "Context window at capacity. Compaction required."
                        },
                        {
                          "type": "progress-bar",
                          "value": 100,
                          "max": 100
                        },
                        {
                          "type": "button",
                          "label": "Compact Now",
                          "event": "COMPACT",
                          "variant": "primary",
                          "icon": "minimize-2"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layers",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.tokenCount",
                              "variant": "default"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "/"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxTokens",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "button",
                          "label": "Update Tokens",
                          "event": "UPDATE_TOKENS",
                          "variant": "secondary",
                          "icon": "refresh-cw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "at_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layers",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.tokenCount",
                              "variant": "default"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "/"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxTokens",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "button",
                          "label": "Update Tokens",
                          "event": "UPDATE_TOKENS",
                          "variant": "secondary",
                          "icon": "refresh-cw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentContextWindow (Warning)",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "warning",
                          "message": "Context window approaching limit."
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.usage",
                          "max": 100
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Compact",
                              "event": "COMPACT",
                              "variant": "primary",
                              "icon": "minimize-2"
                            },
                            {
                              "type": "button",
                              "label": "Update",
                              "event": "UPDATE_TOKENS",
                              "variant": "secondary",
                              "icon": "refresh-cw"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "AgentContextWindowPage",
          "path": "/agentcontextwindows",
          "traits": [
            {
              "ref": "AgentContextWindowManager"
            }
          ]
        }
      ]
    }
  ],
  "description": "Context window management atom for agent token tracking. Monitors token usage and auto-compacts when approaching limits. States: normal -> approaching_limit -> at_limit with guards on thresholds."
}