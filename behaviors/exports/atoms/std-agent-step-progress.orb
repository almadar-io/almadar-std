{
  "name": "AgentStepProgressOrbital",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "AgentStepProgressOrbital",
      "entity": {
        "name": "AgentStepProgress",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4
          }
        ]
      },
      "traits": [
        {
          "name": "AgentStepProgressProgress",
          "linkedEntity": "AgentStepProgress",
          "category": "interaction",
          "emits": [
            {
              "event": "ADVANCE",
              "scope": "external",
              "payload": [
                {
                  "name": "step",
                  "type": "number"
                }
              ]
            },
            {
              "event": "COMPLETE",
              "scope": "external",
              "payload": [
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ]
            },
            {
              "event": "FAIL",
              "scope": "external",
              "payload": [
                {
                  "name": "step",
                  "type": "number"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ADVANCE",
              "triggers": "ADVANCE",
              "scope": "external"
            },
            {
              "event": "COMPLETE",
              "triggers": "COMPLETE",
              "scope": "external"
            },
            {
              "event": "FAIL",
              "triggers": "FAIL",
              "scope": "external"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "in_progress"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start Pipeline"
              },
              {
                "key": "ADVANCE",
                "name": "Advance Step"
              },
              {
                "key": "COMPLETE",
                "name": "Complete Pipeline"
              },
              {
                "key": "FAIL",
                "name": "Pipeline Failed"
              },
              {
                "key": "RESET",
                "name": "Reset Pipeline"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentStepProgress"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-ordered",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "AgentStepProgress",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "label": "Idle",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
