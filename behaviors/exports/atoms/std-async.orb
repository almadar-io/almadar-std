{
  "name": "ItemOrbital",
  "orbitals": [
    {
      "name": "ItemOrbital",
      "entity": {
        "name": "Item",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ItemAsync",
          "linkedEntity": "Item",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "success"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LOADED",
                "name": "Loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Item"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "loader",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Loading...",
                          "variant": "h3"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "success",
                "event": "LOADED",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Item",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Operation completed successfully.",
                          "variant": "h3"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Reset",
                              "event": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  [
                    "notify",
                    "Item created successfully"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-circle",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "An error occurred. Please try again.",
                          "variant": "h3"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Retry",
                              "event": "RETRY",
                              "variant": "primary",
                              "icon": "refresh-cw"
                            },
                            {
                              "type": "button",
                              "label": "Reset",
                              "event": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "success",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "loader",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Loading...",
                          "variant": "h3"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ItemPage",
          "path": "/items",
          "traits": [
            {
              "ref": "ItemAsync"
            }
          ]
        }
      ]
    }
  ]
}