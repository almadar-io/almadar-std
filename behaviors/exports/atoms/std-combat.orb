{
  "name": "std-combat",
  "version": "1.0.0",
  "description": "Attack cycle behavior: ready, attacking, cooldown, defeated. Pure function: params in, OrbitalDefinition out.",
  "orbitals": [
    {
      "name": "CombatantOrbital",
      "entity": {
        "name": "Combatant",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "hp",
            "type": "number",
            "default": 100
          },
          {
            "name": "attack",
            "type": "number",
            "default": 10
          },
          {
            "name": "defense",
            "type": "number",
            "default": 5
          }
        ]
      },
      "traits": [
        {
          "name": "CombatantCombat",
          "linkedEntity": "Combatant",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "attacking"
              },
              {
                "name": "cooldown"
              },
              {
                "name": "defeated"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ATTACK",
                "name": "Attack",
                "payload": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HIT",
                "name": "Hit",
                "payload": [
                  {
                    "name": "damage",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COOLDOWN_END",
                "name": "Cooldown End"
              },
              {
                "key": "DEFEAT",
                "name": "Defeat"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Combatant"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Attack",
                          "event": "ATTACK",
                          "variant": "primary",
                          "icon": "swords"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "attacking",
                "event": "ATTACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Cooldown End",
                          "event": "HIT",
                          "variant": "secondary",
                          "icon": "clock"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "cooldown",
                "event": "HIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "badge",
                          "label": "Cooling down..."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "ready",
                "event": "COOLDOWN_END",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Attack",
                          "event": "ATTACK",
                          "variant": "primary",
                          "icon": "swords"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-over-screen",
                          "title": "Defeated",
                          "variant": "defeat"
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "event": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-over-screen",
                          "title": "Defeated",
                          "variant": "defeat"
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "event": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "defeated",
                "to": "ready",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Attack",
                          "event": "ATTACK",
                          "variant": "primary",
                          "icon": "swords"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "CombatantPage",
          "path": "/combatants",
          "traits": [
            {
              "ref": "CombatantCombat"
            }
          ]
        }
      ]
    }
  ]
}
