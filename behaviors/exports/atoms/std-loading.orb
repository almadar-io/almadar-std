{
  "name": "ItemOrbital",
  "orbitals": [
    {
      "name": "ItemOrbital",
      "entity": {
        "name": "Item",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "loadingStatus",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "ItemLoading",
          "linkedEntity": "Item",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "success"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start Loading"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "FAILED",
                "name": "Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "play-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "Ready to load item. Click Start to begin."
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "loading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Loading...",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "progress-bar",
                          "value": 50
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Please wait while the operation completes."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "success",
                "event": "LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "success"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Success",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "Operation completed successfully."
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "event": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Error",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "Something went wrong."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Retry",
                              "event": "START",
                              "variant": "primary",
                              "icon": "rotate-ccw"
                            },
                            {
                              "type": "button",
                              "label": "Reset",
                              "event": "RESET",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "loading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Loading...",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "progress-bar",
                          "value": 50
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Please wait while the operation completes."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "play-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "Ready to load item. Click Start to begin."
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "success",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.loadingStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "play-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Item",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "Ready to load item. Click Start to begin."
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ItemLoadingPage",
          "path": "/items/loading",
          "traits": [
            {
              "ref": "ItemLoading"
            }
          ]
        }
      ]
    }
  ],
  "description": "Loading behavior parameterized for any domain. Provides a multi-state loading lifecycle: idle, loading, success, error. Tracks async operation status with appropriate UI for each state."
}