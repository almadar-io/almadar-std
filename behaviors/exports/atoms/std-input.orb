{
  "name": "FormFieldOrbital",
  "orbitals": [
    {
      "name": "FormFieldOrbital",
      "entity": {
        "name": "FormField",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string",
            "default": ""
          },
          {
            "name": "inputStatus",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "FormFieldInput",
          "linkedEntity": "FormField",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "focused"
              },
              {
                "name": "validating"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FOCUS",
                "name": "Focus"
              },
              {
                "key": "BLUR",
                "name": "Blur"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "payload": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VALIDATE",
                "name": "Validate"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "text-cursor-input",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "FormField",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "FormField"
                            },
                            {
                              "type": "input",
                              "placeholder": "Enter formfield...",
                              "event": "CHANGE"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "color": "muted",
                              "content": "@entity.value"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "focused",
                "event": "FOCUS",
                "effects": [
                  [
                    "set",
                    "@entity.inputStatus",
                    "focused"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "text-cursor-input",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "FormField",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
