                            }
                          ]
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "value"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
