                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "FormField"
                            },
                            {
                              "type": "input",
                              "placeholder": "Enter formfield...",
                              "event": "CHANGE"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "color": "muted",
                              "content": "@entity.value"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
