{
  "name": "FormEntryOrbital",
  "orbitals": [
    {
      "name": "FormEntryOrbital",
      "entity": {
        "name": "FormEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "age",
            "type": "number",
            "default": 0
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": false
          },
          {
            "name": "birthDate",
            "type": "date",
            "default": ""
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "categoryId",
            "type": "relation",
            "default": "",
            "relation": {
              "entity": "FormEntry",
              "cardinality": "many-to-one"
            }
          }
        ]
      },
      "traits": [
        {
          "name": "FormEntryFormAdvanced",
          "linkedEntity": "FormEntry",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "editing",
                "isInitial": true
              },
              {
                "name": "submitted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "editing",
                "to": "editing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "include": [
                        "categoryId"
                      ]
                    }
                  ],
                  [
                    "fetch",
                    "FormEntry"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "FormEntry Form",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "FormEntry",
                          "mode": "create",
                          "submitEvent": "SUBMIT",
                          "cancelEvent": "INIT",
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "type": "enum",
                              "values": [
                                "active",
                                "inactive",
                                "pending"
                              ]
                            },
                            {
                              "name": "createdAt",
                              "label": "CreatedAt"
                            },
                            {
                              "name": "notes",
                              "label": "Notes",
                              "type": "textarea"
                            },
                            {
                              "name": "age",
                              "label": "Age",
                              "type": "number"
                            },
                            {
                              "name": "isActive",
                              "label": "IsActive",
                              "type": "boolean"
                            },
                            {
                              "name": "birthDate",
                              "label": "BirthDate",
                              "type": "date"
                            },
                            {
                              "name": "priority",
                              "label": "Priority",
                              "type": "enum",
                              "values": [
                                "low",
                                "medium",
                                "high",
                                "critical"
                              ]
                            },
                            {
                              "name": "categoryId",
                              "label": "CategoryId",
                              "type": "relation",
                              "relation": {
                                "entity": "FormEntry",
                                "cardinality": "many-to-one"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "submitted",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
