{
  "name": "ListItemOrbital",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "ListItemOrbital",
      "entity": {
        "name": "ListItem",
        "persistence": "persistent",
        "collection": "listitems",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ListItemBrowse",
          "linkedEntity": "ListItem",
          "category": "interaction",
          "listens": [
            {
              "event": "LIST_ITEM_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "LIST_ITEM_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "LIST_ITEM_DELETED",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "CREATE"
              },
              {
                "key": "VIEW",
                "name": "VIEW",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "EDIT",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "DELETE",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ListItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "list",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "ListItems",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "button",
                                  "label": "Create ListItem",
                                  "event": "CREATE",
                                  "variant": "primary",
                                  "icon": "plus"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "ListItem",
                          "emptyIcon": "inbox",
                          "emptyTitle": "No listitems yet",
                          "emptyDescription": "Create your first listitem to get started.",
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "variant": "ghost",
                              "size": "sm"
                            },
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "ghost",
                              "size": "sm"
                            },
                            {
                              "label": "Delete",
                              "event": "DELETE",
                              "variant": "danger",
                              "size": "sm"
                            }
                          ],
                          "columns": [
                            {
                              "name": "name",
                              "label": "Name",
                              "variant": "h4",
                              "icon": "list"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "variant": "badge",
                              "colorMap": {
                                "active": "success",
                                "completed": "success",
                                "done": "success",
                                "pending": "warning",
                                "draft": "warning",
                                "scheduled": "warning",
                                "inactive": "neutral",
                                "archived": "neutral",
                                "disabled": "neutral",
                                "error": "destructive",
                                "cancelled": "destructive",
                                "failed": "destructive"
                              }
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "caption"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "ListItemCreate",
          "linkedEntity": "ListItem",
          "category": "interaction",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "LIST_ITEM_CREATED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Open"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ListItem"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "ListItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Create ListItem",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "ListItem",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ListItem",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "LIST_ITEM_CREATED"
                  ],
                  [
                    "notify",
                    "ListItem created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "ListItemEdit",
          "linkedEntity": "ListItem",
          "category": "interaction",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "LIST_ITEM_UPDATED"
            }
