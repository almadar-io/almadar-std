                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Listening for task outcomes...",
                                  "variant": "body"
                                },
                                {
                                  "type": "typography",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Outcome",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.outcome",
                                  "variant": "body"
                                },
                                {
                                  "type": "typography",
                                  "content": "Impact Analysis",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.impact",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
