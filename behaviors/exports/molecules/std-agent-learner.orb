                    "AgentLearner updated successfully"
                  ]
                ]
              }
            ]
          },
          "listens": []
        }
      ],
      "pages": [
        {
          "name": "AgentLearnerPage",
          "path": "/agentlearners",
          "traits": [
            {
              "ref": "AgentLearnerLearner"
            },
            {
              "ref": "LearnerRecordsBrowse"
            },
            {
              "ref": "LearnerMemoryLifecycle"
            },
            {
