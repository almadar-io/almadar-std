                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Listening for task outcomes...",
                                  "variant": "body"
                                },
                                {
                                  "type": "typography",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ]
                        },
                        {
