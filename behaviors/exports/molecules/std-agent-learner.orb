                          "description": "Click Open to view details in a modal overlay."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentLearner",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SWITCHED"
                  ],
                  [
                    "ref",
                    "AgentLearner"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "repeat",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Switch Provider",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Open",
                              "event": "SWITCH",
                              "variant": "primary",
                              "icon": "repeat"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "description": "Click Open to view details in a modal overlay."
                        }
                      ]
                    }
                  ],
                  [
