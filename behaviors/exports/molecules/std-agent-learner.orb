                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Outcome",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
