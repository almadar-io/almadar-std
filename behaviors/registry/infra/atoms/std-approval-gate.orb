{
  "name": "std-approval-gate",
  "version": "1.0.1",
  "description": "std-approval-gate — generic approval gate / approver workflow. Use when a user voices that an action must be reviewed, approved, signed off, or authorized by a privileged role before it proceeds (admin approval, supervisor sign-off, manager approval, gatekeeper review, editor approval, senior editor approval, reviewer approval, publishing approval, draft approval, content review, submit drafts then editors review and approve or reject, needs approval before going live, requires sign-off before publish). Persists ApprovalRequest rows + surfaces them in a review queue with Approve / Deny / Reject actions, optionally requiring a written rejection reason or feedback comment. On approval emits ApprovalGranted; on denial emits ApprovalDenied. Compose onto any orbital whose action you want to gate: the target orbital emits an external event, an ApprovalRequest row is created, and downstream effects wait on ApprovalGranted. Differs from std-mod-queue, which is content-moderation-specific.",
  "orbitals": [
    {
      "name": "ApprovalGateOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approval_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "gatedEvent",
            "type": "string",
            "default": "",
            "description": "The event that triggered the approval request.",
            "synonyms": "trigger, event, source"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "denied",
              "escalated"
            ],
            "description": "Current state of the approval process.",
            "synonyms": "approval status, state, condition"
          },
          {
            "name": "reviewer",
            "type": "string",
            "default": "",
            "description": "The user or system responsible for reviewing the request.",
            "synonyms": "assignee, owner, approver, responsible party"
          },
          {
            "name": "requestedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when the approval request was initiated.",
            "synonyms": "creation time, request date, submission time"
          },
          {
            "name": "decidedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when a decision was made on the request.",
            "synonyms": "decision time, resolved at, completed at"
          },
          {
            "name": "escalatedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when the request was escalated.",
            "synonyms": "escalation time, escalation timestamp, escalated time"
          },
          {
            "name": "notes",
            "type": "string",
            "default": "",
            "description": "Free-form text providing additional context or details.",
            "synonyms": "comments, remarks, explanation, details"
          },
          {
            "name": "payload",
            "type": "object",
            "default": {},
            "description": "The held data of the gated action, replayed by the downstream listener when the request is granted.",
            "synonyms": "request data, held payload, pending data, gated data"
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalGateReview",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "reviewer",
              "status"
            ]
          },
          "category": "interaction",
          "capabilities": [
            "approval"
          ],
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "APPROVE",
              "description": "Signals that an approval request has been approved.",
              "synonyms": "accept, authorize, confirm, pass",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "gatedEvent",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "reviewer",
                      "type": "string"
                    },
                    {
                      "name": "requestedAt",
                      "type": "number"
                    },
                    {
                      "name": "decidedAt",
                      "type": "number"
                    },
                    {
                      "name": "escalatedAt",
                      "type": "number"
                    },
                    {
                      "name": "notes",
                      "type": "string"
                    },
                    {
                      "name": "payload",
                      "type": "object"
                    }
                  ]
                }
              ]
            },
            {
              "event": "DENY",
              "description": "Signals that an approval request has been denied.",
              "synonyms": "reject, decline",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "gatedEvent",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "reviewer",
                      "type": "string"
                    },
                    {
                      "name": "requestedAt",
                      "type": "number"
                    },
                    {
                      "name": "decidedAt",
                      "type": "number"
                    },
                    {
                      "name": "escalatedAt",
                      "type": "number"
                    },
                    {
                      "name": "notes",
                      "type": "string"
                    },
                    {
                      "name": "payload",
                      "type": "object"
                    }
                  ]
                }
              ]
            },
            {
              "event": "CLOSE",
              "description": "Dismisses the review queue overlay.",
              "synonyms": "dismiss, hide, cancel, done",
              "tier": "essential"
            },
            {
              "event": "ApprovalGranted",
              "description": "Signals that an approval process has been successfully completed; carries the held payload for the downstream listener to replay.",
              "synonyms": "approved, authorized, confirmed, validated",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                },
                {
                  "name": "payload",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ApprovalDenied",
              "description": "Indicates an approval request has been denied.",
              "synonyms": "rejected, declined",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoaded",
              "description": "Indicates an approval request has been successfully loaded.",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "description": "Indicates failure to load an approval request.",
              "synonyms": "load error, failed load, request failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewed",
              "description": "Signals that an approval request has been reviewed.",
              "synonyms": "reviewed, processed, examined",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "gatedEvent",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "reviewer",
                      "type": "string"
                    },
                    {
                      "name": "requestedAt",
                      "type": "number"
                    },
                    {
                      "name": "decidedAt",
                      "type": "number"
                    },
                    {
                      "name": "escalatedAt",
                      "type": "number"
                    },
                    {
                      "name": "notes",
                      "type": "string"
                    },
                    {
                      "name": "payload",
                      "type": "object"
                    }
                  ]
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewFailed",
              "description": "Indicates a failure to load or process an approval request for review.",
              "synonyms": "load error, failed review, processing failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "reviewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "description": "Indicates an approval request has been successfully loaded.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "description": "Indicates failure to load an approval request.",
                "synonyms": "load error, failed load, request failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open",
                "description": "Summons the review queue (host nav/affordance requests it).",
                "synonyms": "open, show, review, view queue, open approvals",
                "tier": "essential"
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "description": "Dismisses the review queue overlay.",
                "synonyms": "dismiss, hide, cancel, done",
                "tier": "essential"
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "description": "Signals that an approval request has been approved.",
                "synonyms": "accept, authorize, confirm, pass",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "DENY",
                "name": "Deny",
                "description": "Signals that an approval request has been denied.",
                "synonyms": "reject, decline",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewed",
                "name": "ApprovalRequest reviewed",
                "description": "Signals that an approval request has been reviewed.",
                "synonyms": "reviewed, processed, examined",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewFailed",
                "name": "ApprovalRequest review failed",
                "description": "Indicates a failure to load or process an approval request for review.",
                "synonyms": "load error, failed review, processing failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApprovalGranted",
                "name": "Approval granted",
                "description": "Signals that an approval process has been successfully completed; carries the held payload for the downstream listener to replay.",
                "synonyms": "approved, authorized, confirmed, validated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  },
                  {
                    "name": "payload",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ApprovalDenied",
                "name": "Approval denied",
                "description": "Indicates an approval request has been denied.",
                "synonyms": "rejected, declined",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ApprovalRequestLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ApprovalRequestLoadFailed"
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "OPEN",
                "guard": "@config.enabled",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading approval queue…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "reviewing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "justify": "between",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "variant": "h3",
                                  "type": "typography",
                                  "content": "Approval queue"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "label": "Close",
                              "variant": "ghost",
                              "type": "button",
                              "icon": "x",
                              "action": "CLOSE"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "APPROVE",
                              "label": "Approve",
                              "variant": "primary",
                              "icon": "check"
                            },
                            {
                              "variant": "danger",
                              "event": "DENY",
                              "label": "Deny",
                              "icon": "x"
                            }
                          ],
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "badge",
                              "name": "gatedEvent",
                              "label": "Action"
                            },
                            {
                              "label": "Requested",
                              "name": "requestedAt",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ],
                          "look": "@config.tableLook",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "approved"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalGranted",
                    {
                      "payload": "@payload.row.payload",
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "DENY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "denied"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalDenied",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "loading",
                "event": "ApprovalRequestReviewed",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "ApprovalRequestReviewFailed",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "OPEN",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "escalationHours": {
              "type": "number",
              "default": 0.0,
              "label": "Escalation hours",
              "description": "Hours a request can sit pending before escalating. v1.0 declarative only; per-row escalation needs loop-with-emit primitive (gap).",
              "tier": "policy"
            },
            "enabled": {
              "type": "boolean",
              "default": false,
              "label": "Require approval",
              "description": "Require sign-off before a record is finalized. Off by default.",
              "synonyms": "enable, turn on, enforce, require, activate, apply, switch on, approval, needs approval, sign-off, signed off, review before, gatekeeper, editor approval, publishing approval, draft approval, content review, requires approval, manager approval, supervisor approval, admin approval, before going live",
              "tier": "policy"
            },
            "reviewSlot": {
              "type": "slot",
              "default": "modal",
              "label": "Review slot",
              "description": "UI slot the review queue renders into. Defaults to the modal overlay so the queue never seizes the host's main content; summoned via OPEN, cleared via CLOSE.",
              "tier": "internal"
            },
            "escalationRoles": {
              "type": "[string]",
              "default": [],
              "label": "Escalation roles",
              "description": "Roles notified when a request escalates (compose sibling std-notify-on-event).",
              "tier": "policy",
              "items": {
                "type": "string"
              }
            },
            "threshold": {
              "type": "number",
              "default": 0.0,
              "label": "Auto-approve threshold",
              "description": "Below this value, requests should be auto-approved. v1.0 declarative only; wiring lands in v1.1 (gap).",
              "tier": "policy"
            },
            "approverRoles": {
              "type": "[string]",
              "default": [],
              "label": "Approver roles",
              "description": "Roles eligible to approve. The host application enforces role-gating on the page.",
              "tier": "policy",
              "items": {
                "type": "string"
              }
            },
            "autoApproveBelowThreshold": {
              "type": "boolean",
              "default": true,
              "label": "Auto-approve below threshold",
              "description": "Skip the review queue when the gated event's value is below the threshold. v1.0 declarative only.",
              "tier": "policy"
            },
            "valueField": {
              "type": "string",
              "default": "",
              "label": "Value field",
              "description": "Payload field name to compare against threshold (e.g. 'amount' on a RefundRequested event). v1.0 declarative only.",
              "tier": "internal"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalGateReviewPage",
          "path": "/approvals/queue",
          "traits": [
            {
              "ref": "ApprovalGateReview"
            }
          ]
        }
      ]
    }
  ]
}
