                {
                  "name": "row",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "gatedEvent",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "reviewer",
                      "type": "string"
                    },
                    {
                      "name": "requestedAt",
                      "type": "number"
                    },
                    {
                      "name": "decidedAt",
