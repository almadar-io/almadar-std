                    }
                  ],
                  "type": "object"
                }
              ],
              "synonyms": "reviewed, processed, examined",
              "tier": "internal"
            },
            {
              "description": "Indicates a failure to load or process an approval request for review.",
              "event": "ApprovalRequestReviewFailed",
              "eventId": "evt_01KXG04EZ0HX0YV7MH4PXFQCM0",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "synonyms": "load error, failed review, processing failure",
              "tier": "internal"
            }
          ],
          "entityContract": {
            "provides": [
              "reviewer",
              "status"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "ApprovalRequest": "ent_01KXG04EYQFWN6TM97JNWHHSF4"
          },
          "id": "trt_01KXG04EYQYT20ZWYKAD2EJAHM",
          "linkedEntity": "ApprovalRequest",
          "linkedEntityId": "ent_01KXG04EYQFWN6TM97JNWHHSF4",
          "listens": [
            {
              "event": "CLOSE",
              "eventId": "evt_01KXG04EZ0MS01J775W2VPESMJ",
              "source": {
                "kind": "trait",
                "trait": "CloseButton",
                "traitId": "trt_01KY21K6QCRRFVK1BRAD774HXP"
              },
              "triggers": "CLOSE",
              "triggersId": "evt_01KXG04EZ0MS01J775W2VPESMJ"
            }
          ],
          "name": "ApprovalGateReview",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04EYQTZ9K6DFDEBK0EPXQ",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates an approval request has been successfully loaded.",
                "id": "evt_01KXG04EZ0BNTY7ZWPWS7Z1AFH",
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal"
              },
              {
                "description": "Indicates failure to load an approval request.",
                "id": "evt_01KXG04EZ0ZFHMHXT4NN21VK6N",
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "load error, failed load, request failure",
                "tier": "internal"
              },
              {
                "description": "Summons the review queue (host nav/affordance requests it).",
                "id": "evt_01KXG04EZ05HP9JSWYNV5XV2QW",
                "key": "OPEN",
                "name": "Open",
                "synonyms": "open, show, review, view queue, open approvals",
                "tier": "domain"
              },
              {
                "description": "Dismisses the review queue overlay.",
                "id": "evt_01KXG04EZ0MS01J775W2VPESMJ",
                "key": "CLOSE",
                "name": "Close",
                "synonyms": "dismiss, hide, cancel, done",
                "tier": "domain"
              },
              {
                "description": "Signals that an approval request has been approved.",
                "id": "evt_01KXG04EZ0H0D5WC8FJKBRGBQE",
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ],
                "synonyms": "accept, authorize, confirm, pass",
                "tier": "domain"
              },
              {
                "description": "Signals that an approval request has been denied.",
                "id": "evt_01KXG04EZ0ZFMGKFBB34B7PMEE",
                "key": "DENY",
                "name": "Deny",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ],
                "synonyms": "reject, decline",
                "tier": "domain"
              },
              {
                "description": "Signals that an approval request has been reviewed.",
                "id": "evt_01KXG04EZ0XXBA89NVB97J1NAM",
                "key": "ApprovalRequestReviewed",
                "name": "ApprovalRequest reviewed",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ],
                "synonyms": "reviewed, processed, examined",
                "tier": "internal"
              },
              {
                "description": "Indicates a failure to load or process an approval request for review.",
                "id": "evt_01KXG04EZ0HX0YV7MH4PXFQCM0",
                "key": "ApprovalRequestReviewFailed",
                "name": "ApprovalRequest review failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "load error, failed review, processing failure",
                "tier": "internal"
              },
              {
                "description": "Signals that an approval process has been successfully completed; carries the held payload for the downstream listener to replay.",
                "id": "evt_01KXG04EZ09QDH2K4ZAGX0JZDQ",
                "key": "ApprovalGranted",
                "name": "Approval granted",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  },
                  {
                    "name": "payload",
                    "type": "object"
                  }
                ],
                "synonyms": "approved, authorized, confirmed, validated",
                "tier": "domain"
              },
              {
                "description": "Indicates an approval request has been denied.",
                "id": "evt_01KXG04EZ0JF1Y4KS5KF3R9X8X",
                "key": "ApprovalDenied",
                "name": "Approval denied",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ],
                "synonyms": "rejected, declined",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "loading"
              },
              {
                "name": "reviewing"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04EYQTZ9K6DFDEBK0EPXQ",
                "from": "idle",
                "to": "idle"
              },
              {
                "event": "ApprovalRequestLoaded",
                "eventId": "evt_01KXG04EZ0BNTY7ZWPWS7Z1AFH",
                "from": "idle",
                "to": "idle"
              },
              {
                "event": "ApprovalRequestLoadFailed",
                "eventId": "evt_01KXG04EZ0ZFHMHXT4NN21VK6N",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "align": "center",
                      "children": [
                        "@trait.LoadingSpinner",
                        "@trait.LoadingText"
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "OPEN",
                "eventId": "evt_01KXG04EZ05HP9JSWYNV5XV2QW",
                "from": "idle",
                "guard": "@config.enabled",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.ShieldCheckIcon",
                                "@trait.ApprovalQueueTitle"
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            "@trait.CloseButton"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        "@trait.ApprovalDivider",
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Action",
                              "name": "gatedEvent",
                              "variant": "badge"
                            },
                            {
                              "label": "Requested",
                              "name": "requestedAt",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            }
                          ],
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "APPROVE",
                              "icon": "check",
                              "label": "Approve",
                              "variant": "primary"
                            },
                            {
                              "event": "DENY",
                              "icon": "x",
                              "label": "Deny",
                              "variant": "danger"
                            }
                          ],
                          "look": "@config.tableLook",
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "ApprovalRequestLoaded",
                "eventId": "evt_01KXG04EZ0BNTY7ZWPWS7Z1AFH",
                "from": "loading",
                "to": "reviewing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "children": [
                        "@trait.ErrorAlert"
                      ],
                      "type": "stack"
                    }
                  ]
                ],
                "event": "ApprovalRequestLoadFailed",
                "eventId": "evt_01KXG04EZ0ZFHMHXT4NN21VK6N",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04EZ0MS01J775W2VPESMJ",
                "from": "loading",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "approved"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalGranted",
                    {
                      "payload": "@payload.row.payload",
                      "requestId": "@payload.id"
                    }
                  ]
                ],
                "event": "APPROVE",
                "eventId": "evt_01KXG04EZ0H0D5WC8FJKBRGBQE",
                "from": "reviewing",
                "to": "reviewing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "denied"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalDenied",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ],
                "event": "DENY",
                "eventId": "evt_01KXG04EZ0ZFMGKFBB34B7PMEE",
                "from": "reviewing",
                "to": "reviewing"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ]
                ],
                "event": "ApprovalRequestReviewed",
                "eventId": "evt_01KXG04EZ0XXBA89NVB97J1NAM",
                "from": "reviewing",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "children": [
                        "@trait.ErrorAlert"
                      ],
                      "type": "stack"
                    }
                  ]
                ],
                "event": "ApprovalRequestReviewFailed",
                "eventId": "evt_01KXG04EZ0HX0YV7MH4PXFQCM0",
                "from": "reviewing",
                "to": "reviewing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04EZ0MS01J775W2VPESMJ",
                "from": "reviewing",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    {
                      "children": [
                        "@trait.ErrorSpinner"
                      ],
                      "type": "stack"
                    }
                  ]
                ],
                "event": "OPEN",
                "eventId": "evt_01KXG04EZ05HP9JSWYNV5XV2QW",
                "from": "error",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "@config.reviewSlot",
                    null
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04EZ0MS01J775W2VPESMJ",
                "from": "error",
                "to": "idle"
              }
            ]
          },
          "traitEmbedIds": {
            "ApprovalDivider": "trt_01KY21K6QC0P4NS69R6ATZPC18",
            "ApprovalQueueTitle": "trt_01KY21K6QCC5BFGZKJF8Q6HYMM",
            "CloseButton": "trt_01KY21K6QCRRFVK1BRAD774HXP",
            "ErrorAlert": "trt_01KY21K6QC64ZQCX4WH65V7SKA",
            "ErrorSpinner": "trt_01KY21K6QCCHHN53WV6VF6NKE4",
            "LoadingSpinner": "trt_01KY21K6QC4NB1EVQJ94HWPN3B",
            "LoadingText": "trt_01KY21K6QCNEAQZG0D3H1NG7MV",
            "ShieldCheckIcon": "trt_01KY21K6QC1BZWD7V4FGS1KPB5"
          }
        }
      ],
      "uses": [
        {
          "as": "Spinner",
          "from": "std/behaviors/ui-spinner"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Button",
          "from": "std/behaviors/ui-button"
        },
        {
          "as": "Divider",
          "from": "std/behaviors/ui-divider"
        },
        {
          "as": "Alert",
          "from": "std/behaviors/ui-alert"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.1"
}