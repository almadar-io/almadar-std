    "schemaVersion": 1
  },
  "name": "std-game-clock",
  "orbitals": [
    {
      "entity": {
        "collection": "game_clock_states",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "Total milliseconds elapsed since the clock started.",
            "name": "elapsedMs",
            "synonyms": "elapsed, time, ms, total time",
            "type": "number"
          },
          {
            "default": true,
            "description": "Whether the clock is currently ticking.",
            "name": "running",
            "synonyms": "active, playing, started",
            "type": "boolean"
          }
        ],
        "id": "ent_01KXG04FBQ6K4G6J1ZNCTFVWT1",
        "name": "GameClockRecord",
        "persistence": "persistent"
      },
      "id": "orb_01KXG04FBQV351H0MNMBN12VGE",
      "name": "GameClockOrbital",
      "pages": [
        {
          "id": "pag_01KXG04FBQFSGC9ATDY5421Q4E",
          "name": "GameClockPage",
          "path": "/game/clock",
          "traits": [
            {
              "ref": "GameClock",
              "refId": "trt_01KXG04FBQ4HX99S2FX3YJY6KK"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "game-core",
          "config": {
            "autoStart": {
              "default": true,
              "description": "When true the clock begins ticking immediately on INIT without waiting for a RESUME event.",
              "label": "Auto-start clock",
              "synonyms": "start on init, auto-run, begin immediately",
              "tier": "domain",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Fires every clock tick while running; consumers use elapsedMs to drive animations and game logic.",
              "event": "GameClockTicked",
              "eventId": "evt_01KXG04FBQG781YHPNG7KH4ET5",
              "payloadSchema": [
                {
                  "name": "elapsedMs",
                  "type": "number"
                }
              ],
              "scope": "external",
              "synonyms": "clock-tick, time-advance, tick, frame, elapsed",
              "tier": "domain"
            }
          ],
          "id": "trt_01KXG04FBQ4HX99S2FX3YJY6KK",
          "linkedEntity": "GameClockRecord",
          "linkedEntityId": "ent_01KXG04FBQ6K4G6J1ZNCTFVWT1",
          "name": "GameClock",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "description": "Fires every clock tick while running; consumers use elapsedMs to drive animations and game logic.",
                "key": "GameClockTicked",
                "name": "Game clock ticked",
                "payloadSchema": [
                  {
                    "name": "elapsedMs",
                    "type": "number"
                  }
                ],
                "synonyms": "clock-tick, time-advance, tick, frame, elapsed",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "running"
              },
              {
                "name": "paused"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    false
                  ]
                ],
                "event": "PAUSE",
                "from": "running",
                "to": "paused"
              },
              {
                "event": "RESUME",
                "from": "running",
                "to": "running"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    true
                  ]
                ],
                "event": "RESUME",
                "from": "paused",
                "to": "running"
              },
              {
                "event": "PAUSE",
                "from": "paused",
                "to": "paused"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.elapsedMs",
                  [
                    "+",
                    "@entity.elapsedMs",
                    100.0
                  ]
                ],
                [
                  "emit",
                  "GameClockTicked",
                  {
                    "elapsedMs": "@entity.elapsedMs"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.running",
                true
              ],
              "interval": 100.0,
              "name": "clockTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}