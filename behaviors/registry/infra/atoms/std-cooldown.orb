{
  "description": "std-cooldown — ability/action cooldown primitive; START begins the countdown, READY fires when it expires.",
  "ledger": {
    "entries": {
      "ent_01KXG04F8TJJ9ASFRDGES09D5K": {
        "bakedName": "CooldownRecord",
        "curName": "CooldownRecord",
        "id": "ent_01KXG04F8TJJ9ASFRDGES09D5K",
