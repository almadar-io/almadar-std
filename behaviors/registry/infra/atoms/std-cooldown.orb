      "evt_01KXG04F8THBCYE2J41N8B1K8T": {
        "bakedName": "CooldownReady",
        "curName": "CooldownReady",
        "id": "evt_01KXG04F8THBCYE2J41N8B1K8T",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04F8TPNA9G1FTCT8Z1308",
        "renames": []
      },
      "evt_01KXG04F8TJP6CWK74T4E3DJV6": {
        "bakedName": "START",
        "curName": "START",
        "id": "evt_01KXG04F8TJP6CWK74T4E3DJV6",
