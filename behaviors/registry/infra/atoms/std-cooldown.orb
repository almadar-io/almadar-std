      "orb_01KXG04F8TJADJKTFF6VASJDX1": {
        "bakedName": "CooldownOrbital",
        "curName": "CooldownOrbital",
        "id": "orb_01KXG04F8TJADJKTFF6VASJDX1",
        "kind": "orbital",
        "owner": "workspace",
        "renames": []
      },
      "pag_01KXG04F8TMZ620DXEPBMX5J6Z": {
        "bakedName": "CooldownPage",
        "curName": "CooldownPage",
        "id": "pag_01KXG04F8TMZ620DXEPBMX5J6Z",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG04F8TPNA9G1FTCT8Z1308": {
        "bakedName": "Cooldown",
        "curName": "Cooldown",
        "id": "trt_01KXG04F8TPNA9G1FTCT8Z1308",
        "kind": "trait",
        "owner": "workspace",
        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "std-cooldown",
  "orbitals": [
    {
      "entity": {
        "collection": "cooldown_states",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "Milliseconds remaining on the active cooldown.",
            "name": "remainingMs",
            "synonyms": "time left, remaining, countdown, ms left",
            "type": "number"
          },
          {
            "default": false,
            "description": "Whether the cooldown is currently counting down.",
            "name": "active",
            "synonyms": "cooling, on cooldown, busy, in progress",
            "type": "boolean"
          }
        ],
        "id": "ent_01KXG04F8TJJ9ASFRDGES09D5K",
        "name": "CooldownRecord",
        "persistence": "persistent"
      },
      "id": "orb_01KXG04F8TJADJKTFF6VASJDX1",
      "name": "CooldownOrbital",
      "pages": [
        {
          "id": "pag_01KXG04F8TMZ620DXEPBMX5J6Z",
          "name": "CooldownPage",
          "path": "/game/cooldown",
          "traits": [
            {
              "ref": "Cooldown",
              "refId": "trt_01KXG04F8TPNA9G1FTCT8Z1308"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "game-core",
          "config": {
            "defaultDurationMs": {
              "default": 3000.0,
              "description": "Milliseconds the cooldown runs when START is received without an explicit durationMs payload.",
              "label": "Default cooldown duration (ms)",
              "synonyms": "cooldown time, duration, delay, recharge time, wait time",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Fired when the cooldown expires; wire to re-enable the ability or action.",
              "event": "CooldownReady",
              "eventId": "evt_01KXG04F8THBCYE2J41N8B1K8T",
              "payloadSchema": [
                {
                  "name": "entityId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "ready, cooldown-done, available, recharged, action-ready",
              "tier": "domain"
            },
            {
              "description": "Internal: fired by the expiry tick to drive the cooling→ready transition.",
              "event": "EXPIRE",
              "eventId": "evt_01KXG04F8TSB50DP423HFSWJNM"
            }
          ],
          "id": "trt_01KXG04F8TPNA9G1FTCT8Z1308",
          "linkedEntity": "CooldownRecord",
          "linkedEntityId": "ent_01KXG04F8TJJ9ASFRDGES09D5K",
          "name": "Cooldown",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04F8TJP6CWK74T4E3DJV6",
                "key": "START",
                "name": "Start",
                "payloadSchema": [
                  {
                    "name": "durationMs",
                    "type": "number"
                  }
                ]
              },
              {
                "description": "Internal: fired by the expiry tick to drive the cooling→ready transition.",
                "id": "evt_01KXG04F8TSB50DP423HFSWJNM",
                "key": "EXPIRE",
                "name": "Expire"
              },
              {
                "description": "Fired when the cooldown expires; wire to re-enable the ability or action.",
                "id": "evt_01KXG04F8THBCYE2J41N8B1K8T",
                "key": "CooldownReady",
                "name": "Cooldown ready",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string"
                  }
                ],
                "synonyms": "ready, cooldown-done, available, recharged, action-ready",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "ready"
              },
              {
                "name": "cooling"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.remainingMs",
                    "@config.defaultDurationMs"
                  ],
                  [
                    "set",
                    "@entity.active",
                    true
                  ]
                ],
                "event": "START",
                "eventId": "evt_01KXG04F8TJP6CWK74T4E3DJV6",
                "from": "ready",
                "to": "cooling"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.active",
                    false
                  ],
                  [
                    "set",
                    "@entity.remainingMs",
                    0.0
                  ],
                  [
                    "emit",
                    "CooldownReady",
                    {
                      "entityId": "@entity.id"
                    }
                  ]
                ],
                "event": "EXPIRE",
                "eventId": "evt_01KXG04F8TSB50DP423HFSWJNM",
                "from": "cooling",
                "to": "ready"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.remainingMs",
                  [
                    "math/max",
                    0.0,
                    [
                      "-",
                      "@entity.remainingMs",
                      100.0
                    ]
                  ]
                ]
              ],
              "guard": [
                "==",
                "@entity.active",
                true
              ],
              "interval": 100.0,
              "name": "cooldownTick"
            },
            {
              "effects": [
                [
                  "emit",
                  "EXPIRE",
                  {}
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.active",
                  true
                ],
                [
                  "<=",
                  "@entity.remainingMs",
                  0.0
                ]
              ],
              "interval": 100.0,
              "name": "expiryCheck"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}