          },
          {
            "description": "A human-readable explanation of the entry's content.",
            "name": "description",
            "synonyms": "explanation, details, notes, summary",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the entry.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
