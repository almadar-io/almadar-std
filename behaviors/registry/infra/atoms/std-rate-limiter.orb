{
  "description": "std-rate-limiter as a Function",
  "name": "std-rate-limiter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A user-defined identifier for the rate limiting bucket.",
            "name": "name",
            "synonyms": "label, identifier, alias",
            "type": "string"
          },
          {
            "description": "A textual explanation of the rate bucket's purpose.",
            "name": "description",
            "synonyms": "explanation, details, notes",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the rate limiting bucket.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The current value of a counter.",
            "name": "count",
            "synonyms": "value, amount, total",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The duration of the rate limiting window, in seconds.",
            "name": "window",
            "synonyms": "duration, time, interval, period",
            "type": "number"
          },
          {
            "default": "open",
            "description": "Current operational state of the rate limiter.",
            "name": "limiterStatus",
            "synonyms": "state, condition, mode",
            "type": "string"
          }
        ],
        "name": "RateBucket",
        "persistence": "runtime"
      },
      "name": "RateBucketOrbital",
      "pages": [
        {
          "name": "RateBucketRateLimiterPage",
          "path": "/ratebuckets/rate-limiter",
          "traits": [
            {
              "ref": "RateBucketRateLimiter"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "name": {
              "default": "shield",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Icon_Shield",
          "ref": "Icon.traits.IconRender"
        },
        {
          "config": {
            "content": {
              "default": "RateBucket Rate Limiter",
              "type": "unknown"
            },
            "variant": {
              "default": "h2",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Typography_RateBucketRateLimiter",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "label": {
              "default": "Open",
              "type": "unknown"
            },
            "pulse": {
              "default": false,
              "type": "unknown"
            },
            "status": {
              "default": "online",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "StatusDot_Open",
          "ref": "StatusDot.traits.StatusDotRender"
        },
        {
          "config": {
            "label": {
              "default": "Throttled",
              "type": "unknown"
            },
            "pulse": {
              "default": true,
              "type": "unknown"
            },
            "status": {
              "default": "critical",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "StatusDot_Throttled",
          "ref": "StatusDot.traits.StatusDotRender"
        },
        {
          "config": {
            "message": {
              "default": "Rate limit exceeded. Requests are being throttled.",
              "type": "unknown"
            },
            "variant": {
              "default": "error",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Alert_RateLimitExceeded",
          "ref": "Alert.traits.AlertRender"
        },
        {
          "config": {
            "label": {
              "default": "Requests",
              "type": "unknown"
            },
            "look": {
              "default": "@config.statLook",
              "type": "unknown"
            },
            "value": {
              "default": "@entity.count",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "StatDisplay_Requests",
          "ref": "StatDisplay.traits.StatDisplayRender"
        },
        {
          "config": {
            "label": {
              "default": "Window",
              "type": "unknown"
            },
            "look": {
              "default": "@config.statLook",
              "type": "unknown"
            },
            "value": {
              "default": "@entity.window",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "StatDisplay_Window",
          "ref": "StatDisplay.traits.StatDisplayRender"
        },
        {
          "config": {
            "max": {
              "default": 100.0,
              "type": "unknown"
            },
            "min": {
              "default": 0.0,
              "type": "unknown"
            },
            "value": {
              "default": "@entity.count",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Meter_Count",
          "ref": "Meter.traits.MeterRender"
        },
        {
          "config": {
            "max": {
              "default": 100.0,
              "type": "unknown"
            },
            "showPercentage": {
              "default": true,
              "type": "unknown"
            },
            "value": {
              "default": "@entity.count",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "ProgressBar_Count",
          "ref": "ProgressBar.traits.ProgressBarRender"
        },
        {
          "config": {
            "action": {
              "default": "REQUEST",
              "type": "unknown"
            },
            "icon": {
              "default": "send",
              "type": "unknown"
            },
            "label": {
              "default": "Request",
              "type": "unknown"
            },
            "variant": {
              "default": "primary",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Button_Request",
          "ref": "Button.traits.ButtonRender"
        },
        {
          "config": {
            "action": {
              "default": "RESET",
              "type": "unknown"
            },
            "icon": {
              "default": "rotate-ccw",
              "type": "unknown"
            },
            "label": {
              "default": "Reset",
              "type": "unknown"
            },
            "variant": {
              "default": "ghost",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Button_Reset",
          "ref": "Button.traits.ButtonRender"
        },
        {
          "config": {
            "action": {
              "default": "RESET",
              "type": "unknown"
            },
            "icon": {
              "default": "rotate-ccw",
              "type": "unknown"
            },
            "label": {
              "default": "Reset",
              "type": "unknown"
            },
            "variant": {
              "default": "primary",
              "type": "unknown"
            }
          },
          "linkedEntity": "RateBucket",
          "name": "Button_Reset_Primary",
          "ref": "Button.traits.ButtonRender"
        },
        {
          "capabilities": [
            "rate-limit"
          ],
          "category": "interaction",
          "config": {
            "burstSize": {
              "default": 10.0,
              "description": "Requests allowed to burst above the per-minute rate before steady-state throttling kicks in. Lower burst = strict/no-spikes; higher burst = forgiving/allow-spikes.",
              "label": "Burst size",
              "synonyms": "burst capacity, allowance, spike allowance, no-spike (low) vs allow-bursts (high)",
              "tier": "domain",
              "type": "number"
            },
            "enabled": {
              "default": false,
              "description": "Whether rate limiting is active for the host orbital. Off by default; turn on to throttle requests.",
              "label": "Enabled",
              "synonyms": "enable, turn on, enforce, require, activate, apply, switch on, rate limit, throttle, requests per minute, slow down, cap usage, request cap, limit traffic, prevent abuse",
              "tier": "domain",
              "type": "boolean"
            },
            "keyStrategy": {
              "default": "user",
              "description": "What identifier the per-bucket counter is keyed on: source IP, authenticated user, API key, or one global bucket.",
              "label": "Rate-limit key strategy",
              "synonyms": "limiter key, bucket key",
              "tier": "domain",
              "type": "string",
              "values": [
                "ip",
                "user",
                "api-key",
                "global"
              ]
            },
            "overrideRoles": {
              "default": [],
              "description": "Roles exempt from rate limiting (e.g. internal services, admin override). Empty = no exemptions.",
              "items": {
                "type": "string"
              },
              "label": "Override roles",
              "synonyms": "exempt roles, bypass list",
              "tier": "domain",
              "type": "[string]"
            },
            "requestsPerMinute": {
              "default": 60.0,
              "description": "Maximum number of requests allowed per minute before throttling begins.",
              "label": "Requests per minute",
              "synonyms": "rate limit, request cap, RPS, throttle threshold",
              "tier": "domain",
              "type": "number"
            },
            "statLook": {
              "default": "elevated",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "label": "Stat display look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            }
          },
          "linkedEntity": "RateBucket",
          "name": "RateBucketRateLimiter",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REQUEST",
                "name": "Request"
              },
              {
                "key": "THROTTLE",
                "name": "Throttle"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "open"
              },
              {
                "name": "throttled"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.window",
                    60.0
                  ],
                  [
                    "set",
                    "@entity.limiterStatus",
                    "open"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Open"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        "@trait.ProgressBar_Count",
                        {
                          "children": [
                            "@trait.Button_Request",
                            "@trait.Button_Reset"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "open",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Open"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        "@trait.ProgressBar_Count",
                        {
                          "children": [
                            "@trait.Button_Request",
                            "@trait.Button_Reset"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "REQUEST",
                "from": "open",
                "guard": "@config.enabled",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.limiterStatus",
                    "throttled"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Throttled"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.Alert_RateLimitExceeded",
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        {
                          "children": [
                            "@trait.Button_Reset_Primary"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "THROTTLE",
                "from": "open",
                "to": "throttled"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.limiterStatus",
                    "open"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Open"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        "@trait.ProgressBar_Count",
                        {
                          "children": [
                            "@trait.Button_Request",
                            "@trait.Button_Reset"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "open",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.limiterStatus",
                    "open"
                  ],
                  [
                    "set",
                    "@entity.count",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Open"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        "@trait.ProgressBar_Count",
                        {
                          "children": [
                            "@trait.Button_Request",
                            "@trait.Button_Reset"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "throttled",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@trait.Icon_Shield",
                                "@trait.Typography_RateBucketRateLimiter"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            "@trait.StatusDot_Throttled"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.Alert_RateLimitExceeded",
                        {
                          "children": [
                            "@trait.StatDisplay_Requests",
                            "@trait.StatDisplay_Window"
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        "@trait.Meter_Count",
                        {
                          "children": [
                            "@trait.Button_Reset_Primary"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "throttled",
                "to": "throttled"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "StatusDot",
          "from": "std/behaviors/ui-status-dot"
        },
        {
          "as": "Alert",
          "from": "std/behaviors/ui-alert"
        },
        {
          "as": "StatDisplay",
          "from": "std/behaviors/ui-stat-display"
        },
        {
          "as": "Meter",
          "from": "std/behaviors/ui-meter"
        },
        {
          "as": "ProgressBar",
          "from": "std/behaviors/ui-progress-bar"
        },
        {
          "as": "Button",
          "from": "std/behaviors/ui-button"
        }
      ]
    }
  ],
  "version": "1.0.0"
}