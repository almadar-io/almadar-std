  "name": "std-cascade-on-delete",
  "orbitals": [
    {
      "entity": {
        "collection": "cascade_logs",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "Identifier of the deleted parent the cascade is clearing dependents for.",
            "name": "parentId",
            "synonyms": "parent, source, origin",
            "type": "string"
          },
          {
            "default": "",
            "description": "Identifies the parent entity of the cascade.",
            "name": "parentEntity",
            "synonyms": "related entity, source entity, parent",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of rows deleted by the cascade.",
            "name": "rowCount",
            "synonyms": "count, size, quantity",
            "type": "number"
          },
          {
            "default": "",
            "description": "Scratch: id of the dependent row the loop is currently deleting.",
            "name": "headId",
            "synonyms": "current id, cursor",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04F628MGXSDK3NH0MDDMJ",
        "name": "CascadeLog",
        "persistence": "persistent"
      },
      "id": "orb_01KXG04F624T2ZQ419Q9VM4PJF",
      "name": "CascadeOnDeleteOrbital",
      "pages": [
        {
          "id": "pag_01KXG04F62A6GAQPJ6M3ESCR8N",
          "name": "CascadeOnDeletePage",
          "path": "/cascade-on-delete",
          "traits": [
            {
              "ref": "CascadeOnDeleteGate",
              "refId": "trt_01KXG04F62Y4JBRC82RK6P338T"
            }
          ]
        }
      ],
      "traits": [
        {
          "capabilities": [
            "cascade-delete"
          ],
          "category": "lifecycle",
          "config": {
            "dependentEntity": {
              "default": "CascadeLog",
              "description": "Entity holding rows that point at the parent (compose one cascade trait per dependent type). Defaults to the atom's own log so the standalone validates; rebind per composition.",
              "label": "Dependent entity",
              "tier": "internal",
              "type": "string"
            },
            "enabled": {
              "default": false,
              "description": "When a record is deleted, also delete the records that belong to it. Off by default.",
              "label": "Delete related records too",
              "synonyms": "enable, turn on, enforce, require, activate, apply, switch on, cascade delete, delete children, on delete cascade, cascade on delete, remove related, soft delete cascade, dependent deletes, integrity cascade",
              "tier": "infra",
              "type": "boolean"
            },
            "foreignKeyField": {
              "default": "parentId",
              "description": "Field on dependent rows that holds the parent's id.",
              "label": "Foreign-key field",
              "tier": "internal",
              "type": "string"
            },
            "parentEntity": {
              "default": "",
              "description": "Entity whose deletion triggers the cascade.",
              "label": "Parent entity",
              "tier": "internal",
              "type": "string"
            }
          },
          "emits": [
            {
              "event": "CascadeRowDeleted",
              "eventId": "evt_01KXG04F622CD962H4G66FXFD4",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "CascadeCompleted",
              "eventId": "evt_01KXG04F62GE7NR5DC9MBPV6PN",
              "payloadSchema": [
                {
                  "name": "parentId",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "DepsLoaded",
              "eventId": "evt_01KXG04F624M2CZ0FSEPAZZD39",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "CascadeStepped",
              "eventId": "evt_01KXG04F62F2J70RRB8DEF0QM6",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CascadeFailed",
              "eventId": "evt_01KXG04F62CJ2RA14CFCY7R5AD",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "id": "trt_01KXG04F62Y4JBRC82RK6P338T",
          "linkedEntity": "CascadeLog",
          "linkedEntityId": "ent_01KXG04F628MGXSDK3NH0MDDMJ",
          "name": "CascadeOnDeleteGate",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04F6281CRC439K4RVYM4T",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04F62016GZS5ER2WYSRXW",
                "key": "ParentDeleted",
                "name": "Parent deleted",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F624M2CZ0FSEPAZZD39",
                "key": "DepsLoaded",
                "name": "Deps loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F62F2J70RRB8DEF0QM6",
                "key": "CascadeStepped",
                "name": "Cascade stepped",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F62CJ2RA14CFCY7R5AD",
                "key": "CascadeFailed",
                "name": "Cascade failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F622CD962H4G66FXFD4",
                "key": "CascadeRowDeleted",
                "name": "Cascade row deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F62GE7NR5DC9MBPV6PN",
                "key": "CascadeCompleted",
                "name": "Cascade completed",
                "payloadSchema": [
                  {
                    "name": "parentId",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "scanning"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "eventId": "evt_01KXG04F6281CRC439K4RVYM4T",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.data.id"
                  ],
                  [
                    "set",
                    "@entity.parentEntity",
                    "@config.parentEntity"
                  ],
                  [
                    "fetch",
                    "@config.dependentEntity",
                    {
                      "emit": {
                        "failure": "CascadeFailed",
                        "success": "DepsLoaded"
                      }
                    }
                  ]
                ],
                "event": "ParentDeleted",
                "eventId": "evt_01KXG04F62016GZS5ER2WYSRXW",
                "from": "idle",
                "guard": "@config.enabled",
                "to": "scanning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.headId",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@payload.data",
                          [
                            "fn",
                            "row",
                            [
                              "=",
                              [
                                "object/get",
                                "@row",
                                "@config.foreignKeyField"
                              ],
                              "@entity.parentId"
                            ]
                          ]
                        ]
                      ],
                      "id"
                    ]
                  ],
                  [
                    "emit",
                    "CascadeRowDeleted",
                    {
                      "id": "@entity.headId"
                    }
                  ],
                  [
                    "persist",
                    "delete",
                    "@config.dependentEntity",
                    "@entity.headId",
                    {
                      "emit": {
                        "failure": "CascadeFailed",
                        "success": "CascadeStepped"
                      }
                    }
                  ]
                ],
                "event": "DepsLoaded",
                "eventId": "evt_01KXG04F624M2CZ0FSEPAZZD39",
                "from": "scanning",
                "guard": [
                  ">",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        [
                          "=",
                          [
                            "object/get",
                            "@row",
                            "@config.foreignKeyField"
                          ],
                          "@entity.parentId"
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "scanning"
              },
              {
                "effects": [
                  [
                    "emit",
                    "CascadeCompleted",
                    {
                      "parentId": "@entity.parentId"
                    }
                  ]
                ],
                "event": "DepsLoaded",
                "eventId": "evt_01KXG04F624M2CZ0FSEPAZZD39",
                "from": "scanning",
                "guard": [
                  "=",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        [
                          "=",
                          [
                            "object/get",
                            "@row",
                            "@config.foreignKeyField"
                          ],
                          "@entity.parentId"
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "@config.dependentEntity",
                    {
                      "emit": {
                        "failure": "CascadeFailed",
                        "success": "DepsLoaded"
                      }
                    }
                  ]
                ],
                "event": "CascadeStepped",
                "eventId": "evt_01KXG04F62F2J70RRB8DEF0QM6",
                "from": "scanning",
                "to": "scanning"
              },
              {
                "event": "CascadeFailed",
                "eventId": "evt_01KXG04F62CJ2RA14CFCY7R5AD",
                "from": "scanning",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.1.0"
}