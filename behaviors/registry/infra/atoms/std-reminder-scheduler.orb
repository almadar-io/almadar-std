{
  "name": "std-reminder-scheduler",
  "version": "1.0.0",
  "description": "std-reminder-scheduler — declarative deadline-reminder rules for a target entity. Periodic tick logs scans to ReminderRunLog. v1.0 ships the knob set + scan topology so the questionnaire surfaces dateField + offsetsHours + template; auto-emit of ReminderDue per matching record lands in v1.1 (loop-with-emit gap — docs/Almadar_Std_Factories.md). Composed alongside std-notify-on-event in organisms once the emit lands.",
  "orbitals": [
    {
      "name": "ReminderSchedulerOrbital",
      "entity": {
        "name": "ReminderRunLog",
        "collection": "reminder_runs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetEntity",
            "type": "string",
            "default": ""
          },
          {
            "name": "recordCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "ranAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "errors",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ReminderScheduler",
          "category": "lifecycle",
          "linkedEntity": "ReminderRunLog",
          "emits": [
            {
              "event": "ScanRecordsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "ScanFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReminderRunLogged",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetEntity",
                  "type": "string"
                },
                {
                  "name": "row.recordCount",
                  "type": "number"
                },
                {
                  "name": "row.ranAt",
                  "type": "number"
                },
                {
                  "name": "row.errors",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReminderRunFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "ScanRecordsLoaded",
                "name": "Scan records loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "ScanFailed",
                "name": "Scan failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReminderRunLogged",
                "name": "ReminderRunLog ged",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ReminderRunLog"
                  }
                ]
              },
              {
                "key": "ReminderRunFailed",
                "name": "Reminder run failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "ScanRecordsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.targetEntity",
                    "@config.targetEntity"
                  ],
                  [
                    "set",
                    "@entity.recordCount",
                    [
                      "array/len",
                      "@payload.data"
                    ]
                  ],
                  [
                    "set",
                    "@entity.ranAt",
                    0.0
                  ],
                  [
                    "persist",
                    "create",
                    "ReminderRunLog",
                    "@entity",
                    {
                      "emit": {
                        "success": "ReminderRunLogged",
                        "failure": "ReminderRunFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ScanFailed",
                "effects": [
                  [
                    "set",
                    "@entity.targetEntity",
                    "@config.targetEntity"
                  ],
                  [
                    "set",
                    "@entity.recordCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.errors",
                    "@payload.error"
                  ],
                  [
                    "persist",
                    "create",
                    "ReminderRunLog",
                    "@entity",
                    {
                      "emit": {
                        "success": "ReminderRunLogged",
                        "failure": "ReminderRunFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReminderRunLogged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReminderRunFailed"
              }
            ]
          },
          "ticks": [
            {
              "name": "scanCycle",
              "interval": 900000.0,
              "effects": [
                [
                  "fetch",
                  "ReminderRunLog",
                  {
                    "emit": {
                      "failure": "ScanFailed",
                      "success": "ScanRecordsLoaded"
                    }
                  }
                ]
              ]
            }
          ],
          "config": {
            "targetEntity": {
              "type": "string",
              "default": "",
              "label": "Target entity",
              "description": "Entity to scan for upcoming deadlines (e.g. 'ClassSession', 'CourtDeadlineRecord').",
              "tier": "domain"
            },
            "dateField": {
              "type": "string",
              "default": "",
              "label": "Deadline field",
              "description": "Field on the target entity holding the deadline timestamp (e.g. 'dueAt', 'startsAt').",
              "tier": "domain"
            },
            "offsetsHours": {
              "type": "[number]",
              "default": [],
              "label": "Reminder offsets (hours before deadline)",
              "description": "Multi-touch reminder offsets: e.g. [168, 24, 1] for 7d/1d/1h reminders. v1.0 declarative only — emit lands in v1.1 (gap).",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            },
            "severity": {
              "type": "string",
              "default": "info",
              "label": "Severity",
              "description": "Severity passed to the notifier when emit lands: info / warning / error.",
              "tier": "domain"
            },
            "template": {
              "type": "string",
              "default": "",
              "label": "Message template",
              "description": "Message body passed to the notifier.",
              "tier": "presentation"
            },
            "windowToleranceMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Match tolerance (minutes)",
              "description": "How close to the offset a record must be to fire a reminder. Wider = more forgiving but more dupes.",
              "tier": "domain"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ReminderSchedulerPage",
          "path": "/reminders/scheduler",
          "traits": [
            {
              "ref": "ReminderScheduler"
            }
          ]
        }
      ]
    }
  ]
}