{
  "description": "std-anim-tick — sprite animation clock atom. Owns a global animation counter and exposes the current frame NAME (@entity.frameName = frames[counter % len]) every 100ms tick. Boards compose it via `uses` + a trait-ref rebound (linkedEntity) to the board entity; render-ui merges @entity.frameName onto the animated sprite's asset, replacing the inlined animTick frame counters that were duplicated across game boards. 1.1.0 redesign: the 1.0.0 units-frame-advance / effects-aging sets were removed — numeric unit frames served the pre-animation-contract regime (draw-sprite paints atlas sub-texture NAMES, which is exactly what frameName now exposes; zero consumers existed), effects aging is owned by std-fx-particles, and the shared-entity one-writer rule (ORB_SHARED_ENTITY_FIELD_CONFLICT) forbids a shared atom co-writing fields a board's own ticks also write. Tick interval is a language-level literal (100ms); the config surface is `frames`.",
  "name": "std-anim-tick",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "animCounter",
            "type": "number"
          },
          {
            "default": "",
            "name": "frameName",
            "type": "string"
          }
        ],
        "name": "AnimTickItem",
        "persistence": "runtime"
      },
      "name": "AnimTickOrbital",
      "pages": [
        {
          "name": "AnimTickPage",
          "path": "/anim-tick",
          "traits": [
            {
              "ref": "AnimTick"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "game-core",
          "config": {
            "frames": {
              "default": [],
              "description": "Atlas sub-texture names cycled into @entity.frameName, one per tick; empty disables name cycling.",
              "items": {
                "type": "string"
              },
              "label": "Frame names",
              "synonyms": "sprite names, atlas frames, animation frames",
              "tier": "domain",
              "type": "[string]"
            }
          },
          "entityContract": {
            "provides": [
              "animCounter",
              "frameName"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AnimTickItem",
          "name": "AnimTick",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "running"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.animCounter",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.frameName",
                    [
                      "if",
                      [
                        ">",
                        [
                          "array/len",
                          "@config.frames"
                        ],
                        0.0
                      ],
                      [
                        "array/nth",
                        "@config.frames",
                        0.0
                      ],
                      "@entity.frameName"
                    ]
                  ]
                ],
                "event": "INIT",
                "from": "running",
                "to": "running"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.animCounter",
                  [
                    "+",
                    "@entity.animCounter",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.frameName",
                  [
                    "if",
                    [
                      ">",
                      [
                        "array/len",
                        "@config.frames"
                      ],
                      0.0
                    ],
                    [
                      "array/nth",
                      "@config.frames",
                      [
                        "%",
                        "@entity.animCounter",
                        [
                          "array/len",
                          "@config.frames"
                        ]
                      ]
                    ],
                    "@entity.frameName"
                  ]
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.1.0"
}