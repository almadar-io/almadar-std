            {
              "ref": "CrossReferenceGate",
              "refId": "trt_01KXG04F9C1MBA6YFXTVB0475Q"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "junctionEntity": {
              "default": "",
              "description": "Persistent entity used as the join table",
              "label": "Junction entity",
              "synonyms": "join table, link table, bridge table, junction table, mapping table",
              "tier": "internal",
              "type": "string"
            },
            "leftEntity": {
              "default": "",
              "description": "Entity type on the left side of the N:M relationship",
              "label": "Left entity",
              "synonyms": "left side, source entity, from entity, parent entity",
              "tier": "internal",
              "type": "string"
            },
            "leftIdField": {
              "default": "",
              "description": "Junction column holding the left entity's id",
              "label": "Left FK field",
              "synonyms": "left foreign key, left FK, source key, parent key",
              "tier": "internal",
              "type": "string"
            },
            "rightEntity": {
              "default": "",
              "description": "Entity type on the right side of the N:M relationship",
              "label": "Right entity",
              "synonyms": "right side, target entity, to entity, child entity, related entity",
              "tier": "internal",
              "type": "string"
            },
            "rightIdField": {
              "default": "",
              "description": "Junction column holding the right entity's id",
              "label": "Right FK field",
              "synonyms": "right foreign key, right FK, target key, child key",
              "tier": "internal",
              "type": "string"
            }
          },
          "emits": [
            {
              "event": "LinkCreated",
              "eventId": "evt_01KXG04F9C9J69NDMJ8DGS1DE1",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinkRemoved",
              "eventId": "evt_01KXG04F9CAF1HCW96ZNTXPJ1T",
              "payloadSchema": [
                {
                  "name": "leftId",
                  "type": "string"
                },
                {
                  "name": "rightId",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinksLoaded",
              "eventId": "evt_01KXG04F9CT2KHRC3C5K4Q078W",
              "payloadSchema": [
                {
                  "name": "leftId",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinksFetched",
              "eventId": "evt_01KXG04F9C4YY3DN15DAVAQB5B",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinkOpFailed",
              "eventId": "evt_01KXG04F9C5DE33MZF9WM6X33A",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "external"
            }
          ],
          "entityRefIds": {
            "CrossRefLink": "ent_01KXG04F9CP8JSW26MMJ9DP9SQ"
          },
          "id": "trt_01KXG04F9C1MBA6YFXTVB0475Q",
          "linkedEntity": "CrossRefLink",
          "linkedEntityId": "ent_01KXG04F9CP8JSW26MMJ9DP9SQ",
          "name": "CrossReferenceGate",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04F9CR69NKQZ61QYEYNE7",
                "key": "LinkRequested",
                "name": "Link requested",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9C34A2M0PD5R97VBD2",
                "key": "UnlinkRequested",
                "name": "Unlink requested",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9C9TWD1BZTRN0WGWB8",
                "key": "FETCH_LINKS_FOR",
                "name": "Fetch Links For",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9C4YY3DN15DAVAQB5B",
                "key": "LinksFetched",
                "name": "Links fetched",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9C9J69NDMJ8DGS1DE1",
                "key": "LinkCreated",
                "name": "Link created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9CAF1HCW96ZNTXPJ1T",
                "key": "LinkRemoved",
                "name": "Link removed",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9CT2KHRC3C5K4Q078W",
                "key": "LinksLoaded",
                "name": "Links loaded",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "id": "evt_01KXG04F9C5DE33MZF9WM6X33A",
                "key": "LinkOpFailed",
                "name": "Link op failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "CrossRefLink",
                    {
                      "leftId": "@payload.leftId",
                      "rightId": "@payload.rightId"
                    },
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinkCreated"
                      }
                    }
                  ]
                ],
                "event": "LinkRequested",
                "eventId": "evt_01KXG04F9CR69NKQZ61QYEYNE7",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CrossRefLink",
                    "@payload",
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinkRemoved"
                      }
                    }
                  ]
                ],
                "event": "UnlinkRequested",
                "eventId": "evt_01KXG04F9C34A2M0PD5R97VBD2",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.leftId",
                    "@payload.leftId"
                  ],
                  [
                    "fetch",
                    "CrossRefLink",
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinksFetched"
                      }
                    }
                  ]
                ],
                "event": "FETCH_LINKS_FOR",
                "eventId": "evt_01KXG04F9C9TWD1BZTRN0WGWB8",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.filteredLinks",
                    [
                      "array/filter",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        [
                          "=",
                          [
                            "object/get",
                            "@row",
                            "leftId"
                          ],
                          "@entity.leftId"
                        ]
                      ]
                    ]
                  ],
                  [
                    "emit",
                    "LinksLoaded",
                    {
                      "data": "@entity.filteredLinks",
                      "leftId": "@entity.leftId"
                    }
                  ]
                ],
                "event": "LinksFetched",
                "eventId": "evt_01KXG04F9C4YY3DN15DAVAQB5B",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}