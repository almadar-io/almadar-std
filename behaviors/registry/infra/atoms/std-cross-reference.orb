            "type": "string"
          },
          {
            "default": "",
            "description": "Identifier for the related entity on the right side.",
            "name": "rightId",
            "synonyms": "targetId, relatedId, counterpartId",
            "type": "string"
          },
          {
            "default": "",
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": [],
            "description": "A list of filtered link specifications.",
            "items": {
              "properties": {
                "href": {
                  "name": "href",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "filteredLinks",
            "synonyms": "links, references, connections",
            "type": "array"
          }
        ],
        "id": "ent_01KXG04F9CP8JSW26MMJ9DP9SQ",
