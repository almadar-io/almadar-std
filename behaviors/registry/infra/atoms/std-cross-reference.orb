{
  "description": "std-cross-reference — join-table primitive for N:M relationships. Listens for LinkRequested/UnlinkRequested/FETCH_LINKS_FOR and manages the junction collection (default CrossRefLink [persistent: cross_ref_links]). Rebind via linkedEntity to your consumer junction. Emits LinkCreated, LinkRemoved, LinksLoaded as external broadcasts for downstream consumers.",
  "name": "std-cross-reference",
  "orbitals": [
    {
      "entity": {
        "collection": "cross_ref_links",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "Identifier for the related entity on the left side.",
            "name": "leftId",
            "synonyms": "sourceId, originId, parentId",
            "type": "string"
          },
          {
            "default": "",
            "description": "Identifier for the related entity on the right side.",
            "name": "rightId",
            "synonyms": "targetId, relatedId, counterpartId",
            "type": "string"
          },
          {
            "default": "",
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": [],
            "description": "A list of filtered link specifications.",
            "items": {
              "properties": {
                "href": {
                  "name": "href",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "filteredLinks",
            "synonyms": "links, references, connections",
            "type": "array"
          }
        ],
        "name": "CrossRefLink",
        "persistence": "persistent"
      },
      "name": "CrossReferenceOrbital",
      "pages": [
        {
          "name": "CrossReferencePage",
          "path": "/cross-reference",
          "traits": [
            {
              "ref": "CrossReferenceGate"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "junctionEntity": {
              "default": "",
              "description": "Persistent entity used as the join table",
              "label": "Junction entity",
              "synonyms": "join table, link table, bridge table, junction table, mapping table",
              "tier": "internal",
              "type": "string"
            },
            "leftEntity": {
              "default": "",
              "description": "Entity type on the left side of the N:M relationship",
              "label": "Left entity",
              "synonyms": "left side, source entity, from entity, parent entity",
              "tier": "internal",
              "type": "string"
            },
            "leftIdField": {
              "default": "",
              "description": "Junction column holding the left entity's id",
              "label": "Left FK field",
              "synonyms": "left foreign key, left FK, source key, parent key",
              "tier": "internal",
              "type": "string"
            },
            "rightEntity": {
              "default": "",
              "description": "Entity type on the right side of the N:M relationship",
              "label": "Right entity",
              "synonyms": "right side, target entity, to entity, child entity, related entity",
              "tier": "internal",
              "type": "string"
            },
            "rightIdField": {
              "default": "",
              "description": "Junction column holding the right entity's id",
              "label": "Right FK field",
              "synonyms": "right foreign key, right FK, target key, child key",
              "tier": "internal",
              "type": "string"
            }
          },
          "emits": [
            {
              "event": "LinkCreated",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinkRemoved",
              "payloadSchema": [
                {
                  "name": "leftId",
                  "type": "string"
                },
                {
                  "name": "rightId",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinksLoaded",
              "payloadSchema": [
                {
                  "name": "leftId",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinksFetched",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ],
              "scope": "external"
            },
            {
              "event": "LinkOpFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "external"
            }
          ],
          "linkedEntity": "CrossRefLink",
          "name": "CrossReferenceGate",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "LinkRequested",
                "name": "Link requested",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UnlinkRequested",
                "name": "Unlink requested",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FETCH_LINKS_FOR",
                "name": "Fetch Links For",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LinksFetched",
                "name": "Links fetched",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "LinkCreated",
                "name": "Link created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "LinkRemoved",
                "name": "Link removed",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LinksLoaded",
                "name": "Links loaded",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "LinkOpFailed",
                "name": "Link op failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "CrossRefLink",
                    {
                      "leftId": "@payload.leftId",
                      "rightId": "@payload.rightId"
                    },
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinkCreated"
                      }
                    }
                  ]
                ],
                "event": "LinkRequested",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CrossRefLink",
                    "@payload",
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinkRemoved"
                      }
                    }
                  ]
                ],
                "event": "UnlinkRequested",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.leftId",
                    "@payload.leftId"
                  ],
                  [
                    "fetch",
                    "CrossRefLink",
                    {
                      "emit": {
                        "failure": "LinkOpFailed",
                        "success": "LinksFetched"
                      }
                    }
                  ]
                ],
                "event": "FETCH_LINKS_FOR",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.filteredLinks",
                    [
                      "array/filter",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        [
                          "=",
                          [
                            "object/get",
                            "@row",
                            "leftId"
                          ],
                          "@entity.leftId"
                        ]
                      ]
                    ]
                  ],
                  [
                    "emit",
                    "LinksLoaded",
                    {
                      "data": "@entity.filteredLinks",
                      "leftId": "@entity.leftId"
                    }
                  ]
                ],
                "event": "LinksFetched",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}