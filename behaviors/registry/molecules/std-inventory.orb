{
  "name": "std-inventory",
  "version": "1.0.0",
  "description": "std-inventory as a Function",
  "orbitals": [
    {
      "name": "InventoryItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "InventoryItem",
        "collection": "inventoryitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "InventoryItemBrowse",
          "category": "interaction",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "InventoryItemLoaded",
              "description": "Fired when the InventoryItem collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[InventoryItem]"
                }
              ]
            },
            {
              "event": "InventoryItemLoadFailed",
              "description": "Fired when the InventoryItem collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_ADDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemPersistor"
              }
            },
            {
              "event": "ITEM_USED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemPersistor"
              }
            },
            {
              "event": "ITEM_DROPPED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InventoryItemLoaded",
                "name": "InventoryItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[InventoryItem]"
                  }
                ]
              },
              {
                "key": "InventoryItemLoadFailed",
                "name": "InventoryItem load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem",
                    {
                      "emit": {
                        "success": "InventoryItemLoaded",
                        "failure": "InventoryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading inventory…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InventoryItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "package",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Inventory"
                                }
                              ]
                            },
                            {
                              "action": "ADD_ITEM",
                              "type": "button",
                              "label": "Add Item",
                              "variant": "primary",
                              "icon": "plus"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name",
                              "variant": "h4",
                              "icon": "package"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "event": "USE_ITEM",
                              "label": "Use"
                            },
                            {
                              "label": "Drop",
                              "variant": "danger",
                              "event": "DROP"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ],
                      "className": "max-w-5xl mx-auto w-full",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InventoryItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to load inventory",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "INIT",
                          "variant": "primary",
                          "label": "Retry"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem",
                    {
                      "emit": {
                        "success": "InventoryItemLoaded",
                        "failure": "InventoryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem",
                    {
                      "emit": {
                        "failure": "InventoryItemLoadFailed",
                        "success": "InventoryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryItemAdd",
          "linkedEntity": "InventoryItem",
          "config": {
            "title": "Add Item",
            "icon": "plus-circle",
            "mode": "create",
            "fields": [
              "name",
              "description",
              "status"
            ]
          },
          "events": {
            "SAVE": "ITEM_ADDED",
            "OPEN": "ADD_ITEM"
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "InventoryItemUse",
          "linkedEntity": "InventoryItem",
          "config": {
            "title": "Use Item",
            "alertMessage": "Consume this item?",
            "icon": "zap",
            "confirmLabel": "Confirm Use"
          },
          "events": {
            "REQUEST": "USE_ITEM",
            "CONFIRM": "ITEM_USED"
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "InventoryItemDrop",
          "linkedEntity": "InventoryItem",
          "config": {
            "title": "Drop Item",
            "confirmLabel": "Drop",
            "icon": "alert-triangle",
            "alertMessage": "Are you sure you want to drop this item? This action cannot be undone."
          },
          "events": {
            "REQUEST": "DROP",
            "CONFIRM": "ITEM_DROPPED"
          }
        },
        {
          "name": "InventoryItemPersistor",
          "category": "lifecycle",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "ITEM_ADDED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_USED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_DROPPED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_ADDED",
              "triggers": "DO_ADD",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemAdd"
              }
            },
            {
              "event": "ITEM_USED",
              "triggers": "DO_USE",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemUse"
              }
            },
            {
              "event": "ITEM_DROPPED",
              "triggers": "DO_DROP",
              "source": {
                "kind": "trait",
                "trait": "InventoryItemDrop"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_ADD",
                "name": "Do Add",
                "payload": [
                  {
                    "name": "data",
                    "type": "InventoryItem"
                  }
                ]
              },
              {
                "key": "DO_USE",
                "name": "Do Use",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DROP",
                "name": "Do Drop",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEM_ADDED",
                "name": "Item Added"
              },
              {
                "key": "ITEM_USED",
                "name": "Item Used"
              },
              {
                "key": "ITEM_DROPPED",
                "name": "Item Dropped"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_ADD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "InventoryItem",
                    "@payload.data"
                  ],
                  [
                    "emit",
                    "ITEM_ADDED",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_USE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "InventoryItem",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ITEM_USED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DROP",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "InventoryItem",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ITEM_DROPPED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InventoryItemPage",
          "path": "/inventoryitems",
          "traits": [
            {
              "ref": "InventoryItemBrowse"
            },
            {
              "ref": "InventoryItemAdd"
            },
            {
              "ref": "InventoryItemUse"
            },
            {
              "ref": "InventoryItemDrop"
            },
            {
              "ref": "InventoryItemPersistor"
            }
          ]
        }
      ]
    }
  ]
}