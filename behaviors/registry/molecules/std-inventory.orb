{
  "name": "std-inventory",
  "version": "1.0.0",
  "description": "std-inventory as a Function",
  "orbitals": [
    {
      "name": "InventoryItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "InventoryItem",
        "collection": "inventoryitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "InventoryItemBrowse",
          "linkedEntity": "InventoryItem",
          "effects": {
            "INIT": [
              [
                "ref",
                "InventoryItem"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "className": "max-w-5xl mx-auto w-full",
                  "children": [
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "package"
                            },
                            {
                              "content": "InventoryItems Inventory",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "event": "ADD_ITEM",
                              "icon": "plus",
                              "type": "button",
                              "variant": "primary",
                              "label": "Add InventoryItem"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "horizontal",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "justify": "space-between"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "data-grid",
                      "emptyTitle": "No items yet",
                      "emptyDescription": "Add your first item to get started.",
                      "itemActions": [
                        {
                          "variant": "ghost",
                          "event": "USE_ITEM",
                          "size": "sm",
                          "label": "Use"
                        },
                        {
                          "variant": "danger",
                          "size": "sm",
                          "event": "DROP",
                          "label": "Drop"
                        }
                      ],
                      "emptyIcon": "inbox",
                      "columns": [
                        {
                          "name": "name",
                          "variant": "h4",
                          "icon": "package",
                          "label": "Name"
                        },
                        {
                          "label": "Description",
                          "name": "description",
                          "colorMap": {
                            "disabled": "neutral",
                            "error": "destructive",
                            "scheduled": "warning",
                            "draft": "warning",
                            "active": "success",
                            "completed": "success",
                            "done": "success",
                            "pending": "warning",
                            "archived": "neutral",
                            "failed": "destructive",
                            "inactive": "neutral",
                            "cancelled": "destructive"
                          },
                          "variant": "badge"
                        },
                        {
                          "name": "status",
                          "label": "Status",
                          "variant": "caption"
                        }
                      ],
                      "entity": "InventoryItem"
                    }
                  ],
                  "direction": "vertical",
                  "gap": "lg"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryItemAdd",
          "linkedEntity": "InventoryItem",
          "events": {
            "OPEN": "ADD_ITEM"
          },
          "effects": {
            "INIT": [
              [
                "ref",
                "InventoryItem"
              ]
            ],
            "SAVE": [
              [
                "persist",
                "create",
                "InventoryItem",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "emit",
                "ITEM_ADDED"
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "ADD_ITEM": [
              [
                "fetch",
                "InventoryItem"
              ],
              [
                "render-ui",
                "modal",
                {
                  "gap": "md",
                  "direction": "vertical",
                  "type": "stack",
                  "children": [
                    {
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "type": "icon",
                          "name": "plus-circle",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Add InventoryItem"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entity": "InventoryItem",
                      "submitEvent": "SAVE",
                      "cancelEvent": "CLOSE",
                      "fields": [
                        "name",
                        "description",
                        "status"
                      ],
                      "mode": "create",
                      "type": "form-section"
                    }
                  ]
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryItemUse",
          "linkedEntity": "InventoryItem",
          "events": {
            "OPEN": "USE_ITEM"
          },
          "effects": {
            "USE_ITEM": [
              [
                "fetch",
                "InventoryItem",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "gap": "md",
                  "type": "stack",
                  "direction": "vertical",
                  "children": [
                    {
                      "gap": "sm",
                      "children": [
                        {
                          "type": "icon",
                          "name": "zap",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "content": "Use InventoryItem",
                          "variant": "h3"
                        }
                      ],
                      "direction": "horizontal",
                      "align": "center",
                      "type": "stack"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "variant": "body",
                      "type": "typography",
                      "content": "@entity.name"
                    },
                    {
                      "children": [
                        {
                          "event": "CLOSE",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "ghost"
                        },
                        {
                          "variant": "primary",
                          "event": "SAVE",
                          "type": "button",
                          "label": "Confirm Use",
                          "icon": "check"
                        }
                      ],
                      "type": "stack",
                      "justify": "center",
                      "direction": "horizontal",
                      "gap": "sm"
                    }
                  ],
                  "align": "center"
                }
              ]
            ],
            "INIT": [
              [
                "ref",
                "InventoryItem"
              ]
            ],
            "SAVE": [
              [
                "persist",
                "update",
                "InventoryItem",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "emit",
                "ITEM_USED"
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ]
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "InventoryItemDrop",
          "linkedEntity": "InventoryItem",
          "events": {
            "REQUEST": "DROP",
            "CONFIRM": "CONFIRM_DROP"
          },
          "effects": {
            "DROP": [
              [
                "set",
                "@entity.pendingId",
                "@payload.id"
              ],
              [
                "fetch",
                "InventoryItem",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "children": [
                    {
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "md"
                        },
                        {
                          "content": "Drop InventoryItem",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ],
                      "align": "center",
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "alert",
                      "variant": "danger",
                      "message": "Are you sure you want to drop this inventoryitem?"
                    },
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "button",
                          "label": "Cancel",
                          "event": "CANCEL",
                          "variant": "ghost"
                        },
                        {
                          "event": "CONFIRM_DROP",
                          "type": "button",
                          "icon": "check",
                          "variant": "danger",
                          "label": "Drop"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "justify": "end"
                    }
                  ],
                  "type": "stack",
                  "gap": "md",
                  "direction": "vertical"
                }
              ]
            ],
            "INIT": [
              [
                "ref",
                "InventoryItem"
              ]
            ],
            "CONFIRM_DROP": [
              [
                "persist",
                "delete",
                "InventoryItem",
                "@entity.pendingId"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "InventoryItem"
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "InventoryItem"
              ]
            ],
            "CANCEL": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "InventoryItem"
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "InventoryItemPage",
          "path": "/inventoryitems",
          "traits": [
            {
              "ref": "InventoryItemBrowse"
            },
            {
              "ref": "InventoryItemAdd"
            },
            {
              "ref": "InventoryItemUse"
            },
            {
              "ref": "InventoryItemDrop"
            }
          ]
        }
      ]
    }
  ]
}