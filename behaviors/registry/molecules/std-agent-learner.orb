{
  "name": "std-agent-learner",
  "version": "1.0.0",
  "description": "std-agent-learner as a Function",
  "orbitals": [
    {
      "name": "AgentLearnerOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-agent-provider",
          "as": "AgentProvider"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "AgentLearner",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "outcome",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "impact",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isSuccess",
            "type": "boolean",
            "default": false
          },
          {
            "name": "provider",
            "type": "string",
            "default": ""
          },
          {
            "name": "consecutiveFailures",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSuccesses",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalFailures",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "currentProvider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "currentModel",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "fallbackProvider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "requestCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentLearnerLearner",
          "category": "interaction",
          "linkedEntity": "AgentLearner",
          "emits": [
            {
              "event": "TASK_SUCCEEDED",
              "scope": "external",
              "payload": [
                {
                  "name": "outcome",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TASK_SUCCEEDED",
              "triggers": "TASK_SUCCEEDED",
              "source": {
                "kind": "trait",
                "trait": "AgentLearnerLearner"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "recording"
              },
              {
                "name": "analyzing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TASK_SUCCEEDED",
                "name": "Task Succeeded",
                "payload": [
                  {
                    "name": "outcome",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TASK_FAILED",
                "name": "Task Failed",
                "payload": [
                  {
                    "name": "outcome",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RECORDED",
                "name": "Recorded",
                "payload": [
                  {
                    "name": "memoryId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ANALYSIS_DONE",
                "name": "Analysis Done",
                "payload": [
                  {
                    "name": "impact",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "graduation-cap"
                            },
                            {
                              "variant": "h2",
                              "content": "Outcome Learner",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "value": "@entity.totalSuccesses",
                              "label": "Successes",
                              "type": "stat-display",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "icon": "x-circle",
                              "value": "@entity.totalFailures",
                              "label": "Failures"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.provider",
                              "label": "Current Provider",
                              "icon": "cpu"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Listening for task outcomes...",
                                  "variant": "body"
                                },
                                {
                                  "type": "typography",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Last Outcome"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "type": "typography",
                                  "content": "Impact Analysis",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.impact",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "recording",
                "event": "TASK_SUCCEEDED",
                "effects": [
                  [
                    "set",
                    "@entity.outcome",
                    "@payload.outcome"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.isSuccess",
                    true
                  ],
                  [
                    "set",
                    "@entity.consecutiveFailures",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSuccesses",
                    [
                      "+",
                      "@entity.totalSuccesses",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recording"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Success: ",
                      "@payload.outcome"
                    ],
                    "@payload.category"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "save"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Recording outcome..."
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "type": "badge",
                          "label": "@entity.outcome"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "recording",
                "event": "TASK_FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.outcome",
                    "@payload.outcome"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.isSuccess",
                    false
                  ],
                  [
                    "set",
                    "@entity.consecutiveFailures",
                    [
                      "+",
                      "@entity.consecutiveFailures",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.totalFailures",
                    [
                      "+",
                      "@entity.totalFailures",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recording"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Failure: ",
                      "@payload.outcome"
                    ],
                    "@payload.category"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "save"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Recording outcome..."
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "label": "@entity.outcome",
                          "type": "badge"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "graduation-cap",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Outcome Learner",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.totalSuccesses",
                              "type": "stat-display",
                              "label": "Successes",
                              "icon": "check-circle"
                            },
                            {
                              "icon": "x-circle",
                              "value": "@entity.totalFailures",
                              "label": "Failures",
                              "type": "stat-display"
                            },
                            {
                              "label": "Current Provider",
                              "value": "@entity.provider",
                              "icon": "cpu",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Listening for task outcomes...",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically."
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Last Outcome",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "content": "Impact Analysis",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.impact",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "recording",
                "to": "analyzing",
                "event": "RECORDED",
                "effects": [
                  [
                    "set",
                    "@entity.memoryId",
                    "@payload.memoryId"
                  ],
                  [
                    "if",
                    "@entity.isSuccess",
                    [
                      "agent/reinforce",
                      "@payload.memoryId"
                    ],
                    [
                      "agent/decay"
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      "@entity.consecutiveFailures",
                      3.0
                    ],
                    [
                      "agent/switch-provider",
                      "anthropic"
                    ],
                    [
                      "log",
                      "No provider switch needed"
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "analyzing"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Outcome: ",
                      "@entity.outcome",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Result: ",
                      [
                        "if",
                        "@entity.isSuccess",
                        "success",
                        "failure"
                      ],
                      "\n",
                      "Consecutive failures: ",
                      [
                        "str/concat",
                        "@entity.consecutiveFailures"
                      ],
                      "\n\n",
                      "Analyze the impact of this outcome. What should be learned? Keep it to 1-2 sentences."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "cpu"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Analyzing impact..."
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "justify": "center",
                          "children": [
                            {
                              "label": [
                                "str/concat",
                                "Category: ",
                                "@entity.category"
                              ],
                              "type": "badge"
                            },
                            {
                              "label": [
                                "if",
                                "@entity.isSuccess",
                                "Success",
                                "Failure"
                              ],
                              "type": "badge"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "recording",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "graduation-cap",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Outcome Learner",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Successes",
                              "icon": "check-circle",
                              "value": "@entity.totalSuccesses",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.totalFailures",
                              "type": "stat-display",
                              "label": "Failures",
                              "icon": "x-circle"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.provider",
                              "icon": "cpu",
                              "label": "Current Provider"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "Listening for task outcomes..."
                                },
                                {
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Last Outcome"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "variant": "caption",
                                  "content": "Impact Analysis",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.impact"
                                }
                              ],
                              "gap": "sm"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "analyzing",
                "to": "idle",
                "event": "ANALYSIS_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.impact",
                    "@payload.impact"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "graduation-cap",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Outcome Learner"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.totalSuccesses",
                              "type": "stat-display",
                              "label": "Successes",
                              "icon": "check-circle"
                            },
                            {
                              "icon": "x-circle",
                              "value": "@entity.totalFailures",
                              "type": "stat-display",
                              "label": "Failures"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.provider",
                              "label": "Current Provider",
                              "icon": "cpu"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "Listening for task outcomes..."
                                },
                                {
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last Outcome"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.outcome",
                                  "variant": "body"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Impact Analysis"
                                },
                                {
                                  "content": "@entity.impact",
                                  "variant": "body",
