{
  "name": "std-detail",
  "version": "1.0.0",
  "description": "std-detail as a Function",
  "orbitals": [
    {
      "name": "DetailRecordOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "DetailRecord",
        "collection": "detailrecords",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DetailRecordBrowse",
          "category": "interaction",
          "linkedEntity": "DetailRecord",
          "emits": [
            {
              "event": "DetailRecordLoaded",
              "description": "Fired when the DetailRecord collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[DetailRecord]"
                }
              ]
            },
            {
              "event": "DetailRecordLoadFailed",
              "description": "Fired when the DetailRecord collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DETAIL_RECORD_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DetailRecordPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DetailRecordLoaded",
                "name": "DetailRecord loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[DetailRecord]"
                  }
                ]
              },
              {
                "key": "DetailRecordLoadFailed",
                "name": "DetailRecord load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord",
                    {
                      "emit": {
                        "success": "DetailRecordLoaded",
                        "failure": "DetailRecordLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading records…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DetailRecordLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text",
                                  "size": "lg"
                                },
                                {
                                  "content": "DetailRecords",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "plus",
                              "label": "Create",
                              "action": "CREATE"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name",
                              "icon": "file-text"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "variant": "ghost",
                              "label": "View"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DetailRecordLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "size": "xl",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load records",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord",
                    {
                      "emit": {
                        "failure": "DetailRecordLoadFailed",
                        "success": "DetailRecordLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord",
                    {
                      "emit": {
                        "success": "DetailRecordLoaded",
                        "failure": "DetailRecordLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DetailRecordCreate",
          "linkedEntity": "DetailRecord",
          "config": {
            "fields": [
              "name",
              "description",
              "status"
            ],
            "title": "New DetailRecord",
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE",
            "SAVE": "DETAIL_RECORD_CREATED"
          }
        },
        {
          "name": "DetailRecordView",
          "category": "interaction",
          "linkedEntity": "DetailRecord",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye",
                              "size": "md"
                            },
                            {
                              "content": "@entity.name",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "content": "Name",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.name"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Description",
                              "type": "typography"
                            },
                            {
                              "content": "@entity.description",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Status"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Close",
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE"
                            }
                          ],
                          "justify": "end",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "DetailRecordPersistor",
          "category": "lifecycle",
          "linkedEntity": "DetailRecord",
          "emits": [
            {
              "event": "DETAIL_RECORD_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DETAIL_RECORD_CREATED",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "DetailRecordCreate"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payload": [
                  {
                    "name": "data",
                    "type": "DetailRecord"
                  }
                ]
              },
              {
                "key": "DETAIL_RECORD_CREATED",
                "name": "Detail Record Created"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "DetailRecord",
                    "@payload.data"
                  ],
                  [
                    "emit",
                    "DETAIL_RECORD_CREATED",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DetailRecordPage",
          "path": "/detailrecords",
          "traits": [
            {
              "ref": "DetailRecordBrowse"
            },
            {
              "ref": "DetailRecordCreate"
            },
            {
              "ref": "DetailRecordView"
            },
            {
              "ref": "DetailRecordPersistor"
            }
          ]
        }
      ]
    }
  ]
}