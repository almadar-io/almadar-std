{
  "name": "std-detail",
  "version": "1.0.0",
  "description": "std-detail as a Function",
  "orbitals": [
    {
      "name": "DetailRecordOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "DetailRecord",
        "collection": "detailrecords",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DetailRecordBrowse",
          "linkedEntity": "DetailRecord",
          "listens": [
            {
              "event": "*.SAVE",
              "triggers": "INIT"
            }
          ],
          "effects": {
            "INIT": [
              [
                "fetch",
                "DetailRecord"
              ]
            ],
            "BrowseItemLoaded": [
              [
                "render-ui",
                "main",
                {
                  "gap": "lg",
                  "direction": "vertical",
                  "children": [
                    {
                      "gap": "md",
                      "justify": "space-between",
                      "align": "center",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text",
                              "size": "lg"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "DetailRecords"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "button",
                          "label": "Create DetailRecord",
                          "variant": "primary",
                          "icon": "plus",
                          "event": "CREATE"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "itemActions": [
                        {
                          "variant": "ghost",
                          "label": "View",
                          "size": "sm",
                          "event": "VIEW"
                        }
                      ],
                      "emptyTitle": "No detailrecords yet",
                      "columns": [
                        {
                          "label": "Name",
                          "variant": "h4",
                          "name": "name",
                          "icon": "file-text"
                        },
                        {
                          "name": "description",
                          "label": "Description",
                          "variant": "badge"
                        },
                        {
                          "variant": "caption",
                          "label": "Status",
                          "name": "status"
                        }
                      ],
                      "type": "data-grid",
                      "entity": "DetailRecord",
                      "emptyIcon": "inbox",
                      "emptyDescription": "Create your first detailrecord to get started."
                    }
                  ],
                  "className": "max-w-5xl mx-auto w-full",
                  "type": "stack"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DetailRecordCreate",
          "linkedEntity": "DetailRecord",
          "events": {
            "OPEN": "CREATE"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "INIT": [
              [
                "fetch",
                "DetailRecord"
              ]
            ],
            "SAVE": [
              [
                "persist",
                "create",
                "DetailRecord",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ]
            ],
            "CREATE": [
              [
                "render-ui",
                "modal",
                {
                  "direction": "vertical",
                  "gap": "md",
                  "type": "stack",
                  "children": [
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "children": [
                        {
                          "name": "plus-circle",
                          "size": "md",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "New DetailRecord"
                        }
                      ],
                      "gap": "sm"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entity": "DetailRecord",
                      "mode": "create",
                      "fields": [
                        "name",
                        "description",
                        "status"
                      ],
                      "submitEvent": "SAVE",
                      "type": "form-section",
                      "cancelEvent": "CLOSE"
                    }
                  ]
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DetailRecordView",
          "linkedEntity": "DetailRecord",
          "events": {
            "OPEN": "VIEW"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ]
            ],
            "SAVE": [
              [
                "render-ui",
                "modal",
                null
              ]
            ],
            "VIEW": [
              [
                "fetch",
                "DetailRecord",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "children": [
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "eye",
                          "type": "icon",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.name",
                          "variant": "h3"
                        }
                      ],
                      "gap": "sm",
                      "direction": "horizontal",
                      "align": "center"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Name"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.name"
                        }
                      ],
                      "gap": "md"
                    },
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Description",
                          "variant": "caption"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.description"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack"
                    },
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "md",
                      "children": [
                        {
                          "content": "Status",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.status",
                          "variant": "body"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "stack",
                      "justify": "end",
                      "direction": "horizontal",
                      "children": [
                        {
                          "variant": "ghost",
                          "type": "button",
                          "event": "CLOSE",
                          "label": "Close"
                        }
                      ],
                      "gap": "sm"
                    }
                  ],
                  "direction": "vertical",
                  "gap": "md",
                  "type": "stack"
                }
              ]
            ],
            "INIT": [
              [
                "fetch",
                "DetailRecord"
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "DetailRecordPage",
          "path": "/detailrecords",
          "traits": [
            {
              "ref": "DetailRecordBrowse"
            },
            {
              "ref": "DetailRecordCreate"
            },
            {
              "ref": "DetailRecordView"
            }
          ]
        }
      ]
    }
  ]
}