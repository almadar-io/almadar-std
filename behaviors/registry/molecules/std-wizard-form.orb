{
  "name": "std-wizard-form",
  "version": "1.0.0",
  "description": "std-wizard-form — canonical molecule-level wizard example",
  "orbitals": [
    {
      "name": "WizardFormOrbital",
      "entity": {
        "name": "WizardFormEntry",
        "collection": "wizardformentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "email",
            "type": "string"
          },
          {
            "name": "theme",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WizardFormFlow",
          "category": "interaction",
          "linkedEntity": "WizardFormEntry",
          "emits": [
            {
              "event": "WizardFormSaved",
              "description": "Fired when wizard flow completes successfully",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardFormSaveFailed",
              "description": "Fired when the final persist fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardFormEntryLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[WizardFormEntry]"
                }
              ]
            },
            {
              "event": "WizardFormEntryLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "personal",
                "isInitial": true
              },
              {
                "name": "preferences"
              },
              {
                "name": "review"
              },
              {
                "name": "persisting"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NEXT",
                "name": "Next",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PREV",
                "name": "Prev"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "WizardFormSaved",
                "name": "Wizard form saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "WizardFormSaveFailed",
                "name": "Wizard form save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "WizardFormEntryLoaded",
                "name": "WizardFormEntry loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[WizardFormEntry]"
                  }
                ]
              },
              {
                "key": "WizardFormEntryLoadFailed",
                "name": "WizardFormEntry load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "personal",
                "to": "personal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardFormEntry",
                    {
                      "emit": {
                        "failure": "WizardFormEntryLoadFailed",
                        "success": "WizardFormEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sign-up",
                          "variant": "h2"
                        },
                        {
                          "type": "wizard-progress",
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "currentStep": 0.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Personal Info"
                        },
                        {
                          "submitEvent": "NEXT",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "type": "form-section",
                          "mode": "create",
                          "entity": "WizardFormEntry",
                          "cancelEvent": "INIT"
                        },
                        {
                          "showBack": false,
                          "showNext": true,
                          "showComplete": false,
                          "onNext": "NEXT",
                          "type": "wizard-navigation",
                          "totalSteps": 3.0,
                          "currentStep": 0.0
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "personal",
                "to": "preferences",
                "event": "NEXT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-xl mx-auto w-full",
                      "children": [
                        {
                          "content": "Sign-up",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "type": "wizard-progress",
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "currentStep": 1.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Preferences",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "mode": "edit",
                          "fields": [
                            "theme"
                          ],
                          "type": "form-section",
                          "entity": "WizardFormEntry",
                          "submitEvent": "NEXT",
                          "cancelEvent": "PREV"
                        },
                        {
                          "type": "wizard-navigation",
                          "showComplete": false,
                          "totalSteps": 3.0,
                          "onBack": "PREV",
                          "showBack": true,
                          "showNext": true,
                          "onNext": "NEXT",
                          "currentStep": 1.0
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "preferences",
                "to": "review",
                "event": "NEXT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Sign-up"
                        },
                        {
                          "currentStep": 2.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Review"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Name"
                                },
                                {
                                  "content": "@entity.name",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "justify": "between",
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Email",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.email",
                                  "type": "typography"
                                }
                              ],
                              "justify": "between"
                            },
                            {
                              "type": "stack",
                              "justify": "between",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Theme"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.theme",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "showNext": false,
                          "onBack": "PREV",
                          "showBack": true,
                          "showComplete": true,
                          "currentStep": 2.0,
                          "type": "wizard-navigation",
                          "onComplete": "COMPLETE",
                          "totalSteps": 3.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "preferences",
                "to": "personal",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sign-up",
                          "variant": "h2"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 0.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Personal Info",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "entity": "WizardFormEntry",
                          "mode": "edit",
                          "type": "form-section",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "cancelEvent": "INIT",
                          "submitEvent": "NEXT"
                        },
                        {
                          "type": "wizard-navigation",
                          "currentStep": 0.0,
                          "totalSteps": 3.0,
                          "showBack": false,
                          "showNext": true,
                          "showComplete": false,
                          "onNext": "NEXT"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "persisting",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "WizardFormEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "WizardFormSaved",
                        "failure": "WizardFormSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Completing sign-up…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-xl mx-auto w-full py-12"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "preferences",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "content": "Sign-up",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "currentStep": 1.0,
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Preferences",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "form-section",
                          "submitEvent": "NEXT",
                          "cancelEvent": "PREV",
                          "fields": [
                            "theme"
                          ],
                          "entity": "WizardFormEntry",
                          "mode": "edit"
                        },
                        {
                          "onNext": "NEXT",
                          "showBack": true,
                          "currentStep": 1.0,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation",
                          "onBack": "PREV",
                          "showComplete": false,
                          "showNext": true
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "complete",
                "event": "WizardFormSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-xl mx-auto w-full py-12",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Welcome!"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "Your account has been created.",
                          "color": "muted"
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "label": "Start Over",
                          "icon": "rotate-ccw",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "review",
                "event": "WizardFormSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "className": "max-w-xl mx-auto w-full py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "Sign-up Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "@payload.error"
                        },
                        {
                          "icon": "refresh-cw",
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "action": "COMPLETE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "personal",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "max-w-xl mx-auto w-full",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sign-up",
                          "variant": "h2"
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Personal Info"
                        },
                        {
                          "submitEvent": "NEXT",
                          "entity": "WizardFormEntry",
                          "type": "form-section",
                          "cancelEvent": "INIT",
                          "mode": "create",
                          "fields": [
                            "name",
                            "email"
                          ]
                        },
                        {
                          "showNext": true,
                          "type": "wizard-navigation",
                          "totalSteps": 3.0,
                          "showBack": false,
                          "currentStep": 0.0,
                          "onNext": "NEXT",
                          "showComplete": false
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardForm",
          "path": "/wizard-form",
          "traits": [
            {
              "ref": "WizardFormFlow"
            }
          ]
        }
      ]
    }
  ]
}