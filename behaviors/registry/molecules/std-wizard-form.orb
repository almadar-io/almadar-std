{
  "name": "std-wizard-form",
  "version": "1.0.0",
  "description": "std-wizard-form as a Function",
  "orbitals": [
    {
      "name": "WizardFormOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-wizard",
          "as": "Wizard"
        },
        {
          "from": "std/behaviors/std-input",
          "as": "Input"
        },
        {
          "from": "std/behaviors/std-validate-on-save",
          "as": "Validate"
        }
      ],
      "entity": {
        "name": "WizardFormEntry",
        "collection": "wizardformentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "step",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "email",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Input.traits.TextInputInput",
          "name": "WizardFormInput",
          "linkedEntity": "WizardFormEntry"
        },
        {
          "ref": "Wizard.traits.WizardEntryWizard",
          "name": "WizardFormWizard",
          "linkedEntity": "WizardFormEntry",
          "effects": {
            "RENDER_STEP": [
              [
                "render-ui",
                "main",
                {
                  "className": "max-w-xl mx-auto w-full",
                  "gap": "md",
                  "children": [
                    {
                      "content": "@entity.step",
                      "variant": "h2",
                      "type": "typography"
                    },
                    {
                      "type": "divider"
                    },
                    "@trait.WizardFormInput",
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Back",
                          "event": "PREV"
                        },
                        {
                          "variant": "primary",
                          "label": "Next",
                          "type": "button",
                          "event": "NEXT"
                        }
                      ],
                      "type": "stack",
                      "justify": "end",
                      "gap": "sm"
                    }
                  ],
                  "type": "stack",
                  "direction": "vertical"
                }
              ]
            ]
          }
        },
        {
          "ref": "Validate.traits.OrbFileWatcher",
          "name": "WizardFormValidate",
          "linkedEntity": "WizardFormEntry",
          "listens": [
            {
              "event": "WizardFormWizard.STEP_COMPLETED",
              "triggers": "VALIDATE"
            }
          ]
        },
        {
          "name": "WizardFormLayout",
          "category": "interaction",
          "linkedEntity": "WizardFormEntry",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardFormEntry"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@trait.WizardFormWizard"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardForm",
          "path": "/wizard-form",
          "traits": [
            {
              "ref": "WizardFormLayout"
            }
          ]
        }
      ]
    }
  ]
}