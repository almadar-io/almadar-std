{
  "name": "std-service-notification-hub",
  "version": "1.0.0",
  "description": "std-service-notification-hub as a Function",
  "orbitals": [
    {
      "name": "ServiceNotificationHubOrbital",
      "entity": {
        "name": "ServiceNotificationHub",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "recipient",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "messageBody",
            "type": "string"
          },
          {
            "name": "channel",
            "type": "string",
            "default": "email"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceNotificationHubNotificationHub",
          "category": "interaction",
          "linkedEntity": "ServiceNotificationHub",
          "emits": [
            {
              "event": "ServiceNotificationHubLoaded",
              "description": "Fired when ServiceNotificationHub finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "recipient",
                  "type": "string"
                },
                {
                  "name": "subject",
                  "type": "string"
                },
                {
                  "name": "messageBody",
                  "type": "string"
                },
                {
                  "name": "channel",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceNotificationHubLoadFailed",
              "description": "Fired when ServiceNotificationHub fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_EMAIL",
                "name": "Send Email"
              },
              {
                "key": "SEND_SMS",
                "name": "Send Sms"
              },
              {
                "key": "SEND_WHATSAPP",
                "name": "Send Whatsapp"
              },
              {
                "key": "SENT",
                "name": "Sent"
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceNotificationHubLoaded",
                "name": "ServiceNotificationHub loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "recipient",
                    "type": "string"
                  },
                  {
                    "name": "subject",
                    "type": "string"
                  },
                  {
                    "name": "messageBody",
                    "type": "string"
                  },
                  {
                    "name": "channel",
                    "type": "string"
                  },
                  {
                    "name": "sendStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceNotificationHubLoadFailed",
                "name": "ServiceNotificationHub load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceNotificationHub",
                    {
                      "emit": {
                        "failure": "ServiceNotificationHubLoadFailed",
                        "success": "ServiceNotificationHubLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceNotificationHub Notification Hub"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email or phone number"
                        },
                        {
                          "type": "input",
                          "placeholder": "Notification subject"
                        },
                        {
                          "placeholder": "Write your message...",
                          "type": "textarea"
                        },
                        {
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Email",
                              "action": "SEND_EMAIL",
                              "icon": "mail",
                              "variant": "primary"
                            },
                            {
                              "icon": "message-circle",
                              "type": "button",
                              "variant": "secondary",
                              "action": "SEND_SMS",
                              "label": "SMS"
                            },
                            {
                              "type": "button",
                              "action": "SEND_WHATSAPP",
                              "icon": "phone",
                              "variant": "secondary",
                              "label": "WhatsApp"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_EMAIL",
                "effects": [
                  [
                    "set",
                    "@entity.channel",
                    "email"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Sending notification...",
                      "message": "Delivering servicenotificationhub notification...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "to": "@entity.recipient",
                      "body": "@entity.messageBody",
                      "subject": "@entity.subject"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_SMS",
                "effects": [
                  [
                    "set",
                    "@entity.channel",
                    "sms"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Sending notification...",
                      "type": "loading-state",
                      "message": "Delivering servicenotificationhub notification..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "body": "@entity.messageBody",
                      "to": "@entity.recipient"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_WHATSAPP",
                "effects": [
                  [
                    "set",
                    "@entity.channel",
                    "whatsapp"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delivering servicenotificationhub notification...",
                      "type": "loading-state",
                      "title": "Sending notification..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendWhatsApp",
                    {
                      "body": "@entity.messageBody",
                      "to": "@entity.recipient"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Notification sent successfully"
                        },
                        {
                          "action": "RESET",
                          "variant": "ghost",
                          "label": "Send Another",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "error-state",
                          "message": "Could not deliver the notification.",
                          "title": "Send Failed",
                          "onRetry": "RETRY"
                        },
                        {
                          "children": [
                            {
                              "icon": "refresh-cw",
                              "type": "button",
                              "label": "Retry",
                              "variant": "primary",
                              "action": "RETRY"
                            },
                            {
                              "type": "button",
                              "label": "Reset",
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "action": "RESET"
                            }
                          ],
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "content": "ServiceNotificationHub Notification Hub",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email or phone number"
                        },
                        {
                          "placeholder": "Notification subject",
                          "type": "input"
                        },
                        {
                          "placeholder": "Write your message...",
                          "type": "textarea"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "action": "SEND_EMAIL",
                              "icon": "mail",
                              "type": "button",
                              "label": "Email",
                              "variant": "primary"
                            },
                            {
                              "action": "SEND_SMS",
                              "variant": "secondary",
                              "type": "button",
                              "label": "SMS",
                              "icon": "message-circle"
                            },
                            {
                              "icon": "phone",
                              "variant": "secondary",
                              "action": "SEND_WHATSAPP",
                              "type": "button",
                              "label": "WhatsApp"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "stretch",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "bell",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceNotificationHub Notification Hub"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email or phone number"
                        },
                        {
                          "type": "input",
                          "placeholder": "Notification subject"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "action": "SEND_EMAIL",
                              "variant": "primary",
                              "type": "button",
                              "label": "Email",
                              "icon": "mail"
                            },
                            {
                              "type": "button",
                              "variant": "secondary",
                              "label": "SMS",
                              "action": "SEND_SMS",
                              "icon": "message-circle"
                            },
                            {
                              "icon": "phone",
                              "action": "SEND_WHATSAPP",
                              "label": "WhatsApp",
                              "type": "button",
                              "variant": "secondary"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "content": "ServiceNotificationHub Notification Hub",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email or phone number"
                        },
                        {
                          "type": "input",
                          "placeholder": "Notification subject"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "children": [
                            {
                              "icon": "mail",
                              "action": "SEND_EMAIL",
                              "variant": "primary",
                              "type": "button",
                              "label": "Email"
                            },
                            {
                              "variant": "secondary",
                              "icon": "message-circle",
                              "label": "SMS",
                              "type": "button",
                              "action": "SEND_SMS"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "action": "SEND_WHATSAPP",
                              "label": "WhatsApp",
                              "icon": "phone"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "align": "stretch",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceNotificationHubPage",
          "path": "/servicenotificationhubs",
          "traits": [
            {
              "ref": "ServiceNotificationHubNotificationHub"
            }
          ]
        }
      ]
    }
  ]
}