{
  "name": "std-agent-rag",
  "version": "1.0.0",
  "description": "std-agent-rag as a Function",
  "orbitals": [
    {
      "name": "AgentRagOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-agent-search",
          "as": "AgentSearch"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "AgentRag",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "context",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryHits",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "searchHits",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "language",
            "type": "string",
            "default": ""
          },
          {
            "name": "resultCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "results",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentRagRag",
          "category": "interaction",
          "linkedEntity": "AgentRag",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "retrieving"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "RETRIEVAL_DONE",
                "name": "Retrieval Done",
                "payload": [
                  {
                    "name": "context",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "memoryHits",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "searchHits",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GENERATION_DONE",
                "name": "Generation Done",
                "payload": [
                  {
                    "name": "response",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "RAG Pipeline",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Enter a query to retrieve context and generate a response",
                                  "variant": "body"
                                },
                                {
                                  "type": "form-section",
                                  "mode": "edit",
                                  "submitEvent": "GENERATE",
                                  "fields": [
                                    "query"
                                  ],
                                  "entity": "AgentRag"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "retrieving",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "retrieving"
                  ],
                  [
                    "agent/recall",
                    "@entity.query",
                    5.0
                  ],
                  [
                    "agent/search-code",
                    "@entity.query"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "search",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Retrieving context..."
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Recalling memories",
                              "type": "badge"
                            },
                            {
                              "label": "Searching code",
                              "type": "badge"
                            }
                          ],
                          "gap": "md"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "generating",
                "event": "RETRIEVAL_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.context",
                    "@payload.context"
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    "@payload.memoryHits"
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    "@payload.searchHits"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Context:\n",
                      "@entity.context",
                      "\n\nQuery: ",
                      "@entity.query",
                      "\n\nProvide a comprehensive answer based on the retrieved context."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "cpu"
                        },
                        {
                          "content": "Generating response...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "justify": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.memoryHits"
                                ],
                                " memories"
                              ]
                            },
                            {
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.searchHits"
                                ],
                                " code hits"
                              ],
                              "type": "badge"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "RAG Pipeline Error",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "message": "@entity.error",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "label": "Try Again",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "RESET"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "GENERATION_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.response"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "RAG query: ",
                      "@entity.query"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle"
                                },
                                {
                                  "content": "RAG Complete",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "type": "button",
                              "action": "RESET",
                              "label": "New Query",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Memory Hits",
                              "icon": "brain",
                              "value": "@entity.memoryHits",
                              "type": "stat-display"
                            },
                            {
                              "icon": "code",
                              "label": "Code Hits",
                              "value": "@entity.searchHits",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Query"
                                },
                                {
                                  "content": "@entity.query",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Response"
                                },
                                {
                                  "content": "@entity.response",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Retrieved Context",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.context",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "RAG Pipeline Error",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "type": "alert",
                          "message": "@entity.error",
                          "variant": "error"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary",
                          "label": "Try Again"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.context",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "variant": "h2",
                              "content": "RAG Pipeline",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Enter a query to retrieve context and generate a response",
                                  "variant": "body"
                                },
                                {
                                  "type": "form-section",
                                  "mode": "edit",
                                  "submitEvent": "GENERATE",
                                  "fields": [
                                    "query"
                                  ],
                                  "entity": "AgentRag"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Tabs.traits.TabContentTabs",
          "name": "RagTabs",
          "linkedEntity": "AgentRag"
        },
        {
          "ref": "AgentMemory.traits.AgentMemoryBrowse",
          "name": "RagMemoryLifecycle",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentSearch.traits.AgentSearchBrowse",
          "name": "RagSearchLifecycle",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentCompletion.traits.AgentCompletionModal",
          "name": "RagCompletionFlow",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        }
      ],
      "pages": [
        {
          "name": "AgentRagPage",
          "path": "/agentrags",
          "traits": [
            {
              "ref": "AgentRagRag"
            },
            {
              "ref": "RagTabs"
            },
            {
              "ref": "RagMemoryLifecycle"
            },
            {
              "ref": "RagSearchLifecycle"
            },
            {
              "ref": "RagCompletionFlow"
            }
          ]
        }
      ]
    }
  ]
}