{
  "name": "std-agent-rag",
  "version": "1.0.0",
  "description": "std-agent-rag as a Function",
  "orbitals": [
    {
      "name": "AgentRagOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-agent-search",
          "as": "AgentSearch"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "AgentRag",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "context",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryHits",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "searchHits",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "language",
            "type": "string",
            "default": ""
          },
          {
            "name": "resultCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "results",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentRagRag",
          "category": "interaction",
          "linkedEntity": "AgentRag",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "retrieving"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "RETRIEVAL_DONE",
                "name": "Retrieval Done",
                "payload": [
                  {
                    "name": "context",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "memoryHits",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "searchHits",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GENERATION_DONE",
                "name": "Generation Done",
                "payload": [
                  {
                    "name": "response",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "content": "RAG Pipeline",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "Enter a query to retrieve context and generate a response"
                                },
                                {
                                  "entity": "AgentRag",
                                  "submitEvent": "GENERATE",
                                  "type": "form-section",
                                  "mode": "edit",
                                  "fields": [
                                    "query"
                                  ]
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "retrieving",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "retrieving"
                  ],
                  [
                    "agent/recall",
                    "@entity.query",
                    5.0
                  ],
                  [
                    "agent/search-code",
                    "@entity.query"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "type": "typography",
                          "content": "Retrieving context...",
                          "variant": "h3"
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "badge",
                              "label": "Recalling memories"
                            },
                            {
                              "type": "badge",
                              "label": "Searching code"
                            }
                          ],
                          "gap": "md",
                          "justify": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "generating",
                "event": "RETRIEVAL_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.context",
                    "@payload.context"
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    "@payload.memoryHits"
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    "@payload.searchHits"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Context:\n",
                      "@entity.context",
                      "\n\nQuery: ",
                      "@entity.query",
                      "\n\nProvide a comprehensive answer based on the retrieved context."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "cpu",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Generating response..."
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "children": [
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.memoryHits"
                                ],
                                " memories"
                              ]
                            },
                            {
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.searchHits"
                                ],
                                " code hits"
                              ],
                              "type": "badge"
                            }
                          ],
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "size": "lg",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "RAG Pipeline Error",
                          "variant": "h2"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "label": "Try Again",
                          "type": "button",
                          "event": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "GENERATION_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.response"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "RAG query: ",
                      "@entity.query"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "justify": "space-between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "RAG Complete"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "event": "RESET",
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "label": "New Query"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "columns": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "brain",
                              "label": "Memory Hits",
                              "value": "@entity.memoryHits"
                            },
                            {
                              "icon": "code",
                              "type": "stat-display",
                              "label": "Code Hits",
                              "value": "@entity.searchHits"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Query",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.query",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Response"
                                },
                                {
                                  "content": "@entity.response",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Retrieved Context",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.context",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "content": "RAG Pipeline Error",
                          "type": "typography"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary",
                          "event": "RESET",
                          "label": "Try Again"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.context",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "brain",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "content": "RAG Pipeline",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "Enter a query to retrieve context and generate a response"
                                },
                                {
                                  "fields": [
                                    "query"
                                  ],
                                  "submitEvent": "GENERATE",
                                  "type": "form-section",
                                  "mode": "edit",
                                  "entity": "AgentRag"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Tabs.traits.TabContentTabs",
          "name": "RagTabs",
          "linkedEntity": "AgentRag",
          "effects": {
            "INIT": [
              [
                "fetch",
                "AgentRag"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "children": [
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "brain",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "RAG Pipeline"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "onTabChange": "SELECT_TAB",
                      "type": "tabs",
                      "defaultActiveTab": "query",
                      "tabs": [
                        {
                          "label": "Query",
                          "value": "query"
                        },
                        {
                          "label": "Sources",
                          "value": "sources"
                        },
                        {
                          "label": "Response",
                          "value": "response"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "children": [
                            {
                              "variant": "h4",
                              "content": "@item.name",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "content": "@item.query",
                              "variant": "caption",
                              "color": "muted"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm"
                        }
                      ],
                      "entity": "AgentRag",
                      "emptyTitle": "No agentrags yet",
                      "type": "data-grid",
                      "className": "transition-shadow hover:shadow-md cursor-pointer",
                      "emptyIcon": "inbox",
                      "emptyDescription": "Add agentrags to see them here."
                    }
                  ],
                  "gap": "lg",
                  "direction": "vertical"
                }
              ]
            ],
            "SELECT_TAB": [
              [
                "fetch",
                "AgentRag"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "gap": "lg",
                  "children": [
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "brain",
                          "size": "lg"
                        },
                        {
                          "content": "RAG Pipeline",
                          "type": "typography",
                          "variant": "h2"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "activeTab": "@payload.tab",
                      "type": "tabs",
                      "tabs": [
                        {
                          "label": "Query",
                          "value": "query"
                        },
                        {
                          "value": "sources",
                          "label": "Sources"
                        },
                        {
                          "label": "Response",
                          "value": "response"
                        }
                      ],
                      "defaultActiveTab": "query",
                      "onTabChange": "SELECT_TAB"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "h4",
                              "content": "@item.name"
                            },
                            {
                              "variant": "caption",
                              "content": "@item.query",
                              "color": "muted",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "emptyTitle": "No agentrags yet",
                      "entity": "AgentRag",
                      "emptyIcon": "inbox",
                      "type": "data-grid",
                      "className": "transition-shadow hover:shadow-md cursor-pointer",
                      "emptyDescription": "Add agentrags to see them here."
                    }
                  ],
                  "direction": "vertical"
                }
              ]
            ]
          }
        },
        {
          "ref": "AgentMemory.traits.AgentMemoryBrowse",
          "name": "RagMemoryLifecycle",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal",
          "effects": {
            "INIT": [
              [
                "ref",
                "AgentRag"
              ],
              [
                "render-ui",
                "main",
                {
                  "gap": "lg",
                  "className": "max-w-5xl mx-auto w-full",
                  "children": [
                    {
                      "gap": "md",
                      "justify": "space-between",
                      "align": "center",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "brain"
                            },
                            {
                              "type": "typography",
                              "content": "AgentRag Manager",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "event": "MEMORIZE",
                              "icon": "plus",
                              "label": "Memorize",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "label": "Recall",
                              "event": "RECALL",
                              "variant": "secondary",
                              "icon": "search"
                            },
                            {
                              "label": "Decay All",
                              "icon": "clock",
                              "type": "button",
                              "event": "DECAY",
                              "variant": "ghost"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "emptyTitle": "No memories yet",
                      "type": "data-grid",
                      "itemActions": [
                        {
                          "label": "Pin",
                          "size": "sm",
                          "variant": "ghost",
                          "event": "PIN"
                        },
                        {
                          "size": "sm",
                          "variant": "ghost",
                          "label": "Reinforce",
                          "event": "REINFORCE"
                        },
                        {
                          "event": "FORGET",
                          "label": "Forget",
                          "size": "sm",
                          "variant": "danger"
                        }
                      ],
                      "entity": "AgentRag",
                      "columns": [
                        {
                          "label": "Content",
                          "variant": "h4",
                          "name": "content",
                          "icon": "brain"
                        },
                        {
                          "colorMap": {
                            "error": "destructive",
                            "scheduled": "warning",
                            "cancelled": "destructive",
                            "active": "success",
                            "draft": "warning",
                            "inactive": "neutral",
