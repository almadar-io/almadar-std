{
  "name": "std-turn-based-battle",
  "version": "1.0.0",
  "description": "std-turn-based-battle as a Function",
  "orbitals": [
    {
      "name": "BattleUnitOrbital",
      "entity": {
        "name": "BattleUnit",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "turn",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "BattleUnitBattleFlow",
          "category": "interaction",
          "linkedEntity": "BattleUnit",
          "emits": [
            {
              "event": "BattleUnitLoaded",
              "description": "Fired when BattleUnit finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "turn",
                  "type": "number"
                },
                {
                  "name": "score",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BattleUnitLoadFailed",
              "description": "Fired when BattleUnit fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "END_TURN",
                "name": "End Turn"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "BattleUnitLoaded",
                "name": "BattleUnit loaded"
              },
              {
                "key": "BattleUnitLoadFailed",
                "name": "BattleUnit load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BattleUnit",
                    {
                      "emit": {
                        "failure": "BattleUnitLoadFailed",
                        "success": "BattleUnitLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Turn-Based Strategy",
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "label": "Start Battle",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "title": "Battle Arena"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "value": "@entity.turn",
                          "label": "Turn"
                        },
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        }
                      ],
                      "type": "game-hud"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "END_TURN",
                "effects": [
                  [
                    "set",
                    "@entity.turn",
                    [
                      "+",
                      "@entity.turn",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "label": "Turn",
                          "value": "@entity.turn"
                        },
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        }
                      ],
                      "type": "game-hud"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "menuItems": [
                        {
                          "variant": "primary",
                          "label": "Resume",
                          "event": "RESUME"
                        },
                        {
                          "event": "RESTART",
                          "label": "Quit",
                          "variant": "ghost"
                        }
                      ],
                      "type": "game-menu",
                      "title": "Paused"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Battle Over",
                      "type": "game-over-screen",
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "event": "RESTART",
                          "variant": "primary"
                        },
                        {
                          "label": "Main Menu",
                          "event": "RESTART",
                          "variant": "secondary"
                        }
                      ],
                      "stats": [
                        {
                          "value": "@entity.turn",
                          "label": "Turns"
                        },
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-hud",
                      "stats": [
                        {
                          "value": "@entity.turn",
                          "label": "Turn"
                        },
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-hud",
                      "stats": [
                        {
                          "value": "@entity.turn",
                          "label": "Turn"
                        },
                        {
                          "value": "@entity.score",
                          "label": "Score"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Battle Arena",
                      "menuItems": [
                        {
                          "label": "Start Battle",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "subtitle": "Turn-Based Strategy",
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "label": "Start Battle",
                          "variant": "primary"
                        }
                      ],
                      "title": "Battle Arena",
                      "subtitle": "Turn-Based Strategy",
                      "type": "game-menu"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "BattleUnitCombatLog",
          "category": "interaction",
          "linkedEntity": "BattleUnit",
          "emits": [
            {
              "event": "BattleUnitLoaded",
              "description": "Fired when BattleUnit finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "turn",
                  "type": "number"
                },
                {
                  "name": "score",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BattleUnitLoadFailed",
              "description": "Fired when BattleUnit fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOG_EVENT",
                "name": "Log Event",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "BattleUnitLoaded",
                "name": "BattleUnit loaded"
              },
              {
                "key": "BattleUnitLoadFailed",
                "name": "BattleUnit load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BattleUnit",
                    {
                      "emit": {
                        "success": "BattleUnitLoaded",
                        "failure": "BattleUnitLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "LOG_EVENT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "maxVisible": 10.0,
                      "type": "combat-log",
                      "showTimestamps": true,
                      "autoScroll": true,
                      "title": "Combat Log",
                      "events": "@BattleUnit"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "maxVisible": 10.0,
                      "type": "combat-log",
                      "events": "@BattleUnit",
                      "showTimestamps": true,
                      "autoScroll": true,
                      "title": "Combat Log"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BattleUnitPage",
          "path": "/battleunits",
          "traits": [
            {
              "ref": "BattleUnitBattleFlow"
            },
            {
              "ref": "BattleUnitCombatLog"
            }
          ]
        }
      ]
    }
  ]
}