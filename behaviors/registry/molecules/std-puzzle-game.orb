{
  "name": "std-puzzle-game",
  "version": "1.0.0",
  "description": "std-puzzle-game as a Function",
  "orbitals": [
    {
      "name": "PuzzleBoardOrbital",
      "entity": {
        "name": "PuzzleBoard",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "highScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "combo",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "multiplier",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "moves",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "PuzzleBoardPuzzleFlow",
          "category": "interaction",
          "linkedEntity": "PuzzleBoard",
          "emits": [
            {
              "event": "PuzzleBoardLoaded",
              "description": "Fired when PuzzleBoard finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "highScore",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                },
                {
                  "name": "moves",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PuzzleBoardLoadFailed",
              "description": "Fired when PuzzleBoard fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "MOVE",
                "name": "Move"
              },
              {
                "key": "HINT",
                "name": "Hint"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "PuzzleBoardLoaded",
                "name": "PuzzleBoard loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  },
                  {
                    "name": "moves",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PuzzleBoardLoadFailed",
                "name": "PuzzleBoard load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PuzzleBoard",
                    {
                      "emit": {
                        "failure": "PuzzleBoardLoadFailed",
                        "success": "PuzzleBoardLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Puzzle Challenge",
                      "type": "game-menu",
                      "title": "Puzzle",
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start Puzzle"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "fps": 60.0,
                      "width": 800.0,
                      "type": "game-canvas-2d",
                      "height": 600.0
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "MOVE",
                "effects": [
                  [
                    "set",
                    "@entity.moves",
                    [
                      "+",
                      "@entity.moves",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "fps": 60.0,
                      "width": 800.0,
                      "type": "game-canvas-2d",
                      "height": 600.0
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "HINT"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "title": "Paused",
                      "menuItems": [
                        {
                          "event": "RESUME",
                          "variant": "primary",
                          "label": "Resume"
                        },
                        {
                          "event": "RESTART",
                          "label": "Quit",
                          "variant": "ghost"
                        }
                      ],
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Puzzle Complete",
                      "menuItems": [
                        {
                          "event": "RESTART",
                          "variant": "primary",
                          "label": "Play Again"
                        },
                        {
                          "variant": "secondary",
                          "event": "RESTART",
                          "label": "Main Menu"
                        }
                      ],
                      "type": "game-over-screen",
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "label": "Moves",
                          "value": "@entity.moves"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": 600.0,
                      "fps": 60.0,
                      "width": 800.0,
                      "type": "game-canvas-2d"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": 600.0,
                      "fps": 60.0,
                      "width": 800.0,
                      "type": "game-canvas-2d"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start Puzzle"
                        }
                      ],
                      "subtitle": "Puzzle Challenge",
                      "type": "game-menu",
                      "title": "Puzzle"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Start Puzzle",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "title": "Puzzle",
                      "subtitle": "Puzzle Challenge",
                      "type": "game-menu"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PuzzleBoardPuzzleScore",
          "category": "interaction",
          "linkedEntity": "PuzzleBoard",
          "emits": [
            {
              "event": "PuzzleBoardLoaded",
              "description": "Fired when PuzzleBoard finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "highScore",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                },
                {
                  "name": "moves",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PuzzleBoardLoadFailed",
              "description": "Fired when PuzzleBoard fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_SCORE",
                "name": "Add Score",
                "payload": [
                  {
                    "name": "points",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PuzzleBoardLoaded",
                "name": "PuzzleBoard loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  },
                  {
                    "name": "moves",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PuzzleBoardLoadFailed",
                "name": "PuzzleBoard load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PuzzleBoard",
                    {
                      "emit": {
                        "success": "PuzzleBoardLoaded",
                        "failure": "PuzzleBoardLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "score": "@entity.score",
                      "multiplier": "@entity.multiplier",
                      "level": "@entity.level",
                      "type": "score-board",
                      "highScore": "@entity.highScore",
                      "combo": "@entity.combo"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "score": "@entity.score",
                      "highScore": "@entity.highScore",
                      "combo": "@entity.combo",
                      "level": "@entity.level",
                      "type": "score-board",
                      "multiplier": "@entity.multiplier"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "combo": "@entity.combo",
                      "level": "@entity.level",
                      "score": "@entity.score",
                      "multiplier": "@entity.multiplier",
                      "highScore": "@entity.highScore",
                      "type": "score-board"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PuzzleBoardPage",
          "path": "/puzzleboards",
          "traits": [
            {
              "ref": "PuzzleBoardPuzzleFlow"
            },
            {
              "ref": "PuzzleBoardPuzzleScore"
            }
          ]
        }
      ]
    }
  ]
}