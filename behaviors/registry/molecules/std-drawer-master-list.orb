{
  "name": "std-drawer-master-list",
  "version": "1.0.0",
  "description": "std-drawer-master-list as a Function",
  "orbitals": [
    {
      "name": "DrawerMasterOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "DrawerMasterItem",
        "collection": "drawermasteritems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DrawerMasterBrowse",
          "linkedEntity": "DrawerMasterItem"
        },
        {
          "ref": "Drawer.traits.DrawerContentDrawer",
          "name": "DrawerMasterDrawer",
          "linkedEntity": "DrawerMasterItem"
        },
        {
          "name": "DrawerMasterLayout",
          "category": "interaction",
          "linkedEntity": "DrawerMasterItem",
          "emits": [
            {
              "event": "DrawerMasterItemLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DrawerMasterItemLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[DrawerMasterItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DrawerMasterItemLoadFailed",
                "name": "DrawerMasterItem load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DrawerMasterItemLoaded",
                "name": "DrawerMasterItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[DrawerMasterItem]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DrawerMasterItem",
                    {
                      "emit": {
                        "failure": "DrawerMasterItemLoadFailed",
                        "success": "DrawerMasterItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "horizontal",
                      "children": [
                        {
                          "children": [
                            "@trait.DrawerMasterBrowse"
                          ],
                          "type": "box"
                        },
                        {
                          "type": "box",
                          "children": [
                            "@trait.DrawerMasterDrawer"
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DrawerMaster",
          "path": "/drawer-master",
          "traits": [
            {
              "ref": "DrawerMasterLayout"
            }
          ]
        }
      ]
    }
  ]
}