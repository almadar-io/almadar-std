{
  "name": "std-drawer-master-list",
  "version": "1.0.0",
  "description": "std-drawer-master-list as a Function",
  "orbitals": [
    {
      "name": "DrawerMasterOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "DrawerMasterItem",
        "collection": "drawermasteritems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DrawerMasterBrowse",
          "linkedEntity": "DrawerMasterItem"
        },
        {
          "ref": "Drawer.traits.DrawerContentDrawer",
          "name": "DrawerMasterDrawer",
          "linkedEntity": "DrawerMasterItem",
          "listens": [
            {
              "event": "DrawerMasterBrowse.SELECT",
              "triggers": "OPEN",
              "payloadMapping": {
                "id": "@payload.id"
              }
            }
          ]
        },
        {
          "name": "DrawerMasterLayout",
          "category": "interaction",
          "linkedEntity": "DrawerMasterItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DrawerMasterItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "horizontal",
                      "type": "stack",
                      "children": [
                        {
                          "type": "box",
                          "style": {
                            "flex": "3"
                          },
                          "children": [
                            "@trait.DrawerMasterBrowse"
                          ]
                        },
                        {
                          "style": {
                            "flex": "2"
                          },
                          "children": [
                            "@trait.DrawerMasterDrawer"
                          ],
                          "type": "box"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DrawerMaster",
          "path": "/drawer-master",
          "traits": [
            {
              "ref": "DrawerMasterLayout"
            }
          ]
        }
      ]
    }
  ]
}