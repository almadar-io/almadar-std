{
  "name": "std-platformer-game",
  "version": "1.0.0",
  "description": "std-platformer-game as a Function",
  "orbitals": [
    {
      "name": "PlatLevelOrbital",
      "entity": {
        "name": "PlatLevel",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lives",
            "type": "number",
            "default": 3.0
          },
          {
            "name": "player",
            "type": "string",
            "default": ""
          },
          {
            "name": "platforms",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PlatLevelPlatformerFlow",
          "category": "interaction",
          "linkedEntity": "PlatLevel",
          "emits": [
            {
              "event": "PlatLevelLoaded",
              "description": "Fired when PlatLevel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "lives",
                  "type": "number"
                },
                {
                  "name": "player",
                  "type": "string"
                },
                {
                  "name": "platforms",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PlatLevelLoadFailed",
              "description": "Fired when PlatLevel fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "PlatLevelLoaded",
                "name": "PlatLevel loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "lives",
                    "type": "number"
                  },
                  {
                    "name": "player",
                    "type": "string"
                  },
                  {
                    "name": "platforms",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PlatLevelLoadFailed",
                "name": "PlatLevel load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatLevel",
                    {
                      "emit": {
                        "failure": "PlatLevelLoadFailed",
                        "success": "PlatLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Side-Scrolling Adventure",
                      "menuItems": [
                        {
                          "event": "START",
                          "label": "Start Game",
                          "variant": "primary"
                        }
                      ],
                      "title": "Platformer",
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "canvasHeight": 400.0,
                      "stopEvent": "STOP",
                      "bgColor": "#1a1a2e",
                      "worldHeight": 400.0,
                      "rightEvent": "RIGHT",
                      "leftEvent": "LEFT",
                      "jumpEvent": "JUMP",
                      "type": "platformer-canvas",
                      "followCamera": true,
                      "worldWidth": 2400.0,
                      "canvasWidth": 800.0
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "LEFT"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "RIGHT"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "JUMP"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "STOP"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "title": "Paused",
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "event": "RESUME",
                          "variant": "primary",
                          "label": "Resume"
                        },
                        {
                          "variant": "ghost",
                          "label": "Quit",
                          "event": "RESTART"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "event": "RESTART",
                          "variant": "primary"
                        },
                        {
                          "event": "RESTART",
                          "label": "Main Menu",
                          "variant": "secondary"
                        }
                      ],
                      "type": "game-over-screen",
                      "title": "Game Over",
                      "stats": [
                        {
                          "value": "@entity.score",
                          "label": "Score"
                        },
                        {
                          "label": "Lives",
                          "value": "@entity.lives"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stopEvent": "STOP",
                      "rightEvent": "RIGHT",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "type": "platformer-canvas",
                      "bgColor": "#1a1a2e",
                      "canvasHeight": 400.0,
                      "canvasWidth": 800.0,
                      "followCamera": true,
                      "worldHeight": 400.0,
                      "worldWidth": 2400.0
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "canvasWidth": 800.0,
                      "worldWidth": 2400.0,
                      "jumpEvent": "JUMP",
                      "worldHeight": 400.0,
                      "stopEvent": "STOP",
                      "canvasHeight": 400.0,
                      "type": "platformer-canvas",
                      "leftEvent": "LEFT",
                      "bgColor": "#1a1a2e",
                      "rightEvent": "RIGHT",
                      "followCamera": true
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start Game"
                        }
                      ],
                      "title": "Platformer",
                      "subtitle": "Side-Scrolling Adventure",
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "variant": "primary",
                          "event": "START",
                          "label": "Start Game"
                        }
                      ],
                      "subtitle": "Side-Scrolling Adventure",
                      "title": "Platformer"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PlatLevelPlatformerCanvas",
          "category": "interaction",
          "linkedEntity": "PlatLevel",
          "emits": [
            {
              "event": "PlatLevelLoaded",
              "description": "Fired when PlatLevel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "lives",
                  "type": "number"
                },
                {
                  "name": "player",
                  "type": "string"
                },
                {
                  "name": "platforms",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PlatLevelLoadFailed",
              "description": "Fired when PlatLevel fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PlatLevelLoaded",
                "name": "PlatLevel loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "lives",
                    "type": "number"
                  },
                  {
                    "name": "player",
                    "type": "string"
                  },
                  {
                    "name": "platforms",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PlatLevelLoadFailed",
                "name": "PlatLevel load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatLevel",
                    {
                      "emit": {
                        "success": "PlatLevelLoaded",
                        "failure": "PlatLevelLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "running",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "worldWidth": 2400.0,
                      "jumpEvent": "JUMP",
                      "rightEvent": "RIGHT",
                      "stopEvent": "STOP",
                      "player": "@entity.player",
                      "leftEvent": "LEFT",
                      "platforms": "@entity.platforms",
                      "canvasWidth": 800.0,
                      "type": "platformer-canvas",
                      "canvasHeight": 400.0,
                      "worldHeight": 400.0,
                      "followCamera": true,
                      "bgColor": "#1a1a2e"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "LEFT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "RIGHT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "JUMP"
              },
              {
                "from": "running",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "worldWidth": 2400.0,
                      "type": "platformer-canvas",
                      "jumpEvent": "JUMP",
                      "stopEvent": "STOP",
                      "platforms": "@entity.platforms",
                      "canvasWidth": 800.0,
                      "leftEvent": "LEFT",
                      "bgColor": "#1a1a2e",
                      "canvasHeight": 400.0,
                      "player": "@entity.player",
                      "followCamera": true,
                      "rightEvent": "RIGHT",
                      "worldHeight": 400.0
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PlatLevelPage",
          "path": "/platlevels",
          "traits": [
            {
              "ref": "PlatLevelPlatformerFlow"
            },
            {
              "ref": "PlatLevelPlatformerCanvas"
            }
          ]
        }
      ]
    }
  ]
}