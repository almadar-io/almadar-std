                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "head",
                    "type": "string"
                  },
                  {
                    "name": "base",
                    "type": "string"
                  },
                  {
                    "name": "prUrl",
                    "type": "string"
                  },
                  {
                    "name": "cacheKey",
                    "type": "string"
                  },
                  {
                    "name": "cacheValue",
                    "type": "string"
                  },
                  {
                    "name": "bucket",
