                  },
                  {
                    "name": "fileKey",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "toolStatus",
                    "type": "string"
                  },
                  {
                    "name": "activeTab",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitLoadFailed",
                "name": "ServiceDevopsToolkit load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "redisIdle",
                "to": "redisIdle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceDevopsToolkit",
                    {
                      "emit": {
                        "failure": "ServiceDevopsToolkitLoadFailed",
                        "success": "ServiceDevopsToolkitLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "database",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Redis Cache",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "cache-key"
                        },
                        {
                          "placeholder": "cache-value",
                          "type": "input"
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "GET_KEY",
                              "icon": "download",
                              "type": "button",
                              "variant": "primary",
                              "label": "Get"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "SET_KEY",
                              "label": "Set",
                              "icon": "upload"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "icon": "trash-2",
                              "action": "DELETE_KEY",
                              "type": "button"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "redisIdle",
                "to": "redisExecuting",
                "event": "GET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Running Redis operation...",
                      "type": "loading-state",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "get",
                    {
                      "key": "@entity.cacheKey"
                    },
                    {
                      "emit": {
                        "failure": "ServiceDevopsToolkitRedisFailed",
                        "success": "ServiceDevopsToolkitRedisCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "redisIdle",
                "to": "redisExecuting",
                "event": "SET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Running Redis operation...",
                      "type": "loading-state",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "set",
                    {
                      "key": "@entity.cacheKey",
                      "value": "@entity.cacheValue"
                    },
                    {
                      "emit": {
                        "success": "ServiceDevopsToolkitRedisCompleted",
                        "failure": "ServiceDevopsToolkitRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "redisIdle",
                "to": "redisExecuting",
                "event": "DELETE_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Executing...",
                      "message": "Running Redis operation...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "delete",
                    {
                      "key": "@entity.cacheKey"
                    },
                    {
                      "emit": {
                        "success": "ServiceDevopsToolkitRedisCompleted",
                        "failure": "ServiceDevopsToolkitRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "redisExecuting",
                "to": "redisComplete",
                "event": "REDIS_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.toolStatus",
                    "redis-complete"
                  ],
                  [
                    "render-ui",
                    "main",
