{
  "name": "std-service-devops-toolkit",
  "version": "1.0.0",
  "description": "std-service-devops-toolkit as a Function",
  "orbitals": [
    {
      "name": "ServiceDevopsToolkitOrbital",
      "entity": {
        "name": "ServiceDevopsToolkit",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "head",
            "type": "string",
            "default": ""
          },
          {
            "name": "base",
            "type": "string",
            "default": "main"
          },
          {
            "name": "prUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "cacheKey",
            "type": "string",
            "default": ""
          },
          {
            "name": "cacheValue",
            "type": "string",
            "default": ""
          },
          {
            "name": "bucket",
            "type": "string",
            "default": "uploads"
          },
          {
            "name": "fileKey",
            "type": "string",
            "default": ""
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "activeTab",
            "type": "string",
            "default": "github"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceDevopsToolkitGithub",
          "category": "interaction",
          "linkedEntity": "ServiceDevopsToolkit",
          "emits": [
            {
              "event": "ServiceDevopsToolkitLoaded",
              "description": "Fired when ServiceDevopsToolkit finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "head",
                  "type": "string"
                },
                {
                  "name": "base",
                  "type": "string"
                },
                {
                  "name": "prUrl",
                  "type": "string"
                },
                {
                  "name": "cacheKey",
                  "type": "string"
                },
                {
                  "name": "cacheValue",
                  "type": "string"
                },
                {
                  "name": "bucket",
                  "type": "string"
                },
                {
                  "name": "fileKey",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "toolStatus",
                  "type": "string"
                },
                {
                  "name": "activeTab",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitLoadFailed",
              "description": "Fired when ServiceDevopsToolkit fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitGithubCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitGithubFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitRedisCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitRedisFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitStorageCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceDevopsToolkitStorageFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ghIdle",
                "isInitial": true
              },
              {
                "name": "creatingPR"
              },
              {
                "name": "prCreated"
              },
              {
                "name": "ghError"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PR",
                "name": "Create Pr"
              },
              {
                "key": "PR_CREATED",
                "name": "Pr Created",
                "payload": [
                  {
                    "name": "url",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GH_FAILED",
                "name": "Gh Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GH_RESET",
                "name": "Gh Reset"
              },
              {
                "key": "GH_RETRY",
                "name": "Gh Retry"
              },
              {
                "key": "ServiceDevopsToolkitLoaded",
                "name": "ServiceDevopsToolkit loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "head",
                    "type": "string"
                  },
                  {
                    "name": "base",
                    "type": "string"
                  },
                  {
                    "name": "prUrl",
                    "type": "string"
                  },
                  {
                    "name": "cacheKey",
                    "type": "string"
                  },
                  {
                    "name": "cacheValue",
                    "type": "string"
                  },
                  {
                    "name": "bucket",
                    "type": "string"
                  },
                  {
                    "name": "fileKey",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "toolStatus",
                    "type": "string"
                  },
                  {
                    "name": "activeTab",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitLoadFailed",
                "name": "ServiceDevopsToolkit load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitGithubCompleted",
                "name": "ServiceDevopsToolkit github completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitGithubFailed",
                "name": "ServiceDevopsToolkit github failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitRedisCompleted",
                "name": "ServiceDevopsToolkit redis completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitRedisFailed",
                "name": "ServiceDevopsToolkit redis failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitStorageCompleted",
                "name": "ServiceDevopsToolkit storage completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceDevopsToolkitStorageFailed",
                "name": "ServiceDevopsToolkit storage failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ghIdle",
                "to": "ghIdle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceDevopsToolkit",
                    {
                      "emit": {
                        "success": "ServiceDevopsToolkitLoaded",
                        "failure": "ServiceDevopsToolkitLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "git-pull-request",
                              "type": "icon"
                            },
                            {
                              "content": "GitHub: Create PR",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "PR title",
                          "type": "input"
                        },
                        {
                          "placeholder": "Describe your changes...",
                          "type": "textarea"
                        },
                        {
                          "type": "input",
                          "placeholder": "feature-branch"
                        },
                        {
                          "placeholder": "main",
                          "type": "input"
                        },
                        {
                          "label": "Create PR",
                          "action": "CREATE_PR",
                          "icon": "git-pull-request",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ghIdle",
                "to": "creatingPR",
                "event": "CREATE_PR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Creating pull request...",
                      "message": "Submitting your PR to GitHub."
                    }
                  ],
                  [
                    "call-service",
                    "github",
                    "createPR",
                    {
                      "title": "@entity.title",
                      "body": "@entity.body",
                      "base": "@entity.base",
                      "head": "@entity.head"
                    },
                    {
                      "emit": {
                        "success": "ServiceDevopsToolkitGithubCompleted",
                        "failure": "ServiceDevopsToolkitGithubFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "prCreated",
                "event": "PR_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.prUrl",
                    "@payload.url"
                  ],
                  [
                    "set",
                    "@entity.toolStatus",
                    "pr-created"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "success",
                          "message": "Pull request created!",
                          "type": "alert"
                        },
                        {
                          "content": "@entity.prUrl",
                          "type": "typography",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "action": "GH_RESET",
                          "variant": "ghost",
                          "label": "Create Another",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "ghError",
                "event": "GH_FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.toolStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "onRetry": "GH_RETRY",
                      "message": "@entity.error",
                      "title": "PR Creation Failed"
                    }
                  ]
                ]
              },
              {
                "from": "prCreated",
                "to": "ghIdle",
                "event": "GH_RESET",
                "effects": [
                  [
                    "set",
                    "@entity.toolStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "git-pull-request",
                              "type": "icon"
                            },
                            {
                              "content": "GitHub: Create PR",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "PR title"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Describe your changes..."
                        },
                        {
                          "placeholder": "feature-branch",
                          "type": "input"
                        },
                        {
                          "placeholder": "main",
                          "type": "input"
                        },
                        {
                          "action": "CREATE_PR",
                          "type": "button",
                          "variant": "primary",
                          "icon": "git-pull-request",
                          "label": "Create PR"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "ghError",
                "to": "ghIdle",
                "event": "GH_RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.toolStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "git-pull-request",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "GitHub: Create PR"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "PR title",
                          "type": "input"
                        },
                        {
                          "placeholder": "Describe your changes...",
                          "type": "textarea"
                        },
                        {
                          "placeholder": "feature-branch",
                          "type": "input"
                        },
                        {
                          "type": "input",
                          "placeholder": "main"
                        },
                        {
                          "action": "CREATE_PR",
                          "type": "button",
                          "label": "Create PR",
                          "variant": "primary",
                          "icon": "git-pull-request"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceDevopsToolkitRedis",
          "category": "interaction",
          "linkedEntity": "ServiceDevopsToolkit",
          "emits": [
            {
              "event": "ServiceDevopsToolkitLoaded",
              "description": "Fired when ServiceDevopsToolkit finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
