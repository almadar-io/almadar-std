{
  "name": "std-service-content-pipeline",
  "version": "1.0.0",
  "description": "std-service-content-pipeline as a Function",
  "orbitals": [
    {
      "name": "ServiceContentPipelineOrbital",
      "entity": {
        "name": "ServiceContentPipeline",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "summary",
            "type": "string",
            "default": ""
          },
          {
            "name": "pipelineStatus",
            "type": "string",
            "default": "idle",
            "values": [
              "idle",
              "searching",
              "results",
              "summarizing",
              "complete",
              "error"
            ]
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceContentPipelinePipeline",
          "category": "interaction",
          "linkedEntity": "ServiceContentPipeline",
          "emits": [
            {
              "event": "SearchComplete",
              "description": "Fired after youtube search completes with narrow result rows (projected into the entity shape)",
              "scope": "internal",
              "payload": [
                {
                  "name": "results",
                  "type": "[ServiceContentPipeline]"
                }
              ]
            },
            {
              "event": "ServiceContentPipelineLlmCompleted",
              "description": "Fired when llm.summarize succeeds; result carries the summary text",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceContentPipelineLlmFailed",
              "description": "Fired when llm service call fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceContentPipelineYoutubeCompleted",
              "description": "Fired when youtube.search/getVideo succeeds; result is the raw service response",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceContentPipelineYoutubeFailed",
              "description": "Fired when youtube service call fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              },
              {
                "name": "summarizing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payload": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SearchComplete",
                "name": "Search complete",
                "payload": [
                  {
                    "name": "results",
                    "type": "[ServiceContentPipeline]"
                  }
                ]
              },
              {
                "key": "ServiceContentPipelineYoutubeFailed",
                "name": "ServiceContentPipeline youtube failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_AND_SUMMARIZE",
                "name": "Select And Summarize",
                "payload": [
                  {
                    "name": "videoId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "VIDEO_FETCHED",
                "name": "Video Fetched",
                "payload": [
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SUMMARY_COMPLETE",
                "name": "Summary Complete",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ServiceContentPipelineLlmFailed",
                "name": "ServiceContentPipeline llm failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceContentPipelineLlmCompleted",
                "name": "ServiceContentPipeline llm completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceContentPipelineYoutubeCompleted",
                "name": "ServiceContentPipeline youtube completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Content Research"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Search YouTube for content to summarize",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "entity": "ServiceContentPipeline",
                                  "submitEvent": "SEARCH",
                                  "fields": [
                                    "query"
                                  ],
                                  "type": "form-section",
                                  "mode": "edit"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "type": "video",
                      "maxResults": 5.0,
                      "query": "@payload.query"
                    },
                    {
                      "emit": {
                        "success": "ServiceContentPipelineYoutubeCompleted",
                        "failure": "ServiceContentPipelineYoutubeFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Searching YouTube..."
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.query",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SearchComplete",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "video"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Search Results"
                                }
                              ],
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "icon": "rotate-ccw",
                              "action": "RESET",
                              "label": "New Search",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "columns": [
                            {
                              "icon": "video",
                              "label": "Title",
                              "name": "videoTitle",
                              "variant": "h4"
                            },
                            {
                              "label": "Description",
                              "name": "videoDescription",
                              "variant": "caption"
                            }
                          ],
                          "entity": "@payload.results",
                          "fields": [],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Summarize",
                              "event": "SELECT_AND_SUMMARIZE"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "error",
                "event": "ServiceContentPipelineYoutubeFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "content": "Search failed",
                          "variant": "h2"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "@payload.error"
                        },
                        {
                          "action": "RESET",
                          "variant": "primary",
                          "label": "Try Again",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "summarizing",
                "event": "SELECT_AND_SUMMARIZE",
                "effects": [
                  [
                    "call-service",
                    "youtube",
                    "getVideo",
                    {
                      "videoId": "@payload.videoId"
                    },
                    {
                      "emit": {
                        "failure": "ServiceContentPipelineYoutubeFailed",
                        "success": "ServiceContentPipelineYoutubeCompleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "cpu",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Fetching & summarizing..."
                        },
                        {
                          "type": "spinner"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "type": "typography",
                              "content": "Content Research",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Search YouTube for content to summarize",
                                  "type": "typography"
                                },
                                {
                                  "mode": "edit",
                                  "submitEvent": "SEARCH",
                                  "fields": [
                                    "query"
                                  ],
                                  "entity": "ServiceContentPipeline",
                                  "type": "form-section"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "summarizing",
                "event": "VIDEO_FETCHED",
                "effects": [
                  [
                    "call-service",
                    "llm",
                    "summarize",
                    {
                      "text": "@payload.description"
                    },
                    {
                      "emit": {
                        "success": "ServiceContentPipelineLlmCompleted",
                        "failure": "ServiceContentPipelineLlmFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "complete",
                "event": "SUMMARY_COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle"
                                },
                                {
                                  "type": "typography",
                                  "content": "Research Complete",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "label": "New Search",
                              "icon": "rotate-ccw",
                              "action": "RESET",
                              "variant": "ghost"
                            }
                          ],
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Summary",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@payload.content"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "error",
                "event": "ServiceContentPipelineLlmFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "Summarization failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "type": "alert",
                          "message": "@payload.error",
                          "variant": "error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "type": "button",
                          "action": "RESET",
                          "label": "Try Again"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "content": "Content Research",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Search YouTube for content to summarize",
                                  "variant": "body"
                                },
                                {
                                  "mode": "edit",
                                  "submitEvent": "SEARCH",
                                  "entity": "ServiceContentPipeline",
                                  "type": "form-section",
                                  "fields": [
                                    "query"
                                  ]
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Content Research"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Search YouTube for content to summarize",
                                  "variant": "body"
                                },
                                {
                                  "submitEvent": "SEARCH",
                                  "mode": "edit",
                                  "fields": [
                                    "query"
                                  ],
                                  "entity": "ServiceContentPipeline",
                                  "type": "form-section"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServiceContentPipelinePage",
          "path": "/servicecontentpipelines",
          "traits": [
            {
              "ref": "ServiceContentPipelinePipeline"
            }
          ]
        }
      ]
    }
  ]
}