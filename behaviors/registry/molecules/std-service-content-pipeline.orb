{
  "name": "std-service-content-pipeline",
  "version": "1.0.0",
  "description": "std-service-content-pipeline as a Function",
  "orbitals": [
    {
      "name": "ServiceContentPipelineOrbital",
      "entity": {
        "name": "ServiceContentPipeline",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "summary",
            "type": "string",
            "default": ""
          },
          {
            "name": "pipelineStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceContentPipelinePipeline",
          "category": "interaction",
          "linkedEntity": "ServiceContentPipeline",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              },
              {
                "name": "summarizing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "SEARCH_COMPLETE",
                "name": "Search Complete",
                "payload": [
                  {
                    "name": "results",
                    "type": "array",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_AND_SUMMARIZE",
                "name": "Select And Summarize",
                "payload": [
                  {
                    "name": "videoId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "VIDEO_FETCHED",
                "name": "Video Fetched",
                "payload": [
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SUMMARY_COMPLETE",
                "name": "Summary Complete",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "content": "Content Research",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Search YouTube for content to summarize",
                                  "type": "typography"
                                },
                                {
                                  "fields": [
                                    "query"
                                  ],
                                  "type": "form-section",
                                  "submitEvent": "SEARCH",
                                  "mode": "edit",
                                  "entity": "ServiceContentPipeline"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "searching"
                  ],
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "maxResults": 5.0,
                      "query": "@entity.query",
                      "type": "video"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Searching YouTube..."
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.query",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SEARCH_COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "results"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "video",
                                  "type": "icon"
                                },
                                {
                                  "content": "Search Results",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "New Search",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "action": "RESET"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Summarize",
                              "event": "SELECT_AND_SUMMARIZE"
                            }
                          ],
                          "columns": [
                            {
                              "name": "videoTitle",
                              "icon": "video",
                              "label": "Title",
                              "variant": "h4"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "videoDescription"
                            }
                          ],
                          "entity": "ServiceContentPipeline"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Pipeline Error"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "@entity.error"
                        },
                        {
                          "label": "Try Again",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "RESET",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "summarizing",
                "event": "SELECT_AND_SUMMARIZE",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "summarizing"
                  ],
                  [
                    "call-service",
                    "youtube",
                    "getVideo",
                    {
                      "videoId": "@payload.videoId"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "cpu",
                          "type": "icon"
                        },
                        {
                          "content": "Fetching & summarizing...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "@entity.videoTitle"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Content Research"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Search YouTube for content to summarize",
                                  "variant": "body"
                                },
                                {
                                  "entity": "ServiceContentPipeline",
                                  "type": "form-section",
                                  "submitEvent": "SEARCH",
                                  "fields": [
                                    "query"
                                  ],
                                  "mode": "edit"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "summarizing",
                "event": "VIDEO_FETCHED",
                "effects": [
                  [
                    "set",
                    "@entity.videoTitle",
                    "@payload.title"
                  ],
                  [
                    "set",
                    "@entity.videoDescription",
                    "@payload.description"
                  ],
                  [
                    "call-service",
                    "llm",
                    "summarize",
                    {
                      "text": "@entity.videoDescription"
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "complete",
                "event": "SUMMARY_COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.summary",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Research Complete"
                                }
                              ]
                            },
                            {
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "type": "button",
                              "label": "New Search",
                              "action": "RESET"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "align": "center",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "name": "video",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "@entity.videoTitle",
                                      "type": "typography",
                                      "variant": "h3"
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "content": "Summary",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.summary",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "summarizing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "content": "Pipeline Error",
                          "variant": "h2"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "@entity.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "action": "RESET",
                          "type": "button",
                          "label": "Try Again"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "set",
                    "@entity.summary",
                    ""
                  ],
                  [
                    "set",
                    "@entity.videoTitle",
                    ""
                  ],
                  [
                    "set",
                    "@entity.videoDescription",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "content": "Content Research",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Search YouTube for content to summarize",
                                  "type": "typography"
                                },
                                {
                                  "entity": "ServiceContentPipeline",
                                  "type": "form-section",
                                  "fields": [
                                    "query"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "SEARCH"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.pipelineStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Content Research"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Search YouTube for content to summarize",
                                  "variant": "body"
                                },
                                {
                                  "fields": [
                                    "query"
                                  ],
                                  "entity": "ServiceContentPipeline",
                                  "mode": "edit",
                                  "submitEvent": "SEARCH",
                                  "type": "form-section"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServiceContentPipelinePage",
          "path": "/servicecontentpipelines",
          "traits": [
            {
              "ref": "ServiceContentPipelinePipeline"
            }
          ]
        }
      ]
    }
  ]
}