{
  "name": "std-related-master-detail",
  "version": "1.0.0",
  "description": "std-related-master-detail as a Function",
  "orbitals": [
    {
      "name": "MasterDetailOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-related",
          "as": "Related"
        }
      ],
      "entity": {
        "name": "MasterDetailItem",
        "collection": "masterdetailitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "items",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "MasterDetailList",
          "linkedEntity": "MasterDetailItem"
        },
        {
          "ref": "Related.traits.RelatedItemList",
          "name": "MasterDetailRelated",
          "linkedEntity": "MasterDetailItem"
        },
        {
          "name": "MasterDetailLayout",
          "category": "interaction",
          "linkedEntity": "MasterDetailItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MasterDetailItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "box",
                          "style": {
                            "flex": "2"
                          },
                          "children": [
                            "@trait.MasterDetailList"
                          ]
                        },
                        {
                          "children": [
                            "@trait.MasterDetailRelated"
                          ],
                          "style": {
                            "flex": "3"
                          },
                          "type": "box"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MasterDetail",
          "path": "/master-detail",
          "traits": [
            {
              "ref": "MasterDetailLayout"
            }
          ]
        }
      ]
    }
  ]
}