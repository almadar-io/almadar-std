{
  "name": "std-messaging",
  "version": "1.0.0",
  "description": "std-messaging as a Function",
  "orbitals": [
    {
      "name": "ChatMessageOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "ChatMessage",
        "collection": "chatmessages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ChatMessageBrowse",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when the ChatMessage collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            },
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when the ChatMessage collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHAT_MESSAGE_SENT",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChatMessagePersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading messages…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ChatMessageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "type": "typography",
                                  "content": "Messages",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "label": "Compose",
                              "action": "COMPOSE",
                              "icon": "edit"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "event": "VIEW",
                              "label": "View"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Name",
                              "variant": "h4",
                              "name": "name",
                              "icon": "message-circle"
                            },
                            {
                              "name": "description",
                              "variant": "caption",
                              "label": "Description"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ChatMessageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load messages",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChatMessageCompose",
          "linkedEntity": "ChatMessage",
          "config": {
            "mode": "create",
            "icon": "edit",
            "title": "New Message",
            "fields": [
              "name",
              "description",
              "status"
            ]
          },
          "events": {
            "SAVE": "CHAT_MESSAGE_SENT",
            "OPEN": "COMPOSE"
          }
        },
        {
          "name": "ChatMessageView",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when the ChatMessage collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when the ChatMessage collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "content": "@entity.name",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Name",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.name"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "content": "Description",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "content": "@entity.description",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Status"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.status",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Close",
                              "action": "CLOSE"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ChatMessagePersistor",
          "category": "lifecycle",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "CHAT_MESSAGE_SENT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHAT_MESSAGE_SENT",
              "triggers": "DO_SEND",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageCompose"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_SEND",
                "name": "Do Send",
                "payload": [
                  {
                    "name": "data",
                    "type": "ChatMessage"
                  }
                ]
              },
              {
                "key": "CHAT_MESSAGE_SENT",
                "name": "Chat Message Sent"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ChatMessage",
                    "@payload.data"
                  ],
                  [
                    "emit",
                    "CHAT_MESSAGE_SENT",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ChatMessagePage",
          "path": "/chatmessages",
          "traits": [
            {
              "ref": "ChatMessageBrowse"
            },
            {
              "ref": "ChatMessageCompose"
            },
            {
              "ref": "ChatMessageView"
            },
            {
              "ref": "ChatMessagePersistor"
            }
          ]
        }
      ]
    }
  ]
}