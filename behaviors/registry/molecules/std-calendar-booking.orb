{
  "name": "std-calendar-booking",
  "version": "1.0.0",
  "description": "std-calendar-booking as a Function",
  "orbitals": [
    {
      "name": "BookingOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "Booking",
        "collection": "bookings",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "startsAt",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "BookingCalendar",
          "linkedEntity": "Booking",
          "listens": [
            {
              "event": "SAVE",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BookingModal"
              }
            },
            {
              "event": "CONFIRM",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BookingConfirmation"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "BookingModal",
          "linkedEntity": "Booking"
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "BookingConfirmation",
          "linkedEntity": "Booking"
        },
        {
          "name": "BookingLayout",
          "category": "interaction",
          "linkedEntity": "Booking",
          "emits": [
            {
              "event": "BookingLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BookingLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Booking]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BookingLoadFailed",
                "name": "Booking load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BookingLoaded",
                "name": "Booking loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Booking]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Booking",
                    {
                      "emit": {
                        "success": "BookingLoaded",
                        "failure": "BookingLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@trait.BookingCalendar"
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Calendar",
          "path": "/calendar",
          "traits": [
            {
              "ref": "BookingLayout"
            }
          ]
        }
      ]
    }
  ]
}