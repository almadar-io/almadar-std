{
  "name": "std-classifier-game",
  "version": "1.0.0",
  "description": "std-classifier-game as a Function",
  "orbitals": [
    {
      "name": "ClassifierGameOrbital",
      "entity": {
        "name": "ClassifierGame",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "ClassifierGameClassifierGame",
          "category": "interaction",
          "linkedEntity": "ClassifierGame",
          "emits": [
            {
              "event": "ClassifierGameLoaded",
              "description": "Fired when ClassifierGame finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ClassifierGameLoadFailed",
              "description": "Fired when ClassifierGame fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "ClassifierGameLoaded",
                "name": "ClassifierGame loaded"
              },
              {
                "key": "ClassifierGameLoadFailed",
                "name": "ClassifierGame load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassifierGame",
                    {
                      "emit": {
                        "failure": "ClassifierGameLoadFailed",
                        "success": "ClassifierGameLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start"
                        }
                      ],
                      "type": "game-menu",
                      "title": "Sort & Classify"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            },
                            {
                              "label": "Level",
                              "value": "@entity.level"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "entity": "ClassifierGame",
                          "completeEvent": "COMPLETE",
                          "type": "classifier-board"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-over-screen",
                      "title": "Well Done!",
                      "menuItems": [
                        {
                          "event": "RESTART",
                          "variant": "primary",
                          "label": "Play Again"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "label": "Start",
                          "variant": "primary"
                        }
                      ],
                      "type": "game-menu",
                      "title": "Sort & Classify"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ClassifierGamePage",
          "path": "/classifiergames",
          "traits": [
            {
              "ref": "ClassifierGameClassifierGame"
            }
          ]
        }
      ]
    }
  ]
}