{
  "name": "std-list",
  "version": "1.0.0",
  "description": "std-list as a Function",
  "orbitals": [
    {
      "name": "ListItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "ListItem",
        "collection": "listitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ListItemBrowse",
          "linkedEntity": "ListItem",
          "effects": {
            "INIT": [
              [
                "ref",
                "ListItem"
              ],
              [
                "render-ui",
                "main",
                {
                  "children": [
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "list",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "ListItems",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "icon": "plus",
                              "event": "CREATE",
                              "type": "button",
                              "label": "Create ListItem"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "horizontal",
                      "justify": "space-between",
                      "align": "center"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "emptyIcon": "inbox",
                      "entity": "ListItem",
                      "type": "data-grid",
                      "emptyTitle": "No listitems yet",
                      "emptyDescription": "Create your first listitem to get started.",
                      "itemActions": [
                        {
                          "variant": "ghost",
                          "event": "VIEW",
                          "size": "sm",
                          "label": "View"
                        },
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "variant": "ghost",
                          "size": "sm"
                        },
                        {
                          "event": "DELETE",
                          "label": "Delete",
                          "variant": "danger",
                          "size": "sm"
                        }
                      ],
                      "columns": [
                        {
                          "label": "Name",
                          "name": "name",
                          "variant": "h4",
                          "icon": "list"
                        },
                        {
                          "name": "description",
                          "variant": "badge",
                          "label": "Description",
                          "colorMap": {
                            "inactive": "neutral",
                            "done": "success",
                            "active": "success",
                            "error": "destructive",
                            "failed": "destructive",
                            "scheduled": "warning",
                            "completed": "success",
                            "cancelled": "destructive",
                            "pending": "warning",
                            "archived": "neutral",
                            "disabled": "neutral",
                            "draft": "warning"
                          }
                        },
                        {
                          "name": "status",
                          "variant": "caption",
                          "label": "Status"
                        }
                      ]
                    }
                  ],
                  "direction": "vertical",
                  "type": "stack",
                  "className": "max-w-5xl mx-auto w-full",
                  "gap": "lg"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListItemCreate",
          "linkedEntity": "ListItem",
          "events": {
            "OPEN": "CREATE"
          },
          "effects": {
            "SAVE": [
              [
                "persist",
                "create",
                "ListItem",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "emit",
                "LIST_ITEM_CREATED"
              ]
            ],
            "INIT": [
              [
                "ref",
                "ListItem"
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "CREATE": [
              [
                "fetch",
                "ListItem"
              ],
              [
                "render-ui",
                "modal",
                {
                  "children": [
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "plus-circle",
                          "size": "md",
                          "type": "icon"
                        },
                        {
                          "content": "Create ListItem",
                          "variant": "h3",
                          "type": "typography"
                        }
                      ],
                      "gap": "sm",
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entity": "ListItem",
                      "fields": [
                        "name",
                        "description",
                        "status"
                      ],
                      "type": "form-section",
                      "cancelEvent": "CLOSE",
                      "submitEvent": "SAVE",
                      "mode": "create"
                    }
                  ],
                  "direction": "vertical",
                  "type": "stack",
                  "gap": "md"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListItemEdit",
          "linkedEntity": "ListItem",
          "events": {
            "OPEN": "EDIT"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "INIT": [
              [
                "ref",
                "ListItem"
              ]
            ],
            "SAVE": [
              [
                "persist",
                "update",
                "ListItem",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "emit",
                "LIST_ITEM_UPDATED"
              ]
            ],
            "EDIT": [
              [
                "fetch",
                "ListItem",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "stack",
                  "gap": "md",
                  "children": [
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "size": "md",
                          "name": "edit",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Edit ListItem"
                        }
                      ],
                      "gap": "sm",
                      "type": "stack"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entityId": "@entity.id",
                      "type": "form-section",
                      "entity": "ListItem",
                      "submitEvent": "SAVE",
                      "cancelEvent": "CLOSE",
                      "mode": "edit",
                      "fields": [
                        "name",
                        "description",
                        "status"
                      ]
                    }
                  ],
                  "direction": "vertical"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListItemView",
          "linkedEntity": "ListItem",
          "events": {
            "OPEN": "VIEW"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "VIEW": [
              [
                "fetch",
                "ListItem",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "stack",
                  "children": [
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack",
                      "children": [
                        {
                          "size": "md",
                          "type": "icon",
                          "name": "eye"
                        },
                        {
                          "content": "@entity.name",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ],
                      "align": "center"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "content": "Name",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.name",
                          "type": "typography"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "type": "stack",
                      "children": [
                        {
                          "content": "Description",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.description",
                          "variant": "body"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md"
                    },
                    {
                      "type": "stack",
                      "children": [
                        {
                          "content": "Status",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.status",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "horizontal"
                    },
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Created At"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.createdAt",
                          "type": "typography"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "justify": "end",
                      "children": [
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Edit",
                          "icon": "edit",
                          "event": "EDIT"
                        },
                        {
                          "variant": "ghost",
                          "event": "CLOSE",
                          "type": "button",
                          "label": "Close"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ],
                  "direction": "vertical",
                  "gap": "md"
                }
              ]
            ],
            "INIT": [
              [
                "ref",
                "ListItem"
              ]
            ],
            "SAVE": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ListItemDelete",
          "linkedEntity": "ListItem",
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "ListItem"
              ]
            ],
            "INIT": [
              [
                "ref",
                "ListItem"
              ]
            ],
            "CONFIRM_DELETE": [
              [
                "persist",
                "delete",
                "ListItem",
                "@entity.pendingId"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "ListItem"
              ],
              [
                "emit",
                "LIST_ITEM_DELETED"
              ]
            ],
            "DELETE": [
              [
                "set",
                "@entity.pendingId",
                "@payload.id"
              ],
              [
                "fetch",
                "ListItem",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "direction": "vertical",
                  "gap": "md",
                  "type": "stack",
                  "children": [
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Delete ListItem"
                        }
                      ],
                      "align": "center"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "alert",
                      "variant": "danger",
                      "message": "This action cannot be undone."
                    },
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack",
                      "children": [
                        {
                          "label": "Cancel",
                          "type": "button",
                          "variant": "ghost",
                          "event": "CANCEL"
                        },
                        {
                          "type": "button",
                          "variant": "danger",
                          "label": "Delete",
                          "icon": "check",
                          "event": "CONFIRM_DELETE"
                        }
                      ],
                      "justify": "end"
                    }
                  ]
                }
              ]
            ],
            "CANCEL": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "ref",
                "ListItem"
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ListItemPage",
          "path": "/listitems",
          "traits": [
            {
              "ref": "ListItemBrowse"
            },
            {
              "ref": "ListItemCreate"
            },
            {
              "ref": "ListItemEdit"
            },
            {
              "ref": "ListItemView"
            },
            {
              "ref": "ListItemDelete"
            }
          ]
        }
      ]
    }
  ]
}