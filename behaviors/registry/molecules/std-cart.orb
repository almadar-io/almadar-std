{
  "name": "std-cart",
  "version": "1.0.0",
  "description": "std-cart as a Function",
  "orbitals": [
    {
      "name": "CartItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "CartItem",
        "collection": "cartitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CartItemCartBrowse",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "CartItemLoaded",
              "description": "Fired when the cart collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemLoadFailed",
              "description": "Fired when the cart collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemAddItem"
              }
            },
            {
              "event": "CONFIRM_REMOVE",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemRemoveConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "checkout"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded"
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PROCEED_CHECKOUT",
                "name": "Proceed Checkout"
              },
              {
                "key": "BACK_TO_CART",
                "name": "Back To Cart"
              },
              {
                "key": "CONFIRM_ORDER",
                "name": "Confirm Order"
              },
              {
                "key": "REQUEST_REMOVE",
                "name": "Request Remove",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading cart…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CartItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shopping-cart",
                                  "size": "lg"
                                },
                                {
                                  "content": "Shopping Cart",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "icon": "plus",
                              "event": "ADD_ITEM",
                              "label": "Add Item",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Items",
                              "value": [
                                "array/len",
                                "@entity"
                              ],
                              "icon": "package",
                              "type": "stat-display"
                            },
                            {
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "label": "Subtotal",
                              "value": [
                                "array/len",
                                "@entity"
                              ]
                            },
                            {
                              "label": "Total",
                              "type": "stat-display",
                              "icon": "receipt",
                              "value": [
                                "array/len",
                                "@entity"
                              ]
                            }
                          ],
                          "columns": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "CartItem",
                          "emptyTitle": "Your cart is empty",
                          "columns": [
                            {
                              "variant": "h4",
                              "name": "name",
                              "label": "Name",
                              "icon": "shopping-cart"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyDescription": "Add items to get started.",
                          "itemActions": [
                            {
                              "variant": "danger",
                              "label": "Remove",
                              "event": "REQUEST_REMOVE",
                              "size": "sm"
                            }
                          ]
                        },
                        {
                          "event": "PROCEED_CHECKOUT",
                          "variant": "primary",
                          "icon": "arrow-right",
                          "label": "Proceed to Checkout",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CartItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "xl",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load cart"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "content": "@payload.message"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "event": "INIT",
                          "label": "Retry"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "checkout",
                "event": "PROCEED_CHECKOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "clipboard",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Checkout"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "emptyIcon": "inbox",
                          "columns": [
                            {
                              "label": "Name",
                              "icon": "shopping-cart",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "entity": "CartItem",
                          "emptyTitle": "Your cart is empty",
                          "emptyDescription": "Add items to get started."
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "icon": "arrow-left",
                              "label": "Back to Cart",
                              "event": "BACK_TO_CART"
                            },
                            {
                              "icon": "check",
                              "event": "CONFIRM_ORDER",
                              "label": "Confirm Order",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "loading",
                "event": "BACK_TO_CART",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "browsing",
                "event": "CONFIRM_ORDER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "size": "lg",
                          "type": "icon"
                        },
                        {
                          "content": "Order Confirmed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "Your order has been placed successfully."
                        },
                        {
                          "event": "INIT",
                          "label": "Continue Shopping",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CartItemAddItem",
          "linkedEntity": "CartItem",
          "events": {
            "OPEN": "ADD_ITEM"
          },
          "effects": {
            "INIT": [
              [
                "fetch",
                "CartItem"
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "SAVE": [
              [
                "persist",
                "create",
                "CartItem",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "ADD_ITEM": [
              [
                "render-ui",
                "modal",
                {
                  "direction": "vertical",
                  "type": "stack",
                  "gap": "md",
                  "children": [
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "plus-circle",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "content": "Add Item",
                          "variant": "h3"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "mode": "create",
                      "type": "form-section",
                      "cancelEvent": "CLOSE",
                      "entity": "CartItem",
                      "submitEvent": "SAVE",
                      "fields": [
                        "name",
                        "description",
                        "status"
                      ]
                    }
                  ]
                }
              ]
            ]
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CartItemRemoveConfirm",
          "linkedEntity": "CartItem",
          "events": {
            "REQUEST": "REQUEST_REMOVE",
            "CONFIRM": "CONFIRM_REMOVE"
          },
          "effects": {
            "CANCEL": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "INIT": [
              [
                "fetch",
                "CartItem"
              ]
            ],
            "CONFIRM_REMOVE": [
              [
                "persist",
                "delete",
                "CartItem",
                "@entity.pendingId"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "REQUEST_REMOVE": [
              [
                "set",
                "@entity.pendingId",
                "@payload.id"
              ],
              [
                "render-ui",
                "modal",
                {
                  "gap": "md",
                  "direction": "vertical",
                  "type": "stack",
                  "children": [
                    {
                      "align": "center",
                      "direction": "horizontal",
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "size": "md",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "content": "Remove Item",
                          "variant": "h3"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "message": "Are you sure you want to remove this item from your cart?",
                      "type": "alert",
                      "variant": "danger"
                    },
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm",
                      "justify": "end",
                      "children": [
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Cancel",
                          "event": "CANCEL"
                        },
                        {
                          "type": "button",
                          "label": "Remove",
                          "event": "CONFIRM_REMOVE",
                          "variant": "danger",
                          "icon": "check"
                        }
                      ]
                    }
                  ]
                }
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "CartItemPage",
          "path": "/cart",
          "traits": [
            {
              "ref": "CartItemCartBrowse"
            },
            {
              "ref": "CartItemAddItem"
            },
            {
              "ref": "CartItemRemoveConfirm"
            }
          ]
        }
      ]
    }
  ]
}