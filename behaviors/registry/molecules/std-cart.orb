{
  "name": "std-cart",
  "version": "1.0.0",
  "description": "std-cart as a Function",
  "orbitals": [
    {
      "name": "CartItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "CartItem",
        "collection": "cartitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CartItemCartBrowse",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "CartItemLoaded",
              "description": "Fired when the cart collection finishes loading; payload.data holds the CartItem list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CartItemLoadFailed",
              "description": "Fired when the cart collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemPersistor"
              }
            },
            {
              "event": "ITEM_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading cart…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CartItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "shopping-cart",
                                  "type": "icon"
                                },
                                {
                                  "content": "Shopping Cart",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Add Item",
                              "action": "ADD_ITEM",
                              "variant": "primary",
                              "icon": "plus"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "REQUEST_REMOVE",
                              "variant": "danger",
                              "label": "Remove"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "icon": "shopping-cart",
                              "variant": "h4",
                              "name": "name"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CartItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load cart",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.message",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CartItemAddItem",
          "linkedEntity": "CartItem",
          "config": {
            "icon": "plus-circle",
            "mode": "create",
            "fields": [
              "name",
              "description",
              "status"
            ],
            "title": "Add Item",
            "openButtonLabel": "Add Item"
          },
          "events": {
            "OPEN": "ADD_ITEM"
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CartItemRemoveConfirm",
          "linkedEntity": "CartItem",
          "config": {
            "confirmLabel": "Remove",
            "alertMessage": "Are you sure you want to remove this item from your cart?",
            "icon": "alert-triangle",
            "title": "Remove Item"
          },
          "events": {
            "CONFIRM": "CONFIRM_REMOVE",
            "REQUEST": "REQUEST_REMOVE"
          }
        },
        {
          "name": "CartItemPersistor",
          "category": "lifecycle",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "ITEM_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ITEM_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CartItemAddItem"
              }
            },
            {
              "event": "CONFIRM_REMOVE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CartItemRemoveConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ITEM_CREATED",
                "name": "Item Created"
              },
              {
                "key": "ITEM_DELETED",
                "name": "Item Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "CartItem",
                    "@payload.data"
                  ],
                  [
                    "emit",
                    "ITEM_CREATED",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CartItem",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ITEM_DELETED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CartItemPage",
          "path": "/cart",
          "traits": [
            {
              "ref": "CartItemCartBrowse"
            },
            {
              "ref": "CartItemAddItem"
            },
            {
              "ref": "CartItemRemoveConfirm"
            },
            {
              "ref": "CartItemPersistor"
            }
          ]
        }
      ]
    }
  ]
}