{
  "name": "std-batch-selected-list",
  "version": "1.0.0",
  "description": "std-batch-selected-list as a Function",
  "orbitals": [
    {
      "name": "BatchListItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-selection",
          "as": "Selection"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "BatchListItem",
        "collection": "batchlistitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "BatchItemBrowse",
          "linkedEntity": "BatchListItem",
          "listens": [
            {
              "event": "CONFIRM",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BatchItemConfirmation"
              }
            }
          ]
        },
        {
          "ref": "Selection.traits.SelectableItemSelection",
          "name": "BatchItemSelection",
          "linkedEntity": "BatchListItem"
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "BatchItemConfirmation",
          "linkedEntity": "BatchListItem"
        },
        {
          "name": "BatchListLayout",
          "category": "interaction",
          "linkedEntity": "BatchListItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BatchListItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "icon": "trash-2",
                              "variant": "danger",
                              "type": "button",
                              "label": "Delete selected",
                              "action": "REQUEST"
                            }
                          ],
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        "@trait.BatchItemSelection",
                        "@trait.BatchItemBrowse"
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BatchList",
          "path": "/batch-list",
          "traits": [
            {
              "ref": "BatchListLayout"
            }
          ]
        }
      ]
    }
  ]
}