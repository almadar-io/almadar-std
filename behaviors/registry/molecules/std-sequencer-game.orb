{
  "name": "std-sequencer-game",
  "version": "1.0.0",
  "description": "std-sequencer-game as a Function",
  "orbitals": [
    {
      "name": "SequencerGameOrbital",
      "entity": {
        "name": "SequencerGame",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "SequencerGameSequencerGame",
          "category": "interaction",
          "linkedEntity": "SequencerGame",
          "emits": [
            {
              "event": "SequencerGameLoaded",
              "description": "Fired when SequencerGame finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SequencerGameLoadFailed",
              "description": "Fired when SequencerGame fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "SequencerGameLoaded",
                "name": "SequencerGame loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "SequencerGameLoadFailed",
                "name": "SequencerGame load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SequencerGame",
                    {
                      "emit": {
                        "success": "SequencerGameLoaded",
                        "failure": "SequencerGameLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Start",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "title": "Sequencer",
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            },
                            {
                              "label": "Level",
                              "value": "@entity.level"
                            }
                          ]
                        },
                        {
                          "entity": "SequencerGame",
                          "completeEvent": "COMPLETE",
                          "type": "sequencer-board"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "event": "RESTART",
                          "variant": "primary"
                        }
                      ],
                      "type": "game-over-screen",
                      "title": "Well Done!"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start"
                        }
                      ],
                      "title": "Sequencer",
                      "type": "game-menu"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SequencerGamePage",
          "path": "/sequencergames",
          "traits": [
            {
              "ref": "SequencerGameSequencerGame"
            }
          ]
        }
      ]
    }
  ]
}