{
  "name": "std-geospatial",
  "version": "1.0.0",
  "description": "std-geospatial as a Function",
  "orbitals": [
    {
      "name": "LocationOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "Location",
        "collection": "locations",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "LocationBrowse",
          "linkedEntity": "Location",
          "effects": {
            "INIT": [
              [
                "ref",
                "Location"
              ],
              [
                "render-ui",
                "main",
                {
                  "direction": "vertical",
                  "gap": "lg",
                  "children": [
                    {
                      "gap": "md",
                      "justify": "space-between",
                      "align": "center",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "map-pin"
                            },
                            {
                              "type": "typography",
                              "content": "Locations Picker",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entity": "Location",
                      "itemActions": [
                        {
                          "size": "sm",
                          "event": "SELECT",
                          "label": "Select Location",
                          "variant": "ghost"
                        }
                      ],
                      "columns": [
                        {
                          "name": "name",
                          "label": "Name",
                          "icon": "map-pin",
                          "variant": "h4"
                        },
                        {
                          "name": "description",
                          "label": "Description",
                          "colorMap": {
                            "draft": "warning",
                            "inactive": "neutral",
                            "active": "success",
                            "done": "success",
                            "pending": "warning",
                            "archived": "neutral",
                            "disabled": "neutral",
                            "failed": "destructive",
                            "scheduled": "warning",
                            "cancelled": "destructive",
                            "completed": "success",
                            "error": "destructive"
                          },
                          "variant": "badge"
                        },
                        {
                          "label": "Status",
                          "variant": "caption",
                          "name": "status"
                        }
                      ],
                      "emptyIcon": "inbox",
                      "emptyTitle": "No locations found",
                      "type": "data-grid",
                      "emptyDescription": "No locations are available to select."
                    },
                    {
                      "type": "floating-action-button",
                      "label": "Create",
                      "event": "INIT",
                      "tooltip": "Create",
                      "icon": "plus"
                    }
                  ],
                  "className": "max-w-5xl mx-auto w-full",
                  "type": "stack"
                }
              ]
            ]
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "LocationSelect",
          "linkedEntity": "Location",
          "events": {
            "OPEN": "SELECT",
            "SAVE": "CONFIRM_SELECT"
          },
          "effects": {
            "CONFIRM_SELECT": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "INIT": [
              [
                "ref",
                "Location"
              ]
            ],
            "SELECT": [
              [
                "fetch",
                "Location",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "direction": "vertical",
                  "gap": "md",
                  "type": "stack",
                  "children": [
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "map-pin",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@entity.name"
                        }
                      ],
                      "gap": "sm"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Name"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.name"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    },
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Description"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.description"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "gap": "md",
                      "children": [
                        {
                          "variant": "caption",
                          "content": "Status",
                          "type": "typography"
                        },
                        {
                          "content": "@entity.status",
                          "variant": "body",
                          "type": "typography"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack"
                    },
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Created At"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.createdAt"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md"
                    },
                    {
                      "gap": "md",
                      "children": [
                        {
                          "variant": "caption",
                          "content": "Pending ID",
                          "type": "typography"
                        },
                        {
                          "content": "@entity.pendingId",
                          "type": "typography",
                          "variant": "body"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "direction": "horizontal",
                      "justify": "end",
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "type": "button",
                          "label": "Cancel",
                          "event": "CLOSE",
                          "variant": "ghost"
                        },
                        {
                          "event": "CONFIRM_SELECT",
                          "type": "button",
                          "label": "Confirm Selection",
                          "variant": "primary",
                          "icon": "check"
                        }
                      ]
                    }
                  ]
                }
              ]
            ]
          }
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "LocationConfirmSelect",
          "linkedEntity": "Location",
          "events": {
            "REQUEST": "CONFIRM_SELECT",
            "CONFIRM": "CONFIRMED"
          },
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "ref",
                "Location"
              ]
            ],
            "INIT": [
              [
                "ref",
                "Location"
              ]
            ],
            "CONFIRM_SELECT": [
              [
                "set",
                "@entity.pendingId",
                "@payload.id"
              ],
              [
                "fetch",
                "Location",
                {
                  "id": "@payload.id"
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "direction": "vertical",
                  "gap": "md",
                  "children": [
                    {
                      "direction": "horizontal",
                      "type": "stack",
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "size": "md",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Confirm Location Selection",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "variant": "danger",
                      "type": "alert",
                      "message": "Are you sure you want to select this location?"
                    },
                    {
                      "type": "stack",
                      "children": [
                        {
                          "label": "Cancel",
                          "type": "button",
                          "event": "CANCEL",
                          "variant": "ghost"
                        },
                        {
                          "event": "CONFIRMED",
                          "variant": "danger",
                          "label": "Confirm",
                          "icon": "check",
                          "type": "button"
                        }
                      ],
                      "gap": "sm",
                      "direction": "horizontal",
                      "justify": "end"
                    }
                  ],
                  "type": "stack"
                }
              ]
            ],
            "CONFIRMED": [
              [
                "fetch",
                "Location"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "ref",
                "Location"
              ]
            ],
            "CANCEL": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "ref",
                "Location"
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "LocationPage",
          "path": "/locations",
          "traits": [
            {
              "ref": "LocationBrowse"
            },
            {
              "ref": "LocationSelect"
            },
            {
              "ref": "LocationConfirmSelect"
            }
          ]
        }
      ]
    }
  ]
}