{
  "name": "std-geospatial",
  "version": "1.0.0",
  "description": "std-geospatial as a Function",
  "orbitals": [
    {
      "name": "LocationOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "Location",
        "collection": "locations",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "LocationBrowse",
          "category": "interaction",
          "linkedEntity": "Location",
          "emits": [
            {
              "event": "LocationLoaded",
              "description": "Fired when the Location collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Location]"
                }
              ]
            },
            {
              "event": "LocationLoadFailed",
              "description": "Fired when the Location collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CONFIRMED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "LocationConfirmSelect"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LocationLoaded",
                "name": "Location loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Location]"
                  }
                ]
              },
              {
                "key": "LocationLoadFailed",
                "name": "Location load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location",
                    {
                      "emit": {
                        "failure": "LocationLoadFailed",
                        "success": "LocationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading locations…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LocationLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "map-pin",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Locations",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Select",
                              "event": "SELECT",
                              "variant": "ghost"
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name",
                              "icon": "map-pin"
                            },
                            {
                              "variant": "caption",
                              "label": "Description",
                              "name": "description"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LocationLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "size": "xl",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load locations",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location",
                    {
                      "emit": {
                        "failure": "LocationLoadFailed",
                        "success": "LocationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location",
                    {
                      "emit": {
                        "failure": "LocationLoadFailed",
                        "success": "LocationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "LocationSelect",
          "category": "interaction",
          "linkedEntity": "Location",
          "emits": [
            {
              "event": "CONFIRM_SELECT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CONFIRM_SELECT",
                "name": "Confirm Select"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "SELECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "map-pin",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Name"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Description",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.description",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Status"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "justify": "end",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "CLOSE",
                              "type": "button",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "variant": "primary",
                              "action": "CONFIRM_SELECT",
                              "icon": "check",
                              "label": "Confirm Selection",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CONFIRM_SELECT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "LocationConfirmSelect",
          "linkedEntity": "Location",
          "config": {
            "icon": "alert-triangle",
            "alertMessage": "Are you sure you want to select this location?",
            "confirmLabel": "Confirm",
            "title": "Confirm Location"
          },
          "events": {
            "REQUEST": "CONFIRM_SELECT",
            "CONFIRM": "CONFIRMED"
          }
        },
        {
          "name": "LocationSelectionFlow",
          "category": "lifecycle",
          "linkedEntity": "Location",
          "emits": [
            {
              "event": "LocationSelected",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CONFIRMED",
              "triggers": "DO_EMIT_SELECTED",
              "source": {
                "kind": "trait",
                "trait": "LocationConfirmSelect"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_EMIT_SELECTED",
                "name": "Do Emit Selected",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "LocationSelected",
                "name": "Location selected",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_EMIT_SELECTED",
                "effects": [
                  [
                    "emit",
                    "LocationSelected",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LocationPage",
          "path": "/locations",
          "traits": [
            {
              "ref": "LocationBrowse"
            },
            {
              "ref": "LocationSelect"
            },
            {
              "ref": "LocationConfirmSelect"
            },
            {
              "ref": "LocationSelectionFlow"
            }
          ]
        }
      ]
    }
  ]
}