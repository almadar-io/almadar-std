{
  "name": "std-agent-planner",
  "version": "1.0.0",
  "description": "std-agent-planner as a Function",
  "orbitals": [
    {
      "name": "AgentPlannerOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-classifier",
          "as": "AgentClassifier"
        },
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "AgentPlanner",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "task",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "steps",
            "type": "string",
            "default": ""
          },
          {
            "name": "confidence",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "relevantMemories",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "input",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentPlannerPlanner",
          "category": "interaction",
          "linkedEntity": "AgentPlanner",
          "emits": [
            {
              "event": "PLAN_READY",
              "scope": "external",
              "payload": [
                {
                  "name": "plan",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PLAN_READY",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentPlannerPlanner"
              }
            },
            {
              "event": "PLAN",
              "triggers": "PLAN",
              "source": {
                "kind": "trait",
                "trait": "PlannerTaskInput"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "classifying"
              },
              {
                "name": "recalling"
              },
              {
                "name": "planning"
              },
              {
                "name": "ready"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN",
                "name": "Plan"
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified",
                "payload": [
                  {
                    "name": "category",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MEMORIES_LOADED",
                "name": "Memories Loaded",
                "payload": [
                  {
                    "name": "memories",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "count",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payload": [
                  {
                    "name": "steps",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "confidence",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PLAN_READY",
                "name": "Plan Ready"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "size": "lg",
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Task Planner",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Describe the task to plan",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "fields": [
                                    "task"
                                  ],
                                  "submitEvent": "PLAN",
                                  "type": "form-section",
                                  "entity": "AgentPlanner",
                                  "mode": "edit"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "PLAN",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "classifying"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify this task into exactly one category.\n",
                      "Categories: ",
                      "code, schema, design, debug, deploy",
                      "\n",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Return only the category name."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "tag"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Classifying task..."
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.task",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "recalling",
                "event": "CLASSIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recalling"
                  ],
                  [
                    "agent/recall",
                    [
                      "str/concat",
                      "@entity.category",
                      " ",
                      "@entity.task"
                    ],
                    5.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "brain"
                        },
                        {
                          "type": "typography",
                          "content": "Recalling relevant experience...",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "type": "badge",
                          "label": [
                            "str/concat",
                            "Category: ",
                            "@entity.category"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "content": "Planning Failed",
                          "type": "typography"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "event": "RESET",
                          "label": "Try Again",
                          "variant": "primary",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "planning",
                "event": "MEMORIES_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.relevantMemories",
                    "@payload.memories"
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Relevant experience:\n",
                      "@entity.relevantMemories",
                      "\n\n",
                      "Generate a numbered step-by-step execution plan. ",
                      "Include a confidence score (0-100) for how likely this plan will succeed."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "cpu",
                          "size": "lg"
                        },
                        {
                          "content": "Generating plan...",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                "Category: ",
                                "@entity.category"
                              ]
                            },
                            {
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.memoryCount"
                                ],
                                " memories loaded"
                              ],
                              "type": "badge"
                            }
                          ],
                          "justify": "center",
                          "gap": "md"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Planning Failed"
                        },
                        {
                          "type": "alert",
                          "message": "@entity.error",
                          "variant": "error"
                        },
                        {
                          "type": "button",
                          "label": "Try Again",
                          "event": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "ready",
                "event": "PLAN_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.steps",
                    "@payload.steps"
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    "@payload.confidence"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "ready"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Plan for ",
                      "@entity.category",
                      " task: ",
                      "@entity.task"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "emit",
                    "PLAN_READY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "space-between",
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "size": "lg",
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Plan Ready",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "label": "New Plan",
                              "event": "RESET",
                              "variant": "ghost",
                              "type": "button",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "columns": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Category",
                              "value": "@entity.category",
                              "icon": "tag",
                              "type": "stat-display"
                            },
                            {
                              "label": "Confidence",
                              "value": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.confidence"
                                ],
                                "%"
                              ],
                              "type": "stat-display",
                              "icon": "target"
                            },
                            {
                              "label": "Memories Used",
                              "icon": "brain",
                              "type": "stat-display",
                              "value": "@entity.memoryCount"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Task",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.task",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "content": "Execution Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.steps",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Relevant Memories",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.relevantMemories",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Planning Failed",
                          "variant": "h2"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Try Again",
                          "type": "button",
                          "event": "RESET"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.steps",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.relevantMemories",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Task Planner",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "Describe the task to plan"
                                },
                                {
                                  "fields": [
                                    "task"
                                  ],
                                  "entity": "AgentPlanner",
                                  "type": "form-section",
                                  "mode": "edit",
                                  "submitEvent": "PLAN"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PlannerTaskInput",
          "linkedEntity": "AgentPlanner",
          "events": {
            "SAVE": "PLAN",
            "OPEN": "NEW_TASK"
          },
          "effects": {
            "INIT": [
              [
                "ref",
                "AgentPlanner"
              ]
            ],
            "PLAN": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ]
            ],
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "box"
                }
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ]
            ],
            "NEW_TASK": [
              [
                "render-ui",
                "modal",
                {
                  "gap": "md",
                  "type": "stack",
                  "children": [
                    {
                      "size": "md",
                      "type": "icon",
                      "name": "map"
                    },
                    {
                      "variant": "h3",
                      "type": "typography",
                      "content": "Describe the task to plan"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "entity": "AgentPlanner",
                      "type": "form-section",
                      "fields": [
                        "task"
                      ],
                      "mode": "edit",
                      "submitEvent": "PLAN",
                      "cancelEvent": "CLOSE"
                    }
                  ],
                  "direction": "vertical"
                }
              ]
            ]
          }
        },
        {
          "ref": "AgentClassifier.traits.AgentClassifierModal",
          "name": "PlannerClassifierFlow",
          "linkedEntity": "AgentPlanner",
          "emitsScope": "internal",
          "effects": {
            "CLOSE": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "notify",
                "Cancelled",
                "info"
              ],
              [
                "ref",
                "AgentPlanner"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "gap": "lg",
                  "children": [
                    {
                      "direction": "horizontal",
                      "justify": "space-between",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "tag",
                              "size": "lg"
                            },
                            {
                              "content": "AgentPlanner",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
