{
  "name": "std-agent-planner",
  "version": "1.0.0",
  "description": "std-agent-planner as a Function",
  "orbitals": [
    {
      "name": "AgentPlannerOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-classifier",
          "as": "AgentClassifier"
        },
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "AgentPlanner",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "task",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "steps",
            "type": "string",
            "default": ""
          },
          {
            "name": "confidence",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "relevantMemories",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "input",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentPlannerPlanner",
          "category": "interaction",
          "linkedEntity": "AgentPlanner",
          "emits": [
            {
              "event": "PLAN_READY",
              "scope": "external",
              "payload": [
                {
                  "name": "plan",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PLAN_READY",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentPlannerPlanner"
              }
            },
            {
              "event": "PLAN",
              "triggers": "PLAN",
              "source": {
                "kind": "trait",
                "trait": "PlannerTaskInput"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "classifying"
              },
              {
                "name": "recalling"
              },
              {
                "name": "planning"
              },
              {
                "name": "ready"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN",
                "name": "Plan"
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified",
                "payload": [
                  {
                    "name": "category",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MEMORIES_LOADED",
                "name": "Memories Loaded",
                "payload": [
                  {
                    "name": "memories",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "count",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payload": [
                  {
                    "name": "steps",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "confidence",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PLAN_READY",
                "name": "Plan Ready"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Task Planner"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Describe the task to plan",
                                  "variant": "body"
                                },
                                {
                                  "mode": "edit",
                                  "type": "form-section",
                                  "fields": [
                                    "task"
                                  ],
                                  "entity": "AgentPlanner",
                                  "submitEvent": "PLAN"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "PLAN",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "classifying"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify this task into exactly one category.\n",
                      "Categories: ",
                      "code, schema, design, debug, deploy",
                      "\n",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Return only the category name."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "tag",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Classifying task...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.task",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "recalling",
                "event": "CLASSIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recalling"
                  ],
                  [
                    "agent/recall",
                    [
                      "str/concat",
                      "@entity.category",
                      " ",
                      "@entity.task"
                    ],
                    5.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "brain",
                          "type": "icon"
                        },
                        {
                          "content": "Recalling relevant experience...",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "badge",
                          "label": [
                            "str/concat",
                            "Category: ",
                            "@entity.category"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Planning Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "variant": "primary",
                          "label": "Try Again",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "planning",
                "event": "MEMORIES_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.relevantMemories",
                    "@payload.memories"
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Relevant experience:\n",
                      "@entity.relevantMemories",
                      "\n\n",
                      "Generate a numbered step-by-step execution plan. ",
                      "Include a confidence score (0-100) for how likely this plan will succeed."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "cpu",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Generating plan...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "children": [
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                "Category: ",
                                "@entity.category"
                              ]
                            },
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.memoryCount"
                                ],
                                " memories loaded"
                              ]
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Planning Failed"
                        },
                        {
                          "type": "alert",
                          "message": "@entity.error",
                          "variant": "error"
                        },
                        {
                          "variant": "primary",
                          "label": "Try Again",
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "type": "button"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "ready",
                "event": "PLAN_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.steps",
                    "@payload.steps"
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    "@payload.confidence"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "ready"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Plan for ",
                      "@entity.category",
                      " task: ",
                      "@entity.task"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "emit",
                    "PLAN_READY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Plan Ready",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "button",
                              "action": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "label": "New Plan"
                            }
                          ],
                          "align": "center",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.category",
                              "icon": "tag",
                              "label": "Category"
                            },
                            {
                              "label": "Confidence",
                              "icon": "target",
                              "type": "stat-display",
                              "value": [
                                "str/concat",
                                [
                                  "str/concat",
                                  "@entity.confidence"
                                ],
                                "%"
                              ]
                            },
                            {
                              "value": "@entity.memoryCount",
                              "icon": "brain",
                              "label": "Memories Used",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Task"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.task"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Execution Plan"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.steps",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Relevant Memories"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.relevantMemories"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Planning Failed"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "@entity.error"
                        },
                        {
                          "type": "button",
                          "label": "Try Again",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.steps",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.relevantMemories",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Task Planner",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Describe the task to plan",
                                  "variant": "body"
                                },
                                {
                                  "type": "form-section",
                                  "fields": [
                                    "task"
                                  ],
                                  "entity": "AgentPlanner",
                                  "mode": "edit",
                                  "submitEvent": "PLAN"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PlannerTaskInput",
          "linkedEntity": "AgentPlanner",
          "config": {
            "mode": "create",
            "icon": "plus-circle",
            "fields": [
              "task"
            ],
            "title": "New Task"
          },
          "events": {
            "SAVE": "PLAN",
            "OPEN": "NEW_TASK"
          }
        },
        {
          "ref": "AgentClassifier.traits.AgentClassifierModal",
          "name": "PlannerClassifierFlow",
          "linkedEntity": "AgentPlanner",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentCompletion.traits.AgentCompletionModal",
          "name": "PlannerCompletionFlow",
          "linkedEntity": "AgentPlanner",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentMemory.traits.AgentMemoryBrowse",
          "name": "PlannerMemoryLifecycle",
          "linkedEntity": "AgentPlanner",
          "emitsScope": "internal"
        }
      ],
      "pages": [
        {
          "name": "AgentPlannerPage",
          "path": "/agentplanners",
          "traits": [
            {
              "ref": "AgentPlannerPlanner"
            },
            {
              "ref": "PlannerTaskInput"
            },
            {
              "ref": "PlannerClassifierFlow"
            },
            {
              "ref": "PlannerCompletionFlow"
            },
            {
              "ref": "PlannerMemoryLifecycle"
            }
          ]
        }
      ]
    }
  ]
}