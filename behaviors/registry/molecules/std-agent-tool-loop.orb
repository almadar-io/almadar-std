                              "content": "Invoke Tool"
                            }
                          ]
                        },
                        {
                          "icon": "wrench",
                          "label": "Open",
                          "variant": "primary",
                          "type": "button",
                          "event": "INVOKE"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack",
                      "gap": "md"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "type": "empty-state",
                      "icon": "wrench",
                      "title": "Nothing open",
                      "description": "Click Open to view details in a modal overlay."
                    }
                  ]
                }
              ]
            ],
            "SAVE": [
              [
                "persist",
                "create",
                "AgentToolLoop",
                "@payload.data"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "emit",
                "INVOKED"
              ],
              [
                "ref",
                "AgentToolLoop"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "children": [
                    {
                      "direction": "horizontal",
                      "gap": "md",
                      "type": "stack",
                      "justify": "space-between",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "size": "lg",
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Invoke Tool",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "icon": "wrench",
                          "event": "INVOKE",
                          "label": "Open",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "icon": "wrench",
                      "description": "Click Open to view details in a modal overlay.",
                      "title": "Nothing open",
                      "type": "empty-state"
                    }
                  ],
                  "direction": "vertical",
                  "gap": "lg"
                }
              ]
            ],
            "INVOKE": [
              [
                "render-ui",
                "modal",
                {
                  "children": [
                    {
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "name": "wrench",
                          "type": "icon",
                          "size": "md"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Invoke Tool"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "cancelEvent": "CLOSE",
                      "fields": [
                        "toolName",
                        "args"
                      ],
                      "entity": "AgentToolLoop",
                      "type": "form-section",
                      "submitEvent": "SAVE",
                      "mode": "create"
                    }
                  ],
                  "direction": "vertical",
                  "type": "stack",
                  "gap": "md"
                }
              ]
            ]
          }
        },
        {
          "ref": "AgentContextWindow.traits.AgentContextWindowGauge",
          "name": "ToolLoopContextMonitor",
          "linkedEntity": "AgentToolLoop",
          "emitsScope": "internal",
          "effects": {
            "INIT": [
              [
                "fetch",
                "AgentToolLoop"
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "stack",
                  "direction": "vertical",
                  "children": [
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "size": "lg",
                          "name": "gauge",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Token Usage"
                        },
                        {
                          "label": "Normal",
                          "variant": "default",
                          "type": "badge"
                        }
                      ]
                    },
                    {
                      "type": "divider"
                    },
                    {
                      "value": "@entity.current",
                      "type": "progress-bar",
                      "max": "@entity.max"
                    },
                    {
                      "children": [
                        {
                          "type": "stat-display",
                          "label": "Tokens Used",
                          "value": "@entity.current"
                        },
                        {
                          "type": "stat-display",
                          "label": "Max Tokens",
                          "value": "@entity.max"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "horizontal"
                    },
                    {
                      "label": "Reset",
                      "variant": "ghost",
                      "icon": "rotate-ccw",
                      "event": "RESET",
                      "type": "button"
                    }
                  ],
                  "gap": "lg"
                }
              ]
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "AgentToolLoopPage",
          "path": "/agenttoolloops",
          "traits": [
            {
              "ref": "AgentToolLoopLoop"
            },
            {
              "ref": "ToolLoopStepProgress"
            },
            {
              "ref": "ToolLoopCompletionFlow"
            },
            {
              "ref": "ToolLoopToolCallFlow"
            },
            {
