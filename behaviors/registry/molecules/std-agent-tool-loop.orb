{
  "name": "std-agent-tool-loop",
  "version": "1.0.0",
  "description": "std-agent-tool-loop as a Function",
  "orbitals": [
    {
      "name": "AgentToolLoopOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-context-window",
          "as": "AgentContextWindow"
        },
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        },
        {
          "from": "std/behaviors/std-agent-tool-call",
          "as": "AgentToolCall"
        }
      ],
      "entity": {
        "name": "AgentToolLoop",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "task",
            "type": "string",
            "default": ""
          },
          {
            "name": "plan",
            "type": "string",
            "default": ""
          },
          {
            "name": "iterations",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxIterations",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentTool",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastToolResult",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "steps",
            "type": "string",
            "default": "Plan,Execute,Check,Complete"
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          },
          {
            "name": "args",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "usage",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "current",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "max",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.85
          },
          {
            "name": "lastCompactedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AgentToolLoopLoop",
          "category": "interaction",
          "linkedEntity": "AgentToolLoop",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "planning"
              },
              {
                "name": "executing"
              },
              {
                "name": "checking"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXECUTE",
                "name": "Execute"
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payload": [
                  {
                    "name": "plan",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolArgs",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOOL_RESULT",
                "name": "Tool Result",
                "payload": [
                  {
                    "name": "output",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CHECK_PASSED",
                "name": "Check Passed",
                "payload": [
                  {
                    "name": "result",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CHECK_NEEDS_MORE",
                "name": "Check Needs More",
                "payload": [
                  {
                    "name": "toolName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolArgs",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "MAX_ITERATIONS",
                "name": "Max Iterations",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "repeat",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Tool Execution Loop"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Describe the task to execute with tools",
                                  "variant": "body"
                                },
                                {
                                  "entity": "AgentToolLoop",
                                  "mode": "edit",
                                  "fields": [
                                    "task"
                                  ],
                                  "submitEvent": "EXECUTE",
                                  "type": "form-section"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "planning",
                "event": "EXECUTE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n\nAvailable tools: ",
                      [
                        "str/join",
                        [
                          "agent/tools"
                        ],
                        ", "
                      ],
                      "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "brain",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Planning execution...",
                          "variant": "h3"
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.task",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "executing",
                "event": "PLAN_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.plan"
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "space-between",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "tool",
                                  "size": "lg"
                                },
                                {
                                  "content": "Executing Tool",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "label": [
                                "str/concat",
                                "Iteration ",
                                [
                                  "str/concat",
                                  "@entity.iterations"
                                ],
                                "/",
                                [
                                  "str/concat",
                                  "@entity.maxIterations"
                                ]
                              ],
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Current Tool",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.currentTool",
                                  "variant": "h4"
                                },
                                {
                                  "type": "spinner",
                                  "size": "md"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Plan"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.plan",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "x-circle"
                        },
                        {
                          "content": "Loop Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "variant": "error",
                          "message": "@entity.error",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.maxIterations",
                              "label": "Max Allowed",
                              "icon": "shield"
                            }
                          ]
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "event": "RESET",
                          "label": "Retry",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "checking",
                "event": "TOOL_RESULT",
                "effects": [
                  [
                    "set",
                    "@entity.lastToolResult",
                    "@payload.output"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\nPlan: ",
                      "@entity.plan",
                      "\nTool output: ",
                      "@payload.output",
                      "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "eye"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Checking result..."
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "label": [
                            "str/concat",
                            "Iteration ",
                            [
                              "str/concat",
                              "@entity.iterations"
                            ]
                          ],
                          "type": "badge"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Loop Failed"
                        },
                        {
                          "variant": "error",
                          "message": "@entity.error",
                          "type": "alert"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.iterations",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "icon": "repeat"
                            },
                            {
                              "label": "Max Allowed",
                              "value": "@entity.maxIterations",
                              "icon": "shield",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "event": "RESET",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "type": "button",
                          "label": "Retry"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "completed",
                "event": "CHECK_PASSED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "content": "Loop Complete",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "New Task",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "event": "RESET"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations",
                              "value": "@entity.iterations",
                              "type": "stat-display"
                            },
                            {
                              "icon": "check",
                              "value": "@entity.status",
                              "type": "stat-display",
                              "label": "Status"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Task",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.task",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Result"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.result",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "executing",
                "event": "CHECK_NEEDS_MORE",
                "effects": [
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      [
                        "agent/context-usage"
                      ],
                      0.8
                    ],
                    [
                      "agent/compact",
                      "hybrid"
                    ],
                    [
                      "log",
                      "Context below compact threshold"
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "tool",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Executing Tool",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "label": [
                                "str/concat",
                                "Iteration ",
                                [
                                  "str/concat",
                                  "@entity.iterations"
                                ],
                                "/",
                                [
                                  "str/concat",
                                  "@entity.maxIterations"
                                ]
                              ],
                              "type": "badge"
                            }
                          ],
                          "justify": "space-between",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Current Tool",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@entity.currentTool"
                                },
                                {
                                  "size": "md",
                                  "type": "spinner"
                                }
                              ],
                              "gap": "sm",
                              "direction": "vertical"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Plan"
                                },
                                {
                                  "content": "@entity.plan",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "failed",
                "event": "MAX_ITERATIONS",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "size": "lg",
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Loop Failed",
                          "variant": "h2"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Iterations Used",
                              "value": "@entity.iterations",
                              "icon": "repeat"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.maxIterations",
                              "icon": "shield",
                              "label": "Max Allowed"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw",
