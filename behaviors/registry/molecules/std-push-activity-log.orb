{
  "name": "std-push-activity-log",
  "version": "1.0.0",
  "description": "std-push-activity-log as a Function",
  "orbitals": [
    {
      "name": "PushActivityLogOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-push",
          "as": "Push"
        },
        {
          "from": "std/behaviors/std-agent-activity-log",
          "as": "ActivityLog"
        }
      ],
      "entity": {
        "name": "PushActivityItem",
        "collection": "pushactivityitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "event",
            "type": "string"
          },
          {
            "name": "receivedAt",
            "type": "string"
          },
          {
            "name": "payload",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Push.traits.PushSubscriberIndicator",
          "name": "PushActivityPush",
          "linkedEntity": "PushActivityItem"
        },
        {
          "ref": "ActivityLog.traits.AgentActivityLogLog",
          "name": "PushActivityLog",
          "linkedEntity": "PushActivityItem",
          "listens": [
            {
              "event": "PUSH_RECEIVED",
              "triggers": "LOG_ENTRY",
              "source": {
                "kind": "trait",
                "trait": "PushActivityPush"
              }
            },
            {
              "event": "PUSH_DISCONNECTED",
              "triggers": "LOG_ENTRY",
              "source": {
                "kind": "trait",
                "trait": "PushActivityPush"
              }
            }
          ]
        },
        {
          "name": "PushActivityLayout",
          "category": "interaction",
          "linkedEntity": "PushActivityItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PushActivityItem",
                    {
                      "emit": {
                        "failure": "PushActivityItemLoadFailed",
                        "success": "PushActivityItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.PushActivityPush",
                        "@trait.PushActivityLog"
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PushActivity",
          "path": "/push-activity",
          "traits": [
            {
              "ref": "PushActivityLayout"
            }
          ]
        }
      ]
    }
  ]
}