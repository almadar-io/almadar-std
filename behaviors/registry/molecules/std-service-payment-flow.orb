{
  "name": "std-service-payment-flow",
  "version": "1.0.0",
  "description": "std-service-payment-flow as a Function",
  "orbitals": [
    {
      "name": "ServicePaymentFlowOrbital",
      "entity": {
        "name": "ServicePaymentFlow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "usd"
          },
          {
            "name": "paymentIntentId",
            "type": "string"
          },
          {
            "name": "clientSecret",
            "type": "string"
          },
          {
            "name": "paymentStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string",
            "default": "Payment Receipt"
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServicePaymentFlowPayment",
          "category": "interaction",
          "linkedEntity": "ServicePaymentFlow",
          "emits": [
            {
              "event": "SEND_RECEIPT"
            },
            {
              "event": "ServicePaymentFlowLoaded",
              "description": "Fired when ServicePaymentFlow finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "amount",
                  "type": "number"
                },
                {
                  "name": "currency",
                  "type": "string"
                },
                {
                  "name": "paymentIntentId",
                  "type": "string"
                },
                {
                  "name": "clientSecret",
                  "type": "string"
                },
                {
                  "name": "paymentStatus",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "subject",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePaymentFlowLoadFailed",
              "description": "Fired when ServicePaymentFlow fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePaymentFlowStripeCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServicePaymentFlowStripeFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePaymentFlowEmailCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServicePaymentFlowEmailFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "confirming"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              },
              {
                "key": "PAYMENT_CREATED",
                "name": "Payment Created",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "clientSecret",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAYMENT_CONFIRMED",
                "name": "Payment Confirmed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "SEND_RECEIPT",
                "name": "Send Receipt"
              },
              {
                "key": "ServicePaymentFlowLoaded",
                "name": "ServicePaymentFlow loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "amount",
                    "type": "number"
                  },
                  {
                    "name": "currency",
                    "type": "string"
                  },
                  {
                    "name": "paymentIntentId",
                    "type": "string"
                  },
                  {
                    "name": "clientSecret",
                    "type": "string"
                  },
                  {
                    "name": "paymentStatus",
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "type": "string"
                  },
                  {
                    "name": "subject",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "sendStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServicePaymentFlowLoadFailed",
                "name": "ServicePaymentFlow load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServicePaymentFlowStripeCompleted",
                "name": "ServicePaymentFlow stripe completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServicePaymentFlowStripeFailed",
                "name": "ServicePaymentFlow stripe failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServicePaymentFlowEmailCompleted",
                "name": "ServicePaymentFlow email completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServicePaymentFlowEmailFailed",
                "name": "ServicePaymentFlow email failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServicePaymentFlow",
                    {
                      "emit": {
                        "success": "ServicePaymentFlowLoaded",
                        "failure": "ServicePaymentFlowLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Payment",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "inputType": "number",
                              "placeholder": "0.00",
                              "type": "input"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "icon": "credit-card",
                          "type": "button",
                          "variant": "primary",
                          "action": "CREATE_PAYMENT",
                          "label": "Pay"
                        }
                      ],
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "creating",
                "event": "CREATE_PAYMENT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Setting up your payment intent.",
                      "title": "Creating payment..."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "createPaymentIntent",
                    {
                      "amount": "@entity.amount",
                      "currency": "@entity.currency"
                    },
                    {
                      "emit": {
                        "failure": "ServicePaymentFlowStripeFailed",
                        "success": "ServicePaymentFlowStripeCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "confirming",
                "event": "PAYMENT_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentIntentId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.clientSecret",
                    "@payload.clientSecret"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Processing your payment.",
                      "title": "Confirming payment..."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "confirmPayment",
                    {
                      "paymentIntentId": "@entity.paymentIntentId"
                    },
                    {
                      "emit": {
                        "success": "ServicePaymentFlowStripeCompleted",
                        "failure": "ServicePaymentFlowStripeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Payment Failed",
                      "message": "@entity.error",
                      "type": "error-state",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "succeeded",
                "event": "PAYMENT_CONFIRMED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentStatus",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "SEND_RECEIPT"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Payment successful! Sending receipt..."
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.paymentIntentId"
                        },
                        {
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "label": "New Payment",
                          "variant": "ghost",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "title": "Payment Failed",
                      "message": "@entity.error",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "content": "Payment",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "inputType": "number",
                              "placeholder": "0.00",
                              "type": "input"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "label": "EUR",
                                  "value": "eur"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "icon": "credit-card",
                          "label": "Pay",
                          "variant": "primary",
                          "action": "CREATE_PAYMENT",
                          "type": "button"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Payment",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "placeholder": "0.00",
                              "inputType": "number",
                              "type": "input"
                            },
                            {
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "variant": "primary",
                          "icon": "credit-card",
                          "action": "CREATE_PAYMENT",
                          "label": "Pay",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "content": "Payment",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "inputType": "number",
                              "type": "input",
                              "placeholder": "0.00"
                            },
                            {
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "label": "Pay",
                          "type": "button",
                          "action": "CREATE_PAYMENT",
                          "variant": "primary",
                          "icon": "credit-card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServicePaymentFlowReceipt",
          "category": "interaction",
          "linkedEntity": "ServicePaymentFlow",
          "listens": [
            {
              "event": "SEND_RECEIPT",
              "triggers": "SEND_RECEIPT",
              "source": {
                "kind": "trait",
                "trait": "ServicePaymentFlowPayment"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "waiting",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "receiptError"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_RECEIPT",
                "name": "Send Receipt"
              },
              {
                "key": "SENT",
                "name": "Sent"
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RETRY_RECEIPT",
                "name": "Retry Receipt"
              }
            ],
            "transitions": [
              {
                "from": "waiting",
                "to": "waiting",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "mail"
                        },
                        {
                          "content": "Receipt will be sent after payment.",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "waiting",
                "to": "sending",
                "event": "SEND_RECEIPT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Sending receipt...",
                      "type": "loading-state",
                      "message": "Delivering your payment receipt."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "body": "@entity.body",
                      "to": "@entity.to",
                      "subject": "@entity.subject"
                    },
                    {
                      "emit": {
                        "failure": "ServicePaymentFlowEmailFailed",
                        "success": "ServicePaymentFlowEmailCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "message": "Receipt sent successfully",
                          "type": "alert"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "receiptError",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "message": "Could not send receipt email.",
                          "title": "Receipt Failed",
                          "onRetry": "RETRY_RECEIPT",
                          "type": "error-state"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "icon": "refresh-cw",
                          "action": "RETRY_RECEIPT"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "sending",
                "event": "SEND_RECEIPT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Resending receipt..."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "subject": "@entity.subject",
                      "body": "@entity.body",
                      "to": "@entity.to"
                    },
                    {
                      "emit": {
                        "failure": "ServicePaymentFlowEmailFailed",
                        "success": "ServicePaymentFlowEmailCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "receiptError",
                "to": "sending",
                "event": "RETRY_RECEIPT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delivering your payment receipt.",
                      "type": "loading-state",
                      "title": "Sending receipt..."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "to": "@entity.to",
                      "body": "@entity.body",
                      "subject": "@entity.subject"
                    },
                    {
                      "emit": {
                        "failure": "ServicePaymentFlowEmailFailed",
                        "success": "ServicePaymentFlowEmailCompleted"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServicePaymentFlowPage",
          "path": "/servicepaymentflows",
          "traits": [
            {
              "ref": "ServicePaymentFlowPayment"
            },
            {
              "ref": "ServicePaymentFlowReceipt"
            }
          ]
        }
      ]
    }
  ]
}