{
  "name": "std-agent-fix-loop",
  "version": "1.0.0",
  "description": "std-agent-fix-loop as a Function",
  "orbitals": [
    {
      "name": "AgentFixLoopOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        },
        {
          "from": "std/behaviors/std-agent-tool-call",
          "as": "AgentToolCall"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "AgentFixLoop",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "target",
            "type": "string",
            "default": ""
          },
          {
            "name": "validationErrors",
            "type": "string",
            "default": ""
          },
          {
            "name": "fixAttempts",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxAttempts",
            "type": "number",
            "default": 5.0
          },
          {
            "name": "currentFix",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "steps",
            "type": "string",
            "default": "Validate,Analyze,Fix,Re-validate"
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          },
          {
            "name": "args",
            "type": "string",
            "default": ""
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentFixLoopCycle",
          "category": "interaction",
          "linkedEntity": "AgentFixLoop",
          "emits": [
            {
              "event": "FIX_SUCCEEDED",
              "scope": "external",
              "payload": [
                {
                  "name": "target",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FIX_FAILED",
              "scope": "external",
              "payload": [
                {
                  "name": "target",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.FIX_SUCCEEDED",
              "triggers": "INIT"
            },
            {
              "event": "*.FIX_FAILED",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "validating"
              },
              {
                "name": "fixing"
              },
              {
                "name": "applying"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FIX",
                "name": "Fix"
              },
              {
                "key": "VALIDATION_PASSED",
                "name": "Validation Passed"
              },
              {
                "key": "VALIDATION_ERRORS",
                "name": "Validation Errors",
                "payload": [
                  {
                    "name": "errors",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "count",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXCEEDED_ATTEMPTS",
                "name": "Exceeded Attempts",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FIX_GENERATED",
                "name": "Fix Generated",
                "payload": [
                  {
                    "name": "fix",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FIX_APPLIED",
                "name": "Fix Applied"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "FIX_SUCCEEDED",
                "name": "Fix Succeeded"
              },
              {
                "key": "FIX_FAILED",
                "name": "Fix Failed"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Validation-Fix Loop",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Enter the target to validate and auto-fix",
                                  "variant": "body"
                                },
                                {
                                  "type": "form-section",
                                  "fields": [
                                    "target"
                                  ],
                                  "entity": "AgentFixLoop",
                                  "submitEvent": "FIX",
                                  "mode": "edit"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "validating",
                "event": "FIX",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "set",
                    "@entity.fixAttempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    ""
                  ],
                  [
                    "set",
                    "@entity.errorCount",
                    0.0
                  ],
                  [
                    "agent/invoke",
                    "validate-schema",
                    {
                      "target": "@entity.target"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "shield-check"
                        },
                        {
                          "variant": "h3",
                          "content": "Validating...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "@entity.target",
                              "type": "badge"
                            },
                            {
                              "label": [
                                "str/concat",
                                "Attempt ",
                                [
                                  "str/concat",
                                  "@entity.fixAttempts"
                                ],
                                "/",
                                [
                                  "str/concat",
                                  "@entity.maxAttempts"
                                ]
                              ],
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "justify": "center"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "succeeded",
                "event": "VALIDATION_PASSED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "FIX_SUCCEEDED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "space-between",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "check-circle"
                                },
                                {
                                  "content": "Validation Passed",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "event": "RESET",
                              "label": "New Target",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "type": "button"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.fixAttempts",
                              "label": "Fix Attempts",
                              "type": "stat-display",
                              "icon": "wrench"
                            },
                            {
                              "label": "Status",
                              "value": "Passed",
                              "icon": "check",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Target",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.target",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "fixing",
                "event": "VALIDATION_ERRORS",
                "effects": [
                  [
                    "set",
                    "@entity.validationErrors",
                    "@payload.errors"
                  ],
                  [
                    "set",
                    "@entity.errorCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.fixAttempts",
                    [
                      "+",
                      "@entity.fixAttempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "fixing"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Target: ",
                      "@entity.target",
                      "\n\nValidation errors:\n",
                      "@payload.errors",
                      "\n\nGenerate a fix that resolves these errors. Return only the fix content."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "justify": "space-between",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "cpu"
                                },
                                {
                                  "type": "typography",
                                  "content": "Generating fix...",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "label": [
                                "str/concat",
                                "Attempt ",
                                [
                                  "str/concat",
                                  "@entity.fixAttempts"
                                ]
                              ],
                              "type": "badge"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Validation Errors",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "message": "@entity.validationErrors",
                                  "type": "alert",
                                  "variant": "error"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "failed",
                "event": "EXCEEDED_ATTEMPTS",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "x-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Fix Loop Failed"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "wrench",
                              "type": "stat-display",
                              "label": "Attempts Used",
                              "value": "@entity.fixAttempts"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.errorCount",
                              "icon": "alert-triangle",
                              "label": "Remaining Errors"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Last Validation Errors"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.validationErrors",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "event": "RESET"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "fixing",
                "to": "applying",
                "event": "FIX_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.currentFix",
                    "@payload.fix"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "applying"
                  ],
                  [
                    "agent/invoke",
                    "apply-fix",
                    {
                      "target": "@entity.target",
                      "fix": "@payload.fix"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "tool",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Applying fix...",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Proposed Fix"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.currentFix"
                                }
                              ],
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "fixing",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Fix Loop Failed"
                        },
                        {
                          "type": "alert",
                          "message": "@entity.error",
                          "variant": "error"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "wrench",
                              "label": "Attempts Used",
                              "value": "@entity.fixAttempts"
                            },
                            {
                              "icon": "alert-triangle",
                              "label": "Remaining Errors",
                              "type": "stat-display",
                              "value": "@entity.errorCount"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last Validation Errors"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.validationErrors"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "label": "Retry",
                          "event": "RESET",
                          "type": "button",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "applying",
                "to": "validating",
                "event": "FIX_APPLIED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "agent/invoke",
                    "validate-schema",
                    {
                      "target": "@entity.target"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "shield-check",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "content": "Validating...",
                          "variant": "h3"
                        },
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "justify": "center",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.target"
                            },
                            {
                              "type": "badge",
                              "label": [
                                "str/concat",
                                "Attempt ",
                                [
                                  "str/concat",
                                  "@entity.fixAttempts"
                                ],
                                "/",
                                [
                                  "str/concat",
                                  "@entity.maxAttempts"
                                ]
                              ]
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "applying",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Fix Loop Failed"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "wrench",
                              "type": "stat-display",
                              "label": "Attempts Used",
                              "value": "@entity.fixAttempts"
                            },
                            {
                              "label": "Remaining Errors",
                              "value": "@entity.errorCount",
                              "icon": "alert-triangle",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last Validation Errors"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.validationErrors",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "event": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.target",
                    ""
                  ],
                  [
