{
  "name": "std-quiz",
  "version": "1.0.0",
  "description": "std-quiz as a Function",
  "orbitals": [
    {
      "name": "QuizItemOrbital",
      "entity": {
        "name": "QuizItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "question",
            "type": "string",
            "default": ""
          },
          {
            "name": "answer",
            "type": "string",
            "default": ""
          },
          {
            "name": "optionA",
            "type": "string",
            "default": ""
          },
          {
            "name": "optionB",
            "type": "string",
            "default": ""
          },
          {
            "name": "optionC",
            "type": "string",
            "default": ""
          },
          {
            "name": "optionD",
            "type": "string",
            "default": ""
          },
          {
            "name": "difficulty",
            "type": "string",
            "default": "medium"
          },
          {
            "name": "currentIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalQuestions",
            "type": "number",
            "default": 3.0
          }
        ]
      },
      "traits": [
        {
          "name": "QuizItemQuiz",
          "category": "interaction",
          "linkedEntity": "QuizItem",
          "emits": [
            {
              "event": "QuizItemLoaded",
              "description": "Fired when QuizItem finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "question",
                  "type": "string"
                },
                {
                  "name": "answer",
                  "type": "string"
                },
                {
                  "name": "optionA",
                  "type": "string"
                },
                {
                  "name": "optionB",
                  "type": "string"
                },
                {
                  "name": "optionC",
                  "type": "string"
                },
                {
                  "name": "optionD",
                  "type": "string"
                },
                {
                  "name": "difficulty",
                  "type": "string"
                },
                {
                  "name": "currentIndex",
                  "type": "number"
                },
                {
                  "name": "totalQuestions",
                  "type": "number"
                }
              ]
            },
            {
              "event": "QuizItemLoadFailed",
              "description": "Fired when QuizItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "question",
                "isInitial": true
              },
              {
                "name": "answer-revealed"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ANSWER",
                "name": "Answer",
                "payload": [
                  {
                    "name": "answer",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "NEXT",
                "name": "Next"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "QuizItemLoaded",
                "name": "QuizItem loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "question",
                    "type": "string"
                  },
                  {
                    "name": "answer",
                    "type": "string"
                  },
                  {
                    "name": "optionA",
                    "type": "string"
                  },
                  {
                    "name": "optionB",
                    "type": "string"
                  },
                  {
                    "name": "optionC",
                    "type": "string"
                  },
                  {
                    "name": "optionD",
                    "type": "string"
                  },
                  {
                    "name": "difficulty",
                    "type": "string"
                  },
                  {
                    "name": "currentIndex",
                    "type": "number"
                  },
                  {
                    "name": "totalQuestions",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "QuizItemLoadFailed",
                "name": "QuizItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "question",
                "to": "question",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuizItem",
                    {
                      "emit": {
                        "success": "QuizItemLoaded",
                        "failure": "QuizItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "help-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Quiz",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "align": "center",
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "help-circle"
                                },
                                {
                                  "type": "typography",
                                  "content": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "name"
                                  ],
                                  "variant": "h3"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "optionA"
                              ],
                              "type": "button",
                              "action": "ANSWER",
                              "variant": "secondary",
                              "actionPayload": {
                                "answer": "A"
                              }
                            },
                            {
                              "type": "button",
                              "action": "ANSWER",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "optionB"
                              ],
                              "actionPayload": {
                                "answer": "B"
                              },
                              "variant": "secondary"
                            },
                            {
                              "type": "button",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "optionC"
