                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "difficulty"
                                  ]
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "xs",
                              "type": "stack",
                              "align": "center",
