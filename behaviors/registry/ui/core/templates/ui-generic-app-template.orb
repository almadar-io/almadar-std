{
  "description": "GenericAppTemplate — UI factory (1:1 with the @almadar/ui generic-app-template pattern).",
  "name": "ui-generic-app-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GenericAppTemplateItem",
        "persistence": "runtime"
      },
      "name": "GenericAppTemplateOrbital",
      "pages": [
        {
          "name": "GenericAppTemplatePage",
          "path": "/generic-app-template",
          "traits": [
            {
              "ref": "GenericAppTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "footer": {
              "description": "Footer content",
              "label": "Footer",
              "tier": "presentation",
              "type": "node"
            },
            "headerActions": {
              "description": "Header actions (buttons, links)",
              "label": "Header Actions",
              "tier": "presentation",
              "type": "node"
            },
            "subtitle": {
              "default": "Subtitle",
              "description": "Subtitle or description",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "Page title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "GenericAppTemplate rows finished loading; payload.data holds the collection.",
              "event": "GenericAppTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GenericAppTemplateItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GenericAppTemplateItem",
          "name": "GenericAppTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "GenericAppTemplate rows finished loading; payload.data holds the collection.",
                "key": "GenericAppTemplateLoaded",
                "name": "Generic app template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GenericAppTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GenericAppTemplateItem",
                    {
                      "emit": {
                        "success": "GenericAppTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "entity": "@entity",
                      "footer": "@config.footer",
                      "headerActions": "@config.headerActions",
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "type": "generic-app-template"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "entity": "@payload.data",
                      "footer": "@config.footer",
                      "headerActions": "@config.headerActions",
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "type": "generic-app-template"
                    }
                  ]
                ],
                "event": "GenericAppTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}