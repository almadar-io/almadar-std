{
  "name": "ui-generic-app-template",
  "version": "1.0.0",
  "description": "GenericAppTemplate — UI factory (1:1 with the @almadar/ui generic-app-template pattern).",
  "orbitals": [
    {
      "name": "GenericAppTemplateOrbital",
      "entity": {
        "name": "GenericAppTemplateItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GenericAppTemplateRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GenericAppTemplateItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GenericAppTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "headerActions": "@config.headerActions",
                      "footer": "@config.footer",
                      "className": "@config.className",
                      "subtitle": "@config.subtitle",
                      "entity": "@entity",
                      "title": "@config.title",
                      "children": "@config.children",
                      "type": "generic-app-template"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "footer": {
              "type": "node",
              "label": "Footer",
              "description": "Footer content",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "",
              "label": "Subtitle",
              "description": "Subtitle or description",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class name",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Page title",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Main content",
              "tier": "presentation"
            },
            "headerActions": {
              "type": "node",
              "label": "Header Actions",
              "description": "Header actions (buttons, links)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GenericAppTemplatePage",
          "path": "/generic-app-template",
          "traits": [
            {
              "ref": "GenericAppTemplateRender"
            }
          ]
        }
      ]
    }
  ]
}