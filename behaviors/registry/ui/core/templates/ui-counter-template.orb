{
  "description": "CounterTemplate — UI factory (1:1 with the @almadar/ui counter-template pattern).",
  "name": "ui-counter-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "count",
            "type": "number"
          },
          {
            "default": false,
            "name": "decrementDisabled",
            "type": "boolean"
          },
          {
            "default": false,
            "name": "incrementDisabled",
            "type": "boolean"
          },
          {
            "default": "Decrement Label",
            "name": "decrementLabel",
            "type": "string"
          },
          {
            "default": "Increment Label",
            "name": "incrementLabel",
            "type": "string"
          },
          {
            "default": "Range Text",
            "name": "rangeText",
            "type": "string"
          }
        ],
        "name": "CounterTemplateItem",
        "persistence": "runtime"
      },
      "name": "CounterTemplateOrbital",
      "pages": [
        {
          "name": "CounterTemplatePage",
          "path": "/counter-template",
          "traits": [
            {
              "ref": "CounterTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "decrementEvent": {
              "default": "DECREMENT",
              "description": "Declarative event key — emits UI:{decrementEvent} via bus on decrement",
              "label": "Decrement Event",
              "tier": "presentation",
              "type": "string"
            },
            "incrementEvent": {
              "default": "INCREMENT",
              "description": "Declarative event key — emits UI:{incrementEvent} via bus on increment",
              "label": "Increment Event",
              "tier": "presentation",
              "type": "string"
            },
            "onDecrement": {
              "default": "DECREMENT",
              "description": "Called when decrement is clicked",
              "label": "On Decrement",
              "tier": "presentation",
              "type": "string"
            },
            "onIncrement": {
              "default": "INCREMENT",
              "description": "Called when increment is clicked",
              "label": "On Increment",
              "tier": "presentation",
              "type": "string"
            },
            "onReset": {
              "default": "RESET",
              "description": "Called when reset is clicked",
              "label": "On Reset",
              "tier": "presentation",
              "type": "string"
            },
            "resetEvent": {
              "default": "RESET",
              "description": "Declarative event key — emits UI:{resetEvent} via bus on reset",
              "label": "Reset Event",
              "tier": "presentation",
              "type": "string"
            },
            "showReset": {
              "default": true,
              "description": "Show reset button",
              "label": "Show Reset",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Counter display size",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "title": {
              "default": "Counter",
              "description": "Title displayed above the counter",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "minimal",
              "description": "Template variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "minimal",
                "standard",
                "full"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when increment is clicked",
              "event": "@config.onIncrement",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when decrement is clicked",
              "event": "@config.onDecrement",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when reset is clicked",
              "event": "@config.onReset",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "CounterTemplate rows finished loading; payload.data holds the collection.",
              "event": "CounterTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CounterTemplateItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CounterTemplateItem",
          "name": "CounterTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "CounterTemplate rows finished loading; payload.data holds the collection.",
                "key": "CounterTemplateLoaded",
                "name": "Counter template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CounterTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "Called when increment is clicked",
                "key": "@config.onIncrement",
                "name": "@config.on increment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when decrement is clicked",
                "key": "@config.onDecrement",
                "name": "@config.on decrement",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when reset is clicked",
                "key": "@config.onReset",
                "name": "@config.on reset",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "CounterTemplateItem",
                    {
                      "emit": {
                        "success": "CounterTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "decrementEvent": "@config.decrementEvent",
                      "entity": "@entity",
                      "incrementEvent": "@config.incrementEvent",
                      "onDecrement": "@config.onDecrement",
                      "onIncrement": "@config.onIncrement",
                      "onReset": "@config.onReset",
                      "resetEvent": "@config.resetEvent",
                      "showReset": "@config.showReset",
                      "size": "@config.size",
                      "title": "@config.title",
                      "type": "counter-template",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "decrementEvent": "@config.decrementEvent",
                      "entity": "@payload.data",
                      "incrementEvent": "@config.incrementEvent",
                      "onDecrement": "@config.onDecrement",
                      "onIncrement": "@config.onIncrement",
                      "onReset": "@config.onReset",
                      "resetEvent": "@config.resetEvent",
                      "showReset": "@config.showReset",
                      "size": "@config.size",
                      "title": "@config.title",
                      "type": "counter-template",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "CounterTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}