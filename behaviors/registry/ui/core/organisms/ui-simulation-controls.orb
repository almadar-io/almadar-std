{
  "name": "ui-simulation-controls",
  "version": "1.0.0",
  "description": "SimulationControls — UI factory (1:1 with the @almadar/ui simulation-controls pattern).",
  "orbitals": [
    {
      "name": "SimulationControlsOrbital",
      "entity": {
        "name": "SimulationControlsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "speed",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "SimulationControlsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "speed"
            ]
          },
          "category": "interaction",
          "linkedEntity": "SimulationControlsItem",
          "emits": [
            {
              "event": "PLAY",
              "description": "onPlay prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PAUSE",
              "description": "onPause prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "STEP",
              "description": "onStep prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESET",
              "description": "onReset prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SPEED_CHANGE",
              "description": "onSpeedChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "speed",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PARAMETER_CHANGE",
              "description": "onParameterChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "value",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SPEED_CHANGE",
                "name": "Speed Change",
                "description": "onSpeedChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "speed",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PLAY",
                "name": "Play",
                "description": "onPlay prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause",
                "description": "onPause prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "STEP",
                "name": "Step",
                "description": "onStep prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset",
                "description": "onReset prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PARAMETER_CHANGE",
                "name": "Parameter Change",
                "description": "onParameterChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.speed",
                    "@config.speed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "speed": "@entity.speed",
                      "onStep": "STEP",
                      "onPause": "PAUSE",
                      "onSpeedChange": "SPEED_CHANGE",
                      "onParameterChange": "PARAMETER_CHANGE",
                      "type": "simulation-controls",
                      "onPlay": "PLAY",
                      "running": "@config.running",
                      "parameters": "@config.parameters",
                      "onReset": "RESET"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SPEED_CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.speed",
                    "@payload.speed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onReset": "RESET",
                      "onPause": "PAUSE",
                      "onPlay": "PLAY",
                      "className": "@config.className",
                      "onStep": "STEP",
                      "running": "@config.running",
                      "onParameterChange": "PARAMETER_CHANGE",
                      "speed": "@entity.speed",
                      "parameters": "@config.parameters",
                      "onSpeedChange": "SPEED_CHANGE",
                      "type": "simulation-controls"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "parameters": {
              "type": "Map<string,SimulationControlsParametersValue>",
              "default": {},
              "label": "Parameters",
              "description": "parameters prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "min": {
                    "name": "min",
                    "type": "number",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "number",
                    "required": true
                  },
                  "step": {
                    "name": "step",
                    "type": "number",
                    "required": true
                  },
                  "max": {
                    "name": "max",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "speed": {
              "type": "number",
              "default": 0.0,
              "label": "Speed",
              "description": "speed prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "running": {
              "type": "boolean",
              "default": false,
              "label": "Running",
              "description": "running prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SimulationControlsPage",
          "path": "/simulation-controls",
          "traits": [
            {
              "ref": "SimulationControlsRender"
            }
          ]
        }
      ]
    }
  ]
}