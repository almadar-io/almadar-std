{
  "name": "ui-sequence-bar",
  "version": "1.0.0",
  "description": "SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern).",
  "orbitals": [
    {
      "name": "SequenceBarOrbital",
      "entity": {
        "name": "SequenceBarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SequenceBarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SequenceBarItem",
          "emits": [
            {
              "event": "SLOT_DROP",
              "description": "Called when an item is dropped into slot at index",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                },
                {
                  "name": "item",
                  "type": "object"
                }
              ]
            },
            {
              "event": "SLOT_REMOVE",
              "description": "Called when a slot is cleared",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SLOT_DROP",
                "name": "Slot Drop",
                "description": "Called when an item is dropped into slot at index",
                "tier": "essential"
              },
              {
                "key": "SLOT_REMOVE",
                "name": "Slot Remove",
                "description": "Called when a slot is cleared",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "currentStep": "@config.currentStep",
                      "onSlotDrop": "SLOT_DROP",
                      "className": "@config.className",
                      "type": "sequence-bar",
                      "onSlotRemove": "SLOT_REMOVE",
                      "size": "@config.size",
                      "maxSlots": "@config.maxSlots",
                      "playing": "@config.playing",
                      "slotFeedback": "@config.slotFeedback",
                      "categoryColors": "@config.categoryColors",
                      "slots": "@config.slots"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "categoryColors": {
              "type": "json",
              "label": "Category Colors",
              "description": "Category → color mapping",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "slots": {
              "type": "[json]",
              "default": [],
              "label": "Slots",
              "description": "The current sequence (sparse — undefined means empty slot)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "slotFeedback": {
              "type": "[string]",
              "default": [],
              "label": "Slot Feedback",
              "description": "Per-slot correctness feedback shown after a failed attempt",
              "tier": "presentation",
              "items": {
                "type": "string",
                "values": [
                  "correct",
                  "wrong"
                ]
              }
            },
            "size": {
              "type": "string",
              "default": "lg",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "maxSlots": {
              "type": "number",
              "default": 0.0,
              "label": "Max Slots",
              "description": "Max number of slots",
              "tier": "presentation"
            },
            "playing": {
              "type": "boolean",
              "default": false,
              "label": "Playing",
              "description": "Whether the sequence is currently playing (disable interaction)",
              "tier": "presentation"
            },
            "currentStep": {
              "type": "number",
              "default": -1.0,
              "label": "Current Step",
              "description": "Current step index during playback (-1 = not playing)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SequenceBarPage",
          "path": "/sequence-bar",
          "traits": [
            {
              "ref": "SequenceBarRender"
            }
          ]
        }
      ]
    }
  ]
}