{
  "name": "ui-entity-table",
  "version": "1.0.0",
  "description": "EntityTable — UI factory (1:1 with the @almadar/ui entity-table pattern).",
  "orbitals": [
    {
      "name": "EntityTableOrbital",
      "entity": {
        "name": "EntityTableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EntityTableRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "EntityTableItem",
          "emits": [
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EntityTableItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "emptyDescription": "@config.emptyDescription",
                      "rowActions": "@config.rowActions",
                      "showTotal": "@config.showTotal",
                      "sortDirection": "@config.sortDirection",
                      "selectedIds": "@config.selectedIds",
                      "totalCount": "@config.totalCount",
                      "sortBy": "@config.sortBy",
                      "bulkActions": "@config.bulkActions",
                      "itemActions": [
                        {
                          "event": "VIEW",
                          "label": "View"
                        }
                      ],
                      "type": "entity-table",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "columns": "@config.columns",
                      "className": "@config.className",
                      "isLoading": "@config.isLoading",
                      "searchable": "@config.searchable",
                      "headerActions": "@config.headerActions",
                      "activeFilters": "@config.activeFilters",
                      "look": "@config.look",
                      "fields": "@config.fields",
                      "emptyTitle": "@config.emptyTitle",
                      "emptyIcon": "@config.emptyIcon",
                      "entity": "@entity",
                      "pageSize": "@config.pageSize",
                      "searchValue": "@config.searchValue",
                      "emptyAction": "@config.emptyAction",
                      "selectable": "@config.selectable",
                      "page": "@config.pageProp",
                      "error": "@config.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "sortBy": {
              "type": "string",
              "default": "",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "bulkActions": {
              "type": "[EntityTableBulkActionsItem]",
              "default": [],
              "label": "Bulk Actions",
              "description": "Bulk actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "danger"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "searchValue": {
              "type": "string",
              "default": "",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "columns": {
              "type": "[EntityTableColumnsItem]",
              "default": [],
              "label": "Columns",
              "description": "Columns can be Column objects or simple string field names",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "width": {
                    "name": "width",
                    "type": "string",
                    "required": false
                  },
                  "sortable": {
                    "name": "sortable",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            },
            "emptyIcon": {
              "type": "string",
              "default": "",
              "label": "Empty Icon",
              "description": "emptyIcon prop",
              "tier": "presentation"
            },
            "emptyTitle": {
              "type": "string",
              "default": "",
              "label": "Empty Title",
              "description": "emptyTitle prop",
              "tier": "presentation"
            },
            "emptyAction": {
              "type": "EntityTableEmptyAction",
              "label": "Empty Action",
              "description": "emptyAction prop",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "event": {
                  "name": "event",
                  "type": "string",
                  "required": false
                }
              }
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "dense",
              "label": "Look",
              "description": "Layer 2 visual treatment — orthogonal to the semantic variant.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "emptyDescription": {
              "type": "string",
              "default": "",
              "label": "Empty Description",
              "description": "emptyDescription prop",
              "tier": "presentation"
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "searchable": {
              "type": "boolean",
              "default": false,
              "label": "Searchable",
              "description": "Search",
              "tier": "presentation"
            },
            "rowActions": {
              "type": "[EntityTableRowActionsItem]",
              "default": [],
              "label": "Row Actions",
              "description": "Row actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "danger"
                    ]
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "showTotal": {
              "type": "boolean",
              "default": true,
              "label": "Show Total",
              "description": "Show total count in pagination",
              "tier": "presentation"
            },
            "itemActions": {
              "type": "[EntityTableItemActionsItem]",
              "default": [],
              "label": "Item Actions",
              "description": "Item actions from generated code - maps to rowActions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "action": {
                    "name": "action",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "placement": {
                    "name": "placement",
                    "type": "string",
                    "required": false,
                    "values": [
                      "row",
                      "bulk"
                    ]
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "selectable": {
              "type": "boolean",
              "default": false,
              "label": "Selectable",
              "description": "Selection",
              "tier": "presentation"
            },
            "error": {
              "type": "EntityTableError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "searchPlaceholder": {
              "type": "string",
              "default": "",
              "label": "Search Placeholder",
              "description": "searchPlaceholder prop",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "headerActions": {
              "type": "node",
              "label": "Header Actions",
              "description": "Header actions",
              "tier": "presentation"
            },
            "fields": {
              "type": "[EntityTableFieldsItem]",
              "default": [],
              "label": "Fields",
              "description": "Fields to display - accepts string[] or Column[] for unified interface. Alias for columns",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "sortable": {
                    "name": "sortable",
                    "type": "boolean",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "width": {
                    "name": "width",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EntityTablePage",
          "path": "/entity-table",
          "traits": [
            {
              "ref": "EntityTableRender"
            }
          ]
        }
      ]
    }
  ]
}