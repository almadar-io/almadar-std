{
  "name": "ui-media-gallery",
  "version": "1.0.0",
  "description": "MediaGallery — UI factory (1:1 with the @almadar/ui media-gallery pattern).",
  "orbitals": [
    {
      "name": "MediaGalleryOrbital",
      "entity": {
        "name": "MediaGalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MediaGalleryRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MediaGalleryItem",
          "emits": [
            {
              "event": "SELECTION",
              "description": "Event name emitted when selection changes (emitted as UI:{selectionEvent})",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "selection",
                  "type": "[object]",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECTION",
                "name": "Selection",
                "description": "Event name emitted when selection changes (emitted as UI:{selectionEvent})",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "selection",
                    "type": "[object]",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MediaGalleryItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "media-gallery",
                      "pageSize": "@config.pageSize",
                      "page": "@config.pageProp",
                      "columns": "@config.columns",
                      "title": "@config.title",
                      "searchValue": "@config.searchValue",
                      "items": "@config.items",
                      "selectionEvent": "SELECTION",
                      "selectedIds": "@config.selectedIds",
                      "entity": "@entity",
                      "error": "@config.error",
                      "totalCount": "@config.totalCount",
                      "aspectRatio": "@config.aspectRatio",
                      "isLoading": "@config.isLoading",
                      "selectedItems": "@config.selectedItems",
                      "activeFilters": "@config.activeFilters",
                      "sortDirection": "@config.sortDirection",
                      "showUpload": "@config.showUpload",
                      "selectable": "@config.selectable",
                      "actions": "@config.actions",
                      "sortBy": "@config.sortBy",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "actions": {
              "type": "[MediaGalleryActionsItem]",
              "default": [],
              "label": "Actions",
              "description": "Actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "error": {
              "type": "MediaGalleryError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "showUpload": {
              "type": "boolean",
              "default": false,
              "label": "Show Upload",
              "description": "Show upload button",
              "tier": "presentation"
            },
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Gallery title",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "aspectRatio": {
              "type": "string",
              "default": "square",
              "label": "Aspect Ratio",
              "description": "Aspect ratio for thumbnails",
              "tier": "presentation",
              "values": [
                "square",
                "landscape",
                "portrait"
              ]
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "items": {
              "type": "[MediaGalleryItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Media items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "thumbnail": {
                    "name": "thumbnail",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "mediaType": {
                    "name": "mediaType",
                    "type": "string",
                    "required": false,
                    "values": [
                      "image",
                      "video"
                    ]
                  },
                  "caption": {
                    "name": "caption",
                    "type": "string",
                    "required": false
                  },
                  "alt": {
                    "name": "alt",
                    "type": "string",
                    "required": false
                  },
                  "fileSize": {
                    "name": "fileSize",
                    "type": "string",
                    "required": false
                  },
                  "src": {
                    "name": "src",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "columns": {
              "type": "number",
              "default": 3.0,
              "label": "Columns",
              "description": "Column count",
              "tier": "presentation"
            },
            "selectedItems": {
              "type": "[string]",
              "default": [],
              "label": "Selected Items",
              "description": "Selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "selectable": {
              "type": "boolean",
              "default": false,
              "label": "Selectable",
              "description": "Enable item selection",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MediaGalleryPage",
          "path": "/media-gallery",
          "traits": [
            {
              "ref": "MediaGalleryRender"
            }
          ]
        }
      ]
    }
  ]
}