{
  "name": "ui-sidebar",
  "version": "1.0.0",
  "description": "Sidebar — UI factory (1:1 with the @almadar/ui sidebar pattern).",
  "orbitals": [
    {
      "name": "SidebarOrbital",
      "entity": {
        "name": "SidebarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SidebarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SidebarItem",
          "emits": [
            {
              "event": "COLLAPSE_CHANGE",
              "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "collapsed",
                  "type": "boolean",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE",
              "description": "Event emitted when close button is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LOGO_CLICK",
              "description": "Event emitted when logo/brand is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COLLAPSE_CHANGE",
                "name": "Collapse Change",
                "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
                "tier": "essential"
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "description": "Event emitted when close button is clicked",
                "tier": "essential"
              },
              {
                "key": "LOGO_CLICK",
                "name": "Logo Click",
                "description": "Event emitted when logo/brand is clicked",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "collapsed": "@config.collapsed",
                      "logoSrc": "@config.logoSrc",
                      "collapseChangeEvent": "COLLAPSE_CHANGE",
                      "hideCollapseButton": "@config.hideCollapseButton",
                      "userSection": "@config.userSection",
                      "items": "@config.items",
                      "error": "@config.error",
                      "className": "@config.className",
                      "defaultCollapsed": "@config.defaultCollapsed",
                      "logo": "@config.logo",
                      "logoClickEvent": "LOGO_CLICK",
                      "isLoading": "@config.isLoading",
                      "showCloseButton": "@config.showCloseButton",
                      "type": "sidebar",
                      "footerContent": "@config.footerContent",
                      "closeEvent": "CLOSE",
                      "brandName": "@config.brandName"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "userSection": {
              "type": "node",
              "label": "User Section",
              "description": "User section content",
              "tier": "presentation"
            },
            "showCloseButton": {
              "type": "boolean",
              "default": false,
              "label": "Show Close Button",
              "description": "Show a close button (for mobile)",
              "tier": "presentation"
            },
            "footerContent": {
              "type": "node",
              "label": "Footer Content",
              "description": "Footer content (e.g., theme toggle)",
              "tier": "presentation"
            },
            "hideCollapseButton": {
              "type": "boolean",
              "default": false,
              "label": "Hide Collapse Button",
              "description": "Hide the collapse/expand button",
              "tier": "presentation"
            },
            "brandName": {
              "type": "string",
              "default": "KFlow",
              "label": "Brand Name",
              "description": "Brand/App name",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "logo": {
              "type": "node",
              "label": "Logo",
              "description": "Logo/Brand content - can be a ReactNode or logo config",
              "tier": "presentation"
            },
            "items": {
              "type": "[SidebarItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Navigation items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "subItems": {
                    "name": "subItems",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "active": {
                    "name": "active",
                    "type": "boolean",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "isActive": {
                    "name": "isActive",
                    "type": "boolean",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "error": {
              "type": "SidebarError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "collapsed": {
              "type": "boolean",
              "default": false,
              "label": "Collapsed",
              "description": "Collapsed state (controlled)",
              "tier": "presentation"
            },
            "defaultCollapsed": {
              "type": "boolean",
              "default": false,
              "label": "Default Collapsed",
              "description": "Default collapsed state",
              "tier": "presentation"
            },
            "logoSrc": {
              "type": "string",
              "default": "",
              "label": "Logo Src",
              "description": "Logo image source",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SidebarPage",
          "path": "/sidebar",
          "traits": [
            {
              "ref": "SidebarRender"
            }
          ]
        }
      ]
    }
  ]
}