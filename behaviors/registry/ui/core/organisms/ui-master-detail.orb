      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeFilters": {
              "default": {},
              "description": "Active filters",
              "label": "Active Filters",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "detailFields": {
              "default": [],
              "description": "Fields for detail view (passed through but typically handled by separate render_ui)",
              "items": {
                "type": "string"
              },
              "label": "Detail Fields",
              "tier": "presentation",
              "type": "[string]"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "MasterDetailError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "loading": {
              "default": false,
              "description": "Loading state (alias for isLoading)",
              "label": "Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "masterFields": {
              "default": [
                "Item",
                "Item 2"
              ],
              "description": "Fields to show in the master list (maps to DataTable columns)",
              "items": {
                "type": "string"
              },
              "label": "Master Fields",
              "tier": "presentation",
              "type": "[string]"
            },
