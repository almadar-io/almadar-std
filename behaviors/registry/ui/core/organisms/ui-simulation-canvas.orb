{
  "name": "ui-simulation-canvas",
  "version": "1.0.0",
  "description": "SimulationCanvas — UI factory (1:1 with the @almadar/ui simulation-canvas pattern).",
  "orbitals": [
    {
      "name": "SimulationCanvasOrbital",
      "entity": {
        "name": "SimulationCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SimulationCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SimulationCanvasItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "preset": "@config.preset",
                      "width": "@config.width",
                      "height": "@config.height",
                      "running": "@config.running",
                      "speed": "@config.speed",
                      "className": "@config.className",
                      "type": "simulation-canvas"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "preset": {
              "type": "SimulationCanvasPreset",
              "label": "Preset",
              "description": "preset prop",
              "tier": "presentation",
              "properties": {
                "gravity": {
                  "name": "gravity",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "x": {
                      "name": "x",
                      "type": "number",
                      "required": true
                    },
                    "y": {
                      "name": "y",
                      "type": "number",
                      "required": true
                    }
                  }
                },
                "bodies": {
                  "name": "bodies",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "radius": {
                        "name": "radius",
                        "type": "number",
                        "required": true
                      },
                      "fixed": {
                        "name": "fixed",
                        "type": "boolean",
                        "required": true
                      },
                      "vy": {
                        "name": "vy",
                        "type": "number",
                        "required": true
                      },
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      "mass": {
                        "name": "mass",
                        "type": "number",
                        "required": true
                      },
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "vx": {
                        "name": "vx",
                        "type": "number",
                        "required": true
                      },
                      "color": {
                        "name": "color",
                        "type": "string",
                        "required": true
                      },
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    }
                  }
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                "domain": {
                  "name": "domain",
                  "type": "string",
                  "required": true
                },
                "backgroundColor": {
                  "name": "backgroundColor",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "showVelocity": {
                  "name": "showVelocity",
                  "type": "boolean",
                  "required": false
                },
                "constraints": {
                  "name": "constraints",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "object",
                    "properties": {
                      "bodyA": {
                        "name": "bodyA",
                        "type": "number",
                        "required": true
                      },
                      "stiffness": {
                        "name": "stiffness",
                        "type": "number",
                        "required": true
                      },
                      "bodyB": {
                        "name": "bodyB",
                        "type": "number",
                        "required": true
                      },
                      "length": {
                        "name": "length",
                        "type": "number",
                        "required": true
                      }
                    }
                  }
                },
                "parameters": {
                  "name": "parameters",
                  "type": "string",
                  "required": true
                }
              }
            },
            "width": {
              "type": "number",
              "default": 600.0,
              "label": "Width",
              "description": "width prop",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 400.0,
              "label": "Height",
              "description": "height prop",
              "tier": "presentation"
            },
            "running": {
              "type": "boolean",
              "default": false,
              "label": "Running",
              "description": "running prop",
              "tier": "presentation"
            },
            "speed": {
              "type": "number",
              "default": 1.0,
              "label": "Speed",
              "description": "speed prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SimulationCanvasPage",
          "path": "/simulation-canvas",
          "traits": [
            {
              "ref": "SimulationCanvasRender"
            }
          ]
        }
      ]
    }
  ]
}