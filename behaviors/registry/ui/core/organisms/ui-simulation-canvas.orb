{
  "name": "ui-simulation-canvas",
  "version": "1.0.0",
  "description": "SimulationCanvas — UI factory (1:1 with the @almadar/ui simulation-canvas pattern).",
  "orbitals": [
    {
      "name": "SimulationCanvasOrbital",
      "entity": {
        "name": "SimulationCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SimulationCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SimulationCanvasItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "speed": "@config.speed",
                      "height": "@config.height",
                      "preset": "@config.preset",
                      "type": "simulation-canvas",
                      "width": "@config.width",
                      "running": "@config.running"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "width": {
              "type": "number",
              "default": 600.0,
              "label": "Width",
              "description": "width prop",
              "tier": "presentation"
            },
            "running": {
              "type": "boolean",
              "default": false,
              "label": "Running",
              "description": "running prop",
              "tier": "presentation"
            },
            "preset": {
              "type": "json",
              "label": "Preset",
              "description": "preset prop",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 400.0,
              "label": "Height",
              "description": "height prop",
              "tier": "presentation"
            },
            "speed": {
              "type": "number",
              "default": 1.0,
              "label": "Speed",
              "description": "speed prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SimulationCanvasPage",
          "path": "/simulation-canvas",
          "traits": [
            {
              "ref": "SimulationCanvasRender"
            }
          ]
        }
      ]
    }
  ]
}