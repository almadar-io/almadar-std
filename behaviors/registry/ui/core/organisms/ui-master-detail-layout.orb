{
  "description": "MasterDetailLayout — UI factory (1:1 with the @almadar/ui master-detail-layout pattern).",
  "name": "ui-master-detail-layout",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MasterDetailLayoutItem",
        "persistence": "runtime"
      },
      "name": "MasterDetailLayoutOrbital",
      "pages": [
        {
          "name": "MasterDetailLayoutPage",
          "path": "/master-detail-layout",
          "traits": [
            {
              "ref": "MasterDetailLayoutRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "detail": {
              "default": [
                {
                  "content": "Detail",
                  "type": "typography"
                }
              ],
              "description": "Detail panel content",
              "label": "Detail",
              "tier": "presentation",
              "type": "node"
            },
            "detailClassName": {
              "default": "Detail Class Name",
              "description": "Class for detail pane",
              "label": "Detail Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "emptyDetail": {
              "description": "Content shown when nothing is selected",
              "label": "Empty Detail",
              "tier": "presentation",
              "type": "node"
            },
            "hasSelection": {
              "default": false,
              "description": "Whether an item is currently selected",
              "label": "Has Selection",
              "tier": "presentation",
              "type": "boolean"
            },
            "master": {
              "default": [
                {
                  "content": "Master",
                  "type": "typography"
                }
              ],
              "description": "Master panel content (usually a list)",
              "label": "Master",
              "tier": "presentation",
              "type": "node"
            },
            "masterClassName": {
              "default": "Master Class Name",
              "description": "Class for master pane",
              "label": "Master Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "masterWidth": {
              "default": "350px",
              "description": "Width of master panel (e.g., '350px', '30%')",
              "label": "Master Width",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MasterDetailLayoutItem",
          "name": "MasterDetailLayoutRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "detail": "@config.detail",
                      "detailClassName": "@config.detailClassName",
                      "emptyDetail": "@config.emptyDetail",
                      "hasSelection": "@config.hasSelection",
                      "master": "@config.master",
                      "masterClassName": "@config.masterClassName",
                      "masterWidth": "@config.masterWidth",
                      "type": "master-detail-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}