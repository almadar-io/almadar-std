{
  "name": "ui-master-detail-layout",
  "version": "1.0.0",
  "description": "MasterDetailLayout — UI factory (1:1 with the @almadar/ui master-detail-layout pattern).",
  "orbitals": [
    {
      "name": "MasterDetailLayoutOrbital",
      "entity": {
        "name": "MasterDetailLayoutItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MasterDetailLayoutRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MasterDetailLayoutItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "masterClassName": "@config.masterClassName",
                      "type": "master-detail-layout",
                      "master": [
                        {
                          "content": "Master",
                          "type": "typography"
                        }
                      ],
                      "masterWidth": "@config.masterWidth",
                      "hasSelection": "@config.hasSelection",
                      "detailClassName": "@config.detailClassName",
                      "emptyDetail": "@config.emptyDetail",
                      "detail": [
                        {
                          "content": "Detail",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "emptyDetail": {
              "type": "node",
              "label": "Empty Detail",
              "description": "Content shown when nothing is selected",
              "tier": "presentation"
            },
            "detailClassName": {
              "type": "string",
              "default": "Detail Class Name",
              "label": "Detail Class Name",
              "description": "Class for detail pane",
              "tier": "presentation"
            },
            "masterWidth": {
              "type": "string",
              "default": "350px",
              "label": "Master Width",
              "description": "Width of master panel (e.g., '350px', '30%')",
              "tier": "presentation"
            },
            "hasSelection": {
              "type": "boolean",
              "default": false,
              "label": "Has Selection",
              "description": "Whether an item is currently selected",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "masterClassName": {
              "type": "string",
              "default": "Master Class Name",
              "label": "Master Class Name",
              "description": "Class for master pane",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MasterDetailLayoutPage",
          "path": "/master-detail-layout",
          "traits": [
            {
              "ref": "MasterDetailLayoutRender"
            }
          ]
        }
      ]
    }
  ]
}