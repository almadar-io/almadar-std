{
  "name": "ui-split-pane",
  "version": "1.0.0",
  "description": "SplitPane — UI factory (1:1 with the @almadar/ui split-pane pattern).",
  "orbitals": [
    {
      "name": "SplitPaneOrbital",
      "entity": {
        "name": "SplitPaneItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SplitPaneRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SplitPaneItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "@config.direction",
                      "leftClassName": "@config.leftClassName",
                      "ratio": "@config.ratio",
                      "className": "@config.className",
                      "left": "@config.left",
                      "right": "@config.right",
                      "rightClassName": "@config.rightClassName",
                      "resizable": "@config.resizable",
                      "minSize": "@config.minSize",
                      "type": "split-pane"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "left": {
              "type": "node",
              "label": "Left",
              "description": "Content for the left/top pane",
              "tier": "presentation"
            },
            "direction": {
              "type": "string",
              "default": "horizontal",
              "label": "Direction",
              "description": "Direction of the split",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "rightClassName": {
              "type": "string",
              "default": "Right Class Name",
              "label": "Right Class Name",
              "description": "Class for right/bottom pane",
              "tier": "presentation"
            },
            "right": {
              "type": "node",
              "label": "Right",
              "description": "Content for the right/bottom pane",
              "tier": "presentation"
            },
            "leftClassName": {
              "type": "string",
              "default": "Left Class Name",
              "label": "Left Class Name",
              "description": "Class for left/top pane",
              "tier": "presentation"
            },
            "ratio": {
              "type": "number",
              "default": 0.0,
              "label": "Ratio",
              "description": "Initial ratio (0-100, percentage of first pane)",
              "tier": "presentation"
            },
            "minSize": {
              "type": "number",
              "default": 100.0,
              "label": "Min Size",
              "description": "Minimum size of either pane in pixels",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "resizable": {
              "type": "boolean",
              "default": true,
              "label": "Resizable",
              "description": "Allow user resizing",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SplitPanePage",
          "path": "/split-pane",
          "traits": [
            {
              "ref": "SplitPaneRender"
            }
          ]
        }
      ]
    }
  ]
}