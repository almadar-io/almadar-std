{
  "name": "ui-timeline",
  "version": "1.0.0",
  "description": "Timeline — UI factory (1:1 with the @almadar/ui timeline pattern).",
  "orbitals": [
    {
      "name": "TimelineOrbital",
      "entity": {
        "name": "TimelineItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TimelineRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TimelineItem",
          "emits": [
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TimelineItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "fields": "@config.fields",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "className": "@config.className",
                      "entity": "@entity",
                      "look": "@config.look",
                      "type": "timeline",
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW"
                        }
                      ],
                      "title": "@config.title",
                      "items": "@config.items"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "error": {
              "type": "TimelineError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "look": {
              "type": "string",
              "default": "vertical-spacious",
              "label": "Look",
              "description": "Layer 2 visual treatment.",
              "tier": "presentation",
              "values": [
                "vertical-compact",
                "vertical-spacious",
                "horizontal",
                "swimlane"
              ]
            },
            "items": {
              "type": "[TimelineItemsItem]",
              "default": [
                {
                  "title": "Title",
                  "description": "Description",
                  "status": "complete",
                  "icon": "circle",
                  "tags": [
                    "Item"
                  ],
                  "id": "Id",
                  "date": "Date"
                }
              ],
              "label": "Items",
              "description": "Timeline items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "date": {
                    "name": "date",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "tags": {
                    "name": "tags",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "status": {
                    "name": "status",
                    "type": "string",
                    "required": false,
                    "values": [
                      "complete",
                      "active",
                      "pending",
                      "error"
                    ]
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Timeline title",
              "tier": "presentation"
            },
            "fields": {
              "type": "[string]",
              "default": [
                "Item"
              ],
              "label": "Fields",
              "description": "Fields to display",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[TimelineItemActionsItem]",
              "default": [
                {
                  "variant": "primary",
                  "navigatesTo": "Navigates To",
                  "label": "Label"
                }
              ],
              "label": "Item Actions",
              "description": "Actions per item",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TimelinePage",
          "path": "/timeline",
          "traits": [
            {
              "ref": "TimelineRender"
            }
          ]
        }
      ]
    }
  ]
}