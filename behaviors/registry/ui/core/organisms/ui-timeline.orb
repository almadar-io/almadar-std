                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04T5N1F9TZR298S9NAD39",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entity": "@payload.data",
                      "error": "@config.error",
                      "fields": "@config.fields",
                      "isLoading": "@config.isLoading",
                      "itemActions": "@config.itemActions",
                      "items": "@config.items",
                      "look": "@config.look",
