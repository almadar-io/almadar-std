{
  "name": "ui-transition-arrow",
  "version": "1.0.0",
  "description": "TransitionArrow — UI factory (1:1 with the @almadar/ui transition-arrow pattern).",
  "orbitals": [
    {
      "name": "TransitionArrowOrbital",
      "entity": {
        "name": "TransitionArrowItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TransitionArrowRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TransitionArrowItem",
          "emits": [
            {
              "event": "CLICK",
              "description": "Click handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Click handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "guardHint": "@config.guardHint",
                      "isActive": "@config.isActive",
                      "type": "transition-arrow",
                      "to": "@config.toProp",
                      "onClick": "CLICK",
                      "eventLabel": "@config.eventLabel",
                      "className": "@config.className",
                      "from": "@config.fromProp"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fromProp": {
              "type": "TransitionArrowFrom",
              "default": {
                "x": 0.0,
                "y": 0.0
              },
              "label": "From",
              "description": "Start position (center of from-node)",
              "synonyms": "from",
              "tier": "presentation",
              "properties": {
                "y": {
                  "name": "y",
                  "type": "number",
                  "required": true
                },
                "x": {
                  "name": "x",
                  "type": "number",
                  "required": true
                }
              }
            },
            "toProp": {
              "type": "TransitionArrowTo",
              "default": {
                "x": 0.0,
                "y": 0.0
              },
              "label": "To",
              "description": "End position (center of to-node)",
              "synonyms": "to",
              "tier": "presentation",
              "properties": {
                "x": {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                "y": {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              }
            },
            "eventLabel": {
              "type": "string",
              "default": "Event Label",
              "label": "Event Label",
              "description": "Event label shown on the arrow",
              "tier": "presentation"
            },
            "guardHint": {
              "type": "string",
              "default": "Guard Hint",
              "label": "Guard Hint",
              "description": "Guard hint shown below event",
              "tier": "presentation"
            },
            "isActive": {
              "type": "boolean",
              "default": false,
              "label": "Is Active",
              "description": "Whether this transition is currently active",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes for the SVG group",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TransitionArrowPage",
          "path": "/transition-arrow",
          "traits": [
            {
              "ref": "TransitionArrowRender"
            }
          ]
        }
      ]
    }
  ]
}