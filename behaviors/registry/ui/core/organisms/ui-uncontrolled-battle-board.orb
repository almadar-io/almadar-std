{
  "name": "ui-uncontrolled-battle-board",
  "version": "1.0.0",
  "description": "UncontrolledBattleBoard — UI factory (1:1 with the @almadar/ui uncontrolled-battle-board pattern).",
  "orbitals": [
    {
      "name": "UncontrolledBattleBoardOrbital",
      "entity": {
        "name": "UncontrolledBattleBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "UncontrolledBattleBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "UncontrolledBattleBoardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@config.entityProp",
                      "type": "uncontrolled-battle-board"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "entityProp": {
              "type": "UncontrolledBattleBoardEntity",
              "label": "Entity",
              "description": "The compiler binds the generic `EntityRow`, so the inlet accepts it (and",
              "synonyms": "entity",
              "tier": "presentation",
              "properties": {
                "initialUnits": {
                  "name": "initialUnits",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "health": {
                        "name": "health",
                        "type": "number",
                        "required": true
                      },
                      "maxHealth": {
                        "name": "maxHealth",
                        "type": "number",
                        "required": true
                      },
                      "attack": {
                        "name": "attack",
                        "type": "number",
                        "required": true
                      },
                      "sprite": {
                        "name": "sprite",
                        "type": "string",
                        "required": false
                      },
                      "defense": {
                        "name": "defense",
                        "type": "number",
                        "required": true
                      },
                      "position": {
                        "name": "position",
                        "type": "object",
                        "required": true,
                        "properties": {
                          "x": {
                            "name": "x",
                            "type": "number",
                            "required": true
                          },
                          "y": {
                            "name": "y",
                            "type": "number",
                            "required": true
                          }
                        }
                      },
                      "spriteSheet": {
                        "name": "spriteSheet",
                        "type": "object",
                        "required": false,
                        "properties": {
                          "se": {
                            "name": "se",
                            "type": "string",
                            "required": true
                          },
                          "sw": {
                            "name": "sw",
                            "type": "string",
                            "required": true
                          },
                          "frameWidth": {
                            "name": "frameWidth",
                            "type": "number",
                            "required": true
                          },
                          "frameHeight": {
                            "name": "frameHeight",
                            "type": "number",
                            "required": true
                          }
                        }
                      },
                      "unitType": {
                        "name": "unitType",
                        "type": "string",
                        "required": false
                      },
                      "movement": {
                        "name": "movement",
                        "type": "number",
                        "required": true
                      },
                      "traits": {
                        "name": "traits",
                        "type": "array",
                        "required": false,
                        "items": {
                          "type": "object",
                          "properties": {
                            "currentState": {
                              "name": "currentState",
                              "type": "string",
                              "required": true
                            },
                            "states": {
                              "name": "states",
                              "type": "array",
                              "required": true,
                              "items": {
                                "type": "string"
                              }
                            },
                            "cooldown": {
                              "name": "cooldown",
                              "type": "number",
                              "required": false
                            },
                            "name": {
                              "name": "name",
                              "type": "string",
                              "required": true
                            }
                          }
                        }
                      },
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      "team": {
                        "name": "team",
                        "type": "string",
                        "required": true,
                        "values": [
                          "player",
                          "enemy"
                        ]
                      },
                      "heroId": {
                        "name": "heroId",
                        "type": "string",
                        "required": false
                      }
                    }
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "UncontrolledBattleBoardPage",
          "path": "/uncontrolled-battle-board",
          "traits": [
            {
              "ref": "UncontrolledBattleBoardRender"
            }
          ]
        }
      ]
    }
  ]
}