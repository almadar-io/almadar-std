{
  "name": "ui-page-header",
  "version": "1.0.0",
  "description": "PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern).",
  "orbitals": [
    {
      "name": "PageHeaderOrbital",
      "entity": {
        "name": "PageHeaderItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PageHeaderRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PageHeaderItem",
          "emits": [
            {
              "event": "BACK",
              "description": "Event to emit when back is clicked (default: BACK)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TAB_CHANGE",
              "description": "onTabChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BACK",
                "name": "Back",
                "description": "Event to emit when back is clicked (default: BACK)",
                "tier": "essential"
              },
              {
                "key": "TAB_CHANGE",
                "name": "Tab Change",
                "description": "onTabChange prop",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageHeaderItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "tabs": "@config.tabs",
                      "entity": "PageHeaderItem",
                      "breadcrumbs": "@config.breadcrumbs",
                      "subtitle": "@config.subtitle",
                      "isLoading": "@config.isLoading",
                      "children": "@config.children",
                      "className": "@config.className",
                      "actions": "@config.actions",
                      "activeTab": "@config.activeTab",
                      "showBack": "@config.showBack",
                      "status": "@config.status",
                      "title": "@config.title",
                      "backEvent": "BACK",
                      "type": "page-header",
                      "onTabChange": "TAB_CHANGE",
                      "error": "@config.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showBack": {
              "type": "boolean",
              "default": false,
              "label": "Show Back",
              "description": "Show back button",
              "tier": "presentation"
            },
            "tabs": {
              "type": "[json]",
              "default": [],
              "label": "Tabs",
              "description": "Tabs for sub-navigation",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Custom content in the header",
              "tier": "presentation"
            },
            "status": {
              "type": "json",
              "label": "Status",
              "description": "Status badge",
              "tier": "presentation"
            },
            "breadcrumbs": {
              "type": "[PageHeaderBreadcrumbsItem]",
              "default": [],
              "label": "Breadcrumbs",
              "description": "Breadcrumbs",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "error": {
              "type": "json",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "json",
              "label": "Subtitle",
              "description": "Optional subtitle/description",
              "tier": "presentation"
            },
            "activeTab": {
              "type": "string",
              "default": "",
              "label": "Active Tab",
              "description": "activeTab prop",
              "tier": "presentation"
            },
            "title": {
              "type": "json",
              "label": "Title",
              "description": "Page title - accepts unknown to handle generated code accessing dynamic entity data",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "actions": {
              "type": "[json]",
              "default": [],
              "label": "Actions",
              "description": "Actions array - first action with variant='primary' (or first action) is the main action",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PageHeaderPage",
          "path": "/page-header",
          "traits": [
            {
              "ref": "PageHeaderRender"
            }
          ]
        }
      ]
    }
  ]
}