{
  "name": "ui-entity-cards",
  "version": "1.0.0",
  "description": "EntityCards — UI factory (1:1 with the @almadar/ui entity-cards pattern).",
  "orbitals": [
    {
      "name": "EntityCardsOrbital",
      "entity": {
        "name": "EntityCardsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EntityCardsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "EntityCardsItem",
          "emits": [
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EntityCardsItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "sortDirection": "@config.sortDirection",
                      "maxCols": "@config.maxCols",
                      "sortBy": "@config.sortBy",
                      "alignItems": "@config.alignItems",
                      "fields": "@config.fields",
                      "searchValue": "@config.searchValue",
                      "showTotal": "@config.showTotal",
                      "showAvatar": "@config.showAvatar",
                      "variant": "@config.variant",
                      "type": "entity-cards",
                      "minCardWidth": "@config.minCardWidth",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sample content"
                        }
                      ],
                      "activeFilters": "@config.activeFilters",
                      "fieldNames": "@config.fieldNames",
                      "gap": "@config.gap",
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW"
                        }
                      ],
                      "imageField": "@config.imageField",
                      "selectedIds": "@config.selectedIds",
                      "columns": "@config.columns",
                      "pageSize": "@config.pageSize",
                      "page": "@config.pageProp",
                      "totalCount": "@config.totalCount",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "entity": "@entity",
                      "className": "@config.className"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "columns": {
              "type": "[EntityCardsColumnsItem]",
              "default": [
                {
                  "name": "Name",
                  "key": "Key",
                  "header": "Header",
                  "label": "Label"
                }
              ],
              "label": "Columns",
              "description": "Alias for fields - backwards compatibility",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between cards",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "variant": {
              "type": "string",
              "default": "Variant",
              "label": "Variant",
              "description": "Visual variant for the card grid",
              "tier": "presentation"
            },
            "fields": {
              "type": "[EntityCardsFieldsItem]",
              "default": [
                {
                  "header": "Header",
                  "name": "Name",
                  "key": "Key",
                  "label": "Label"
                }
              ],
              "label": "Fields",
              "description": "Fields to display - required for schema-driven rendering",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "showAvatar": {
              "type": "boolean",
              "default": false,
              "label": "Show Avatar",
              "description": "Show avatar/image field on cards",
              "tier": "presentation"
            },
            "imageField": {
              "type": "string",
              "default": "Image Field",
              "label": "Image Field",
              "description": "Entity field name containing an image URL to display as card thumbnail",
              "tier": "presentation"
            },
            "alignItems": {
              "type": "string",
              "default": "stretch",
              "label": "Align Items",
              "description": "Align cards vertically in their cells",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "error": {
              "type": "EntityCardsError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "fieldNames": {
              "type": "[string]",
              "default": [],
              "label": "Field Names",
              "description": "Alias for fields - backwards compatibility",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "maxCols": {
              "type": "number",
              "default": 1.0,
              "label": "Max Cols",
              "description": "Maximum number of columns",
              "tier": "presentation"
            },
            "showTotal": {
              "type": "boolean",
              "default": true,
              "label": "Show Total",
              "description": "Show total count in pagination",
              "tier": "presentation"
            },
            "minCardWidth": {
              "type": "number",
              "default": 280.0,
              "label": "Min Card Width",
              "description": "Minimum width of each card (default: 280px)",
              "tier": "presentation"
            },
            "itemActions": {
              "type": "[EntityCardsItemActionsItem]",
              "default": [
                {
                  "navigatesTo": "Navigates To",
                  "placement": "card",
                  "label": "Label",
                  "action": "Action",
                  "variant": "primary"
                }
              ],
              "label": "Item Actions",
              "description": "Actions for each card item (schema-driven)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "action": {
                    "name": "action",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "placement": {
                    "name": "placement",
                    "type": "string",
                    "required": false,
                    "values": [
                      "card",
                      "footer",
                      "row"
                    ]
                  }
                }
              }
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EntityCardsPage",
          "path": "/entity-cards",
          "traits": [
            {
              "ref": "EntityCardsRender"
            }
          ]
        }
      ]
    }
  ]
}