{
  "name": "ui-entity-cards",
  "version": "1.0.0",
  "description": "EntityCards — UI factory (1:1 with the @almadar/ui entity-cards pattern).",
  "orbitals": [
    {
      "name": "EntityCardsOrbital",
      "entity": {
        "name": "EntityCardsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EntityCardsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "EntityCardsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EntityCardsItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "@config.gap",
                      "showTotal": "@config.showTotal",
                      "className": "@config.className",
                      "sortDirection": "@config.sortDirection",
                      "selectedIds": "@config.selectedIds",
                      "alignItems": "@config.alignItems",
                      "fields": "@config.fields",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "variant": "@config.variant",
                      "pageSize": "@config.pageSize",
                      "fieldNames": "@config.fieldNames",
                      "showAvatar": "@config.showAvatar",
                      "imageField": "@config.imageField",
                      "totalCount": "@config.totalCount",
                      "columns": "@config.columns",
                      "children": "@config.children",
                      "type": "entity-cards",
                      "searchValue": "@config.searchValue",
                      "itemActions": "@config.itemActions",
                      "entity": "@entity",
                      "sortBy": "@config.sortBy",
                      "minCardWidth": "@config.minCardWidth",
                      "maxCols": "@config.maxCols",
                      "activeFilters": "@config.activeFilters"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[json]",
              "default": [],
              "label": "Fields",
              "description": "Fields to display - required for schema-driven rendering",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "showAvatar": {
              "type": "boolean",
              "default": false,
              "label": "Show Avatar",
              "description": "Show avatar/image field on cards",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Children elements (cards) - optional when using entity prop",
              "tier": "presentation"
            },
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between cards",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "sortBy": {
              "type": "string",
              "default": "",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation"
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "columns": {
              "type": "[json]",
              "default": [],
              "label": "Columns",
              "description": "Alias for fields - backwards compatibility",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[EntityCardsItemActionsItem]",
              "default": [],
              "label": "Item Actions",
              "description": "Actions for each card item (schema-driven)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "placement": {
                    "name": "placement",
                    "type": "string",
                    "required": false
                  },
                  "onClick": {
                    "name": "onClick",
                    "type": "string",
                    "required": false
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "action": {
                    "name": "action",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "variant": {
              "type": "string",
              "default": "",
              "label": "Variant",
              "description": "Visual variant for the card grid",
              "tier": "presentation"
            },
            "showTotal": {
              "type": "boolean",
              "default": true,
              "label": "Show Total",
              "description": "Show total count in pagination",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "alignItems": {
              "type": "string",
              "default": "stretch",
              "label": "Align Items",
              "description": "Align cards vertically in their cells",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            },
            "selectedIds": {
              "type": "[json]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "minCardWidth": {
              "type": "number",
              "default": 280.0,
              "label": "Min Card Width",
              "description": "Minimum width of each card (default: 280px)",
              "tier": "presentation"
            },
            "error": {
              "type": "json",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "maxCols": {
              "type": "number",
              "default": 0.0,
              "label": "Max Cols",
              "description": "Maximum number of columns",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "fieldNames": {
              "type": "[string]",
              "default": [],
              "label": "Field Names",
              "description": "Alias for fields - backwards compatibility",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "imageField": {
              "type": "string",
              "default": "",
              "label": "Image Field",
              "description": "Entity field name containing an image URL to display as card thumbnail",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EntityCardsPage",
          "path": "/entity-cards",
          "traits": [
            {
              "ref": "EntityCardsRender"
            }
          ]
        }
      ]
    }
  ]
}