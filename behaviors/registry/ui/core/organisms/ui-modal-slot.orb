{
  "description": "ModalSlot — UI factory (1:1 with the @almadar/ui modal-slot pattern).",
  "name": "ui-modal-slot",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ModalSlotItem",
        "persistence": "runtime"
      },
      "name": "ModalSlotOrbital",
      "pages": [
        {
          "name": "ModalSlotPage",
          "path": "/modal-slot",
          "traits": [
            {
              "ref": "ModalSlotRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Content to display in the modal",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Custom class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ModalSlotError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Modal size",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl",
                "full"
              ]
            },
            "sourceTrait": {
              "default": "Source Trait",
              "description": "Source trait name for qualified event emission",
              "label": "Source Trait",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "Override modal title (extracted from children if not provided)",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ModalSlotItem",
          "name": "ModalSlotRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "ModalSlotItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "entity": "ModalSlotItem",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "size": "@config.size",
                      "sourceTrait": "@config.sourceTrait",
                      "title": "@config.title",
                      "type": "modal-slot"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}