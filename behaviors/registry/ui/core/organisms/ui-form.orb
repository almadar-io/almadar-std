              "label": "Config Path",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "FormError"
            },
            "evaluationContext": {
              "description": "Context for S-expression evaluation",
              "label": "Evaluation Context",
              "properties": {
                "entity": {
                  "name": "entity",
                  "required": false,
                  "type": "string"
                },
                "formValues": {
                  "name": "formValues",
                  "required": true,
                  "type": "string"
                },
                "globalVariables": {
                  "items": {
                    "type": "string"
                  },
                  "name": "globalVariables",
                  "required": true,
                  "type": "object"
                },
                "localVariables": {
                  "items": {
                    "type": "string"
                  },
                  "name": "localVariables",
                  "required": false,
                  "type": "object"
                }
              },
              "tier": "presentation",
              "type": "FormEvaluationContext"
            },
