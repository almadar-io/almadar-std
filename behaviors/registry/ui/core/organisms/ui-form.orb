{
  "name": "ui-form",
  "version": "1.0.0",
  "description": "Form — UI factory (1:1 with the @almadar/ui form pattern).",
  "orbitals": [
    {
      "name": "FormOrbital",
      "entity": {
        "name": "FormItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FormRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FormItem",
          "emits": [
            {
              "event": "SUBMIT",
              "description": "Event dispatch props (for trait state machine integration)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "description": "Event to dispatch on cancel (defaults to 'CANCEL')",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FIELD_CHANGE",
              "description": "Callback when any field value changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "change",
                  "type": "object"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "description": "Event dispatch props (for trait state machine integration)",
                "tier": "essential"
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "description": "Event to dispatch on cancel (defaults to 'CANCEL')",
                "tier": "essential"
              },
              {
                "key": "FIELD_CHANGE",
                "name": "Field Change",
                "description": "Callback when any field value changes",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FormItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "relationsData": "@config.relationsData",
                      "entity": "@entity",
                      "submitLabel": "@config.submitLabel",
                      "gap": "@config.gap",
                      "error": "@config.error",
                      "sections": "@config.sections",
                      "type": "form",
                      "configPath": "@config.configPath",
                      "layout": "@config.layout",
                      "relationsLoading": "@config.relationsLoading",
                      "fields": "@config.fields",
                      "children": "@config.children",
                      "initialData": "@config.initialData",
                      "cancelLabel": "@config.cancelLabel",
                      "violationTriggers": "@config.violationTriggers",
                      "submitEvent": "SUBMIT",
                      "isLoading": "@config.isLoading",
                      "cancelEvent": "CANCEL",
                      "onFieldChange": "FIELD_CHANGE",
                      "showCancel": "@config.showCancel",
                      "onSubmit": "@config.onSubmit",
                      "title": "@config.title",
                      "mode": "@config.mode",
                      "hiddenCalculations": "@config.hiddenCalculations",
                      "className": "@config.className",
                      "onCancel": "@config.onCancel",
                      "repeatable": "@config.repeatable",
                      "showSubmit": "@config.showSubmit",
                      "conditionalFields": "@config.conditionalFields",
                      "evaluationContext": "@config.evaluationContext"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "sections": {
              "type": "[FormSectionsItem]",
              "default": [],
              "label": "Sections",
              "description": "Nested form sections with optional conditions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "fields": {
                    "name": "fields",
                    "type": "array",
                    "required": true,
                    "items": {
                      "type": "object",
                      "properties": {
                        "options": {
                          "name": "options",
                          "type": "array",
                          "required": false,
                          "items": {
                            "type": "object",
                            "properties": {
                              "value": {
                                "name": "value",
                                "type": "string",
                                "required": true
                              },
                              "label": {
                                "name": "label",
                                "type": "string",
                                "required": true
                              }
                            }
                          }
                        },
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": false
                        },
                        "readonly": {
                          "name": "readonly",
                          "type": "boolean",
                          "required": false
                        },
                        "disabled": {
                          "name": "disabled",
                          "type": "boolean",
                          "required": false
                        },
                        "placeholder": {
                          "name": "placeholder",
                          "type": "string",
                          "required": false
                        },
                        "inputType": {
                          "name": "inputType",
                          "type": "string",
                          "required": false
                        },
                        "max": {
                          "name": "max",
                          "type": "number",
                          "required": false
                        },
                        "values": {
                          "name": "values",
                          "type": "array",
                          "required": false,
                          "items": {
                            "type": "string"
                          }
                        },
                        "validation": {
                          "name": "validation",
                          "type": "string",
                          "required": false
                        },
                        "type": {
                          "name": "type",
                          "type": "string",
                          "required": false
                        },
                        "relation": {
                          "name": "relation",
                          "type": "object",
                          "required": false,
                          "properties": {
                            "displayField": {
                              "name": "displayField",
                              "type": "string",
                              "required": false
                            },
                            "cardinality": {
                              "name": "cardinality",
                              "type": "string",
                              "required": false,
                              "values": [
                                "one",
                                "many"
                              ]
                            },
                            "entity": {
                              "name": "entity",
                              "type": "string",
                              "required": true
                            }
                          }
                        },
                        "min": {
                          "name": "min",
                          "type": "number",
                          "required": false
                        },
                        "field": {
                          "name": "field",
                          "type": "string",
                          "required": false
                        },
                        "pattern": {
                          "name": "pattern",
                          "type": "string",
                          "required": false
                        },
                        "required": {
                          "name": "required",
                          "type": "boolean",
                          "required": false
                        },
                        "name": {
                          "name": "name",
                          "type": "string",
                          "required": false
                        },
                        "defaultValue": {
                          "name": "defaultValue",
                          "type": "string",
                          "required": false
                        }
                      }
                    }
                  },
                  "collapsible": {
                    "name": "collapsible",
                    "type": "boolean",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "condition": {
                    "name": "condition",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "submitLabel": {
              "type": "string",
              "default": "",
              "label": "Submit Label",
              "description": "Submit button label",
              "tier": "presentation"
            },
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between fields",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "showCancel": {
              "type": "boolean",
              "default": false,
              "label": "Show Cancel",
              "description": "Show cancel button (defaults to true for schema forms)",
              "tier": "presentation"
            },
            "configPath": {
              "type": "string",
              "default": "",
              "label": "Config Path",
              "description": "Config path for form configuration (schema-driven)",
              "tier": "presentation"
            },
            "showSubmit": {
              "type": "boolean",
              "default": true,
              "label": "Show Submit",
              "description": "Show submit button (defaults to true for schema forms). Set false when a parent atom owns the submit action externally (e.g. wizard footers).",
              "tier": "presentation"
            },
            "cancelLabel": {
              "type": "string",
              "default": "",
              "label": "Cancel Label",
              "description": "Cancel button label (if provided, shows cancel button)",
              "tier": "presentation"
            },
            "hiddenCalculations": {
              "type": "json",
              "label": "Hidden Calculations",
              "description": "Hidden calculations that emit GLOBAL_VARIABLE_SET on field change (boolean true means enabled but config loaded separately)",
              "tier": "presentation"
            },
            "layout": {
              "type": "string",
              "default": "vertical",
              "label": "Layout",
              "description": "Form layout",
              "tier": "presentation",
              "values": [
                "vertical",
                "horizontal",
                "inline"
              ]
            },
            "conditionalFields": {
              "type": "json",
              "label": "Conditional Fields",
              "description": "Inspection form extensions",
              "tier": "presentation"
            },
            "mode": {
              "type": "string",
              "default": "",
              "label": "Mode",
              "description": "Form mode — 'create' for new records, 'edit' for updating existing. Accepts `string` so schema-driven callers (whose `config.mode` is typed as `string` per the trait's declared config block) compile cleanly. The runtime treats anything other than 'edit' as 'create'.",
              "tier": "presentation"
            },
            "initialData": {
              "type": "json",
              "label": "Initial Data",
              "description": "Initial form data",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Form title (used by ModalSlot to extract title)",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Form fields (traditional React children)",
              "tier": "presentation"
            },
            "relationsLoading": {
              "type": "json",
              "label": "Relations Loading",
              "description": "Loading state for relation data: { fieldName: boolean }",
              "tier": "presentation"
            },
            "evaluationContext": {
              "type": "FormEvaluationContext",
              "label": "Evaluation Context",
              "description": "Context for S-expression evaluation - accepts flexible types from generated code",
              "tier": "presentation",
              "properties": {
                "localVariables": {
                  "name": "localVariables",
                  "type": "string",
                  "required": false
                },
                "formValues": {
                  "name": "formValues",
                  "type": "string",
                  "required": true
                },
                "globalVariables": {
                  "name": "globalVariables",
                  "type": "string",
                  "required": true
                },
                "entity": {
                  "name": "entity",
                  "type": "string",
                  "required": false
                }
              }
            },
            "onCancel": {
              "type": "string",
              "default": "",
              "label": "On Cancel",
              "description": "Cancel event name for trait dispatch (emitted via eventBus as UI:{onCancel})",
              "tier": "presentation"
            },
            "relationsData": {
              "type": "json",
              "label": "Relations Data",
              "description": "Relation data props",
              "tier": "presentation"
            },
            "error": {
              "type": "FormError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "violationTriggers": {
              "type": "json",
              "label": "Violation Triggers",
              "description": "Violation conditions that emit VIOLATION_DETECTED when met (boolean true means enabled but config loaded separately)",
              "tier": "presentation"
            },
            "fields": {
              "type": "[FormFieldsItem]",
              "default": [],
              "label": "Fields",
              "description": "Fields definition (schema format) - accepts readonly for generated const arrays",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "validation": {
                    "name": "validation",
                    "type": "string",
                    "required": false
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  },
                  "relation": {
                    "name": "relation",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "entity": {
                        "name": "entity",
                        "type": "string",
                        "required": true
                      },
                      "displayField": {
                        "name": "displayField",
                        "type": "string",
                        "required": false
                      },
                      "cardinality": {
                        "name": "cardinality",
                        "type": "string",
                        "required": false,
                        "values": [
                          "one",
                          "many"
                        ]
                      }
                    }
                  },
                  "options": {
                    "name": "options",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "value": {
                          "name": "value",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  },
                  "inputType": {
                    "name": "inputType",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "required": {
                    "name": "required",
                    "type": "boolean",
                    "required": false
                  },
                  "pattern": {
                    "name": "pattern",
                    "type": "string",
                    "required": false
                  },
                  "placeholder": {
                    "name": "placeholder",
                    "type": "string",
                    "required": false
                  },
                  "defaultValue": {
                    "name": "defaultValue",
                    "type": "string",
                    "required": false
                  },
                  "max": {
                    "name": "max",
                    "type": "number",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "min": {
                    "name": "min",
                    "type": "number",
                    "required": false
                  },
                  "readonly": {
                    "name": "readonly",
                    "type": "boolean",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "values": {
                    "name": "values",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "repeatable": {
              "type": "boolean",
              "default": false,
              "label": "Repeatable",
              "description": "Whether the form supports repeatable entries",
              "tier": "presentation"
            },
            "onSubmit": {
              "type": "string",
              "default": "",
              "label": "On Submit",
              "description": "Submit event name for trait dispatch (emitted via eventBus as UI:{onSubmit})",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormPage",
          "path": "/form",
          "traits": [
            {
              "ref": "FormRender"
            }
          ]
        }
      ]
    }
  ]
}