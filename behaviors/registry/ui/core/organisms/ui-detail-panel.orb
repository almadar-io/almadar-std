{
  "name": "ui-detail-panel",
  "version": "1.0.0",
  "description": "DetailPanel — UI factory (1:1 with the @almadar/ui detail-panel pattern).",
  "orbitals": [
    {
      "name": "DetailPanelOrbital",
      "entity": {
        "name": "DetailPanelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DetailPanelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DetailPanelItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailPanelItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "activeFilters": "@config.activeFilters",
                      "initialData": "@config.initialData",
                      "title": "@config.title",
                      "avatar": "@config.avatar",
                      "displayFields": "@config.displayFields",
                      "searchValue": "@config.searchValue",
                      "width": "@config.width",
                      "sortBy": "@config.sortBy",
                      "subtitle": "@config.subtitle",
                      "position": "@config.position",
                      "showActions": "@config.showActions",
                      "sortDirection": "@config.sortDirection",
                      "actions": "@config.actions",
                      "fieldNames": "@config.fieldNames",
                      "page": "@config.pageProp",
                      "slideOver": "@config.slideOver",
                      "fields": "@config.fields",
                      "error": "@config.error",
                      "pageSize": "@config.pageSize",
                      "mode": "@config.mode",
                      "type": "detail-panel",
                      "status": "@config.status",
                      "sections": "@config.sections",
                      "entity": "@entity",
                      "selectedIds": "@config.selectedIds",
                      "footer": "@config.footer",
                      "isLoading": "@config.isLoading",
                      "className": "@config.className",
                      "totalCount": "@config.totalCount"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "fields": {
              "type": "[DetailPanelFieldsItem]",
              "default": [],
              "label": "Fields",
              "description": "Fields to display - accepts string[], {key, header}[], or DetailField[]",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "width": {
              "type": "string",
              "default": "",
              "label": "Width",
              "description": "Panel width (CSS value, e.g., '400px', '50%')",
              "tier": "presentation"
            },
            "mode": {
              "type": "string",
              "default": "",
              "label": "Mode",
              "description": "Display mode (passed by compiler)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "position": {
              "type": "string",
              "default": "left",
              "label": "Position",
              "description": "Panel position (for drawer/sidebar placement)",
              "tier": "presentation",
              "values": [
                "left",
                "right"
              ]
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "fieldNames": {
              "type": "[string]",
              "default": [],
              "label": "Field Names",
              "description": "Alias for fields - backwards compatibility",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "status": {
              "type": "DetailPanelStatus",
              "label": "Status",
              "description": "status prop",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "success",
                    "warning",
                    "danger",
                    "info"
                  ]
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "actions": {
              "type": "[DetailPanelActionsItem]",
              "default": [],
              "label": "Actions",
              "description": "Unified actions array - first action with variant='primary' is the main action",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "initialData": {
              "type": "json",
              "label": "Initial Data",
              "description": "Initial data for edit mode (passed by compiler)",
              "tier": "presentation"
            },
            "showActions": {
              "type": "boolean",
              "default": false,
              "label": "Show Actions",
              "description": "Show actions flag",
              "tier": "presentation"
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "title prop",
              "tier": "presentation"
            },
            "sections": {
              "type": "[DetailPanelSectionsItem]",
              "default": [],
              "label": "Sections",
              "description": "sections prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "fields": {
                    "name": "fields",
                    "type": "array",
                    "required": true,
                    "items": {
                      "type": "object",
                      "properties": {
                        "icon": {
                          "name": "icon",
                          "type": "string",
                          "required": false
                        },
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "copyable": {
                          "name": "copyable",
                          "type": "boolean",
                          "required": false
                        },
                        "value": {
                          "name": "value",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  }
                }
              }
            },
            "error": {
              "type": "DetailPanelError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "searchValue": {
              "type": "string",
              "default": "",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "sortBy": {
              "type": "string",
              "default": "",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "avatar": {
              "type": "node",
              "label": "Avatar",
              "description": "avatar prop",
              "tier": "presentation"
            },
            "displayFields": {
              "type": "[string]",
              "default": [],
              "label": "Display Fields",
              "description": "Display fields (alias for fields)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "footer": {
              "type": "node",
              "label": "Footer",
              "description": "footer prop",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "",
              "label": "Subtitle",
              "description": "subtitle prop",
              "tier": "presentation"
            },
            "slideOver": {
              "type": "boolean",
              "default": false,
              "label": "Slide Over",
              "description": "slideOver prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DetailPanelPage",
          "path": "/detail-panel",
          "traits": [
            {
              "ref": "DetailPanelRender"
            }
          ]
        }
      ]
    }
  ]
}
