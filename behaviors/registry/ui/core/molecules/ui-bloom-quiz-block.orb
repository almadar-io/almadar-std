{
  "name": "ui-bloom-quiz-block",
  "version": "1.0.0",
  "description": "BloomQuizBlock — UI factory (1:1 with the @almadar/ui bloom-quiz-block pattern).",
  "orbitals": [
    {
      "name": "BloomQuizBlockOrbital",
      "entity": {
        "name": "BloomQuizBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BloomQuizBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BloomQuizBlockItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "answer": "@config.answer",
                      "index": "@config.index",
                      "type": "bloom-quiz-block",
                      "level": "@config.level",
                      "question": "@config.question",
                      "isAnswered": "@config.isAnswered",
                      "answerEvent": "@config.answerEvent",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "question": {
              "type": "string",
              "default": "Question",
              "label": "Question",
              "description": "question prop",
              "tier": "presentation"
            },
            "level": {
              "type": "string",
              "default": "remember",
              "label": "Level",
              "description": "level prop",
              "tier": "presentation",
              "values": [
                "remember",
                "understand",
                "apply",
                "analyze",
                "evaluate",
                "create"
              ]
            },
            "answerEvent": {
              "type": "string",
              "default": "ANSWER_BLOOM",
              "label": "Answer Event",
              "description": "Event name emitted on first reveal (as `UI:<answerEvent>`). Defaults to 'ANSWER_BLOOM'.",
              "tier": "presentation"
            },
            "isAnswered": {
              "type": "boolean",
              "default": false,
              "label": "Is Answered",
              "description": "Whether the learner has already answered",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "index": {
              "type": "number",
              "default": 0.0,
              "label": "Index",
              "description": "Zero-based index (used in the emitted event payload)",
              "tier": "presentation"
            },
            "answer": {
              "type": "string",
              "default": "Answer",
              "label": "Answer",
              "description": "answer prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BloomQuizBlockPage",
          "path": "/bloom-quiz-block",
          "traits": [
            {
              "ref": "BloomQuizBlockRender"
            }
          ]
        }
      ]
    }
  ]
}