{
  "name": "ui-code-viewer",
  "version": "1.0.0",
  "description": "CodeViewer — UI factory (1:1 with the @almadar/ui code-viewer pattern).",
  "orbitals": [
    {
      "name": "CodeViewerOrbital",
      "entity": {
        "name": "CodeViewerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CodeViewerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CodeViewerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CodeViewerItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "mode": "@config.mode",
                      "maxHeight": "@config.maxHeight",
                      "className": "@config.className",
                      "language": "@config.language",
                      "files": "@config.files",
                      "error": "@config.error",
                      "showLineNumbers": "@config.showLineNumbers",
                      "diff": "@config.diff",
                      "isLoading": "@config.isLoading",
                      "oldValue": "@config.oldValue",
                      "showCopy": "@config.showCopy",
                      "code": "@config.code",
                      "type": "code-viewer",
                      "entity": "CodeViewerItem",
                      "newValue": "@config.newValue",
                      "title": "@config.title",
                      "actions": "@config.actions",
                      "wordWrap": "@config.wordWrap"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showCopy": {
              "type": "boolean",
              "default": true,
              "label": "Show Copy",
              "description": "Show copy button",
              "tier": "presentation"
            },
            "wordWrap": {
              "type": "boolean",
              "default": false,
              "label": "Word Wrap",
              "description": "Enable word wrap",
              "tier": "presentation"
            },
            "actions": {
              "type": "[CodeViewerActionsItem]",
              "default": [],
              "label": "Actions",
              "description": "Actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": "CodeViewerError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "newValue": {
              "type": "string",
              "default": "New Value",
              "label": "New Value",
              "description": "New value (for generating diff)",
              "tier": "presentation"
            },
            "language": {
              "type": "string",
              "default": "Language",
              "label": "Language",
              "description": "Language for display label",
              "tier": "presentation"
            },
            "code": {
              "type": "string",
              "default": "Code",
              "label": "Code",
              "description": "Code content",
              "tier": "presentation"
            },
            "mode": {
              "type": "string",
              "default": "code",
              "label": "Mode",
              "description": "Display mode",
              "tier": "presentation",
              "values": [
                "code",
                "diff"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Viewer title",
              "tier": "presentation"
            },
            "oldValue": {
              "type": "string",
              "default": "Old Value",
              "label": "Old Value",
              "description": "Old value (for generating diff)",
              "tier": "presentation"
            },
            "diff": {
              "type": "[CodeViewerDiffItem]",
              "default": [],
              "label": "Diff",
              "description": "Diff lines (for diff mode)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true,
                    "values": [
                      "added",
                      "removed",
                      "unchanged",
                      "context"
                    ]
                  },
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "afterLineNumber": {
                    "name": "afterLineNumber",
                    "type": "number",
                    "required": false
                  },
                  "beforeLineNumber": {
                    "name": "beforeLineNumber",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
            "showLineNumbers": {
              "type": "boolean",
              "default": true,
              "label": "Show Line Numbers",
              "description": "Show line numbers",
              "tier": "presentation"
            },
            "maxHeight": {
              "type": "string",
              "default": "Max Height",
              "label": "Max Height",
              "description": "Max height before scrolling",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "files": {
              "type": "[CodeViewerFilesItem]",
              "default": [],
              "label": "Files",
              "description": "Multiple files (tabbed view)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": true
                  },
                  "language": {
                    "name": "language",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CodeViewerPage",
          "path": "/code-viewer",
          "traits": [
            {
              "ref": "CodeViewerRender"
            }
          ]
        }
      ]
    }
  ]
}