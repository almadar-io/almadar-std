            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "DataGrid rows finished loading; payload.data holds the collection.",
                "key": "DataGridLoaded",
                "name": "Data grid loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DataGridItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "User opened a record from the list.",
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })",
                "key": "@config.selectionEvent",
                "name": "@config.selection event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
