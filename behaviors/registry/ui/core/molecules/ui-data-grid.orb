                      "sortable": "@config.sortable",
                      "type": "data-grid"
                    }
                  ]
                ],
                "event": "DataGridLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ],
                "event": "VIEW",
                "from": "idle",
                "to": "idle"
              }
            ]
