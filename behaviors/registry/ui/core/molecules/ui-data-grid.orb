              "label": "Accepts",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "cols": {
              "default": 1.0,
              "description": "Number of columns (uses auto-fit if omitted)",
              "label": "Cols",
              "tier": "presentation",
              "type": "number"
            },
            "columns": {
              "default": [
                {
                  "format": "date",
                  "icon": "circle",
                  "label": "Label",
                  "name": "Name",
                  "variant": "h3"
                },
                {
                  "format": "currency",
                  "icon": "circle",
                  "label": "Label 2",
                  "name": "Name 2",
                  "variant": "h4"
                }
              ],
              "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
              "items": {
                "properties": {
                  "colorMap": {
                    "items": {
                      "type": "string"
                    },
                    "name": "colorMap",
                    "required": false,
                    "type": "object"
                  },
                  "format": {
                    "name": "format",
                    "required": false,
                    "type": "string",
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
