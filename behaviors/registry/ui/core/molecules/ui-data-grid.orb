                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Columns",
              "tier": "presentation",
              "type": "[DataGridColumnsItem]"
            },
            "dndItemIdField": {
              "default": "Dnd Item Id Field",
              "description": "Row field used as the @dnd-kit draggable id (default 'id')",
              "label": "Dnd Item Id Field",
              "tier": "presentation",
              "type": "string"
            },
            "dndRoot": {
              "default": false,
              "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
              "label": "Dnd Root",
              "tier": "presentation",
              "type": "boolean"
            },
            "dragGroup": {
              "default": "Drag Group",
              "description": "When set, items in this container are draggable and announce this group as their source",
              "label": "Drag Group",
              "tier": "presentation",
              "type": "string"
            },
            "dropEvent": {
              "default": "Drop Event",
              "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
              "label": "Drop Event",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
