{
  "name": "ui-data-grid",
  "version": "1.0.0",
  "description": "DataGrid — UI factory (1:1 with the @almadar/ui data-grid pattern).",
  "orbitals": [
    {
      "name": "DataGridOrbital",
      "entity": {
        "name": "DataGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DataGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DataGridItem",
          "emits": [
            {
              "event": "SELECTION",
              "description": "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LOAD_MORE",
              "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECTION",
                "name": "Selection",
                "description": "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LOAD_MORE",
                "name": "Load More",
                "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DataGridItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "dndRoot": "@config.dndRoot",
                      "selectionEvent": "SELECTION",
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW"
                        }
                      ],
                      "reorderEvent": "@config.reorderEvent",
                      "type": "data-grid",
                      "dragGroup": "@config.dragGroup",
                      "fields": "@config.fields",
                      "cols": "@config.cols",
                      "pageSize": "@config.pageSize",
                      "imageField": "@config.imageField",
                      "accepts": "@config.accepts",
                      "infiniteScroll": "@config.infiniteScroll",
                      "look": "@config.look",
                      "sortable": "@config.sortable",
                      "isLoading": "@config.isLoading",
                      "dropEvent": "@config.dropEvent",
                      "dndItemIdField": "@config.dndItemIdField",
                      "maxInlineActions": "@config.maxInlineActions",
                      "selectable": "@config.selectable",
                      "columns": "@config.columns",
                      "minCardWidth": "@config.minCardWidth",
                      "scrollX": "@config.scrollX",
                      "loadMoreEvent": "LOAD_MORE",
                      "hasMore": "@config.hasMore",
                      "gap": "@config.gap",
                      "entity": "@entity",
                      "error": "@config.error",
                      "positionEvent": "@config.positionEvent",
                      "className": "@config.className"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "positionEvent": {
              "type": "string",
              "default": "Position Event",
              "label": "Position Event",
              "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "sortable": {
              "type": "boolean",
              "default": false,
              "label": "Sortable",
              "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
              "tier": "presentation"
            },
            "dndItemIdField": {
              "type": "string",
              "default": "Dnd Item Id Field",
              "label": "Dnd Item Id Field",
              "description": "Row field used as the @dnd-kit draggable id (default 'id')",
              "tier": "presentation"
            },
            "hasMore": {
              "type": "boolean",
              "default": false,
              "label": "Has More",
              "description": "Whether more items are available for infinite scroll",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "reorderEvent": {
              "type": "string",
              "default": "Reorder Event",
              "label": "Reorder Event",
              "description": "Bus event fired on in-container reorder. Payload: { id, oldIndex, newIndex }",
              "tier": "presentation"
            },
            "cols": {
              "type": "number",
              "default": 1.0,
              "label": "Cols",
              "description": "Number of columns (uses auto-fit if omitted)",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Max items to show before 'Show More' button. Defaults to 0 (disabled).",
              "tier": "presentation"
            },
            "scrollX": {
              "type": "boolean",
              "default": false,
              "label": "Scroll X",
              "description": "Lay items in a single horizontally-scrolling row (kanban columns) sized to `minCardWidth` instead of a wrapping grid.",
              "tier": "presentation"
            },
            "error": {
              "type": "DataGridError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "infiniteScroll": {
              "type": "boolean",
              "default": false,
              "label": "Infinite Scroll",
              "description": "Enable infinite scroll loading",
              "tier": "presentation"
            },
            "accepts": {
              "type": "string",
              "default": "Accepts",
              "label": "Accepts",
              "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
              "tier": "presentation"
            },
            "itemActions": {
              "type": "[DataGridItemActionsItem]",
              "default": [],
              "label": "Item Actions",
              "description": "Per-item action buttons",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  }
                }
              }
            },
            "minCardWidth": {
              "type": "number",
              "default": 280.0,
              "label": "Min Card Width",
              "description": "Minimum card width in pixels (used when cols is not set, default 280)",
              "tier": "presentation"
            },
            "fields": {
              "type": "[DataGridFieldsItem]",
              "default": [
                {
                  "label": "Label",
                  "format": "date",
                  "name": "Name",
                  "icon": "circle",
                  "variant": "h3"
                }
              ],
              "label": "Fields",
              "description": "Field definitions for rendering each card. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "colorMap": {
                    "name": "colorMap",
                    "type": "object",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "imageField": {
              "type": "string",
              "default": "Image Field",
              "label": "Image Field",
              "description": "Entity field name containing an image URL for card thumbnails",
              "tier": "presentation"
            },
            "dropEvent": {
              "type": "string",
              "default": "Drop Event",
              "label": "Drop Event",
              "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
              "tier": "presentation"
            },
            "dragGroup": {
              "type": "string",
              "default": "Drag Group",
              "label": "Drag Group",
              "description": "When set, items in this container are draggable and announce this group as their source",
              "tier": "presentation"
            },
            "columns": {
              "type": "[DataGridColumnsItem]",
              "default": [
                {
                  "name": "Name",
                  "icon": "circle",
                  "format": "date",
                  "label": "Label",
                  "variant": "h3"
                }
              ],
              "label": "Columns",
              "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "colorMap": {
                    "name": "colorMap",
                    "type": "object",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  }
                }
              }
            },
            "maxInlineActions": {
              "type": "number",
              "default": 0.0,
              "label": "Max Inline Actions",
              "description": "Max inline primary action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
              "tier": "presentation"
            },
            "selectable": {
              "type": "boolean",
              "default": false,
              "label": "Selectable",
              "description": "Enable multi-select with checkboxes",
              "tier": "presentation"
            },
            "dndRoot": {
              "type": "boolean",
              "default": false,
              "label": "Dnd Root",
              "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "dense",
              "label": "Look",
              "description": "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between cards",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DataGridPage",
          "path": "/data-grid",
          "traits": [
            {
              "ref": "DataGridRender"
            }
          ]
        }
      ]
    }
  ]
}