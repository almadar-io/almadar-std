{
  "description": "GraphView — UI factory (1:1 with the @almadar/ui graph-view pattern).",
  "name": "ui-graph-view",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GraphViewItem",
        "persistence": "runtime"
      },
      "name": "GraphViewOrbital",
      "pages": [
        {
          "name": "GraphViewPage",
          "path": "/graph-view",
          "traits": [
            {
              "ref": "GraphViewRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "edges": {
              "default": [
                {
                  "color": "Color",
                  "label": "Label",
                  "source": "Source",
                  "target": "Target"
                },
                {
                  "color": "Color 2",
                  "label": "Label 2",
                  "source": "Source 2",
                  "target": "Target 2"
                }
              ],
              "description": "Graph edges",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "source": {
                    "name": "source",
                    "required": true,
                    "type": "string"
                  },
                  "target": {
                    "name": "target",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Edges",
              "tier": "presentation",
              "type": "[GraphViewEdgesItem]"
            },
            "height": {
              "default": 0.0,
              "description": "Height in pixels",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "nodes": {
              "default": [
                {
                  "color": "Color",
                  "group": "Group",
                  "id": "Id",
                  "label": "Label",
                  "size": 1.0
                },
                {
                  "color": "Color 2",
                  "group": "Group 2",
                  "id": "Id 2",
                  "label": "Label 2",
                  "size": 2.0
                }
              ],
              "description": "Graph nodes",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "group": {
                    "name": "group",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "size": {
                    "name": "size",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "presentation",
              "type": "[GraphViewNodesItem]"
            },
            "onNodeClick": {
              "default": "NODE_CLICK",
              "description": "Callback when a node is clicked",
              "label": "On Node Click",
              "tier": "presentation",
              "type": "string"
            },
            "onNodeHover": {
              "default": "NODE_HOVER",
              "description": "Callback when a node is hovered (null on leave)",
              "label": "On Node Hover",
              "tier": "presentation",
              "type": "string"
            },
            "showLabels": {
              "default": true,
              "description": "Show node labels (default true)",
              "label": "Show Labels",
              "tier": "presentation",
              "type": "boolean"
            },
            "width": {
              "default": 0.0,
              "description": "Width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            },
            "zoomToFit": {
              "default": true,
              "description": "Auto zoom-to-fit after layout settles (default true)",
              "label": "Zoom To Fit",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Callback when a node is clicked",
              "event": "@config.onNodeClick",
              "payloadSchema": [
                {
                  "name": "node",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when a node is hovered (null on leave)",
              "event": "@config.onNodeHover",
              "payloadSchema": [
                {
                  "name": "node",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GraphViewItem",
          "name": "GraphViewRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when a node is clicked",
                "key": "@config.onNodeClick",
                "name": "@config.on node click",
                "payloadSchema": [
                  {
                    "name": "node",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when a node is hovered (null on leave)",
                "key": "@config.onNodeHover",
                "name": "@config.on node hover",
                "payloadSchema": [
                  {
                    "name": "node",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "edges": "@config.edges",
                      "height": "@config.height",
                      "nodes": "@config.nodes",
                      "onNodeClick": "@config.onNodeClick",
                      "onNodeHover": "@config.onNodeHover",
                      "showLabels": "@config.showLabels",
                      "type": "graph-view",
                      "width": "@config.width",
                      "zoomToFit": "@config.zoomToFit"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}