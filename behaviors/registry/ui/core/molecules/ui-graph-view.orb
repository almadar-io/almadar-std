{
  "name": "ui-graph-view",
  "version": "1.0.0",
  "description": "GraphView — UI factory (1:1 with the @almadar/ui graph-view pattern).",
  "orbitals": [
    {
      "name": "GraphViewOrbital",
      "entity": {
        "name": "GraphViewItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GraphViewRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GraphViewItem",
          "emits": [
            {
              "event": "NODE_CLICK",
              "description": "Callback when a node is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "node",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    }
                  ]
                }
              ]
            },
            {
              "event": "NODE_HOVER",
              "description": "Callback when a node is hovered (null on leave)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "node",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    }
                  ]
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NODE_CLICK",
                "name": "Node Click",
                "description": "Callback when a node is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "node",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "key": "NODE_HOVER",
                "name": "Node Hover",
                "description": "Callback when a node is hovered (null on leave)",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "node",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      }
                    ]
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "zoomToFit": "@config.zoomToFit",
                      "showLabels": "@config.showLabels",
                      "edges": "@config.edges",
                      "onNodeClick": "NODE_CLICK",
                      "nodes": "@config.nodes",
                      "className": "@config.className",
                      "height": "@config.height",
                      "type": "graph-view",
                      "width": "@config.width",
                      "onNodeHover": "NODE_HOVER"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "height": {
              "type": "number",
              "default": 0.0,
              "label": "Height",
              "description": "Height in pixels",
              "tier": "presentation"
            },
            "nodes": {
              "type": "[GraphViewNodesItem]",
              "default": [],
              "label": "Nodes",
              "description": "Graph nodes",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "size": {
                    "name": "size",
                    "type": "number",
                    "required": false
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "group": {
                    "name": "group",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "edges": {
              "type": "[GraphViewEdgesItem]",
              "default": [],
              "label": "Edges",
              "description": "Graph edges",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "source": {
                    "name": "source",
                    "type": "string",
                    "required": true
                  },
                  "target": {
                    "name": "target",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "showLabels": {
              "type": "boolean",
              "default": true,
              "label": "Show Labels",
              "description": "Show node labels (default true)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 0.0,
              "label": "Width",
              "description": "Width in pixels",
              "tier": "presentation"
            },
            "zoomToFit": {
              "type": "boolean",
              "default": true,
              "label": "Zoom To Fit",
              "description": "Auto zoom-to-fit after layout settles (default true)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphViewPage",
          "path": "/graph-view",
          "traits": [
            {
              "ref": "GraphViewRender"
            }
          ]
        }
      ]
    }
  ]
}
