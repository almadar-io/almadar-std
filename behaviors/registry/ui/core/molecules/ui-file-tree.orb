{
  "name": "ui-file-tree",
  "version": "1.0.0",
  "description": "FileTree — UI factory (1:1 with the @almadar/ui file-tree pattern).",
  "orbitals": [
    {
      "name": "FileTreeOrbital",
      "entity": {
        "name": "FileTreeItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FileTreeRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FileTreeItem",
          "emits": [
            {
              "event": "FILE_SELECT",
              "description": "Called when a file is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "path",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILE_SELECT",
                "name": "File Select",
                "description": "Called when a file is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "path",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "selectedPath": "@config.selectedPath",
                      "onFileSelect": "FILE_SELECT",
                      "className": "@config.className",
                      "tree": "@config.tree",
                      "indent": "@config.indent",
                      "type": "file-tree"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "tree": {
              "type": "[FileTreeTreeItem]",
              "default": [
                {
                  "type": "file",
                  "path": "Path",
                  "name": "Name",
                  "children": [],
                  "size": 1.0,
                  "language": "Language"
                }
              ],
              "label": "Tree",
              "description": "The tree data",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true,
                    "values": [
                      "file",
                      "dir"
                    ]
                  },
                  "size": {
                    "name": "size",
                    "type": "number",
                    "required": false
                  },
                  "children": {
                    "name": "children",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "language": {
                    "name": "language",
                    "type": "string",
                    "required": false
                  },
                  "path": {
                    "name": "path",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "selectedPath": {
              "type": "string",
              "default": "Selected Path",
              "label": "Selected Path",
              "description": "Currently selected file path",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "CSS class",
              "tier": "presentation"
            },
            "indent": {
              "type": "number",
              "default": 16.0,
              "label": "Indent",
              "description": "Indent size per level in px (default: 16)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FileTreePage",
          "path": "/file-tree",
          "traits": [
            {
              "ref": "FileTreeRender"
            }
          ]
        }
      ]
    }
  ]
}