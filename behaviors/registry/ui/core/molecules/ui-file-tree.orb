{
  "description": "FileTree — UI factory (1:1 with the @almadar/ui file-tree pattern).",
  "name": "ui-file-tree",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FileTreeItem",
        "persistence": "runtime"
      },
      "name": "FileTreeOrbital",
      "pages": [
        {
          "name": "FileTreePage",
          "path": "/file-tree",
          "traits": [
            {
              "ref": "FileTreeRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "CSS class",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "indent": {
              "default": 16.0,
              "description": "Indent size per level in px (default: 16)",
              "label": "Indent",
              "tier": "presentation",
              "type": "number"
            },
            "selectedPath": {
              "default": "Selected Path",
              "description": "Currently selected file path",
              "label": "Selected Path",
              "tier": "presentation",
              "type": "string"
            },
            "tree": {
              "default": [
                {
                  "children": [],
                  "language": "Language",
                  "name": "Name",
                  "path": "Path",
                  "size": 1.0,
                  "type": "file"
                },
                {
                  "children": [],
                  "language": "Language 2",
                  "name": "Name 2",
                  "path": "Path 2",
                  "size": 2.0,
                  "type": "dir"
                }
              ],
              "description": "The tree data",
              "items": {
                "properties": {
                  "children": {
                    "items": {
                      "type": "string"
                    },
                    "name": "children",
                    "required": false,
                    "type": "array"
                  },
                  "language": {
                    "name": "language",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "path": {
                    "name": "path",
                    "required": true,
                    "type": "string"
                  },
                  "size": {
                    "name": "size",
                    "required": false,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string",
                    "values": [
                      "file",
                      "dir"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Tree",
              "tier": "presentation",
              "type": "[FileTreeTreeItem]"
            }
          },
          "emits": [
            {
              "description": "Called when a file is clicked",
              "event": "FILE_SELECT",
              "payloadSchema": [
                {
                  "name": "path",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FileTreeItem",
          "name": "FileTreeRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when a file is clicked",
                "key": "FILE_SELECT",
                "name": "File Select",
                "payloadSchema": [
                  {
                    "name": "path",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "indent": "@config.indent",
                      "onFileSelect": "FILE_SELECT",
                      "selectedPath": "@config.selectedPath",
                      "tree": "@config.tree",
                      "type": "file-tree"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}