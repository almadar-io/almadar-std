{
  "name": "ui-content-renderer",
  "version": "1.0.0",
  "description": "ContentRenderer — UI factory (1:1 with the @almadar/ui content-renderer pattern).",
  "orbitals": [
    {
      "name": "ContentRendererOrbital",
      "entity": {
        "name": "ContentRendererItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ContentRendererRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ContentRendererItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "isLoading": "@config.isLoading",
                      "activeFilters": "@config.activeFilters",
                      "selectedIds": "@config.selectedIds",
                      "type": "content-renderer",
                      "searchValue": "@config.searchValue",
                      "error": "@config.error",
                      "page": "@config.pageProp",
                      "className": "@config.className",
                      "content": "@config.content",
                      "sortBy": "@config.sortBy",
                      "pageSize": "@config.pageSize",
                      "sortDirection": "@config.sortDirection",
                      "segments": "@config.segments",
                      "totalCount": "@config.totalCount",
                      "direction": "@config.direction"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "error": {
              "type": "ContentRendererError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                }
              }
            },
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "content": {
              "type": "string",
              "default": "Content",
              "label": "Content",
              "description": "Raw content string — auto-parsed into segments",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "segments": {
              "type": "[ContentRendererSegmentsItem]",
              "default": [
                {
                  "type": "markdown",
                  "content": "Content"
                }
              ],
              "label": "Segments",
              "description": "Pre-parsed segments (overrides content)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true,
                    "values": [
                      "markdown",
                      "code",
                      "orbital",
                      "quiz"
                    ]
                  }
                }
              }
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "direction": {
              "type": "string",
              "default": "rtl",
              "label": "Direction",
              "description": "Text direction for markdown",
              "tier": "presentation",
              "values": [
                "rtl",
                "ltr"
              ]
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ContentRendererPage",
          "path": "/content-renderer",
          "traits": [
            {
              "ref": "ContentRendererRender"
            }
          ]
        }
      ]
    }
  ]
}