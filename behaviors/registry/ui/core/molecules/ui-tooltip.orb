{
  "description": "Tooltip — UI factory (1:1 with the @almadar/ui tooltip pattern).",
  "name": "ui-tooltip",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TooltipItem",
        "persistence": "runtime"
      },
      "name": "TooltipOrbital",
      "pages": [
        {
          "name": "TooltipPage",
          "path": "/tooltip",
          "traits": [
            {
              "ref": "TooltipRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Tooltip trigger element (ReactElement or ReactNode that will be wrapped in span)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "content": {
              "default": [
                {
                  "content": "Content",
                  "type": "typography"
                }
              ],
              "description": "Tooltip content",
              "label": "Content",
              "tier": "presentation",
              "type": "node"
            },
            "delay": {
              "default": 200.0,
              "description": "Show delay in milliseconds",
              "label": "Delay",
              "tier": "presentation",
              "type": "number"
            },
            "hideDelay": {
              "default": 0.0,
              "description": "Hide delay in milliseconds",
              "label": "Hide Delay",
              "tier": "presentation",
              "type": "number"
            },
            "position": {
              "default": "top",
              "description": "Tooltip position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom",
                "left",
                "right"
              ]
            },
            "showArrow": {
              "default": true,
              "description": "Show arrow",
              "label": "Show Arrow",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TooltipItem",
          "name": "TooltipRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "content": "@config.content",
                      "delay": "@config.delay",
                      "hideDelay": "@config.hideDelay",
                      "position": "@config.position",
                      "showArrow": "@config.showArrow",
                      "type": "tooltip"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}