{
  "name": "ui-star-rating",
  "version": "1.0.0",
  "description": "StarRating — UI factory (1:1 with the @almadar/ui star-rating pattern).",
  "orbitals": [
    {
      "name": "StarRatingOrbital",
      "entity": {
        "name": "StarRatingItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "StarRatingRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "value"
            ]
          },
          "category": "interaction",
          "linkedEntity": "StarRatingItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name for rating changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CHANGE",
              "description": "Direct onChange callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Direct onChange callback",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for rating changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "@config.label",
                      "value": "@entity.value",
                      "precision": "@config.precision",
                      "action": "ACTION",
                      "className": "@config.className",
                      "type": "star-rating",
                      "max": "@config.max",
                      "actionPayload": "@config.actionPayload",
                      "size": "@config.size",
                      "readOnly": "@config.readOnly",
                      "onChange": "CHANGE"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "precision": "@config.precision",
                      "label": "@config.label",
                      "size": "@config.size",
                      "max": "@config.max",
                      "value": "@entity.value",
                      "action": "ACTION",
                      "actionPayload": "@config.actionPayload",
                      "readOnly": "@config.readOnly",
                      "onChange": "CHANGE",
                      "className": "@config.className",
                      "type": "star-rating"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "readOnly": {
              "type": "boolean",
              "default": false,
              "label": "Read Only",
              "description": "Read-only display mode",
              "tier": "presentation"
            },
            "precision": {
              "type": "string",
              "default": "full",
              "label": "Precision",
              "description": "Full or half-star precision",
              "tier": "presentation",
              "values": [
                "full",
                "half"
              ]
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Accessible label",
              "tier": "presentation"
            },
            "value": {
              "type": "number",
              "default": 0.0,
              "label": "Value",
              "description": "Current rating value",
              "tier": "presentation"
            },
            "actionPayload": {
              "type": "json",
              "default": {},
              "label": "Action Payload",
              "description": "Payload to include with the action event",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Star size",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "max": {
              "type": "number",
              "default": 5.0,
              "label": "Max",
              "description": "Maximum number of stars",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StarRatingPage",
          "path": "/star-rating",
          "traits": [
            {
              "ref": "StarRatingRender"
            }
          ]
        }
      ]
    }
  ]
}