{
  "description": "StarRating — UI factory (1:1 with the @almadar/ui star-rating pattern).",
  "name": "ui-star-rating",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "value",
            "type": "number"
          }
        ],
        "name": "StarRatingItem",
        "persistence": "runtime"
      },
      "name": "StarRatingOrbital",
      "pages": [
        {
          "name": "StarRatingPage",
          "path": "/star-rating",
          "traits": [
            {
              "ref": "StarRatingRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "action": {
              "default": "ACTION",
              "description": "Declarative event name for rating changes",
              "label": "Action",
              "tier": "presentation",
              "type": "string"
            },
            "actionPayload": {
              "default": {},
              "description": "Payload to include with the action event",
              "label": "Action Payload",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Accessible label",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "max": {
              "default": 5.0,
              "description": "Maximum number of stars",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "onChange": {
              "default": "CHANGE",
              "description": "Direct onChange callback",
              "label": "On Change",
              "tier": "presentation",
              "type": "string"
            },
            "precision": {
              "default": "full",
              "description": "Full or half-star precision",
              "label": "Precision",
              "tier": "presentation",
              "type": "string",
              "values": [
                "full",
                "half"
              ]
            },
            "readOnly": {
              "default": false,
              "description": "Read-only display mode",
              "label": "Read Only",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Star size",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "value": {
              "default": 0.0,
              "description": "Current rating value",
              "label": "Value",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Declarative event name for rating changes",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Direct onChange callback",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "value"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StarRatingItem",
          "name": "StarRatingRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Direct onChange callback",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative event name for rating changes",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "@config.action",
                      "actionPayload": "@config.actionPayload",
                      "className": "@config.className",
                      "label": "@config.label",
                      "max": "@config.max",
                      "onChange": "@config.onChange",
                      "precision": "@config.precision",
                      "readOnly": "@config.readOnly",
                      "size": "@config.size",
                      "type": "star-rating",
                      "value": "@entity.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "@config.action",
                      "actionPayload": "@config.actionPayload",
                      "className": "@config.className",
                      "label": "@config.label",
                      "max": "@config.max",
                      "onChange": "@config.onChange",
                      "precision": "@config.precision",
                      "readOnly": "@config.readOnly",
                      "size": "@config.size",
                      "type": "star-rating",
                      "value": "@entity.value"
                    }
                  ]
                ],
                "event": "CHANGE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}