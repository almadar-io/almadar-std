{
  "description": "Menu — UI factory (1:1 with the @almadar/ui menu pattern).",
  "name": "ui-menu",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MenuItem",
        "persistence": "runtime"
      },
      "name": "MenuOrbital",
      "pages": [
        {
          "name": "MenuPage",
          "path": "/menu",
          "traits": [
            {
              "ref": "MenuRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "footer": {
              "description": "Optional slot rendered below the items.",
              "label": "Footer",
              "tier": "presentation",
              "type": "node"
            },
            "header": {
              "description": "Optional slot rendered above the items.",
              "label": "Header",
              "tier": "presentation",
              "type": "node"
            },
            "items": {
              "default": [
                {
                  "badge": "Badge",
                  "disabled": false,
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "subMenu": [],
                  "variant": "default"
                },
                {
                  "badge": "Badge 2",
                  "disabled": true,
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "subMenu": [],
                  "variant": "danger"
                }
              ],
              "description": "Menu items",
              "items": {
                "properties": {
                  "badge": {
                    "name": "badge",
                    "required": false,
                    "type": "string"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "subMenu": {
                    "items": {
                      "type": "string"
                    },
                    "name": "subMenu",
                    "required": false,
                    "type": "array"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "default",
                      "danger"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[MenuItemsItem]"
            },
            "position": {
              "default": "bottom-left",
              "description": "Menu position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top-left",
                "top-right",
                "bottom-left",
                "bottom-right",
                "top-start",
                "top-end",
                "bottom-start",
                "bottom-end"
              ]
            },
            "trigger": {
              "default": [
                {
                  "content": "Trigger",
                  "type": "typography"
                }
              ],
              "description": "Menu trigger element",
              "label": "Trigger",
              "tier": "presentation",
              "type": "node"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MenuItem",
          "name": "MenuRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "footer": "@config.footer",
                      "header": "@config.header",
                      "items": "@config.items",
                      "position": "@config.position",
                      "trigger": "@config.trigger",
                      "type": "menu"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}