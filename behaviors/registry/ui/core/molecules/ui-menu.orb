{
  "name": "ui-menu",
  "version": "1.0.0",
  "description": "Menu — UI factory (1:1 with the @almadar/ui menu pattern).",
  "orbitals": [
    {
      "name": "MenuOrbital",
      "entity": {
        "name": "MenuItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MenuRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MenuItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "items": "@config.items",
                      "className": "@config.className",
                      "trigger": [
                        {
                          "type": "typography",
                          "content": "Trigger"
                        }
                      ],
                      "type": "menu",
                      "position": "@config.position"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "items": {
              "type": "[MenuItemsItem]",
              "default": [
                {
                  "variant": "default",
                  "subMenu": [],
                  "label": "Label",
                  "id": "Id",
                  "icon": "circle",
                  "badge": "Badge",
                  "disabled": false
                }
              ],
              "label": "Items",
              "description": "Menu items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "danger"
                    ]
                  },
                  "subMenu": {
                    "name": "subMenu",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "position": {
              "type": "string",
              "default": "bottom-left",
              "label": "Position",
              "description": "Menu position",
              "tier": "presentation",
              "values": [
                "top-left",
                "top-right",
                "bottom-left",
                "bottom-right",
                "top-start",
                "top-end",
                "bottom-start",
                "bottom-end"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MenuPage",
          "path": "/menu",
          "traits": [
            {
              "ref": "MenuRender"
            }
          ]
        }
      ]
    }
  ]
}