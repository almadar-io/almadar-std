{
  "name": "ui-navigation",
  "version": "1.0.0",
  "description": "Navigation — UI factory (1:1 with the @almadar/ui navigation pattern).",
  "orbitals": [
    {
      "name": "NavigationOrbital",
      "entity": {
        "name": "NavigationItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "NavigationRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "NavigationItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NavigationItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "items": "@config.items",
                      "entity": "NavigationItem",
                      "type": "navigation",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "className": "@config.className",
                      "orientation": "@config.orientation"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "error": {
              "type": "NavigationError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "Navigation orientation",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "items": {
              "type": "[NavigationItemsItem]",
              "default": [
                {
                  "id": "Id",
                  "label": "Label"
                }
              ],
              "label": "Items",
              "description": "Navigation items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "isActive": {
                    "name": "isActive",
                    "type": "boolean",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "subMenu": {
                    "name": "subMenu",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "NavigationPage",
          "path": "/navigation",
          "traits": [
            {
              "ref": "NavigationRender"
            }
          ]
        }
      ]
    }
  ]
}