{
  "name": "ui-positioned-canvas",
  "version": "1.0.0",
  "description": "PositionedCanvas — UI factory (1:1 with the @almadar/ui positioned-canvas pattern).",
  "orbitals": [
    {
      "name": "PositionedCanvasOrbital",
      "entity": {
        "name": "PositionedCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "label",
            "type": "string",
            "default": ""
          },
          {
            "name": "x",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "shape",
            "type": "string",
            "default": "round",
            "values": [
              "round",
              "rectangle",
              "square"
            ]
          },
          {
            "name": "capacity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "empty",
            "values": [
              "empty",
              "seated",
              "ordered",
              "awaiting-bill",
              "cleaning"
            ]
          },
          {
            "name": "partySize",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "serverName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PositionedCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PositionedCanvasItem",
          "emits": [
            {
              "event": "SELECT",
              "description": "onSelect prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MOVE",
              "description": "onMove prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "description": "onSelect prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MOVE",
                "name": "Move",
                "description": "onMove prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PositionedCanvasItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "width": "@config.width",
                      "onSelect": "SELECT",
                      "moveEvent": "MOVE",
                      "className": "@config.className",
                      "type": "positioned-canvas",
                      "items": "@entity",
                      "height": "@config.height",
                      "onMove": "MOVE",
                      "editable": "@config.editable",
                      "selectEvent": "SELECT",
                      "selectedId": "@config.selectedId"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "editable": {
              "type": "boolean",
              "default": false,
              "label": "Editable",
              "description": "editable prop",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 600.0,
              "label": "Height",
              "description": "height prop",
              "tier": "presentation"
            },
            "selectedId": {
              "type": "string",
              "default": "",
              "label": "Selected Id",
              "description": "selectedId prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 800.0,
              "label": "Width",
              "description": "width prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PositionedCanvasPage",
          "path": "/positioned-canvas",
          "traits": [
            {
              "ref": "PositionedCanvasRender"
            }
          ]
        }
      ]
    }
  ]
}