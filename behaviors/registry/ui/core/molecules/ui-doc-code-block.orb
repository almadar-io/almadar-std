{
  "name": "ui-doc-code-block",
  "version": "1.0.0",
  "description": "DocCodeBlock — UI factory (1:1 with the @almadar/ui doc-code-block pattern).",
  "orbitals": [
    {
      "name": "DocCodeBlockOrbital",
      "entity": {
        "name": "DocCodeBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DocCodeBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DocCodeBlockItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showLineNumbers": "@config.showLineNumbers",
                      "type": "doc-code-block",
                      "code": "@config.code",
                      "className": "@config.className",
                      "language": "@config.language",
                      "title": "@config.title"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "language": {
              "type": "string",
              "default": "Language",
              "label": "Language",
              "description": "Programming language label",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Optional title/filename shown in the header bar",
              "tier": "presentation"
            },
            "code": {
              "type": "string",
              "default": "Code",
              "label": "Code",
              "description": "Code content to display",
              "tier": "presentation"
            },
            "showLineNumbers": {
              "type": "boolean",
              "default": false,
              "label": "Show Line Numbers",
              "description": "Show line numbers in the gutter",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DocCodeBlockPage",
          "path": "/doc-code-block",
          "traits": [
            {
              "ref": "DocCodeBlockRender"
            }
          ]
        }
      ]
    }
  ]
}