{
  "description": "Notification — UI factory (1:1 with the @almadar/ui notification pattern).",
  "name": "ui-notification",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "NotificationItem",
        "persistence": "runtime"
      },
      "name": "NotificationOrbital",
      "pages": [
        {
          "name": "NotificationPage",
          "path": "/notification",
          "traits": [
            {
              "ref": "NotificationRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actionEvent": {
              "default": "ACTION",
              "description": "Declarative action event — emits UI:{actionEvent} via eventBus when action button is clicked",
              "label": "Action Event",
              "tier": "presentation",
              "type": "string"
            },
            "actionLabel": {
              "default": "Action Label",
              "description": "Action button label",
              "label": "Action Label",
              "tier": "presentation",
              "type": "string"
            },
            "badge": {
              "default": "Badge",
              "description": "Badge count (optional)",
              "label": "Badge",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "dismissEvent": {
              "default": "DISMISS",
              "description": "Declarative dismiss event — emits UI:{dismissEvent} via eventBus when toast is dismissed",
              "label": "Dismiss Event",
              "tier": "presentation",
              "type": "string"
            },
            "dismissible": {
              "default": true,
              "description": "Show dismiss button",
              "label": "Dismissible",
              "tier": "presentation",
              "type": "boolean"
            },
            "duration": {
              "default": 5000.0,
              "description": "Auto-dismiss duration in milliseconds (0 = no auto-dismiss)",
              "label": "Duration",
              "tier": "presentation",
              "type": "number"
            },
            "message": {
              "default": "Message",
              "description": "Toast message",
              "label": "Message",
              "tier": "presentation",
              "type": "string"
            },
            "onAction": {
              "default": "ACTION",
              "description": "Action button click handler",
              "label": "On Action",
              "tier": "presentation",
              "type": "string"
            },
            "onDismiss": {
              "default": "DISMISS",
              "description": "Callback when toast is dismissed",
              "label": "On Dismiss",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "Toast title (optional)",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "info",
              "description": "Toast variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "success",
                "error",
                "info",
                "warning"
              ]
            }
          },
          "emits": [
            {
              "description": "Callback when toast is dismissed",
              "event": "@config.onDismiss",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Action button click handler",
              "event": "@config.onAction",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "NotificationItem",
          "name": "NotificationRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when toast is dismissed",
                "key": "@config.onDismiss",
                "name": "@config.on dismiss",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Action button click handler",
                "key": "@config.onAction",
                "name": "@config.on action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actionEvent": "@config.actionEvent",
                      "actionLabel": "@config.actionLabel",
                      "badge": "@config.badge",
                      "className": "@config.className",
                      "dismissEvent": "@config.dismissEvent",
                      "dismissible": "@config.dismissible",
                      "duration": "@config.duration",
                      "message": "@config.message",
                      "onAction": "@config.onAction",
                      "onDismiss": "@config.onDismiss",
                      "title": "@config.title",
                      "type": "notification",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}