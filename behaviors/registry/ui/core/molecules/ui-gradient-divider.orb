{
  "description": "GradientDivider — UI factory (1:1 with the @almadar/ui gradient-divider pattern).",
  "name": "ui-gradient-divider",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GradientDividerItem",
        "persistence": "runtime"
      },
      "name": "GradientDividerOrbital",
      "pages": [
        {
          "name": "GradientDividerPage",
          "path": "/gradient-divider",
          "traits": [
            {
              "ref": "GradientDividerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "color": {
              "default": "primary",
              "description": "Semantic palette token or a raw CSS color value. Defaults to 'primary'.",
              "label": "Color",
              "tier": "presentation",
              "type": "string",
              "values": [
                "primary",
                "secondary",
                "success",
                "warning",
                "error",
                "muted"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GradientDividerItem",
          "name": "GradientDividerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "color": "@config.color",
                      "type": "gradient-divider"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}