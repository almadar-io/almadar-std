{
  "name": "ui-gradient-divider",
  "version": "1.0.0",
  "description": "GradientDivider — UI factory (1:1 with the @almadar/ui gradient-divider pattern).",
  "orbitals": [
    {
      "name": "GradientDividerOrbital",
      "entity": {
        "name": "GradientDividerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GradientDividerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GradientDividerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "color": "@config.color",
                      "type": "gradient-divider",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "color": {
              "type": "string",
              "default": "",
              "label": "Color",
              "description": "Override the center color (CSS value). Defaults to var(--color-primary).",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GradientDividerPage",
          "path": "/gradient-divider",
          "traits": [
            {
              "ref": "GradientDividerRender"
            }
          ]
        }
      ]
    }
  ]
}