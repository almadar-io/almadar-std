{
  "description": "FlipCard — UI factory (1:1 with the @almadar/ui flip-card pattern).",
  "name": "ui-flip-card",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FlipCardItem",
        "persistence": "runtime"
      },
      "name": "FlipCardOrbital",
      "pages": [
        {
          "name": "FlipCardPage",
          "path": "/flip-card",
          "traits": [
            {
              "ref": "FlipCardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Optional className for the outer container",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "flipped": {
              "default": false,
              "description": "Controlled flip state",
              "label": "Flipped",
              "tier": "presentation",
              "type": "boolean"
            },
            "height": {
              "default": "h-64",
              "description": "Card height as a Tailwind class (default: 'h-64')",
              "label": "Height",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when the card is clicked to flip",
              "event": "FLIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FlipCardItem",
          "name": "FlipCardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when the card is clicked to flip",
                "key": "FLIP",
                "name": "Flip",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "back": [
                        {
                          "content": "Back",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "flipped": "@config.flipped",
                      "front": [
                        {
                          "content": "Front",
                          "type": "typography"
                        }
                      ],
                      "height": "@config.height",
                      "onFlip": "FLIP",
                      "type": "flip-card"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}