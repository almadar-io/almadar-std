{
  "description": "Carousel — UI factory (1:1 with the @almadar/ui carousel pattern).",
  "name": "ui-carousel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CarouselItem",
        "persistence": "runtime"
      },
      "name": "CarouselOrbital",
      "pages": [
        {
          "name": "CarouselPage",
          "path": "/carousel",
          "traits": [
            {
              "ref": "CarouselRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "autoPlay": {
              "default": false,
              "description": "Enable auto-play rotation",
              "label": "Auto Play",
              "tier": "presentation",
              "type": "boolean"
            },
            "autoPlayInterval": {
              "default": 5000.0,
              "description": "Auto-play interval in milliseconds (default: 5000)",
              "label": "Auto Play Interval",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [],
              "description": "Array of items to display as slides",
              "items": {
                "type": "string"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[json]"
            },
            "loop": {
              "default": false,
              "description": "Enable infinite loop",
              "label": "Loop",
              "tier": "presentation",
              "type": "boolean"
            },
            "showArrows": {
              "default": true,
              "description": "Show prev/next arrow buttons",
              "label": "Show Arrows",
              "tier": "presentation",
              "type": "boolean"
            },
            "showDots": {
              "default": true,
              "description": "Show dot indicators",
              "label": "Show Dots",
              "tier": "presentation",
              "type": "boolean"
            },
            "slideChangeEvent": {
              "default": "SLIDE_CHANGE",
              "description": "Declarative event name for slide change",
              "label": "Slide Change Event",
              "tier": "presentation",
              "type": "string"
            },
            "slideChangePayload": {
              "default": {},
              "description": "Payload to include with the slide change event",
              "label": "Slide Change Payload",
              "tier": "presentation",
              "type": "json"
            }
          },
          "emits": [
            {
              "description": "Declarative event name for slide change",
              "event": "@config.slideChangeEvent",
              "payloadSchema": [
                {
                  "name": "index",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CarouselItem",
          "name": "CarouselRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event name for slide change",
                "key": "@config.slideChangeEvent",
                "name": "@config.slide change event",
                "payloadSchema": [
                  {
                    "name": "index",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "autoPlay": "@config.autoPlay",
                      "autoPlayInterval": "@config.autoPlayInterval",
                      "className": "@config.className",
                      "items": "@config.items",
                      "loop": "@config.loop",
                      "showArrows": "@config.showArrows",
                      "showDots": "@config.showDots",
                      "slideChangeEvent": "@config.slideChangeEvent",
                      "slideChangePayload": "@config.slideChangePayload",
                      "type": "carousel"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}