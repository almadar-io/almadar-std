{
  "name": "ui-error-boundary",
  "version": "1.0.0",
  "description": "ErrorBoundary — UI factory (1:1 with the @almadar/ui error-boundary pattern).",
  "orbitals": [
    {
      "name": "ErrorBoundaryOrbital",
      "entity": {
        "name": "ErrorBoundaryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ErrorBoundaryRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ErrorBoundaryItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "children": [
                        {
                          "type": "text",
                          "content": ""
                        }
                      ],
                      "type": "error-boundary"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes for the wrapper",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ErrorBoundaryPage",
          "path": "/error-boundary",
          "traits": [
            {
              "ref": "ErrorBoundaryRender"
            }
          ]
        }
      ]
    }
  ]
}
