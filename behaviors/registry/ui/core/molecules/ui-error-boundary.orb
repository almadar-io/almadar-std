{
  "description": "ErrorBoundary — UI factory (1:1 with the @almadar/ui error-boundary pattern).",
  "name": "ui-error-boundary",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ErrorBoundaryItem",
        "persistence": "runtime"
      },
      "name": "ErrorBoundaryOrbital",
      "pages": [
        {
          "name": "ErrorBoundaryPage",
          "path": "/error-boundary",
          "traits": [
            {
              "ref": "ErrorBoundaryRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes for the wrapper",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ErrorBoundaryItem",
          "name": "ErrorBoundaryRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "type": "error-boundary"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}