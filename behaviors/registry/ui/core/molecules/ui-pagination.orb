{
  "description": "Pagination — UI factory (1:1 with the @almadar/ui pagination pattern).",
  "name": "ui-pagination",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "pageSize",
            "type": "number"
          }
        ],
        "name": "PaginationItem",
        "persistence": "runtime"
      },
      "name": "PaginationOrbital",
      "pages": [
        {
          "name": "PaginationPage",
          "path": "/pagination",
          "traits": [
            {
              "ref": "PaginationRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentPage": {
              "default": 0.0,
              "description": "Current page (1-indexed)",
              "label": "Current Page",
              "tier": "presentation",
              "type": "number"
            },
            "maxVisiblePages": {
              "default": 7.0,
              "description": "Maximum number of page buttons to show",
              "label": "Max Visible Pages",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 0.0,
              "description": "Current page size",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "pageSizeOptions": {
              "default": [],
              "description": "Page size options",
              "items": {
                "type": "number"
              },
              "label": "Page Size Options",
              "tier": "presentation",
              "type": "[number]"
            },
            "showJumpToPage": {
              "default": false,
              "description": "Show jump to page input",
              "label": "Show Jump To Page",
              "tier": "presentation",
              "type": "boolean"
            },
            "showPageSize": {
              "default": false,
              "description": "Show page size selector",
              "label": "Show Page Size",
              "tier": "presentation",
              "type": "boolean"
            },
            "showTotal": {
              "default": false,
              "description": "Show total count",
              "label": "Show Total",
              "tier": "presentation",
              "type": "boolean"
            },
            "totalItems": {
              "default": 0.0,
              "description": "Total items count",
              "label": "Total Items",
              "tier": "presentation",
              "type": "number"
            },
            "totalPages": {
              "default": 0.0,
              "description": "Total number of pages",
              "label": "Total Pages",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Callback when page changes (optional - can be a no-op if not interactive)",
              "event": "PAGE_CHANGE",
              "payloadSchema": [
                {
                  "name": "page",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when page size changes",
              "event": "PAGE_SIZE_CHANGE",
              "payloadSchema": [
                {
                  "name": "size",
                  "type": "number"
                },
                {
                  "name": "pageSize",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "pageSize"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PaginationItem",
          "name": "PaginationRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when page size changes",
                "key": "PAGE_SIZE_CHANGE",
                "name": "Page Size Change",
                "payloadSchema": [
                  {
                    "name": "size",
                    "type": "number"
                  },
                  {
                    "name": "pageSize",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when page changes (optional - can be a no-op if not interactive)",
                "key": "PAGE_CHANGE",
                "name": "Page Change",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.pageSize",
                    "@config.pageSize"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "currentPage": "@config.currentPage",
                      "maxVisiblePages": "@config.maxVisiblePages",
                      "onPageChange": "PAGE_CHANGE",
                      "onPageSizeChange": "PAGE_SIZE_CHANGE",
                      "pageChangeEvent": "PAGE_CHANGE",
                      "pageSize": "@entity.pageSize",
                      "pageSizeChangeEvent": "PAGE_SIZE_CHANGE",
                      "pageSizeOptions": "@config.pageSizeOptions",
                      "showJumpToPage": "@config.showJumpToPage",
                      "showPageSize": "@config.showPageSize",
                      "showTotal": "@config.showTotal",
                      "totalItems": "@config.totalItems",
                      "totalPages": "@config.totalPages",
                      "type": "pagination"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.pageSize",
                    "@payload.pageSize"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "currentPage": "@config.currentPage",
                      "maxVisiblePages": "@config.maxVisiblePages",
                      "onPageChange": "PAGE_CHANGE",
                      "onPageSizeChange": "PAGE_SIZE_CHANGE",
                      "pageChangeEvent": "PAGE_CHANGE",
                      "pageSize": "@entity.pageSize",
                      "pageSizeChangeEvent": "PAGE_SIZE_CHANGE",
                      "pageSizeOptions": "@config.pageSizeOptions",
                      "showJumpToPage": "@config.showJumpToPage",
                      "showPageSize": "@config.showPageSize",
                      "showTotal": "@config.showTotal",
                      "totalItems": "@config.totalItems",
                      "totalPages": "@config.totalPages",
                      "type": "pagination"
                    }
                  ]
                ],
                "event": "PAGE_SIZE_CHANGE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}