{
  "name": "ui-pagination",
  "version": "1.0.0",
  "description": "Pagination — UI factory (1:1 with the @almadar/ui pagination pattern).",
  "orbitals": [
    {
      "name": "PaginationOrbital",
      "entity": {
        "name": "PaginationItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PaginationRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PaginationItem",
          "emits": [
            {
              "event": "PAGE_CHANGE",
              "description": "Callback when page changes (optional - can be a no-op if not interactive)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "page",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PAGE_SIZE_CHANGE",
              "description": "Callback when page size changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "size",
                  "type": "number"
                },
                {
                  "name": "pageSize",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PAGE_CHANGE",
                "name": "Page Change",
                "description": "Callback when page changes (optional - can be a no-op if not interactive)",
                "tier": "essential"
              },
              {
                "key": "PAGE_SIZE_CHANGE",
                "name": "Page Size Change",
                "description": "Callback when page size changes",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "showPageSize": "@config.showPageSize",
                      "onPageChange": "PAGE_CHANGE",
                      "totalPages": "@config.totalPages",
                      "pageSizeOptions": "@config.pageSizeOptions",
                      "totalItems": "@config.totalItems",
                      "maxVisiblePages": "@config.maxVisiblePages",
                      "showJumpToPage": "@config.showJumpToPage",
                      "pageSize": "@config.pageSize",
                      "currentPage": "@config.currentPage",
                      "onPageSizeChange": "PAGE_SIZE_CHANGE",
                      "showTotal": "@config.showTotal",
                      "pageChangeEvent": "PAGE_CHANGE",
                      "className": "@config.className",
                      "pageSizeChangeEvent": "PAGE_SIZE_CHANGE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "totalPages": {
              "type": "number",
              "default": 0.0,
              "label": "Total Pages",
              "description": "Total number of pages",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Current page size",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "showJumpToPage": {
              "type": "boolean",
              "default": false,
              "label": "Show Jump To Page",
              "description": "Show jump to page input",
              "tier": "presentation"
            },
            "totalItems": {
              "type": "number",
              "default": 0.0,
              "label": "Total Items",
              "description": "Total items count",
              "tier": "presentation"
            },
            "pageSizeOptions": {
              "type": "[number]",
              "default": [],
              "label": "Page Size Options",
              "description": "Page size options",
              "tier": "presentation",
              "items": {
                "type": "number"
              }
            },
            "showPageSize": {
              "type": "boolean",
              "default": false,
              "label": "Show Page Size",
              "description": "Show page size selector",
              "tier": "presentation"
            },
            "currentPage": {
              "type": "number",
              "default": 0.0,
              "label": "Current Page",
              "description": "Current page (1-indexed)",
              "tier": "presentation"
            },
            "maxVisiblePages": {
              "type": "number",
              "default": 7.0,
              "label": "Max Visible Pages",
              "description": "Maximum number of page buttons to show",
              "tier": "presentation"
            },
            "showTotal": {
              "type": "boolean",
              "default": false,
              "label": "Show Total",
              "description": "Show total count",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PaginationPage",
          "path": "/pagination",
          "traits": [
            {
              "ref": "PaginationRender"
            }
          ]
        }
      ]
    }
  ]
}