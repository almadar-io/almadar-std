          "traits": [
            {
              "ref": "ModalRender",
              "refId": "trt_01KXG04Q5PYA9J2QPM3Z0VHS4P"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "description": "Modal content (can be empty if using slot content)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "closeEvent": {
              "default": "CLOSE",
              "description": "Declarative close event — emits UI:{closeEvent} via eventBus when modal should close",
              "label": "Close Event",
              "tier": "presentation",
              "type": "string"
            },
            "closeOnEscape": {
              "default": true,
              "description": "closeOnEscape prop",
              "label": "Close On Escape",
              "tier": "presentation",
              "type": "boolean"
            },
            "closeOnOverlayClick": {
              "default": true,
              "description": "closeOnOverlayClick prop",
              "label": "Close On Overlay Click",
              "tier": "presentation",
              "type": "boolean"
            },
            "footer": {
              "description": "footer prop",
              "label": "Footer",
              "tier": "presentation",
              "type": "node"
            },
            "isOpen": {
              "default": true,
              "description": "Whether the modal is open (defaults to true when rendered by slot wrapper)",
              "label": "Is Open",
              "tier": "presentation",
              "type": "boolean"
            },
            "look": {
              "default": "centered-card",
              "description": "Layer 2 visual treatment — orthogonal to the semantic variant.",
              "label": "Look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "centered-card",
                "top-sheet",
                "side-drawer",
                "full-screen"
              ]
            },
            "onClose": {
              "default": "CLOSE",
              "description": "Callback when modal should close (injected by slot wrapper)",
              "label": "On Close",
              "tier": "presentation",
              "type": "string"
            },
            "showCloseButton": {
              "default": true,
              "description": "showCloseButton prop",
              "label": "Show Close Button",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl",
                "full"
              ]
            },
            "swipeDownToClose": {
              "default": true,
              "description": "Enable swipe-down-to-close on mobile bottom sheet (default: true)",
              "label": "Swipe Down To Close",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when modal should close (injected by slot wrapper)",
              "event": "@config.onClose",
              "eventId": "evt_01KXG04Q5T0RF2CANHKFSFY31X",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Open the Modal.",
              "event": "OPEN",
              "eventId": "evt_01KXG04Q5T5TD4WDV7C33F1DXK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04Q5PYA9J2QPM3Z0VHS4P",
          "linkedEntity": "ModalItem",
          "linkedEntityId": "ent_01KXG04Q5PX7A7K0XE0GCEKMVK",
          "name": "ModalRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04Q5P9V6JG8HCYHGD2Y46",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Open the Modal.",
                "id": "evt_01KXG04Q5T5TD4WDV7C33F1DXK",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "id": "evt_01KXG04Q5T3B6FYMBQPC1QFABB",
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "description": "Callback when modal should close (injected by slot wrapper)",
                "id": "evt_01KXG04Q5T0RF2CANHKFSFY31X",
                "key": "@config.onClose",
                "name": "@config.on close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Modal",
                      "type": "button"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04Q5P9V6JG8HCYHGD2Y46",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "closeEvent": "@config.closeEvent",
                      "closeOnEscape": "@config.closeOnEscape",
                      "closeOnOverlayClick": "@config.closeOnOverlayClick",
                      "footer": "@config.footer",
                      "isOpen": "@config.isOpen",
                      "look": "@config.look",
                      "onClose": "@config.onClose",
                      "showCloseButton": "@config.showCloseButton",
                      "size": "@config.size",
                      "swipeDownToClose": "@config.swipeDownToClose",
                      "title": "@config.title",
                      "type": "modal"
                    }
                  ]
                ],
                "event": "OPEN",
                "eventId": "evt_01KXG04Q5T5TD4WDV7C33F1DXK",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Modal",
                      "type": "button"
                    }
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04Q5T3B6FYMBQPC1QFABB",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
