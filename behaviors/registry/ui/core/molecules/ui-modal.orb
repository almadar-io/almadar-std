  "name": "ui-modal",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "id": "ent_01KXG04Q5PX7A7K0XE0GCEKMVK",
        "name": "ModalItem",
        "persistence": "runtime"
      },
      "id": "orb_01KXG04Q5PQDDJ3KGQAWNGE9BA",
      "name": "ModalOrbital",
      "pages": [
        {
          "id": "pag_01KXG04Q5T3EN42DTSHB7K06MB",
          "name": "ModalPage",
