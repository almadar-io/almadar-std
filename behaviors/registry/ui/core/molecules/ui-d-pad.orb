{
  "name": "ui-d-pad",
  "version": "1.0.0",
  "description": "DPad — UI factory (1:1 with the @almadar/ui d-pad pattern).",
  "orbitals": [
    {
      "name": "DPadOrbital",
      "entity": {
        "name": "DPadItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DPadRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DPadItem",
          "emits": [
            {
              "event": "DIRECTION",
              "description": "Called when a direction is pressed/released",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "direction",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DIRECTION",
                "name": "Direction",
                "description": "Called when a direction is pressed/released",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "disabled": "@config.disabled",
                      "type": "d-pad",
                      "size": "@config.size",
                      "includeDiagonals": "@config.includeDiagonals",
                      "onDirection": "DIRECTION",
                      "directionEvent": "DIRECTION",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "includeDiagonals": {
              "type": "boolean",
              "default": false,
              "label": "Include Diagonals",
              "description": "Whether to include diagonal buttons",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disabled state",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DPadPage",
          "path": "/d-pad",
          "traits": [
            {
              "ref": "DPadRender"
            }
          ]
        }
      ]
    }
  ]
}