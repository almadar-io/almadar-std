{
  "description": "DocSearch — UI factory (1:1 with the @almadar/ui doc-search pattern).",
  "name": "ui-doc-search",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DocSearchItem",
        "persistence": "runtime"
      },
      "name": "DocSearchOrbital",
      "pages": [
        {
          "name": "DocSearchPage",
          "path": "/doc-search",
          "traits": [
            {
              "ref": "DocSearchRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "placeholder": {
              "default": "Placeholder",
              "description": "Placeholder text for the input",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DocSearchItem",
          "name": "DocSearchRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "placeholder": "@config.placeholder",
                      "type": "doc-search"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}