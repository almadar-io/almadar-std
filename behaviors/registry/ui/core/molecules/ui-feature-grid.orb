{
  "name": "ui-feature-grid",
  "version": "1.0.0",
  "description": "FeatureGrid — UI factory (1:1 with the @almadar/ui feature-grid pattern).",
  "orbitals": [
    {
      "name": "FeatureGridOrbital",
      "entity": {
        "name": "FeatureGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FeatureGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FeatureGridItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "columns": "@config.columns",
                      "gap": "@config.gap",
                      "items": "@config.items",
                      "className": "@config.className",
                      "type": "feature-grid"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between grid items",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "items": {
              "type": "[FeatureGridItemsItem]",
              "default": [
                {
                  "title": "Title",
                  "icon": "circle",
                  "size": "sm",
                  "linkLabel": "Link Label",
                  "href": "Href",
                  "variant": "default",
                  "className": "Class Name",
                  "description": "Description"
                }
              ],
              "label": "Items",
              "description": "Array of feature card configurations",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "bordered",
                      "elevated",
                      "interactive"
                    ]
                  },
                  "size": {
                    "name": "size",
                    "type": "string",
                    "required": false,
                    "values": [
                      "sm",
                      "md",
                      "lg"
                    ]
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "className": {
                    "name": "className",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "columns": {
              "type": "number",
              "default": 3.0,
              "label": "Columns",
              "description": "Number of grid columns",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FeatureGridPage",
          "path": "/feature-grid",
          "traits": [
            {
              "ref": "FeatureGridRender"
            }
          ]
        }
      ]
    }
  ]
}