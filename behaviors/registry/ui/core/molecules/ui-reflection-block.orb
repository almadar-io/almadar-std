{
  "description": "ReflectionBlock — UI factory (1:1 with the @almadar/ui reflection-block pattern).",
  "name": "ui-reflection-block",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ReflectionBlockItem",
        "persistence": "runtime"
      },
      "name": "ReflectionBlockOrbital",
      "pages": [
        {
          "name": "ReflectionBlockPage",
          "path": "/reflection-block",
          "traits": [
            {
              "ref": "ReflectionBlockRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "index": {
              "default": 0.0,
              "description": "Zero-based index of this block (used in the emitted event payload)",
              "label": "Index",
              "tier": "presentation",
              "type": "number"
            },
            "prompt": {
              "default": "Prompt",
              "description": "The reflection prompt",
              "label": "Prompt",
              "tier": "presentation",
              "type": "string"
            },
            "saveEvent": {
              "default": "SAVE_REFLECTION",
              "description": "Event name emitted on save (as `UI:<saveEvent>`). Defaults to 'SAVE_REFLECTION'.",
              "label": "Save Event",
              "tier": "presentation",
              "type": "string"
            },
            "savedNote": {
              "default": "Saved Note",
              "description": "Pre-filled note from saved state",
              "label": "Saved Note",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ReflectionBlockItem",
          "name": "ReflectionBlockRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "index": "@config.index",
                      "prompt": "@config.prompt",
                      "saveEvent": "@config.saveEvent",
                      "savedNote": "@config.savedNote",
                      "type": "reflection-block"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}