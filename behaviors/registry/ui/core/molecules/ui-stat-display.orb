{
  "name": "ui-stat-display",
  "version": "1.0.0",
  "description": "StatDisplay — UI factory (1:1 with the @almadar/ui stat-display pattern).",
  "orbitals": [
    {
      "name": "StatDisplayOrbital",
      "entity": {
        "name": "StatDisplayItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StatDisplayRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StatDisplayItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "suffix": "@config.suffix",
                      "trendPolarity": "@config.trendPolarity",
                      "isLoading": "@config.isLoading",
                      "clickEvent": "@config.clickEvent",
                      "label": "@config.label",
                      "size": "@config.size",
                      "icon": "@config.icon",
                      "trendFormat": "@config.trendFormat",
                      "prefix": "@config.prefix",
                      "look": "@config.look",
                      "variant": "@config.variant",
                      "iconBg": "@config.iconBg",
                      "value": "@config.value",
                      "target": "@config.target",
                      "iconColor": "@config.iconColor",
                      "max": "@config.max",
                      "sparklineData": "@config.sparklineData",
                      "compact": "@config.compact",
                      "trend": "@config.trend",
                      "format": "@config.format",
                      "className": "@config.className",
                      "error": "@config.error",
                      "type": "stat-display"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "iconColor": {
              "type": "string",
              "default": "text-foreground",
              "label": "Icon Color",
              "description": "Icon color class",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "prefix": {
              "type": "string",
              "default": "Prefix",
              "label": "Prefix",
              "description": "Prefix prepended to the formatted value (e.g. '≈ ').",
              "tier": "presentation"
            },
            "trend": {
              "type": "number",
              "default": 0.0,
              "label": "Trend",
              "description": "Signed delta vs previous period. >0 renders ↑ green, <0 renders ↓ red, 0 hides. Polarity reversal via `trendPolarity`.",
              "tier": "presentation"
            },
            "sparklineData": {
              "type": "[number]",
              "default": [],
              "label": "Sparkline Data",
              "description": "Optional inline sparkline data appended to the trend row. Length < 2 renders nothing.",
              "tier": "presentation",
              "items": {
                "type": "number"
              }
            },
            "suffix": {
              "type": "string",
              "default": "Suffix",
              "label": "Suffix",
              "description": "Suffix appended to the formatted value (e.g. ' /mo', ' ms').",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Color variant",
              "tier": "presentation",
              "values": [
                "default",
                "primary",
                "success",
                "warning",
                "error",
                "info"
              ]
            },
            "iconBg": {
              "type": "string",
              "default": "bg-muted",
              "label": "Icon Bg",
              "description": "Icon background color class",
              "tier": "presentation"
            },
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Primary value (number or formatted string)",
              "tier": "presentation"
            },
            "clickEvent": {
              "type": "string",
              "default": "Click Event",
              "label": "Click Event",
              "description": "Event name emitted as `UI:{clickEvent}` with `{ metricLabel }` when the card is clicked.",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "elevated",
              "label": "Look",
              "description": "Layer 2 visual treatment.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "trendPolarity": {
              "type": "string",
              "default": "higher-is-better",
              "label": "Trend Polarity",
              "description": "Controls whether `trend > 0` is 'good' (default) or 'bad'. `lower-is-better` inverts the color logic.",
              "tier": "presentation",
              "values": [
                "higher-is-better",
                "lower-is-better"
              ]
            },
            "format": {
              "type": "string",
              "default": "Format",
              "label": "Format",
              "description": "Display format: 'number', 'currency', 'percent'",
              "tier": "presentation"
            },
            "compact": {
              "type": "boolean",
              "default": false,
              "label": "Compact",
              "description": "Compact mode (inline, no card wrapper)",
              "tier": "presentation"
            },
            "error": {
              "type": "StatDisplayError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                }
              }
            },
            "max": {
              "type": "number",
              "default": 0.0,
              "label": "Max",
              "description": "Optional denominator. >0 renders 'value / max'; 0 or omitted hides the divider.",
              "tier": "presentation"
            },
            "trendFormat": {
              "type": "string",
              "default": "absolute",
              "label": "Trend Format",
              "description": "When `'percent'`, renders trend with a `%` suffix (e.g. `↓ 3.3%`); default is `'absolute'`.",
              "tier": "presentation",
              "values": [
                "absolute",
                "percent"
              ]
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Display label (e.g., 'Total', 'Remaining')",
              "tier": "presentation"
            },
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Lucide icon name or component",
              "tier": "presentation"
            },
            "target": {
              "type": "number",
              "default": 0.0,
              "label": "Target",
              "description": "Optional progress target. >0 renders a progress bar at value/target.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatDisplayPage",
          "path": "/stat-display",
          "traits": [
            {
              "ref": "StatDisplayRender"
            }
          ]
        }
      ]
    }
  ]
}