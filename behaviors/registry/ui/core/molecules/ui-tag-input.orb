{
  "description": "TagInput — UI factory (1:1 with the @almadar/ui tag-input pattern).",
  "name": "ui-tag-input",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TagInputItem",
        "persistence": "runtime"
      },
      "name": "TagInputOrbital",
      "pages": [
        {
          "name": "TagInputPage",
          "path": "/tag-input",
          "traits": [
            {
              "ref": "TagInputRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "addEvent": {
              "default": "ADD",
              "description": "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`.",
              "label": "Add Event",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the outer container.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Disable add + remove interactions.",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "helperText": {
              "default": "Helper Text",
              "description": "Helper text rendered under the input.",
              "label": "Helper Text",
              "tier": "presentation",
              "type": "string"
            },
            "onChange": {
              "default": "CHANGE",
              "description": "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below.",
              "label": "On Change",
              "tier": "presentation",
              "type": "string"
            },
            "placeholder": {
              "default": "Placeholder",
              "description": "Placeholder for the entry input. Default: `'Type and press Enter…'`.",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "removeEvent": {
              "default": "REMOVE",
              "description": "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`.",
              "label": "Remove Event",
              "tier": "presentation",
              "type": "string"
            },
            "unique": {
              "default": true,
              "description": "Suppress duplicate entries. Default: `true`.",
              "label": "Unique",
              "tier": "presentation",
              "type": "boolean"
            },
            "value": {
              "default": [
                "Item",
                "Item 2"
              ],
              "description": "Current list of tags.",
              "items": {
                "type": "string"
              },
              "label": "Value",
              "tier": "presentation",
              "type": "[string]"
            },
            "variant": {
              "default": "default",
              "description": "Variant applied to each chip Badge. Default: `'default'`.",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "primary",
                "secondary",
                "success",
                "warning",
                "danger",
                "error",
                "info",
                "neutral"
              ]
            }
          },
          "emits": [
            {
              "description": "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below.",
              "event": "@config.onChange",
              "payloadSchema": [
                {
                  "name": "next",
                  "type": "[object]"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`.",
              "event": "@config.addEvent",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`.",
              "event": "@config.removeEvent",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TagInputItem",
          "name": "TagInputRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below.",
                "key": "@config.onChange",
                "name": "@config.on change",
                "payloadSchema": [
                  {
                    "name": "next",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`.",
                "key": "@config.addEvent",
                "name": "@config.add event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`.",
                "key": "@config.removeEvent",
                "name": "@config.remove event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "addEvent": "@config.addEvent",
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "helperText": "@config.helperText",
                      "onChange": "@config.onChange",
                      "placeholder": "@config.placeholder",
                      "removeEvent": "@config.removeEvent",
                      "type": "tag-input",
                      "unique": "@config.unique",
                      "value": "@config.value",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}