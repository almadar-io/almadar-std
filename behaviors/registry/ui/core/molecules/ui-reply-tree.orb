{
  "name": "ui-reply-tree",
  "version": "1.0.0",
  "description": "ReplyTree — UI factory (1:1 with the @almadar/ui reply-tree pattern).",
  "orbitals": [
    {
      "name": "ReplyTreeOrbital",
      "entity": {
        "name": "ReplyTreeItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "authorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ReplyTreeRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ReplyTreeItem",
          "emits": [
            {
              "event": "VOTE",
              "description": "onVote prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                },
                {
                  "name": "vote",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REPLY",
              "description": "onReply prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "parentNodeId",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FLAG",
              "description": "onFlag prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CONTINUE_THREAD",
              "description": "onContinueThread prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VOTE",
                "name": "Vote",
                "description": "onVote prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  },
                  {
                    "name": "vote",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REPLY",
                "name": "Reply",
                "description": "onReply prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "parentNodeId",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FLAG",
                "name": "Flag",
                "description": "onFlag prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONTINUE_THREAD",
                "name": "Continue Thread",
                "description": "onContinueThread prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReplyTreeItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "flagEvent": "FLAG",
                      "onFlag": "FLAG",
                      "onContinueThread": "CONTINUE_THREAD",
                      "continueThreadEvent": "CONTINUE_THREAD",
                      "onVote": "VOTE",
                      "className": "@config.className",
                      "type": "reply-tree",
                      "showActions": "@config.showActions",
                      "voteEvent": "VOTE",
                      "replyEvent": "REPLY",
                      "maxDepth": "@config.maxDepth",
                      "nodes": "@entity",
                      "onReply": "REPLY"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showActions": {
              "type": "boolean",
              "default": true,
              "label": "Show Actions",
              "description": "showActions prop",
              "tier": "presentation"
            },
            "maxDepth": {
              "type": "number",
              "default": 6.0,
              "label": "Max Depth",
              "description": "maxDepth prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ReplyTreePage",
          "path": "/reply-tree",
          "traits": [
            {
              "ref": "ReplyTreeRender"
            }
          ]
        }
      ]
    }
  ]
}