{
  "description": "ReplyTree — UI factory (1:1 with the @almadar/ui reply-tree pattern).",
  "name": "ui-reply-tree",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Author Name",
            "name": "authorName",
            "type": "string"
          },
          {
            "default": "Content",
            "name": "content",
            "type": "string"
          },
          {
            "default": "Author Avatar Url",
            "name": "authorAvatarUrl",
            "type": "string"
          },
          {
            "default": "Posted At",
            "name": "postedAt",
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "voteCount",
            "type": "number"
          },
          {
            "default": "up",
            "name": "userVote",
            "type": "string",
            "values": [
              "up",
              "down",
              "none"
            ]
          },
          {
            "default": false,
            "name": "collapsed",
            "type": "boolean"
          },
          {
            "default": {},
            "name": "replies",
            "type": "string"
          }
        ],
        "name": "ReplyTreeItem",
        "persistence": "runtime"
      },
      "name": "ReplyTreeOrbital",
      "pages": [
        {
          "name": "ReplyTreePage",
          "path": "/reply-tree",
          "traits": [
            {
              "ref": "ReplyTreeRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "maxDepth": {
              "default": 6.0,
              "description": "maxDepth prop",
              "label": "Max Depth",
              "tier": "presentation",
              "type": "number"
            },
            "showActions": {
              "default": true,
              "description": "showActions prop",
              "label": "Show Actions",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "onVote prop",
              "event": "VOTE",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                },
                {
                  "name": "vote",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "onReply prop",
              "event": "REPLY",
              "payloadSchema": [
                {
                  "name": "parentNodeId",
                  "type": "string"
                },
                {
                  "name": "content",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "onFlag prop",
              "event": "FLAG",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "onContinueThread prop",
              "event": "CONTINUE_THREAD",
              "payloadSchema": [
                {
                  "name": "nodeId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ReplyTreeItem",
          "name": "ReplyTreeRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onVote prop",
                "key": "VOTE",
                "name": "Vote",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  },
                  {
                    "name": "vote",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "onReply prop",
                "key": "REPLY",
                "name": "Reply",
                "payloadSchema": [
                  {
                    "name": "parentNodeId",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "onFlag prop",
                "key": "FLAG",
                "name": "Flag",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "onContinueThread prop",
                "key": "CONTINUE_THREAD",
                "name": "Continue Thread",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "ReplyTreeItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "continueThreadEvent": "CONTINUE_THREAD",
                      "flagEvent": "FLAG",
                      "maxDepth": "@config.maxDepth",
                      "nodes": "@entity",
                      "onContinueThread": "CONTINUE_THREAD",
                      "onFlag": "FLAG",
                      "onReply": "REPLY",
                      "onVote": "VOTE",
                      "replyEvent": "REPLY",
                      "showActions": "@config.showActions",
                      "type": "reply-tree",
                      "voteEvent": "VOTE"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}