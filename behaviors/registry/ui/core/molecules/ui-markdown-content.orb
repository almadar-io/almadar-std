{
  "name": "ui-markdown-content",
  "version": "1.0.0",
  "description": "MarkdownContent — UI factory (1:1 with the @almadar/ui markdown-content pattern).",
  "orbitals": [
    {
      "name": "MarkdownContentOrbital",
      "entity": {
        "name": "MarkdownContentItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MarkdownContentRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MarkdownContentItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "@config.direction",
                      "className": "@config.className",
                      "type": "markdown-content",
                      "content": "@config.content"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "direction": {
              "type": "string",
              "default": "rtl",
              "label": "Direction",
              "description": "Text direction",
              "tier": "presentation",
              "values": [
                "rtl",
                "ltr"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "content": {
              "type": "string",
              "default": "Content",
              "label": "Content",
              "description": "The markdown content to render",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MarkdownContentPage",
          "path": "/markdown-content",
          "traits": [
            {
              "ref": "MarkdownContentRender"
            }
          ]
        }
      ]
    }
  ]
}