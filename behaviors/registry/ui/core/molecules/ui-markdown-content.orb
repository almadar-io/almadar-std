{
  "description": "MarkdownContent — UI factory (1:1 with the @almadar/ui markdown-content pattern).",
  "name": "ui-markdown-content",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MarkdownContentItem",
        "persistence": "runtime"
      },
      "name": "MarkdownContentOrbital",
      "pages": [
        {
          "name": "MarkdownContentPage",
          "path": "/markdown-content",
          "traits": [
            {
              "ref": "MarkdownContentRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "content": {
              "default": "Content",
              "description": "The markdown content to render",
              "label": "Content",
              "tier": "presentation",
              "type": "string"
            },
            "direction": {
              "default": "ltr",
              "description": "Text direction (defaults to ltr; `ltr` is first so the generated config seeds it)",
              "label": "Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "ltr",
                "rtl"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MarkdownContentItem",
          "name": "MarkdownContentRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "content": "@config.content",
                      "direction": "@config.direction",
                      "type": "markdown-content"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}