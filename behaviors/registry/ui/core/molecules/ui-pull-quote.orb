{
  "name": "ui-pull-quote",
  "version": "1.0.0",
  "description": "PullQuote — UI factory (1:1 with the @almadar/ui pull-quote pattern).",
  "orbitals": [
    {
      "name": "PullQuoteOrbital",
      "entity": {
        "name": "PullQuoteItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PullQuoteRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PullQuoteItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pull-quote",
                      "children": "Sample content",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PullQuotePage",
          "path": "/pull-quote",
          "traits": [
            {
              "ref": "PullQuoteRender"
            }
          ]
        }
      ]
    }
  ]
}
