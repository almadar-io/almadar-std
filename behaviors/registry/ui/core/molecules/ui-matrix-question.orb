{
  "name": "ui-matrix-question",
  "version": "1.0.0",
  "description": "MatrixQuestion — UI factory (1:1 with the @almadar/ui matrix-question pattern).",
  "orbitals": [
    {
      "name": "MatrixQuestionOrbital",
      "entity": {
        "name": "MatrixQuestionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MatrixQuestionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MatrixQuestionItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "Change handler invoked with rowId and selected column value",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "rowId",
                  "type": "string"
                },
                {
                  "name": "value",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Change handler invoked with rowId and selected column value",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "onChange": "CHANGE",
                      "title": "@config.title",
                      "columns": "@config.columns",
                      "values": "@config.values",
                      "rows": "@config.rows",
                      "changeEvent": "CHANGE",
                      "className": "@config.className",
                      "size": "@config.size",
                      "disabled": "@config.disabled",
                      "type": "matrix-question"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disable all inputs",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Visual size",
              "tier": "presentation",
              "values": [
                "sm",
                "md"
              ]
            },
            "rows": {
              "type": "[MatrixQuestionRowsItem]",
              "default": [],
              "label": "Rows",
              "description": "Question rows",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Optional title rendered above the matrix",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "values": {
              "type": "json",
              "label": "Values",
              "description": "Selected value per row, keyed by rowId",
              "tier": "presentation"
            },
            "columns": {
              "type": "[MatrixQuestionColumnsItem]",
              "default": [],
              "label": "Columns",
              "description": "Column definitions; defaults to 5-point Likert",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true,
                    "values": [
                      "number",
                      "string"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MatrixQuestionPage",
          "path": "/matrix-question",
          "traits": [
            {
              "ref": "MatrixQuestionRender"
            }
          ]
        }
      ]
    }
  ]
}