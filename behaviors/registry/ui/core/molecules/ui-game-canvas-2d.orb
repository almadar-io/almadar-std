{
  "name": "ui-game-canvas-2d",
  "version": "1.0.0",
  "description": "GameCanvas2d — UI factory (1:1 with the @almadar/ui game-canvas-2d pattern).",
  "orbitals": [
    {
      "name": "GameCanvas2dOrbital",
      "entity": {
        "name": "GameCanvas2dItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GameCanvas2dRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GameCanvas2dItem",
          "emits": [
            {
              "event": "DRAW",
              "description": "Called each frame with the 2D context and current frame count",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "ctx",
                  "type": "object"
                },
                {
                  "name": "frame",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TICK",
              "description": "Called each tick with delta time in seconds",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "dt",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DRAW",
                "name": "Draw",
                "description": "Called each frame with the 2D context and current frame count",
                "tier": "essential"
              },
              {
                "key": "TICK",
                "name": "Tick",
                "description": "Called each tick with delta time in seconds",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "backgroundImage": "@config.backgroundImage",
                      "fps": "@config.fps",
                      "tickEvent": "@config.tickEvent",
                      "drawEvent": "@config.drawEvent",
                      "className": "@config.className",
                      "height": "@config.height",
                      "width": "@config.width",
                      "onDraw": "DRAW",
                      "onTick": "TICK",
                      "type": "game-canvas-2d"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "width": {
              "type": "number",
              "default": 800.0,
              "label": "Width",
              "description": "Canvas width in pixels",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 600.0,
              "label": "Height",
              "description": "Canvas height in pixels",
              "tier": "presentation"
            },
            "assetBaseUrl": {
              "type": "string",
              "default": "",
              "label": "Asset Base Url",
              "description": "Base URL prefix for asset URLs",
              "tier": "presentation"
            },
            "tickEvent": {
              "type": "string",
              "default": "",
              "label": "Tick Event",
              "description": "Event name emitted each tick with { dt, frame } — for closed-circuit .orb integration",
              "tier": "presentation"
            },
            "drawEvent": {
              "type": "string",
              "default": "",
              "label": "Draw Event",
              "description": "Event name emitted each draw frame with { frame } — for closed-circuit .orb integration",
              "tier": "presentation"
            },
            "fps": {
              "type": "number",
              "default": 60.0,
              "label": "Fps",
              "description": "Target frames per second",
              "tier": "presentation"
            },
            "backgroundImage": {
              "type": "string",
              "default": "",
              "label": "Background Image",
              "description": "Background image URL",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameCanvas2dPage",
          "path": "/game-canvas-2d",
          "traits": [
            {
              "ref": "GameCanvas2dRender"
            }
          ]
        }
      ]
    }
  ]
}