{
  "name": "ui-grid",
  "version": "1.0.0",
  "description": "Grid — UI factory (1:1 with the @almadar/ui grid pattern).",
  "orbitals": [
    {
      "name": "GridOrbital",
      "entity": {
        "name": "GridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GridItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "gap": "@config.gap",
                      "cols": "@config.cols",
                      "rows": "@config.rows",
                      "colGap": "@config.colGap",
                      "className": "@config.className",
                      "style": "@config.style",
                      "justifyItems": "@config.justifyItems",
                      "type": "grid",
                      "alignItems": "@config.alignItems",
                      "flow": "@config.flow",
                      "rowGap": "@config.rowGap"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "alignItems": {
              "type": "string",
              "default": "start",
              "label": "Align Items",
              "description": "Align items on block axis",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "stretch",
                "baseline"
              ]
            },
            "rowGap": {
              "type": "string",
              "default": "none",
              "label": "Row Gap",
              "description": "Row gap (overrides gap for rows)",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "rows": {
              "type": "number",
              "default": 0.0,
              "label": "Rows",
              "description": "Number of rows",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Custom class name",
              "tier": "presentation"
            },
            "flow": {
              "type": "string",
              "default": "row",
              "label": "Flow",
              "description": "Auto-flow direction",
              "tier": "presentation",
              "values": [
                "row",
                "col",
                "row-dense",
                "col-dense"
              ]
            },
            "justifyItems": {
              "type": "string",
              "default": "start",
              "label": "Justify Items",
              "description": "Justify items on inline axis",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            },
            "cols": {
              "type": "string",
              "label": "Cols",
              "description": "Number of columns (can be responsive object)",
              "tier": "presentation"
            },
            "gap": {
              "type": "string",
              "default": "md",
              "label": "Gap",
              "description": "Gap between items",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "colGap": {
              "type": "string",
              "default": "none",
              "label": "Col Gap",
              "description": "Column gap (overrides gap for columns)",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "style": {
              "type": "json",
              "label": "Style",
              "description": "Inline styles",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GridPage",
          "path": "/grid",
          "traits": [
            {
              "ref": "GridRender"
            }
          ]
        }
      ]
    }
  ]
}