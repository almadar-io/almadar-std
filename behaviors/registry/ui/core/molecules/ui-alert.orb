{
  "description": "Alert — UI factory (1:1 with the @almadar/ui alert pattern).",
  "name": "ui-alert",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AlertItem",
        "persistence": "runtime"
      },
      "name": "AlertOrbital",
      "pages": [
        {
          "name": "AlertPage",
          "path": "/alert",
          "traits": [
            {
              "ref": "AlertRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "description": "actions prop",
              "label": "Actions",
              "tier": "presentation",
              "type": "node"
            },
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Alert content (children or message)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "dismissEvent": {
              "default": "DISMISS",
              "description": "Declarative dismiss event — emits UI:{dismissEvent} via eventBus when alert is dismissed",
              "label": "Dismiss Event",
              "tier": "presentation",
              "type": "string"
            },
            "dismissible": {
              "default": false,
              "description": "dismissible prop",
              "label": "Dismissible",
              "tier": "presentation",
              "type": "boolean"
            },
            "message": {
              "default": "Message",
              "description": "Alert message (alias for children)",
              "label": "Message",
              "tier": "presentation",
              "type": "string"
            },
            "onClose": {
              "default": "CLOSE",
              "description": "onClose prop",
              "label": "On Close",
              "tier": "presentation",
              "type": "string"
            },
            "onDismiss": {
              "default": "DISMISS",
              "description": "onDismiss prop",
              "label": "On Dismiss",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "info",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "info",
                "success",
                "warning",
                "error"
              ]
            }
          },
          "emits": [
            {
              "description": "onDismiss prop",
              "event": "DISMISS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "onClose prop",
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AlertItem",
          "name": "AlertRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onDismiss prop",
                "key": "DISMISS",
                "name": "Dismiss",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "onClose prop",
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "children": "@config.children",
                      "className": "@config.className",
                      "dismissEvent": "@config.dismissEvent",
                      "dismissible": "@config.dismissible",
                      "message": "@config.message",
                      "onClose": "@config.onClose",
                      "onDismiss": "@config.onDismiss",
                      "title": "@config.title",
                      "type": "alert",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}