{
  "description": "SignaturePad — UI factory (1:1 with the @almadar/ui signature-pad pattern).",
  "name": "ui-signature-pad",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SignaturePadItem",
        "persistence": "runtime"
      },
      "name": "SignaturePadOrbital",
      "pages": [
        {
          "name": "SignaturePadPage",
          "path": "/signature-pad",
          "traits": [
            {
              "ref": "SignaturePadRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "clearEvent": {
              "default": "CLEAR",
              "description": "Event to emit on clear",
              "label": "Clear Event",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SignaturePadError"
            },
            "height": {
              "default": 200.0,
              "description": "Pad height",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "helperText": {
              "default": "Helper Text",
              "description": "Helper text",
              "label": "Helper Text",
              "tier": "presentation",
              "type": "string"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "label": {
              "default": "Label",
              "description": "Label above the pad",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "onChange": {
              "default": "CHANGE",
              "description": "Callback when signature changes",
              "label": "On Change",
              "tier": "presentation",
              "type": "string"
            },
            "readOnly": {
              "default": false,
              "description": "Whether the pad is read-only",
              "label": "Read Only",
              "tier": "presentation",
              "type": "boolean"
            },
            "signEvent": {
              "default": "SIGN",
              "description": "Event to emit on sign",
              "label": "Sign Event",
              "tier": "presentation",
              "type": "string"
            },
            "strokeColor": {
              "default": "Stroke Color",
              "description": "Stroke color",
              "label": "Stroke Color",
              "tier": "presentation",
              "type": "string"
            },
            "strokeWidth": {
              "default": 2.0,
              "description": "Stroke width",
              "label": "Stroke Width",
              "tier": "presentation",
              "type": "number"
            },
            "value": {
              "default": "Value",
              "description": "Existing signature image URL",
              "label": "Value",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when signature changes",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "dataUrl",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event to emit on sign",
              "event": "SIGN",
              "payloadSchema": [
                {
                  "name": "signature",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event to emit on clear",
              "event": "CLEAR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SignaturePadItem",
          "name": "SignaturePadRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when signature changes",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "dataUrl",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event to emit on sign",
                "key": "SIGN",
                "name": "Sign",
                "payloadSchema": [
                  {
                    "name": "signature",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event to emit on clear",
                "key": "CLEAR",
                "name": "Clear",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clearEvent": "@config.clearEvent",
                      "error": "@config.error",
                      "height": "@config.height",
                      "helperText": "@config.helperText",
                      "isLoading": "@config.isLoading",
                      "label": "@config.label",
                      "onChange": "@config.onChange",
                      "readOnly": "@config.readOnly",
                      "signEvent": "@config.signEvent",
                      "strokeColor": "@config.strokeColor",
                      "strokeWidth": "@config.strokeWidth",
                      "type": "signature-pad",
                      "value": "@config.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}