{
  "name": "ui-signature-pad",
  "version": "1.0.0",
  "description": "SignaturePad — UI factory (1:1 with the @almadar/ui signature-pad pattern).",
  "orbitals": [
    {
      "name": "SignaturePadOrbital",
      "entity": {
        "name": "SignaturePadItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SignaturePadRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SignaturePadItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "Callback when signature changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "dataUrl",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SIGN",
              "description": "Event to emit on sign",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "signature",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CLEAR",
              "description": "Event to emit on clear",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Callback when signature changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "dataUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SIGN",
                "name": "Sign",
                "description": "Event to emit on sign",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "signature",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear",
                "description": "Event to emit on clear",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SignaturePadItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "@config.label",
                      "readOnly": "@config.readOnly",
                      "error": "@config.error",
                      "signEvent": "SIGN",
                      "className": "@config.className",
                      "value": "@config.value",
                      "helperText": "@config.helperText",
                      "clearEvent": "CLEAR",
                      "isLoading": "@config.isLoading",
                      "height": "@config.height",
                      "entity": "SignaturePadItem",
                      "strokeColor": "@config.strokeColor",
                      "strokeWidth": "@config.strokeWidth",
                      "type": "signature-pad",
                      "onChange": "CHANGE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "strokeColor": {
              "type": "string",
              "default": "Stroke Color",
              "label": "Stroke Color",
              "description": "Stroke color",
              "tier": "presentation"
            },
            "helperText": {
              "type": "string",
              "default": "Helper Text",
              "label": "Helper Text",
              "description": "Helper text",
              "tier": "presentation"
            },
            "readOnly": {
              "type": "boolean",
              "default": false,
              "label": "Read Only",
              "description": "Whether the pad is read-only",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "strokeWidth": {
              "type": "number",
              "default": 2.0,
              "label": "Stroke Width",
              "description": "Stroke width",
              "tier": "presentation"
            },
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Existing signature image URL",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Label above the pad",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 200.0,
              "label": "Height",
              "description": "Pad height",
              "tier": "presentation"
            },
            "error": {
              "type": "SignaturePadError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SignaturePadPage",
          "path": "/signature-pad",
          "traits": [
            {
              "ref": "SignaturePadRender"
            }
          ]
        }
      ]
    }
  ]
}