{
  "name": "ui-calendar-grid",
  "version": "1.0.0",
  "description": "CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern).",
  "orbitals": [
    {
      "name": "CalendarGridOrbital",
      "entity": {
        "name": "CalendarGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CalendarGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CalendarGridItem",
          "emits": [
            {
              "event": "SLOT_CLICK",
              "description": "Called when a time slot is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "day",
                  "type": "object"
                },
                {
                  "name": "time",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DAY_CLICK",
              "description": "Called when a day header is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "day",
                  "type": "object"
                }
              ]
            },
            {
              "event": "EVENT_CLICK",
              "description": "Called when an event is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "event",
                  "type": "object"
                }
              ]
            },
            {
              "event": "LONG_PRESS",
              "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "date",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "time",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SWIPE_LEFT",
              "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SWIPE_RIGHT",
              "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SLOT_CLICK",
                "name": "Slot Click",
                "description": "Called when a time slot is clicked",
                "tier": "essential"
              },
              {
                "key": "DAY_CLICK",
                "name": "Day Click",
                "description": "Called when a day header is clicked",
                "tier": "essential"
              },
              {
                "key": "EVENT_CLICK",
                "name": "Event Click",
                "description": "Called when an event is clicked",
                "tier": "essential"
              },
              {
                "key": "LONG_PRESS",
                "name": "Long Press",
                "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
                "tier": "essential"
              },
              {
                "key": "SWIPE_LEFT",
                "name": "Swipe Left",
                "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
                "tier": "essential"
              },
              {
                "key": "SWIPE_RIGHT",
                "name": "Swipe Right",
                "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarGridItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onDayClick": "DAY_CLICK",
                      "longPressPayload": "@config.longPressPayload",
                      "className": "@config.className",
                      "longPressEvent": "LONG_PRESS",
                      "swipeLeftEvent": "SWIPE_LEFT",
                      "dayWindow": "@config.dayWindow",
                      "type": "calendar-grid",
                      "onEventClick": "EVENT_CLICK",
                      "events": "@entity",
                      "timeSlots": "@config.timeSlots",
                      "weekStart": "@config.weekStart",
                      "onSlotClick": "SLOT_CLICK",
                      "swipeRightEvent": "SWIPE_RIGHT"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "weekStart": {
              "type": "json",
              "label": "Week Start",
              "description": "Start of the week (defaults to current week's Monday)",
              "tier": "presentation"
            },
            "dayWindow": {
              "type": "string",
              "default": "auto",
              "label": "Day Window",
              "description": "Override the viewport-driven day window. `'auto'` (default) tracks `window.innerWidth` — 1 day on mobile, 3 on tablet, 7 on laptop+. Pass an explicit number to force a fixed window (useful for print layouts or screenshot tests).",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "longPressPayload": {
              "type": "json",
              "label": "Long Press Payload",
              "description": "Additional payload for long-press events",
              "tier": "presentation"
            },
            "timeSlots": {
              "type": "[string]",
              "default": [],
              "label": "Time Slots",
              "description": "Time slot labels (defaults to 09:00-17:00)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CalendarGridPage",
          "path": "/calendar-grid",
          "traits": [
            {
              "ref": "CalendarGridRender"
            }
          ]
        }
      ]
    }
  ]
}