{
  "description": "CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern).",
  "name": "ui-calendar-grid",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Title",
            "name": "title",
            "type": "string"
          },
          {
            "default": "Start Time",
            "name": "startTime",
            "type": "string"
          },
          {
            "default": "End Time",
            "name": "endTime",
            "type": "string"
          },
          {
            "default": "Color",
            "name": "color",
            "type": "string"
          }
        ],
        "name": "CalendarGridItem",
        "persistence": "runtime"
      },
      "name": "CalendarGridOrbital",
      "pages": [
        {
          "name": "CalendarGridPage",
          "path": "/calendar-grid",
          "traits": [
            {
              "ref": "CalendarGridRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "dayWindow": {
              "description": "Override the viewport-driven day window. `'auto'` (default) tracks `window.innerWidth` — 1 day on mobile, 3 on tablet, 7 on laptop+. Pass an explicit number to force a fixed window (useful for print layouts or screenshot tests).",
              "label": "Day Window",
              "tier": "presentation",
              "type": "string"
            },
            "longPressPayload": {
              "default": {},
              "description": "Additional payload for long-press events",
              "label": "Long Press Payload",
              "tier": "presentation",
              "type": "json"
            },
            "timeSlots": {
              "default": [],
              "description": "Time slot labels (defaults to 09:00-17:00)",
              "items": {
                "type": "string"
              },
              "label": "Time Slots",
              "tier": "presentation",
              "type": "[string]"
            },
            "weekStart": {
              "default": "2024-01-01",
              "description": "Start of the week (defaults to current week's Monday)",
              "label": "Week Start",
              "tier": "presentation",
              "type": "date"
            }
          },
          "emits": [
            {
              "description": "Called when a time slot is clicked",
              "event": "SLOT_CLICK",
              "payloadSchema": [
                {
                  "name": "day",
                  "type": "date"
                },
                {
                  "name": "time",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when a day header is clicked",
              "event": "DAY_CLICK",
              "payloadSchema": [
                {
                  "name": "day",
                  "type": "date"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when an event is clicked",
              "event": "EVENT_CLICK",
              "payloadSchema": [
                {
                  "name": "event",
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
              "event": "LONG_PRESS",
              "payloadSchema": [
                {
                  "name": "date",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "time",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
              "event": "SWIPE_LEFT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
              "event": "SWIPE_RIGHT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "CalendarGrid rows finished loading; payload.data holds the collection.",
              "event": "CalendarGridLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CalendarGridItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CalendarGridItem",
          "name": "CalendarGridRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "CalendarGrid rows finished loading; payload.data holds the collection.",
                "key": "CalendarGridLoaded",
                "name": "Calendar grid loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CalendarGridItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "Called when a time slot is clicked",
                "key": "SLOT_CLICK",
                "name": "Slot Click",
                "payloadSchema": [
                  {
                    "name": "day",
                    "type": "date"
                  },
                  {
                    "name": "time",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when a day header is clicked",
                "key": "DAY_CLICK",
                "name": "Day Click",
                "payloadSchema": [
                  {
                    "name": "day",
                    "type": "date"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when an event is clicked",
                "key": "EVENT_CLICK",
                "name": "Event Click",
                "payloadSchema": [
                  {
                    "name": "event",
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
                "key": "LONG_PRESS",
                "name": "Long Press",
                "payloadSchema": [
                  {
                    "name": "date",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "time",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
                "key": "SWIPE_LEFT",
                "name": "Swipe Left",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
                "key": "SWIPE_RIGHT",
                "name": "Swipe Right",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "CalendarGridItem",
                    {
                      "emit": {
                        "success": "CalendarGridLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "dayWindow": "@config.dayWindow",
                      "events": "@entity",
                      "longPressEvent": "LONG_PRESS",
                      "longPressPayload": "@config.longPressPayload",
                      "onDayClick": "DAY_CLICK",
                      "onEventClick": "EVENT_CLICK",
                      "onSlotClick": "SLOT_CLICK",
                      "swipeLeftEvent": "SWIPE_LEFT",
                      "swipeRightEvent": "SWIPE_RIGHT",
                      "timeSlots": "@config.timeSlots",
                      "type": "calendar-grid",
                      "weekStart": "@config.weekStart"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "dayWindow": "@config.dayWindow",
                      "events": "@payload.data",
                      "longPressEvent": "LONG_PRESS",
                      "longPressPayload": "@config.longPressPayload",
                      "onDayClick": "DAY_CLICK",
                      "onEventClick": "EVENT_CLICK",
                      "onSlotClick": "SLOT_CLICK",
                      "swipeLeftEvent": "SWIPE_LEFT",
                      "swipeRightEvent": "SWIPE_RIGHT",
                      "timeSlots": "@config.timeSlots",
                      "type": "calendar-grid",
                      "weekStart": "@config.weekStart"
                    }
                  ]
                ],
                "event": "CalendarGridLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}