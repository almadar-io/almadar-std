{
  "name": "ui-data-list",
  "version": "1.0.0",
  "description": "DataList — UI factory (1:1 with the @almadar/ui data-list pattern).",
  "orbitals": [
    {
      "name": "DataListOrbital",
      "entity": {
        "name": "DataListItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DataListRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DataListItem",
          "emits": [
            {
              "event": "REORDER",
              "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ITEM_CLICK",
              "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SWIPE_LEFT",
              "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SWIPE_RIGHT",
              "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LONG_PRESS",
              "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LOAD_MORE",
              "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REORDER",
                "name": "Reorder",
                "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ITEM_CLICK",
                "name": "Item Click",
                "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SWIPE_LEFT",
                "name": "Swipe Left",
                "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SWIPE_RIGHT",
                "name": "Swipe Right",
                "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LONG_PRESS",
                "name": "Long Press",
                "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LOAD_MORE",
                "name": "Load More",
                "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DataListItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "fields": "@config.fields",
                      "dndRoot": "@config.dndRoot",
                      "pageSize": "@config.pageSize",
                      "loadMoreEvent": "LOAD_MORE",
                      "entity": "@entity",
                      "swipeRightEvent": "SWIPE_RIGHT",
                      "itemClickEvent": "ITEM_CLICK",
                      "accepts": "@config.accepts",
                      "groupBy": "@config.groupBy",
                      "className": "@config.className",
                      "maxInlineActions": "@config.maxInlineActions",
                      "infiniteScroll": "@config.infiniteScroll",
                      "hasMore": "@config.hasMore",
                      "look": "@config.look",
                      "senderField": "@config.senderField",
                      "longPressEvent": "LONG_PRESS",
                      "variant": "@config.variant",
                      "dndItemIdField": "@config.dndItemIdField",
                      "positionEvent": "@config.positionEvent",
                      "swipeLeftEvent": "SWIPE_LEFT",
                      "swipeRightActions": "@config.swipeRightActions",
                      "reorderable": "@config.reorderable",
                      "gap": "@config.gap",
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW"
                        }
                      ],
                      "dropEvent": "@config.dropEvent",
                      "currentUser": "@config.currentUser",
                      "sortable": "@config.sortable",
                      "columns": "@config.columns",
                      "error": "@config.error",
                      "swipeLeftActions": "@config.swipeLeftActions",
                      "isLoading": "@config.isLoading",
                      "dragGroup": "@config.dragGroup",
                      "reorderEvent": "REORDER",
                      "type": "data-list"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "reorderable": {
              "type": "boolean",
              "default": false,
              "label": "Reorderable",
              "description": "Enable drag-to-reorder with grip handles",
              "tier": "presentation"
            },
            "hasMore": {
              "type": "boolean",
              "default": false,
              "label": "Has More",
              "description": "Whether more items are available for infinite scroll",
              "tier": "presentation"
            },
            "swipeLeftActions": {
              "type": "[DataListSwipeLeftActionsItem]",
              "default": [
                {
                  "icon": "circle",
                  "variant": "primary",
                  "label": "Label"
                }
              ],
              "label": "Swipe Left Actions",
              "description": "Actions revealed on left swipe",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "swipeRightActions": {
              "type": "[DataListSwipeRightActionsItem]",
              "default": [
                {
                  "label": "Label",
                  "icon": "circle",
                  "variant": "primary"
                }
              ],
              "label": "Swipe Right Actions",
              "description": "Actions revealed on right swipe",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  }
                }
              }
            },
            "groupBy": {
              "type": "string",
              "default": "Group By",
              "label": "Group By",
              "description": "Group items by a field value (renders section headers between groups)",
              "tier": "presentation"
            },
            "dragGroup": {
              "type": "string",
              "default": "Drag Group",
              "label": "Drag Group",
              "description": "When set, items in this container are draggable and announce this group as their source",
              "tier": "presentation"
            },
            "positionEvent": {
              "type": "string",
              "default": "Position Event",
              "label": "Position Event",
              "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
              "tier": "presentation"
            },
            "columns": {
              "type": "[DataListColumnsItem]",
              "default": [
                {
                  "label": "Label",
                  "name": "Name",
                  "format": "date",
                  "variant": "h3",
                  "icon": "circle"
                }
              ],
              "label": "Columns",
              "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "dndRoot": {
              "type": "boolean",
              "default": false,
              "label": "Dnd Root",
              "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
              "tier": "presentation"
            },
            "accepts": {
              "type": "string",
              "default": "Accepts",
              "label": "Accepts",
              "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
              "tier": "presentation"
            },
            "fields": {
              "type": "[DataListFieldsItem]",
              "default": [
                {
                  "label": "Label",
                  "name": "Name",
                  "format": "date",
                  "icon": "circle",
                  "variant": "h3"
                }
              ],
              "label": "Fields",
              "description": "Field definitions for rendering each row. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[DataListItemActionsItem]",
              "default": [],
              "label": "Item Actions",
              "description": "Per-item action buttons",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  }
                }
              }
            },
            "gap": {
              "type": "string",
              "default": "none",
              "label": "Gap",
              "description": "Gap between rows",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg"
              ]
            },
            "error": {
              "type": "DataListError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                }
              }
            },
            "infiniteScroll": {
              "type": "boolean",
              "default": false,
              "label": "Infinite Scroll",
              "description": "Enable infinite scroll loading",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "dense",
              "label": "Look",
              "description": "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "dndItemIdField": {
              "type": "string",
              "default": "Dnd Item Id Field",
              "label": "Dnd Item Id Field",
              "description": "Row field used as the @dnd-kit draggable id (default 'id')",
              "tier": "presentation"
            },
            "senderField": {
              "type": "string",
              "default": "Sender Field",
              "label": "Sender Field",
              "description": "Field name identifying the sender (used with variant: 'message')",
              "tier": "presentation"
            },
            "maxInlineActions": {
              "type": "number",
              "default": 0.0,
              "label": "Max Inline Actions",
              "description": "Max inline action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
              "tier": "presentation"
            },
            "sortable": {
              "type": "boolean",
              "default": false,
              "label": "Sortable",
              "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
              "tier": "presentation"
            },
            "currentUser": {
              "type": "string",
              "default": "Current User",
              "label": "Current User",
              "description": "Current user identifier; messages matching this value align right (used with variant: 'message')",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Visual variant",
              "tier": "presentation",
              "values": [
                "default",
                "card",
                "compact",
                "message"
              ]
            },
            "pageSize": {
              "type": "number",
              "default": 5.0,
              "label": "Page Size",
              "description": "Max items to show before 'Show More' button. Defaults to 5. Set to 0 to disable.",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "dropEvent": {
              "type": "string",
              "default": "Drop Event",
              "label": "Drop Event",
              "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DataListPage",
          "path": "/data-list",
          "traits": [
            {
              "ref": "DataListRender"
            }
          ]
        }
      ]
    }
  ]
}