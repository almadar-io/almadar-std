{
  "description": "DataList — UI factory (1:1 with the @almadar/ui data-list pattern).",
  "name": "ui-data-list",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DataListItem",
        "persistence": "runtime"
      },
      "name": "DataListOrbital",
      "pages": [
        {
          "name": "DataListPage",
          "path": "/data-list",
          "traits": [
            {
              "ref": "DataListRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "accepts": {
              "default": "Accepts",
              "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
              "label": "Accepts",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "columns": {
              "default": [
                {
                  "format": "date",
                  "icon": "circle",
                  "label": "Label",
                  "name": "Name",
                  "variant": "h3"
                },
                {
                  "format": "currency",
                  "icon": "circle",
                  "label": "Label 2",
                  "name": "Name 2",
                  "variant": "h4"
                }
              ],
              "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
              "items": {
                "properties": {
                  "format": {
                    "name": "format",
                    "required": false,
                    "type": "string",
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Columns",
              "tier": "presentation",
              "type": "[DataListColumnsItem]"
            },
            "currentUser": {
              "default": "Current User",
              "description": "Current user identifier; messages matching this value align right (used with variant: 'message')",
              "label": "Current User",
              "tier": "presentation",
              "type": "string"
            },
            "dndItemIdField": {
              "default": "Dnd Item Id Field",
              "description": "Row field used as the @dnd-kit draggable id (default 'id')",
              "label": "Dnd Item Id Field",
              "tier": "presentation",
              "type": "string"
            },
            "dndRoot": {
              "default": false,
              "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
              "label": "Dnd Root",
              "tier": "presentation",
              "type": "boolean"
            },
            "dragGroup": {
              "default": "Drag Group",
              "description": "When set, items in this container are draggable and announce this group as their source",
              "label": "Drag Group",
              "tier": "presentation",
              "type": "string"
            },
            "dropEvent": {
              "default": "Drop Event",
              "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
              "label": "Drop Event",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "DataListError"
            },
            "fields": {
              "default": [
                {
                  "format": "date",
                  "icon": "circle",
                  "label": "Label",
                  "name": "Name",
                  "variant": "h3"
                },
                {
                  "format": "currency",
                  "icon": "circle",
                  "label": "Label 2",
                  "name": "Name 2",
                  "variant": "h4"
                }
              ],
              "description": "Field definitions for rendering each row. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either.",
              "items": {
                "properties": {
                  "format": {
                    "name": "format",
                    "required": false,
                    "type": "string",
                    "values": [
                      "date",
                      "currency",
                      "number",
                      "boolean",
                      "percent"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "h3",
                      "h4",
                      "body",
                      "caption",
                      "badge",
                      "small",
                      "progress"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Fields",
              "tier": "presentation",
              "type": "[DataListFieldsItem]"
            },
            "gap": {
              "default": "none",
              "description": "Gap between rows",
              "label": "Gap",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "sm",
                "md",
                "lg"
              ]
            },
            "groupBy": {
              "default": "Group By",
              "description": "Group items by a field value (renders section headers between groups)",
              "label": "Group By",
              "tier": "presentation",
              "type": "string"
            },
            "hasMore": {
              "default": false,
              "description": "Whether more items are available for infinite scroll",
              "label": "Has More",
              "tier": "presentation",
              "type": "boolean"
            },
            "infiniteScroll": {
              "default": false,
              "description": "Enable infinite scroll loading",
              "label": "Infinite Scroll",
              "tier": "presentation",
              "type": "boolean"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "itemActions": {
              "default": [
                {
                  "event": "VIEW",
                  "label": "View",
                  "variant": "ghost"
                }
              ],
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  }
                },
                "type": "object"
              },
              "tier": "presentation",
              "type": "[DataListItemActionsItem]"
            },
            "itemClickEvent": {
              "default": "ITEM_CLICK",
              "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
              "label": "Item Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "loadMoreEvent": {
              "default": "LOAD_MORE",
              "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
              "label": "Load More Event",
              "tier": "presentation",
              "type": "string"
            },
            "longPressEvent": {
              "default": "LONG_PRESS",
              "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
              "label": "Long Press Event",
              "tier": "presentation",
              "type": "string"
            },
            "look": {
              "default": "dense",
              "description": "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors.",
              "label": "Look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "maxInlineActions": {
              "default": 0.0,
              "description": "Max inline action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
              "label": "Max Inline Actions",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 5.0,
              "description": "Max items to show before 'Show More' button. Defaults to 5. Set to 0 to disable.",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "positionEvent": {
              "default": "Position Event",
              "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
              "label": "Position Event",
              "tier": "presentation",
              "type": "string"
            },
            "reorderEvent": {
              "default": "REORDER",
              "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
              "label": "Reorder Event",
              "tier": "presentation",
              "type": "string"
            },
            "reorderable": {
              "default": false,
              "description": "Enable drag-to-reorder with grip handles",
              "label": "Reorderable",
              "tier": "presentation",
              "type": "boolean"
            },
            "senderField": {
              "default": "Sender Field",
              "description": "Field name identifying the sender (used with variant: 'message')",
              "label": "Sender Field",
              "tier": "presentation",
              "type": "string"
            },
            "sortable": {
              "default": false,
              "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
              "label": "Sortable",
              "tier": "presentation",
              "type": "boolean"
            },
            "swipeLeftActions": {
              "default": [
                {
                  "icon": "circle",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "icon": "circle",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Actions revealed on left swipe",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Swipe Left Actions",
              "tier": "presentation",
              "type": "[DataListSwipeLeftActionsItem]"
            },
            "swipeLeftEvent": {
              "default": "SWIPE_LEFT",
              "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
              "label": "Swipe Left Event",
              "tier": "presentation",
              "type": "string"
            },
            "swipeRightActions": {
              "default": [
                {
                  "icon": "circle",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "icon": "circle",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Actions revealed on right swipe",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Swipe Right Actions",
              "tier": "presentation",
              "type": "[DataListSwipeRightActionsItem]"
            },
            "swipeRightEvent": {
              "default": "SWIPE_RIGHT",
              "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
              "label": "Swipe Right Event",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "default",
              "description": "Visual variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "card",
                "compact",
                "message"
              ]
            }
          },
          "emits": [
            {
              "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
              "event": "REORDER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
              "event": "ITEM_CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
              "event": "SWIPE_LEFT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
              "event": "SWIPE_RIGHT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
              "event": "LONG_PRESS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
              "event": "LOAD_MORE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "User opened a record from the list.",
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "DataList rows finished loading; payload.data holds the collection.",
              "event": "DataListLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DataListItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DataListItem",
          "name": "DataListRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "DataList rows finished loading; payload.data holds the collection.",
                "key": "DataListLoaded",
                "name": "Data list loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DataListItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "User opened a record from the list.",
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
                "key": "REORDER",
                "name": "Reorder",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
                "key": "ITEM_CLICK",
                "name": "Item Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
                "key": "SWIPE_LEFT",
                "name": "Swipe Left",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
                "key": "SWIPE_RIGHT",
                "name": "Swipe Right",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
                "key": "LONG_PRESS",
                "name": "Long Press",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                "key": "LOAD_MORE",
                "name": "Load More",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "DataListItem",
                    {
                      "emit": {
                        "success": "DataListLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "accepts": "@config.accepts",
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "currentUser": "@config.currentUser",
                      "dndItemIdField": "@config.dndItemIdField",
                      "dndRoot": "@config.dndRoot",
                      "dragGroup": "@config.dragGroup",
                      "dropEvent": "@config.dropEvent",
                      "entity": "@entity",
                      "error": "@config.error",
                      "fields": "@config.fields",
                      "gap": "@config.gap",
                      "groupBy": "@config.groupBy",
                      "hasMore": "@config.hasMore",
                      "infiniteScroll": "@config.infiniteScroll",
                      "isLoading": "@config.isLoading",
                      "itemActions": "@config.itemActions",
                      "itemClickEvent": "@config.itemClickEvent",
                      "loadMoreEvent": "@config.loadMoreEvent",
                      "longPressEvent": "@config.longPressEvent",
                      "look": "@config.look",
                      "maxInlineActions": "@config.maxInlineActions",
                      "pageSize": "@config.pageSize",
                      "positionEvent": "@config.positionEvent",
                      "reorderEvent": "@config.reorderEvent",
                      "reorderable": "@config.reorderable",
                      "senderField": "@config.senderField",
                      "sortable": "@config.sortable",
                      "swipeLeftActions": "@config.swipeLeftActions",
                      "swipeLeftEvent": "@config.swipeLeftEvent",
                      "swipeRightActions": "@config.swipeRightActions",
                      "swipeRightEvent": "@config.swipeRightEvent",
                      "type": "data-list",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "accepts": "@config.accepts",
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "currentUser": "@config.currentUser",
                      "dndItemIdField": "@config.dndItemIdField",
                      "dndRoot": "@config.dndRoot",
                      "dragGroup": "@config.dragGroup",
                      "dropEvent": "@config.dropEvent",
                      "entity": "@payload.data",
                      "error": "@config.error",
                      "fields": "@config.fields",
                      "gap": "@config.gap",
                      "groupBy": "@config.groupBy",
                      "hasMore": "@config.hasMore",
                      "infiniteScroll": "@config.infiniteScroll",
                      "isLoading": "@config.isLoading",
                      "itemActions": "@config.itemActions",
                      "itemClickEvent": "@config.itemClickEvent",
                      "loadMoreEvent": "@config.loadMoreEvent",
                      "longPressEvent": "@config.longPressEvent",
                      "look": "@config.look",
                      "maxInlineActions": "@config.maxInlineActions",
                      "pageSize": "@config.pageSize",
                      "positionEvent": "@config.positionEvent",
                      "reorderEvent": "@config.reorderEvent",
                      "reorderable": "@config.reorderable",
                      "senderField": "@config.senderField",
                      "sortable": "@config.sortable",
                      "swipeLeftActions": "@config.swipeLeftActions",
                      "swipeLeftEvent": "@config.swipeLeftEvent",
                      "swipeRightActions": "@config.swipeRightActions",
                      "swipeRightEvent": "@config.swipeRightEvent",
                      "type": "data-list",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "DataListLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ],
                "event": "VIEW",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}