      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "description": "Drawer content (can be empty if using slot content)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "closeEvent": {
              "default": "CLOSE",
              "description": "Declarative close event — emits UI:{closeEvent} via eventBus when drawer should close",
              "label": "Close Event",
              "tier": "presentation",
              "type": "string"
            },
            "closeOnEscape": {
              "default": true,
              "description": "Close on escape key",
              "label": "Close On Escape",
              "tier": "presentation",
              "type": "boolean"
            },
            "closeOnOverlayClick": {
              "default": true,
              "description": "Close on overlay click",
              "label": "Close On Overlay Click",
              "tier": "presentation",
              "type": "boolean"
            },
            "footer": {
              "description": "Footer content",
              "label": "Footer",
              "tier": "presentation",
              "type": "node"
            },
            "isOpen": {
              "default": true,
              "description": "Whether the drawer is open (defaults to true when rendered by slot wrapper)",
              "label": "Is Open",
              "tier": "presentation",
              "type": "boolean"
            },
            "onClose": {
              "default": "CLOSE",
              "description": "Callback when drawer should close (injected by slot wrapper)",
              "label": "On Close",
              "tier": "presentation",
              "type": "string"
            },
            "position": {
              "default": "right",
              "description": "Position (left or right)",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "left",
                "right"
              ]
            },
            "showCloseButton": {
              "default": true,
              "description": "Show close button",
              "label": "Show Close Button",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "",
              "description": "Drawer title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "width": {
              "default": "md",
              "description": "Width (CSS value or preset size)",
              "label": "Width",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl",
                "full"
              ]
            }
          },
          "emits": [
            {
              "description": "Callback when drawer should close (injected by slot wrapper)",
              "event": "@config.onClose",
              "eventId": "evt_01KXG04NNQF8X136A5E4RS94BZ",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Open the Drawer.",
              "event": "OPEN",
              "eventId": "evt_01KXG04NNQK2S379CPWJ589XSG",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04NNM7QJHC934D0EDT8KC",
          "linkedEntity": "DrawerItem",
          "linkedEntityId": "ent_01KXG04NNMAZAMXP675RGX1PEW",
          "name": "DrawerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04NNMZVX8E6S0S49Z4FZQ",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Open the Drawer.",
                "id": "evt_01KXG04NNQK2S379CPWJ589XSG",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "id": "evt_01KXG04NNQMAR2GZF96Z86E0YV",
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "description": "Callback when drawer should close (injected by slot wrapper)",
                "id": "evt_01KXG04NNQF8X136A5E4RS94BZ",
                "key": "@config.onClose",
                "name": "@config.on close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Drawer",
                      "type": "button"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04NNMZVX8E6S0S49Z4FZQ",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "closeEvent": "@config.closeEvent",
                      "closeOnEscape": "@config.closeOnEscape",
                      "closeOnOverlayClick": "@config.closeOnOverlayClick",
                      "footer": "@config.footer",
                      "isOpen": "@config.isOpen",
                      "onClose": "@config.onClose",
                      "position": "@config.position",
                      "showCloseButton": "@config.showCloseButton",
                      "title": "@config.title",
                      "type": "drawer",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "OPEN",
                "eventId": "evt_01KXG04NNQK2S379CPWJ589XSG",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Drawer",
                      "type": "button"
                    }
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04NNQMAR2GZF96Z86E0YV",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
