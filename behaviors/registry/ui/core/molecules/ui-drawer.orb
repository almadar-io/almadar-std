{
  "name": "ui-drawer",
  "version": "1.0.0",
  "description": "Drawer — UI factory (1:1 with the @almadar/ui drawer pattern).",
  "orbitals": [
    {
      "name": "DrawerOrbital",
      "entity": {
        "name": "DrawerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DrawerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DrawerItem",
          "emits": [
            {
              "event": "CLOSE",
              "description": "Callback when drawer should close (injected by slot wrapper)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "description": "Callback when drawer should close (injected by slot wrapper)",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "width": "@config.width",
                      "onClose": "CLOSE",
                      "closeOnOverlayClick": "@config.closeOnOverlayClick",
                      "className": "@config.className",
                      "closeEvent": "CLOSE",
                      "showCloseButton": "@config.showCloseButton",
                      "children": "@config.children",
                      "closeOnEscape": "@config.closeOnEscape",
                      "type": "drawer",
                      "isOpen": "@config.isOpen",
                      "position": "@config.position",
                      "title": "@config.title",
                      "footer": "@config.footer"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "closeOnEscape": {
              "type": "boolean",
              "default": true,
              "label": "Close On Escape",
              "description": "Close on escape key",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Drawer content (can be empty if using slot content)",
              "tier": "presentation"
            },
            "closeOnOverlayClick": {
              "type": "boolean",
              "default": true,
              "label": "Close On Overlay Click",
              "description": "Close on overlay click",
              "tier": "presentation"
            },
            "width": {
              "type": "string",
              "default": "md",
              "label": "Width",
              "description": "Width (CSS value or preset size)",
              "tier": "presentation"
            },
            "showCloseButton": {
              "type": "boolean",
              "default": true,
              "label": "Show Close Button",
              "description": "Show close button",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class name",
              "tier": "presentation"
            },
            "footer": {
              "type": "node",
              "label": "Footer",
              "description": "Footer content",
              "tier": "presentation"
            },
            "position": {
              "type": "string",
              "default": "right",
              "label": "Position",
              "description": "Position (left or right)",
              "tier": "presentation",
              "values": [
                "left",
                "right"
              ]
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Drawer title",
              "tier": "presentation"
            },
            "isOpen": {
              "type": "boolean",
              "default": true,
              "label": "Is Open",
              "description": "Whether the drawer is open (defaults to true when rendered by slot wrapper)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DrawerPage",
          "path": "/drawer",
          "traits": [
            {
              "ref": "DrawerRender"
            }
          ]
        }
      ]
    }
  ]
}