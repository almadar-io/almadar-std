{
  "description": "WizardNavigation — UI factory (1:1 with the @almadar/ui wizard-navigation pattern).",
  "name": "ui-wizard-navigation",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "currentStep",
            "type": "number"
          },
          {
            "default": 1.0,
            "name": "totalSteps",
            "type": "number"
          }
        ],
        "name": "WizardNavigationItem",
        "persistence": "runtime"
      },
      "name": "WizardNavigationOrbital",
      "pages": [
        {
          "name": "WizardNavigationPage",
          "path": "/wizard-navigation",
          "traits": [
            {
              "ref": "WizardNavigationRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backLabel": {
              "default": "Back Label",
              "description": "Custom label for Back button",
              "label": "Back Label",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "compact": {
              "default": false,
              "description": "Compact mode (smaller padding)",
              "label": "Compact",
              "tier": "presentation",
              "type": "boolean"
            },
            "completeLabel": {
              "default": "Complete Label",
              "description": "Custom label for Complete button",
              "label": "Complete Label",
              "tier": "presentation",
              "type": "string"
            },
            "currentStep": {
              "default": 1.0,
              "description": "Current step index (0-based)",
              "label": "Current Step",
              "tier": "presentation",
              "type": "number"
            },
            "isValid": {
              "default": true,
              "description": "Whether the current step is valid (enables Next/Complete)",
              "label": "Is Valid",
              "tier": "presentation",
              "type": "boolean"
            },
            "nextLabel": {
              "default": "Next Label",
              "description": "Custom label for Next button",
              "label": "Next Label",
              "tier": "presentation",
              "type": "string"
            },
            "onBack": {
              "default": "BACK",
              "description": "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }",
              "label": "On Back",
              "tier": "presentation",
              "type": "string"
            },
            "onBackClick": {
              "default": "BACK_CLICK",
              "description": "Direct callback for Back (alternative to event)",
              "label": "On Back Click",
              "tier": "presentation",
              "type": "string"
            },
            "onComplete": {
              "default": "COMPLETE",
              "description": "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }",
              "label": "On Complete",
              "tier": "presentation",
              "type": "string"
            },
            "onCompleteClick": {
              "default": "COMPLETE_CLICK",
              "description": "Direct callback for Complete (alternative to event)",
              "label": "On Complete Click",
              "tier": "presentation",
              "type": "string"
            },
            "onNext": {
              "default": "NEXT",
              "description": "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }",
              "label": "On Next",
              "tier": "presentation",
              "type": "string"
            },
            "onNextClick": {
              "default": "NEXT_CLICK",
              "description": "Direct callback for Next (alternative to event)",
              "label": "On Next Click",
              "tier": "presentation",
              "type": "string"
            },
            "showBack": {
              "default": true,
              "description": "Show the Back button",
              "label": "Show Back",
              "tier": "presentation",
              "type": "boolean"
            },
            "showComplete": {
              "default": true,
              "description": "Show the Complete button (on last step)",
              "label": "Show Complete",
              "tier": "presentation",
              "type": "boolean"
            },
            "showNext": {
              "default": true,
              "description": "Show the Next button",
              "label": "Show Next",
              "tier": "presentation",
              "type": "boolean"
            },
            "totalSteps": {
              "default": 1.0,
              "description": "Total number of steps",
              "label": "Total Steps",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }",
              "event": "@config.onBack",
              "payloadSchema": [
                {
                  "name": "currentStep",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }",
              "event": "@config.onNext",
              "payloadSchema": [
                {
                  "name": "currentStep",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }",
              "event": "@config.onComplete",
              "payloadSchema": [
                {
                  "name": "currentStep",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Direct callback for Back (alternative to event)",
              "event": "@config.onBackClick",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Direct callback for Next (alternative to event)",
              "event": "@config.onNextClick",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Direct callback for Complete (alternative to event)",
              "event": "@config.onCompleteClick",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "currentStep",
              "totalSteps"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "WizardNavigationItem",
          "name": "WizardNavigationRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BACK",
                "name": "Back",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "NEXT",
                "name": "Next",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "description": "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }",
                "key": "@config.onBack",
                "name": "@config.on back",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }",
                "key": "@config.onNext",
                "name": "@config.on next",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }",
                "key": "@config.onComplete",
                "name": "@config.on complete",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Direct callback for Back (alternative to event)",
                "key": "@config.onBackClick",
                "name": "@config.on back click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Direct callback for Next (alternative to event)",
                "key": "@config.onNextClick",
                "name": "@config.on next click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Direct callback for Complete (alternative to event)",
                "key": "@config.onCompleteClick",
                "name": "@config.on complete click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "@config.currentStep"
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    "@config.totalSteps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backLabel": "@config.backLabel",
                      "className": "@config.className",
                      "compact": "@config.compact",
                      "completeLabel": "@config.completeLabel",
                      "currentStep": "@entity.currentStep",
                      "isValid": "@config.isValid",
                      "nextLabel": "@config.nextLabel",
                      "onBack": "@config.onBack",
                      "onBackClick": "@config.onBackClick",
                      "onComplete": "@config.onComplete",
                      "onCompleteClick": "@config.onCompleteClick",
                      "onNext": "@config.onNext",
                      "onNextClick": "@config.onNextClick",
                      "showBack": "@config.showBack",
                      "showComplete": "@config.showComplete",
                      "showNext": "@config.showNext",
                      "totalSteps": "@entity.totalSteps",
                      "type": "wizard-navigation"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "@payload.currentStep"
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    "@payload.totalSteps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backLabel": "@config.backLabel",
                      "className": "@config.className",
                      "compact": "@config.compact",
                      "completeLabel": "@config.completeLabel",
                      "currentStep": "@entity.currentStep",
                      "isValid": "@config.isValid",
                      "nextLabel": "@config.nextLabel",
                      "onBack": "@config.onBack",
                      "onBackClick": "@config.onBackClick",
                      "onComplete": "@config.onComplete",
                      "onCompleteClick": "@config.onCompleteClick",
                      "onNext": "@config.onNext",
                      "onNextClick": "@config.onNextClick",
                      "showBack": "@config.showBack",
                      "showComplete": "@config.showComplete",
                      "showNext": "@config.showNext",
                      "totalSteps": "@entity.totalSteps",
                      "type": "wizard-navigation"
                    }
                  ]
                ],
                "event": "BACK",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "@payload.currentStep"
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    "@payload.totalSteps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backLabel": "@config.backLabel",
                      "className": "@config.className",
                      "compact": "@config.compact",
                      "completeLabel": "@config.completeLabel",
                      "currentStep": "@entity.currentStep",
                      "isValid": "@config.isValid",
                      "nextLabel": "@config.nextLabel",
                      "onBack": "@config.onBack",
                      "onBackClick": "@config.onBackClick",
                      "onComplete": "@config.onComplete",
                      "onCompleteClick": "@config.onCompleteClick",
                      "onNext": "@config.onNext",
                      "onNextClick": "@config.onNextClick",
                      "showBack": "@config.showBack",
                      "showComplete": "@config.showComplete",
                      "showNext": "@config.showNext",
                      "totalSteps": "@entity.totalSteps",
                      "type": "wizard-navigation"
                    }
                  ]
                ],
                "event": "NEXT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "@payload.currentStep"
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    "@payload.totalSteps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backLabel": "@config.backLabel",
                      "className": "@config.className",
                      "compact": "@config.compact",
                      "completeLabel": "@config.completeLabel",
                      "currentStep": "@entity.currentStep",
                      "isValid": "@config.isValid",
                      "nextLabel": "@config.nextLabel",
                      "onBack": "@config.onBack",
                      "onBackClick": "@config.onBackClick",
                      "onComplete": "@config.onComplete",
                      "onCompleteClick": "@config.onCompleteClick",
                      "onNext": "@config.onNext",
                      "onNextClick": "@config.onNextClick",
                      "showBack": "@config.showBack",
                      "showComplete": "@config.showComplete",
                      "showNext": "@config.showNext",
                      "totalSteps": "@entity.totalSteps",
                      "type": "wizard-navigation"
                    }
                  ]
                ],
                "event": "COMPLETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}