{
  "description": "DateRangeSelector — UI factory (1:1 with the @almadar/ui date-range-selector pattern).",
  "name": "ui-date-range-selector",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DateRangeSelectorItem",
        "persistence": "runtime"
      },
      "name": "DateRangeSelectorOrbital",
      "pages": [
        {
          "name": "DateRangeSelectorPage",
          "path": "/date-range-selector",
          "traits": [
            {
              "ref": "DateRangeSelectorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "options": {
              "default": [
                {
                  "label": "Label",
                  "value": "Value"
                },
                {
                  "label": "Label 2",
                  "value": "Value 2"
                }
              ],
              "description": "Available range options",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Options",
              "tier": "presentation",
              "type": "[DateRangeSelectorOptionsItem]"
            },
            "selected": {
              "default": "month",
              "description": "Currently selected value",
              "label": "Selected",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when a range is selected",
              "event": "SELECT",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DateRangeSelectorItem",
          "name": "DateRangeSelectorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when a range is selected",
                "key": "SELECT",
                "name": "Select",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "onSelect": "SELECT",
                      "options": "@config.options",
                      "selected": "@config.selected",
                      "type": "date-range-selector"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}