{
  "name": "ui-date-range-selector",
  "version": "1.0.0",
  "description": "DateRangeSelector — UI factory (1:1 with the @almadar/ui date-range-selector pattern).",
  "orbitals": [
    {
      "name": "DateRangeSelectorOrbital",
      "entity": {
        "name": "DateRangeSelectorItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DateRangeSelectorRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DateRangeSelectorItem",
          "emits": [
            {
              "event": "SELECT",
              "description": "Callback when a range is selected",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "description": "Callback when a range is selected",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "selected": "@config.selected",
                      "options": "@config.options",
                      "type": "date-range-selector",
                      "onSelect": "SELECT"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "selected": {
              "type": "string",
              "default": "month",
              "label": "Selected",
              "description": "Currently selected value",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "options": {
              "type": "[DateRangeSelectorOptionsItem]",
              "default": [],
              "label": "Options",
              "description": "Available range options",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DateRangeSelectorPage",
          "path": "/date-range-selector",
          "traits": [
            {
              "ref": "DateRangeSelectorRender"
            }
          ]
        }
      ]
    }
  ]
}
