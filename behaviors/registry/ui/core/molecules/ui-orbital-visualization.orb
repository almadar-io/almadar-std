{
  "name": "ui-orbital-visualization",
  "version": "1.0.0",
  "description": "OrbitalVisualization — UI factory (1:1 with the @almadar/ui orbital-visualization pattern).",
  "orbitals": [
    {
      "name": "OrbitalVisualizationOrbital",
      "entity": {
        "name": "OrbitalVisualizationItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "OrbitalVisualizationRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "OrbitalVisualizationItem",
          "emits": [
            {
              "event": "CLICK",
              "description": "Click handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Click handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OrbitalVisualizationItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showLabel": "@config.showLabel",
                      "schema": "@config.schema",
                      "isLoading": "@config.isLoading",
                      "entity": "OrbitalVisualizationItem",
                      "className": "@config.className",
                      "size": "@config.size",
                      "error": "@config.error",
                      "type": "orbital-visualization",
                      "animated": "@config.animated",
                      "onClick": "CLICK",
                      "complexity": "@config.complexity"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size of the visualization",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "showLabel": {
              "type": "boolean",
              "default": true,
              "label": "Show Label",
              "description": "Show complexity label",
              "tier": "presentation"
            },
            "complexity": {
              "type": "number",
              "default": 0.0,
              "label": "Complexity",
              "description": "Direct complexity override (1-100+)",
              "tier": "presentation"
            },
            "animated": {
              "type": "boolean",
              "default": true,
              "label": "Animated",
              "description": "Animation enabled",
              "tier": "presentation"
            },
            "error": {
              "type": "OrbitalVisualizationError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "schema": {
              "type": "OrbitalVisualizationSchema",
              "label": "Schema",
              "description": "Full KFlow schema object",
              "tier": "presentation",
              "properties": {
                "ui": {
                  "name": "ui",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "pages": {
                      "name": "pages",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "object",
                        "properties": {
                          "sections": {
                            "name": "sections",
                            "type": "array",
                            "required": false,
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "dataEntities": {
                  "name": "dataEntities",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                },
                "traits": {
                  "name": "traits",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "OrbitalVisualizationPage",
          "path": "/orbital-visualization",
          "traits": [
            {
              "ref": "OrbitalVisualizationRender"
            }
          ]
        }
      ]
    }
  ]
}