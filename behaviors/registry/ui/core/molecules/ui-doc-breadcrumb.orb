{
  "name": "ui-doc-breadcrumb",
  "version": "1.0.0",
  "description": "DocBreadcrumb — UI factory (1:1 with the @almadar/ui doc-breadcrumb pattern).",
  "orbitals": [
    {
      "name": "DocBreadcrumbOrbital",
      "entity": {
        "name": "DocBreadcrumbItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DocBreadcrumbRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DocBreadcrumbItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "doc-breadcrumb",
                      "className": "@config.className",
                      "items": "@config.items"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "items": {
              "type": "[DocBreadcrumbItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Breadcrumb path items, last item is treated as current page",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DocBreadcrumbPage",
          "path": "/doc-breadcrumb",
          "traits": [
            {
              "ref": "DocBreadcrumbRender"
            }
          ]
        }
      ]
    }
  ]
}