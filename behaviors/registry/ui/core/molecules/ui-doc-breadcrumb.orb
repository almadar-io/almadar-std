{
  "description": "DocBreadcrumb — UI factory (1:1 with the @almadar/ui doc-breadcrumb pattern).",
  "name": "ui-doc-breadcrumb",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DocBreadcrumbItem",
        "persistence": "runtime"
      },
      "name": "DocBreadcrumbOrbital",
      "pages": [
        {
          "name": "DocBreadcrumbPage",
          "path": "/doc-breadcrumb",
          "traits": [
            {
              "ref": "DocBreadcrumbRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "href": "Href",
                  "label": "Label"
                },
                {
                  "href": "Href 2",
                  "label": "Label 2"
                }
              ],
              "description": "Breadcrumb path items, last item is treated as current page",
              "items": {
                "properties": {
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[DocBreadcrumbItemsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DocBreadcrumbItem",
          "name": "DocBreadcrumbRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "items": "@config.items",
                      "type": "doc-breadcrumb"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}