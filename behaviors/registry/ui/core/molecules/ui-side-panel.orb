{
  "description": "SidePanel — UI factory (1:1 with the @almadar/ui side-panel pattern).",
  "name": "ui-side-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SidePanelItem",
        "persistence": "runtime"
      },
      "name": "SidePanelOrbital",
      "pages": [
        {
          "name": "SidePanelPage",
          "path": "/side-panel",
          "traits": [
            {
              "ref": "SidePanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Panel content",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "isOpen": {
              "default": false,
              "description": "Is panel open",
              "label": "Is Open",
              "tier": "presentation",
              "type": "boolean"
            },
            "position": {
              "default": "right",
              "description": "Panel position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "left",
                "right"
              ]
            },
            "showOverlay": {
              "default": true,
              "description": "Show overlay on mobile",
              "label": "Show Overlay",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Title",
              "description": "Panel title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "width": {
              "default": "w-full sm:w-96",
              "description": "Panel width as Tailwind class string. Default fills the viewport on mobile and snaps to `w-96` (384 px) at `sm:` and above so phones don't lose content to a fixed 384 px column. Consumers passing a custom value should include a `w-full` mobile fallback in the same string (e.g. `'w-full sm:w-[480px]'`) — Tailwind's JIT can't see dynamically-concatenated class names.",
              "label": "Width",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "On close handler",
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Open the Side-panel.",
              "event": "OPEN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SidePanelItem",
          "name": "SidePanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Open the Side-panel.",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "On close handler",
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Side-panel",
                      "type": "button"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "closeEvent": "CLOSE",
                      "isOpen": "@config.isOpen",
                      "onClose": "CLOSE",
                      "position": "@config.position",
                      "showOverlay": "@config.showOverlay",
                      "title": "@config.title",
                      "type": "side-panel",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "OPEN",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Side-panel",
                      "type": "button"
                    }
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}