{
  "name": "ui-side-panel",
  "version": "1.0.0",
  "description": "SidePanel — UI factory (1:1 with the @almadar/ui side-panel pattern).",
  "orbitals": [
    {
      "name": "SidePanelOrbital",
      "entity": {
        "name": "SidePanelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SidePanelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SidePanelItem",
          "emits": [
            {
              "event": "CLOSE",
              "description": "On close handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "description": "On close handler",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showOverlay": "@config.showOverlay",
                      "width": "@config.width",
                      "type": "side-panel",
                      "onClose": "CLOSE",
                      "children": "@config.children",
                      "className": "@config.className",
                      "title": "@config.title",
                      "isOpen": "@config.isOpen",
                      "closeEvent": "CLOSE",
                      "position": "@config.position"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "position": {
              "type": "string",
              "default": "right",
              "label": "Position",
              "description": "Panel position",
              "tier": "presentation",
              "values": [
                "left",
                "right"
              ]
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Panel content",
              "tier": "presentation"
            },
            "isOpen": {
              "type": "boolean",
              "default": false,
              "label": "Is Open",
              "description": "Is panel open",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Panel title",
              "tier": "presentation"
            },
            "width": {
              "type": "string",
              "default": "w-full sm:w-96",
              "label": "Width",
              "description": "Panel width as Tailwind class string. Default fills the viewport on mobile and snaps to `w-96` (384 px) at `sm:` and above so phones don't lose content to a fixed 384 px column. Consumers passing a custom value should include a `w-full` mobile fallback in the same string (e.g. `'w-full sm:w-[480px]'`) — Tailwind's JIT can't see dynamically-concatenated class names.",
              "tier": "presentation"
            },
            "showOverlay": {
              "type": "boolean",
              "default": true,
              "label": "Show Overlay",
              "description": "Show overlay on mobile",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SidePanelPage",
          "path": "/side-panel",
          "traits": [
            {
              "ref": "SidePanelRender"
            }
          ]
        }
      ]
    }
  ]
}