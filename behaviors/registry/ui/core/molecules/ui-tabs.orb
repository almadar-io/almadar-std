          "emits": [
            {
              "description": "Callback when tab changes",
              "event": "TAB_CHANGE",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TabsItem",
          "name": "TabsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when tab changes",
                "key": "TAB_CHANGE",
                "name": "Tab Change",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeTab": "@config.activeTab",
                      "className": "@config.className",
                      "defaultActiveTab": "@config.defaultActiveTab",
                      "items": "@config.items",
                      "onTabChange": "@config.onTabChange",
                      "orientation": "@config.orientation",
                      "tabChangeEvent": "@config.tabChangeEvent",
                      "tabs": "@config.tabs",
                      "type": "tabs",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}