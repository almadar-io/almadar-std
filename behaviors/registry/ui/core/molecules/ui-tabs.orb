{
  "name": "ui-tabs",
  "version": "1.0.0",
  "description": "Tabs — UI factory (1:1 with the @almadar/ui tabs pattern).",
  "orbitals": [
    {
      "name": "TabsOrbital",
      "entity": {
        "name": "TabsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TabsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TabsItem",
          "emits": [
            {
              "event": "TAB_CHANGE",
              "description": "Callback when tab changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TAB_CHANGE",
                "name": "Tab Change",
                "description": "Callback when tab changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "defaultActiveTab": "@config.defaultActiveTab",
                      "orientation": "@config.orientation",
                      "onTabChange": "TAB_CHANGE",
                      "tabChangeEvent": "TAB_CHANGE",
                      "className": "@config.className",
                      "activeTab": "@config.activeTab",
                      "type": "tabs",
                      "tabs": "@config.tabs",
                      "variant": "@config.variant",
                      "items": "@config.items"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Tab variant",
              "tier": "presentation",
              "values": [
                "default",
                "pills",
                "underline"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "tabs": {
              "type": "[TabsTabsItem]",
              "default": [
                {
                  "label": "Label",
                  "value": "Value",
                  "badge": "Badge",
                  "active": false,
                  "content": "Content",
                  "id": "Id",
                  "disabled": false,
                  "icon": "circle"
                }
              ],
              "label": "Tabs",
              "description": "Tab items (alias for items - used by generated code)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": false
                  },
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "active": {
                    "name": "active",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            },
            "defaultActiveTab": {
              "type": "string",
              "default": "Default Active Tab",
              "label": "Default Active Tab",
              "description": "Default active tab ID",
              "tier": "presentation"
            },
            "items": {
              "type": "[TabsItemsItem]",
              "default": [
                {
                  "value": "Value",
                  "active": false,
                  "content": "Content",
                  "label": "Label",
                  "icon": "circle",
                  "badge": "Badge",
                  "disabled": false,
                  "id": "Id"
                }
              ],
              "label": "Items",
              "description": "Tab items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": false
                  },
                  "active": {
                    "name": "active",
                    "type": "boolean",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "Tab orientation",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "activeTab": {
              "type": "string",
              "default": "Active Tab",
              "label": "Active Tab",
              "description": "Controlled active tab ID",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TabsPage",
          "path": "/tabs",
          "traits": [
            {
              "ref": "TabsRender"
            }
          ]
        }
      ]
    }
  ]
}