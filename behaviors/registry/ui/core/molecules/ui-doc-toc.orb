{
  "description": "DocToc — UI factory (1:1 with the @almadar/ui doc-toc pattern).",
  "name": "ui-doc-toc",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DocTocItem",
        "persistence": "runtime"
      },
      "name": "DocTocOrbital",
      "pages": [
        {
          "name": "DocTocPage",
          "path": "/doc-toc",
          "traits": [
            {
              "ref": "DocTocRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeId": {
              "default": "Active Id",
              "description": "Currently active section id",
              "label": "Active Id",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "id": "Id",
                  "label": "Label",
                  "level": 1.0
                }
              ],
              "description": "Table of contents items",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "level": {
                    "name": "level",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[DocTocItemsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DocTocItem",
          "name": "DocTocRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeId": "@config.activeId",
                      "className": "@config.className",
                      "items": "@config.items",
                      "type": "doc-toc"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}