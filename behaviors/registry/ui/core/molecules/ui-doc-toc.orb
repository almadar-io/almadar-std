{
  "name": "ui-doc-toc",
  "version": "1.0.0",
  "description": "DocToc — UI factory (1:1 with the @almadar/ui doc-toc pattern).",
  "orbitals": [
    {
      "name": "DocTocOrbital",
      "entity": {
        "name": "DocTocItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DocTocRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DocTocItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "type": "doc-toc",
                      "items": "@config.items",
                      "activeId": "@config.activeId"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "activeId": {
              "type": "string",
              "default": "Active Id",
              "label": "Active Id",
              "description": "Currently active section id",
              "tier": "presentation"
            },
            "items": {
              "type": "[DocTocItemsItem]",
              "default": [
                {
                  "level": 1.0,
                  "id": "Id",
                  "label": "Label"
                }
              ],
              "label": "Items",
              "description": "Table of contents items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "level": {
                    "name": "level",
                    "type": "number",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DocTocPage",
          "path": "/doc-toc",
          "traits": [
            {
              "ref": "DocTocRender"
            }
          ]
        }
      ]
    }
  ]
}