{
  "name": "ui-meter",
  "version": "1.0.0",
  "description": "Meter — UI factory (1:1 with the @almadar/ui meter pattern).",
  "orbitals": [
    {
      "name": "MeterOrbital",
      "entity": {
        "name": "MeterItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MeterRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MeterItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "unit": "@config.unit",
                      "thresholds": "@config.thresholds",
                      "actions": "@config.actions",
                      "className": "@config.className",
                      "label": "@config.label",
                      "showValue": "@config.showValue",
                      "size": "@config.size",
                      "value": "@config.value",
                      "segments": "@config.segments",
                      "max": "@config.max",
                      "type": "meter",
                      "error": "@config.error",
                      "variant": "@config.variant",
                      "isLoading": "@config.isLoading",
                      "min": "@config.min"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "unit": {
              "type": "string",
              "default": "Unit",
              "label": "Unit",
              "description": "Unit suffix (e.g., '%', 'MB', 'credits')",
              "tier": "presentation"
            },
            "segments": {
              "type": "number",
              "default": 5.0,
              "label": "Segments",
              "description": "Number of segments (for segmented variant)",
              "tier": "presentation"
            },
            "max": {
              "type": "number",
              "default": 100.0,
              "label": "Max",
              "description": "Maximum value",
              "tier": "presentation"
            },
            "min": {
              "type": "number",
              "default": 0.0,
              "label": "Min",
              "description": "Minimum value",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Display label",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "linear",
              "label": "Variant",
              "description": "Display variant",
              "tier": "presentation",
              "values": [
                "linear",
                "radial",
                "segmented"
              ]
            },
            "thresholds": {
              "type": "[MeterThresholdsItem]",
              "default": [
                {
                  "value": 1.0,
                  "color": "Color",
                  "label": "Label"
                }
              ],
              "label": "Thresholds",
              "description": "Color thresholds",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "number",
                    "required": true
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "actions": {
              "type": "[MeterActionsItem]",
              "default": [
                {
                  "navigatesTo": "Navigates To",
                  "label": "Label",
                  "variant": "primary"
                }
              ],
              "label": "Actions",
              "description": "Actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "value": {
              "type": "number",
              "default": 0.0,
              "label": "Value",
              "description": "Current value",
              "tier": "presentation"
            },
            "showValue": {
              "type": "boolean",
              "default": true,
              "label": "Show Value",
              "description": "Show value text",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size (for radial variant)",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "error": {
              "type": "MeterError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MeterPage",
          "path": "/meter",
          "traits": [
            {
              "ref": "MeterRender"
            }
          ]
        }
      ]
    }
  ]
}