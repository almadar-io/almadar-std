              "refId": "trt_01KXG04PR0HWQ8QD87BJTZY18N"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "areaColor": {
              "default": "var(--color-primary)",
              "description": "Area fill color (used for gradient)",
              "label": "Area Color",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "data": {
              "default": [
                {
                  "date": "2024-01-01",
                  "label": "Label",
                  "value": 1.0
                },
                {
                  "date": "2024-01-01",
                  "label": "Label 2",
                  "value": 2.0
                }
              ],
              "description": "Data points to plot",
              "items": {
                "properties": {
                  "date": {
                    "name": "date",
                    "required": false,
                    "type": "date"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Data",
              "tier": "presentation",
              "type": "[LineChartDataItem]"
            },
            "height": {
              "default": 200.0,
              "description": "SVG viewBox height",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "lineColor": {
              "default": "var(--color-primary)",
              "description": "Line stroke color",
              "label": "Line Color",
              "tier": "presentation",
              "type": "string"
            },
            "showArea": {
              "default": true,
              "description": "Fill area under line with gradient",
              "label": "Show Area",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": true,
              "description": "Show horizontal grid lines at 25/50/75%",
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "showValues": {
              "default": false,
              "description": "Show value labels near data points",
              "label": "Show Values",
              "tier": "presentation",
              "type": "boolean"
            },
            "width": {
              "default": 400.0,
              "description": "SVG viewBox width",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
