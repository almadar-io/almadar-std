{
  "name": "ui-line-chart",
  "version": "1.0.0",
  "description": "LineChart — UI factory (1:1 with the @almadar/ui line-chart pattern).",
  "orbitals": [
    {
      "name": "LineChartOrbital",
      "entity": {
        "name": "LineChartItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "LineChartRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "LineChartItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "showArea": "@config.showArea",
                      "areaColor": "@config.areaColor",
                      "width": "@config.width",
                      "showGrid": "@config.showGrid",
                      "showValues": "@config.showValues",
                      "type": "line-chart",
                      "lineColor": "@config.lineColor",
                      "data": "@config.data",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "data": {
              "type": "[LineChartDataItem]",
              "default": [
                {
                  "date": "Date",
                  "value": 1.0
                }
              ],
              "label": "Data",
              "description": "Data points to plot",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "date": {
                    "name": "date",
                    "type": "date",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "number",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "showArea": {
              "type": "boolean",
              "default": true,
              "label": "Show Area",
              "description": "Fill area under line with gradient",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 200.0,
              "label": "Height",
              "description": "SVG viewBox height",
              "tier": "presentation"
            },
            "showGrid": {
              "type": "boolean",
              "default": true,
              "label": "Show Grid",
              "description": "Show horizontal grid lines at 25/50/75%",
              "tier": "presentation"
            },
            "lineColor": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Line Color",
              "description": "Line stroke color",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 400.0,
              "label": "Width",
              "description": "SVG viewBox width",
              "tier": "presentation"
            },
            "showValues": {
              "type": "boolean",
              "default": false,
              "label": "Show Values",
              "description": "Show value labels near data points",
              "tier": "presentation"
            },
            "areaColor": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Area Color",
              "description": "Area fill color (used for gradient)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LineChartPage",
          "path": "/line-chart",
          "traits": [
            {
              "ref": "LineChartRender"
            }
          ]
        }
      ]
    }
  ]
}
