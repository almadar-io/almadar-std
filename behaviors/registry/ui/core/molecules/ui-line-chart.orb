          "name": "LineChartRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "areaColor": "@config.areaColor",
                      "className": "@config.className",
                      "data": "@config.data",
                      "height": "@config.height",
                      "lineColor": "@config.lineColor",
                      "showArea": "@config.showArea",
                      "showGrid": "@config.showGrid",
                      "showValues": "@config.showValues",
                      "type": "line-chart",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
