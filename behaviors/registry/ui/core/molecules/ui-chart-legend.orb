{
  "name": "ui-chart-legend",
  "version": "1.0.0",
  "description": "ChartLegend — UI factory (1:1 with the @almadar/ui chart-legend pattern).",
  "orbitals": [
    {
      "name": "ChartLegendOrbital",
      "entity": {
        "name": "ChartLegendItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ChartLegendRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ChartLegendItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "@config.direction",
                      "type": "chart-legend",
                      "className": "@config.className",
                      "items": "@config.items"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[ChartLegendItemsItem]",
              "default": [
                {
                  "color": "Color",
                  "label": "Label"
                }
              ],
              "label": "Items",
              "description": "Legend items with label and color",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "direction": {
              "type": "string",
              "default": "horizontal",
              "label": "Direction",
              "description": "Layout direction",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ChartLegendPage",
          "path": "/chart-legend",
          "traits": [
            {
              "ref": "ChartLegendRender"
            }
          ]
        }
      ]
    }
  ]
}