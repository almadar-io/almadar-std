{
  "description": "ChartLegend — UI factory (1:1 with the @almadar/ui chart-legend pattern).",
  "name": "ui-chart-legend",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ChartLegendItem",
        "persistence": "runtime"
      },
      "name": "ChartLegendOrbital",
      "pages": [
        {
          "name": "ChartLegendPage",
          "path": "/chart-legend",
          "traits": [
            {
              "ref": "ChartLegendRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "direction": {
              "default": "horizontal",
              "description": "Layout direction",
              "label": "Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "items": {
              "default": [
                {
                  "color": "Color",
                  "label": "Label"
                },
                {
                  "color": "Color 2",
                  "label": "Label 2"
                }
              ],
              "description": "Legend items with label and color",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[ChartLegendItemsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ChartLegendItem",
          "name": "ChartLegendRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "direction": "@config.direction",
                      "items": "@config.items",
                      "type": "chart-legend"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}