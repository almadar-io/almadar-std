{
  "description": "InputGroup — UI factory (1:1 with the @almadar/ui input-group pattern).",
  "name": "ui-input-group",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "InputGroupItem",
        "persistence": "runtime"
      },
      "name": "InputGroupOrbital",
      "pages": [
        {
          "name": "InputGroupPage",
          "path": "/input-group",
          "traits": [
            {
              "ref": "InputGroupRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "leftAddon": {
              "description": "Left addon (icon, button, or text)",
              "label": "Left Addon",
              "tier": "presentation",
              "type": "node"
            },
            "rightAddon": {
              "description": "Right addon (icon, button, or text)",
              "label": "Right Addon",
              "tier": "presentation",
              "type": "node"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "InputGroupItem",
          "name": "InputGroupRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "leftAddon": "@config.leftAddon",
                      "rightAddon": "@config.rightAddon",
                      "type": "input-group"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}