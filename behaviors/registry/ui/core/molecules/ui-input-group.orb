{
  "name": "ui-input-group",
  "version": "1.0.0",
  "description": "InputGroup — UI factory (1:1 with the @almadar/ui input-group pattern).",
  "orbitals": [
    {
      "name": "InputGroupOrbital",
      "entity": {
        "name": "InputGroupItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "InputGroupRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "InputGroupItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "leftAddon": "@config.leftAddon",
                      "type": "input-group",
                      "rightAddon": "@config.rightAddon",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "rightAddon": {
              "type": "node",
              "label": "Right Addon",
              "description": "Right addon (icon, button, or text)",
              "tier": "presentation"
            },
            "leftAddon": {
              "type": "node",
              "label": "Left Addon",
              "description": "Left addon (icon, button, or text)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InputGroupPage",
          "path": "/input-group",
          "traits": [
            {
              "ref": "InputGroupRender"
            }
          ]
        }
      ]
    }
  ]
}