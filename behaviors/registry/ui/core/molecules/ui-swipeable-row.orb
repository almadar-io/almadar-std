{
  "name": "ui-swipeable-row",
  "version": "1.0.0",
  "description": "SwipeableRow — UI factory (1:1 with the @almadar/ui swipeable-row pattern).",
  "orbitals": [
    {
      "name": "SwipeableRowOrbital",
      "entity": {
        "name": "SwipeableRowItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SwipeableRowRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SwipeableRowItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "threshold": "@config.threshold",
                      "leftActions": "@config.leftActions",
                      "className": "@config.className",
                      "type": "swipeable-row",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sample content"
                        }
                      ],
                      "itemData": "@config.itemData",
                      "rightActions": "@config.rightActions"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "leftActions": {
              "type": "[SwipeableRowLeftActionsItem]",
              "default": [],
              "label": "Left Actions",
              "description": "leftActions prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  },
                  "eventPayload": {
                    "name": "eventPayload",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "threshold": {
              "type": "number",
              "default": 80.0,
              "label": "Threshold",
              "description": "threshold prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "rightActions": {
              "type": "[SwipeableRowRightActionsItem]",
              "default": [],
              "label": "Right Actions",
              "description": "rightActions prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "eventPayload": {
                    "name": "eventPayload",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "itemData": {
              "type": "json",
              "label": "Item Data",
              "description": "itemData prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SwipeableRowPage",
          "path": "/swipeable-row",
          "traits": [
            {
              "ref": "SwipeableRowRender"
            }
          ]
        }
      ]
    }
  ]
}