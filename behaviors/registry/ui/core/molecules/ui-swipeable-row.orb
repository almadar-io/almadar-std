{
  "description": "SwipeableRow — UI factory (1:1 with the @almadar/ui swipeable-row pattern).",
  "name": "ui-swipeable-row",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SwipeableRowItem",
        "persistence": "runtime"
      },
      "name": "SwipeableRowOrbital",
      "pages": [
        {
          "name": "SwipeableRowPage",
          "path": "/swipeable-row",
          "traits": [
            {
              "ref": "SwipeableRowRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "itemData": {
              "description": "itemData prop",
              "label": "Item Data",
              "tier": "presentation",
              "type": "json"
            },
            "leftActions": {
              "default": [],
              "description": "leftActions prop",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  },
                  "eventPayload": {
                    "name": "eventPayload",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Left Actions",
              "tier": "presentation",
              "type": "[SwipeableRowLeftActionsItem]"
            },
            "rightActions": {
              "default": [],
              "description": "rightActions prop",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  },
                  "eventPayload": {
                    "name": "eventPayload",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "danger",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Right Actions",
              "tier": "presentation",
              "type": "[SwipeableRowRightActionsItem]"
            },
            "threshold": {
              "default": 80.0,
              "description": "threshold prop",
              "label": "Threshold",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SwipeableRowItem",
          "name": "SwipeableRowRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "itemData": "@config.itemData",
                      "leftActions": "@config.leftActions",
                      "rightActions": "@config.rightActions",
                      "threshold": "@config.threshold",
                      "type": "swipeable-row"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}