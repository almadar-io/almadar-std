{
  "description": "WizardProgress — UI factory (1:1 with the @almadar/ui wizard-progress pattern).",
  "name": "ui-wizard-progress",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "WizardProgressItem",
        "persistence": "runtime"
      },
      "name": "WizardProgressOrbital",
      "pages": [
        {
          "name": "WizardProgressPage",
          "path": "/wizard-progress",
          "traits": [
            {
              "ref": "WizardProgressRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "allowNavigation": {
              "default": true,
              "description": "Allow clicking on completed steps to navigate back",
              "label": "Allow Navigation",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "compact": {
              "default": false,
              "description": "Compact mode (smaller, no titles)",
              "label": "Compact",
              "tier": "presentation",
              "type": "boolean"
            },
            "currentStep": {
              "default": 1.0,
              "description": "Current step index (0-based)",
              "label": "Current Step",
              "tier": "presentation",
              "type": "number"
            },
            "steps": {
              "default": [
                {
                  "description": "Description",
                  "id": "Id",
                  "title": "Title"
                },
                {
                  "description": "Description 2",
                  "id": "Id 2",
                  "title": "Title 2"
                }
              ],
              "description": "Step definitions (compatible with WizardContainer's WizardStep). A string is shorthand for `{ id: str, title: str }`.",
              "items": {
                "properties": {
                  "description": {
                    "name": "description",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "title": {
                    "name": "title",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Steps",
              "tier": "presentation",
              "type": "[WizardProgressStepsItem]"
            }
          },
          "emits": [
            {
              "description": "Callback when a completed step is clicked",
              "event": "STEP_CLICK",
              "payloadSchema": [
                {
                  "name": "stepIndex",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "WizardProgressItem",
          "name": "WizardProgressRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when a completed step is clicked",
                "key": "STEP_CLICK",
                "name": "Step Click",
                "payloadSchema": [
                  {
                    "name": "stepIndex",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "allowNavigation": "@config.allowNavigation",
                      "className": "@config.className",
                      "compact": "@config.compact",
                      "currentStep": "@config.currentStep",
                      "onStepClick": "STEP_CLICK",
                      "stepClickEvent": "STEP_CLICK",
                      "steps": "@config.steps",
                      "type": "wizard-progress"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}