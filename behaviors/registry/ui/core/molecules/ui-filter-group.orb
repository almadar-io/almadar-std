{
  "name": "ui-filter-group",
  "version": "1.0.0",
  "description": "FilterGroup — UI factory (1:1 with the @almadar/ui filter-group pattern).",
  "orbitals": [
    {
      "name": "FilterGroupOrbital",
      "entity": {
        "name": "FilterGroupItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FilterGroupRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FilterGroupItem",
          "emits": [
            {
              "event": "FILTER_CHANGE",
              "description": "Callback when a filter changes - for EntityStore integration",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "field",
                  "type": "string"
                },
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLEAR_ALL",
              "description": "Callback to clear all filters",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER_CHANGE",
                "name": "Filter Change",
                "description": "Callback when a filter changes - for EntityStore integration",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR_ALL",
                "name": "Clear All",
                "description": "Callback to clear all filters",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterGroupItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onClearAll": "CLEAR_ALL",
                      "entity": "FilterGroupItem",
                      "isLoading": "@config.isLoading",
                      "type": "filter-group",
                      "query": "@config.query",
                      "filters": "@config.filters",
                      "className": "@config.className",
                      "onFilterChange": "FILTER_CHANGE",
                      "look": "@config.look",
                      "showIcon": "@config.showIcon",
                      "variant": "@config.variant"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showIcon": {
              "type": "boolean",
              "default": true,
              "label": "Show Icon",
              "description": "Show filter icon",
              "tier": "presentation"
            },
            "query": {
              "type": "string",
              "default": "Query",
              "label": "Query",
              "description": "Query singleton binding for state management. When provided, syncs filter state with the query singleton. Example: '@TaskQuery'",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "filters": {
              "type": "[FilterGroupFiltersItem]",
              "default": [
                {
                  "label": "Label",
                  "type": "checkbox",
                  "options": [
                    "Item"
                  ],
                  "field": "Field"
                }
              ],
              "label": "Filters",
              "description": "Filter definitions from schema",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": false,
                    "values": [
                      "checkbox",
                      "select",
                      "toggle"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "options": {
                    "name": "options",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "toolbar",
              "label": "Look",
              "description": "Layer 2 visual treatment — orthogonal to the semantic variant.",
              "tier": "presentation",
              "values": [
                "toolbar",
                "chips",
                "pills",
                "popover-trigger",
                "inline-column-header"
              ]
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Variant style",
              "tier": "presentation",
              "values": [
                "default",
                "compact",
                "pills",
                "vertical"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FilterGroupPage",
          "path": "/filter-group",
          "traits": [
            {
              "ref": "FilterGroupRender"
            }
          ]
        }
      ]
    }
  ]
}