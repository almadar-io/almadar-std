{
  "description": "FormActions — UI factory (1:1 with the @almadar/ui form-actions pattern).",
  "name": "ui-form-actions",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FormActionsItem",
        "persistence": "runtime"
      },
      "name": "FormActionsOrbital",
      "pages": [
        {
          "name": "FormActionsPage",
          "path": "/form-actions",
          "traits": [
            {
              "ref": "FormActionsRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "filters": {
              "default": [
                {
                  "field": "Field",
                  "label": "Label",
                  "options": [
                    "Item"
                  ],
                  "type": "checkbox"
                }
              ],
              "description": "Filter definitions for filter-group pattern",
              "items": {
                "properties": {
                  "field": {
                    "name": "field",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "options": {
                    "items": {
                      "type": "string"
                    },
                    "name": "options",
                    "required": false,
                    "type": "array"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "checkbox",
                      "select",
                      "toggle"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Filters",
              "tier": "presentation",
              "type": "[FormActionsFiltersItem]"
            },
            "look": {
              "default": "right-aligned-buttons",
              "description": "Layer 2 visual treatment for the action-cluster (form-actions) pattern.",
              "label": "Look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "right-aligned-buttons",
                "floating-bar",
                "inline-row",
                "dropdown-menu",
                "command-palette-trigger"
              ]
            },
            "orientation": {
              "default": "horizontal",
              "description": "Orientation",
              "label": "Orientation",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "primary": {
              "default": {
                "actionType": "Action Type",
                "label": "Label",
                "navigatesTo": "Navigates To",
                "variant": "Variant"
              },
              "description": "Primary action button config (for form-actions pattern) Accepts Readonly for compatibility with generated const objects",
              "label": "Primary",
              "properties": {
                "actionType": {
                  "name": "actionType",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "navigatesTo": {
                  "name": "navigatesTo",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "FormActionsPrimary"
            },
            "secondary": {
              "default": [
                {
                  "actionType": "Action Type",
                  "label": "Label",
                  "navigatesTo": "Navigates To",
                  "variant": "Variant"
                }
              ],
              "description": "Secondary action buttons config (for form-actions pattern) Accepts readonly array for compatibility with generated const arrays",
              "items": {
                "properties": {
                  "actionType": {
                    "name": "actionType",
                    "required": false,
                    "type": "string"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Secondary",
              "tier": "presentation",
              "type": "[FormActionsSecondaryItem]"
            },
            "variant": {
              "default": "default",
              "description": "Visual variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "segmented",
                "toggle"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FormActionsItem",
          "name": "FormActionsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "FormActionsItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "entity": "FormActionsItem",
                      "filters": "@config.filters",
                      "look": "@config.look",
                      "orientation": "@config.orientation",
                      "primary": "@config.primary",
                      "secondary": "@config.secondary",
                      "type": "form-actions",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}