{
  "name": "ui-form-actions",
  "version": "1.0.0",
  "description": "FormActions — UI factory (1:1 with the @almadar/ui form-actions pattern).",
  "orbitals": [
    {
      "name": "FormActionsOrbital",
      "entity": {
        "name": "FormActionsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FormActionsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FormActionsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FormActionsItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "primary": "@config.primary",
                      "secondary": "@config.secondary",
                      "variant": "@config.variant",
                      "filters": "@config.filters",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "look": "@config.look",
                      "entity": "FormActionsItem",
                      "type": "form-actions",
                      "orientation": "@config.orientation",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Visual variant",
              "tier": "presentation",
              "values": [
                "default",
                "segmented",
                "toggle"
              ]
            },
            "secondary": {
              "type": "[FormActionsSecondaryItem]",
              "default": [
                {
                  "variant": "Variant",
                  "navigatesTo": "Navigates To",
                  "label": "Label",
                  "actionType": "Action Type"
                }
              ],
              "label": "Secondary",
              "description": "Secondary action buttons config (for form-actions pattern) Accepts readonly array for compatibility with generated const arrays",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "actionType": {
                    "name": "actionType",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "Orientation",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "primary": {
              "type": "FormActionsPrimary",
              "default": {
                "variant": "Variant",
                "navigatesTo": "Navigates To",
                "label": "Label",
                "actionType": "Action Type"
              },
              "label": "Primary",
              "description": "Primary action button config (for form-actions pattern) Accepts Readonly for compatibility with generated const objects",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "actionType": {
                  "name": "actionType",
                  "type": "string",
                  "required": false
                },
                "navigatesTo": {
                  "name": "navigatesTo",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false
                },
                "event": {
                  "name": "event",
                  "type": "string",
                  "required": false
                }
              }
            },
            "look": {
              "type": "string",
              "default": "right-aligned-buttons",
              "label": "Look",
              "description": "Layer 2 visual treatment for the action-cluster (form-actions) pattern.",
              "tier": "presentation",
              "values": [
                "right-aligned-buttons",
                "floating-bar",
                "inline-row",
                "dropdown-menu",
                "command-palette-trigger"
              ]
            },
            "filters": {
              "type": "[FormActionsFiltersItem]",
              "default": [
                {
                  "label": "Label",
                  "field": "Field",
                  "type": "checkbox",
                  "options": [
                    "Item"
                  ]
                }
              ],
              "label": "Filters",
              "description": "Filter definitions for filter-group pattern",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": false,
                    "values": [
                      "checkbox",
                      "select",
                      "toggle"
                    ]
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  "options": {
                    "name": "options",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormActionsPage",
          "path": "/form-actions",
          "traits": [
            {
              "ref": "FormActionsRender"
            }
          ]
        }
      ]
    }
  ]
}