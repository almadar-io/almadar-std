          "linkedEntityId": "ent_01KXN842ECGZ79QB93372JK9CC",
          "name": "StatRowsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXN842ECHZGCQTTNVDW0JFZQ",
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.rows",
                    "@config.rows"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        [
                          "array/map",
                          "@entity.rows",
                          [
                            "fn",
                            "item",
                            {
                              "label": "@item.label",
                              "type": "stat-badge",
                              "value": "@item.value"
                            }
                          ]
                        ]
                      ],
                      "className": "@config.className",
                      "direction": "vertical",
                      "gap": "@config.gap",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXN842ECHZGCQTTNVDW0JFZQ",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
