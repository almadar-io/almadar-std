{
  "name": "ui-skeleton",
  "version": "1.0.0",
  "description": "Skeleton — UI factory (1:1 with the @almadar/ui skeleton pattern).",
  "orbitals": [
    {
      "name": "SkeletonOrbital",
      "entity": {
        "name": "SkeletonItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SkeletonRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SkeletonItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "rows": "@config.rows",
                      "fields": "@config.fields",
                      "className": "@config.className",
                      "type": "skeleton",
                      "columns": "@config.columns",
                      "variant": "@config.variant"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "columns": {
              "type": "number",
              "default": 4.0,
              "label": "Columns",
              "description": "Number of columns for table variant",
              "tier": "presentation"
            },
            "fields": {
              "type": "number",
              "default": 4.0,
              "label": "Fields",
              "description": "Number of fields for form variant",
              "tier": "presentation"
            },
            "rows": {
              "type": "number",
              "default": 5.0,
              "label": "Rows",
              "description": "Number of rows for table/text variants",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "text",
              "label": "Variant",
              "description": "The skeleton variant to render",
              "tier": "presentation",
              "values": [
                "header",
                "table",
                "form",
                "card",
                "text"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SkeletonPage",
          "path": "/skeleton",
          "traits": [
            {
              "ref": "SkeletonRender"
            }
          ]
        }
      ]
    }
  ]
}