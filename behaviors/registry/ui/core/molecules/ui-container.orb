{
  "description": "Container — UI factory (1:1 with the @almadar/ui container pattern).",
  "name": "ui-container",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ContainerItem",
        "persistence": "runtime"
      },
      "name": "ContainerOrbital",
      "pages": [
        {
          "name": "ContainerPage",
          "path": "/container",
          "traits": [
            {
              "ref": "ContainerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "center": {
              "default": true,
              "description": "Center horizontally",
              "label": "Center",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Custom class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "maxWidth": {
              "default": "xs",
              "description": "Alias for size (pattern compatibility)",
              "label": "Max Width",
              "tier": "presentation",
              "type": "string",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "full"
              ]
            },
            "padding": {
              "default": "md",
              "description": "Horizontal padding",
              "label": "Padding",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "size": {
              "default": "xs",
              "description": "Maximum width",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "full"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ContainerItem",
          "name": "ContainerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "center": "@config.center",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "maxWidth": "@config.maxWidth",
                      "padding": "@config.padding",
                      "size": "@config.size",
                      "type": "container"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}