{
  "name": "ui-container",
  "version": "1.0.0",
  "description": "Container — UI factory (1:1 with the @almadar/ui container pattern).",
  "orbitals": [
    {
      "name": "ContainerOrbital",
      "entity": {
        "name": "ContainerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ContainerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ContainerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "maxWidth": "@config.maxWidth",
                      "padding": "@config.padding",
                      "center": "@config.center",
                      "children": "@config.children",
                      "size": "@config.size",
                      "className": "@config.className",
                      "type": "container"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Children elements",
              "tier": "presentation"
            },
            "center": {
              "type": "boolean",
              "default": true,
              "label": "Center",
              "description": "Center horizontally",
              "tier": "presentation"
            },
            "maxWidth": {
              "type": "string",
              "default": "xs",
              "label": "Max Width",
              "description": "Alias for size (pattern compatibility)",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "full"
              ]
            },
            "padding": {
              "type": "string",
              "default": "md",
              "label": "Padding",
              "description": "Horizontal padding",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Custom class name",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "xs",
              "label": "Size",
              "description": "Maximum width",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "full"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ContainerPage",
          "path": "/container",
          "traits": [
            {
              "ref": "ContainerRender"
            }
          ]
        }
      ]
    }
  ]
}
