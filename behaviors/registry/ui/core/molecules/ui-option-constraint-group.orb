{
  "description": "OptionConstraintGroup — UI factory (1:1 with the @almadar/ui option-constraint-group pattern).",
  "name": "ui-option-constraint-group",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "OptionConstraintGroupItem",
        "persistence": "runtime"
      },
      "name": "OptionConstraintGroupOrbital",
      "pages": [
        {
          "name": "OptionConstraintGroupPage",
          "path": "/option-constraint-group",
          "traits": [
            {
              "ref": "OptionConstraintGroupRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Description",
              "description": "description prop",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "groupId": {
              "default": "Group Id",
              "description": "groupId prop",
              "label": "Group Id",
              "tier": "presentation",
              "type": "string"
            },
            "options": {
              "default": [
                {
                  "disabled": false,
                  "id": "Id",
                  "label": "Label",
                  "outOfStock": false,
                  "priceDelta": 1.0
                }
              ],
              "description": "options prop",
              "items": {
                "properties": {
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "outOfStock": {
                    "name": "outOfStock",
                    "required": false,
                    "type": "boolean"
                  },
                  "priceDelta": {
                    "name": "priceDelta",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Options",
              "tier": "presentation",
              "type": "[OptionConstraintGroupOptionsItem]"
            },
            "selected": {
              "default": [],
              "description": "selected prop",
              "items": {
                "type": "string"
              },
              "label": "Selected",
              "tier": "presentation",
              "type": "[string]"
            },
            "size": {
              "default": "md",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md"
              ]
            },
            "title": {
              "default": "Title",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "onChange prop",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "selected",
                  "type": "[object]"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "OptionConstraintGroupItem",
          "name": "OptionConstraintGroupRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onChange prop",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "selected",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "changeEvent": "CHANGE",
                      "className": "@config.className",
                      "description": "@config.description",
                      "groupId": "@config.groupId",
                      "onChange": "CHANGE",
                      "options": "@config.options",
                      "selected": "@config.selected",
                      "size": "@config.size",
                      "title": "@config.title",
                      "type": "option-constraint-group"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}