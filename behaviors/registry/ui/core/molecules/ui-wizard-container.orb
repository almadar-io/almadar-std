{
  "name": "ui-wizard-container",
  "version": "1.0.0",
  "description": "WizardContainer — UI factory (1:1 with the @almadar/ui wizard-container pattern).",
  "orbitals": [
    {
      "name": "WizardContainerOrbital",
      "entity": {
        "name": "WizardContainerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "WizardContainerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "WizardContainerItem",
          "emits": [
            {
              "event": "STEP_CHANGE",
              "description": "Callback when step changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "stepIndex",
                  "type": "number"
                }
              ]
            },
            {
              "event": "COMPLETE",
              "description": "Callback when wizard is completed",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "STEP_CHANGE",
                "name": "Step Change",
                "description": "Callback when step changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "stepIndex",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "Callback when wizard is completed",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardContainerItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onStepChange": "STEP_CHANGE",
                      "allowBack": "@config.allowBack",
                      "entity": "WizardContainerItem",
                      "className": "@config.className",
                      "isLoading": "@config.isLoading",
                      "showProgress": "@config.showProgress",
                      "error": "@config.error",
                      "onComplete": "COMPLETE",
                      "type": "wizard-container",
                      "compact": "@config.compact",
                      "steps": "@config.steps",
                      "currentStep": "@config.currentStep"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "currentStep": {
              "type": "json",
              "label": "Current Step",
              "description": "Current step index (controlled) - accepts unknown for generated code compatibility",
              "tier": "presentation"
            },
            "allowBack": {
              "type": "boolean",
              "default": true,
              "label": "Allow Back",
              "description": "Allow navigation to previous steps",
              "tier": "presentation"
            },
            "steps": {
              "type": "[WizardContainerStepsItem]",
              "default": [
                {
                  "optional": false,
                  "entityMapping": {
                    "idField": "Id Field",
                    "parentField": "Parent Field",
                    "mode": "search_or_create",
                    "entity": "Entity"
                  },
                  "title": "Title",
                  "tabId": "Tab Id",
                  "id": "Id",
                  "description": "Description",
                  "localVariables": [
                    "Item"
                  ],
                  "validationRules": [
                    {
                      "message": "Message",
                      "condition": []
                    }
                  ],
                  "name": "Name",
                  "lawReferences": [
                    {
                      "description": "Description",
                      "article": "Article",
                      "law": "Law"
                    }
                  ],
                  "sections": [
                    {
                      "addButtonLabel": "Add Button Label",
                      "subsections": [],
                      "title": "Title",
                      "description": "Description",
                      "condition": [],
                      "id": "Id",
                      "minItems": 1.0,
                      "hiddenCalculations": [
                        {
                          "scope": "Scope",
                          "variable": "Variable",
                          "expression": "Expression"
                        }
                      ],
                      "repeatable": false,
                      "fields": [
                        {
                          "label": "Label",
                          "items": [],
                          "placeholder": "Placeholder",
                          "entityField": "Entity Field",
                          "hiddenCalculations": [],
                          "type": "Type",
                          "stats": [],
