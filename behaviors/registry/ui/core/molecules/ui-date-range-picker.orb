{
  "description": "DateRangePicker — UI factory (1:1 with the @almadar/ui date-range-picker pattern).",
  "name": "ui-date-range-picker",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "From",
            "name": "fromProp",
            "type": "string"
          },
          {
            "default": "To",
            "name": "toProp",
            "type": "string"
          }
        ],
        "name": "DateRangePickerItem",
        "persistence": "runtime"
      },
      "name": "DateRangePickerOrbital",
      "pages": [
        {
          "name": "DateRangePickerPage",
          "path": "/date-range-picker",
          "traits": [
            {
              "ref": "DateRangePickerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "fromLabel": {
              "default": "From",
              "description": "From-input label.",
              "label": "From Label",
              "tier": "presentation",
              "type": "string"
            },
            "fromProp": {
              "default": "From",
              "description": "Controlled `from` (ISO date YYYY-MM-DD).",
              "label": "From",
              "synonyms": "from",
              "tier": "presentation",
              "type": "string"
            },
            "presets": {
              "default": [],
              "description": "Preset shortcuts. Defaults to the standard finance set (Last 7d / Last 30d / This Month / This Quarter / YTD). Pass an empty array to hide presets entirely.",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Presets",
              "tier": "presentation",
              "type": "[DateRangePickerPresetsItem]"
            },
            "toLabel": {
              "default": "To",
              "description": "To-input label.",
              "label": "To Label",
              "tier": "presentation",
              "type": "string"
            },
            "toProp": {
              "default": "To",
              "description": "Controlled `to` (ISO date YYYY-MM-DD).",
              "label": "To",
              "synonyms": "to",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Event name emitted as `UI:{event}` with payload `{ from, to }`. Optional — when omitted, only the `onChange` callback fires.",
              "event": "EVENT",
              "payloadSchema": [
                {
                  "name": "from",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "to",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback fired alongside the bus emit.",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "range",
                  "properties": [
                    {
                      "name": "from",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "to",
                      "required": true,
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "fromProp",
              "toProp"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DateRangePickerItem",
          "name": "DateRangePickerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Event name emitted as `UI:{event}` with payload `{ from, to }`. Optional — when omitted, only the `onChange` callback fires.",
                "key": "EVENT",
                "name": "Event",
                "payloadSchema": [
                  {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback fired alongside the bus emit.",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "range",
                    "properties": [
                      {
                        "name": "from",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "to",
                        "required": true,
                        "type": "string"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.fromProp",
                    "@config.fromProp"
                  ],
                  [
                    "set",
                    "@entity.toProp",
                    "@config.toProp"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "event": "EVENT",
                      "from": "@entity.fromProp",
                      "fromLabel": "@config.fromLabel",
                      "onChange": "CHANGE",
                      "presets": "@config.presets",
                      "to": "@entity.toProp",
                      "toLabel": "@config.toLabel",
                      "type": "date-range-picker"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.fromProp",
                    "@payload.from"
                  ],
                  [
                    "set",
                    "@entity.toProp",
                    "@payload.to"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "event": "EVENT",
                      "from": "@entity.fromProp",
                      "fromLabel": "@config.fromLabel",
                      "onChange": "CHANGE",
                      "presets": "@config.presets",
                      "to": "@entity.toProp",
                      "toLabel": "@config.toLabel",
                      "type": "date-range-picker"
                    }
                  ]
                ],
                "event": "EVENT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}