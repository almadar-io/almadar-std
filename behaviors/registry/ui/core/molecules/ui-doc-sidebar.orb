{
  "name": "ui-doc-sidebar",
  "version": "1.0.0",
  "description": "DocSidebar — UI factory (1:1 with the @almadar/ui doc-sidebar pattern).",
  "orbitals": [
    {
      "name": "DocSidebarOrbital",
      "entity": {
        "name": "DocSidebarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DocSidebarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DocSidebarItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "type": "doc-sidebar",
                      "items": "@config.items"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[DocSidebarItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Sidebar navigation items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "active": {
                    "name": "active",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DocSidebarPage",
          "path": "/doc-sidebar",
          "traits": [
            {
              "ref": "DocSidebarRender"
            }
          ]
        }
      ]
    }
  ]
}
