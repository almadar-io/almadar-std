{
  "description": "DocSidebar — UI factory (1:1 with the @almadar/ui doc-sidebar pattern).",
  "name": "ui-doc-sidebar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DocSidebarItem",
        "persistence": "runtime"
      },
      "name": "DocSidebarOrbital",
      "pages": [
        {
          "name": "DocSidebarPage",
          "path": "/doc-sidebar",
          "traits": [
            {
              "ref": "DocSidebarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "active": false,
                  "href": "Href",
                  "items": [],
                  "label": "Label"
                }
              ],
              "description": "Sidebar navigation items",
              "items": {
                "properties": {
                  "active": {
                    "name": "active",
                    "required": false,
                    "type": "boolean"
                  },
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "items": {
                    "items": {
                      "type": "string"
                    },
                    "name": "items",
                    "required": false,
                    "type": "array"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[DocSidebarItemsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DocSidebarItem",
          "name": "DocSidebarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "items": "@config.items",
                      "type": "doc-sidebar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}