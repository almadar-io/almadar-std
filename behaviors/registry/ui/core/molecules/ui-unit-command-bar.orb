{
  "name": "ui-unit-command-bar",
  "version": "1.0.0",
  "description": "UnitCommandBar — UI factory (1:1 with the @almadar/ui unit-command-bar pattern).",
  "orbitals": [
    {
      "name": "UnitCommandBarOrbital",
      "entity": {
        "name": "UnitCommandBarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "UnitCommandBarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "UnitCommandBarItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "selectedUnitId": "@config.selectedUnitId",
                      "className": "@config.className",
                      "type": "unit-command-bar",
                      "commands": "@config.commands"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "commands": {
              "type": "[UnitCommandBarCommandsItem]",
              "default": [],
              "label": "Commands",
              "description": "Available commands",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "hotkey": {
                    "name": "hotkey",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "selectedUnitId": {
              "type": "string",
              "default": "",
              "label": "Selected Unit Id",
              "description": "ID of the currently selected unit",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "UnitCommandBarPage",
          "path": "/unit-command-bar",
          "traits": [
            {
              "ref": "UnitCommandBarRender"
            }
          ]
        }
      ]
    }
  ]
}