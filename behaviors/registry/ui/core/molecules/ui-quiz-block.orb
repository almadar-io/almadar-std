{
  "description": "QuizBlock — UI factory (1:1 with the @almadar/ui quiz-block pattern).",
  "name": "ui-quiz-block",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "QuizBlockItem",
        "persistence": "runtime"
      },
      "name": "QuizBlockOrbital",
      "pages": [
        {
          "name": "QuizBlockPage",
          "path": "/quiz-block",
          "traits": [
            {
              "ref": "QuizBlockRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "answer": {
              "default": "Answer",
              "description": "The quiz answer (revealed on toggle)",
              "label": "Answer",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "question": {
              "default": "Question",
              "description": "The quiz question",
              "label": "Question",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "QuizBlockItem",
          "name": "QuizBlockRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "answer": "@config.answer",
                      "className": "@config.className",
                      "question": "@config.question",
                      "type": "quiz-block"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}