{
  "name": "ui-repeatable-form-section",
  "version": "1.0.0",
  "description": "RepeatableFormSection — UI factory (1:1 with the @almadar/ui repeatable-form-section pattern).",
  "orbitals": [
    {
      "name": "RepeatableFormSectionOrbital",
      "entity": {
        "name": "RepeatableFormSectionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "RepeatableFormSectionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "RepeatableFormSectionItem",
          "emits": [
            {
              "event": "ADD",
              "description": "Add handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REMOVE",
              "description": "Remove handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string"
                },
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            },
            {
              "event": "REORDER",
              "description": "Reorder handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "fromIndex",
                  "type": "number"
                },
                {
                  "name": "toIndex",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD",
                "name": "Add",
                "description": "Add handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REMOVE",
                "name": "Remove",
                "description": "Remove handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string"
                  },
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "REORDER",
                "name": "Reorder",
                "description": "Reorder handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "fromIndex",
                    "type": "number"
                  },
                  {
                    "name": "toIndex",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "readOnly": "@config.readOnly",
                      "maxItems": "@config.maxItems",
                      "title": "@config.title",
                      "sectionType": "@config.sectionType",
                      "type": "repeatable-form-section",
                      "onRemove": "REMOVE",
                      "allowReorder": "@config.allowReorder",
                      "items": "@config.items",
                      "renderItem": [
                        "fn",
                        "item",
                        "index",
                        {
                          "type": "text",
                          "content": "@item.id"
                        }
                      ],
                      "className": "@config.className",
                      "currentState": "@config.currentState",
                      "minItems": "@config.minItems",
                      "onReorder": "REORDER",
                      "onAdd": "ADD",
                      "showAuditInfo": "@config.showAuditInfo",
                      "trackAddedInState": "@config.trackAddedInState",
                      "emptyMessage": "@config.emptyMessage",
                      "addLabel": "@config.addLabel"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "readOnly": {
              "type": "boolean",
              "default": false,
              "label": "Read Only",
              "description": "Read-only mode",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "currentState": {
              "type": "string",
              "default": "",
              "label": "Current State",
              "description": "Current inspection state (used when trackAddedInState is true)",
              "tier": "presentation"
            },
            "maxItems": {
              "type": "number",
              "default": 0.0,
              "label": "Max Items",
              "description": "Maximum items allowed",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Section title",
              "tier": "presentation"
            },
            "trackAddedInState": {
              "type": "boolean",
              "default": false,
              "label": "Track Added In State",
              "description": "Inspection-specific enhancements",
              "tier": "presentation"
            },
            "allowReorder": {
              "type": "boolean",
              "default": false,
              "label": "Allow Reorder",
              "description": "Allow reordering",
              "tier": "presentation"
            },
            "showAuditInfo": {
              "type": "boolean",
              "default": false,
              "label": "Show Audit Info",
              "description": "Show audit metadata (addedInState, addedAt)",
              "tier": "presentation"
            },
            "sectionType": {
              "type": "string",
              "default": "",
              "label": "Section Type",
              "description": "Section type identifier",
              "tier": "presentation"
            },
            "minItems": {
              "type": "number",
              "default": 0.0,
              "label": "Min Items",
              "description": "Minimum items required",
              "tier": "presentation"
            },
            "addLabel": {
              "type": "string",
              "default": "",
              "label": "Add Label",
              "description": "Add button label",
              "tier": "presentation"
            },
            "items": {
              "type": "[RepeatableFormSectionItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Items in the section",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "addedInState": {
                    "name": "addedInState",
                    "type": "string",
                    "required": false
                  },
                  "addedAt": {
                    "name": "addedAt",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "emptyMessage": {
              "type": "string",
              "default": "",
              "label": "Empty Message",
              "description": "Empty state message",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RepeatableFormSectionPage",
          "path": "/repeatable-form-section",
          "traits": [
            {
              "ref": "RepeatableFormSectionRender"
            }
          ]
        }
      ]
    }
  ]
}
