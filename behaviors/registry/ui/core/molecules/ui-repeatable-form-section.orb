{
  "description": "RepeatableFormSection — UI factory (1:1 with the @almadar/ui repeatable-form-section pattern).",
  "name": "ui-repeatable-form-section",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "RepeatableFormSectionItem",
        "persistence": "runtime"
      },
      "name": "RepeatableFormSectionOrbital",
      "pages": [
        {
          "name": "RepeatableFormSectionPage",
          "path": "/repeatable-form-section",
          "traits": [
            {
              "ref": "RepeatableFormSectionRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "addLabel": {
              "default": "Add Label",
              "description": "Add button label",
              "label": "Add Label",
              "tier": "presentation",
              "type": "string"
            },
            "allowReorder": {
              "default": false,
              "description": "Allow reordering",
              "label": "Allow Reorder",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentState": {
              "default": "Current State",
              "description": "Current inspection state (used when trackAddedInState is true)",
              "label": "Current State",
              "tier": "presentation",
              "type": "string"
            },
            "emptyMessage": {
              "default": "Empty Message",
              "description": "Empty state message",
              "label": "Empty Message",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "addedAt": "Added At",
                  "addedInState": "Added In State",
                  "id": "Id"
                },
                {
                  "addedAt": "Added At 2",
                  "addedInState": "Added In State 2",
                  "id": "Id 2"
                }
              ],
              "description": "Items in the section",
              "items": {
                "properties": {
                  "addedAt": {
                    "name": "addedAt",
                    "required": false,
                    "type": "string"
                  },
                  "addedInState": {
                    "name": "addedInState",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[RepeatableFormSectionItemsItem]"
            },
            "maxItems": {
              "default": 0.0,
              "description": "Maximum items allowed",
              "label": "Max Items",
              "tier": "presentation",
              "type": "number"
            },
            "minItems": {
              "default": 0.0,
              "description": "Minimum items required",
              "label": "Min Items",
              "tier": "presentation",
              "type": "number"
            },
            "onAdd": {
              "default": "ADD",
              "description": "Add handler",
              "label": "On Add",
              "tier": "presentation",
              "type": "string"
            },
            "onRemove": {
              "default": "REMOVE",
              "description": "Remove handler",
              "label": "On Remove",
              "tier": "presentation",
              "type": "string"
            },
            "onReorder": {
              "default": "REORDER",
              "description": "Reorder handler",
              "label": "On Reorder",
              "tier": "presentation",
              "type": "string"
            },
            "readOnly": {
              "default": false,
              "description": "Read-only mode",
              "label": "Read Only",
              "tier": "presentation",
              "type": "boolean"
            },
            "sectionType": {
              "default": "Section Type",
              "description": "Section type identifier",
              "label": "Section Type",
              "tier": "presentation",
              "type": "string"
            },
            "showAuditInfo": {
              "default": false,
              "description": "Show audit metadata (addedInState, addedAt)",
              "label": "Show Audit Info",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Title",
              "description": "Section title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "trackAddedInState": {
              "default": false,
              "description": "Inspection-specific enhancements",
              "label": "Track Added In State",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Add handler",
              "event": "ADD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Remove handler",
              "event": "REMOVE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string"
                },
                {
                  "name": "index",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Reorder handler",
              "event": "REORDER",
              "payloadSchema": [
                {
                  "name": "fromIndex",
                  "type": "number"
                },
                {
                  "name": "toIndex",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RepeatableFormSectionItem",
          "name": "RepeatableFormSectionRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Add handler",
                "key": "ADD",
                "name": "Add",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Remove handler",
                "key": "REMOVE",
                "name": "Remove",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string"
                  },
                  {
                    "name": "index",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Reorder handler",
                "key": "REORDER",
                "name": "Reorder",
                "payloadSchema": [
                  {
                    "name": "fromIndex",
                    "type": "number"
                  },
                  {
                    "name": "toIndex",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "addLabel": "@config.addLabel",
                      "allowReorder": "@config.allowReorder",
                      "className": "@config.className",
                      "currentState": "@config.currentState",
                      "emptyMessage": "@config.emptyMessage",
                      "items": "@config.items",
                      "maxItems": "@config.maxItems",
                      "minItems": "@config.minItems",
                      "onAdd": "@config.onAdd",
                      "onRemove": "@config.onRemove",
                      "onReorder": "@config.onReorder",
                      "readOnly": "@config.readOnly",
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "content": "@item.id",
                          "type": "typography"
                        }
                      ],
                      "sectionType": "@config.sectionType",
                      "showAuditInfo": "@config.showAuditInfo",
                      "title": "@config.title",
                      "trackAddedInState": "@config.trackAddedInState",
                      "type": "repeatable-form-section"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}