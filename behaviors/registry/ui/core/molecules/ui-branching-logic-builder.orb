{
  "description": "BranchingLogicBuilder — UI factory (1:1 with the @almadar/ui branching-logic-builder pattern).",
  "name": "ui-branching-logic-builder",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "BranchingLogicBuilderItem",
        "persistence": "runtime"
      },
      "name": "BranchingLogicBuilderOrbital",
      "pages": [
        {
          "name": "BranchingLogicBuilderPage",
          "path": "/branching-logic-builder",
          "traits": [
            {
              "ref": "BranchingLogicBuilderRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "questions": {
              "default": [
                {
                  "id": "Id",
                  "label": "Label",
                  "optionValues": [
                    "Item"
                  ]
                }
              ],
              "description": "questions prop",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "optionValues": {
                    "items": {
                      "type": "string"
                    },
                    "name": "optionValues",
                    "required": false,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Questions",
              "tier": "presentation",
              "type": "[BranchingLogicBuilderQuestionsItem]"
            },
            "readOnly": {
              "default": false,
              "description": "readOnly prop",
              "label": "Read Only",
              "tier": "presentation",
              "type": "boolean"
            },
            "rules": {
              "default": [
                {
                  "id": "Id",
                  "operator": "equals",
                  "sourceQuestionId": "Source Question Id",
                  "targetQuestionId": "Target Question Id",
                  "value": [
                    "Item"
                  ]
                }
              ],
              "description": "Rules. Accepts either a typed array (direct consumers) or the runtime payload shape from a render-ui binding (`@payload.data`). Narrowed to `[]` internally when the value isn't an array.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "operator": {
                    "name": "operator",
                    "required": true,
                    "type": "string",
                    "values": [
                      "equals",
                      "not-equals",
                      "contains",
                      "in"
                    ]
                  },
                  "sourceQuestionId": {
                    "name": "sourceQuestionId",
                    "required": true,
                    "type": "string"
                  },
                  "targetQuestionId": {
                    "name": "targetQuestionId",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "items": {
                      "type": "string"
                    },
                    "name": "value",
                    "required": true,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Rules",
              "tier": "presentation",
              "type": "[BranchingLogicBuilderRulesItem]"
            }
          },
          "emits": [
            {
              "description": "onRulesChange prop",
              "event": "RULES_CHANGE",
              "payloadSchema": [
                {
                  "name": "rules",
                  "type": "[object]"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "BranchingLogicBuilderItem",
          "name": "BranchingLogicBuilderRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onRulesChange prop",
                "key": "RULES_CHANGE",
                "name": "Rules Change",
                "payloadSchema": [
                  {
                    "name": "rules",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "onRulesChange": "RULES_CHANGE",
                      "questions": "@config.questions",
                      "readOnly": "@config.readOnly",
                      "rules": "@config.rules",
                      "rulesChangeEvent": "RULES_CHANGE",
                      "type": "branching-logic-builder"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}