{
  "description": "ErrorState — UI factory (1:1 with the @almadar/ui error-state pattern).",
  "name": "ui-error-state",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ErrorStateItem",
        "persistence": "runtime"
      },
      "name": "ErrorStateOrbital",
      "pages": [
        {
          "name": "ErrorStatePage",
          "path": "/error-state",
          "traits": [
            {
              "ref": "ErrorStateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Description",
              "description": "Alias for message (schema compatibility)",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "message": {
              "default": "Message",
              "description": "Error message to display",
              "label": "Message",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "onRetry prop",
              "event": "RETRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ErrorStateItem",
          "name": "ErrorStateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onRetry prop",
                "key": "RETRY",
                "name": "Retry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "description": "@config.description",
                      "message": "@config.message",
                      "onRetry": "RETRY",
                      "retryEvent": "RETRY",
                      "title": "@config.title",
                      "type": "error-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}