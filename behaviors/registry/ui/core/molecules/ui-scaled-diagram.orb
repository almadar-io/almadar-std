{
  "name": "ui-scaled-diagram",
  "version": "1.0.0",
  "description": "ScaledDiagram — UI factory (1:1 with the @almadar/ui scaled-diagram pattern).",
  "orbitals": [
    {
      "name": "ScaledDiagramOrbital",
      "entity": {
        "name": "ScaledDiagramItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ScaledDiagramRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ScaledDiagramItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "type": "scaled-diagram"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "children": {
              "type": "node",
              "label": "Children",
              "description": "children prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ScaledDiagramPage",
          "path": "/scaled-diagram",
          "traits": [
            {
              "ref": "ScaledDiagramRender"
            }
          ]
        }
      ]
    }
  ]
}