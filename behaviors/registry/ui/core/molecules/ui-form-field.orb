{
  "description": "FormField — UI factory (1:1 with the @almadar/ui form-field pattern).",
  "name": "ui-form-field",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FormFieldItem",
        "persistence": "runtime"
      },
      "name": "FormFieldOrbital",
      "pages": [
        {
          "name": "FormFieldPage",
          "path": "/form-field",
          "traits": [
            {
              "ref": "FormFieldRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "children prop",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "default": "",
              "description": "error prop",
              "label": "Error",
              "tier": "presentation",
              "type": "string"
            },
            "hint": {
              "default": "Hint",
              "description": "hint prop",
              "label": "Hint",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "label prop",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "required": {
              "default": false,
              "description": "required prop",
              "label": "Required",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FormFieldItem",
          "name": "FormFieldRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "error": "@config.error",
                      "hint": "@config.hint",
                      "label": "@config.label",
                      "required": "@config.required",
                      "type": "form-field"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}