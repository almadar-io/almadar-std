{
  "description": "PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern).",
  "name": "ui-page-header",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PageHeaderItem",
        "persistence": "runtime"
      },
      "name": "PageHeaderOrbital",
      "pages": [
        {
          "name": "PageHeaderPage",
          "path": "/page-header",
          "traits": [
            {
              "ref": "PageHeaderRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "default": [
                {
                  "disabled": false,
                  "icon": "circle",
                  "label": "Label",
                  "loading": false,
                  "navigatesTo": "Navigates To",
                  "variant": "primary"
                },
                {
                  "disabled": true,
                  "icon": "circle",
                  "label": "Label 2",
                  "loading": true,
                  "navigatesTo": "Navigates To 2",
                  "variant": "secondary"
                }
              ],
              "description": "Actions array - first action with variant='primary' (or first action) is the main action",
              "items": {
                "properties": {
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "loading": {
                    "name": "loading",
                    "required": false,
                    "type": "boolean"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Actions",
              "tier": "presentation",
              "type": "[PageHeaderActionsItem]"
            },
            "activeTab": {
              "default": "Active Tab",
              "description": "activeTab prop",
              "label": "Active Tab",
              "tier": "presentation",
              "type": "string"
            },
            "breadcrumbs": {
              "default": [
                {
                  "href": "Href",
                  "label": "Label"
                },
                {
                  "href": "Href 2",
                  "label": "Label 2"
                }
              ],
              "description": "Breadcrumbs",
              "items": {
                "properties": {
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Breadcrumbs",
              "tier": "presentation",
              "type": "[PageHeaderBreadcrumbsItem]"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "PageHeaderError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "showBack": {
              "default": false,
              "description": "Show back button",
              "label": "Show Back",
              "tier": "presentation",
              "type": "boolean"
            },
            "status": {
              "description": "Status badge",
              "label": "Status",
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string",
                  "values": [
                    "default",
                    "success",
                    "warning",
                    "danger",
                    "info"
                  ]
                }
              },
              "tier": "presentation",
              "type": "PageHeaderStatus"
            },
            "subtitle": {
              "default": {},
              "description": "Optional subtitle/description",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "json"
            },
            "tabs": {
              "default": [
                {
                  "count": 1.0,
                  "label": "Label",
                  "value": "Value"
                },
                {
                  "count": 2.0,
                  "label": "Label 2",
                  "value": "Value 2"
                }
              ],
              "description": "Tabs for sub-navigation",
              "items": {
                "properties": {
                  "count": {
                    "name": "count",
                    "required": false,
                    "type": "number"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Tabs",
              "tier": "presentation",
              "type": "[PageHeaderTabsItem]"
            },
            "title": {
              "default": {},
              "description": "Page title - accepts unknown to handle generated code accessing dynamic entity data",
              "label": "Title",
              "tier": "presentation",
              "type": "json"
            }
          },
          "emits": [
            {
              "description": "Event to emit when back is clicked (default: BACK)",
              "event": "BACK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "onTabChange prop",
              "event": "TAB_CHANGE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PageHeaderItem",
          "name": "PageHeaderRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Event to emit when back is clicked (default: BACK)",
                "key": "BACK",
                "name": "Back",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "onTabChange prop",
                "key": "TAB_CHANGE",
                "name": "Tab Change",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "activeTab": "@config.activeTab",
                      "backEvent": "BACK",
                      "breadcrumbs": "@config.breadcrumbs",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "onTabChange": "TAB_CHANGE",
                      "showBack": "@config.showBack",
                      "status": "@config.status",
                      "subtitle": "@config.subtitle",
                      "tabs": "@config.tabs",
                      "title": "@config.title",
                      "type": "page-header"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}