{
  "name": "ui-page-header",
  "version": "1.0.0",
  "description": "PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern).",
  "orbitals": [
    {
      "name": "PageHeaderOrbital",
      "entity": {
        "name": "PageHeaderItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PageHeaderRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PageHeaderItem",
          "emits": [
            {
              "event": "BACK",
              "description": "Event to emit when back is clicked (default: BACK)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TAB_CHANGE",
              "description": "onTabChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BACK",
                "name": "Back",
                "description": "Event to emit when back is clicked (default: BACK)",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TAB_CHANGE",
                "name": "Tab Change",
                "description": "onTabChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageHeaderItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "status": "@config.status",
                      "actions": "@config.actions",
                      "isLoading": "@config.isLoading",
                      "type": "page-header",
                      "backEvent": "BACK",
                      "tabs": "@config.tabs",
                      "title": "@config.title",
                      "onTabChange": "TAB_CHANGE",
                      "className": "@config.className",
                      "showBack": "@config.showBack",
                      "subtitle": "@config.subtitle",
                      "breadcrumbs": "@config.breadcrumbs",
                      "children": [
                        {
                          "type": "text",
                          "content": "Sample content"
                        }
                      ],
                      "activeTab": "@config.activeTab",
                      "entity": "PageHeaderItem",
                      "error": "@config.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "showBack": {
              "type": "boolean",
              "default": false,
              "label": "Show Back",
              "description": "Show back button",
              "tier": "presentation"
            },
            "error": {
              "type": "PageHeaderError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "tabs": {
              "type": "[PageHeaderTabsItem]",
              "default": [],
              "label": "Tabs",
              "description": "Tabs for sub-navigation",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  },
                  "count": {
                    "name": "count",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "json",
              "label": "Title",
              "description": "Page title - accepts unknown to handle generated code accessing dynamic entity data",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "breadcrumbs": {
              "type": "[PageHeaderBreadcrumbsItem]",
              "default": [],
              "label": "Breadcrumbs",
              "description": "Breadcrumbs",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "subtitle": {
              "type": "json",
              "label": "Subtitle",
              "description": "Optional subtitle/description",
              "tier": "presentation"
            },
            "status": {
              "type": "PageHeaderStatus",
              "label": "Status",
              "description": "Status badge",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "success",
                    "warning",
                    "danger",
                    "info"
                  ]
                }
              }
            },
            "actions": {
              "type": "[PageHeaderActionsItem]",
              "default": [],
              "label": "Actions",
              "description": "Actions array - first action with variant='primary' (or first action) is the main action",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "loading": {
                    "name": "loading",
                    "type": "boolean",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  }
                }
              }
            },
            "activeTab": {
              "type": "string",
              "default": "",
              "label": "Active Tab",
              "description": "activeTab prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PageHeaderPage",
          "path": "/page-header",
          "traits": [
            {
              "ref": "PageHeaderRender"
            }
          ]
        }
      ]
    }
  ]
}