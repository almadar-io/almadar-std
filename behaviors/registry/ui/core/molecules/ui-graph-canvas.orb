{
  "name": "ui-graph-canvas",
  "version": "1.0.0",
  "description": "GraphCanvas — UI factory (1:1 with the @almadar/ui graph-canvas pattern).",
  "orbitals": [
    {
      "name": "GraphCanvasOrbital",
      "entity": {
        "name": "GraphCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GraphCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GraphCanvasItem",
          "emits": [
            {
              "event": "NODE_CLICK",
              "description": "On node click",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "node",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "x",
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "type": "number"
                    }
                  ]
                },
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NODE_CLICK",
                "name": "Node Click",
                "description": "On node click",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "node",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "x",
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "type": "number"
                      }
                    ]
                  },
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GraphCanvasItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "error": "@config.error",
                      "interactive": "@config.interactive",
                      "height": "@config.height",
                      "layout": "@config.layout",
                      "entity": "GraphCanvasItem",
                      "nodes": "@config.nodes",
                      "className": "@config.className",
                      "onNodeClick": "NODE_CLICK",
                      "edges": "@config.edges",
                      "nodeClickEvent": "NODE_CLICK",
                      "isLoading": "@config.isLoading",
                      "draggable": "@config.draggable",
                      "type": "graph-canvas",
                      "title": "@config.title",
                      "showLabels": "@config.showLabels",
                      "actions": "@config.actions"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Graph title",
              "tier": "presentation"
            },
            "showLabels": {
              "type": "boolean",
              "default": true,
              "label": "Show Labels",
              "description": "Show node labels",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "actions": {
              "type": "[GraphCanvasActionsItem]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Label",
                  "navigatesTo": "Navigates To"
                }
              ],
              "label": "Actions",
              "description": "Actions",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "error": {
              "type": "GraphCanvasError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "layout": {
              "type": "string",
              "default": "force",
              "label": "Layout",
              "description": "Layout algorithm",
              "tier": "presentation",
              "values": [
                "force",
                "circular",
                "grid"
              ]
            },
            "edges": {
              "type": "[GraphCanvasEdgesItem]",
              "default": [
                {
                  "source": "Source",
                  "label": "Label",
                  "color": "Color",
                  "target": "Target",
                  "weight": 1.0
                }
              ],
              "label": "Edges",
              "description": "Graph edges",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "weight": {
                    "name": "weight",
                    "type": "number",
                    "required": false
                  },
                  "target": {
                    "name": "target",
                    "type": "string",
                    "required": true
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "source": {
                    "name": "source",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "nodes": {
              "type": "[GraphCanvasNodesItem]",
              "default": [
                {
                  "x": 1.0,
                  "y": 1.0,
                  "id": "Id",
                  "group": "Group",
                  "size": 1.0,
                  "label": "Label",
                  "color": "Color"
                }
              ],
              "label": "Nodes",
              "description": "Graph nodes",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "size": {
                    "name": "size",
                    "type": "number",
                    "required": false
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "group": {
                    "name": "group",
                    "type": "string",
                    "required": false
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
            "interactive": {
              "type": "boolean",
              "default": true,
              "label": "Interactive",
              "description": "Enable zoom/pan",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 400.0,
              "label": "Height",
              "description": "Canvas height",
              "tier": "presentation"
            },
            "draggable": {
              "type": "boolean",
              "default": true,
              "label": "Draggable",
              "description": "Enable node dragging",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphCanvasPage",
          "path": "/graph-canvas",
          "traits": [
            {
              "ref": "GraphCanvasRender"
            }
          ]
        }
      ]
    }
  ]
}