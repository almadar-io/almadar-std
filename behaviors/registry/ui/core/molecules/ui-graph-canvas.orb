{
  "description": "GraphCanvas — UI factory (1:1 with the @almadar/ui graph-canvas pattern).",
  "name": "ui-graph-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GraphCanvasItem",
        "persistence": "runtime"
      },
      "name": "GraphCanvasOrbital",
      "pages": [
        {
          "name": "GraphCanvasPage",
          "path": "/graph-canvas",
          "traits": [
            {
              "ref": "GraphCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "default": [
                {
                  "label": "Label",
                  "navigatesTo": "Navigates To",
                  "variant": "primary"
                },
                {
                  "label": "Label 2",
                  "navigatesTo": "Navigates To 2",
                  "variant": "secondary"
                }
              ],
              "description": "Actions",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Actions",
              "tier": "presentation",
              "type": "[GraphCanvasActionsItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "draggable": {
              "default": true,
              "description": "Enable node dragging",
              "label": "Draggable",
              "tier": "presentation",
              "type": "boolean"
            },
            "edges": {
              "default": [
                {
                  "color": "Color",
                  "label": "Label",
                  "source": "Source",
                  "target": "Target",
                  "weight": 1.0
                },
                {
                  "color": "Color 2",
                  "label": "Label 2",
                  "source": "Source 2",
                  "target": "Target 2",
                  "weight": 2.0
                }
              ],
              "description": "Graph edges",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "source": {
                    "name": "source",
                    "required": true,
                    "type": "string"
                  },
                  "target": {
                    "name": "target",
                    "required": true,
                    "type": "string"
                  },
                  "weight": {
                    "name": "weight",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Edges",
              "tier": "presentation",
              "type": "[GraphCanvasEdgesItem]"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GraphCanvasError"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": true,
              "description": "Enable zoom/pan",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "layout": {
              "default": "force",
              "description": "Layout algorithm",
              "label": "Layout",
              "tier": "presentation",
              "type": "string",
              "values": [
                "force",
                "circular",
                "grid"
              ]
            },
            "linkDistance": {
              "default": 100.0,
              "description": "Force-sim target edge length (larger ⇒ more spread out)",
              "label": "Link Distance",
              "tier": "presentation",
              "type": "number"
            },
            "linkOpacity": {
              "default": 0.18,
              "description": "Base opacity for links when nothing is hovered (kept faint so dense graphs stay readable; incident links brighten on hover).",
              "label": "Link Opacity",
              "tier": "presentation",
              "type": "number"
            },
            "nodeClickEvent": {
              "default": "NODE_CLICK",
              "description": "Node click event",
              "label": "Node Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "nodeSpacing": {
              "default": 28.0,
              "description": "Minimum empty gap (px) enforced between node edges so nodes never overlap.",
              "label": "Node Spacing",
              "tier": "presentation",
              "type": "number"
            },
            "nodes": {
              "default": [
                {
                  "color": "Color",
                  "group": "Group",
                  "id": "Id",
                  "label": "Label",
                  "size": 1.0,
                  "x": 1.0,
                  "y": 1.0
                },
                {
                  "color": "Color 2",
                  "group": "Group 2",
                  "id": "Id 2",
                  "label": "Label 2",
                  "size": 2.0,
                  "x": 2.0,
                  "y": 2.0
                }
              ],
              "description": "Graph nodes",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "group": {
                    "name": "group",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "size": {
                    "name": "size",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": false,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "presentation",
              "type": "[GraphCanvasNodesItem]"
            },
            "onNodeClick": {
              "default": "NODE_CLICK",
              "description": "On node click",
              "label": "On Node Click",
              "tier": "presentation",
              "type": "string"
            },
            "onNodeDoubleClick": {
              "default": "NODE_DOUBLE_CLICK",
              "description": "On node double-click (e.g. to drill in)",
              "label": "On Node Double Click",
              "tier": "presentation",
              "type": "string"
            },
            "repulsion": {
              "default": 800.0,
              "description": "Force-sim repulsion strength between nodes (larger ⇒ more spread out)",
              "label": "Repulsion",
              "tier": "presentation",
              "type": "number"
            },
            "selectedNodeId": {
              "default": "Selected Node Id",
              "description": "Currently selected node id (rendered emphasized)",
              "label": "Selected Node Id",
              "tier": "presentation",
              "type": "string"
            },
            "showLabels": {
              "default": true,
              "description": "Show node labels",
              "label": "Show Labels",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Title",
              "description": "Graph title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "On node click",
              "event": "@config.onNodeClick",
              "payloadSchema": [
                {
                  "name": "node",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "x",
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "type": "number"
                    }
                  ],
                  "type": "object"
                },
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "On node double-click (e.g. to drill in)",
              "event": "@config.onNodeDoubleClick",
              "payloadSchema": [
                {
                  "name": "node",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "group",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "x",
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "type": "number"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GraphCanvasItem",
          "name": "GraphCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "On node click",
                "key": "@config.onNodeClick",
                "name": "@config.on node click",
                "payloadSchema": [
                  {
                    "name": "node",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "x",
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  },
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "On node double-click (e.g. to drill in)",
                "key": "@config.onNodeDoubleClick",
                "name": "@config.on node double click",
                "payloadSchema": [
                  {
                    "name": "node",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "group",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "size",
                        "type": "number"
                      },
                      {
                        "name": "x",
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "className": "@config.className",
                      "draggable": "@config.draggable",
                      "edges": "@config.edges",
                      "error": "@config.error",
                      "height": "@config.height",
                      "interactive": "@config.interactive",
                      "isLoading": "@config.isLoading",
                      "layout": "@config.layout",
                      "linkDistance": "@config.linkDistance",
                      "linkOpacity": "@config.linkOpacity",
                      "nodeClickEvent": "@config.nodeClickEvent",
                      "nodeSpacing": "@config.nodeSpacing",
                      "nodes": "@config.nodes",
                      "onNodeClick": "@config.onNodeClick",
                      "onNodeDoubleClick": "@config.onNodeDoubleClick",
                      "repulsion": "@config.repulsion",
                      "selectedNodeId": "@config.selectedNodeId",
                      "showLabels": "@config.showLabels",
                      "title": "@config.title",
                      "type": "graph-canvas"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}