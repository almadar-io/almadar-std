                "id": "evt_01KXG04QXZ8YG6WJY152V7BH8P",
                "key": "@config.onChange",
                "name": "@config.on change",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "RichBlockEditorItem",
                    {
                      "emit": {
