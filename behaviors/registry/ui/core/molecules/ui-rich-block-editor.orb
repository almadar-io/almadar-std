{
  "name": "ui-rich-block-editor",
  "version": "1.0.0",
  "description": "RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern).",
  "orbitals": [
    {
      "name": "RichBlockEditorOrbital",
      "entity": {
        "name": "RichBlockEditorItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "RichBlockEditorRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "RichBlockEditorItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "onChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "onChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RichBlockEditorItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "placeholder": "@config.placeholder",
                      "changeEvent": "CHANGE",
                      "enableBlocks": "@config.enableBlocks",
                      "readOnly": "@config.readOnly",
                      "onChange": "CHANGE",
                      "type": "rich-block-editor",
                      "className": "@config.className",
                      "showToolbar": "@config.showToolbar",
                      "initialBlocks": "@entity"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "placeholder": {
              "type": "string",
              "default": "Placeholder",
              "label": "Placeholder",
              "description": "placeholder prop",
              "tier": "presentation"
            },
            "enableBlocks": {
              "type": "boolean",
              "default": false,
              "label": "Enable Blocks",
              "description": "Opt-in to the Notion-style block authoring chrome (insert toolbar, per-row +/menu gutter, turn-into menu). Off by default: the editor renders as a plain rich text surface that edits block content inline without any add-block affordances.",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "readOnly": {
              "type": "boolean",
              "default": false,
              "label": "Read Only",
              "description": "readOnly prop",
              "tier": "presentation"
            },
            "showToolbar": {
              "type": "boolean",
              "default": true,
              "label": "Show Toolbar",
              "description": "showToolbar prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RichBlockEditorPage",
          "path": "/rich-block-editor",
          "traits": [
            {
              "ref": "RichBlockEditorRender"
            }
          ]
        }
      ]
    }
  ]
}