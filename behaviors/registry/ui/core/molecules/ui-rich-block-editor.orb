{
  "description": "RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern).",
  "name": "ui-rich-block-editor",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "RichBlockEditorItem",
        "persistence": "runtime"
      },
      "name": "RichBlockEditorOrbital",
      "pages": [
        {
          "name": "RichBlockEditorPage",
          "path": "/rich-block-editor",
          "traits": [
            {
              "ref": "RichBlockEditorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "changeEvent": {
              "default": "CHANGE",
              "description": "changeEvent prop",
              "label": "Change Event",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "enableBlocks": {
              "default": true,
              "description": "Opt-in to the Notion-style block authoring chrome (insert toolbar, per-row +/menu gutter, turn-into menu). Off by default: the editor renders as a plain rich text surface that edits block content inline without any add-block affordances.",
              "label": "Enable Blocks",
              "tier": "presentation",
              "type": "boolean"
            },
            "onChange": {
              "default": "CHANGE",
              "description": "onChange prop",
              "label": "On Change",
              "tier": "presentation",
              "type": "string"
            },
            "placeholder": {
              "default": "Placeholder",
              "description": "placeholder prop",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "readOnly": {
              "default": false,
              "description": "readOnly prop",
              "label": "Read Only",
              "tier": "presentation",
              "type": "boolean"
            },
            "showToolbar": {
              "default": true,
              "description": "showToolbar prop",
              "label": "Show Toolbar",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "onChange prop",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "RichBlockEditor rows finished loading; payload.data holds the collection.",
              "event": "RichBlockEditorLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RichBlockEditorItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RichBlockEditorItem",
          "name": "RichBlockEditorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "RichBlockEditor rows finished loading; payload.data holds the collection.",
                "key": "RichBlockEditorLoaded",
                "name": "Rich block editor loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RichBlockEditorItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "onChange prop",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "RichBlockEditorItem",
                    {
                      "emit": {
                        "success": "RichBlockEditorLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "changeEvent": "@config.changeEvent",
                      "className": "@config.className",
                      "enableBlocks": "@config.enableBlocks",
                      "initialBlocks": "@entity",
                      "onChange": "@config.onChange",
                      "placeholder": "@config.placeholder",
                      "readOnly": "@config.readOnly",
                      "showToolbar": "@config.showToolbar",
                      "type": "rich-block-editor"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "changeEvent": "@config.changeEvent",
                      "className": "@config.className",
                      "enableBlocks": "@config.enableBlocks",
                      "initialBlocks": "@payload.data",
                      "onChange": "@config.onChange",
                      "placeholder": "@config.placeholder",
                      "readOnly": "@config.readOnly",
                      "showToolbar": "@config.showToolbar",
                      "type": "rich-block-editor"
                    }
                  ]
                ],
                "event": "RichBlockEditorLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}