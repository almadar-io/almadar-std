{
  "name": "ui-rich-block-editor",
  "version": "1.0.0",
  "description": "RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern).",
  "orbitals": [
    {
      "name": "RichBlockEditorOrbital",
      "entity": {
        "name": "RichBlockEditorItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "RichBlockEditorRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "RichBlockEditorItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "onChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "onChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "changeEvent": "CHANGE",
                      "initialBlocks": "@config.initialBlocks",
                      "onChange": "CHANGE",
                      "type": "rich-block-editor",
                      "showToolbar": "@config.showToolbar",
                      "placeholder": "@config.placeholder",
                      "readOnly": "@config.readOnly",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "readOnly": {
              "type": "boolean",
              "default": false,
              "label": "Read Only",
              "description": "readOnly prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "showToolbar": {
              "type": "boolean",
              "default": true,
              "label": "Show Toolbar",
              "description": "showToolbar prop",
              "tier": "presentation"
            },
            "placeholder": {
              "type": "string",
              "default": "",
              "label": "Placeholder",
              "description": "placeholder prop",
              "tier": "presentation"
            },
            "initialBlocks": {
              "type": "[RichBlockEditorInitialBlocksItem]",
              "default": [],
              "label": "Initial Blocks",
              "description": "Initial block payload. Accepts strongly-typed RichBlock[] from native callers and the wider EntityRow[] shape that orb-bound traits emit (orb `[object]` lowers to `Record<string, FieldValue | undefined>[]`, which is structurally EntityRow[]). Items missing id/type are normalized into paragraph blocks at mount.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true,
                    "values": [
                      "paragraph",
                      "heading-1",
                      "heading-2",
                      "heading-3",
                      "bullet-list",
                      "numbered-list",
                      "quote",
                      "code",
                      "divider",
                      "image"
                    ]
                  },
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": false
                  },
                  "metadata": {
                    "name": "metadata",
                    "type": "object",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "children": {
                    "name": "children",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RichBlockEditorPage",
          "path": "/rich-block-editor",
          "traits": [
            {
              "ref": "RichBlockEditorRender"
            }
          ]
        }
      ]
    }
  ]
}