{
  "name": "ui-code-block",
  "version": "1.0.0",
  "description": "CodeBlock — UI factory (1:1 with the @almadar/ui code-block pattern).",
  "orbitals": [
    {
      "name": "CodeBlockOrbital",
      "entity": {
        "name": "CodeBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CodeBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CodeBlockItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "maxHeight": "@config.maxHeight",
                      "foldable": "@config.foldable",
                      "showLanguageBadge": "@config.showLanguageBadge",
                      "code": "@config.code",
                      "onChange": "CHANGE",
                      "errorLines": "@config.errorLines",
                      "language": "@config.language",
                      "showCopyButton": "@config.showCopyButton",
                      "editable": "@config.editable",
                      "type": "code-block",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "code": {
              "type": "string",
              "default": "",
              "label": "Code",
              "description": "The code content to display",
              "tier": "presentation"
            },
            "foldable": {
              "type": "boolean",
              "default": false,
              "label": "Foldable",
              "description": "Enable brace-based code folding of multi-line `{}`/`[]` blocks (default: true).",
              "tier": "presentation"
            },
            "maxHeight": {
              "type": "string",
              "default": "60vh",
              "label": "Max Height",
              "description": "Maximum height before scrolling",
              "tier": "presentation"
            },
            "language": {
              "type": "string",
              "default": "text",
              "label": "Language",
              "description": "Programming language for syntax highlighting",
              "tier": "presentation"
            },
            "editable": {
              "type": "boolean",
              "default": false,
              "label": "Editable",
              "description": "When true, render an editable surface that composes a transparent `Textarea` over a Prism-highlighted overlay. The overlay re-tokenizes on each keystroke (driven from a local mirror of the textarea value), so users see syntax-highlighted code while still being able to type. Folding is skipped in editable mode. History: GAP-51 first-cut shipped plain (no-highlighting) editable text; GAP-77 (2026-04-12) added the Prism overlay layer. Default: false (existing read-only behavior unchanged).",
              "tier": "presentation"
            },
            "errorLines": {
              "type": "json",
              "label": "Error Lines",
              "description": "GAP-80: line-level error/warning highlights for editable mode. Map of 1-based line number → severity. The overlay paints a colored background on each line: error = red, warning = yellow. Pass undefined (default) to disable. The consumer is responsible for computing the path → line map from the schema + validation results.",
              "tier": "presentation"
            },
            "showLanguageBadge": {
              "type": "boolean",
              "default": true,
              "label": "Show Language Badge",
              "description": "Show the language badge",
              "tier": "presentation"
            },
            "showCopyButton": {
              "type": "boolean",
              "default": true,
              "label": "Show Copy Button",
              "description": "Show the copy button",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CodeBlockPage",
          "path": "/code-block",
          "traits": [
            {
              "ref": "CodeBlockRender"
            }
          ]
        }
      ]
    }
  ]
}