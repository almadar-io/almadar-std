{
  "name": "ui-code-block",
  "version": "1.0.0",
  "description": "CodeBlock — UI factory (1:1 with the @almadar/ui code-block pattern).",
  "orbitals": [
    {
      "name": "CodeBlockOrbital",
      "entity": {
        "name": "CodeBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "default": "Code"
          }
        ]
      },
      "traits": [
        {
          "name": "CodeBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "code"
            ]
          },
          "category": "interaction",
          "linkedEntity": "CodeBlockItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.code",
                    "@config.code"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "editable": "@config.editable",
                      "error": "@config.error",
                      "newValue": "@config.newValue",
                      "showLineNumbers": "@config.showLineNumbers",
                      "files": "@config.files",
                      "maxHeight": "@config.maxHeight",
                      "actions": "@config.actions",
                      "showLanguageBadge": "@config.showLanguageBadge",
                      "onChange": "CHANGE",
                      "mode": "@config.mode",
                      "diff": "@config.diff",
                      "wordWrap": "@config.wordWrap",
                      "isLoading": "@config.isLoading",
                      "language": "@config.language",
                      "showCopy": "@config.showCopy",
                      "title": "@config.title",
                      "type": "code-block",
                      "className": "@config.className",
                      "foldable": "@config.foldable",
                      "showCopyButton": "@config.showCopyButton",
                      "oldValue": "@config.oldValue",
                      "code": "@entity.code"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.code",
                    "@payload.code"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "mode": "@config.mode",
                      "showLineNumbers": "@config.showLineNumbers",
                      "showLanguageBadge": "@config.showLanguageBadge",
                      "diff": "@config.diff",
                      "files": "@config.files",
                      "oldValue": "@config.oldValue",
                      "newValue": "@config.newValue",
                      "onChange": "CHANGE",
                      "actions": "@config.actions",
                      "foldable": "@config.foldable",
                      "language": "@config.language",
                      "editable": "@config.editable",
                      "showCopyButton": "@config.showCopyButton",
                      "code": "@entity.code",
                      "title": "@config.title",
                      "maxHeight": "@config.maxHeight",
                      "wordWrap": "@config.wordWrap",
                      "showCopy": "@config.showCopy",
                      "type": "code-block",
                      "isLoading": "@config.isLoading",
                      "className": "@config.className",
                      "error": "@config.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "error": {
              "type": "CodeBlockError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "showLineNumbers": {
              "type": "boolean",
              "default": false,
              "label": "Show Line Numbers",
              "description": "Show line numbers in code / diff mode",
              "tier": "presentation"
            },
            "mode": {
              "type": "string",
              "default": "code",
              "label": "Mode",
              "description": "Diff or plain-code display mode",
              "tier": "presentation",
              "values": [
                "code",
                "diff"
              ]
            },
            "foldable": {
              "type": "boolean",
              "default": false,
              "label": "Foldable",
              "description": "Enable brace-based code folding of multi-line `{}`/`[]` blocks (default: true).",
              "tier": "presentation"
            },
            "showCopyButton": {
              "type": "boolean",
              "default": true,
              "label": "Show Copy Button",
              "description": "Show the copy button",
              "tier": "presentation"
            },
            "code": {
              "type": "string",
              "default": "Code",
              "label": "Code",
              "description": "The code content to display",
              "tier": "presentation"
            },
            "maxHeight": {
              "type": "string",
              "default": "60vh",
              "label": "Max Height",
              "description": "Maximum height before scrolling",
              "tier": "presentation"
            },
            "showLanguageBadge": {
              "type": "boolean",
              "default": true,
              "label": "Show Language Badge",
              "description": "Show the language badge",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "files": {
              "type": "[CodeBlockFilesItem]",
              "default": [
                {
                  "language": "text",
                  "code": "Code",
                  "label": "Label"
                }
              ],
              "label": "Files",
              "description": "Multiple files shown as tabs",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": true
                  },
                  "language": {
                    "name": "language",
                    "type": "string",
                    "required": false,
                    "values": [
                      "text",
                      "json",
                      "javascript",
                      "js",
                      "typescript",
                      "ts",
                      "jsx",
                      "tsx",
                      "css",
                      "markdown",
                      "md",
                      "bash",
                      "shell",
                      "sh",
                      "yaml",
                      "yml",
                      "rust",
                      "python",
                      "py",
                      "sql",
                      "diff",
                      "toml",
                      "go",
                      "graphql",
                      "html",
                      "xml",
                      "orb",
                      "lolo"
                    ]
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "oldValue": {
              "type": "string",
              "default": "Old Value",
              "label": "Old Value",
              "description": "Old source text — generates diff when combined with newValue",
              "tier": "presentation"
            },
            "showCopy": {
              "type": "boolean",
              "default": false,
              "label": "Show Copy",
              "description": "Show copy button (viewer alias for showCopyButton)",
              "tier": "presentation"
            },
            "actions": {
              "type": "[CodeBlockActionsItem]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Label",
                  "navigatesTo": "Navigates To"
                }
              ],
              "label": "Actions",
              "description": "Action badges in the toolbar",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "wordWrap": {
              "type": "boolean",
              "default": false,
              "label": "Word Wrap",
              "description": "Enable word-wrap in code / diff mode",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "── Viewer props (absorbed from CodeViewer / DocCodeBlock) ────────────────",
              "tier": "presentation"
            },
            "newValue": {
              "type": "string",
              "default": "New Value",
              "label": "New Value",
              "description": "New source text — generates diff when combined with oldValue",
              "tier": "presentation"
            },
            "language": {
              "type": "string",
              "default": "text",
              "label": "Language",
              "description": "Programming language for syntax highlighting",
              "tier": "presentation",
              "values": [
                "text",
                "json",
                "javascript",
                "js",
                "typescript",
                "ts",
                "jsx",
                "tsx",
                "css",
                "markdown",
                "md",
                "bash",
                "shell",
                "sh",
                "yaml",
                "yml",
                "rust",
                "python",
                "py",
                "sql",
                "diff",
                "toml",
                "go",
                "graphql",
                "html",
                "xml",
                "orb",
                "lolo"
              ]
            },
            "editable": {
              "type": "boolean",
              "default": false,
              "label": "Editable",
              "description": "When true, render an editable surface that composes a transparent `Textarea` over a Prism-highlighted overlay. The overlay re-tokenizes on each keystroke (driven from a local mirror of the textarea value), so users see syntax-highlighted code while still being able to type. Folding is skipped in editable mode. History: GAP-51 first-cut shipped plain (no-highlighting) editable text; GAP-77 (2026-04-12) added the Prism overlay layer. Default: false (existing read-only behavior unchanged).",
              "tier": "presentation"
            },
            "diff": {
              "type": "[CodeBlockDiffItem]",
              "default": [
                {
                  "afterLineNumber": 1.0,
                  "type": "added",
                  "content": "Content",
                  "beforeLineNumber": 1.0
                }
              ],
              "label": "Diff",
              "description": "Pre-computed diff lines",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "beforeLineNumber": {
                    "name": "beforeLineNumber",
                    "type": "number",
                    "required": false
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true,
                    "values": [
                      "added",
                      "removed",
                      "unchanged",
                      "context"
                    ]
                  },
                  "afterLineNumber": {
                    "name": "afterLineNumber",
                    "type": "number",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CodeBlockPage",
          "path": "/code-block",
          "traits": [
            {
              "ref": "CodeBlockRender"
            }
          ]
        }
      ]
    }
  ]
}