{
  "name": "ui-quest-tracker",
  "version": "1.0.0",
  "description": "QuestTracker — UI factory (1:1 with the @almadar/ui quest-tracker pattern).",
  "orbitals": [
    {
      "name": "QuestTrackerOrbital",
      "entity": {
        "name": "QuestTrackerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "QuestTrackerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "QuestTrackerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "quests": "@config.quests",
                      "activeQuestId": "@config.activeQuestId",
                      "type": "quest-tracker"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "activeQuestId": {
              "type": "string",
              "default": "",
              "label": "Active Quest Id",
              "description": "ID of the currently active quest",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "quests": {
              "type": "[QuestTrackerQuestsItem]",
              "default": [
                {
                  "title": "Title",
                  "id": "Id",
                  "maxProgress": 1.0,
                  "progress": 1.0
                }
              ],
              "label": "Quests",
              "description": "Array of quests to display",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "maxProgress": {
                    "name": "maxProgress",
                    "type": "number",
                    "required": true
                  },
                  "progress": {
                    "name": "progress",
                    "type": "number",
                    "required": true
                  },
                  "completed": {
                    "name": "completed",
                    "type": "boolean",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "active": {
                    "name": "active",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "QuestTrackerPage",
          "path": "/quest-tracker",
          "traits": [
            {
              "ref": "QuestTrackerRender"
            }
          ]
        }
      ]
    }
  ]
}