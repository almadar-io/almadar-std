{
  "name": "ui-activation-block",
  "version": "1.0.0",
  "description": "ActivationBlock — UI factory (1:1 with the @almadar/ui activation-block pattern).",
  "orbitals": [
    {
      "name": "ActivationBlockOrbital",
      "entity": {
        "name": "ActivationBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ActivationBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ActivationBlockItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "activation-block",
                      "question": "@config.question",
                      "savedResponse": "@config.savedResponse",
                      "saveEvent": "@config.saveEvent",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "savedResponse": {
              "type": "string",
              "default": "Saved Response",
              "label": "Saved Response",
              "description": "Pre-filled response from saved state",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "question": {
              "type": "string",
              "default": "Question",
              "label": "Question",
              "description": "The prior-knowledge question",
              "tier": "presentation"
            },
            "saveEvent": {
              "type": "string",
              "default": "SAVE_ACTIVATION",
              "label": "Save Event",
              "description": "Event name emitted on save/skip (as `UI:<saveEvent>`). Defaults to 'SAVE_ACTIVATION'.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ActivationBlockPage",
          "path": "/activation-block",
          "traits": [
            {
              "ref": "ActivationBlockRender"
            }
          ]
        }
      ]
    }
  ]
}