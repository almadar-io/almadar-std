{
  "description": "Split — UI factory (1:1 with the @almadar/ui split pattern).",
  "name": "ui-split",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SplitItem",
        "persistence": "runtime"
      },
      "name": "SplitOrbital",
      "pages": [
        {
          "name": "SplitPage",
          "path": "/split",
          "traits": [
            {
              "ref": "SplitRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "align": {
              "default": "stretch",
              "description": "Align items vertically",
              "label": "Align",
              "tier": "presentation",
              "type": "string",
              "values": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            },
            "children": {
              "default": [
                {
                  "content": "Panel A",
                  "type": "typography"
                },
                {
                  "content": "Panel B",
                  "type": "typography"
                }
              ],
              "description": "Exactly two children: [left, right]",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Custom class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SplitError"
            },
            "gap": {
              "default": "md",
              "description": "Gap between panels",
              "label": "Gap",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "leftClassName": {
              "default": "Left Class Name",
              "description": "Left/first panel class name",
              "label": "Left Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "ratio": {
              "default": "1:1",
              "description": "Size ratio between left and right panels",
              "label": "Ratio",
              "tier": "presentation",
              "type": "string",
              "values": [
                "1:1",
                "1:2",
                "2:1",
                "1:3",
                "3:1",
                "1:4",
                "4:1",
                "2:3",
                "3:2"
              ]
            },
            "reverse": {
              "default": false,
              "description": "Reverse the order (right first)",
              "label": "Reverse",
              "tier": "presentation",
              "type": "boolean"
            },
            "rightClassName": {
              "default": "Right Class Name",
              "description": "Right/second panel class name",
              "label": "Right Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "stackBreakpoint": {
              "default": "md",
              "description": "Breakpoint to switch from stacked to side-by-side",
              "label": "Stack Breakpoint",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "stackOnMobile": {
              "default": true,
              "description": "Stack vertically on mobile",
              "label": "Stack On Mobile",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SplitItem",
          "name": "SplitRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "@config.align",
                      "children": "@config.children",
                      "className": "@config.className",
                      "error": "@config.error",
                      "gap": "@config.gap",
                      "isLoading": "@config.isLoading",
                      "leftClassName": "@config.leftClassName",
                      "ratio": "@config.ratio",
                      "reverse": "@config.reverse",
                      "rightClassName": "@config.rightClassName",
                      "stackBreakpoint": "@config.stackBreakpoint",
                      "stackOnMobile": "@config.stackOnMobile",
                      "type": "split"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}