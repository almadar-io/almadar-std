{
  "description": "Sidebar — UI factory (1:1 with the @almadar/ui sidebar pattern).",
  "name": "ui-sidebar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": false,
            "name": "collapsed",
            "type": "boolean"
          }
        ],
        "name": "SidebarItem",
        "persistence": "runtime"
      },
      "name": "SidebarOrbital",
      "pages": [
        {
          "name": "SidebarPage",
          "path": "/sidebar",
          "traits": [
            {
              "ref": "SidebarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "brandName": {
              "default": "KFlow",
              "description": "Brand/App name",
              "label": "Brand Name",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "collapsed": {
              "default": false,
              "description": "Collapsed state (controlled)",
              "label": "Collapsed",
              "tier": "presentation",
              "type": "boolean"
            },
            "defaultCollapsed": {
              "default": false,
              "description": "Default collapsed state",
              "label": "Default Collapsed",
              "tier": "presentation",
              "type": "boolean"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SidebarError"
            },
            "footerContent": {
              "description": "Footer content (e.g., theme toggle)",
              "label": "Footer Content",
              "tier": "presentation",
              "type": "node"
            },
            "hideCollapseButton": {
              "default": false,
              "description": "Hide the collapse/expand button",
              "label": "Hide Collapse Button",
              "tier": "presentation",
              "type": "boolean"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "items": {
              "default": [
                {
                  "active": false,
                  "badge": "Badge",
                  "href": "Href",
                  "icon": "circle",
                  "id": "Id",
                  "isActive": false,
                  "label": "Label",
                  "subItems": []
                },
                {
                  "active": true,
                  "badge": "Badge 2",
                  "href": "Href 2",
                  "icon": "circle",
                  "id": "Id 2",
                  "isActive": true,
                  "label": "Label 2",
                  "subItems": []
                }
              ],
              "description": "Navigation items",
              "items": {
                "properties": {
                  "active": {
                    "name": "active",
                    "required": false,
                    "type": "boolean"
                  },
                  "badge": {
                    "name": "badge",
                    "required": false,
                    "type": "string"
                  },
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "isActive": {
                    "name": "isActive",
                    "required": false,
                    "type": "boolean"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "subItems": {
                    "items": {
                      "type": "string"
                    },
                    "name": "subItems",
                    "required": false,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[SidebarItemsItem]"
            },
            "logoSrc": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
              "description": "Logo image source",
              "label": "Logo Src",
              "tier": "presentation",
              "type": "asset"
            },
            "showCloseButton": {
              "default": false,
              "description": "Show a close button (for mobile)",
              "label": "Show Close Button",
              "tier": "presentation",
              "type": "boolean"
            },
            "userSection": {
              "description": "User section content",
              "label": "User Section",
              "tier": "presentation",
              "type": "node"
            }
          },
          "emits": [
            {
              "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
              "event": "COLLAPSE_CHANGE",
              "payloadSchema": [
                {
                  "name": "collapsed",
                  "required": true,
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted when close button is clicked",
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Event emitted when logo/brand is clicked",
              "event": "LOGO_CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "collapsed"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SidebarItem",
          "name": "SidebarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
                "key": "COLLAPSE_CHANGE",
                "name": "Collapse Change",
                "payloadSchema": [
                  {
                    "name": "collapsed",
                    "required": true,
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted when close button is clicked",
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Event emitted when logo/brand is clicked",
                "key": "LOGO_CLICK",
                "name": "Logo Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.collapsed",
                    "@config.collapsed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "brandName": "@config.brandName",
                      "className": "@config.className",
                      "closeEvent": "CLOSE",
                      "collapseChangeEvent": "COLLAPSE_CHANGE",
                      "collapsed": "@entity.collapsed",
                      "defaultCollapsed": "@config.defaultCollapsed",
                      "error": "@config.error",
                      "footerContent": "@config.footerContent",
                      "hideCollapseButton": "@config.hideCollapseButton",
                      "isLoading": "@config.isLoading",
                      "items": "@config.items",
                      "logo": [
                        {
                          "content": "Logo",
                          "type": "typography"
                        }
                      ],
                      "logoClickEvent": "LOGO_CLICK",
                      "logoSrc": "@config.logoSrc",
                      "showCloseButton": "@config.showCloseButton",
                      "type": "sidebar",
                      "userSection": "@config.userSection"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.collapsed",
                    "@payload.collapsed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "brandName": "@config.brandName",
                      "className": "@config.className",
                      "closeEvent": "CLOSE",
                      "collapseChangeEvent": "COLLAPSE_CHANGE",
                      "collapsed": "@entity.collapsed",
                      "defaultCollapsed": "@config.defaultCollapsed",
                      "error": "@config.error",
                      "footerContent": "@config.footerContent",
                      "hideCollapseButton": "@config.hideCollapseButton",
                      "isLoading": "@config.isLoading",
                      "items": "@config.items",
                      "logo": [
                        {
                          "content": "Logo",
                          "type": "typography"
                        }
                      ],
                      "logoClickEvent": "LOGO_CLICK",
                      "logoSrc": "@config.logoSrc",
                      "showCloseButton": "@config.showCloseButton",
                      "type": "sidebar",
                      "userSection": "@config.userSection"
                    }
                  ]
                ],
                "event": "COLLAPSE_CHANGE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}