{
  "description": "SocialProof — UI factory (1:1 with the @almadar/ui social-proof pattern).",
  "name": "ui-social-proof",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SocialProofItem",
        "persistence": "runtime"
      },
      "name": "SocialProofOrbital",
      "pages": [
        {
          "name": "SocialProofPage",
          "path": "/social-proof",
          "traits": [
            {
              "ref": "SocialProofRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "logo": "Logo",
                  "name": "Name",
                  "quote": "Quote"
                },
                {
                  "logo": "Logo 2",
                  "name": "Name 2",
                  "quote": "Quote 2"
                }
              ],
              "description": "List of social proof items",
              "items": {
                "properties": {
                  "logo": {
                    "name": "logo",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "quote": {
                    "name": "quote",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[SocialProofItemsItem]"
            },
            "variant": {
              "default": "logos",
              "description": "Display variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "logos",
                "quotes",
                "badges"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SocialProofItem",
          "name": "SocialProofRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "items": "@config.items",
                      "type": "social-proof",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}