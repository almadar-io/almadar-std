{
  "description": "Chart — UI factory (1:1 with the @almadar/ui chart pattern).",
  "name": "ui-chart",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ChartItem",
        "persistence": "runtime"
      },
      "name": "ChartOrbital",
      "pages": [
        {
          "name": "ChartPage",
          "path": "/chart",
          "traits": [
            {
              "ref": "ChartRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "default": [
                {
                  "label": "Label",
                  "navigatesTo": "Navigates To",
                  "variant": "primary"
                },
                {
                  "label": "Label 2",
                  "navigatesTo": "Navigates To 2",
                  "variant": "secondary"
                }
              ],
              "description": "Top-level chart actions (export, refresh, etc.)",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Actions",
              "tier": "presentation",
              "type": "[ChartActionsItem]"
            },
            "chartType": {
              "default": "bar",
              "description": "Chart type (legacy alias for `look`).",
              "label": "Chart Type",
              "synonyms": "chart style, graph type, bar chart, line chart, pie chart, area chart, donut chart, scatter plot, histogram",
              "tier": "domain",
              "type": "string",
              "values": [
                "bar",
                "line",
                "pie",
                "area",
                "donut",
                "scatter",
                "histogram"
              ]
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "data": {
              "default": [
                {
                  "color": "Color",
                  "label": "Label",
                  "value": 1.0
                },
                {
                  "color": "Color 2",
                  "label": "Label 2",
                  "value": 2.0
                }
              ],
              "description": "Simple single-series shorthand (bar/line/pie/area/donut/histogram)",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Data",
              "tier": "presentation",
              "type": "[ChartDataItem]"
            },
            "drillEvent": {
              "default": "Drill Event",
              "description": "Event name emitted as `UI:{drillEvent}` with `{ label, value, seriesLabel? }` on data-point click",
              "label": "Drill Event",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ChartError"
            },
            "height": {
              "default": 200.0,
              "description": "Chart height in px",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "look": {
              "default": "bar-vertical",
              "description": "Layer 2 visual treatment — drives the chart sub-renderer (bar / line / pie / etc.).",
              "label": "Look",
              "synonyms": "chart style, render style, visual treatment",
              "tier": "presentation",
              "type": "string",
              "values": [
                "bar-vertical",
                "bar-horizontal",
                "line",
                "area",
                "pie",
                "donut",
                "scatter",
                "histogram"
              ]
            },
            "scatterData": {
              "default": [
                {
                  "color": "Color",
                  "label": "Label",
                  "size": 1.0,
                  "x": 1.0,
                  "y": 1.0
                },
                {
                  "color": "Color 2",
                  "label": "Label 2",
                  "size": 2.0,
                  "x": 2.0,
                  "y": 2.0
                }
              ],
              "description": "Raw {x,y} points for scatter",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "size": {
                    "name": "size",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Scatter Data",
              "tier": "presentation",
              "type": "[ChartScatterDataItem]"
            },
            "series": {
              "default": [
                {
                  "color": "Color",
                  "dashed": false,
                  "data": [
                    {
                      "color": "Color",
                      "label": "Label",
                      "value": 1.0
                    },
                    {
                      "color": "Color 2",
                      "label": "Label 2",
                      "value": 2.0
                    }
                  ],
                  "name": "Name"
                },
                {
                  "color": "Color 2",
                  "dashed": true,
                  "data": [
                    {
                      "color": "Color",
                      "label": "Label",
                      "value": 1.0
                    },
                    {
                      "color": "Color 2",
                      "label": "Label 2",
                      "value": 2.0
                    }
                  ],
                  "name": "Name 2"
                }
              ],
              "description": "Multi-series data",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "dashed": {
                    "name": "dashed",
                    "required": false,
                    "type": "boolean"
                  },
                  "data": {
                    "items": {
                      "properties": {
                        "color": {
                          "name": "color",
                          "required": false,
                          "type": "string"
                        },
                        "label": {
                          "name": "label",
                          "required": true,
                          "type": "string"
                        },
                        "value": {
                          "name": "value",
                          "required": true,
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "name": "data",
                    "required": true,
                    "type": "array"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Series",
              "tier": "presentation",
              "type": "[ChartSeriesItem]"
            },
            "showLegend": {
              "default": true,
              "description": "Show legend",
              "label": "Show Legend",
              "tier": "presentation",
              "type": "boolean"
            },
            "showValues": {
              "default": false,
              "description": "Show values on chart",
              "label": "Show Values",
              "tier": "presentation",
              "type": "boolean"
            },
            "stack": {
              "default": "none",
              "description": "Stack mode for bar / area",
              "label": "Stack",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "stack",
                "normalize"
              ]
            },
            "subtitle": {
              "default": "Subtitle",
              "description": "Chart subtitle / description",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "timeAxis": {
              "default": false,
              "description": "Format X-axis labels as time (ISO date in → 'Mar 2026'-style label out)",
              "label": "Time Axis",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Title",
              "description": "Chart title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ChartItem",
          "name": "ChartRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "chartType": "@config.chartType",
                      "className": "@config.className",
                      "data": "@config.data",
                      "drillEvent": "@config.drillEvent",
                      "error": "@config.error",
                      "height": "@config.height",
                      "isLoading": "@config.isLoading",
                      "look": "@config.look",
                      "scatterData": "@config.scatterData",
                      "series": "@config.series",
                      "showLegend": "@config.showLegend",
                      "showValues": "@config.showValues",
                      "stack": "@config.stack",
                      "subtitle": "@config.subtitle",
                      "timeAxis": "@config.timeAxis",
                      "title": "@config.title",
                      "type": "chart"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}