{
  "name": "ui-stat-badge",
  "version": "1.0.0",
  "description": "StatBadge — UI factory (1:1 with the @almadar/ui stat-badge pattern).",
  "orbitals": [
    {
      "name": "StatBadgeOrbital",
      "entity": {
        "name": "StatBadgeItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StatBadgeRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StatBadgeItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "@config.label",
                      "size": "@config.size",
                      "field": "@config.field",
                      "max": "@config.max",
                      "format": "@config.format",
                      "value": "@config.value",
                      "source": "@config.source",
                      "type": "stat-badge",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "variant": "@config.variant"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "field": {
              "type": "string",
              "default": "",
              "label": "Field",
              "description": "Field name in the source (for schema config)",
              "tier": "presentation"
            },
            "icon": {
              "type": "node",
              "label": "Icon",
              "description": "Icon component or emoji",
              "tier": "presentation"
            },
            "source": {
              "type": "string",
              "default": "",
              "label": "Source",
              "description": "Data source entity name (for schema config)",
              "tier": "presentation"
            },
            "value": {
              "type": "string",
              "default": "",
              "label": "Value",
              "description": "Current value (defaults to 0 if not provided)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "max": {
              "type": "number",
              "default": 0.0,
              "label": "Max",
              "description": "Maximum value (for bar/hearts format)",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Visual variant",
              "tier": "presentation"
            },
            "format": {
              "type": "string",
              "default": "number",
              "label": "Format",
              "description": "Display format",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "Stat label",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatBadgePage",
          "path": "/stat-badge",
          "traits": [
            {
              "ref": "StatBadgeRender"
            }
          ]
        }
      ]
    }
  ]
}