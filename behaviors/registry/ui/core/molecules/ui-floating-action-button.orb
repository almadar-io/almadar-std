{
  "name": "ui-floating-action-button",
  "version": "1.0.0",
  "description": "FloatingActionButton — UI factory (1:1 with the @almadar/ui floating-action-button pattern).",
  "orbitals": [
    {
      "name": "FloatingActionButtonOrbital",
      "entity": {
        "name": "FloatingActionButtonItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FloatingActionButtonRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FloatingActionButtonItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name. When set, clicking the FAB emits `UI:{action}` via the event bus and (if also provided) calls `onClick`. Mirrors the Button atom's `action` prop so schemas can write `{ type: 'floating-action-button', action: 'INIT' }` uniformly.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLICK",
              "description": "Optional direct click handler. Runs after the action emit when both are present.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name. When set, clicking the FAB emits `UI:{action}` via the event bus and (if also provided) calls `onClick`. Mirrors the Button atom's `action` prop so schemas can write `{ type: 'floating-action-button', action: 'INIT' }` uniformly.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Optional direct click handler. Runs after the action emit when both are present.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actionPayload": "@config.actionPayload",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "position": "@config.position",
                      "variant": "@config.variant",
                      "type": "floating-action-button",
                      "label": "@config.label",
                      "action": "ACTION",
                      "onClick": "CLICK",
                      "actions": "@config.actions"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "actionPayload": {
              "type": "json",
              "default": {},
              "label": "Action Payload",
              "description": "Payload to include with the dispatched action event.",
              "tier": "presentation"
            },
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Icon name (resolves to a Lucide icon by PascalCase / kebab-case lookup).",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Optional label shown via `aria-label` (visually hidden in single-action mode; rendered as a tooltip beside expanded actions in multi-action mode).",
              "tier": "presentation"
            },
            "position": {
              "type": "string",
              "default": "bottom-right",
              "label": "Position",
              "description": "Button position",
              "tier": "presentation",
              "values": [
                "bottom-right",
                "bottom-left",
                "bottom-center",
                "top-right",
                "top-left",
                "top-center"
              ]
            },
            "variant": {
              "type": "string",
              "default": "primary",
              "label": "Variant",
              "description": "Visual variant.",
              "tier": "presentation",
              "values": [
                "primary",
                "secondary",
                "success",
                "danger",
                "warning"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "actions": {
              "type": "[FloatingActionButtonActionsItem]",
              "default": [
                {
                  "icon": "circle",
                  "id": "Id",
                  "variant": "primary",
                  "label": "Label"
                }
              ],
              "label": "Actions",
              "description": "Multiple actions. When provided, the button expands to show all of them.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "success",
                      "danger",
                      "warning"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FloatingActionButtonPage",
          "path": "/floating-action-button",
          "traits": [
            {
              "ref": "FloatingActionButtonRender"
            }
          ]
        }
      ]
    }
  ]
}