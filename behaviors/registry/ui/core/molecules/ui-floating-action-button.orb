{
  "description": "FloatingActionButton — UI factory (1:1 with the @almadar/ui floating-action-button pattern).",
  "name": "ui-floating-action-button",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FloatingActionButtonItem",
        "persistence": "runtime"
      },
      "name": "FloatingActionButtonOrbital",
      "pages": [
        {
          "name": "FloatingActionButtonPage",
          "path": "/floating-action-button",
          "traits": [
            {
              "ref": "FloatingActionButtonRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actionPayload": {
              "default": {},
              "description": "Payload to include with the dispatched action event.",
              "label": "Action Payload",
              "tier": "presentation",
              "type": "json"
            },
            "actions": {
              "default": [
                {
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Multiple actions. When provided, the button expands to show all of them.",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": true,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "success",
                      "danger",
                      "warning"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Actions",
              "tier": "presentation",
              "type": "[FloatingActionButtonActionsItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Icon: a canonical icon name string (resolved by Button) or a Lucide component.",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Optional label shown via `aria-label` (visually hidden in single-action mode; rendered as a tooltip beside expanded actions in multi-action mode).",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "position": {
              "default": "bottom-right",
              "description": "Button position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "bottom-right",
                "bottom-left",
                "bottom-center",
                "top-right",
                "top-left",
                "top-center"
              ]
            },
            "variant": {
              "default": "primary",
              "description": "Visual variant.",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "primary",
                "secondary",
                "success",
                "danger",
                "warning"
              ]
            }
          },
          "emits": [
            {
              "description": "Declarative event name. When set, clicking the FAB emits `UI:{action}` via the event bus and (if also provided) calls `onClick`. Mirrors the Button atom's `action` prop so schemas can write `{ type: 'floating-action-button', action: 'INIT' }` uniformly.",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Optional direct click handler. Runs after the action emit when both are present.",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FloatingActionButtonItem",
          "name": "FloatingActionButtonRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event name. When set, clicking the FAB emits `UI:{action}` via the event bus and (if also provided) calls `onClick`. Mirrors the Button atom's `action` prop so schemas can write `{ type: 'floating-action-button', action: 'INIT' }` uniformly.",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Optional direct click handler. Runs after the action emit when both are present.",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "actionPayload": "@config.actionPayload",
                      "actions": "@config.actions",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "onClick": "CLICK",
                      "position": "@config.position",
                      "type": "floating-action-button",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}