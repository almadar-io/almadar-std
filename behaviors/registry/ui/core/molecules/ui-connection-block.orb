{
  "description": "ConnectionBlock — UI factory (1:1 with the @almadar/ui connection-block pattern).",
  "name": "ui-connection-block",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ConnectionBlockItem",
        "persistence": "runtime"
      },
      "name": "ConnectionBlockOrbital",
      "pages": [
        {
          "name": "ConnectionBlockPage",
          "path": "/connection-block",
          "traits": [
            {
              "ref": "ConnectionBlockRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "content": {
              "default": "Content",
              "description": "Markdown content summarising what the learner already knows",
              "label": "Content",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ConnectionBlockItem",
          "name": "ConnectionBlockRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "content": "@config.content",
                      "type": "connection-block"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}