{
  "name": "ui-connection-block",
  "version": "1.0.0",
  "description": "ConnectionBlock — UI factory (1:1 with the @almadar/ui connection-block pattern).",
  "orbitals": [
    {
      "name": "ConnectionBlockOrbital",
      "entity": {
        "name": "ConnectionBlockItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ConnectionBlockRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ConnectionBlockItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "connection-block",
                      "content": "@config.content",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "content": {
              "type": "string",
              "default": "Content",
              "label": "Content",
              "description": "Markdown content summarising what the learner already knows",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ConnectionBlockPage",
          "path": "/connection-block",
          "traits": [
            {
              "ref": "ConnectionBlockRender"
            }
          ]
        }
      ]
    }
  ]
}