{
  "name": "ui-flex",
  "version": "1.0.0",
  "description": "Flex — UI factory (1:1 with the @almadar/ui flex pattern).",
  "orbitals": [
    {
      "name": "FlexOrbital",
      "entity": {
        "name": "FlexItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FlexRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FlexItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "as": "@config.asProp",
                      "type": "flex",
                      "wrap": "@config.wrap",
                      "children": "@config.children",
                      "justify": "@config.justify",
                      "direction": "@config.direction",
                      "inline": "@config.inline",
                      "grow": "@config.grow",
                      "shrink": "@config.shrink",
                      "basis": "@config.basis",
                      "className": "@config.className",
                      "gap": "@config.gap",
                      "align": "@config.align"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Custom class name",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Children elements",
              "tier": "presentation"
            },
            "gap": {
              "type": "string",
              "default": "none",
              "label": "Gap",
              "description": "Gap between items",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "grow": {
              "type": "number",
              "default": 0.0,
              "label": "Grow",
              "description": "Flex grow",
              "tier": "presentation"
            },
            "shrink": {
              "type": "number",
              "default": 0.0,
              "label": "Shrink",
              "description": "Flex shrink",
              "tier": "presentation"
            },
            "inline": {
              "type": "boolean",
              "default": false,
              "label": "Inline",
              "description": "Inline flex",
              "tier": "presentation"
            },
            "asProp": {
              "type": "json",
              "label": "As",
              "description": "HTML element to render as",
              "synonyms": "as",
              "tier": "presentation"
            },
            "align": {
              "type": "string",
              "default": "stretch",
              "label": "Align",
              "description": "Align items",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "stretch",
                "baseline"
              ]
            },
            "direction": {
              "type": "string",
              "default": "row",
              "label": "Direction",
              "description": "Flex direction",
              "tier": "presentation",
              "values": [
                "row",
                "row-reverse",
                "col",
                "col-reverse"
              ]
            },
            "justify": {
              "type": "string",
              "default": "start",
              "label": "Justify",
              "description": "Justify content",
              "tier": "presentation",
              "values": [
                "start",
                "center",
                "end",
                "between",
                "around",
                "evenly"
              ]
            },
            "basis": {
              "type": "string",
              "default": "",
              "label": "Basis",
              "description": "Flex basis",
              "tier": "presentation"
            },
            "wrap": {
              "type": "string",
              "default": "nowrap",
              "label": "Wrap",
              "description": "Flex wrap",
              "tier": "presentation",
              "values": [
                "nowrap",
                "wrap",
                "wrap-reverse"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FlexPage",
          "path": "/flex",
          "traits": [
            {
              "ref": "FlexRender"
            }
          ]
        }
      ]
    }
  ]
}