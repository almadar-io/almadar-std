{
  "description": "RelationSelect — UI factory (1:1 with the @almadar/ui relation-select pattern).",
  "name": "ui-relation-select",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Value",
            "name": "value",
            "type": "string"
          }
        ],
        "name": "RelationSelectItem",
        "persistence": "runtime"
      },
      "name": "RelationSelectOrbital",
      "pages": [
        {
          "name": "RelationSelectPage",
          "path": "/relation-select",
          "traits": [
            {
              "ref": "RelationSelectRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "clearable": {
              "default": true,
              "description": "Allow clearing the selection",
              "label": "Clearable",
              "tier": "presentation",
              "type": "boolean"
            },
            "disabled": {
              "default": false,
              "description": "Whether the field is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "emptyMessage": {
              "default": "Empty Message",
              "description": "Empty state message",
              "label": "Empty Message",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "default": "",
              "description": "Error message",
              "label": "Error",
              "tier": "presentation",
              "type": "string"
            },
            "isLoading": {
              "default": false,
              "description": "Whether data is loading",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "name": {
              "default": "Name",
              "description": "Name attribute for forms",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            },
            "onChange": {
              "default": "CHANGE",
              "description": "Callback when value changes",
              "label": "On Change",
              "tier": "presentation",
              "type": "string"
            },
            "options": {
              "default": [
                {
                  "description": "Description",
                  "disabled": false,
                  "label": "Label",
                  "value": "Value"
                },
                {
                  "description": "Description 2",
                  "disabled": true,
                  "label": "Label 2",
                  "value": "Value 2"
                }
              ],
              "description": "Available options - accepts readonly for compatibility with generated const arrays",
              "items": {
                "properties": {
                  "description": {
                    "name": "description",
                    "required": false,
                    "type": "string"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Options",
              "tier": "presentation",
              "type": "[RelationSelectOptionsItem]"
            },
            "placeholder": {
              "default": "Placeholder",
              "description": "Placeholder text",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "required": {
              "default": false,
              "description": "Whether the field is required",
              "label": "Required",
              "tier": "presentation",
              "type": "boolean"
            },
            "searchPlaceholder": {
              "default": "Search Placeholder",
              "description": "Search placeholder",
              "label": "Search Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "value": {
              "default": "Value",
              "description": "Current value (ID)",
              "label": "Value",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when value changes",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "value"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RelationSelectItem",
          "name": "RelationSelectRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when value changes",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clearable": "@config.clearable",
                      "disabled": "@config.disabled",
                      "emptyMessage": "@config.emptyMessage",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "name": "@config.name",
                      "onChange": "@config.onChange",
                      "options": "@config.options",
                      "placeholder": "@config.placeholder",
                      "required": "@config.required",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "type": "relation-select",
                      "value": "@entity.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clearable": "@config.clearable",
                      "disabled": "@config.disabled",
                      "emptyMessage": "@config.emptyMessage",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "name": "@config.name",
                      "onChange": "@config.onChange",
                      "options": "@config.options",
                      "placeholder": "@config.placeholder",
                      "required": "@config.required",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "type": "relation-select",
                      "value": "@entity.value"
                    }
                  ]
                ],
                "event": "CHANGE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}