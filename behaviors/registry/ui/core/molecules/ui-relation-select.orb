{
  "name": "ui-relation-select",
  "version": "1.0.0",
  "description": "RelationSelect — UI factory (1:1 with the @almadar/ui relation-select pattern).",
  "orbitals": [
    {
      "name": "RelationSelectOrbital",
      "entity": {
        "name": "RelationSelectItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "string",
            "default": "Value"
          }
        ]
      },
      "traits": [
        {
          "name": "RelationSelectRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "value"
            ]
          },
          "category": "interaction",
          "linkedEntity": "RelationSelectItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "Callback when value changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Callback when value changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "disabled": "@config.disabled",
                      "onChange": "CHANGE",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "className": "@config.className",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "placeholder": "@config.placeholder",
                      "required": "@config.required",
                      "value": "@entity.value",
                      "clearable": "@config.clearable",
                      "name": "@config.name",
                      "emptyMessage": "@config.emptyMessage",
                      "type": "relation-select",
                      "options": "@config.options"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "disabled": "@config.disabled",
                      "className": "@config.className",
                      "type": "relation-select",
                      "clearable": "@config.clearable",
                      "emptyMessage": "@config.emptyMessage",
                      "name": "@config.name",
                      "placeholder": "@config.placeholder",
                      "required": "@config.required",
                      "onChange": "CHANGE",
                      "options": "@config.options",
                      "error": "@config.error",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "isLoading": "@config.isLoading",
                      "value": "@entity.value"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "searchPlaceholder": {
              "type": "string",
              "default": "Search Placeholder",
              "label": "Search Placeholder",
              "description": "Search placeholder",
              "tier": "presentation"
            },
            "clearable": {
              "type": "boolean",
              "default": true,
              "label": "Clearable",
              "description": "Allow clearing the selection",
              "tier": "presentation"
            },
            "required": {
              "type": "boolean",
              "default": false,
              "label": "Required",
              "description": "Whether the field is required",
              "tier": "presentation"
            },
            "name": {
              "type": "string",
              "default": "Name",
              "label": "Name",
              "description": "Name attribute for forms",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Whether data is loading",
              "tier": "presentation"
            },
            "placeholder": {
              "type": "string",
              "default": "Placeholder",
              "label": "Placeholder",
              "description": "Placeholder text",
              "tier": "presentation"
            },
            "emptyMessage": {
              "type": "string",
              "default": "Empty Message",
              "label": "Empty Message",
              "description": "Empty state message",
              "tier": "presentation"
            },
            "error": {
              "type": "string",
              "default": "",
              "label": "Error",
              "description": "Error message",
              "tier": "presentation"
            },
            "options": {
              "type": "[RelationSelectOptionsItem]",
              "default": [
                {
                  "label": "Label",
                  "description": "Description",
                  "disabled": false,
                  "value": "Value"
                }
              ],
              "label": "Options",
              "description": "Available options - accepts readonly for compatibility with generated const arrays",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Current value (ID)",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Whether the field is disabled",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RelationSelectPage",
          "path": "/relation-select",
          "traits": [
            {
              "ref": "RelationSelectRender"
            }
          ]
        }
      ]
    }
  ]
}