{
  "name": "ui-progress-dots",
  "version": "1.0.0",
  "description": "ProgressDots — UI factory (1:1 with the @almadar/ui progress-dots pattern).",
  "orbitals": [
    {
      "name": "ProgressDotsOrbital",
      "entity": {
        "name": "ProgressDotsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ProgressDotsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ProgressDotsItem",
          "emits": [
            {
              "event": "DOT_CLICK",
              "description": "Callback when a dot is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DOT_CLICK",
                "name": "Dot Click",
                "description": "Callback when a dot is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "progress-dots",
                      "onDotClick": "DOT_CLICK",
                      "currentIndex": "@config.currentIndex",
                      "size": "@config.size",
                      "count": "@config.count",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "count": {
              "type": "number",
              "default": 0.0,
              "label": "Count",
              "description": "Total number of dots",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Dot size",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "currentIndex": {
              "type": "number",
              "default": 0.0,
              "label": "Current Index",
              "description": "Current active index (0-based)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ProgressDotsPage",
          "path": "/progress-dots",
          "traits": [
            {
              "ref": "ProgressDotsRender"
            }
          ]
        }
      ]
    }
  ]
}