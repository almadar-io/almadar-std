{
  "description": "ProgressDots — UI factory (1:1 with the @almadar/ui progress-dots pattern).",
  "name": "ui-progress-dots",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ProgressDotsItem",
        "persistence": "runtime"
      },
      "name": "ProgressDotsOrbital",
      "pages": [
        {
          "name": "ProgressDotsPage",
          "path": "/progress-dots",
          "traits": [
            {
              "ref": "ProgressDotsRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "count": {
              "default": 1.0,
              "description": "Total number of dots",
              "label": "Count",
              "tier": "presentation",
              "type": "number"
            },
            "currentIndex": {
              "default": 1.0,
              "description": "Current active index (0-based)",
              "label": "Current Index",
              "tier": "presentation",
              "type": "number"
            },
            "onDotClick": {
              "default": "DOT_CLICK",
              "description": "Callback when a dot is clicked",
              "label": "On Dot Click",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Dot size",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Callback when a dot is clicked",
              "event": "DOT_CLICK",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ProgressDotsItem",
          "name": "ProgressDotsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when a dot is clicked",
                "key": "DOT_CLICK",
                "name": "Dot Click",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "count": "@config.count",
                      "currentIndex": "@config.currentIndex",
                      "onDotClick": "@config.onDotClick",
                      "size": "@config.size",
                      "type": "progress-dots"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}