{
  "name": "ui-likert-scale",
  "version": "1.0.0",
  "description": "LikertScale — UI factory (1:1 with the @almadar/ui likert-scale pattern).",
  "orbitals": [
    {
      "name": "LikertScaleOrbital",
      "entity": {
        "name": "LikertScaleItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "LikertScaleRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "LikertScaleItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "Change callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Change callback",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "disabled": "@config.disabled",
                      "question": "@config.question",
                      "variant": "@config.variant",
                      "className": "@config.className",
                      "value": "@config.value",
                      "changeEvent": "CHANGE",
                      "size": "@config.size",
                      "options": "@config.options",
                      "onChange": "CHANGE",
                      "type": "likert-scale"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disabled state",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "radios",
              "label": "Variant",
              "description": "Visual variant: classic radios or pill segmented buttons",
              "tier": "presentation",
              "values": [
                "radios",
                "buttons"
              ]
            },
            "value": {
              "type": "string",
              "default": "",
              "label": "Value",
              "description": "Selected value (controlled)",
              "tier": "presentation"
            },
            "options": {
              "type": "[LikertScaleOptionsItem]",
              "default": [],
              "label": "Options",
              "description": "Scale points (defaults to a 5-point agree/disagree set)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "question": {
              "type": "string",
              "default": "",
              "label": "Question",
              "description": "Optional row prompt above the scale",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LikertScalePage",
          "path": "/likert-scale",
          "traits": [
            {
              "ref": "LikertScaleRender"
            }
          ]
        }
      ]
    }
  ]
}