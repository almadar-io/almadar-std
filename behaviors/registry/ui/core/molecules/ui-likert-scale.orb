{
  "description": "LikertScale — UI factory (1:1 with the @almadar/ui likert-scale pattern).",
  "name": "ui-likert-scale",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LikertScaleItem",
        "persistence": "runtime"
      },
      "name": "LikertScaleOrbital",
      "pages": [
        {
          "name": "LikertScalePage",
          "path": "/likert-scale",
          "traits": [
            {
              "ref": "LikertScaleRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Disabled state",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "options": {
              "default": [
                {
                  "label": "Label",
                  "value": "Value"
                },
                {
                  "label": "Label 2",
                  "value": "Value 2"
                }
              ],
              "description": "Scale points (defaults to a 5-point agree/disagree set)",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Options",
              "tier": "presentation",
              "type": "[LikertScaleOptionsItem]"
            },
            "question": {
              "default": "Question",
              "description": "Optional row prompt above the scale",
              "label": "Question",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "value": {
              "default": "",
              "description": "Selected value (controlled)",
              "label": "Value",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "radios",
              "description": "Visual variant: classic radios or pill segmented buttons",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "radios",
                "buttons"
              ]
            }
          },
          "emits": [
            {
              "description": "Change callback",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LikertScaleItem",
          "name": "LikertScaleRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Change callback",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "changeEvent": "CHANGE",
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "onChange": "CHANGE",
                      "options": "@config.options",
                      "question": "@config.question",
                      "size": "@config.size",
                      "type": "likert-scale",
                      "value": "@config.value",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}