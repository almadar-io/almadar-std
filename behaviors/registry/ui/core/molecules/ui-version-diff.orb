{
  "description": "VersionDiff — UI factory (1:1 with the @almadar/ui version-diff pattern).",
  "name": "ui-version-diff",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "VersionDiffItem",
        "persistence": "runtime"
      },
      "name": "VersionDiffOrbital",
      "pages": [
        {
          "name": "VersionDiffPage",
          "path": "/version-diff",
          "traits": [
            {
              "ref": "VersionDiffRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "afterId": {
              "default": "After Id",
              "description": "Currently selected 'after' revision id.",
              "label": "After Id",
              "tier": "presentation",
              "type": "string"
            },
            "beforeId": {
              "default": "Before Id",
              "description": "Currently selected 'before' revision id.",
              "label": "Before Id",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "language": {
              "default": "Language",
              "description": "Language label (informational).",
              "label": "Language",
              "tier": "presentation",
              "type": "string"
            },
            "onRevert": {
              "default": "REVERT",
              "description": "Called when the user clicks the revert button (passes the 'before' id).",
              "label": "On Revert",
              "tier": "presentation",
              "type": "string"
            },
            "onSelectAfter": {
              "default": "SELECT_AFTER",
              "description": "Called when the user picks a different 'after' revision.",
              "label": "On Select After",
              "tier": "presentation",
              "type": "string"
            },
            "onSelectBefore": {
              "default": "SELECT_BEFORE",
              "description": "Called when the user picks a different 'before' revision.",
              "label": "On Select Before",
              "tier": "presentation",
              "type": "string"
            },
            "revertEvent": {
              "default": "REVERT",
              "description": "Event name dispatched via event bus when the user clicks revert. Payload: { id }.",
              "label": "Revert Event",
              "tier": "presentation",
              "type": "string"
            },
            "revisions": {
              "default": [
                {
                  "author": "Author",
                  "content": "Content",
                  "id": "Id",
                  "label": "Label",
                  "timestamp": "Timestamp"
                },
                {
                  "author": "Author 2",
                  "content": "Content 2",
                  "id": "Id 2",
                  "label": "Label 2",
                  "timestamp": "Timestamp 2"
                }
              ],
              "description": "All available revisions (at least 2). Accepts either a typed array (direct consumers) or the runtime payload shape from a render-ui binding (`@payload.revisions`). Narrowed to `[]` internally when the value isn't an array.",
              "items": {
                "properties": {
                  "author": {
                    "name": "author",
                    "required": false,
                    "type": "string"
                  },
                  "content": {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "timestamp": {
                    "name": "timestamp",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Revisions",
              "tier": "presentation",
              "type": "[VersionDiffRevisionsItem]"
            },
            "selectAfterEvent": {
              "default": "SELECT_AFTER",
              "description": "Event name dispatched via event bus when the 'after' revision changes. Payload: { id }.",
              "label": "Select After Event",
              "tier": "presentation",
              "type": "string"
            },
            "selectBeforeEvent": {
              "default": "SELECT_BEFORE",
              "description": "Event name dispatched via event bus when the 'before' revision changes. Payload: { id }.",
              "label": "Select Before Event",
              "tier": "presentation",
              "type": "string"
            },
            "view": {
              "default": "side-by-side",
              "description": "Display mode.",
              "label": "View",
              "tier": "presentation",
              "type": "string",
              "values": [
                "side-by-side",
                "inline"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when the user picks a different 'before' revision.",
              "event": "SELECT_BEFORE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when the user picks a different 'after' revision.",
              "event": "SELECT_AFTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when the user clicks the revert button (passes the 'before' id).",
              "event": "REVERT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VersionDiffItem",
          "name": "VersionDiffRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when the user picks a different 'before' revision.",
                "key": "SELECT_BEFORE",
                "name": "Select Before",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when the user picks a different 'after' revision.",
                "key": "SELECT_AFTER",
                "name": "Select After",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when the user clicks the revert button (passes the 'before' id).",
                "key": "REVERT",
                "name": "Revert",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "afterId": "@config.afterId",
                      "beforeId": "@config.beforeId",
                      "className": "@config.className",
                      "language": "@config.language",
                      "onRevert": "@config.onRevert",
                      "onSelectAfter": "@config.onSelectAfter",
                      "onSelectBefore": "@config.onSelectBefore",
                      "revertEvent": "@config.revertEvent",
                      "revisions": "@config.revisions",
                      "selectAfterEvent": "@config.selectAfterEvent",
                      "selectBeforeEvent": "@config.selectBeforeEvent",
                      "type": "version-diff",
                      "view": "@config.view"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}