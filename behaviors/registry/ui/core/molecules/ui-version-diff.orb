{
  "name": "ui-version-diff",
  "version": "1.0.0",
  "description": "VersionDiff — UI factory (1:1 with the @almadar/ui version-diff pattern).",
  "orbitals": [
    {
      "name": "VersionDiffOrbital",
      "entity": {
        "name": "VersionDiffItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "VersionDiffRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "VersionDiffItem",
          "emits": [
            {
              "event": "SELECT_BEFORE",
              "description": "Called when the user picks a different 'before' revision.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SELECT_AFTER",
              "description": "Called when the user picks a different 'after' revision.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REVERT",
              "description": "Called when the user clicks the revert button (passes the 'before' id).",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_BEFORE",
                "name": "Select Before",
                "description": "Called when the user picks a different 'before' revision.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_AFTER",
                "name": "Select After",
                "description": "Called when the user picks a different 'after' revision.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REVERT",
                "name": "Revert",
                "description": "Called when the user clicks the revert button (passes the 'before' id).",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "version-diff",
                      "onSelectAfter": "SELECT_AFTER",
                      "className": "@config.className",
                      "revisions": "@config.revisions",
                      "onSelectBefore": "SELECT_BEFORE",
                      "view": "@config.view",
                      "selectBeforeEvent": "SELECT_BEFORE",
                      "afterId": "@config.afterId",
                      "selectAfterEvent": "SELECT_AFTER",
                      "language": "@config.language",
                      "revertEvent": "REVERT",
                      "onRevert": "REVERT",
                      "beforeId": "@config.beforeId"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "revisions": {
              "type": "[VersionDiffRevisionsItem]",
              "default": [
                {
                  "id": "Id",
                  "label": "Label",
                  "content": "Content"
                }
              ],
              "label": "Revisions",
              "description": "All available revisions (at least 2). Accepts either a typed array (direct consumers) or the runtime payload shape from a render-ui binding (`@payload.revisions`). Narrowed to `[]` internally when the value isn't an array.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "author": {
                    "name": "author",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "timestamp": {
                    "name": "timestamp",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "language": {
              "type": "string",
              "default": "",
              "label": "Language",
              "description": "Language label (informational).",
              "tier": "presentation"
            },
            "beforeId": {
              "type": "string",
              "default": "",
              "label": "Before Id",
              "description": "Currently selected 'before' revision id.",
              "tier": "presentation"
            },
            "afterId": {
              "type": "string",
              "default": "",
              "label": "After Id",
              "description": "Currently selected 'after' revision id.",
              "tier": "presentation"
            },
            "view": {
              "type": "string",
              "default": "side-by-side",
              "label": "View",
              "description": "Display mode.",
              "tier": "presentation",
              "values": [
                "side-by-side",
                "inline"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "VersionDiffPage",
          "path": "/version-diff",
          "traits": [
            {
              "ref": "VersionDiffRender"
            }
          ]
        }
      ]
    }
  ]
}