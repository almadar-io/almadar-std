{
  "description": "QrScanner — UI factory (1:1 with the @almadar/ui qr-scanner pattern).",
  "name": "ui-qr-scanner",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "QrScannerItem",
        "persistence": "runtime"
      },
      "name": "QrScannerOrbital",
      "pages": [
        {
          "name": "QrScannerPage",
          "path": "/qr-scanner",
          "traits": [
            {
              "ref": "QrScannerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "facingMode": {
              "default": "environment",
              "description": "facingMode prop",
              "label": "Facing Mode",
              "tier": "presentation",
              "type": "string",
              "values": [
                "environment",
                "user"
              ]
            },
            "paused": {
              "default": false,
              "description": "paused prop",
              "label": "Paused",
              "tier": "presentation",
              "type": "boolean"
            },
            "showCameraControls": {
              "default": true,
              "description": "showCameraControls prop",
              "label": "Show Camera Controls",
              "tier": "presentation",
              "type": "boolean"
            },
            "showOverlay": {
              "default": true,
              "description": "showOverlay prop",
              "label": "Show Overlay",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "onScan prop",
              "event": "SCAN",
              "payloadSchema": [
                {
                  "name": "result",
                  "properties": [
                    {
                      "name": "text",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "format",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "timestamp",
                      "required": true,
                      "type": "number"
                    }
                  ],
                  "type": "object"
                },
                {
                  "name": "_payload",
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "QrScannerItem",
          "name": "QrScannerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onScan prop",
                "key": "SCAN",
                "name": "Scan",
                "payloadSchema": [
                  {
                    "name": "result",
                    "properties": [
                      {
                        "name": "text",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "format",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "timestamp",
                        "required": true,
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  },
                  {
                    "name": "_payload",
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "facingMode": "@config.facingMode",
                      "fallback": [
                        {
                          "content": "Fallback",
                          "type": "typography"
                        }
                      ],
                      "onScan": "SCAN",
                      "paused": "@config.paused",
                      "scanEvent": "SCAN",
                      "showCameraControls": "@config.showCameraControls",
                      "showOverlay": "@config.showOverlay",
                      "type": "qr-scanner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}