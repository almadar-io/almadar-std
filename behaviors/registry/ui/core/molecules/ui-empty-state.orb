{
  "name": "ui-empty-state",
  "version": "1.0.0",
  "description": "EmptyState — UI factory (1:1 with the @almadar/ui empty-state pattern).",
  "orbitals": [
    {
      "name": "EmptyStateOrbital",
      "entity": {
        "name": "EmptyStateItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EmptyStateRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "EmptyStateItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "onAction prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "onAction prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@config.message",
                      "icon": "@config.icon",
                      "className": "@config.className",
                      "onAction": "ACTION",
                      "title": "@config.title",
                      "variant": "@config.variant",
                      "actionEvent": "ACTION",
                      "description": "@config.description",
                      "destructive": "@config.destructive",
                      "look": "@config.look",
                      "actionLabel": "@config.actionLabel",
                      "type": "empty-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Icon to display. Accepts either: - A Lucide icon component (LucideIcon) - A string icon name (e.g., 'check-circle', 'x-circle')",
              "tier": "presentation"
            },
            "destructive": {
              "type": "boolean",
              "default": false,
              "label": "Destructive",
              "description": "Destructive styling for confirmation dialogs",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "icon-only",
              "label": "Look",
              "description": "Layer 2 visual treatment — orthogonal to the semantic variant (which carries status color).",
              "tier": "presentation",
              "values": [
                "illustrated",
                "icon-only",
                "text-only",
                "mascot"
              ]
            },
            "actionLabel": {
              "type": "string",
              "default": "Action Label",
              "label": "Action Label",
              "description": "actionLabel prop",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Primary text to display - use title or message (message is alias for backwards compat)",
              "tier": "presentation"
            },
            "description": {
              "type": "string",
              "default": "Description",
              "label": "Description",
              "description": "description prop",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Variant",
              "description": "Variant for color styling",
              "tier": "presentation",
              "values": [
                "default",
                "success",
                "error",
                "warning",
                "info"
              ]
            },
            "message": {
              "type": "string",
              "default": "Message",
              "label": "Message",
              "description": "Alias for title - used by schema patterns",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EmptyStatePage",
          "path": "/empty-state",
          "traits": [
            {
              "ref": "EmptyStateRender"
            }
          ]
        }
      ]
    }
  ]
}