{
  "description": "Accordion — UI factory (1:1 with the @almadar/ui accordion pattern).",
  "name": "ui-accordion",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AccordionItem",
        "persistence": "runtime"
      },
      "name": "AccordionOrbital",
      "pages": [
        {
          "name": "AccordionPage",
          "path": "/accordion",
          "traits": [
            {
              "ref": "AccordionRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "defaultOpen": {
              "default": [],
              "description": "Default open items by index (pattern compatibility)",
              "items": {
                "type": "number"
              },
              "label": "Default Open",
              "tier": "presentation",
              "type": "[number]"
            },
            "defaultOpenItems": {
              "default": [],
              "description": "Default open items (IDs)",
              "items": {
                "type": "string"
              },
              "label": "Default Open Items",
              "tier": "presentation",
              "type": "[string]"
            },
            "items": {
              "default": [
                {
                  "content": "Content",
                  "defaultOpen": false,
                  "disabled": false,
                  "header": "Header",
                  "id": "Id",
                  "title": "Title"
                },
                {
                  "content": "Content 2",
                  "defaultOpen": true,
                  "disabled": true,
                  "header": "Header 2",
                  "id": "Id 2",
                  "title": "Title 2"
                }
              ],
              "description": "Accordion items",
              "items": {
                "properties": {
                  "content": {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  },
                  "defaultOpen": {
                    "name": "defaultOpen",
                    "required": false,
                    "type": "boolean"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "header": {
                    "name": "header",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "title": {
                    "name": "title",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[AccordionItemsItem]"
            },
            "multiple": {
              "default": false,
              "description": "Allow multiple items open at once",
              "label": "Multiple",
              "tier": "presentation",
              "type": "boolean"
            },
            "openItems": {
              "default": [],
              "description": "Controlled open items (IDs)",
              "items": {
                "type": "string"
              },
              "label": "Open Items",
              "tier": "presentation",
              "type": "[string]"
            }
          },
          "emits": [
            {
              "description": "Callback when item opens/closes",
              "event": "ITEM_TOGGLE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string"
                },
                {
                  "name": "isOpen",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }",
              "event": "TOGGLE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "isOpen",
                  "required": true,
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AccordionItem",
          "name": "AccordionRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when item opens/closes",
                "key": "ITEM_TOGGLE",
                "name": "Item Toggle",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string"
                  },
                  {
                    "name": "isOpen",
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }",
                "key": "TOGGLE",
                "name": "Toggle",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "isOpen",
                    "required": true,
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "defaultOpen": "@config.defaultOpen",
                      "defaultOpenItems": "@config.defaultOpenItems",
                      "items": "@config.items",
                      "multiple": "@config.multiple",
                      "onItemToggle": "ITEM_TOGGLE",
                      "openItems": "@config.openItems",
                      "toggleEvent": "TOGGLE",
                      "type": "accordion"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}