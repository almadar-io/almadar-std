{
  "name": "ui-accordion",
  "version": "1.0.0",
  "description": "Accordion — UI factory (1:1 with the @almadar/ui accordion pattern).",
  "orbitals": [
    {
      "name": "AccordionOrbital",
      "entity": {
        "name": "AccordionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AccordionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "AccordionItem",
          "emits": [
            {
              "event": "ITEM_TOGGLE",
              "description": "Callback when item opens/closes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string"
                },
                {
                  "name": "isOpen",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "TOGGLE",
              "description": "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "isOpen",
                  "type": "boolean",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEM_TOGGLE",
                "name": "Item Toggle",
                "description": "Callback when item opens/closes",
                "tier": "essential"
              },
              {
                "key": "TOGGLE",
                "name": "Toggle",
                "description": "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "multiple": "@config.multiple",
                      "toggleEvent": "TOGGLE",
                      "onItemToggle": "ITEM_TOGGLE",
                      "type": "accordion",
                      "openItems": "@config.openItems",
                      "defaultOpenItems": "@config.defaultOpenItems",
                      "defaultOpen": "@config.defaultOpen",
                      "items": "@config.items",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "openItems": {
              "type": "[string]",
              "default": [],
              "label": "Open Items",
              "description": "Controlled open items (IDs)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "items": {
              "type": "[AccordionItemsItem]",
              "default": [],
              "label": "Items",
              "description": "Accordion items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "defaultOpen": {
                    "name": "defaultOpen",
                    "type": "boolean",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "multiple": {
              "type": "boolean",
              "default": false,
              "label": "Multiple",
              "description": "Allow multiple items open at once",
              "tier": "presentation"
            },
            "defaultOpenItems": {
              "type": "[string]",
              "default": [],
              "label": "Default Open Items",
              "description": "Default open items (IDs)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "defaultOpen": {
              "type": "[number]",
              "default": [],
              "label": "Default Open",
              "description": "Default open items by index (pattern compatibility)",
              "tier": "presentation",
              "items": {
                "type": "number"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AccordionPage",
          "path": "/accordion",
          "traits": [
            {
              "ref": "AccordionRender"
            }
          ]
        }
      ]
    }
  ]
}