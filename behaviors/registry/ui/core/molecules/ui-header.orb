{
  "description": "Header — UI factory (1:1 with the @almadar/ui header pattern).",
  "name": "ui-header",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "HeaderItem",
        "persistence": "runtime"
      },
      "name": "HeaderOrbital",
      "pages": [
        {
          "name": "HeaderPage",
          "path": "/header",
          "traits": [
            {
              "ref": "HeaderRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "description": "Action buttons (right side)",
              "label": "Actions",
              "tier": "presentation",
              "type": "node"
            },
            "brandName": {
              "default": "KFlow",
              "description": "Brand/App name",
              "label": "Brand Name",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state (closed circuit)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "HeaderError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator (closed circuit)",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "isMenuOpen": {
              "default": false,
              "description": "Is menu open (for toggle icon)",
              "label": "Is Menu Open",
              "tier": "presentation",
              "type": "boolean"
            },
            "logoSrc": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png",
              "description": "Logo image source",
              "label": "Logo Src",
              "tier": "presentation",
              "type": "asset"
            },
            "look": {
              "default": "compact-bar",
              "description": "Layer 2 visual treatment — orthogonal to the structural variant (which currently flips mobile vs desktop).",
              "label": "Look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "hero",
                "compact-bar",
                "breadcrumb",
                "contextual",
                "editorial-banner"
              ]
            },
            "navigationItems": {
              "default": [
                {
                  "active": false,
                  "badge": "Badge",
                  "href": "Href",
                  "icon": "circle",
                  "label": "Label"
                },
                {
                  "active": true,
                  "badge": "Badge 2",
                  "href": "Href 2",
                  "icon": "circle",
                  "label": "Label 2"
                }
              ],
              "description": "Navigation items (for desktop header variant)",
              "items": {
                "properties": {
                  "active": {
                    "name": "active",
                    "required": false,
                    "type": "boolean"
                  },
                  "badge": {
                    "name": "badge",
                    "required": false,
                    "type": "string"
                  },
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Navigation Items",
              "tier": "presentation",
              "type": "[HeaderNavigationItemsItem]"
            },
            "searchPlaceholder": {
              "default": "Search Placeholder",
              "description": "Search placeholder",
              "label": "Search Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "showMenuToggle": {
              "default": true,
              "description": "Show menu toggle button",
              "label": "Show Menu Toggle",
              "tier": "presentation",
              "type": "boolean"
            },
            "showSearch": {
              "default": false,
              "description": "Show search input",
              "label": "Show Search",
              "tier": "presentation",
              "type": "boolean"
            },
            "sticky": {
              "default": true,
              "description": "Sticky header",
              "label": "Sticky",
              "tier": "presentation",
              "type": "boolean"
            },
            "userAvatar": {
              "default": {
                "alt": "Alt",
                "initials": "Initials",
                "src": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png"
              },
              "description": "User avatar configuration",
              "label": "User Avatar",
              "properties": {
                "alt": {
                  "name": "alt",
                  "required": false,
                  "type": "string"
                },
                "initials": {
                  "name": "initials",
                  "required": false,
                  "type": "string"
                },
                "src": {
                  "name": "src",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "HeaderUserAvatar"
            },
            "userName": {
              "default": "User Name",
              "description": "User name (display name or email)",
              "label": "User Name",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "mobile",
              "description": "Variant - mobile shows menu toggle, desktop shows full nav",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "mobile",
                "desktop"
              ]
            }
          },
          "emits": [
            {
              "description": "Menu toggle callback",
              "event": "MENU_TOGGLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Search callback",
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when user avatar is clicked",
              "event": "USER_CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when logo/brand is clicked",
              "event": "LOGO_CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HeaderItem",
          "name": "HeaderRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Menu toggle callback",
                "key": "MENU_TOGGLE",
                "name": "Menu Toggle",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Search callback",
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when user avatar is clicked",
                "key": "USER_CLICK",
                "name": "User Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when logo/brand is clicked",
                "key": "LOGO_CLICK",
                "name": "Logo Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "brandName": "@config.brandName",
                      "className": "@config.className",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "isMenuOpen": "@config.isMenuOpen",
                      "logo": [
                        {
                          "content": "Logo",
                          "type": "typography"
                        }
                      ],
                      "logoSrc": "@config.logoSrc",
                      "look": "@config.look",
                      "navigationItems": "@config.navigationItems",
                      "onLogoClick": "LOGO_CLICK",
                      "onMenuToggle": "MENU_TOGGLE",
                      "onSearch": "SEARCH",
                      "onUserClick": "USER_CLICK",
                      "searchPlaceholder": "@config.searchPlaceholder",
                      "showMenuToggle": "@config.showMenuToggle",
                      "showSearch": "@config.showSearch",
                      "sticky": "@config.sticky",
                      "type": "header",
                      "userAvatar": "@config.userAvatar",
                      "userName": "@config.userName",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}