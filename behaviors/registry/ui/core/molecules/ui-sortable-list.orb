{
  "description": "SortableList — UI factory (1:1 with the @almadar/ui sortable-list pattern).",
  "name": "ui-sortable-list",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SortableListItem",
        "persistence": "runtime"
      },
      "name": "SortableListOrbital",
      "pages": [
        {
          "name": "SortableListPage",
          "path": "/sortable-list",
          "traits": [
            {
              "ref": "SortableListRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "dragHandlePosition": {
              "default": "left",
              "description": "dragHandlePosition prop",
              "label": "Drag Handle Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "left",
                "right"
              ]
            },
            "reorderPayload": {
              "default": {},
              "description": "reorderPayload prop",
              "label": "Reorder Payload",
              "tier": "presentation",
              "type": "json"
            }
          },
          "emits": [
            {
              "description": "reorderEvent prop",
              "event": "REORDER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SortableListItem",
          "name": "SortableListRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "reorderEvent prop",
                "key": "REORDER",
                "name": "Reorder",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "SortableListItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "dragHandlePosition": "@config.dragHandlePosition",
                      "items": "@entity",
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "content": "@item.id",
                          "type": "typography"
                        }
                      ],
                      "reorderEvent": "REORDER",
                      "reorderPayload": "@config.reorderPayload",
                      "type": "sortable-list"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}