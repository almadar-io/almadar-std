{
  "name": "ui-upload-drop-zone",
  "version": "1.0.0",
  "description": "UploadDropZone — UI factory (1:1 with the @almadar/ui upload-drop-zone pattern).",
  "orbitals": [
    {
      "name": "UploadDropZoneOrbital",
      "entity": {
        "name": "UploadDropZoneItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "UploadDropZoneRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "UploadDropZoneItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name for file selection",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FILES",
              "description": "Direct onFiles callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "files",
                  "type": "[object]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for file selection",
                "tier": "essential"
              },
              {
                "key": "FILES",
                "name": "Files",
                "description": "Direct onFiles callback",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "maxFiles": "@config.maxFiles",
                      "description": "@config.description",
                      "disabled": "@config.disabled",
                      "type": "upload-drop-zone",
                      "onFiles": "FILES",
                      "accept": "@config.accept",
                      "className": "@config.className",
                      "label": "@config.label",
                      "icon": "@config.icon",
                      "action": "ACTION",
                      "actionPayload": "@config.actionPayload",
                      "maxSize": "@config.maxSize"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "maxSize": {
              "type": "number",
              "default": 0.0,
              "label": "Max Size",
              "description": "Max file size in bytes",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disabled state",
              "tier": "presentation"
            },
            "icon": {
              "type": "string",
              "default": "circle",
              "label": "Icon",
              "description": "Icon name (Lucide string)",
              "tier": "presentation"
            },
            "maxFiles": {
              "type": "number",
              "default": 1.0,
              "label": "Max Files",
              "description": "Max number of files",
              "tier": "presentation"
            },
            "description": {
              "type": "string",
              "default": "",
              "label": "Description",
              "description": "Description text below label",
              "tier": "presentation"
            },
            "actionPayload": {
              "type": "json",
              "label": "Action Payload",
              "description": "Payload to include with the action event",
              "tier": "presentation"
            },
            "accept": {
              "type": "string",
              "default": "",
              "label": "Accept",
              "description": "Accepted MIME types (e.g., 'image/*', 'application/pdf')",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Drop files here or click to browse",
              "label": "Label",
              "description": "Label text",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "UploadDropZonePage",
          "path": "/upload-drop-zone",
          "traits": [
            {
              "ref": "UploadDropZoneRender"
            }
          ]
        }
      ]
    }
  ]
}