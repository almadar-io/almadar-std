{
  "description": "UploadDropZone — UI factory (1:1 with the @almadar/ui upload-drop-zone pattern).",
  "name": "ui-upload-drop-zone",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "UploadDropZoneItem",
        "persistence": "runtime"
      },
      "name": "UploadDropZoneOrbital",
      "pages": [
        {
          "name": "UploadDropZonePage",
          "path": "/upload-drop-zone",
          "traits": [
            {
              "ref": "UploadDropZoneRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "accept": {
              "default": "Accept",
              "description": "Accepted MIME types (e.g., 'image/*', 'application/pdf')",
              "label": "Accept",
              "tier": "presentation",
              "type": "string"
            },
            "action": {
              "default": "ACTION",
              "description": "Declarative event name for file selection",
              "label": "Action",
              "tier": "presentation",
              "type": "string"
            },
            "actionPayload": {
              "default": {},
              "description": "Payload to include with the action event",
              "label": "Action Payload",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Description",
              "description": "Description text below label",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Disabled state",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "icon": {
              "default": "circle",
              "description": "Icon name or component",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Label text",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "maxFiles": {
              "default": 1.0,
              "description": "Max number of files",
              "label": "Max Files",
              "tier": "presentation",
              "type": "number"
            },
            "maxSize": {
              "default": 0.0,
              "description": "Max file size in bytes",
              "label": "Max Size",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Declarative event name for file selection",
              "event": "@config.action",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "UploadDropZoneItem",
          "name": "UploadDropZoneRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event name for file selection",
                "key": "@config.action",
                "name": "@config.action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "accept": "@config.accept",
                      "action": "@config.action",
                      "actionPayload": "@config.actionPayload",
                      "className": "@config.className",
                      "description": "@config.description",
                      "disabled": "@config.disabled",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "maxFiles": "@config.maxFiles",
                      "maxSize": "@config.maxSize",
                      "type": "upload-drop-zone"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}