{
  "description": "MapView — UI factory (1:1 with the @almadar/ui map-view pattern).",
  "name": "ui-map-view",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MapViewItem",
        "persistence": "runtime"
      },
      "name": "MapViewOrbital",
      "pages": [
        {
          "name": "MapViewPage",
          "path": "/map-view",
          "traits": [
            {
              "ref": "MapViewRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "centerLat": {
              "default": 51.505,
              "description": "Map center latitude",
              "label": "Center Lat",
              "tier": "presentation",
              "type": "number"
            },
            "centerLng": {
              "default": -0.09,
              "description": "Map center longitude",
              "label": "Center Lng",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "height": {
              "default": "400px",
              "description": "Height of the map container (default '400px')",
              "label": "Height",
              "tier": "presentation",
              "type": "string"
            },
            "mapClickEvent": {
              "default": "MAP_CLICK",
              "description": "Event name dispatched via event bus when the map is clicked. Payload: { latitude, longitude }",
              "label": "Map Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "markerClickEvent": {
              "default": "MARKER_CLICK",
              "description": "Event name dispatched via event bus when a marker is clicked. Payload: full MapMarkerData spread.",
              "label": "Marker Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "markers": {
              "default": [
                {
                  "category": "Category",
                  "id": "Id",
                  "label": "Label",
                  "lat": 1.0,
                  "lng": 1.0
                },
                {
                  "category": "Category 2",
                  "id": "Id 2",
                  "label": "Label 2",
                  "lat": 2.0,
                  "lng": 2.0
                }
              ],
              "description": "Array of markers to display",
              "items": {
                "properties": {
                  "category": {
                    "name": "category",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "lat": {
                    "name": "lat",
                    "required": true,
                    "type": "number"
                  },
                  "lng": {
                    "name": "lng",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Markers",
              "tier": "presentation",
              "type": "[MapViewMarkersItem]"
            },
            "onMapClick": {
              "default": "MAP_CLICK",
              "description": "Callback when the map is clicked (programmatic use)",
              "label": "On Map Click",
              "tier": "presentation",
              "type": "string"
            },
            "onMarkerClick": {
              "default": "MARKER_CLICK",
              "description": "Callback when a marker is clicked (programmatic use)",
              "label": "On Marker Click",
              "tier": "presentation",
              "type": "string"
            },
            "routes": {
              "default": [
                {
                  "color": "Color",
                  "dashArray": "Dash Array",
                  "id": "Id",
                  "label": "Label",
                  "opacity": 1.0,
                  "waypoints": [
                    {
                      "lat": 1.0,
                      "lng": 1.0
                    },
                    {
                      "lat": 2.0,
                      "lng": 2.0
                    }
                  ],
                  "weight": 1.0
                },
                {
                  "color": "Color 2",
                  "dashArray": "Dash Array 2",
                  "id": "Id 2",
                  "label": "Label 2",
                  "opacity": 2.0,
                  "waypoints": [
                    {
                      "lat": 1.0,
                      "lng": 1.0
                    },
                    {
                      "lat": 2.0,
                      "lng": 2.0
                    }
                  ],
                  "weight": 2.0
                }
              ],
              "description": "Routes (polylines with optional popups) drawn over the tile layer",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "dashArray": {
                    "name": "dashArray",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "opacity": {
                    "name": "opacity",
                    "required": false,
                    "type": "number"
                  },
                  "waypoints": {
                    "items": {
                      "properties": {
                        "lat": {
                          "name": "lat",
                          "required": true,
                          "type": "number"
                        },
                        "lng": {
                          "name": "lng",
                          "required": true,
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "name": "waypoints",
                    "required": true,
                    "type": "array"
                  },
                  "weight": {
                    "name": "weight",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Routes",
              "tier": "presentation",
              "type": "[MapViewRoutesItem]"
            },
            "showAttribution": {
              "default": true,
              "description": "Show attribution (default true)",
              "label": "Show Attribution",
              "tier": "presentation",
              "type": "boolean"
            },
            "showClickedPin": {
              "default": false,
              "description": "Whether to show a pin at the clicked location",
              "label": "Show Clicked Pin",
              "tier": "presentation",
              "type": "boolean"
            },
            "zoom": {
              "default": 13.0,
              "description": "Zoom level (1-18, default 13)",
              "label": "Zoom",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Callback when a marker is clicked (programmatic use)",
              "event": "@config.onMarkerClick",
              "payloadSchema": [
                {
                  "name": "marker",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "lat",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "lng",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    },
                    {
                      "name": "category",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                },
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "lat",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "lng",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "label",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when the map is clicked (programmatic use)",
              "event": "@config.onMapClick",
              "payloadSchema": [
                {
                  "name": "lat",
                  "type": "number"
                },
                {
                  "name": "lng",
                  "type": "number"
                },
                {
                  "name": "latitude",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "longitude",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MapViewItem",
          "name": "MapViewRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when a marker is clicked (programmatic use)",
                "key": "@config.onMarkerClick",
                "name": "@config.on marker click",
                "payloadSchema": [
                  {
                    "name": "marker",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "lat",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "lng",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "label",
                        "type": "string"
                      },
                      {
                        "name": "category",
                        "type": "string"
                      }
                    ],
                    "type": "object"
                  },
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "lat",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "lng",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when the map is clicked (programmatic use)",
                "key": "@config.onMapClick",
                "name": "@config.on map click",
                "payloadSchema": [
                  {
                    "name": "lat",
                    "type": "number"
                  },
                  {
                    "name": "lng",
                    "type": "number"
                  },
                  {
                    "name": "latitude",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "longitude",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "centerLat": "@config.centerLat",
                      "centerLng": "@config.centerLng",
                      "className": "@config.className",
                      "height": "@config.height",
                      "mapClickEvent": "@config.mapClickEvent",
                      "markerClickEvent": "@config.markerClickEvent",
                      "markers": "@config.markers",
                      "onMapClick": "@config.onMapClick",
                      "onMarkerClick": "@config.onMarkerClick",
                      "routes": "@config.routes",
                      "showAttribution": "@config.showAttribution",
                      "showClickedPin": "@config.showClickedPin",
                      "type": "map-view",
                      "zoom": "@config.zoom"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}