{
  "name": "ui-table-view",
  "version": "1.0.0",
  "description": "TableView — UI factory (1:1 with the @almadar/ui table-view pattern).",
  "orbitals": [
    {
      "name": "TableViewOrbital",
      "entity": {
        "name": "TableViewItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TableViewRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TableViewItem",
          "emits": [
            {
              "event": "SELECT",
              "description": "Event emitted on selection change: UI:{selectEvent} with { ids, rows }.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SORT",
              "description": "Event emitted on sortable-header click: UI:{sortEvent} with { column, direction }.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VIEW",
              "description": "User opened a record from the list.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT",
                "name": "Select",
                "description": "Event emitted on selection change: UI:{selectEvent} with { ids, rows }.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SORT",
                "name": "Sort",
                "description": "Event emitted on sortable-header click: UI:{sortEvent} with { column, direction }.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TableViewItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "maxInlineActions": "@config.maxInlineActions",
                      "selectEvent": "SELECT",
                      "fields": "@config.fields",
                      "sortEvent": "SORT",
                      "emptyMessage": "@config.emptyMessage",
                      "dndRoot": "@config.dndRoot",
                      "dndItemIdField": "@config.dndItemIdField",
                      "sortable": "@config.sortable",
                      "groupBy": "@config.groupBy",
                      "pageSize": "@config.pageSize",
                      "columns": "@config.columns",
                      "reorderEvent": "@config.reorderEvent",
                      "error": "@config.error",
                      "accepts": "@config.accepts",
                      "selectable": "@config.selectable",
                      "dropEvent": "@config.dropEvent",
                      "dragGroup": "@config.dragGroup",
                      "sortColumn": "@config.sortColumn",
                      "selectedIds": "@config.selectedIds",
                      "sortDirection": "@config.sortDirection",
                      "look": "@config.look",
                      "type": "table-view",
                      "isLoading": "@config.isLoading",
                      "positionEvent": "@config.positionEvent",
                      "className": "@config.className",
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW"
                        }
                      ],
                      "entity": "@entity"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW",
                "effects": [
                  [
                    "emit",
                    "VIEW",
                    {}
                  ]
                ]
              }
            ]
          },
          "config": {
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction (display hint).",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "sortColumn": {
              "type": "string",
              "default": "Sort Column",
              "label": "Sort Column",
              "description": "Current sort column (display hint for the active header arrow).",
              "tier": "presentation"
            },
            "dragGroup": {
              "type": "string",
              "default": "Drag Group",
              "label": "Drag Group",
              "description": "When set, items in this container are draggable and announce this group as their source",
              "tier": "presentation"
            },
            "groupBy": {
              "type": "string",
              "default": "Group By",
              "label": "Group By",
              "description": "Group rows under section headers by a field value.",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the table root.",
              "tier": "presentation"
            },
            "dropEvent": {
              "type": "string",
              "default": "Drop Event",
              "label": "Drop Event",
              "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
              "tier": "presentation"
            },
            "dndRoot": {
              "type": "boolean",
              "default": false,
              "label": "Dnd Root",
              "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
              "tier": "presentation"
            },
            "maxInlineActions": {
              "type": "number",
              "default": 0.0,
              "label": "Max Inline Actions",
              "description": "Max inline action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
              "tier": "presentation"
            },
            "error": {
              "type": "TableViewError",
              "label": "Error",
              "description": "Error state.",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "positionEvent": {
              "type": "string",
              "default": "Position Event",
              "label": "Position Event",
              "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
              "tier": "presentation"
            },
            "look": {
              "type": "string",
              "default": "dense",
              "label": "Look",
              "description": "Layer 2 visual treatment — mirrors the data-list / entity-table look enum so authors share one knob name across row renderers.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "bordered"
              ]
            },
            "dndItemIdField": {
              "type": "string",
              "default": "Dnd Item Id Field",
              "label": "Dnd Item Id Field",
              "description": "Row field used as the @dnd-kit draggable id (default 'id')",
              "tier": "presentation"
            },
            "columns": {
              "type": "[TableViewColumnsItem]",
              "default": [
                {
                  "width": "Width",
                  "align": "left",
                  "sortable": false,
                  "header": "Header",
                  "label": "Label",
                  "className": "Class Name",
                  "key": "Key",
                  "format": "badge",
                  "weight": "normal",
                  "field": "Field",
                  "icon": "circle"
                }
              ],
              "label": "Columns",
              "description": "Column definitions. The compiler emits `columns`; `fields` is the alias.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "weight": {
                    "name": "weight",
                    "type": "string",
                    "required": false,
                    "values": [
                      "normal",
                      "medium",
                      "semibold"
                    ]
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "sortable": {
                    "name": "sortable",
                    "type": "boolean",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "className": {
                    "name": "className",
                    "type": "string",
                    "required": false
                  },
                  "align": {
                    "name": "align",
                    "type": "string",
                    "required": false,
                    "values": [
                      "left",
                      "center",
                      "right"
                    ]
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "badge",
                      "date",
                      "currency",
                      "number",
                      "percent",
                      "boolean"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "width": {
                    "name": "width",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "accepts": {
              "type": "string",
              "default": "Accepts",
              "label": "Accepts",
              "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
              "tier": "presentation"
            },
            "fields": {
              "type": "[TableViewFieldsItem]",
              "default": [
                {
                  "field": "Field",
                  "weight": "normal",
                  "format": "badge",
                  "icon": "circle",
                  "align": "left",
                  "sortable": false,
                  "className": "Class Name",
                  "key": "Key",
                  "label": "Label",
                  "width": "Width",
                  "header": "Header"
                }
              ],
              "label": "Fields",
              "description": "Alias for `columns`.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "badge",
                      "date",
                      "currency",
                      "number",
                      "percent",
                      "boolean"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "align": {
                    "name": "align",
                    "type": "string",
                    "required": false,
                    "values": [
                      "left",
                      "center",
                      "right"
                    ]
                  },
                  "className": {
                    "name": "className",
                    "type": "string",
                    "required": false
                  },
                  "sortable": {
                    "name": "sortable",
                    "type": "boolean",
                    "required": false
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  },
                  "weight": {
                    "name": "weight",
                    "type": "string",
                    "required": false,
                    "values": [
                      "normal",
                      "medium",
                      "semibold"
                    ]
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "selectable": {
              "type": "boolean",
              "default": false,
              "label": "Selectable",
              "description": "Render a leading checkbox column. Selection changes emit `selectEvent`.",
              "tier": "presentation"
            },
            "reorderEvent": {
              "type": "string",
              "default": "Reorder Event",
              "label": "Reorder Event",
              "description": "Bus event fired on in-container reorder. Payload: { id, oldIndex, newIndex }",
              "tier": "presentation"
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently-selected ids (controlled). Falls back to local state when omitted.",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "emptyMessage": {
              "type": "string",
              "default": "Empty Message",
              "label": "Empty Message",
              "description": "Message shown when there are no rows.",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Max rows before a 'Show More' button. Defaults to 0 (show all).",
              "tier": "presentation"
            },
            "sortable": {
              "type": "boolean",
              "default": false,
              "label": "Sortable",
              "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
              "tier": "presentation"
            },
            "itemActions": {
              "type": "[TableViewItemActionsItem]",
              "default": [],
              "label": "Item Actions",
              "description": "Per-row action buttons (trailing column).",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost",
                      "danger"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TableViewPage",
          "path": "/table-view",
          "traits": [
            {
              "ref": "TableViewRender"
            }
          ]
        }
      ]
    }
  ]
}