{
  "name": "ui-lightbox",
  "version": "1.0.0",
  "description": "Lightbox — UI factory (1:1 with the @almadar/ui lightbox pattern).",
  "orbitals": [
    {
      "name": "LightboxOrbital",
      "entity": {
        "name": "LightboxItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "LightboxRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "LightboxItem",
          "emits": [
            {
              "event": "CLOSE",
              "description": "Direct onClose callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "INDEX_CHANGE",
              "description": "Direct onIndexChange callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            },
            {
              "event": "OPEN",
              "description": "Open the Lightbox.",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN",
                "name": "Open",
                "description": "Open the Lightbox.",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "description": "Direct onClose callback",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INDEX_CHANGE",
                "name": "Index Change",
                "description": "Direct onIndexChange callback",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "Open Lightbox",
                      "type": "button",
                      "action": "OPEN"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    {
                      "showCounter": "@config.showCounter",
                      "closeAction": "@config.closeAction",
                      "images": "@config.images",
                      "currentIndex": "@config.currentIndex",
                      "isOpen": "@config.isOpen",
                      "onClose": "CLOSE",
                      "className": "@config.className",
                      "type": "lightbox",
                      "onIndexChange": "INDEX_CHANGE"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "Open Lightbox",
                      "type": "button",
                      "action": "OPEN"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "currentIndex": {
              "type": "number",
              "default": 0.0,
              "label": "Current Index",
              "description": "Current image index",
              "tier": "presentation"
            },
            "closeAction": {
              "type": "string",
              "default": "Close Action",
              "label": "Close Action",
              "description": "Declarative close event name",
              "tier": "presentation"
            },
            "isOpen": {
              "type": "boolean",
              "default": false,
              "label": "Is Open",
              "description": "Whether the lightbox is open",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "showCounter": {
              "type": "boolean",
              "default": true,
              "label": "Show Counter",
              "description": "Show image counter (e.g., '3 of 12')",
              "tier": "presentation"
            },
            "images": {
              "type": "[LightboxImagesItem]",
              "default": [
                {
                  "alt": "Alt",
                  "caption": "Caption",
                  "src": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                }
              ],
              "label": "Images",
              "description": "Array of images to display",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "caption": {
                    "name": "caption",
                    "type": "string",
                    "required": false
                  },
                  "src": {
                    "name": "src",
                    "type": "string",
                    "required": false
                  },
                  "alt": {
                    "name": "alt",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LightboxPage",
          "path": "/lightbox",
          "traits": [
            {
              "ref": "LightboxRender"
            }
          ]
        }
      ]
    }
  ]
}