{
  "description": "Lightbox — UI factory (1:1 with the @almadar/ui lightbox pattern).",
  "name": "ui-lightbox",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LightboxItem",
        "persistence": "runtime"
      },
      "name": "LightboxOrbital",
      "pages": [
        {
          "name": "LightboxPage",
          "path": "/lightbox",
          "traits": [
            {
              "ref": "LightboxRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "closeAction": {
              "default": "Close Action",
              "description": "Declarative close event name",
              "label": "Close Action",
              "tier": "presentation",
              "type": "string"
            },
            "currentIndex": {
              "default": 0.0,
              "description": "Current image index",
              "label": "Current Index",
              "tier": "presentation",
              "type": "number"
            },
            "images": {
              "default": [
                {
                  "alt": "Alt",
                  "caption": "Caption",
                  "src": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                },
                {
                  "alt": "Alt 2",
                  "caption": "Caption 2",
                  "src": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                }
              ],
              "description": "Array of images to display",
              "items": {
                "properties": {
                  "alt": {
                    "name": "alt",
                    "required": false,
                    "type": "string"
                  },
                  "caption": {
                    "name": "caption",
                    "required": false,
                    "type": "string"
                  },
                  "src": {
                    "name": "src",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Images",
              "tier": "presentation",
              "type": "[LightboxImagesItem]"
            },
            "isOpen": {
              "default": false,
              "description": "Whether the lightbox is open",
              "label": "Is Open",
              "tier": "presentation",
              "type": "boolean"
            },
            "showCounter": {
              "default": true,
              "description": "Show image counter (e.g., '3 of 12')",
              "label": "Show Counter",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Direct onClose callback",
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Direct onIndexChange callback",
              "event": "INDEX_CHANGE",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Open the Lightbox.",
              "event": "OPEN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LightboxItem",
          "name": "LightboxRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Open the Lightbox.",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Direct onClose callback",
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Direct onIndexChange callback",
                "key": "INDEX_CHANGE",
                "name": "Index Change",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Lightbox",
                      "type": "button"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    {
                      "className": "@config.className",
                      "closeAction": "@config.closeAction",
                      "currentIndex": "@config.currentIndex",
                      "images": "@config.images",
                      "isOpen": "@config.isOpen",
                      "onClose": "CLOSE",
                      "onIndexChange": "INDEX_CHANGE",
                      "showCounter": "@config.showCounter",
                      "type": "lightbox"
                    }
                  ]
                ],
                "event": "OPEN",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "OPEN",
                      "label": "Open Lightbox",
                      "type": "button"
                    }
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}