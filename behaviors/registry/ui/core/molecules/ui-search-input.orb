{
  "name": "ui-search-input",
  "version": "1.0.0",
  "description": "SearchInput — UI factory (1:1 with the @almadar/ui search-input pattern).",
  "orbitals": [
    {
      "name": "SearchInputOrbital",
      "entity": {
        "name": "SearchInputItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "string",
            "default": "Value"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchInputRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "value"
            ]
          },
          "category": "interaction",
          "linkedEntity": "SearchInputItem",
          "emits": [
            {
              "event": "SEARCH",
              "description": "Callback when search value changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "description": "Callback when search value changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SearchInputItem",
                    {}
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "value": "@entity.value",
                      "onSearch": "SEARCH",
                      "isLoading": "@config.isLoading",
                      "debounceMs": "@config.debounceMs",
                      "className": "@config.className",
                      "query": "@config.query",
                      "type": "search-input",
                      "event": "@config.event",
                      "entity": "SearchInputItem",
                      "clearable": "@config.clearable",
                      "placeholder": "@config.placeholder"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "debounceMs": "@config.debounceMs",
                      "onSearch": "SEARCH",
                      "query": "@config.query",
                      "placeholder": "@config.placeholder",
                      "value": "@entity.value",
                      "className": "@config.className",
                      "entity": "SearchInputItem",
                      "event": "@config.event",
                      "type": "search-input",
                      "clearable": "@config.clearable",
                      "isLoading": "@config.isLoading"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Search value (controlled mode)",
              "tier": "presentation"
            },
            "clearable": {
              "type": "boolean",
              "default": true,
              "label": "Clearable",
              "description": "Show clear button",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "query": {
              "type": "string",
              "default": "Query",
              "label": "Query",
              "description": "Query singleton binding for state management. When provided, syncs search state with the query singleton. Example: '@TaskQuery'",
              "tier": "presentation"
            },
            "event": {
              "type": "string",
              "default": "Event",
              "label": "Event",
              "description": "Event name to dispatch on search (schema metadata, wired by trait) This is metadata used by the trait generator, not by the component.",
              "tier": "presentation"
            },
            "debounceMs": {
              "type": "number",
              "default": 300.0,
              "label": "Debounce Ms",
              "description": "Debounce delay in milliseconds",
              "tier": "presentation"
            },
            "placeholder": {
              "type": "string",
              "default": "Placeholder",
              "label": "Placeholder",
              "description": "Placeholder text",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Show loading state",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SearchInputPage",
          "path": "/search-input",
          "traits": [
            {
              "ref": "SearchInputRender"
            }
          ]
        }
      ]
    }
  ]
}