{
  "name": "ui-breadcrumb",
  "version": "1.0.0",
  "description": "Breadcrumb — UI factory (1:1 with the @almadar/ui breadcrumb pattern).",
  "orbitals": [
    {
      "name": "BreadcrumbOrbital",
      "entity": {
        "name": "BreadcrumbItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BreadcrumbRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BreadcrumbItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "breadcrumb",
                      "items": "@config.items",
                      "separator": "@config.separator",
                      "className": "@config.className",
                      "maxItems": "@config.maxItems"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "maxItems": {
              "type": "number",
              "default": 0.0,
              "label": "Max Items",
              "description": "Maximum items to show (truncates with ellipsis)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "separator": {
              "type": "icon",
              "label": "Separator",
              "description": "Separator icon (canonical kebab-case name or LucideIcon component)",
              "tier": "presentation"
            },
            "items": {
              "type": "[BreadcrumbItemsItem]",
              "default": [
                {
                  "label": "Label"
                }
              ],
              "label": "Items",
              "description": "Breadcrumb items",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "path": {
                    "name": "path",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "isCurrent": {
                    "name": "isCurrent",
                    "type": "boolean",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BreadcrumbPage",
          "path": "/breadcrumb",
          "traits": [
            {
              "ref": "BreadcrumbRender"
            }
          ]
        }
      ]
    }
  ]
}