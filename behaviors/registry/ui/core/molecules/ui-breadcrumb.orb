{
  "description": "Breadcrumb — UI factory (1:1 with the @almadar/ui breadcrumb pattern).",
  "name": "ui-breadcrumb",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "BreadcrumbItem",
        "persistence": "runtime"
      },
      "name": "BreadcrumbOrbital",
      "pages": [
        {
          "name": "BreadcrumbPage",
          "path": "/breadcrumb",
          "traits": [
            {
              "ref": "BreadcrumbRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "href": "Href",
                  "icon": "circle",
                  "isCurrent": false,
                  "label": "Label",
                  "path": "Path"
                },
                {
                  "href": "Href 2",
                  "icon": "circle",
                  "isCurrent": true,
                  "label": "Label 2",
                  "path": "Path 2"
                }
              ],
              "description": "Breadcrumb items",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "isCurrent": {
                    "name": "isCurrent",
                    "required": false,
                    "type": "boolean"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "path": {
                    "name": "path",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[BreadcrumbItemsItem]"
            },
            "maxItems": {
              "default": 0.0,
              "description": "Maximum items to show (truncates with ellipsis)",
              "label": "Max Items",
              "tier": "presentation",
              "type": "number"
            },
            "separator": {
              "description": "Separator icon (canonical kebab-case name or LucideIcon component)",
              "label": "Separator",
              "tier": "presentation",
              "type": "icon"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "BreadcrumbItem",
          "name": "BreadcrumbRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "items": "@config.items",
                      "maxItems": "@config.maxItems",
                      "separator": "@config.separator",
                      "type": "breadcrumb"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}