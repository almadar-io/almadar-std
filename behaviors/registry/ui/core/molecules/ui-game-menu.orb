{
  "name": "ui-game-menu",
  "version": "1.0.0",
  "description": "GameMenu — UI factory (1:1 with the @almadar/ui game-menu pattern).",
  "orbitals": [
    {
      "name": "GameMenuOrbital",
      "entity": {
        "name": "GameMenuItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GameMenuRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GameMenuItem",
          "emits": [
            {
              "event": "SELECT",
              "description": "Called when an option is selected (legacy callback, prefer event bus)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "option",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "event",
                      "type": "string"
                    },
                    {
                      "name": "navigatesTo",
                      "type": "string"
                    },
                    {
                      "name": "variant",
                      "type": "string"
                    },
                    {
                      "name": "disabled",
                      "type": "boolean"
                    },
                    {
                      "name": "subLabel",
                      "type": "string"
                    },
                    {
                      "name": "action",
                      "type": "string"
                    }
                  ]
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "description": "Called when an option is selected (legacy callback, prefer event bus)",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "option",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "event",
                        "type": "string"
                      },
                      {
                        "name": "navigatesTo",
                        "type": "string"
                      },
                      {
                        "name": "variant",
                        "type": "string"
                      },
                      {
                        "name": "disabled",
                        "type": "boolean"
                      },
                      {
                        "name": "subLabel",
                        "type": "string"
                      },
                      {
                        "name": "action",
                        "type": "string"
                      }
                    ]
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "@config.title",
                      "subtitle": "@config.subtitle",
                      "className": "@config.className",
                      "menuItems": "@config.menuItems",
                      "logo": "@config.logo",
                      "type": "game-menu",
                      "background": "@config.background",
                      "onSelect": "SELECT",
                      "options": "@config.options"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Menu title",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "",
              "label": "Subtitle",
              "description": "Optional subtitle or version",
              "tier": "presentation"
            },
            "logo": {
              "type": "string",
              "default": "",
              "label": "Logo",
              "description": "Logo image URL",
              "tier": "presentation"
            },
            "menuItems": {
              "type": "[GameMenuMenuItemsItem]",
              "default": [],
              "label": "Menu Items",
              "description": "Alias for options (schema compatibility)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "action": {
                    "name": "action",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "subLabel": {
                    "name": "subLabel",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "options": {
              "type": "[GameMenuOptionsItem]",
              "default": [],
              "label": "Options",
              "description": "Menu options - accepts readonly for compatibility with generated const arrays",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "type": "string",
                    "required": false
                  },
                  "subLabel": {
                    "name": "subLabel",
                    "type": "string",
                    "required": false
                  },
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "action": {
                    "name": "action",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "background": {
              "type": "string",
              "default": "",
              "label": "Background",
              "description": "Background image or gradient",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameMenuPage",
          "path": "/game-menu",
          "traits": [
            {
              "ref": "GameMenuRender"
            }
          ]
        }
      ]
    }
  ]
}
