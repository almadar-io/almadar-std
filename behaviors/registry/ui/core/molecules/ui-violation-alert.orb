{
  "name": "ui-violation-alert",
  "version": "1.0.0",
  "description": "ViolationAlert — UI factory (1:1 with the @almadar/ui violation-alert pattern).",
  "orbitals": [
    {
      "name": "ViolationAlertOrbital",
      "entity": {
        "name": "ViolationAlertItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ViolationAlertRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ViolationAlertItem",
          "emits": [
            {
              "event": "DISMISS",
              "description": "Dismiss handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NAVIGATE_TO_FIELD",
              "description": "Navigate to the field that caused violation",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "fieldId",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DISMISS",
                "name": "Dismiss",
                "description": "Dismiss handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "NAVIGATE_TO_FIELD",
                "name": "Navigate To Field",
                "description": "Navigate to the field that caused violation",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "fieldId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "violation-alert",
                      "severity": "@config.severity",
                      "className": "@config.className",
                      "violation": "@config.violation",
                      "compact": "@config.compact",
                      "dismissible": "@config.dismissible",
                      "onNavigateToField": "NAVIGATE_TO_FIELD",
                      "onDismiss": "DISMISS"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "violation": {
              "type": "ViolationAlertViolation",
              "default": {
                "article": "Article",
                "penaltyAction": "Penalty Action",
                "law": "Law",
                "actionType": "measure",
                "adminAction": "Admin Action",
                "fieldId": "Field Id",
                "id": "Id",
                "tabId": "Tab Id",
                "message": "Message"
              },
              "label": "Violation",
              "description": "Violation data",
              "tier": "presentation",
              "properties": {
                "article": {
                  "name": "article",
                  "type": "string",
                  "required": true
                },
                "tabId": {
                  "name": "tabId",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "adminAction": {
                  "name": "adminAction",
                  "type": "string",
                  "required": false
                },
                "fieldId": {
                  "name": "fieldId",
                  "type": "string",
                  "required": false
                },
                "law": {
                  "name": "law",
                  "type": "string",
                  "required": true
                },
                "penaltyAction": {
                  "name": "penaltyAction",
                  "type": "string",
                  "required": false
                },
                "actionType": {
                  "name": "actionType",
                  "type": "string",
                  "required": true,
                  "values": [
                    "measure",
                    "admin",
                    "penalty"
                  ]
                }
              }
            },
            "severity": {
              "type": "string",
              "default": "warning",
              "label": "Severity",
              "description": "Visual severity (derived from actionType if not specified)",
              "tier": "presentation",
              "values": [
                "warning",
                "error"
              ]
            },
            "compact": {
              "type": "boolean",
              "default": false,
              "label": "Compact",
              "description": "Compact display mode",
              "tier": "presentation"
            },
            "dismissible": {
              "type": "boolean",
              "default": false,
              "label": "Dismissible",
              "description": "Dismissible alert",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ViolationAlertPage",
          "path": "/violation-alert",
          "traits": [
            {
              "ref": "ViolationAlertRender"
            }
          ]
        }
      ]
    }
  ]
}