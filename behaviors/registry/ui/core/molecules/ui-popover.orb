{
  "name": "ui-popover",
  "version": "1.0.0",
  "description": "Popover — UI factory (1:1 with the @almadar/ui popover pattern).",
  "orbitals": [
    {
      "name": "PopoverOrbital",
      "entity": {
        "name": "PopoverItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PopoverRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PopoverItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "text"
                        }
                      ],
                      "position": "@config.position",
                      "type": "popover",
                      "showArrow": "@config.showArrow",
                      "content": "@config.content",
                      "className": "@config.className",
                      "trigger": "@config.trigger"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "trigger": {
              "type": "string",
              "default": "click",
              "label": "Trigger",
              "description": "Trigger type",
              "tier": "presentation",
              "values": [
                "click",
                "hover"
              ]
            },
            "showArrow": {
              "type": "boolean",
              "default": true,
              "label": "Show Arrow",
              "description": "Show arrow",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "content": {
              "type": "node",
              "label": "Content",
              "description": "Popover content",
              "tier": "presentation"
            },
            "position": {
              "type": "string",
              "default": "bottom",
              "label": "Position",
              "description": "Popover position",
              "tier": "presentation",
              "values": [
                "top",
                "bottom",
                "left",
                "right"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PopoverPage",
          "path": "/popover",
          "traits": [
            {
              "ref": "PopoverRender"
            }
          ]
        }
      ]
    }
  ]
}
