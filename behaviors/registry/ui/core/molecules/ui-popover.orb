{
  "description": "Popover — UI factory (1:1 with the @almadar/ui popover pattern).",
  "name": "ui-popover",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PopoverItem",
        "persistence": "runtime"
      },
      "name": "PopoverOrbital",
      "pages": [
        {
          "name": "PopoverPage",
          "path": "/popover",
          "traits": [
            {
              "ref": "PopoverRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Popover trigger element (ReactElement or ReactNode that will be wrapped in span)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "position": {
              "default": "bottom",
              "description": "Popover position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom",
                "left",
                "right"
              ]
            },
            "showArrow": {
              "default": true,
              "description": "Show arrow",
              "label": "Show Arrow",
              "tier": "presentation",
              "type": "boolean"
            },
            "trigger": {
              "default": "click",
              "description": "Trigger type",
              "label": "Trigger",
              "tier": "presentation",
              "type": "string",
              "values": [
                "click",
                "hover"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PopoverItem",
          "name": "PopoverRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "content": [
                        {
                          "content": "Content",
                          "type": "typography"
                        }
                      ],
                      "position": "@config.position",
                      "showArrow": "@config.showArrow",
                      "trigger": "@config.trigger",
                      "type": "popover"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}