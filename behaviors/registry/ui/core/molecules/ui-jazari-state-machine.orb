{
  "description": "JazariStateMachine — UI factory (1:1 with the @almadar/ui jazari-state-machine pattern).",
  "name": "ui-jazari-state-machine",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "JazariStateMachineItem",
        "persistence": "runtime"
      },
      "name": "JazariStateMachineOrbital",
      "pages": [
        {
          "name": "JazariStateMachinePage",
          "path": "/jazari-state-machine",
          "traits": [
            {
              "ref": "JazariStateMachineRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "direction": {
              "default": "ltr",
              "description": "Text direction (default: 'ltr')",
              "label": "Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "ltr",
                "rtl"
              ]
            },
            "entityFields": {
              "default": [],
              "description": "Override entity field labels",
              "items": {
                "type": "string"
              },
              "label": "Entity Fields",
              "tier": "presentation",
              "type": "[string]"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "JazariStateMachineError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "traitIndex": {
              "default": 0.0,
              "description": "Which trait to visualize (default: 0)",
              "label": "Trait Index",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "JazariStateMachineItem",
          "name": "JazariStateMachineRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "direction": "@config.direction",
                      "entityFields": "@config.entityFields",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "traitIndex": "@config.traitIndex",
                      "type": "jazari-state-machine"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}