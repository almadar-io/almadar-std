{
  "description": "DocPagination — UI factory (1:1 with the @almadar/ui doc-pagination pattern).",
  "name": "ui-doc-pagination",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DocPaginationItem",
        "persistence": "runtime"
      },
      "name": "DocPaginationOrbital",
      "pages": [
        {
          "name": "DocPaginationPage",
          "path": "/doc-pagination",
          "traits": [
            {
              "ref": "DocPaginationRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "next": {
              "default": {
                "category": "Category",
                "href": "Href",
                "label": "Label"
              },
              "description": "Next page link",
              "label": "Next",
              "properties": {
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "href": {
                  "name": "href",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "DocPaginationNext"
            },
            "prev": {
              "default": {
                "category": "Category",
                "href": "Href",
                "label": "Label"
              },
              "description": "Previous page link",
              "label": "Prev",
              "properties": {
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "href": {
                  "name": "href",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "DocPaginationPrev"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DocPaginationItem",
          "name": "DocPaginationRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "next": "@config.next",
                      "prev": "@config.prev",
                      "type": "doc-pagination"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}