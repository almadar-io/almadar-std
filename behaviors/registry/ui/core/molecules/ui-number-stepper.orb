{
  "name": "ui-number-stepper",
  "version": "1.0.0",
  "description": "NumberStepper — UI factory (1:1 with the @almadar/ui number-stepper pattern).",
  "orbitals": [
    {
      "name": "NumberStepperOrbital",
      "entity": {
        "name": "NumberStepperItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "NumberStepperRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "value"
            ]
          },
          "category": "interaction",
          "linkedEntity": "NumberStepperItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "Direct onChange callback",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ACTION",
              "description": "Declarative event name for value changes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "Direct onChange callback",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for value changes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "className": "@config.className",
                      "actionPayload": "@config.actionPayload",
                      "label": "@config.label",
                      "min": "@config.min",
                      "value": "@entity.value",
                      "type": "number-stepper",
                      "step": "@config.step",
                      "disabled": "@config.disabled",
                      "max": "@config.max",
                      "onChange": "CHANGE",
                      "size": "@config.size"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "@config.label",
                      "size": "@config.size",
                      "min": "@config.min",
                      "disabled": "@config.disabled",
                      "actionPayload": "@config.actionPayload",
                      "type": "number-stepper",
                      "action": "ACTION",
                      "max": "@config.max",
                      "value": "@entity.value",
                      "onChange": "CHANGE",
                      "step": "@config.step",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "min": {
              "type": "number",
              "default": 0.0,
              "label": "Min",
              "description": "Minimum value",
              "tier": "presentation"
            },
            "max": {
              "type": "number",
              "default": 0.0,
              "label": "Max",
              "description": "Maximum value",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disabled state",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Accessible label",
              "tier": "presentation"
            },
            "actionPayload": {
              "type": "json",
              "default": {},
              "label": "Action Payload",
              "description": "Payload to include with the action event",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "value": {
              "type": "number",
              "default": 0.0,
              "label": "Value",
              "description": "Current value",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "step": {
              "type": "number",
              "default": 1.0,
              "label": "Step",
              "description": "Step increment",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "NumberStepperPage",
          "path": "/number-stepper",
          "traits": [
            {
              "ref": "NumberStepperRender"
            }
          ]
        }
      ]
    }
  ]
}