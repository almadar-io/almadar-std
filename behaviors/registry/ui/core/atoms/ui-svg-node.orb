{
  "name": "ui-svg-node",
  "version": "1.0.0",
  "description": "SvgNode — UI factory (1:1 with the @almadar/ui svg-node pattern).",
  "orbitals": [
    {
      "name": "SvgNodeOrbital",
      "entity": {
        "name": "SvgNodeItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SvgNodeRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SvgNodeItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "@config.variant",
                      "opacity": "@config.opacity",
                      "r": "@config.r",
                      "x": "@config.x",
                      "y": "@config.y",
                      "color": "@config.color",
                      "className": "@config.className",
                      "label": "@config.label",
                      "type": "svg-node"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "y": {
              "type": "number",
              "default": 0.0,
              "label": "Y",
              "description": "y prop",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "filled",
              "label": "Variant",
              "description": "variant prop",
              "tier": "presentation",
              "values": [
                "filled",
                "stroked",
                "pulse"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "opacity": {
              "type": "number",
              "default": 1.0,
              "label": "Opacity",
              "description": "opacity prop",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "color prop",
              "tier": "presentation"
            },
            "x": {
              "type": "number",
              "default": 0.0,
              "label": "X",
              "description": "x prop",
              "tier": "presentation"
            },
            "r": {
              "type": "number",
              "default": 6.0,
              "label": "R",
              "description": "r prop",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "label prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SvgNodePage",
          "path": "/svg-node",
          "traits": [
            {
              "ref": "SvgNodeRender"
            }
          ]
        }
      ]
    }
  ]
}