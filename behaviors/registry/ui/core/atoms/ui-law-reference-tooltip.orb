{
  "description": "LawReferenceTooltip — UI factory (1:1 with the @almadar/ui law-reference-tooltip pattern).",
  "name": "ui-law-reference-tooltip",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LawReferenceTooltipItem",
        "persistence": "runtime"
      },
      "name": "LawReferenceTooltipOrbital",
      "pages": [
        {
          "name": "LawReferenceTooltipPage",
          "path": "/law-reference-tooltip",
          "traits": [
            {
              "ref": "LawReferenceTooltipRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "position": {
              "default": "top",
              "description": "Tooltip position",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom",
                "left",
                "right"
              ]
            },
            "reference": {
              "default": {
                "article": "Article",
                "clause": "Clause",
                "law": "Law",
                "lawName": "Law Name",
                "link": "Link"
              },
              "description": "The law reference to display",
              "label": "Reference",
              "properties": {
                "article": {
                  "name": "article",
                  "required": true,
                  "type": "string"
                },
                "clause": {
                  "name": "clause",
                  "required": false,
                  "type": "string"
                },
                "law": {
                  "name": "law",
                  "required": true,
                  "type": "string"
                },
                "lawName": {
                  "name": "lawName",
                  "required": false,
                  "type": "string"
                },
                "link": {
                  "name": "link",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "LawReferenceTooltipReference"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LawReferenceTooltipItem",
          "name": "LawReferenceTooltipRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "position": "@config.position",
                      "reference": "@config.reference",
                      "type": "law-reference-tooltip"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}