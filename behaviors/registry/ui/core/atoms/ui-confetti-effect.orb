{
  "description": "ConfettiEffect — UI factory (1:1 with the @almadar/ui confetti-effect pattern).",
  "name": "ui-confetti-effect",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ConfettiEffectItem",
        "persistence": "runtime"
      },
      "name": "ConfettiEffectOrbital",
      "pages": [
        {
          "name": "ConfettiEffectPage",
          "path": "/confetti-effect",
          "traits": [
            {
              "ref": "ConfettiEffectRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "duration": {
              "default": 2000.0,
              "description": "How long the animation lasts in milliseconds",
              "label": "Duration",
              "tier": "presentation",
              "type": "number"
            },
            "particleCount": {
              "default": 30.0,
              "description": "Number of particles to spawn",
              "label": "Particle Count",
              "tier": "presentation",
              "type": "number"
            },
            "trigger": {
              "default": false,
              "description": "When this changes from false to true, a burst of particles is spawned",
              "label": "Trigger",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ConfettiEffectItem",
          "name": "ConfettiEffectRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "duration": "@config.duration",
                      "particleCount": "@config.particleCount",
                      "trigger": "@config.trigger",
                      "type": "confetti-effect"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}