{
  "description": "std-pagination — single primitive: pagination control. PAGE accepts the Pagination component's `{page}` emit; ITEMS_LOADED accepts an upstream `{data:[ObjectSpec]}` payload and derives totalPages = ceil(len/pageSize). Molecules wire `BrowseItemLoaded -> ITEMS_LOADED` to keep it in lockstep with the data hub.",
  "name": "std-pagination",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "description": "The current page number being displayed.",
            "name": "currentPage",
            "synonyms": "page, current, index",
            "type": "number"
          },
          {
            "default": 1.0,
            "description": "The total number of pages available.",
            "name": "totalPages",
            "synonyms": "page count, total pages, number of pages",
            "type": "number"
          }
        ],
        "name": "PagedItem",
        "persistence": "runtime"
      },
      "name": "PagedItemOrbital",
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPaginationRender"
            },
            {
              "ref": "PagedItemPaginationEvents"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "currentPage": {
              "default": "@entity.currentPage",
              "type": "unknown"
            },
            "pageChangeEvent": {
              "default": "@config.event",
              "type": "unknown"
            },
            "showPageSize": {
              "default": false,
              "type": "unknown"
            },
            "totalPages": {
              "default": "@entity.totalPages",
              "type": "unknown"
            }
          },
          "linkedEntity": "PagedItem",
          "name": "PagedItemPaginationRender",
          "ref": "Pagination.traits.PaginationRender"
        },
        {
          "category": "interaction",
          "config": {
            "event": {
              "default": "PAGE",
              "description": "Event emitted when the user picks a new page",
              "label": "Page-change event",
              "tier": "internal",
              "type": "string"
            },
            "pageSize": {
              "default": 10.0,
              "description": "Rows per page used to derive total page count",
              "label": "Page size",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Indicates a change in the currently displayed page.",
              "event": "PAGE",
              "payloadSchema": [
                {
                  "name": "page",
                  "required": true,
                  "type": "number"
                }
              ],
              "synonyms": "page-change, navigate, go-to",
              "tier": "domain"
            },
            {
              "description": "Indicates a single item has been loaded within a paginated view.",
              "event": "PagedItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PagedItem]"
                }
              ],
              "synonyms": "item-loaded, data-received, entry-loaded",
              "tier": "domain"
            }
          ],
          "linkedEntity": "PagedItem",
          "name": "PagedItemPaginationEvents",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates a single item has been loaded within a paginated view.",
                "key": "PagedItemLoaded",
                "name": "PagedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PagedItem]"
                  }
                ],
                "synonyms": "item-loaded, data-received, entry-loaded",
                "tier": "domain"
              },
              {
                "description": "Indicates a change in the currently displayed page.",
                "key": "PAGE",
                "name": "Page",
                "payloadSchema": [
                  {
                    "name": "page",
                    "required": true,
                    "type": "number"
                  }
                ],
                "synonyms": "page-change, navigate, go-to",
                "tier": "domain"
              },
              {
                "description": "Data has been loaded and pagination limits updated.",
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ],
                "synonyms": "data-ready, content-loaded, refresh",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.totalPages",
                    1.0
                  ],
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded"
                      }
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "event": "PagedItemLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    "@payload.page"
                  ]
                ],
                "event": "PAGE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.totalPages",
                    [
                      "math/ceil",
                      [
                        "/",
                        "@payload.totalCount",
                        "@config.pageSize"
                      ]
                    ]
                  ]
                ],
                "event": "ITEMS_LOADED",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Pagination",
          "from": "std/behaviors/ui-pagination"
        }
      ]
    }
  ],
  "version": "1.0.0"
}