      },
      "pag_01KXG04H3A42QE3TGX5PXK9B5Y": {
        "bakedName": "PagedItemPaginationPage",
        "curName": "PagedItemPaginationPage",
        "id": "pag_01KXG04H3A42QE3TGX5PXK9B5Y",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG04H33CGDADNXRK0H2MXRN": {
        "bakedName": "PagedItemPagination",
        "curName": "PagedItemPagination",
        "id": "trt_01KXG04H33CGDADNXRK0H2MXRN",
