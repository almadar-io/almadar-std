      },
      "evt_01KXG04H33ESA7CZW8PBC7QW7C": {
        "bakedName": "INIT",
        "curName": "INIT",
        "id": "evt_01KXG04H33ESA7CZW8PBC7QW7C",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04H33CGDADNXRK0H2MXRN",
        "renames": []
      },
      "evt_01KXG04H3AH44RBBN0Z4HY7GQ9": {
        "bakedName": "PagedItemLoaded",
        "curName": "PagedItemLoaded",
        "id": "evt_01KXG04H3AH44RBBN0Z4HY7GQ9",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04H33CGDADNXRK0H2MXRN",
        "renames": []
      },
      "evt_01KXG04H3AMAJWFXYDPN6NZ6NY": {
        "bakedName": "PAGE",
        "curName": "PAGE",
        "id": "evt_01KXG04H3AMAJWFXYDPN6NZ6NY",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04H33CGDADNXRK0H2MXRN",
        "renames": []
      },
      "evt_01KXG04H3AYMRKHYRF1SA09XWD": {
        "bakedName": "ITEMS_LOADED",
        "curName": "ITEMS_LOADED",
        "id": "evt_01KXG04H3AYMRKHYRF1SA09XWD",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04H33CGDADNXRK0H2MXRN",
