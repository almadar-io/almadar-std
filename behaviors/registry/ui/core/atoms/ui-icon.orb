{
  "name": "ui-icon",
  "version": "1.0.0",
  "description": "Icon — UI factory (1:1 with the @almadar/ui icon pattern).",
  "orbitals": [
    {
      "name": "IconOrbital",
      "entity": {
        "name": "IconItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "IconRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "IconItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "@config.icon",
                      "color": "@config.color",
                      "className": "@config.className",
                      "name": "@config.name",
                      "size": "@config.size",
                      "type": "icon",
                      "style": "@config.style",
                      "animation": "@config.animation",
                      "strokeWidth": "@config.strokeWidth"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "strokeWidth": {
              "type": "number",
              "default": 0.0,
              "label": "Stroke Width",
              "description": "Icon stroke width - uses theme default if not specified",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "style": {
              "type": "json",
              "label": "Style",
              "description": "Inline style",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "primary",
              "label": "Color",
              "description": "Semantic palette token or an arbitrary Tailwind color class.",
              "tier": "presentation",
              "values": [
                "primary",
                "secondary",
                "success",
                "warning",
                "error",
                "muted"
              ]
            },
            "animation": {
              "type": "string",
              "default": "none",
              "label": "Animation",
              "description": "Animation type",
              "tier": "presentation",
              "values": [
                "spin",
                "pulse",
                "none"
              ]
            },
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Lucide icon component (preferred for type-safe usage), OR a canonical kebab-case icon name string — a string is treated exactly like `name` so trait/factory authors can pass an icon by name through the `icon` prop.",
              "tier": "presentation"
            },
            "name": {
              "type": "string",
              "default": "Name",
              "label": "Name",
              "description": "Icon name as string (resolved from iconMap)",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size of the icon",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "IconPage",
          "path": "/icon",
          "traits": [
            {
              "ref": "IconRender"
            }
          ]
        }
      ]
    }
  ]
}