{
  "name": "ui-svg-stack",
  "version": "1.0.0",
  "description": "SvgStack — UI factory (1:1 with the @almadar/ui svg-stack pattern).",
  "orbitals": [
    {
      "name": "SvgStackOrbital",
      "entity": {
        "name": "SvgStackItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SvgStackRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SvgStackItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "opacity": "@config.opacity",
                      "layers": "@config.layers",
                      "x": "@config.x",
                      "height": "@config.height",
                      "y": "@config.y",
                      "labels": "@config.labels",
                      "type": "svg-stack",
                      "color": "@config.color",
                      "width": "@config.width",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "width": {
              "type": "number",
              "default": 60.0,
              "label": "Width",
              "description": "width prop",
              "tier": "presentation"
            },
            "opacity": {
              "type": "number",
              "default": 1.0,
              "label": "Opacity",
              "description": "opacity prop",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "color prop",
              "tier": "presentation"
            },
            "layers": {
              "type": "number",
              "default": 0.0,
              "label": "Layers",
              "description": "layers prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "labels": {
              "type": "[string]",
              "default": [],
              "label": "Labels",
              "description": "labels prop",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "y": {
              "type": "number",
              "default": 0.0,
              "label": "Y",
              "description": "y prop",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 40.0,
              "label": "Height",
              "description": "height prop",
              "tier": "presentation"
            },
            "x": {
              "type": "number",
              "default": 0.0,
              "label": "X",
              "description": "x prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SvgStackPage",
          "path": "/svg-stack",
          "traits": [
            {
              "ref": "SvgStackRender"
            }
          ]
        }
      ]
    }
  ]
}
