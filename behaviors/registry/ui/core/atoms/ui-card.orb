{
  "description": "Card — UI factory (1:1 with the @almadar/ui card pattern).",
  "name": "ui-card",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CardItem",
        "persistence": "runtime"
      },
      "name": "CardOrbital",
      "pages": [
        {
          "name": "CardPage",
          "path": "/card",
          "traits": [
            {
              "ref": "CardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "action": {
              "default": "ACTION",
              "description": "Declarative event key emitted on click for trait dispatch",
              "label": "Action",
              "tier": "presentation",
              "type": "string"
            },
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Card content",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "loading": {
              "default": false,
              "description": "Shows a skeleton/spinner overlay while true.",
              "label": "Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "look": {
              "default": "elevated",
              "description": "Layer 2 visual treatment — orthogonal to the semantic variant.",
              "label": "Look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            },
            "padding": {
              "default": "md",
              "description": "padding prop",
              "label": "Padding",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "sm",
                "md",
                "lg"
              ]
            },
            "shadow": {
              "default": "none",
              "description": "Shadow size override",
              "label": "Shadow",
              "tier": "presentation",
              "type": "string",
              "values": [
                "none",
                "sm",
                "md",
                "lg"
              ]
            },
            "subtitle": {
              "default": "Subtitle",
              "description": "Card subtitle - renders below title",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Title",
              "description": "Card title - renders in header if provided",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "variant": {
              "default": "bordered",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "bordered",
                "elevated",
                "interactive"
              ]
            }
          },
          "emits": [
            {
              "description": "Declarative event key emitted on click for trait dispatch",
              "event": "@config.action",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CardItem",
          "name": "CardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event key emitted on click for trait dispatch",
                "key": "@config.action",
                "name": "@config.action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "@config.action",
                      "children": "@config.children",
                      "className": "@config.className",
                      "loading": "@config.loading",
                      "look": "@config.look",
                      "padding": "@config.padding",
                      "shadow": "@config.shadow",
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "type": "card",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}