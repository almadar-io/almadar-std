{
  "description": "AtlasPanel — UI factory (1:1 with the @almadar/ui atlas-panel pattern).",
  "name": "ui-atlas-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AtlasPanelItem",
        "persistence": "runtime"
      },
      "name": "AtlasPanelOrbital",
      "pages": [
        {
          "name": "AtlasPanelPage",
          "path": "/atlas-panel",
          "traits": [
            {
              "ref": "AtlasPanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "asset": {
              "default": {
                "category": "Category",
                "name": "Name"
              },
              "description": "asset prop",
              "label": "Asset",
              "properties": {
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "AtlasPanelAsset"
            },
            "borderSlice": {
              "default": 16.0,
              "description": "Border thickness (source pixels) for the 9-slice cut.",
              "label": "Border Slice",
              "tier": "presentation",
              "type": "number"
            },
            "borderWidth": {
              "default": 16.0,
              "description": "Rendered border width in CSS px.",
              "label": "Border Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "mode": {
              "default": "nineSlice",
              "description": "'nineSlice' scales edges crisp (panels/buttons); 'repeat' tiles the slice (pattern fills).",
              "label": "Mode",
              "tier": "presentation",
              "type": "string",
              "values": [
                "nineSlice",
                "repeat"
              ]
            },
            "style": {
              "default": {},
              "description": "style prop",
              "label": "Style",
              "tier": "presentation",
              "type": "json"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AtlasPanelItem",
          "name": "AtlasPanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "asset": "@config.asset",
                      "borderSlice": "@config.borderSlice",
                      "borderWidth": "@config.borderWidth",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "mode": "@config.mode",
                      "style": "@config.style",
                      "type": "atlas-panel"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}