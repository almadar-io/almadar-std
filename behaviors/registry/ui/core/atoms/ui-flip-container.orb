{
  "description": "FlipContainer — UI factory (1:1 with the @almadar/ui flip-container pattern).",
  "name": "ui-flip-container",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FlipContainerItem",
        "persistence": "runtime"
      },
      "name": "FlipContainerOrbital",
      "pages": [
        {
          "name": "FlipContainerPage",
          "path": "/flip-container",
          "traits": [
            {
              "ref": "FlipContainerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "The two face elements (front and back)",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Optional className for the outer wrapper",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "flipped": {
              "default": false,
              "description": "Whether the container is flipped (rotateY 180deg)",
              "label": "Flipped",
              "tier": "presentation",
              "type": "boolean"
            },
            "onClick": {
              "default": "CLICK",
              "description": "Click handler on the outer wrapper",
              "label": "On Click",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Click handler on the outer wrapper",
              "event": "@config.onClick",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FlipContainerItem",
          "name": "FlipContainerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler on the outer wrapper",
                "key": "@config.onClick",
                "name": "@config.on click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "flipped": "@config.flipped",
                      "onClick": "@config.onClick",
                      "type": "flip-container"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}