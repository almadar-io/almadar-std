{
  "description": "Center — UI factory (1:1 with the @almadar/ui center pattern).",
  "name": "ui-center",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CenterItem",
        "persistence": "runtime"
      },
      "name": "CenterOrbital",
      "pages": [
        {
          "name": "CenterPage",
          "path": "/center",
          "traits": [
            {
              "ref": "CenterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Children elements",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Custom class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "fullHeight": {
              "default": false,
              "description": "Fill available height",
              "label": "Full Height",
              "tier": "presentation",
              "type": "boolean"
            },
            "fullWidth": {
              "default": false,
              "description": "Fill available width",
              "label": "Full Width",
              "tier": "presentation",
              "type": "boolean"
            },
            "horizontal": {
              "default": true,
              "description": "Center only horizontally",
              "label": "Horizontal",
              "tier": "presentation",
              "type": "boolean"
            },
            "inline": {
              "default": false,
              "description": "Center inline (width fits content) vs block (full width)",
              "label": "Inline",
              "tier": "presentation",
              "type": "boolean"
            },
            "minHeight": {
              "default": "Min Height",
              "description": "Minimum height (useful for vertical centering)",
              "label": "Min Height",
              "tier": "presentation",
              "type": "string"
            },
            "style": {
              "default": {},
              "description": "Inline styles",
              "label": "Style",
              "tier": "presentation",
              "type": "json"
            },
            "vertical": {
              "default": true,
              "description": "Center only vertically",
              "label": "Vertical",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CenterItem",
          "name": "CenterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "fullHeight": "@config.fullHeight",
                      "fullWidth": "@config.fullWidth",
                      "horizontal": "@config.horizontal",
                      "inline": "@config.inline",
                      "minHeight": "@config.minHeight",
                      "style": "@config.style",
                      "type": "center",
                      "vertical": "@config.vertical"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}