            {
              "ref": "BadgeRender",
              "refId": "trt_01KXG04J66F1NVJTF3ZS57P7K6"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "amount": {
              "default": 0.0,
              "description": "Numeric count or amount to display in badge",
              "label": "Amount",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Lucide icon component or canonical kebab-case icon name string",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "iconAsset": {
              "description": "Asset image rendered as the badge icon; takes precedence over icon when provided.",
              "label": "Icon Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "BadgeIconAsset"
            },
            "label": {
              "default": "",
              "description": "Badge label text (alternative to children for schema-driven rendering). Numeric values are auto-coerced to string for rendering — common case is unread counts, error counts, status codes, etc.",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "onRemove": {
              "default": "REMOVE",
              "description": "When set, renders a small X button on the right of the badge that invokes this handler — turns the badge into a removable chip. Used by the TagInput molecule and other 'list of removable values' surfaces.",
              "label": "On Remove",
              "tier": "presentation",
              "type": "string"
            },
            "removeLabel": {
              "default": "",
              "description": "Accessible label for the remove button. Defaults to 'Remove'.",
              "label": "Remove Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "sm",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "variant": {
              "default": "default",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "primary",
                "secondary",
                "success",
                "warning",
                "danger",
                "error",
                "info",
                "neutral"
              ]
            }
          },
          "emits": [
            {
              "description": "When set, renders a small X button on the right of the badge that invokes this handler — turns the badge into a removable chip. Used by the TagInput molecule and other 'list of removable values' surfaces.",
              "event": "@config.onRemove",
              "eventId": "evt_01KXG04J690VY1KHNSN7EFXBQX",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
