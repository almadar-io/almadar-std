          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04J66HMQ87R0XX75VN72Q",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "When set, renders a small X button on the right of the badge that invokes this handler — turns the badge into a removable chip. Used by the TagInput molecule and other 'list of removable values' surfaces.",
                "id": "evt_01KXG04J690VY1KHNSN7EFXBQX",
                "key": "@config.onRemove",
                "name": "@config.on remove",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "amount": "@config.amount",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "iconAsset": "@config.iconAsset",
                      "label": "@config.label",
                      "onRemove": "@config.onRemove",
                      "removeLabel": "@config.removeLabel",
                      "size": "@config.size",
                      "type": "badge",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04J66HMQ87R0XX75VN72Q",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
