{
  "description": "DayCell — UI factory (1:1 with the @almadar/ui day-cell pattern).",
  "name": "ui-day-cell",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DayCellItem",
        "persistence": "runtime"
      },
      "name": "DayCellOrbital",
      "pages": [
        {
          "name": "DayCellPage",
          "path": "/day-cell",
          "traits": [
            {
              "ref": "DayCellRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "date": {
              "default": "2024-01-01",
              "description": "The date this cell represents. Optional at the dynamic render edge: an unbound `@config.date` arrives as `undefined`, so the cell falls back to today.",
              "label": "Date",
              "tier": "presentation",
              "type": "date"
            },
            "isToday": {
              "default": false,
              "description": "Whether this date is today",
              "label": "Is Today",
              "tier": "presentation",
              "type": "boolean"
            },
            "onClick": {
              "default": "CLICK",
              "description": "Called when the day is clicked",
              "label": "On Click",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Called when the day is clicked",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "date",
                  "type": "date"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DayCellItem",
          "name": "DayCellRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when the day is clicked",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "date",
                    "type": "date"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "date": "@config.date",
                      "isToday": "@config.isToday",
                      "onClick": "@config.onClick",
                      "type": "day-cell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}