{
  "name": "ui-day-cell",
  "version": "1.0.0",
  "description": "DayCell — UI factory (1:1 with the @almadar/ui day-cell pattern).",
  "orbitals": [
    {
      "name": "DayCellOrbital",
      "entity": {
        "name": "DayCellItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DayCellRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DayCellItem",
          "emits": [
            {
              "event": "CLICK",
              "description": "Called when the day is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "date",
                  "type": "date"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Called when the day is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "date",
                    "type": "date"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "date": "@config.date",
                      "isToday": "@config.isToday",
                      "className": "@config.className",
                      "type": "day-cell",
                      "onClick": "CLICK"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "date": {
              "type": "date",
              "default": "2024-01-01",
              "label": "Date",
              "description": "The date this cell represents. Optional at the dynamic render edge: an unbound `@config.date` arrives as `undefined`, so the cell falls back to today.",
              "tier": "presentation"
            },
            "isToday": {
              "type": "boolean",
              "default": false,
              "label": "Is Today",
              "description": "Whether this date is today",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DayCellPage",
          "path": "/day-cell",
          "traits": [
            {
              "ref": "DayCellRender"
            }
          ]
        }
      ]
    }
  ]
}