{
  "name": "ui-box",
  "version": "1.0.0",
  "description": "Box — UI factory (1:1 with the @almadar/ui box pattern).",
  "orbitals": [
    {
      "name": "BoxOrbital",
      "entity": {
        "name": "BoxItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BoxRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BoxItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOVER",
              "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false } on mouseEnter/mouseLeave",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "HOVER",
                "name": "Hover",
                "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false } on mouseEnter/mouseLeave",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "border": "@config.border",
                      "overflow": "@config.overflow",
                      "hoverEvent": "HOVER",
                      "marginX": "@config.marginX",
                      "actionPayload": "@config.actionPayload",
                      "action": "ACTION",
                      "fullHeight": "@config.fullHeight",
                      "marginY": "@config.marginY",
                      "maxWidth": "@config.maxWidth",
                      "padding": "@config.padding",
                      "className": "@config.className",
                      "position": "@config.position",
                      "type": "box",
                      "bg": "@config.bg",
                      "fullWidth": "@config.fullWidth",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sample content"
                        }
                      ],
                      "margin": "@config.margin",
                      "rounded": "@config.rounded",
                      "display": "@config.display",
                      "shadow": "@config.shadow",
                      "paddingX": "@config.paddingX",
                      "paddingY": "@config.paddingY"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "paddingX": {
              "type": "string",
              "default": "none",
              "label": "Padding X",
              "description": "Horizontal padding (overrides padding for x-axis)",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "fullHeight": {
              "type": "boolean",
              "default": false,
              "label": "Full Height",
              "description": "Fill available height",
              "tier": "presentation"
            },
            "bg": {
              "type": "string",
              "default": "transparent",
              "label": "Bg",
              "description": "Background color",
              "tier": "presentation",
              "values": [
                "transparent",
                "primary",
                "secondary",
                "muted",
                "accent",
                "surface",
                "overlay"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "actionPayload": {
              "type": "json",
              "default": {},
              "label": "Action Payload",
              "description": "Payload to include with the action event",
              "tier": "presentation"
            },
            "padding": {
              "type": "string",
              "default": "none",
              "label": "Padding",
              "description": "Padding on all sides",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "border": {
              "type": "boolean",
              "default": false,
              "label": "Border",
              "description": "Show border",
              "tier": "presentation"
            },
            "overflow": {
              "type": "string",
              "default": "auto",
              "label": "Overflow",
              "description": "Overflow behavior",
              "tier": "presentation",
              "values": [
                "auto",
                "hidden",
                "visible",
                "scroll"
              ]
            },
            "shadow": {
              "type": "string",
              "default": "none",
              "label": "Shadow",
              "description": "Box shadow",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "maxWidth": {
              "type": "string",
              "default": "Max Width",
              "label": "Max Width",
              "description": "Maximum width (CSS value, e.g., '550px', '80rem')",
              "tier": "presentation"
            },
            "rounded": {
              "type": "string",
              "default": "none",
              "label": "Rounded",
              "description": "Border radius",
              "tier": "presentation",
              "values": [
                "none",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "full"
              ]
            },
            "position": {
              "type": "string",
              "default": "relative",
              "label": "Position",
              "description": "Position",
              "tier": "presentation",
              "values": [
                "relative",
                "absolute",
                "fixed",
                "sticky"
              ]
            },
            "margin": {
              "type": "string",
              "default": "none",
              "label": "Margin",
              "description": "Margin on all sides",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "auto"
              ]
            },
            "marginY": {
              "type": "string",
              "default": "none",
              "label": "Margin Y",
              "description": "Vertical margin",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "auto"
              ]
            },
            "paddingY": {
              "type": "string",
              "default": "none",
              "label": "Padding Y",
              "description": "Vertical padding (overrides padding for y-axis)",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl"
              ]
            },
            "marginX": {
              "type": "string",
              "default": "none",
              "label": "Margin X",
              "description": "Horizontal margin",
              "tier": "presentation",
              "values": [
                "none",
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "auto"
              ]
            },
            "display": {
              "type": "string",
              "default": "block",
              "label": "Display",
              "description": "Display type",
              "tier": "presentation",
              "values": [
                "block",
                "inline",
                "inline-block",
                "flex",
                "inline-flex",
                "grid"
              ]
            },
            "fullWidth": {
              "type": "boolean",
              "default": false,
              "label": "Full Width",
              "description": "Fill available width",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BoxPage",
          "path": "/box",
          "traits": [
            {
              "ref": "BoxRender"
            }
          ]
        }
      ]
    }
  ]
}