{
  "description": "Vstack — UI factory (1:1 with the @almadar/ui vstack pattern).",
  "name": "ui-vstack",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "VstackItem",
        "persistence": "runtime"
      },
      "name": "VstackOrbital",
      "pages": [
        {
          "name": "VstackPage",
          "path": "/vstack",
          "traits": [
            {
              "ref": "VstackRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VstackItem",
          "name": "VstackRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "vstack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}