{
  "name": "ui-svg-grid",
  "version": "1.0.0",
  "description": "SvgGrid — UI factory (1:1 with the @almadar/ui svg-grid pattern).",
  "orbitals": [
    {
      "name": "SvgGridOrbital",
      "entity": {
        "name": "SvgGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SvgGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SvgGridItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "highlights": "@config.highlights",
                      "nodeRadius": "@config.nodeRadius",
                      "x": "@config.x",
                      "cols": "@config.cols",
                      "height": "@config.height",
                      "type": "svg-grid",
                      "opacity": "@config.opacity",
                      "y": "@config.y",
                      "color": "@config.color",
                      "spacing": "@config.spacing",
                      "className": "@config.className",
                      "asRoot": "@config.asRoot",
                      "width": "@config.width",
                      "rows": "@config.rows"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "x": {
              "type": "number",
              "default": 10.0,
              "label": "X",
              "description": "x prop",
              "tier": "presentation"
            },
            "highlights": {
              "type": "[number]",
              "default": [],
              "label": "Highlights",
              "description": "highlights prop",
              "tier": "presentation",
              "items": {
                "type": "number"
              }
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "color prop",
              "tier": "presentation"
            },
            "opacity": {
              "type": "number",
              "default": 1.0,
              "label": "Opacity",
              "description": "opacity prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "spacing": {
              "type": "number",
              "default": 20.0,
              "label": "Spacing",
              "description": "spacing prop",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 100.0,
              "label": "Width",
              "description": "width prop",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 100.0,
              "label": "Height",
              "description": "height prop",
              "tier": "presentation"
            },
            "nodeRadius": {
              "type": "number",
              "default": 3.0,
              "label": "Node Radius",
              "description": "nodeRadius prop",
              "tier": "presentation"
            },
            "y": {
              "type": "number",
              "default": 10.0,
              "label": "Y",
              "description": "y prop",
              "tier": "presentation"
            },
            "cols": {
              "type": "number",
              "default": 4.0,
              "label": "Cols",
              "description": "cols prop",
              "tier": "presentation"
            },
            "asRoot": {
              "type": "boolean",
              "default": true,
              "label": "As Root",
              "description": "When true (default), wraps in a standalone <svg> so the shape is visible without a parent SVG context.",
              "tier": "presentation"
            },
            "rows": {
              "type": "number",
              "default": 3.0,
              "label": "Rows",
              "description": "rows prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SvgGridPage",
          "path": "/svg-grid",
          "traits": [
            {
              "ref": "SvgGridRender"
            }
          ]
        }
      ]
    }
  ]
}