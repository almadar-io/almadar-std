              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading documents…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04HCH27VWW7REDY7M0CAF",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "icon": "file-text",
                              "label": "Total docs",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "edit-3",
                              "label": "Drafts",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "12"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Published",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "84"
                            },
                            {
                              "icon": "archive",
                              "label": "Archived",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "9"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": [
