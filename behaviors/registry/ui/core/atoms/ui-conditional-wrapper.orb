{
  "description": "ConditionalWrapper — UI factory (1:1 with the @almadar/ui conditional-wrapper pattern).",
  "name": "ui-conditional-wrapper",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ConditionalWrapperItem",
        "persistence": "runtime"
      },
      "name": "ConditionalWrapperOrbital",
      "pages": [
        {
          "name": "ConditionalWrapperPage",
          "path": "/conditional-wrapper",
          "traits": [
            {
              "ref": "ConditionalWrapperRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Whether to animate the transition (uses CSS transitions)",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "condition": {
              "description": "The S-expression condition to evaluate",
              "label": "Condition",
              "tier": "presentation",
              "type": "SExpr"
            },
            "context": {
              "default": {
                "formValues": {},
                "globalVariables": {}
              },
              "description": "Context for evaluating the condition",
              "label": "Context",
              "properties": {
                "entity": {
                  "name": "entity",
                  "required": false,
                  "type": "string"
                },
                "formValues": {
                  "name": "formValues",
                  "required": true,
                  "type": "string"
                },
                "globalVariables": {
                  "name": "globalVariables",
                  "required": true,
                  "type": "string"
                },
                "localVariables": {
                  "name": "localVariables",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ConditionalWrapperContext"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ConditionalWrapperItem",
          "name": "ConditionalWrapperRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animate": "@config.animate",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "condition": "@config.condition",
                      "context": "@config.context",
                      "fallback": [
                        {
                          "content": "Fallback",
                          "type": "typography"
                        }
                      ],
                      "type": "conditional-wrapper"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}