{
  "name": "ui-conditional-wrapper",
  "version": "1.0.0",
  "description": "ConditionalWrapper — UI factory (1:1 with the @almadar/ui conditional-wrapper pattern).",
  "orbitals": [
    {
      "name": "ConditionalWrapperOrbital",
      "entity": {
        "name": "ConditionalWrapperItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ConditionalWrapperRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ConditionalWrapperItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "condition": "@config.condition",
                      "context": "@config.context",
                      "animate": "@config.animate",
                      "type": "conditional-wrapper",
                      "children": [
                        {
                          "type": "text",
                          "content": "Sample content"
                        }
                      ],
                      "fallback": "@config.fallback"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "condition": {
              "type": "SExpr",
              "label": "Condition",
              "description": "The S-expression condition to evaluate",
              "tier": "presentation"
            },
            "animate": {
              "type": "boolean",
              "default": false,
              "label": "Animate",
              "description": "Whether to animate the transition (uses CSS transitions)",
              "tier": "presentation"
            },
            "fallback": {
              "type": "node",
              "label": "Fallback",
              "description": "Optional fallback to render when condition is false",
              "tier": "presentation"
            },
            "context": {
              "type": "ConditionalWrapperContext",
              "default": {
                "formValues": {},
                "globalVariables": {}
              },
              "label": "Context",
              "description": "Context for evaluating the condition",
              "tier": "presentation",
              "properties": {
                "formValues": {
                  "name": "formValues",
                  "type": "string",
                  "required": true
                },
                "globalVariables": {
                  "name": "globalVariables",
                  "type": "string",
                  "required": true
                },
                "entity": {
                  "name": "entity",
                  "type": "string",
                  "required": false
                },
                "localVariables": {
                  "name": "localVariables",
                  "type": "string",
                  "required": false
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ConditionalWrapperPage",
          "path": "/conditional-wrapper",
          "traits": [
            {
              "ref": "ConditionalWrapperRender"
            }
          ]
        }
      ]
    }
  ]
}
