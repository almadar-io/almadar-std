                            {
                              "icon": "hourglass",
                              "label": "Unbilled hours",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "248"
                            },
                            {
                              "icon": "file-text",
                              "label": "Invoiced this month",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "32"
                            },
                            {
                              "icon": "x-circle",
                              "label": "Written off",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "4"
                            }
