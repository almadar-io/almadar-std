          "ref": "Menu.traits.MenuRender",
          "refId": "trt_01KXG04Q03EYTCP5J0MX1ACQH7"
        },
        {
          "category": "interaction",
          "config": {
            "buttonLabel": {
              "default": "Export",
              "description": "Text shown on the toolbar button that opens the export popover",
              "label": "Button label",
              "synonyms": "the text on the export trigger button. user phrases: 'rename export button to X' / 'set the button label to X' / 'call the button X' / 'change export button text to X' -> X (e.g. 'Download CSV', 'Download', 'Export Data')",
              "tier": "presentation",
              "type": "string"
            },
            "event": {
              "default": "EXPORT_REQUESTED",
              "description": "Event emitted when the user picks a format. Each entry in formats[] carries its own literal event field (no per-item templating in .lolo) — overriding this alone does not retarget the click; also set formats[].event to match.",
              "label": "Export event",
              "synonyms": "bus event name. internal wiring; users rarely target directly",
              "tier": "internal",
              "type": "string"
            },
            "formats": {
              "default": [
                {
                  "event": "EXPORT_REQUESTED",
                  "format": "csv",
                  "id": "csv",
                  "label": "CSV"
                },
                {
                  "event": "EXPORT_REQUESTED",
                  "format": "xlsx",
                  "id": "xlsx",
                  "label": "XLSX"
                },
                {
                  "event": "EXPORT_REQUESTED",
                  "format": "pdf",
                  "id": "pdf",
                  "label": "PDF"
                }
              ],
              "description": "Export formats shown to the user in the popover",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "format": {
                    "name": "format",
                    "required": true,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Available formats",
              "synonyms": "list of export format entries (csv / xlsx / pdf / png / json). user phrases: 'only CSV' -> keep only csv entry; 'add JSON' -> append json entry; 'no PNG' -> remove png; 'allow X and Y' -> set the array to those two",
              "tier": "presentation",
              "type": "[FormatOption]"
            },
            "tileId": {
              "default": "",
              "description": "Identifier of the dashboard tile being exported",
              "label": "Tile id",
              "synonyms": "internal identifier — host orbital wires this; users rarely set it directly",
              "tier": "internal",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Requests export of data in the picked format. itemId is the format id (matches the FormatOption.id/format of the picked entry).",
              "event": "EXPORT_REQUESTED",
              "eventId": "evt_01KXG04G9QBV4RHH6MNX4315SC",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "export, save, download, generate",
              "tier": "domain"
            }
          ],
          "id": "trt_01KXG04G9Q062KHMRPMR44YBW0",
          "linkedEntity": "ExportPanel",
          "linkedEntityId": "ent_01KXG04G9QEP94NGAMEV0WVKF8",
          "name": "ExportMenu",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN_EXPORT",
                "name": "Open Export"
              },
              {
                "description": "Requests export of data in the picked format. itemId is the format id (matches the FormatOption.id/format of the picked entry).",
                "key": "EXPORT_REQUESTED",
                "name": "Export Requested",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "export, save, download, generate",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.Menu1"
                      ],
                      "type": "box"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "event": "OPEN_EXPORT",
                "from": "idle",
                "to": "idle"
              },
              {
                "event": "EXPORT_REQUESTED",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Button",
          "from": "std/behaviors/ui-button"
        },
        {
          "as": "Menu",
          "from": "std/behaviors/ui-menu"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "3.0.0"
