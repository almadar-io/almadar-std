{
  "name": "ui-divider",
  "version": "1.0.0",
  "description": "Divider — UI factory (1:1 with the @almadar/ui divider pattern).",
  "orbitals": [
    {
      "name": "DividerOrbital",
      "entity": {
        "name": "DividerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DividerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DividerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "orientation": "@config.orientation",
                      "variant": "@config.variant",
                      "className": "@config.className",
                      "label": "@config.label",
                      "type": "divider"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "variant": {
              "type": "string",
              "default": "solid",
              "label": "Variant",
              "description": "Line style variant",
              "tier": "presentation",
              "values": [
                "solid",
                "dashed",
                "dotted"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "Orientation of the divider",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Text label to display in the divider",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DividerPage",
          "path": "/divider",
          "traits": [
            {
              "ref": "DividerRender"
            }
          ]
        }
      ]
    }
  ]
}