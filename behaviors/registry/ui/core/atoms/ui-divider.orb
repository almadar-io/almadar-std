{
  "description": "Divider — UI factory (1:1 with the @almadar/ui divider pattern).",
  "name": "ui-divider",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DividerItem",
        "persistence": "runtime"
      },
      "name": "DividerOrbital",
      "pages": [
        {
          "name": "DividerPage",
          "path": "/divider",
          "traits": [
            {
              "ref": "DividerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Text label to display in the divider",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "orientation": {
              "default": "horizontal",
              "description": "Orientation of the divider",
              "label": "Orientation",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "variant": {
              "default": "solid",
              "description": "Line style variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "solid",
                "dashed",
                "dotted"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DividerItem",
          "name": "DividerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "label": "@config.label",
                      "orientation": "@config.orientation",
                      "type": "divider",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}