                  }
                ],
                "synonyms": "sort, rearrange, reposition",
                "tier": "presentation"
              },
              {
                "description": "Signals that board items have been successfully saved.",
                "id": "evt_01KXG04FS8ZFPK0V29TASPD99M",
                "key": "BoardItemsSaved",
                "name": "Board items saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ],
