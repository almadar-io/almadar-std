                "tier": "domain"
              },
              {
                "description": "Aborts an in-progress addition operation.",
                "id": "evt_01KXG04FS8NKD3C0P2F499WEC7",
                "key": "CANCEL_ADD",
                "name": "Cancel Add",
                "synonyms": "discard, undo, reset",
                "tier": "presentation"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "viewing_board"
              },
              {
                "name": "viewing_card"
              },
              {
                "name": "adding"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "failure": "BoardItemsLoadFailed",
                        "success": "BoardItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading board…",
                      "type": "loading-state"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04FS5QM08R185ACBMA51K",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.boards",
                    [
                      "array/map",
                      "@config.columns",
                      [
                        "fn",
                        "col",
                        {
                          "count": [
                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          "icon": [
                            "object/get",
                            "@col",
                            "icon",
                            "circle"
                          ],
                          "items": [
                            "array/sort",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "key": [
                            "object/get",
                            "@col",
                            "key"
                          ],
                          "label": [
                            "object/get",
                            "@col",
                            "label"
                          ],
                          "variant": [
                            "object/get",
                            "@col",
                            "variant",
                            "default"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "=",
                      "@config.boardLook",
                      "kanban-classic"
                    ],
                    [
                      "render-ui",
                      "main",
                      "@config.kanbanClassicBodyContent"
                    ],
                    [
                      "render-ui",
                      "main",
                      "@config.bodyContent"
                    ]
                  ]
                ],
                "event": "BoardItemsLoaded",
                "eventId": "evt_01KXG04FS8GKCFCG7CJ725GCTA",
                "from": "loading",
                "to": "viewing_board"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Failed to load board",
                      "type": "error-state"
                    }
                  ]
                ],
                "event": "BoardItemsLoadFailed",
                "eventId": "evt_01KXG04FS8Q57MN79QCV2TET49",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Save failed",
                      "type": "error-state"
                    }
                  ]
                ],
                "event": "BoardItemsSaveFailed",
                "eventId": "evt_01KXG04FS8QRXR73QKGT1GFY20",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    "@payload.row.stage"
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_CARD",
                              "icon": "arrow-left",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.currentTitle",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.currentStage",
                              "type": "badge",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Description",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.currentDescription",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "color": "muted",
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.currentNotes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "look": "@config.cardLook",
                          "type": "card"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "content": "Move to stage:",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "entity": "@entity.boards",
                          "fields": [],
                          "gap": "sm",
                          "renderItem": [
                            "fn",
                            "col",
                            {
                              "action": "MOVE_CARD",
                              "actionPayload": {
                                "id": "@entity.currentId",
                                "targetGroup": "@col.key"
                              },
                              "icon": "@col.icon",
                              "label": "@col.label",
                              "type": "button",
                              "variant": "secondary"
                            }
                          ],
                          "type": "data-list",
                          "variant": "default"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "action": "DELETE_CARD",
                              "actionPayload": {
                                "id": "@entity.currentId"
                              },
                              "icon": "trash-2",
                              "label": "Delete",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "OPEN_CARD",
                "eventId": "evt_01KXG04FS86V7K920MWMRJMXQM",
                "from": "viewing_board",
                "to": "viewing_card"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "action": "CANCEL_ADD",
                              "icon": "x",
                              "label": "Cancel",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "plus",
                              "type": "icon"
                            },
                            {
                              "content": "New board item",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CANCEL_ADD",
                          "entity": "@entity",
                          "fields": "@config.formFields",
                          "mode": "create",
                          "submitEvent": "SAVE_CARD",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "ADD_CARD",
                "eventId": "evt_01KXG04FS8V2PBJ4NPXMAF4XKP",
                "from": "viewing_board",
                "to": "adding"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "stage": "@payload.targetGroup"
                    },
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ]
                ],
                "event": "MOVE_CARD",
                "eventId": "evt_01KXG04FS8X8X62AWNJ90NAYWB",
                "from": "viewing_board",
                "to": "viewing_board"
              },
              {
                "event": "REORDER_CARD",
                "eventId": "evt_01KXG04FS84BV8ABH2PWVQSGGW",
                "from": "viewing_board",
                "to": "viewing_board"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "position": "@payload.position"
                    },
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ]
                ],
                "event": "REORDER_POSITION",
                "eventId": "evt_01KXG04FS8WZZTPP94WR7Z3F9N",
                "from": "viewing_board",
                "to": "viewing_board"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "failure": "BoardItemsLoadFailed",
                        "success": "BoardItemsLoaded"
