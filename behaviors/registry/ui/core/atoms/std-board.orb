                "tier": "presentation"
              },
              {
                "description": "Indicates a change in the order of items within a column.",
                "id": "evt_01KXG04FS8WZZTPP94WR7Z3F9N",
                "key": "REORDER_POSITION",
                "name": "Reorder Position",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "position",
                    "required": true,
