                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
