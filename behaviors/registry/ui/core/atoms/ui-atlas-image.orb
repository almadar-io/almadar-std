{
  "description": "AtlasImage — UI factory (1:1 with the @almadar/ui atlas-image pattern).",
  "name": "ui-atlas-image",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AtlasImageItem",
        "persistence": "runtime"
      },
      "name": "AtlasImageOrbital",
      "pages": [
        {
          "name": "AtlasImagePage",
          "path": "/atlas-image",
          "traits": [
            {
              "ref": "AtlasImageRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "alt": {
              "default": "Alt",
              "description": "alt prop",
              "label": "Alt",
              "tier": "presentation",
              "type": "string"
            },
            "asset": {
              "default": {
                "category": "Category",
                "name": "Name"
              },
              "description": "asset prop",
              "label": "Asset",
              "properties": {
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "AtlasImageAsset"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "fill": {
              "default": false,
              "description": "Absolutely fill the nearest positioned ancestor (background usage).",
              "label": "Fill",
              "tier": "presentation",
              "type": "boolean"
            },
            "fit": {
              "default": "contain",
              "description": "fit prop",
              "label": "Fit",
              "tier": "presentation",
              "type": "string",
              "values": [
                "contain",
                "cover",
                "fill"
              ]
            },
            "height": {
              "default": 0.0,
              "description": "height prop",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": 0.0,
              "description": "Square pixel size (icon usage). Ignored when `fill`.",
              "label": "Size",
              "tier": "presentation",
              "type": "number"
            },
            "style": {
              "default": {},
              "description": "style prop",
              "label": "Style",
              "tier": "presentation",
              "type": "json"
            },
            "width": {
              "default": 0.0,
              "description": "width prop",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AtlasImageItem",
          "name": "AtlasImageRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "alt": "@config.alt",
                      "asset": "@config.asset",
                      "className": "@config.className",
                      "fill": "@config.fill",
                      "fit": "@config.fit",
                      "height": "@config.height",
                      "size": "@config.size",
                      "style": "@config.style",
                      "type": "atlas-image",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}