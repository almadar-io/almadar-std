{
  "description": "SvgRing — UI factory (1:1 with the @almadar/ui svg-ring pattern).",
  "name": "ui-svg-ring",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SvgRingItem",
        "persistence": "runtime"
      },
      "name": "SvgRingOrbital",
      "pages": [
        {
          "name": "SvgRingPage",
          "path": "/svg-ring",
          "traits": [
            {
              "ref": "SvgRingRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "asRoot": {
              "default": true,
              "description": "When true (default), wraps in a standalone <svg> so the shape is visible without a parent SVG context.",
              "label": "As Root",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "color": {
              "default": "var(--color-primary)",
              "description": "color prop",
              "label": "Color",
              "tier": "presentation",
              "type": "string"
            },
            "cx": {
              "default": 50.0,
              "description": "cx prop",
              "label": "Cx",
              "tier": "presentation",
              "type": "number"
            },
            "cy": {
              "default": 50.0,
              "description": "cy prop",
              "label": "Cy",
              "tier": "presentation",
              "type": "number"
            },
            "height": {
              "default": 100.0,
              "description": "height prop",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "label": {
              "default": "Label",
              "description": "label prop",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "opacity": {
              "default": 1.0,
              "description": "opacity prop",
              "label": "Opacity",
              "tier": "presentation",
              "type": "number"
            },
            "r": {
              "default": 40.0,
              "description": "r prop",
              "label": "R",
              "tier": "presentation",
              "type": "number"
            },
            "strokeWidth": {
              "default": 1.5,
              "description": "strokeWidth prop",
              "label": "Stroke Width",
              "tier": "presentation",
              "type": "number"
            },
            "variant": {
              "default": "solid",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "solid",
                "dashed",
                "glow"
              ]
            },
            "width": {
              "default": 100.0,
              "description": "width prop",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SvgRingItem",
          "name": "SvgRingRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "asRoot": "@config.asRoot",
                      "className": "@config.className",
                      "color": "@config.color",
                      "cx": "@config.cx",
                      "cy": "@config.cy",
                      "height": "@config.height",
                      "label": "@config.label",
                      "opacity": "@config.opacity",
                      "r": "@config.r",
                      "strokeWidth": "@config.strokeWidth",
                      "type": "svg-ring",
                      "variant": "@config.variant",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}