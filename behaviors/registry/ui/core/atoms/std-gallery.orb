        },
        {
          "category": "interaction",
          "config": {
            "imageField": {
              "default": "imageUrl",
              "description": "Entity field holding the image URL shown in the lightbox for the selected item",
              "label": "Image field",
              "synonyms": "image url field, thumbnail field, src field",
              "tier": "presentation",
              "type": "string"
            },
            "nameField": {
              "default": "name",
              "description": "Entity field providing the lightbox alt text and caption for the selected item",
              "label": "Name field",
              "synonyms": "title field, label field",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Gallery",
              "description": "Heading shown above the image gallery",
              "label": "Section title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Signals an item has been selected for viewing.",
              "event": "VIEW",
              "eventId": "evt_01KXG04GJ9J0Q9FCBGZV9ZV50B",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "row",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "createdAt",
                      "type": "string"
                    },
                    {
                      "name": "imageUrl",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "synonyms": "select, choose, display",
              "tier": "domain"
            },
            {
              "description": "Indicates a GalleryItem has finished loading.",
              "event": "GalleryItemLoaded",
              "eventId": "evt_01KXG04GJ96GWXWMB99T91CGKE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GalleryItem]"
                }
              ],
              "synonyms": "loaded, ready, available",
              "tier": "internal"
            },
            {
              "description": "Indicates a GalleryItem failed to load.",
              "event": "GalleryItemLoadFailed",
              "eventId": "evt_01KXG04GJ9RSHKRPV86G1T79DS",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "synonyms": "error, failure, problem, load error",
              "tier": "internal"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "GalleryItem": "ent_01KXG04GJ9CSPRAKTW27XMN7DV"
          },
          "id": "trt_01KXG04GJ9PVVVHGVAHEP7YVDE",
          "linkedEntity": "GalleryItem",
          "linkedEntityId": "ent_01KXG04GJ9CSPRAKTW27XMN7DV",
          "name": "GalleryItemGallery",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04GJ9Z66Y7BREMV82AANS",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates a GalleryItem has finished loading.",
                "id": "evt_01KXG04GJ96GWXWMB99T91CGKE",
                "key": "GalleryItemLoaded",
                "name": "GalleryItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GalleryItem]"
                  }
                ],
                "synonyms": "loaded, ready, available",
                "tier": "internal"
              },
              {
                "description": "Indicates a GalleryItem failed to load.",
                "id": "evt_01KXG04GJ9RSHKRPV86G1T79DS",
                "key": "GalleryItemLoadFailed",
                "name": "GalleryItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, problem, load error",
                "tier": "internal"
              },
              {
                "description": "Signals an item has been selected for viewing.",
                "id": "evt_01KXG04GJ9J0Q9FCBGZV9ZV50B",
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "GalleryItem"
                  }
                ],
                "synonyms": "select, choose, display",
                "tier": "domain"
              },
              {
                "description": "Indicates the gallery or lightbox has been dismissed.",
                "id": "evt_01KXG04GJ9VFJRXQP9QNN2TA1E",
                "key": "CLOSE",
                "name": "Close",
                "synonyms": "dismiss, hide, close, cancel",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        "@trait.LoadingSpinner",
                        "@trait.LoadingCaption"
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04GJ9Z66Y7BREMV82AANS",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            "@trait.GalleryIcon",
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        "@trait.TitleDivider",
                        "@trait.MediaGalleryGrid"
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "GalleryItemLoaded",
                "eventId": "evt_01KXG04GJ96GWXWMB99T91CGKE",
                "from": "loading",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ErrorAlert"
                      ],
                      "type": "box"
                    }
                  ]
                ],
                "event": "GalleryItemLoadFailed",
                "eventId": "evt_01KXG04GJ9RSHKRPV86G1T79DS",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "closeAction": "CLOSE",
                          "currentIndex": 0.0,
                          "images": [
                            {
                              "alt": [
                                "object/get",
                                "@payload.row",
                                "@config.nameField"
                              ],
                              "caption": [
                                "object/get",
                                "@payload.row",
                                "@config.nameField"
                              ],
                              "src": [
                                "object/get",
                                "@payload.row",
                                "@config.imageField"
                              ]
                            }
                          ],
                          "isOpen": true,
                          "showCounter": true,
                          "type": "lightbox"
                        }
                      ],
                      "type": "box"
                    }
                  ]
                ],
                "event": "VIEW",
                "eventId": "evt_01KXG04GJ9J0Q9FCBGZV9ZV50B",
                "from": "browsing",
                "to": "viewing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        "@trait.ReloadSpinner",
                        "@trait.ReloadCaption"
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CLOSE",
                "eventId": "evt_01KXG04GJ9VFJRXQP9QNN2TA1E",
                "from": "viewing",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        "@trait.RetrySpinner"
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04GJ9Z66Y7BREMV82AANS",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Spinner",
          "from": "std/behaviors/ui-spinner"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Divider",
          "from": "std/behaviors/ui-divider"
        },
        {
          "as": "MediaGallery",
          "from": "std/behaviors/ui-media-gallery"
        },
        {
          "as": "Alert",
          "from": "std/behaviors/ui-alert"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}