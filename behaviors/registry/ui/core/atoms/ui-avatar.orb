{
  "description": "Avatar — UI factory (1:1 with the @almadar/ui avatar pattern).",
  "name": "ui-avatar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AvatarItem",
        "persistence": "runtime"
      },
      "name": "AvatarOrbital",
      "pages": [
        {
          "name": "AvatarPage",
          "path": "/avatar",
          "traits": [
            {
              "ref": "AvatarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actionPayload": {
              "default": {},
              "description": "Payload to include with the action event",
              "label": "Action Payload",
              "tier": "presentation",
              "type": "json"
            },
            "alt": {
              "default": "Alt",
              "description": "Alt text for the image",
              "label": "Alt",
              "tier": "presentation",
              "type": "string"
            },
            "badge": {
              "default": "Badge",
              "description": "Badge content (e.g., notification count)",
              "label": "Badge",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Icon to display when no image or initials. Accepts a Lucide component directly, or a canonical kebab-case icon name string (resolved via `resolveIcon`) so trait/factory authors can pass an icon by name.",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "initials": {
              "default": "Initials",
              "description": "Initials to display (e.g., 'JD' for John Doe) If not provided but name is, initials will be auto-generated",
              "label": "Initials",
              "tier": "presentation",
              "type": "string"
            },
            "name": {
              "default": "Name",
              "description": "Full name - initials will be generated automatically",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size of the avatar",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "src": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/portraits/guide.png",
              "description": "Image source URL",
              "label": "Src",
              "tier": "presentation",
              "type": "asset"
            },
            "status": {
              "default": "online",
              "description": "Status indicator",
              "label": "Status",
              "tier": "presentation",
              "type": "string",
              "values": [
                "online",
                "offline",
                "away",
                "busy"
              ]
            }
          },
          "emits": [
            {
              "description": "Click handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AvatarItem",
          "name": "AvatarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "actionPayload": "@config.actionPayload",
                      "alt": "@config.alt",
                      "badge": "@config.badge",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "initials": "@config.initials",
                      "name": "@config.name",
                      "onClick": "CLICK",
                      "size": "@config.size",
                      "src": "@config.src",
                      "status": "@config.status",
                      "type": "avatar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}