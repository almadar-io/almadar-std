{
  "description": "TextHighlight — UI factory (1:1 with the @almadar/ui text-highlight pattern).",
  "name": "ui-text-highlight",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TextHighlightItem",
        "persistence": "runtime"
      },
      "name": "TextHighlightOrbital",
      "pages": [
        {
          "name": "TextHighlightPage",
          "path": "/text-highlight",
          "traits": [
            {
              "ref": "TextHighlightRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "action": {
              "default": "ACTION",
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "label": "Action",
              "tier": "presentation",
              "type": "string"
            },
            "annotationId": {
              "default": "Annotation Id",
              "description": "Unique ID for the annotation",
              "label": "Annotation Id",
              "tier": "presentation",
              "type": "string"
            },
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Highlighted text content",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "highlightType": {
              "default": "question",
              "description": "Type of highlight (determines color)",
              "label": "Highlight Type",
              "tier": "presentation",
              "type": "string",
              "values": [
                "question",
                "note"
              ]
            },
            "hoverEvent": {
              "default": "HOVER",
              "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
              "label": "Hover Event",
              "tier": "presentation",
              "type": "string"
            },
            "isActive": {
              "default": false,
              "description": "Whether the highlight is currently active/focused",
              "label": "Is Active",
              "tier": "presentation",
              "type": "boolean"
            },
            "onClick": {
              "default": "CLICK",
              "description": "Callback when highlight is clicked",
              "label": "On Click",
              "tier": "presentation",
              "type": "string"
            },
            "onMouseEnter": {
              "default": "MOUSE_ENTER",
              "description": "Callback when highlight is hovered",
              "label": "On Mouse Enter",
              "tier": "presentation",
              "type": "string"
            },
            "onMouseLeave": {
              "default": "MOUSE_LEAVE",
              "description": "Callback when hover ends",
              "label": "On Mouse Leave",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Callback when highlight is clicked",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when highlight is hovered",
              "event": "MOUSE_ENTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Callback when hover ends",
              "event": "MOUSE_LEAVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
              "event": "HOVER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TextHighlightItem",
          "name": "TextHighlightRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when highlight is clicked",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when highlight is hovered",
                "key": "MOUSE_ENTER",
                "name": "Mouse Enter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Callback when hover ends",
                "key": "MOUSE_LEAVE",
                "name": "Mouse Leave",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
                "key": "HOVER",
                "name": "Hover",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "@config.action",
                      "annotationId": "@config.annotationId",
                      "children": "@config.children",
                      "className": "@config.className",
                      "highlightType": "@config.highlightType",
                      "hoverEvent": "@config.hoverEvent",
                      "isActive": "@config.isActive",
                      "onClick": "@config.onClick",
                      "onMouseEnter": "@config.onMouseEnter",
                      "onMouseLeave": "@config.onMouseLeave",
                      "type": "text-highlight"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}