{
  "description": "TextHighlight — UI factory (1:1 with the @almadar/ui text-highlight pattern).",
  "name": "ui-text-highlight",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TextHighlightItem",
        "persistence": "runtime"
      },
      "name": "TextHighlightOrbital",
      "pages": [
        {
          "name": "TextHighlightPage",
          "path": "/text-highlight",
          "traits": [
            {
              "ref": "TextHighlightRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "annotationId": {
              "default": "Annotation Id",
              "description": "Unique ID for the annotation",
              "label": "Annotation Id",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "highlightType": {
              "default": "question",
              "description": "Type of highlight (determines color)",
              "label": "Highlight Type",
              "tier": "presentation",
              "type": "string",
              "values": [
                "question",
                "note"
              ]
            },
            "isActive": {
              "default": false,
              "description": "Whether the highlight is currently active/focused",
              "label": "Is Active",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Callback when highlight is clicked",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Callback when highlight is hovered",
              "event": "MOUSE_ENTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Callback when hover ends",
              "event": "MOUSE_LEAVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
              "event": "HOVER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TextHighlightItem",
          "name": "TextHighlightRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when highlight is clicked",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Callback when highlight is hovered",
                "key": "MOUSE_ENTER",
                "name": "Mouse Enter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Callback when hover ends",
                "key": "MOUSE_LEAVE",
                "name": "Mouse Leave",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
                "key": "HOVER",
                "name": "Hover",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "annotationId": "@config.annotationId",
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "typography"
                        }
                      ],
                      "className": "@config.className",
                      "highlightType": "@config.highlightType",
                      "hoverEvent": "HOVER",
                      "isActive": "@config.isActive",
                      "onClick": "CLICK",
                      "onMouseEnter": "MOUSE_ENTER",
                      "onMouseLeave": "MOUSE_LEAVE",
                      "type": "text-highlight"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}