{
  "description": "TrendIndicator — UI factory (1:1 with the @almadar/ui trend-indicator pattern).",
  "name": "ui-trend-indicator",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TrendIndicatorItem",
        "persistence": "runtime"
      },
      "name": "TrendIndicatorOrbital",
      "pages": [
        {
          "name": "TrendIndicatorPage",
          "path": "/trend-indicator",
          "traits": [
            {
              "ref": "TrendIndicatorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "direction": {
              "default": "up",
              "description": "Override automatic direction detection (positive=up, negative=down, zero=flat)",
              "label": "Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "up",
                "down",
                "flat"
              ]
            },
            "invert": {
              "default": false,
              "description": "Invert color logic (for metrics where down is good, e.g., error rate, bounce rate)",
              "label": "Invert",
              "tier": "presentation",
              "type": "boolean"
            },
            "label": {
              "default": "Label",
              "description": "Accessible label override",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "showValue": {
              "default": true,
              "description": "Show the formatted value text next to the arrow",
              "label": "Show Value",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size of the indicator",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "value": {
              "default": 0.0,
              "description": "Numeric value to display (e.g., 12.5 for +12.5%)",
              "label": "Value",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TrendIndicatorItem",
          "name": "TrendIndicatorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "direction": "@config.direction",
                      "invert": "@config.invert",
                      "label": "@config.label",
                      "showValue": "@config.showValue",
                      "size": "@config.size",
                      "type": "trend-indicator",
                      "value": "@config.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}