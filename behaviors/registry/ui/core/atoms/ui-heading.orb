{
  "name": "ui-heading",
  "version": "1.0.0",
  "description": "Heading — UI factory (1:1 with the @almadar/ui heading pattern).",
  "orbitals": [
    {
      "name": "HeadingOrbital",
      "entity": {
        "name": "HeadingItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "HeadingRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "HeadingItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "content": "@config.content",
                      "as": "@config.asProp",
                      "className": "@config.className",
                      "level": "@config.level",
                      "color": "@config.color",
                      "truncate": "@config.truncate",
                      "style": "@config.style",
                      "size": "@config.size",
                      "align": "@config.align",
                      "overflow": "@config.overflow",
                      "children": "@config.children",
                      "type": "heading",
                      "weight": "@config.weight",
                      "variant": "@config.variant"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            },
            "content": {
              "type": "node",
              "label": "Content",
              "description": "Text content (alternative to children)",
              "tier": "presentation"
            },
            "level": {
              "type": "number",
              "default": 2.0,
              "label": "Level",
              "description": "Heading level (1-6) - alternative to variant for headings",
              "tier": "presentation"
            },
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Children elements",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "primary",
              "label": "Color",
              "description": "Text color",
              "tier": "presentation",
              "values": [
                "primary",
                "secondary",
                "muted",
                "error",
                "success",
                "warning",
                "inherit"
              ]
            },
            "overflow": {
              "type": "string",
              "default": "visible",
              "label": "Overflow",
              "description": "Overflow handling mode",
              "tier": "presentation",
              "values": [
                "visible",
                "hidden",
                "wrap",
                "clamp-2",
                "clamp-3"
              ]
            },
            "style": {
              "type": "json",
              "label": "Style",
              "description": "Inline style",
              "tier": "presentation"
            },
            "weight": {
              "type": "string",
              "default": "light",
              "label": "Weight",
              "description": "Font weight override",
              "tier": "presentation",
              "values": [
                "light",
                "normal",
                "medium",
                "semibold",
                "bold"
              ]
            },
            "size": {
              "type": "string",
              "default": "xs",
              "label": "Size",
              "description": "Font size override",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "3xl"
              ]
            },
            "truncate": {
              "type": "boolean",
              "default": false,
              "label": "Truncate",
              "description": "Truncate with ellipsis (single line)",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "body",
              "label": "Variant",
              "description": "Typography variant",
              "tier": "presentation",
              "values": [
                "h1",
                "h2",
                "h3",
                "h4",
                "h5",
                "h6",
                "heading",
                "subheading",
                "body1",
                "body2",
                "body",
                "caption",
                "overline",
                "small",
                "large",
                "label"
              ]
            },
            "align": {
              "type": "string",
              "default": "left",
              "label": "Align",
              "description": "Text alignment",
              "tier": "presentation",
              "values": [
                "left",
                "center",
                "right"
              ]
            },
            "asProp": {
              "type": "string",
              "default": "",
              "label": "As",
              "description": "Custom HTML element",
              "synonyms": "as",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "HeadingPage",
          "path": "/heading",
          "traits": [
            {
              "ref": "HeadingRender"
            }
          ]
        }
      ]
    }
  ]
}