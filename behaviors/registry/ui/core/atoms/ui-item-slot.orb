{
  "name": "ui-item-slot",
  "version": "1.0.0",
  "description": "ItemSlot — UI factory (1:1 with the @almadar/ui item-slot pattern).",
  "orbitals": [
    {
      "name": "ItemSlotOrbital",
      "entity": {
        "name": "ItemSlotItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ItemSlotRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ItemSlotItem",
          "emits": [
            {
              "event": "CLICK",
              "description": "Click handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Click handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "empty": "@config.empty",
                      "selected": "@config.selected",
                      "quantity": "@config.quantity",
                      "label": "@config.label",
                      "onClick": "CLICK",
                      "type": "item-slot",
                      "icon": "@config.icon",
                      "rarity": "@config.rarity",
                      "size": "@config.size",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "empty": {
              "type": "boolean",
              "default": false,
              "label": "Empty",
              "description": "Whether the slot is empty",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "rarity": {
              "type": "string",
              "default": "common",
              "label": "Rarity",
              "description": "Rarity tier affecting border color",
              "tier": "presentation",
              "values": [
                "common",
                "uncommon",
                "rare",
                "epic",
                "legendary"
              ]
            },
            "icon": {
              "type": "node",
              "label": "Icon",
              "description": "Icon component or emoji",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "selected": {
              "type": "boolean",
              "default": false,
              "label": "Selected",
              "description": "Whether the slot is selected",
              "tier": "presentation"
            },
            "quantity": {
              "type": "number",
              "default": 0.0,
              "label": "Quantity",
              "description": "Stack quantity",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "Item label",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ItemSlotPage",
          "path": "/item-slot",
          "traits": [
            {
              "ref": "ItemSlotRender"
            }
          ]
        }
      ]
    }
  ]
}
