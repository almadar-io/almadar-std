{
  "name": "ui-theme-toggle",
  "version": "1.0.0",
  "description": "ThemeToggle — UI factory (1:1 with the @almadar/ui theme-toggle pattern).",
  "orbitals": [
    {
      "name": "ThemeToggleOrbital",
      "entity": {
        "name": "ThemeToggleItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ThemeToggleRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ThemeToggleItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "showLabel": "@config.showLabel",
                      "type": "theme-toggle",
                      "size": "@config.size"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "showLabel": {
              "type": "boolean",
              "default": false,
              "label": "Show Label",
              "description": "Show label text",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ThemeTogglePage",
          "path": "/theme-toggle",
          "traits": [
            {
              "ref": "ThemeToggleRender"
            }
          ]
        }
      ]
    }
  ]
}
