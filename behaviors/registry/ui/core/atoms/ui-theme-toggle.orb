{
  "description": "ThemeToggle — UI factory (1:1 with the @almadar/ui theme-toggle pattern).",
  "name": "ui-theme-toggle",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ThemeToggleItem",
        "persistence": "runtime"
      },
      "name": "ThemeToggleOrbital",
      "pages": [
        {
          "name": "ThemeTogglePage",
          "path": "/theme-toggle",
          "traits": [
            {
              "ref": "ThemeToggleRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "showLabel": {
              "default": false,
              "description": "Show label text",
              "label": "Show Label",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ThemeToggleItem",
          "name": "ThemeToggleRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "showLabel": "@config.showLabel",
                      "size": "@config.size",
                      "type": "theme-toggle"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}