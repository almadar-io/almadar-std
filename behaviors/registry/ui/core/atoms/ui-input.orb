{
  "name": "ui-input",
  "version": "1.0.0",
  "description": "Input — UI factory (1:1 with the @almadar/ui input pattern).",
  "orbitals": [
    {
      "name": "InputOrbital",
      "entity": {
        "name": "InputItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "InputRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "InputItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name for trait dispatch",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLEAR",
              "description": "Callback or declarative event key when clear button is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CHANGE",
              "description": "onChange handler or declarative event key for trait dispatch",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for trait dispatch",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear",
                "description": "Callback or declarative event key when clear button is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "onChange handler or declarative event key for trait dispatch",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "rows": "@config.rows",
                      "type": "input",
                      "disabled": "@config.disabled",
                      "placeholder": "@config.placeholder",
                      "error": "@config.error",
                      "icon": "@config.icon",
                      "onClear": "CLEAR",
                      "clearable": "@config.clearable",
                      "options": "@config.options",
                      "leftIcon": "@config.leftIcon",
                      "inputType": "@config.inputType",
                      "value": "@config.value",
                      "className": "@config.className",
                      "action": "ACTION",
                      "rightIcon": "@config.rightIcon",
                      "onChange": "CHANGE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "clearable": {
              "type": "boolean",
              "default": false,
              "label": "Clearable",
              "description": "Show clear button when input has value",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "error": {
              "type": "string",
              "default": "",
              "label": "Error",
              "description": "error prop",
              "tier": "presentation"
            },
            "leftIcon": {
              "type": "icon",
              "label": "Left Icon",
              "description": "leftIcon prop",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Whether input is disabled",
              "tier": "presentation"
            },
            "inputType": {
              "type": "string",
              "default": "text",
              "label": "Input Type",
              "description": "Input type - supports 'select' and 'textarea' in addition to standard types",
              "tier": "presentation",
              "values": [
                "text",
                "email",
                "password",
                "number",
                "tel",
                "url",
                "search",
                "date",
                "datetime-local",
                "time",
                "checkbox",
                "select",
                "textarea"
              ]
            },
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Current value",
              "tier": "presentation"
            },
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Lucide icon component or canonical kebab-case icon name string for left side",
              "tier": "presentation"
            },
            "rows": {
              "type": "number",
              "default": 3.0,
              "label": "Rows",
              "description": "Rows for textarea type",
              "tier": "presentation"
            },
            "options": {
              "type": "[InputOptionsItem]",
              "default": [
                {
                  "value": "Value",
                  "label": "Label"
                }
              ],
              "label": "Options",
              "description": "Options for select type",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "placeholder": {
              "type": "string",
              "default": "Placeholder",
              "label": "Placeholder",
              "description": "Placeholder text",
              "tier": "presentation"
            },
            "rightIcon": {
              "type": "icon",
              "label": "Right Icon",
              "description": "rightIcon prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InputPage",
          "path": "/input",
          "traits": [
            {
              "ref": "InputRender"
            }
          ]
        }
      ]
    }
  ]
}