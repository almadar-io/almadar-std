{
  "description": "TypewriterText — UI factory (1:1 with the @almadar/ui typewriter-text pattern).",
  "name": "ui-typewriter-text",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TypewriterTextItem",
        "persistence": "runtime"
      },
      "name": "TypewriterTextOrbital",
      "pages": [
        {
          "name": "TypewriterTextPage",
          "path": "/typewriter-text",
          "traits": [
            {
              "ref": "TypewriterTextRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "onComplete": {
              "default": "COMPLETE",
              "description": "Called when the entire text has been revealed",
              "label": "On Complete",
              "tier": "presentation",
              "type": "string"
            },
            "speed": {
              "default": 40.0,
              "description": "Milliseconds per character",
              "label": "Speed",
              "tier": "presentation",
              "type": "number"
            },
            "startDelay": {
              "default": 0.0,
              "description": "Delay before typing starts (ms)",
              "label": "Start Delay",
              "tier": "presentation",
              "type": "number"
            },
            "text": {
              "default": "Text",
              "description": "The full text to reveal",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Called when the entire text has been revealed",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TypewriterTextItem",
          "name": "TypewriterTextRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when the entire text has been revealed",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "onComplete": "@config.onComplete",
                      "speed": "@config.speed",
                      "startDelay": "@config.startDelay",
                      "text": "@config.text",
                      "type": "typewriter-text"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}