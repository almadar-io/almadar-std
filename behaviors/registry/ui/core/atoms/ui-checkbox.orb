{
  "name": "ui-checkbox",
  "version": "1.0.0",
  "description": "Checkbox — UI factory (1:1 with the @almadar/ui checkbox pattern).",
  "orbitals": [
    {
      "name": "CheckboxOrbital",
      "entity": {
        "name": "CheckboxItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CheckboxRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CheckboxItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "onChange handler or declarative event key for trait dispatch",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "onChange handler or declarative event key for trait dispatch",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "checked": "@config.checked",
                      "defaultChecked": "@config.defaultChecked",
                      "className": "@config.className",
                      "label": "@config.label",
                      "onChange": "CHANGE",
                      "type": "checkbox"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "label prop",
              "tier": "presentation"
            },
            "checked": {
              "type": "boolean",
              "default": false,
              "label": "Checked",
              "description": "Whether the checkbox is checked",
              "tier": "presentation"
            },
            "defaultChecked": {
              "type": "boolean",
              "default": false,
              "label": "Default Checked",
              "description": "Default checked state (uncontrolled)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CheckboxPage",
          "path": "/checkbox",
          "traits": [
            {
              "ref": "CheckboxRender"
            }
          ]
        }
      ]
    }
  ]
}