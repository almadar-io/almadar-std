{
  "description": "Checkbox — UI factory (1:1 with the @almadar/ui checkbox pattern).",
  "name": "ui-checkbox",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CheckboxItem",
        "persistence": "runtime"
      },
      "name": "CheckboxOrbital",
      "pages": [
        {
          "name": "CheckboxPage",
          "path": "/checkbox",
          "traits": [
            {
              "ref": "CheckboxRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "checked": {
              "default": false,
              "description": "Whether the checkbox is checked",
              "label": "Checked",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "defaultChecked": {
              "default": false,
              "description": "Default checked state (uncontrolled)",
              "label": "Default Checked",
              "tier": "presentation",
              "type": "boolean"
            },
            "label": {
              "default": "Label",
              "description": "label prop",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "onChange handler or declarative event key for trait dispatch",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CheckboxItem",
          "name": "CheckboxRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onChange handler or declarative event key for trait dispatch",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "checked": "@config.checked",
                      "className": "@config.className",
                      "defaultChecked": "@config.defaultChecked",
                      "label": "@config.label",
                      "onChange": "CHANGE",
                      "type": "checkbox"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}