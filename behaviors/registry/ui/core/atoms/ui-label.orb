{
  "description": "Label — UI factory (1:1 with the @almadar/ui label pattern).",
  "name": "ui-label",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LabelItem",
        "persistence": "runtime"
      },
      "name": "LabelOrbital",
      "pages": [
        {
          "name": "LabelPage",
          "path": "/label",
          "traits": [
            {
              "ref": "LabelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "htmlFor": {
              "default": "Html For",
              "description": "Associated input element ID",
              "label": "Html For",
              "tier": "presentation",
              "type": "string"
            },
            "required": {
              "default": false,
              "description": "Show required indicator",
              "label": "Required",
              "tier": "presentation",
              "type": "boolean"
            },
            "text": {
              "default": "Text",
              "description": "Label text content",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LabelItem",
          "name": "LabelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "htmlFor": "@config.htmlFor",
                      "required": "@config.required",
                      "text": "@config.text",
                      "type": "label"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}