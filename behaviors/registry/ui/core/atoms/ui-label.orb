{
  "name": "ui-label",
  "version": "1.0.0",
  "description": "Label — UI factory (1:1 with the @almadar/ui label pattern).",
  "orbitals": [
    {
      "name": "LabelOrbital",
      "entity": {
        "name": "LabelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "LabelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "LabelItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "required": "@config.required",
                      "text": "@config.text",
                      "htmlFor": "@config.htmlFor",
                      "type": "label",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "text": {
              "type": "string",
              "default": "",
              "label": "Text",
              "description": "Label text content",
              "tier": "presentation"
            },
            "required": {
              "type": "boolean",
              "default": false,
              "label": "Required",
              "description": "Show required indicator",
              "tier": "presentation"
            },
            "htmlFor": {
              "type": "string",
              "default": "",
              "label": "Html For",
              "description": "Associated input element ID",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LabelPage",
          "path": "/label",
          "traits": [
            {
              "ref": "LabelRender"
            }
          ]
        }
      ]
    }
  ]
}