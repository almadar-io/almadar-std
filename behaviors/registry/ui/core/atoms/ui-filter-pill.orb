{
  "description": "FilterPill — UI factory (1:1 with the @almadar/ui filter-pill pattern).",
  "name": "ui-filter-pill",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Label",
            "name": "label",
            "type": "string"
          }
        ],
        "name": "FilterPillItem",
        "persistence": "runtime"
      },
      "name": "FilterPillOrbital",
      "pages": [
        {
          "name": "FilterPillPage",
          "path": "/filter-pill",
          "traits": [
            {
              "ref": "FilterPillRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "clickEvent": {
              "default": "CLICK",
              "description": "Event name dispatched via event bus when the pill body is clicked. Payload: { label }",
              "label": "Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Lucide icon component or canonical kebab-case icon name string",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Pill label text (alternative to children for schema-driven rendering).",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "onClick": {
              "default": "CLICK",
              "description": "Click handler for the body of the pill (filter toggle)",
              "label": "On Click",
              "tier": "presentation",
              "type": "string"
            },
            "onRemove": {
              "default": "REMOVE",
              "description": "Called when the user clicks the remove (×) button",
              "label": "On Remove",
              "tier": "presentation",
              "type": "string"
            },
            "removable": {
              "default": true,
              "description": "Disable the remove button (renders without × control)",
              "label": "Removable",
              "tier": "presentation",
              "type": "boolean"
            },
            "removeEvent": {
              "default": "REMOVE",
              "description": "Event name dispatched via event bus when the remove (×) button is clicked. Payload: { label }",
              "label": "Remove Event",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "sm",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "variant": {
              "default": "default",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "primary",
                "secondary",
                "success",
                "warning",
                "danger",
                "info",
                "neutral"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when the user clicks the remove (×) button",
              "event": "@config.onRemove",
              "payloadSchema": [
                {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Click handler for the body of the pill (filter toggle)",
              "event": "@config.onClick",
              "payloadSchema": [
                {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "label"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FilterPillItem",
          "name": "FilterPillRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REMOVE",
                "name": "Remove",
                "payloadSchema": [
                  {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Called when the user clicks the remove (×) button",
                "key": "@config.onRemove",
                "name": "@config.on remove",
                "payloadSchema": [
                  {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Click handler for the body of the pill (filter toggle)",
                "key": "@config.onClick",
                "name": "@config.on click",
                "payloadSchema": [
                  {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.label",
                    "@config.label"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clickEvent": "@config.clickEvent",
                      "icon": "@config.icon",
                      "label": "@entity.label",
                      "onClick": "@config.onClick",
                      "onRemove": "@config.onRemove",
                      "removable": "@config.removable",
                      "removeEvent": "@config.removeEvent",
                      "size": "@config.size",
                      "type": "filter-pill",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.label",
                    "@payload.label"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clickEvent": "@config.clickEvent",
                      "icon": "@config.icon",
                      "label": "@entity.label",
                      "onClick": "@config.onClick",
                      "onRemove": "@config.onRemove",
                      "removable": "@config.removable",
                      "removeEvent": "@config.removeEvent",
                      "size": "@config.size",
                      "type": "filter-pill",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "REMOVE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.label",
                    "@payload.label"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "clickEvent": "@config.clickEvent",
                      "icon": "@config.icon",
                      "label": "@entity.label",
                      "onClick": "@config.onClick",
                      "onRemove": "@config.onRemove",
                      "removable": "@config.removable",
                      "removeEvent": "@config.removeEvent",
                      "size": "@config.size",
                      "type": "filter-pill",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "CLICK",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}