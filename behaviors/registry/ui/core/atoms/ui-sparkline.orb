{
  "description": "Sparkline — UI factory (1:1 with the @almadar/ui sparkline pattern).",
  "name": "ui-sparkline",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SparklineItem",
        "persistence": "runtime"
      },
      "name": "SparklineOrbital",
      "pages": [
        {
          "name": "SparklinePage",
          "path": "/sparkline",
          "traits": [
            {
              "ref": "SparklineRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "color": {
              "default": "auto",
              "description": "Stroke color. `auto` (default): success when the series trends up (last ≥ first), error when it trends down.",
              "label": "Color",
              "tier": "presentation",
              "type": "string",
              "values": [
                "auto",
                "primary",
                "success",
                "warning",
                "error",
                "info",
                "muted"
              ]
            },
            "data": {
              "default": [
                1.0
              ],
              "description": "Numeric series to plot. Length < 2 renders nothing.",
              "items": {
                "type": "number"
              },
              "label": "Data",
              "tier": "presentation",
              "type": "[number]"
            },
            "fill": {
              "default": false,
              "description": "Fill the area under the line with the stroke color at low opacity.",
              "label": "Fill",
              "tier": "presentation",
              "type": "boolean"
            },
            "height": {
              "default": 32.0,
              "description": "SVG height in px. Default 32.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "strokeWidth": {
              "default": 2.0,
              "description": "Stroke width in px. Default 2.",
              "label": "Stroke Width",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 80.0,
              "description": "SVG width in px. Default 80.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SparklineItem",
          "name": "SparklineRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "color": "@config.color",
                      "data": "@config.data",
                      "fill": "@config.fill",
                      "height": "@config.height",
                      "strokeWidth": "@config.strokeWidth",
                      "type": "sparkline",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}