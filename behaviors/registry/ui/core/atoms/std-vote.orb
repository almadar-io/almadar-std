{
  "description": "std-vote — forum-style up/down vote tally with single-vote-per-user constraint. Owns a Vote entity; VOTE persists the new direction (toggling to none when re-clicking the active arrow) and emits VoteCasted so cross-trait listeners can recompute aggregates.",
  "ledger": {
    "entries": {
      "ent_01KXG04HWQB99PEK6YNZTD2QYJ": {
        "bakedName": "Vote",
        "curName": "Vote",
        "id": "ent_01KXG04HWQB99PEK6YNZTD2QYJ",
        "kind": "entity",
        "owner": "workspace",
        "renames": []
      },
      "evt_01KXG04HWQSB9GE93GQ9S5EPH9": {
        "bakedName": "INIT",
        "curName": "INIT",
        "id": "evt_01KXG04HWQSB9GE93GQ9S5EPH9",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04HWQ5TBXJGAPVBA2DGD7",
