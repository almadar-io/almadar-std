              "description": "Heading shown above the signature-request list",
              "label": "Section title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Signals a request has been sent for signature.",
              "event": "SEND_REQUEST",
              "eventId": "evt_01KXG04G5B4Y0AA91XZSQS49FY",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "synonyms": "dispatch, submit, transmit",
              "tier": "domain"
            },
            {
              "description": "Indicates a signature request has been cancelled.",
              "event": "REVOKE_REQUEST",
              "eventId": "evt_01KXG04G5BWKWY6G81XHKFZ2C5",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "synonyms": "cancel, void, retract",
              "tier": "presentation"
            },
            {
              "description": "Signals that the request list has been successfully populated.",
              "event": "ESignRequestLoaded",
              "eventId": "evt_01KXG04G5BW1GAF7GSNKJ8A1DH",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ESignRequest]"
                }
              ],
              "synonyms": "loaded, refreshed, populated, initialized",
              "tier": "domain"
            },
            {
              "description": "Indicates a failure to load e-signature request data.",
              "event": "ESignRequestLoadFailed",
              "eventId": "evt_01KXG04G5B7GGJAV30TKFABEYZ",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "synonyms": "error, failure, load error",
              "tier": "internal"
            }
          ],
          "entityRefIds": {
            "ESignRequest": "ent_01KXG04G5B7M3Z329MRPPNYF8T"
          },
          "id": "trt_01KXG04G5BFN0ZJZ59A9ATAZ62",
          "linkedEntity": "ESignRequest",
          "linkedEntityId": "ent_01KXG04G5B7M3Z329MRPPNYF8T",
          "name": "ESignRequestSigning",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04G5BG651JPHPEVPEMAK6",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals that the request list has been successfully populated.",
                "id": "evt_01KXG04G5BW1GAF7GSNKJ8A1DH",
                "key": "ESignRequestLoaded",
                "name": "ESignRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ESignRequest]"
                  }
                ],
                "synonyms": "loaded, refreshed, populated, initialized",
                "tier": "domain"
              },
              {
                "description": "Indicates a failure to load e-signature request data.",
                "id": "evt_01KXG04G5B7GGJAV30TKFABEYZ",
                "key": "ESignRequestLoadFailed",
                "name": "ESignRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, load error",
                "tier": "internal"
              },
              {
                "description": "Signals a request has been sent for signature.",
                "id": "evt_01KXG04G5B4Y0AA91XZSQS49FY",
                "key": "SEND_REQUEST",
                "name": "Send Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "dispatch, submit, transmit",
                "tier": "domain"
              },
              {
                "description": "Indicates a signature request has been cancelled.",
                "id": "evt_01KXG04G5BWKWY6G81XHKFZ2C5",
                "key": "REVOKE_REQUEST",
                "name": "Revoke Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "cancel, void, retract",
                "tier": "presentation"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "ESignRequest",
                    {
                      "emit": {
                        "failure": "ESignRequestLoadFailed",
                        "success": "ESignRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "md",
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04G5BG651JPHPEVPEMAK6",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.TitleHeading",
                        "@trait.RequestDataGrid"
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "ESignRequestLoaded",
                "eventId": "evt_01KXG04G5BW1GAF7GSNKJ8A1DH",
                "from": "loading",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ErrorAlert"
                      ],
                      "type": "box"
                    }
                  ]
                ],
                "event": "ESignRequestLoadFailed",
                "eventId": "evt_01KXG04G5B7GGJAV30TKFABEYZ",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Signature request sent",
                    "success"
                  ]
                ],
                "event": "SEND_REQUEST",
                "eventId": "evt_01KXG04G5B4Y0AA91XZSQS49FY",
                "from": "browsing",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Signature request revoked",
                    "info"
                  ]
                ],
                "event": "REVOKE_REQUEST",
                "eventId": "evt_01KXG04G5BWKWY6G81XHKFZ2C5",
                "from": "browsing",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "ESignRequest",
                    {
                      "emit": {
                        "failure": "ESignRequestLoadFailed",
                        "success": "ESignRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "md",
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04G5BG651JPHPEVPEMAK6",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "DataGrid",
          "from": "std/behaviors/ui-data-grid"
        },
        {
          "as": "Alert",
          "from": "std/behaviors/ui-alert"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.1.0"
}