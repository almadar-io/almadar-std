{
  "name": "ui-switch",
  "version": "1.0.0",
  "description": "Switch — UI factory (1:1 with the @almadar/ui switch pattern).",
  "orbitals": [
    {
      "name": "SwitchOrbital",
      "entity": {
        "name": "SwitchItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "checked",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "SwitchRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "checked"
            ]
          },
          "category": "interaction",
          "linkedEntity": "SwitchItem",
          "emits": [
            {
              "event": "CHANGE",
              "description": "onChange prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "checked",
                  "type": "boolean"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "description": "onChange prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "checked",
                    "type": "boolean"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.checked",
                    "@config.checked"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checked": "@entity.checked",
                      "onChange": "CHANGE",
                      "name": "@config.name",
                      "defaultChecked": "@config.defaultChecked",
                      "type": "switch",
                      "disabled": "@config.disabled",
                      "label": "@config.label",
                      "className": "@config.className"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.checked",
                    "@payload.checked"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "name": "@config.name",
                      "className": "@config.className",
                      "label": "@config.label",
                      "defaultChecked": "@config.defaultChecked",
                      "type": "switch",
                      "onChange": "CHANGE",
                      "disabled": "@config.disabled",
                      "checked": "@entity.checked"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "name": {
              "type": "string",
              "default": "Name",
              "label": "Name",
              "description": "name prop",
              "tier": "presentation"
            },
            "checked": {
              "type": "boolean",
              "default": false,
              "label": "Checked",
              "description": "checked prop",
              "tier": "presentation"
            },
            "defaultChecked": {
              "type": "boolean",
              "default": false,
              "label": "Default Checked",
              "description": "defaultChecked prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "disabled prop",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "label prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SwitchPage",
          "path": "/switch",
          "traits": [
            {
              "ref": "SwitchRender"
            }
          ]
        }
      ]
    }
  ]
}
