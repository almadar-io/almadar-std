{
  "description": "Switch — UI factory (1:1 with the @almadar/ui switch pattern).",
  "name": "ui-switch",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": false,
            "name": "checked",
            "type": "boolean"
          }
        ],
        "name": "SwitchItem",
        "persistence": "runtime"
      },
      "name": "SwitchOrbital",
      "pages": [
        {
          "name": "SwitchPage",
          "path": "/switch",
          "traits": [
            {
              "ref": "SwitchRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "checked": {
              "default": false,
              "description": "checked prop",
              "label": "Checked",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "defaultChecked": {
              "default": false,
              "description": "defaultChecked prop",
              "label": "Default Checked",
              "tier": "presentation",
              "type": "boolean"
            },
            "disabled": {
              "default": false,
              "description": "disabled prop",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "label": {
              "default": "Label",
              "description": "label prop",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "name": {
              "default": "Name",
              "description": "name prop",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "onChange prop",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "checked",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "checked"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SwitchItem",
          "name": "SwitchRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "onChange prop",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "checked",
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.checked",
                    "@config.checked"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checked": "@entity.checked",
                      "className": "@config.className",
                      "defaultChecked": "@config.defaultChecked",
                      "disabled": "@config.disabled",
                      "label": "@config.label",
                      "name": "@config.name",
                      "onChange": "CHANGE",
                      "type": "switch"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.checked",
                    "@payload.checked"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checked": "@entity.checked",
                      "className": "@config.className",
                      "defaultChecked": "@config.defaultChecked",
                      "disabled": "@config.disabled",
                      "label": "@config.label",
                      "name": "@config.name",
                      "onChange": "CHANGE",
                      "type": "switch"
                    }
                  ]
                ],
                "event": "CHANGE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}