{
  "description": "Spinner — UI factory (1:1 with the @almadar/ui spinner pattern).",
  "name": "ui-spinner",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SpinnerItem",
        "persistence": "runtime"
      },
      "name": "SpinnerOrbital",
      "pages": [
        {
          "name": "SpinnerPage",
          "path": "/spinner",
          "traits": [
            {
              "ref": "SpinnerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "overlay": {
              "default": false,
              "description": "Renders a centered overlay backdrop instead of inline.",
              "label": "Overlay",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "xs",
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpinnerItem",
          "name": "SpinnerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "overlay": "@config.overlay",
                      "size": "@config.size",
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}