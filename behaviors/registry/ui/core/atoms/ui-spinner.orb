{
  "name": "ui-spinner",
  "version": "1.0.0",
  "description": "Spinner — UI factory (1:1 with the @almadar/ui spinner pattern).",
  "orbitals": [
    {
      "name": "SpinnerOrbital",
      "entity": {
        "name": "SpinnerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SpinnerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SpinnerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "size": "@config.size",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "size prop",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SpinnerPage",
          "path": "/spinner",
          "traits": [
            {
              "ref": "SpinnerRender"
            }
          ]
        }
      ]
    }
  ]
}