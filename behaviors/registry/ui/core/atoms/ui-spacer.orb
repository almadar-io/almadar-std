{
  "name": "ui-spacer",
  "version": "1.0.0",
  "description": "Spacer — UI factory (1:1 with the @almadar/ui spacer pattern).",
  "orbitals": [
    {
      "name": "SpacerOrbital",
      "entity": {
        "name": "SpacerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SpacerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SpacerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "@config.size",
                      "axis": "@config.axis",
                      "className": "@config.className",
                      "type": "spacer"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Custom class name",
              "tier": "presentation"
            },
            "axis": {
              "type": "string",
              "default": "horizontal",
              "label": "Axis",
              "description": "Orientation (for fixed sizes)",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "size": {
              "type": "string",
              "default": "auto",
              "label": "Size",
              "description": "Fixed size (auto = flex grow)",
              "tier": "presentation",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "auto"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SpacerPage",
          "path": "/spacer",
          "traits": [
            {
              "ref": "SpacerRender"
            }
          ]
        }
      ]
    }
  ]
}