{
  "description": "Spacer — UI factory (1:1 with the @almadar/ui spacer pattern).",
  "name": "ui-spacer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SpacerItem",
        "persistence": "runtime"
      },
      "name": "SpacerOrbital",
      "pages": [
        {
          "name": "SpacerPage",
          "path": "/spacer",
          "traits": [
            {
              "ref": "SpacerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "axis": {
              "default": "horizontal",
              "description": "Orientation (for fixed sizes)",
              "label": "Axis",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "className": {
              "default": "",
              "description": "Custom class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "auto",
              "description": "Fixed size (auto = flex grow)",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
                "2xl",
                "auto"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpacerItem",
          "name": "SpacerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "axis": "@config.axis",
                      "className": "@config.className",
                      "size": "@config.size",
                      "type": "spacer"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}