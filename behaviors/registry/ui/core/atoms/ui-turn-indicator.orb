{
  "name": "ui-turn-indicator",
  "version": "1.0.0",
  "description": "TurnIndicator — UI factory (1:1 with the @almadar/ui turn-indicator pattern).",
  "orbitals": [
    {
      "name": "TurnIndicatorOrbital",
      "entity": {
        "name": "TurnIndicatorItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TurnIndicatorRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TurnIndicatorItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "turn-indicator",
                      "className": "@config.className",
                      "activeTeam": "@config.activeTeam",
                      "maxTurns": "@config.maxTurns",
                      "phase": "@config.phase",
                      "currentTurn": "@config.currentTurn",
                      "size": "@config.size"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "activeTeam": {
              "type": "string",
              "default": "",
              "label": "Active Team",
              "description": "Name of the active team",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "currentTurn": {
              "type": "number",
              "default": 0.0,
              "label": "Current Turn",
              "description": "Current turn number",
              "tier": "presentation"
            },
            "phase": {
              "type": "string",
              "default": "",
              "label": "Phase",
              "description": "Current phase label",
              "tier": "presentation"
            },
            "maxTurns": {
              "type": "number",
              "default": 0.0,
              "label": "Max Turns",
              "description": "Maximum number of turns",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TurnIndicatorPage",
          "path": "/turn-indicator",
          "traits": [
            {
              "ref": "TurnIndicatorRender"
            }
          ]
        }
      ]
    }
  ]
}
