{
  "description": "StatusDot — UI factory (1:1 with the @almadar/ui status-dot pattern).",
  "name": "ui-status-dot",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StatusDotItem",
        "persistence": "runtime"
      },
      "name": "StatusDotOrbital",
      "pages": [
        {
          "name": "StatusDotPage",
          "path": "/status-dot",
          "traits": [
            {
              "ref": "StatusDotRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Accessible label (rendered as sr-only text)",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "pulse": {
              "default": false,
              "description": "Enable pulse animation for active/critical states",
              "label": "Pulse",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Dot size",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "status": {
              "default": "offline",
              "description": "Status determines the dot color",
              "label": "Status",
              "tier": "presentation",
              "type": "string",
              "values": [
                "online",
                "offline",
                "away",
                "busy",
                "warning",
                "critical"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StatusDotItem",
          "name": "StatusDotRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "label": "@config.label",
                      "pulse": "@config.pulse",
                      "size": "@config.size",
                      "status": "@config.status",
                      "type": "status-dot"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}