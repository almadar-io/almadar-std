                      "type": "string"
                    },
                    {
                      "name": "signatureDataUrl",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "signedAt",
                      "type": "string"
                    },
                    {
                      "name": "ipAddress",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "synonyms": "signed, finalized, completed",
              "tier": "domain"
            },
            {
