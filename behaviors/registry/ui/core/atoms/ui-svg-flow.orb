{
  "description": "SvgFlow — UI factory (1:1 with the @almadar/ui svg-flow pattern).",
  "name": "ui-svg-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SvgFlowItem",
        "persistence": "runtime"
      },
      "name": "SvgFlowOrbital",
      "pages": [
        {
          "name": "SvgFlowPage",
          "path": "/svg-flow",
          "traits": [
            {
              "ref": "SvgFlowRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": false,
              "description": "animated prop",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "asRoot": {
              "default": true,
              "description": "When true (default), wraps in a standalone <svg> so the shape is visible without a parent SVG context.",
              "label": "As Root",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "color": {
              "default": "var(--color-primary)",
              "description": "color prop",
              "label": "Color",
              "tier": "presentation",
              "type": "string"
            },
            "height": {
              "default": 100.0,
              "description": "height prop",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "opacity": {
              "default": 1.0,
              "description": "opacity prop",
              "label": "Opacity",
              "tier": "presentation",
              "type": "number"
            },
            "points": {
              "default": [],
              "description": "points prop",
              "items": {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              "label": "Points",
              "tier": "presentation",
              "type": "[[number]]"
            },
            "strokeWidth": {
              "default": 1.5,
              "description": "strokeWidth prop",
              "label": "Stroke Width",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 100.0,
              "description": "width prop",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SvgFlowItem",
          "name": "SvgFlowRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "asRoot": "@config.asRoot",
                      "className": "@config.className",
                      "color": "@config.color",
                      "height": "@config.height",
                      "opacity": "@config.opacity",
                      "points": "@config.points",
                      "strokeWidth": "@config.strokeWidth",
                      "type": "svg-flow",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}