{
  "description": "TimeSlotCell — UI factory (1:1 with the @almadar/ui time-slot-cell pattern).",
  "name": "ui-time-slot-cell",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Time",
            "name": "time",
            "type": "string"
          }
        ],
        "name": "TimeSlotCellItem",
        "persistence": "runtime"
      },
      "name": "TimeSlotCellOrbital",
      "pages": [
        {
          "name": "TimeSlotCellPage",
          "path": "/time-slot-cell",
          "traits": [
            {
              "ref": "TimeSlotCellRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Event content placed inside the slot",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "isOccupied": {
              "default": false,
              "description": "Whether this slot contains an event",
              "label": "Is Occupied",
              "tier": "presentation",
              "type": "boolean"
            },
            "onClick": {
              "default": "CLICK",
              "description": "Called when the slot is clicked",
              "label": "On Click",
              "tier": "presentation",
              "type": "string"
            },
            "time": {
              "default": "Time",
              "description": "Time label for this slot (e.g. '09:00')",
              "label": "Time",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Called when the slot is clicked",
              "event": "@config.onClick",
              "payloadSchema": [
                {
                  "name": "time",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "time"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TimeSlotCellItem",
          "name": "TimeSlotCellRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Called when the slot is clicked",
                "key": "@config.onClick",
                "name": "@config.on click",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.time",
                    "@config.time"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "isOccupied": "@config.isOccupied",
                      "onClick": "@config.onClick",
                      "time": "@entity.time",
                      "type": "time-slot-cell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.time",
                    "@payload.time"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "isOccupied": "@config.isOccupied",
                      "onClick": "@config.onClick",
                      "time": "@entity.time",
                      "type": "time-slot-cell"
                    }
                  ]
                ],
                "event": "CLICK",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}