{
  "name": "ui-time-slot-cell",
  "version": "1.0.0",
  "description": "TimeSlotCell — UI factory (1:1 with the @almadar/ui time-slot-cell pattern).",
  "orbitals": [
    {
      "name": "TimeSlotCellOrbital",
      "entity": {
        "name": "TimeSlotCellItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "time",
            "type": "string",
            "default": "Time"
          }
        ]
      },
      "traits": [
        {
          "name": "TimeSlotCellRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "time"
            ]
          },
          "category": "interaction",
          "linkedEntity": "TimeSlotCellItem",
          "emits": [
            {
              "event": "CLICK",
              "description": "Called when the slot is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "time",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "Called when the slot is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.time",
                    "@config.time"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "time": "@entity.time",
                      "isOccupied": "@config.isOccupied",
                      "onClick": "CLICK",
                      "type": "time-slot-cell",
                      "className": "@config.className",
                      "children": "@config.children"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLICK",
                "effects": [
                  [
                    "set",
                    "@entity.time",
                    "@payload.time"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onClick": "CLICK",
                      "className": "@config.className",
                      "isOccupied": "@config.isOccupied",
                      "type": "time-slot-cell",
                      "time": "@entity.time",
                      "children": "@config.children"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "children": {
              "type": "node",
              "label": "Children",
              "description": "Event content placed inside the slot",
              "tier": "presentation"
            },
            "isOccupied": {
              "type": "boolean",
              "default": false,
              "label": "Is Occupied",
              "description": "Whether this slot contains an event",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "time": {
              "type": "string",
              "default": "Time",
              "label": "Time",
              "description": "Time label for this slot (e.g. '09:00')",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TimeSlotCellPage",
          "path": "/time-slot-cell",
          "traits": [
            {
              "ref": "TimeSlotCellRender"
            }
          ]
        }
      ]
    }
  ]
}
