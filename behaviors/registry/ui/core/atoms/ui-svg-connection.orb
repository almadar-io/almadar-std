{
  "name": "ui-svg-connection",
  "version": "1.0.0",
  "description": "SvgConnection — UI factory (1:1 with the @almadar/ui svg-connection pattern).",
  "orbitals": [
    {
      "name": "SvgConnectionOrbital",
      "entity": {
        "name": "SvgConnectionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SvgConnectionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SvgConnectionItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "y2": "@config.y2",
                      "opacity": "@config.opacity",
                      "type": "svg-connection",
                      "strokeWidth": "@config.strokeWidth",
                      "x2": "@config.x2",
                      "x1": "@config.x1",
                      "color": "@config.color",
                      "className": "@config.className",
                      "variant": "@config.variant",
                      "y1": "@config.y1"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "opacity": {
              "type": "number",
              "default": 1.0,
              "label": "Opacity",
              "description": "opacity prop",
              "tier": "presentation"
            },
            "x1": {
              "type": "number",
              "default": 0.0,
              "label": "X1",
              "description": "x1 prop",
              "tier": "presentation"
            },
            "y2": {
              "type": "number",
              "default": 0.0,
              "label": "Y2",
              "description": "y2 prop",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "solid",
              "label": "Variant",
              "description": "variant prop",
              "tier": "presentation",
              "values": [
                "solid",
                "dashed",
                "animated"
              ]
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "color prop",
              "tier": "presentation"
            },
            "strokeWidth": {
              "type": "number",
              "default": 1.5,
              "label": "Stroke Width",
              "description": "strokeWidth prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "x2": {
              "type": "number",
              "default": 0.0,
              "label": "X2",
              "description": "x2 prop",
              "tier": "presentation"
            },
            "y1": {
              "type": "number",
              "default": 0.0,
              "label": "Y1",
              "description": "y1 prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SvgConnectionPage",
          "path": "/svg-connection",
          "traits": [
            {
              "ref": "SvgConnectionRender"
            }
          ]
        }
      ]
    }
  ]
}