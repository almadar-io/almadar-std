{
  "name": "ui-svg-branch",
  "version": "1.0.0",
  "description": "SvgBranch — UI factory (1:1 with the @almadar/ui svg-branch pattern).",
  "orbitals": [
    {
      "name": "SvgBranchOrbital",
      "entity": {
        "name": "SvgBranchItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SvgBranchRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SvgBranchItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "branches": "@config.branches",
                      "y": "@config.y",
                      "opacity": "@config.opacity",
                      "className": "@config.className",
                      "color": "@config.color",
                      "type": "svg-branch",
                      "variant": "@config.variant",
                      "size": "@config.size",
                      "x": "@config.x"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "y": {
              "type": "number",
              "default": 0.0,
              "label": "Y",
              "description": "y prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "color prop",
              "tier": "presentation"
            },
            "size": {
              "type": "number",
              "default": 1.0,
              "label": "Size",
              "description": "size prop",
              "tier": "presentation"
            },
            "opacity": {
              "type": "number",
              "default": 1.0,
              "label": "Opacity",
              "description": "opacity prop",
              "tier": "presentation"
            },
            "x": {
              "type": "number",
              "default": 0.0,
              "label": "X",
              "description": "x prop",
              "tier": "presentation"
            },
            "branches": {
              "type": "number",
              "default": 2.0,
              "label": "Branches",
              "description": "branches prop",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "fork",
              "label": "Variant",
              "description": "variant prop",
              "tier": "presentation",
              "values": [
                "fork",
                "merge",
                "diamond"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SvgBranchPage",
          "path": "/svg-branch",
          "traits": [
            {
              "ref": "SvgBranchRender"
            }
          ]
        }
      ]
    }
  ]
}