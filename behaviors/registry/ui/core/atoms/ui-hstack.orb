{
  "description": "Hstack — UI factory (1:1 with the @almadar/ui hstack pattern).",
  "name": "ui-hstack",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "HstackItem",
        "persistence": "runtime"
      },
      "name": "HstackOrbital",
      "pages": [
        {
          "name": "HstackPage",
          "path": "/hstack",
          "traits": [
            {
              "ref": "HstackRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HstackItem",
          "name": "HstackRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "hstack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}