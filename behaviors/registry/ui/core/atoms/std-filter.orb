{
  "description": "std-filter — single primitive: filter-group. Owns a FilterTarget runtime entity; every FILTER transition persists field/value so cross-trait listeners can route the latest selection into data atoms.",
  "name": "std-filter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The name of the data field being filtered.",
            "name": "field",
            "synonyms": "attribute, property, key",
            "type": "string"
          },
          {
            "description": "The data associated with the filter criterion.",
            "name": "value",
            "synonyms": "data, criterion, content",
            "type": "string"
          }
        ],
        "name": "FilterTarget",
        "persistence": "runtime"
      },
      "name": "FilterTargetOrbital",
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "event": {
              "default": "FILTER",
              "description": "Event emitted when the user changes a filter selection",
              "label": "Filter event",
              "tier": "internal",
              "type": "string"
            },
            "filterBarLook": {
              "default": "toolbar",
              "description": "Layer 2 visual treatment for the filter bar.",
              "label": "Filter bar look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "toolbar",
                "chips",
                "pills",
                "popover-trigger",
                "inline-column-header"
              ]
            },
            "filters": {
              "default": [
                {
                  "field": "status",
                  "filterType": "select",
                  "label": "Status",
                  "options": [
                    "active",
                    "inactive",
                    "pending"
                  ]
                }
              ],
              "description": "Field, label, control type, and options for each filter input",
              "items": {
                "properties": {
                  "field": {
                    "name": "field",
                    "required": true,
                    "type": "string"
                  },
                  "filterType": {
                    "name": "filterType",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "options": {
                    "items": {
                      "type": "string"
                    },
                    "name": "options",
                    "required": false,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Filter controls",
              "tier": "presentation",
              "type": "[FilterSpec]"
            }
          },
          "emits": [
            {
              "description": "Signals a filter has been applied or changed.",
              "event": "FILTER",
              "payloadSchema": [
                {
                  "name": "field",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "value",
                  "required": true,
                  "type": "string"
                }
              ],
              "synonyms": "apply, update, change, refine",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "field",
              "value"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FilterTarget",
          "name": "FilterTargetFilter",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals a filter has been applied or changed.",
                "key": "FILTER",
                "name": "Filter",
                "payloadSchema": [
                  {
                    "name": "field",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "apply, update, change, refine",
                "tier": "domain"
              },
              {
                "description": "Resets the filter selection to its initial state.",
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters",
                "synonyms": "reset, clear, remove, undo",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "look": "@config.filterBarLook",
                      "type": "filter-group"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    "@payload.field"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "look": "@config.filterBarLook",
                      "type": "filter-group"
                    }
                  ]
                ],
                "event": "FILTER",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "emit",
                    "FILTER",
                    {
                      "field": "",
                      "value": ""
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "look": "@config.filterBarLook",
                      "type": "filter-group"
                    }
                  ]
                ],
                "event": "CLEAR_FILTERS",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}