{
  "description": "Textarea — UI factory (1:1 with the @almadar/ui textarea pattern).",
  "name": "ui-textarea",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TextareaItem",
        "persistence": "runtime"
      },
      "name": "TextareaOrbital",
      "pages": [
        {
          "name": "TextareaPage",
          "path": "/textarea",
          "traits": [
            {
              "ref": "TextareaRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes applied to the root element.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "default": "",
              "description": "Error message",
              "label": "Error",
              "tier": "presentation",
              "type": "string"
            },
            "placeholder": {
              "default": "Placeholder",
              "description": "Placeholder text",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "rows": {
              "default": 0.0,
              "description": "Number of visible rows",
              "label": "Rows",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Declarative event name for trait dispatch",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "onChange handler or declarative event key for trait dispatch",
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TextareaItem",
          "name": "TextareaRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event name for trait dispatch",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "onChange handler or declarative event key for trait dispatch",
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "className": "@config.className",
                      "error": "@config.error",
                      "onChange": "CHANGE",
                      "placeholder": "@config.placeholder",
                      "rows": "@config.rows",
                      "type": "textarea"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}