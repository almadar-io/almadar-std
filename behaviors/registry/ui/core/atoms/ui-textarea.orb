{
  "name": "ui-textarea",
  "version": "1.0.0",
  "description": "Textarea — UI factory (1:1 with the @almadar/ui textarea pattern).",
  "orbitals": [
    {
      "name": "TextareaOrbital",
      "entity": {
        "name": "TextareaItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TextareaRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TextareaItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name for trait dispatch",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for trait dispatch",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "rows": "@config.rows",
                      "className": "@config.className",
                      "action": "ACTION",
                      "error": "@config.error",
                      "placeholder": "@config.placeholder",
                      "type": "textarea"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "rows": {
              "type": "number",
              "default": 0.0,
              "label": "Rows",
              "description": "Number of visible rows",
              "tier": "presentation"
            },
            "error": {
              "type": "string",
              "default": "",
              "label": "Error",
              "description": "Error message",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "placeholder": {
              "type": "string",
              "default": "",
              "label": "Placeholder",
              "description": "Placeholder text",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TextareaPage",
          "path": "/textarea",
          "traits": [
            {
              "ref": "TextareaRender"
            }
          ]
        }
      ]
    }
  ]
}