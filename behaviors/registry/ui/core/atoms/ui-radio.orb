{
  "name": "ui-radio",
  "version": "1.0.0",
  "description": "Radio — UI factory (1:1 with the @almadar/ui radio pattern).",
  "orbitals": [
    {
      "name": "RadioOrbital",
      "entity": {
        "name": "RadioItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "RadioRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "RadioItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Declarative event name for trait dispatch",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Declarative event name for trait dispatch",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "value": "@config.value",
                      "action": "ACTION",
                      "size": "@config.size",
                      "className": "@config.className",
                      "label": "@config.label",
                      "options": "@config.options",
                      "type": "radio",
                      "helperText": "@config.helperText",
                      "error": "@config.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size of the radio button",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Label text displayed next to the radio button",
              "tier": "presentation"
            },
            "helperText": {
              "type": "string",
              "default": "Helper Text",
              "label": "Helper Text",
              "description": "Helper text displayed below the radio button",
              "tier": "presentation"
            },
            "error": {
              "type": "string",
              "default": "",
              "label": "Error",
              "description": "Error message displayed below the radio button",
              "tier": "presentation"
            },
            "value": {
              "type": "string",
              "default": "Value",
              "label": "Value",
              "description": "Current selected value",
              "tier": "presentation"
            },
            "options": {
              "type": "[string]",
              "default": [],
              "label": "Options",
              "description": "Radio options (string array or SelectOption array)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RadioPage",
          "path": "/radio",
          "traits": [
            {
              "ref": "RadioRender"
            }
          ]
        }
      ]
    }
  ]
}