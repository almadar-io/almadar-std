{
  "name": "ui-score-display",
  "version": "1.0.0",
  "description": "ScoreDisplay — UI factory (1:1 with the @almadar/ui score-display pattern).",
  "orbitals": [
    {
      "name": "ScoreDisplayOrbital",
      "entity": {
        "name": "ScoreDisplayItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ScoreDisplayRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ScoreDisplayItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "locale": "@config.locale",
                      "label": "@config.label",
                      "className": "@config.className",
                      "size": "@config.size",
                      "type": "score-display",
                      "icon": "@config.icon",
                      "animated": "@config.animated",
                      "value": "@config.value"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "Label to display before score",
              "tier": "presentation"
            },
            "value": {
              "type": "number",
              "default": 0.0,
              "label": "Value",
              "description": "Current score value",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "animated": {
              "type": "boolean",
              "default": true,
              "label": "Animated",
              "description": "Animation on value change",
              "tier": "presentation"
            },
            "locale": {
              "type": "string",
              "default": "en-US",
              "label": "Locale",
              "description": "Number formatting locale",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "icon": {
              "type": "node",
              "label": "Icon",
              "description": "Icon component or emoji",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ScoreDisplayPage",
          "path": "/score-display",
          "traits": [
            {
              "ref": "ScoreDisplayRender"
            }
          ]
        }
      ]
    }
  ]
}