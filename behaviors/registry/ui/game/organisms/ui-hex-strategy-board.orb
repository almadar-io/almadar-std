                    "type": "string"
                  },
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{endTurnEvent} with {} on end turn",
                "key": "END_TURN",
                "name": "End Turn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when strategy game ends",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called after a unit moves to a new hex",
                "key": "UNIT_MOVE",
                "name": "Unit Move",
                "payloadSchema": [
                  {
                    "name": "unit",
                    "type": "object"
                  },
                  {
                    "name": "to",
                    "properties": [
                      {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.territory",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.enemyTurn",
                    false
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "hex",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Territory",
                            "value": "@entity.territory"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
