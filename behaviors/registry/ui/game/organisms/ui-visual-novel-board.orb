          },
          "entityRebindable": true,
          "id": "trt_01KXG0508WQGBFK0KYZ2MWB42N",
          "linkedEntity": "VisualNovelBoardItem",
          "linkedEntityId": "ent_01KXG0508WXESGXZHCMTS6V4QG",
          "name": "VisualNovelBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG0508WPHMPVKYSP5SQ7N6J",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{chooseEvent} with {nextId} when the player selects a branching choice",
                "id": "evt_01KXG0508ZXGQ0JXW2BQWWJHDX",
                "key": "CHOOSE",
                "name": "Choose",
                "payloadSchema": [
                  {
                    "name": "nextId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{advanceEvent} with {} to advance to the next node",
                "id": "evt_01KXG0508ZGTFMBWS30SDNJRVX",
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{restartEvent} with {} to reset the scene to the start node",
                "id": "evt_01KXG0508Z04D5S5HF0VKRSCSD",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@config.startNodeId"
                  ],
                  [
                    "set",
                    "@entity.currentSpeaker",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "n",
                            [
                              "==",
                              "@n.id",
                              "@entity.currentNodeId"
                            ]
                          ]
                        ]
                      ],
                      "speaker"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentText",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "n",
                            [
                              "==",
                              "@n.id",
                              "@entity.currentNodeId"
                            ]
                          ]
                        ]
                      ],
                      "text"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentChoices",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "n",
                            [
                              "==",
                              "@n.id",
                              "@entity.currentNodeId"
                            ]
                          ]
                        ]
                      ],
                      "choices"
                    ]
                  ],
                  [
                    "set",
                    "@entity.revealedChars",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": [
                        "let",
                        [
                          [
                            "bg",
                            [
                              "object/get",
                              [
                                "array/first",
                                [
                                  "array/filter",
                                  "@entity.nodes",
                                  [
                                    "fn",
                                    "n",
                                    [
                                      "==",
                                      "@n.id",
                                      "@entity.currentNodeId"
                                    ]
                                  ]
                                ]
                              ],
                              "backgroundKey"
                            ]
                          ]
                        ],
                        [
                          "if",
                          [
                            "==",
                            "@bg",
                            "forge"
                          ],
                          "@config.forgeBg",
                          [
                            "if",
                            [
                              "==",
                              "@bg",
                              "core"
                            ],
                            "@config.coreBg",
                            "@config.corridorBg"
                          ]
                        ]
                      ],
                      "children": [
                        {
                          "portrait": "@config.portraitUrl",
                          "revealedChars": "@entity.revealedChars",
                          "speaker": "@entity.currentSpeaker",
                          "text": "@entity.currentText",
                          "type": "dialogue-bubble"
