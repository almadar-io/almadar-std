{
  "description": "VisualNovelBoard — UI factory (1:1 with the @almadar/ui visual-novel-board pattern).",
  "name": "ui-visual-novel-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "backgroundKey": {
                  "name": "backgroundKey",
                  "required": false,
                  "type": "string"
                },
                "choices": {
                  "items": {
                    "properties": {
                      "label": {
                        "name": "label",
                        "required": true,
                        "type": "string"
                      },
                      "nextId": {
                        "name": "nextId",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "name": "choices",
                  "required": false,
                  "type": "array"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "portraitKey": {
                  "name": "portraitKey",
                  "required": false,
                  "type": "string"
                },
                "speaker": {
                  "name": "speaker",
                  "required": true,
                  "type": "string"
                },
                "text": {
                  "name": "text",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "nodes",
            "type": "array"
          },
          {
            "default": "start",
            "name": "currentNodeId",
            "type": "string"
          }
        ],
        "name": "VisualNovelBoardItem",
        "persistence": "runtime"
      },
      "name": "VisualNovelBoardOrbital",
      "pages": [
        {
          "name": "VisualNovelBoardPage",
          "path": "/visual-novel-board",
          "traits": [
            {
              "ref": "VisualNovelBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetManifest": {
              "default": {
                "backgrounds": {
                  "chamber": "scenes/vn-villain-closeup.png",
                  "core": "scenes/vn-foundry-forge.png",
                  "corridor": "scenes/vn-corridor-sentinel.png",
                  "forge": "scenes/vn-foundry-golem.png"
                },
                "baseUrl": "https://almadar-kflow-assets.web.app/shared/",
                "portraits": {
                  "emissary": "portraits/vn-lyra.png",
                  "guide": "portraits/vn-amir.png",
                  "rival": "portraits/vn-dr-aris.png"
                }
              },
              "description": "Base-url + scene-background and character-portrait sprite maps keyed by node backgroundKey/portraitKey.",
              "label": "Asset Manifest",
              "properties": {
                "backgrounds": {
                  "items": {
                    "type": "string"
                  },
                  "name": "backgrounds",
                  "required": false,
                  "type": "object"
                },
                "baseUrl": {
                  "name": "baseUrl",
                  "required": false,
                  "type": "string"
                },
                "portraits": {
                  "items": {
                    "type": "string"
                  },
                  "name": "portraits",
                  "required": false,
                  "type": "object"
                }
              },
              "tier": "presentation",
              "type": "VisualNovelBoardAssetManifest"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "VisualNovelBoardError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "nodes": {
              "default": [
                {
                  "backgroundKey": "corridor",
                  "choices": [
                    {
                      "label": "Approach the sentinel.",
                      "nextId": "meet"
                    },
                    {
                      "label": "Turn back.",
                      "nextId": "retreat"
                    }
                  ],
                  "id": "start",
                  "portraitKey": "guide",
                  "speaker": "Narrator",
                  "text": "The corridor stretches into shadow. A lone sentinel blocks your path."
                },
                {
                  "backgroundKey": "forge",
                  "choices": [
                    {
                      "label": "I seek the core.",
                      "nextId": "end"
                    },
                    {
                      "label": "I am only passing through.",
                      "nextId": "retreat"
                    }
                  ],
                  "id": "meet",
                  "portraitKey": "rival",
                  "speaker": "Sentinel",
                  "text": "You carry the old marks. Speak your purpose, traveler."
                },
                {
                  "backgroundKey": "corridor",
                  "choices": [
                    {
                      "label": "Begin again.",
                      "nextId": "start"
                    }
                  ],
                  "id": "retreat",
                  "portraitKey": "guide",
                  "speaker": "Narrator",
                  "text": "You withdraw into the dark. The path will wait for braver feet."
                },
                {
                  "backgroundKey": "core",
                  "choices": [
                    {
                      "label": "Begin again.",
                      "nextId": "start"
                    }
                  ],
                  "id": "end",
                  "portraitKey": "rival",
                  "speaker": "Sentinel",
                  "text": "Then the way is open. Walk it well."
                }
              ],
              "description": "Dialogue graph: each node has speaker text, scene/portrait keys, and branching choices.",
              "items": {
                "properties": {
                  "backgroundKey": {
                    "name": "backgroundKey",
                    "required": false,
                    "type": "string"
                  },
                  "choices": {
                    "items": {
                      "properties": {
                        "label": {
                          "name": "label",
                          "required": true,
                          "type": "string"
                        },
                        "nextId": {
                          "name": "nextId",
                          "required": true,
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "name": "choices",
                    "required": false,
                    "type": "array"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "portraitKey": {
                    "name": "portraitKey",
                    "required": false,
                    "type": "string"
                  },
                  "speaker": {
                    "name": "speaker",
                    "required": true,
                    "type": "string"
                  },
                  "text": {
                    "name": "text",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "presentation",
              "type": "[VisualNovelBoardNodesItem]"
            },
            "portraitScale": {
              "default": 1.0,
              "description": "Character portrait draw-size multiplier",
              "label": "Portrait Scale",
              "tier": "presentation",
              "type": "number"
            },
            "startNodeId": {
              "default": "start",
              "description": "Id of the dialogue node shown first / on restart",
              "label": "Start Node Id",
              "tier": "presentation",
              "type": "string"
            },
            "typewriterSpeed": {
              "default": 30.0,
              "description": "Milliseconds per character of dialogue text reveal (0 = instant)",
              "label": "Typewriter Speed",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{chooseEvent} with {choiceIndex} when the player selects a branching choice",
              "event": "CHOOSE",
              "payloadSchema": [
                {
                  "name": "choiceIndex",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{advanceEvent} with {} to advance to the first choice's target node",
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{restartEvent} with {} to reset the scene to the start node",
              "event": "RESTART",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "currentNodeId",
              "nodes"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VisualNovelBoardItem",
          "name": "VisualNovelBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{chooseEvent} with {choiceIndex} when the player selects a branching choice",
                "key": "CHOOSE",
                "name": "Choose",
                "payloadSchema": [
                  {
                    "name": "choiceIndex",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{advanceEvent} with {} to advance to the first choice's target node",
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{restartEvent} with {} to reset the scene to the start node",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@config.startNodeId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "assetManifest": "@config.assetManifest",
                      "chooseEvent": "CHOOSE",
                      "className": "@config.className",
                      "currentNodeId": "@entity.currentNodeId",
                      "entity": "@entity",
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentNodeId",
                    [
                      "object/get",
                      [
                        "array/nth",
                        [
                          "object/get",
                          [
                            "array/first",
                            [
                              "array/filter",
                              "@entity.nodes",
                              [
                                "fn",
                                "n",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@n",
                                    "id"
                                  ],
                                  "@entity.currentNodeId"
                                ]
                              ]
                            ]
                          ],
                          "choices"
                        ],
                        "@payload.choiceIndex"
                      ],
                      "nextId"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "assetManifest": "@config.assetManifest",
                      "chooseEvent": "CHOOSE",
                      "className": "@config.className",
                      "currentNodeId": "@entity.currentNodeId",
                      "entity": "@entity",
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "CHOOSE",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    ">=",
                    "@payload.choiceIndex",
                    0.0
                  ],
                  [
                    "<",
                    "@payload.choiceIndex",
                    [
                      "array/len",
                      [
                        "object/get",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@entity.nodes",
                            [
                              "fn",
                              "n",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@n",
                                  "id"
                                ],
                                "@entity.currentNodeId"
                              ]
                            ]
                          ]
                        ],
                        "choices"
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentNodeId",
                    [
                      "object/get",
                      [
                        "array/nth",
                        [
                          "object/get",
                          [
                            "array/first",
                            [
                              "array/filter",
                              "@entity.nodes",
                              [
                                "fn",
                                "n",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@n",
                                    "id"
                                  ],
                                  "@entity.currentNodeId"
                                ]
                              ]
                            ]
                          ],
                          "choices"
                        ],
                        0.0
                      ],
                      "nextId"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "assetManifest": "@config.assetManifest",
                      "chooseEvent": "CHOOSE",
                      "className": "@config.className",
                      "currentNodeId": "@entity.currentNodeId",
                      "entity": "@entity",
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "ADVANCE",
                "from": "playing",
                "guard": [
                  ">",
                  [
                    "array/len",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "n",
                            [
                              "==",
                              [
                                "object/get",
                                "@n",
                                "id"
                              ],
                              "@entity.currentNodeId"
                            ]
                          ]
                        ]
                      ],
                      "choices"
                    ]
                  ],
                  0.0
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@config.startNodeId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "assetManifest": "@config.assetManifest",
                      "chooseEvent": "CHOOSE",
                      "className": "@config.className",
                      "currentNodeId": "@entity.currentNodeId",
                      "entity": "@entity",
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "RESTART",
                "from": "playing",
                "to": "playing"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}