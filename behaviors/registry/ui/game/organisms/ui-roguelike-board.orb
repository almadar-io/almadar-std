              ],
              "description": "Dungeon tile grid with wall/floor/stairs layout.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "passable": {
                    "name": "passable",
                    "required": false,
                    "type": "boolean"
                  },
                  "terrain": {
                    "name": "terrain",
                    "required": false,
                    "type": "string"
                  },
                  "terrainSprite": {
                    "name": "terrainSprite",
                    "required": false,
                    "type": "string"
                  },
                  "tileType": {
                    "name": "tileType",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[RoguelikeBoardTilesItem]"
            },
            "unitScale": {
              "default": 1.0,
              "description": "Unit draw-size multiplier",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Player move by delta (arrow key or tile click)",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "dx",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "dy",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Resets the dungeon to depth 1",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emitted when result transitions to won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "depth",
              "enemies",
              "gridHeight",
              "gridWidth",
              "items",
              "phase",
              "player",
              "playerAttack",
              "playerHp",
              "playerMaxHp",
              "result",
              "stairsX",
              "stairsY",
              "tiles"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RoguelikeBoardItem",
          "name": "RoguelikeBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Player move by delta (arrow key or tile click)",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "dx",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "dy",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emitted when result transitions to won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Resets the dungeon to depth 1",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.tiles",
                    "@config.tiles"
                  ],
                  [
                    "set",
                    "@entity.player",
                    "@config.player"
                  ],
                  [
                    "set",
                    "@entity.playerHp",
                    "@config.playerMaxHp"
                  ],
                  [
                    "set",
                    "@entity.playerMaxHp",
                    "@config.playerMaxHp"
                  ],
                  [
                    "set",
                    "@entity.playerAttack",
                    "@config.playerAttack"
                  ],
                  [
                    "set",
                    "@entity.enemies",
                    "@config.enemies"
                  ],
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "set",
                    "@entity.depth",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "player_turn"
                  ],
                  [
                    "set",
                    "@entity.stairsX",
                    "@config.stairsX"
                  ],
                  [
                    "set",
                    "@entity.stairsY",
                    "@config.stairsY"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    16.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "depth": "@entity.depth",
                      "enemies": "@entity.enemies",
                      "entity": "@entity",
                      "items": "@entity.items",
                      "moveEvent": "MOVE",
                      "phase": "@entity.phase",
                      "playAgainEvent": "PLAY_AGAIN",
                      "player": "@entity.player",
                      "playerHp": "@entity.playerHp",
                      "playerMaxHp": "@entity.playerMaxHp",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "stairsX": "@entity.stairsX",
                      "stairsY": "@entity.stairsY",
                      "tiles": "@entity.tiles",
                      "type": "roguelike-board",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "tx",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "x"
                          ],
                          "@payload.dx"
                        ]
                      ],
                      [
                        "ty",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "y"
                          ],
                          "@payload.dy"
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "inBounds",
                          [
                            "and",
                            [
                              "and",
                              [
                                ">=",
                                "@tx",
                                0.0
                              ],
                              [
                                "<",
                                "@tx",
                                "@entity.gridWidth"
                              ]
                            ],
                            [
                              "and",
                              [
                                ">=",
                                "@ty",
                                0.0
                              ],
                              [
                                "<",
                                "@ty",
                                "@entity.gridHeight"
                              ]
                            ]
                          ]
                        ],
                        [
                          "tile",
                          [
                            "array/find",
                            "@entity.tiles",
                            [
                              "fn",
                              "t",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@t",
                                    "x"
                                  ],
                                  "@tx"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@t",
                                    "y"
                                  ],
                                  "@ty"
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "walkable",
                          [
                            "if",
                            [
                              "==",
                              "@tile",
                              null
                            ],
                            false,
                            [
                              "object/get",
                              "@tile",
                              "passable"
                            ]
                          ]
                        ],
                        [
                          "hitEnemy",
                          [
                            "array/find",
                            "@entity.enemies",
                            [
                              "fn",
                              "e",
                              [
                                "and",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@e.x",
                                    "@tx"
                                  ],
                                  [
                                    "==",
                                    "@e.y",
                                    "@ty"
                                  ]
                                ],
                                [
                                  ">",
                                  "@e.hp",
                                  0.0
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "hitItem",
                          [
                            "array/find",
                            "@entity.items",
                            [
                              "fn",
                              "i",
                              [
                                "and",
                                [
                                  "==",
