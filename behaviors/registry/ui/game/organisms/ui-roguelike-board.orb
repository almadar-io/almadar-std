            }
          },
          "emits": [
            {
              "description": "Player move by delta (arrow key or tile click)",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "dx",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "dy",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Resets the dungeon to depth 1",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emitted when result transitions to won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "depth",
              "effects",
              "enemies",
              "gridHeight",
              "gridWidth",
              "items",
              "phase",
              "player",
              "playerAnimation",
              "playerAttack",
              "playerFrame",
              "playerHp",
              "playerMaxHp",
              "result",
              "stairsX",
              "stairsY",
              "tiles"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RoguelikeBoardItem",
          "name": "RoguelikeBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Player move by delta (arrow key or tile click)",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "dx",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "dy",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emitted when result transitions to won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Resets the dungeon to depth 1",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.tiles",
                    "@config.tiles"
                  ],
                  [
                    "set",
                    "@entity.player",
                    "@config.player"
                  ],
                  [
                    "set",
                    "@entity.playerHp",
                    "@config.playerMaxHp"
                  ],
                  [
                    "set",
                    "@entity.playerMaxHp",
                    "@config.playerMaxHp"
                  ],
                  [
                    "set",
                    "@entity.playerAttack",
                    "@config.playerAttack"
                  ],
                  [
                    "set",
                    "@entity.playerAnimation",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.playerFrame",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.enemies",
                    [
                      "array/map",
                      "@config.enemies",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "animation": "idle",
                            "frame": 0.0
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "set",
                    "@entity.depth",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "player_turn"
                  ],
                  [
                    "set",
                    "@entity.stairsX",
                    "@config.stairsX"
                  ],
                  [
                    "set",
                    "@entity.stairsY",
                    "@config.stairsY"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": [
                            "array/map",
                            "@entity.items",
                            [
                              "fn",
                              "i",
                              {
                                "id": "@i.id",
                                "sprite": [
                                  "if",
                                  [
                                    "==",
                                    "@i.kind",
                                    "health_potion"
                                  ],
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@config.assetManifest",
                                      "features"
                                    ],
                                    "health_potion"
                                  ],
                                  [
                                    "if",
                                    [
                                      "==",
                                      "@i.kind",
                                      "sword"
                                    ],
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@config.assetManifest",
                                        "features"
                                      ],
                                      "sword"
                                    ],
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@config.assetManifest",
                                        "features"
                                      ],
                                      "shield"
                                    ]
                                  ]
                                ],
                                "type": "@i.kind",
                                "x": "@i.x",
                                "y": "@i.y"
                              }
                            ]
                          ],
                          "projection": "isometric",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tiles": "@entity.tiles",
                          "type": "canvas-2d",
                          "units": [
                            "array/append",
                            [
                              "array/map",
                              "@entity.enemies",
                              [
                                "fn",
                                "e",
                                [
                                  "object/merge",
                                  {
                                    "animation": "@e.animation",
                                    "frame": "@e.frame",
                                    "health": "@e.hp",
                                    "id": "@e.id",
                                    "maxHealth": 5.0,
                                    "sprite": {
                                      "animations": [
                                        "idle",
                                        "walk",
                                        "attack",
                                        "hit",
                                        "death"
                                      ],
                                      "aspect": "1:1",
                                      "category": "enemy",
                                      "dimension": "2d",
                                      "name": "enemy",
                                      "role": "npc",
                                      "style": "",
                                      "thumbnailUrl": "",
                                      "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png"
                                    },
                                    "team": "enemy",
                                    "x": "@e.x",
                                    "y": "@e.y"
                                  },
                                  {}
                                ]
                              ]
                            ],
                            {
                              "animation": "@entity.playerAnimation",
                              "frame": "@entity.playerFrame",
                              "health": "@entity.playerHp",
                              "id": "player",
                              "maxHealth": "@entity.playerMaxHp",
                              "sprite": {
                                "animations": [
                                  "idle",
                                  "walk",
                                  "attack",
                                  "hit",
                                  "death"
                                ],
                                "aspect": "1:1",
                                "category": "player",
                                "dimension": "2d",
                                "name": "player",
                                "role": "npc",
                                "style": "",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                              },
                              "team": "player",
                              "x": [
                                "object/get",
                                "@entity.player",
                                "x"
                              ],
                              "y": [
                                "object/get",
                                "@entity.player",
                                "y"
                              ]
                            }
                          ]
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "HP",
                            "value": "@entity.playerHp"
                          },
                          {
                            "label": "Floor",
                            "value": "@entity.depth"
                          },
                          {
                            "label": "Gold",
                            "value": [
                              "array/len",
                              "@entity.enemies"
                            ]
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "tx",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "x"
                          ],
                          "@payload.dx"
                        ]
                      ],
                      [
                        "ty",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "y"
                          ],
                          "@payload.dy"
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "let",
                        [
                          [
                            "inBounds",
                            [
                              "and",
                              [
                                "and",
                                [
                                  ">=",
                                  "@tx",
                                  0.0
                                ],
                                [
                                  "<",
                                  "@tx",
                                  "@entity.gridWidth"
                                ]
                              ],
                              [
                                "and",
                                [
                                  ">=",
                                  "@ty",
                                  0.0
                                ],
                                [
                                  "<",
                                  "@ty",
                                  "@entity.gridHeight"
                                ]
                              ]
                            ]
                          ],
                          [
                            "tile",
                            [
                              "array/find",
                              "@entity.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "@tx"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ],
                                    "@ty"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "hitEnemy",
                            [
                              "array/find",
                              "@entity.enemies",
                              [
                                "fn",
                                "e",
                                [
                                  "and",
                                  [
                                    "and",
                                    [
                                      "==",
                                      "@e.x",
                                      "@tx"
                                    ],
                                    [
                                      "==",
                                      "@e.y",
                                      "@ty"
                                    ]
                                  ],
                                  [
                                    ">",
                                    "@e.hp",
                                    0.0
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "hitItem",
                            [
                              "array/find",
                              "@entity.items",
                              [
                                "fn",
                                "i",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@i.x",
                                    "@tx"
                                  ],
                                  [
                                    "==",
                                    "@i.y",
                                    "@ty"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "walkable",
                              [
                                "if",
                                [
                                  "==",
                                  "@tile",
                                  null
                                ],
                                false,
                                [
                                  "object/get",
                                  "@tile",
                                  "passable"
                                ]
                              ]
                            ]
                          ],
                          [
                            "if",
                            [
                              "and",
                              "@inBounds",
                              [
                                "==",
                                "@hitEnemy",
                                null
                              ]
                            ],
                            [
                              "do",
                              [
                                "if",
                                [
                                  "==",
                                  "@hitItem",
                                  null
                                ],
                                true,
                                [
                                  "do",
                                  [
                                    "if",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@hitItem",
                                        "kind"
                                      ],
                                      "health_potion"
                                    ],
                                    [
                                      "set",
                                      "@entity.playerHp",
                                      [
                                        "math/min",
                                        "@entity.playerMaxHp",
                                        [
                                          "+",
                                          "@entity.playerHp",
                                          5.0
                                        ]
                                      ]
                                    ],
                                    true
                                  ],
                                  [
                                    "if",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@hitItem",
                                        "kind"
                                      ],
                                      "sword"
                                    ],
                                    [
                                      "set",
                                      "@entity.playerAttack",
                                      [
                                        "+",
                                        "@entity.playerAttack",
                                        1.0
                                      ]
                                    ],
                                    true
                                  ],
                                  [
                                    "set",
                                    "@entity.items",
                                    [
                                      "array/filter",
                                      "@entity.items",
                                      [
                                        "fn",
                                        "i",
                                        [
                                          "!=",
                                          "@i.id",
                                          [
                                            "object/get",
                                            "@hitItem",
                                            "id"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "if",
                                [
                                  "and",
                                  "@walkable",
                                  "@inBounds"
                                ],
                                [
                                  "do",
                                  [
                                    "set",
                                    "@entity.player",
                                    {
                                      "x": "@tx",
                                      "y": "@ty"
                                    }
                                  ],
                                  [
                                    "set",
                                    "@entity.playerAnimation",
                                    "walk"
                                  ]
                                ],
                                true
                              ]
                            ],
                            [
                              "if",
                              [
                                "!=",
                                "@hitEnemy",
                                null
                              ],
                              [
                                "do",
                                [
                                  "set",
                                  "@entity.playerAnimation",
                                  "attack"
                                ],
                                [
                                  "set",
                                  "@entity.enemies",
                                  [
                                    "array/map",
                                    "@entity.enemies",
                                    [
                                      "fn",
                                      "e",
                                      [
                                        "if",
                                        [
                                          "==",
                                          "@e.id",
                                          [
                                            "object/get",
                                            "@hitEnemy",
                                            "id"
                                          ]
                                        ],
                                        [
                                          "object/merge",
                                          "@e",
                                          {
                                            "animation": [
                                              "if",
                                              [
                                                "<=",
                                                [
                                                  "math/max",
                                                  0.0,
                                                  [
                                                    "-",
                                                    "@e.hp",
                                                    "@entity.playerAttack"
                                                  ]
                                                ],
                                                0.0
                                              ],
                                              "death",
                                              "hit"
                                            ],
                                            "hp": [
                                              "math/max",
                                              0.0,
                                              [
                                                "-",
                                                "@e.hp",
                                                "@entity.playerAttack"
                                              ]
                                            ]
                                          }
                                        ],
                                        "@e"
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "set",
                                  "@entity.effects",
                                  [
                                    "array/append",
                                    "@entity.effects",
                                    {
                                      "key": "slash",
                                      "ttl": 4.0,
                                      "x": [
                                        "object/get",
                                        "@hitEnemy",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@hitEnemy",
                                        "y"
                                      ]
                                    }
                                  ]
                                ],
                                [
                                  "if",
                                  [
                                    "<=",
                                    [
                                      "object/get",
                                      [
                                        "array/find",
                                        "@entity.enemies",
                                        [
                                          "fn",
                                          "e",
                                          [
                                            "==",
                                            "@e.id",
                                            [
                                              "object/get",
                                              "@hitEnemy",
                                              "id"
                                            ]
                                          ]
                                        ]
                                      ],
                                      "hp"
                                    ],
                                    0.0
                                  ],
                                  [
                                    "set",
                                    "@entity.effects",
                                    [
                                      "array/append",
                                      "@entity.effects",
                                      {
                                        "key": "explosion",
                                        "ttl": 5.0,
                                        "x": [
                                          "object/get",
                                          "@hitEnemy",
                                          "x"
                                        ],
                                        "y": [
                                          "object/get",
                                          "@hitEnemy",
                                          "y"
                                        ]
                                      }
                                    ]
                                  ],
                                  null
                                ]
                              ],
                              true
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.enemies",
                        [
                          "array/filter",
                          "@entity.enemies",
                          [
                            "fn",
                            "e",
                            [
                              ">",
                              "@e.hp",
                              0.0
                            ]
                          ]
                        ]
                      ],
                      [
                        "if",
                        [
                          "and",
                          [
                            "==",
                            [
                              "object/get",
                              "@entity.player",
                              "x"
                            ],
                            "@entity.stairsX"
                          ],
                          [
                            "==",
                            [
                              "object/get",
                              "@entity.player",
                              "y"
                            ],
                            "@entity.stairsY"
                          ]
                        ],
                        [
                          "set",
                          "@entity.depth",
                          [
                            "+",
                            "@entity.depth",
                            1.0
                          ]
                        ],
                        true
                      ],
                      [
                        "set",
                        "@entity.phase",
                        "enemy_turn"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            "@entity.player",
                            "x"
                          ],
                          "@entity.stairsX"
                        ],
                        [
                          "==",
                          [
                            "object/get",
                            "@entity.player",
                            "y"
                          ],
                          "@entity.stairsY"
                        ]
                      ],
                      [
                        "if",
                        [
                          ">=",
                          "@entity.depth",
                          5.0
                        ],
                        "won",
                        "none"
                      ],
                      [
                        "if",
                        [
                          "==",
                          "@entity.playerHp",
                          0.0
                        ],
                        "lost",
                        "none"
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": [
                            "array/map",
                            "@entity.items",
                            [
                              "fn",
                              "i",
                              {
                                "id": "@i.id",
                                "sprite": [
                                  "if",
                                  [
                                    "==",
                                    "@i.kind",
                                    "health_potion"
                                  ],
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@config.assetManifest",
                                      "features"
                                    ],
                                    "health_potion"
                                  ],
                                  [
                                    "if",
                                    [
                                      "==",
                                      "@i.kind",
                                      "sword"
                                    ],
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@config.assetManifest",
                                        "features"
                                      ],
                                      "sword"
                                    ],
