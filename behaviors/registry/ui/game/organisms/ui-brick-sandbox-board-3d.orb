                ],
                "event": "INIT",
                "eventId": "evt_01KXG04WR82H9ZNQA35WK08F8B",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "hit",
                        [
                          "array/find",
                          "@entity.blueprint",
                          [
                            "fn",
                            "b",
                            [
                              "and",
                              [
                                "==",
                                "@b.x",
                                "@payload.x"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  "@b.y",
                                  "@payload.z"
                                ],
                                [
                                  "==",
                                  "@b.filled",
                                  false
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.blueprint",
                        [
                          "if",
                          [
                            "!=",
                            "@hit",
                            null
                          ],
                          [
                            "array/map",
                            "@entity.blueprint",
                            [
                              "fn",
                              "b",
                              [
                                "if",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@b.x",
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    "@b.y",
                                    "@payload.z"
                                  ]
                                ],
                                [
                                  "object/merge",
                                  "@b",
                                  {
                                    "filled": true
                                  }
                                ],
                                "@b"
                              ]
                            ]
                          ],
                          "@entity.blueprint"
                        ]
                      ],
                      [
                        "set",
                        "@entity.placed",
                        [
                          "if",
                          [
                            "!=",
                            "@hit",
                            null
                          ],
                          [
                            "+",
                            "@entity.placed",
                            1.0
                          ],
                          "@entity.placed"
                        ]
                      ],
                      [
                        "set",
                        "@entity.mistakes",
                        [
                          "if",
                          [
                            "==",
                            "@hit",
                            null
                          ],
                          [
                            "+",
                            "@entity.mistakes",
                            1.0
                          ],
                          "@entity.mistakes"
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            ">=",
                            "@entity.placed",
                            [
                              "array/len",
                              "@entity.blueprint"
                            ]
                          ],
                          "won",
                          [
                            "if",
                            [
                              ">=",
                              "@entity.mistakes",
                              3.0
                            ],
                            "lost",
                            "none"
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.features",
                        [
                          "array/map",
                          "@entity.blueprint",
                          [
                            "fn",
                            "b",
                            [
                              "if",
                              [
                                "==",
                                "@b.filled",
                                true
                              ],
                              {
                                "assetUrl": "@b.brickModel",
                                "id": "@b.id",
                                "type": "brick",
                                "x": "@b.x",
                                "y": "@b.y"
                              },
                              {
                                "assetUrl": "@config.markerModel",
                                "id": "@b.id",
                                "type": "marker",
                                "x": "@b.x",
                                "y": "@b.y"
                              }
                            ]
                          ]
                        ]
                      ],
