          "linkedEntity": "BrickSandboxBoard3DItem",
          "linkedEntityId": "ent_01KXG04WR8H474SN2BVND72PC0",
          "name": "BrickSandboxBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04WR82H9ZNQA35WK08F8B",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{tileClickEvent} with {tileId,x,z} on grid cell click",
                "id": "evt_01KXG04WRA7X7FCSX403DA513X",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "tileId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "id": "evt_01KXG04WRATBWBP8R5TG69KHZT",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.gridWidth",
                    12.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    12.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          12.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              12.0
                            ],
                            [
                              "fn",
                              "gx",
                              {
                                "id": [
                                  "str/concat",
                                  "t-",
                                  "@gx",
                                  "-",
                                  "@gy"
                                ],
                                "modelUrl": "@config.baseplateModel",
                                "passable": true,
                                "terrain": "baseplate",
                                "x": "@gx",
                                "y": "@gy"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.blueprint",
                    [
                      "array/map",
                      "@config.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "object/merge",
                          "@b",
                          {
                            "filled": false
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.placed",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.mistakes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.features",
                    [
                      "array/map",
                      "@entity.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "if",
                          [
                            "==",
                            "@b.filled",
                            true
                          ],
                          {
                            "assetUrl": "@b.brickModel",
                            "id": "@b.id",
                            "type": "brick",
                            "x": "@b.x",
                            "y": "@b.y"
                          },
                          {
                            "assetUrl": "@config.markerModel",
                            "id": "@b.id",
                            "type": "marker",
                            "x": "@b.x",
                            "y": "@b.y"
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "backgroundColor": "@config.bgColor",
                          "camera": {
                            "mode": "top-down",
                            "zoom": "@config.scale"
                          },
                          "children": [
                            {
                              "items": [
                                "array/map",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@t",
                                      "modelUrl"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@f",
                                      "assetUrl"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.fx",
                                [
                                  "fn",
                                  "fx",
                                  {
                                    "color": "#ffe066",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@fx",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@fx",
                                        "y"
                                      ],
                                      "z": [
                                        "object/get",
                                        "@fx",
                                        "z"
                                      ]
                                    },
                                    "text": [
                                      "object/get",
                                      "@fx",
                                      "message"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            }
                          ],
                          "mode": "3d",
                          "tileClickEvent": "TILE_CLICK",
                          "type": "canvas"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Placed",
                                "value": "@entity.placed"
                              },
                              {
                                "label": "Mistakes",
                                "value": "@entity.mistakes"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              },
                              {
                                "label": "Goal",
                                "value": "Fill every marked cell with a brick"
                              },
                              {
                                "label": "How",
                                "value": "Click a marked cell to drop a brick — 3 mistakes and you're out"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "options": [
                            {
                              "event": "PLAY_AGAIN",
                              "id": "again",
                              "label": "Play Again",
                              "variant": "primary"
                            }
                          ],
                          "subtitle": [
                            "str/concat",
                            "Placed ",
                            "@entity.placed"
                          ],
                          "title": [
                            "if",
                            [
                              "==",
                              "@entity.result",
                              "won"
                            ],
                            "BUILD COMPLETE",
                            "OUT OF TRIES"
                          ],
                          "type": "game-menu"
                        },
                        null
                      ],
                      "type": "game-shell"
