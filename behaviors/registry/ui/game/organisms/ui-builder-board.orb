                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "completeEvent prop",
                "id": "evt_01KXG04WSNZA7F3A1ZM1MYBBXZ",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  },
                  {
                    "name": "attempts",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.components",
                    "@config.components"
                  ],
                  [
                    "set",
                    "@entity.slots",
                    [
                      "array/map",
                      "@config.slots",
                      [
                        "fn",
                        "s",
                        [
                          "object/merge",
                          "@s",
                          {
                            "options": [
                              "array/map",
                              "@config.components",
                              [
                                "fn",
                                "c",
                                {
                                  "componentId": [
                                    "object/get",
                                    "@c",
                                    "id"
                                  ],
                                  "iconUrl": [
                                    "object/get",
                                    "@c",
                                    "iconUrl"
                                  ],
                                  "label": [
                                    "object/get",
                                    "@c",
                                    "label"
                                  ],
                                  "slotId": [
                                    "object/get",
                                    "@s",
                                    "id"
                                  ]
                                }
                              ]
                            ]
                          }
                        ]
                      ]
                    ]
                  ],
                  [
