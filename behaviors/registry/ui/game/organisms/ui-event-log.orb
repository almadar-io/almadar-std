{
  "name": "ui-event-log",
  "version": "1.0.0",
  "description": "EventLog — UI factory (1:1 with the @almadar/ui event-log pattern).",
  "orbitals": [
    {
      "name": "EventLogOrbital",
      "entity": {
        "name": "EventLogItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EventLogRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "EventLogItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "entries": "@config.entries",
                      "label": "@config.label",
                      "maxHeight": "@config.maxHeight",
                      "className": "@config.className",
                      "type": "event-log"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "entries": {
              "type": "[EventLogEntriesItem]",
              "default": [
                {
                  "timestamp": 1.0,
                  "icon": "circle",
                  "message": "Message",
                  "status": "pending",
                  "id": "Id"
                }
              ],
              "label": "Entries",
              "description": "Log entries",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "timestamp": {
                    "name": "timestamp",
                    "type": "number",
                    "required": true
                  },
                  "status": {
                    "name": "status",
                    "type": "string",
                    "required": true,
                    "values": [
                      "pending",
                      "active",
                      "done",
                      "error"
                    ]
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Title label",
              "tier": "presentation"
            },
            "maxHeight": {
              "type": "number",
              "default": 200.0,
              "label": "Max Height",
              "description": "Max visible height before scroll",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EventLogPage",
          "path": "/event-log",
          "traits": [
            {
              "ref": "EventLogRender"
            }
          ]
        }
      ]
    }
  ]
}