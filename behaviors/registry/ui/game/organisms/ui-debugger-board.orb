{
  "name": "ui-debugger-board",
  "version": "1.0.0",
  "description": "DebuggerBoard — UI factory (1:1 with the @almadar/ui debugger-board pattern).",
  "orbitals": [
    {
      "name": "DebuggerBoardOrbital",
      "entity": {
        "name": "DebuggerBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DebuggerBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DebuggerBoardItem",
          "emits": [
            {
              "event": "COMPLETE",
              "description": "completeEvent prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "success",
                  "type": "boolean",
                  "required": true
                },
                {
                  "name": "attempts",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "completeEvent prop",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DebuggerBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity",
                      "completeEvent": "COMPLETE",
                      "type": "debugger-board"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DebuggerBoardPage",
          "path": "/debugger-board",
          "traits": [
            {
              "ref": "DebuggerBoardRender"
            }
          ]
        }
      ]
    }
  ]
}