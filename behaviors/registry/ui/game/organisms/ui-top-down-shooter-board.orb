              "type": "number"
            },
            "projectileSpeed": {
              "default": 24.0,
              "description": "Pixels a projectile travels per tick",
              "label": "Projectile Speed",
              "tier": "presentation",
              "type": "number"
            },
            "scale": {
              "default": 1.0,
              "description": "Canvas render scale",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "scorePerKill": {
              "default": 10.0,
              "description": "Score awarded for each enemy destroyed",
              "label": "Score Per Kill",
              "tier": "presentation",
              "type": "number"
            },
            "spriteSize": {
              "default": 32.0,
              "description": "Pixel draw-size of player/enemy sprites",
              "label": "Sprite Size",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 640.0,
              "description": "Arena / canvas width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{moveEvent} with {dx,dy} on arrow/WASD key press to move the player",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "dx",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "dy",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{fireEvent} with {tx,ty} on space / arena click to fire a projectile",
              "event": "FIRE",
              "payloadSchema": [
                {
                  "name": "tx",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "ty",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "effects",
              "enemies",
              "lives",
              "nextId",
              "player",
              "projectiles",
              "result",
              "score",
              "tick",
              "wave"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TopDownShooterBoardItem",
          "name": "TopDownShooterBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{moveEvent} with {dx,dy} on arrow/WASD key press to move the player",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "dx",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "dy",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{fireEvent} with {tx,ty} on space / arena click to fire a projectile",
                "key": "FIRE",
                "name": "Fire",
                "payloadSchema": [
                  {
                    "name": "tx",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "ty",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "frame": 0.0,
                      "x": [
                        "/",
                        "@config.width",
                        2.0
                      ],
                      "y": [
                        "-",
                        "@config.height",
                        "@config.spriteSize"
                      ]
                    }
                  ],
                  [
                    "set",
                    "@entity.enemies",
                    [
                      "array/map",
                      [
                        "array/range",
                        0.0,
                        "@config.enemiesPerWave"
                      ],
                      [
                        "fn",
                        "i",
                        {
                          "animation": "idle",
                          "frame": 0.0,
                          "hp": "@config.enemyHp",
                          "id": [
                            "str/concat",
                            "enemy-",
                            "@i"
                          ],
                          "x": [
                            "+",
                            "@config.spriteSize",
                            [
                              "*",
                              "@i",
                              [
                                "/",
                                "@config.width",
                                "@config.enemiesPerWave"
                              ]
                            ]
                          ],
                          "y": "@config.spriteSize"
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.projectiles",
                    []
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.wave",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    "@config.lives"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.tick",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.nextId",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": [
                            "array/map",
                            "@entity.projectiles",
                            [
                              "fn",
                              "p",
                              {
                                "id": "@p.id",
                                "sprite": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "features"
                                  ],
                                  "projectile"
                                ],
                                "type": "projectile",
                                "x": [
                                  "object/get",
                                  "@p",
                                  "x"
                                ],
                                "y": [
                                  "object/get",
                                  "@p",
                                  "y"
                                ]
                              }
                            ]
                          ],
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": [],
                          "type": "isometric-canvas",
                          "units": [
                            "array/concat",
                            [
                              {
                                "animation": [
                                  "object/get",
                                  "@entity.player",
                                  "animation"
                                ],
                                "frame": [
                                  "object/get",
                                  "@entity.player",
                                  "frame"
                                ],
                                "id": "player",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@entity.player",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@entity.player",
                                    "y"
                                  ]
                                },
                                "sprite": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "units"
                                  ],
                                  "player"
                                ],
                                "team": "player"
                              }
                            ],
                            [
                              "array/map",
                              "@entity.enemies",
                              [
                                "fn",
                                "e",
                                {
                                  "animation": [
                                    "object/get",
                                    "@e",
                                    "animation"
                                  ],
                                  "frame": [
                                    "object/get",
                                    "@e",
                                    "frame"
                                  ],
                                  "id": "@e.id",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@e",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@e",
                                      "y"
                                    ]
                                  },
                                  "sprite": [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@config.assetManifest",
