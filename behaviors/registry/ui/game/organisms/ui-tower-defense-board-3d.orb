                  "@config.maxWaves"
                ]
              ],
              "interval": 1200.0,
              "name": "enemySpawnTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "let",
                        [
                          [
                            "nextIndex",
                            [
                              "math/min",
                              [
                                "+",
                                "@u.pathIndex",
                                1.0
                              ],
                              [
                                "-",
                                [
                                  "array/len",
                                  "@config.path"
                                ],
                                1.0
                              ]
                            ]
                          ],
                          [
                            "nextWaypoint",
                            [
                              "array/nth",
                              "@config.path",
                              [
                                "math/min",
                                [
                                  "+",
                                  "@u.pathIndex",
                                  1.0
                                ],
                                [
                                  "-",
                                  [
                                    "array/len",
                                    "@config.path"
                                  ],
                                  1.0
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "object/merge",
                          "@u",
                          {
                            "pathIndex": "@nextIndex",
                            "position": {
                              "x": [
                                "object/get",
                                "@nextWaypoint",
                                "x"
                              ],
                              "y": [
                                "object/get",
                                "@nextWaypoint",
                                "y"
                              ]
                            }
                          }
                        ]
