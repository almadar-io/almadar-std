                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.pathIndex",
                            [
                              "-",
                              [
                                "array/len",
                                "@config.path"
                              ],
                              1.0
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "u",
                        {
                          "id": [
                            "str/concat",
                            "fx-leak-",
                            "@u.id"
