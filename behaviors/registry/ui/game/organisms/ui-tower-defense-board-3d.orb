                        "array/len",
                        [
                          "array/filter",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "==",
                              "@u.pathIndex",
                              [
                                "-",
                                [
                                  "array/len",
                                  "@config.path"
                                ],
                                1.0
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.units",
                  [
                    "array/filter",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "<",
                        "@u.pathIndex",
                        [
                          "-",
                          [
                            "array/len",
                            "@config.path"
                          ],
                          1.0
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "<=",
                      "@entity.lives",
                      0.0
                    ],
                    "defeat",
                    "@entity.result"
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "and",
                      [
                        ">=",
                        "@entity.wave",
                        "@config.maxWaves"
