          "linkedEntity": "TowerDefenseBoard3DItem",
          "linkedEntityId": "ent_01KXG0500XZ6PVG81KZNXHKVB4",
          "name": "TowerDefenseBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, z } — builds a tower on a buildable grass cell",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "tileId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when lives reach 0 (defeat) or all waves are cleared with lives left (victory)",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    []
                  ],
                  [
                    "set",
                    "@entity.towers",
                    []
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.gold",
                    "@config.startingGold"
                  ],
                  [
                    "set",
                    "@entity.lives",
                    "@config.startingLives"
                  ],
                  [
                    "set",
                    "@entity.wave",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          14.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              14.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "onPath",
                                    [
                                      ">",
                                      [
                                        "array/len",
                                        [
                                          "array/filter",
                                          "@config.path",
                                          [
                                            "fn",
                                            "p",
                                            [
                                              "and",
                                              [
                                                "==",
                                                "@p.x",
                                                "@gx"
                                              ],
                                              [
                                                "==",
                                                "@p.y",
                                                "@gy"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ],
                                      0.0
                                    ]
                                  ]
                                ],
                                {
                                  "id": [
                                    "str/concat",
                                    "t-",
                                    "@gx",
                                    "-",
                                    "@gy"
                                  ],
                                  "modelUrl": [
                                    "if",
                                    "@onPath",
                                    "@config.pathAsset",
                                    "@config.grassAsset"
                                  ],
                                  "passable": [
                                    "if",
                                    "@onPath",
                                    false,
                                    true
                                  ],
                                  "terrain": [
                                    "if",
                                    "@onPath",
                                    "path",
                                    "grass"
                                  ],
                                  "x": "@gx",
                                  "y": "@gy"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.towerCoverage",
                    []
                  ],
                  [
