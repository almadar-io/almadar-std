                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "title": {
                    "name": "title",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Hand",
              "tier": "presentation",
              "type": "[CardBattlerBoardCard]"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "manaCap": {
              "default": 10.0,
              "description": "Maximum mana the per-turn ramp can reach.",
              "label": "Mana Cap",
              "tier": "presentation",
              "type": "number"
            },
            "maxMana": {
              "default": 3.0,
              "description": "Mana the player starts each match with; also refills each turn.",
              "label": "Starting Mana",
              "tier": "presentation",
              "type": "number"
            },
            "turnsToWin": {
              "default": 8.0,
              "description": "Survive this many turns to win the match.",
              "label": "Turns To Win",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{playCardEvent} with {cardId} when the player plays a card from hand",
              "event": "PLAY_CARD",
              "payloadSchema": [
                {
                  "name": "cardId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{endTurnEvent} with {} when the player ends the turn",
              "event": "END_TURN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{gameEndEvent} with {result} when the match reaches won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "board",
              "deck",
              "hand",
              "mana",
              "maxMana",
              "result",
              "turn"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CardBattlerBoardItem",
          "name": "CardBattlerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{playCardEvent} with {cardId} when the player plays a card from hand",
                "key": "PLAY_CARD",
                "name": "Play Card",
                "payloadSchema": [
                  {
                    "name": "cardId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{endTurnEvent} with {} when the player ends the turn",
                "key": "END_TURN",
                "name": "End Turn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{gameEndEvent} with {result} when the match reaches won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.mana",
                    "@config.maxMana"
                  ],
                  [
                    "set",
                    "@entity.maxMana",
                    "@config.maxMana"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.deck",
                    "@config.deck"
                  ],
                  [
                    "set",
                    "@entity.hand",
                    "@config.hand"
                  ],
                  [
                    "set",
                    "@entity.board",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "board": "@entity.board",
                      "deck": "@entity.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@entity.hand",
                      "mana": "@entity.mana",
                      "maxMana": "@entity.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "result": "@entity.result",
                      "turn": "@entity.turn",
                      "type": "card-battler-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.mana",
                    [
                      "-",
                      "@entity.mana",
                      [
                        "object/get",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@entity.hand",
                            [
                              "fn",
                              "c",
                              [
                                "==",
                                "@c.id",
                                "@payload.cardId"
                              ]
                            ]
                          ]
                        ],
                        "cost"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.board",
                    [
                      "array/concat",
                      "@entity.board",
                      [
                        "array/filter",
                        "@entity.hand",
                        [
                          "fn",
                          "c",
                          [
                            "==",
                            "@c.id",
                            "@payload.cardId"
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.hand",
                    [
                      "array/filter",
                      "@entity.hand",
                      [
                        "fn",
                        "c",
                        [
                          "not",
                          [
                            "==",
                            "@c.id",
                            "@payload.cardId"
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "board": "@entity.board",
                      "deck": "@entity.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@entity.hand",
                      "mana": "@entity.mana",
                      "maxMana": "@entity.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "result": "@entity.result",
                      "turn": "@entity.turn",
                      "type": "card-battler-board"
                    }
                  ]
                ],
                "event": "PLAY_CARD",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    ">",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@entity.hand",
                        [
                          "fn",
                          "c",
                          [
                            "and",
                            [
                              "==",
                              "@c.id",
                              "@payload.cardId"
                            ],
                            [
                              "<=",
                              [
                                "object/get",
                                "@c",
                                "cost"
                              ],
                              "@entity.mana"
                            ]
                          ]
                        ]
                      ]
                    ],
                    0.0
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.turn",
                    [
                      "+",
                      "@entity.turn",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.maxMana",
                    [
                      "math/min",
                      "@config.manaCap",
                      [
                        "+",
                        "@entity.maxMana",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.mana",
                    "@entity.maxMana"
                  ],
                  [
                    "set",
                    "@entity.hand",
                    [
                      "array/concat",
                      "@entity.hand",
                      [
                        "array/slice",
                        "@entity.deck",
                        0.0,
                        "@config.drawPerTurn"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.deck",
                    [
                      "array/slice",
                      "@entity.deck",
                      "@config.drawPerTurn",
                      [
                        "array/len",
                        "@entity.deck"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.turn",
                        "@config.turnsToWin"
                      ],
                      "won",
                      "@entity.result"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "board": "@entity.board",
                      "deck": "@entity.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@entity.hand",
                      "mana": "@entity.mana",
                      "maxMana": "@entity.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "result": "@entity.result",
                      "turn": "@entity.turn",
                      "type": "card-battler-board"
                    }
                  ]
                ],
                "event": "END_TURN",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "board": "@entity.board",
                      "deck": "@entity.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@entity.hand",
                      "mana": "@entity.mana",
                      "maxMana": "@entity.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "result": "@entity.result",
                      "turn": "@entity.turn",
                      "type": "card-battler-board"
                    }
                  ]
                ],
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "or",
                  [
                    "==",
                    "@entity.result",
                    "won"
                  ],
                  [
                    "==",
                    "@entity.result",
                    "lost"
                  ]
                ],
                "to": "gameover"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.mana",
                    "@config.maxMana"
                  ],
                  [
                    "set",
                    "@entity.maxMana",
                    "@config.maxMana"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.deck",
                    "@config.deck"
                  ],
                  [
                    "set",
                    "@entity.hand",
                    "@config.hand"
                  ],
                  [
                    "set",
                    "@entity.board",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "board": "@entity.board",
                      "deck": "@entity.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@entity.hand",
                      "mana": "@entity.mana",
                      "maxMana": "@entity.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "result": "@entity.result",
                      "turn": "@entity.turn",
                      "type": "card-battler-board"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "gameover",
