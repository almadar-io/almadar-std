                  "iconKey": "snake",
                  "id": "c5",
                  "title": "Snake"
                }
              ],
              "description": "Opening hand dealt at INIT; takes priority over entity-derived hand.",
              "items": {
                "properties": {
                  "attack": {
                    "name": "attack",
                    "required": false,
                    "type": "number"
                  },
                  "cost": {
                    "name": "cost",
                    "required": false,
                    "type": "number"
                  },
                  "defense": {
                    "name": "defense",
