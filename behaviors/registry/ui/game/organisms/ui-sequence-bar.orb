{
  "description": "SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern).",
  "name": "ui-sequence-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SequenceBarItem",
        "persistence": "runtime"
      },
      "name": "SequenceBarOrbital",
      "pages": [
        {
          "name": "SequenceBarPage",
          "path": "/sequence-bar",
          "traits": [
            {
              "ref": "SequenceBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "categoryColors": {
              "default": {},
              "description": "Category → color mapping",
              "items": {
                "properties": {
                  "bg": {
                    "name": "bg",
                    "required": true,
                    "type": "string"
                  },
                  "border": {
                    "name": "border",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Category Colors",
              "tier": "presentation",
              "type": "Map<string,SequenceBarCategoryColorsValue>"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentStep": {
              "default": -1.0,
              "description": "Current step index during playback (-1 = not playing)",
              "label": "Current Step",
              "tier": "presentation",
              "type": "number"
            },
            "maxSlots": {
              "default": 0.0,
              "description": "Max number of slots",
              "label": "Max Slots",
              "tier": "presentation",
              "type": "number"
            },
            "playing": {
              "default": false,
              "description": "Whether the sequence is currently playing (disable interaction)",
              "label": "Playing",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "lg",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "slotFeedback": {
              "default": [],
              "description": "Per-slot correctness feedback shown after a failed attempt",
              "items": {
                "type": "string",
                "values": [
                  "correct",
                  "wrong"
                ]
              },
              "label": "Slot Feedback",
              "tier": "presentation",
              "type": "[string]"
            },
            "slots": {
              "default": [
                {
                  "category": "Category",
                  "description": "Description",
                  "iconEmoji": "Icon Emoji",
                  "id": "Id",
                  "name": "Name"
                }
              ],
              "description": "The current sequence (sparse — undefined means empty slot)",
              "items": {
                "properties": {
                  "category": {
                    "name": "category",
                    "required": true,
                    "type": "string"
                  },
                  "description": {
                    "name": "description",
                    "required": false,
                    "type": "string"
                  },
                  "iconEmoji": {
                    "name": "iconEmoji",
                    "required": false,
                    "type": "string"
                  },
                  "iconUrl": {
                    "name": "iconUrl",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "stateMachine": {
                    "name": "stateMachine",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Slots",
              "tier": "presentation",
              "type": "[SequenceBarSlotsItem]"
            }
          },
          "emits": [
            {
              "description": "Called when an item is dropped into slot at index",
              "event": "SLOT_DROP",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                },
                {
                  "name": "item",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "category",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "json"
                    },
                    {
                      "name": "stateMachine",
                      "type": "json"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when a slot is cleared",
              "event": "SLOT_REMOVE",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SequenceBarItem",
          "name": "SequenceBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when an item is dropped into slot at index",
                "key": "SLOT_DROP",
                "name": "Slot Drop",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  },
                  {
                    "name": "item",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "category",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "json"
                      },
                      {
                        "name": "stateMachine",
                        "type": "json"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when a slot is cleared",
                "key": "SLOT_REMOVE",
                "name": "Slot Remove",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "className": "@config.className",
                      "currentStep": "@config.currentStep",
                      "maxSlots": "@config.maxSlots",
                      "onSlotDrop": "SLOT_DROP",
                      "onSlotRemove": "SLOT_REMOVE",
                      "playing": "@config.playing",
                      "size": "@config.size",
                      "slotFeedback": "@config.slotFeedback",
                      "slots": "@config.slots",
                      "type": "sequence-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}