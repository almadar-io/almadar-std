{
  "name": "ui-sequence-bar",
  "version": "1.0.0",
  "description": "SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern).",
  "orbitals": [
    {
      "name": "SequenceBarOrbital",
      "entity": {
        "name": "SequenceBarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SequenceBarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SequenceBarItem",
          "emits": [
            {
              "event": "SLOT_DROP",
              "description": "Called when an item is dropped into slot at index",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                },
                {
                  "name": "item",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "category",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "string"
                    },
                    {
                      "name": "stateMachine",
                      "type": "object",
                      "properties": [
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "states",
                          "type": "[string]",
                          "required": true
                        },
                        {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "transitions",
                          "type": "[object]",
                          "required": true,
                          "properties": [
                            {
                              "name": "from",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "to",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "event",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "guardHint",
                              "type": "string"
                            }
                          ]
                        },
                        {
                          "name": "description",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "event": "SLOT_REMOVE",
              "description": "Called when a slot is cleared",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SLOT_DROP",
                "name": "Slot Drop",
                "description": "Called when an item is dropped into slot at index",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  },
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "category",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "string"
                      },
                      {
                        "name": "stateMachine",
                        "type": "object",
                        "properties": [
                          {
                            "name": "name",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "states",
                            "type": "[string]",
                            "required": true
                          },
                          {
                            "name": "currentState",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "transitions",
                            "type": "[object]",
                            "required": true,
                            "properties": [
                              {
                                "name": "from",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "to",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "event",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "guardHint",
                                "type": "string"
                              }
                            ]
                          },
                          {
                            "name": "description",
                            "type": "string"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "key": "SLOT_REMOVE",
                "name": "Slot Remove",
                "description": "Called when a slot is cleared",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "playing": "@config.playing",
                      "maxSlots": "@config.maxSlots",
                      "slotFeedback": "@config.slotFeedback",
                      "onSlotDrop": "SLOT_DROP",
                      "onSlotRemove": "SLOT_REMOVE",
                      "slots": "@config.slots",
                      "className": "@config.className",
                      "type": "sequence-bar",
                      "size": "@config.size",
                      "categoryColors": "@config.categoryColors",
                      "currentStep": "@config.currentStep"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "lg",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "currentStep": {
              "type": "number",
              "default": -1.0,
              "label": "Current Step",
              "description": "Current step index during playback (-1 = not playing)",
              "tier": "presentation"
            },
            "maxSlots": {
              "type": "number",
              "default": 0.0,
              "label": "Max Slots",
              "description": "Max number of slots",
              "tier": "presentation"
            },
            "categoryColors": {
              "type": "Map<string,SequenceBarCategoryColorsValue>",
              "default": {},
              "label": "Category Colors",
              "description": "Category → color mapping",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "bg": {
                    "name": "bg",
                    "type": "string",
                    "required": true
                  },
                  "border": {
                    "name": "border",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "slots": {
              "type": "[SequenceBarSlotsItem]",
              "default": [
                {
                  "name": "Name",
                  "iconUrl": "Icon Url",
                  "description": "Description",
                  "stateMachine": {
                    "name": "Name",
                    "states": [
                      "Item"
                    ],
                    "transitions": [
                      {
                        "guardHint": "Guard Hint",
                        "from": "From",
                        "to": "To",
                        "event": "Event"
                      }
                    ],
                    "description": "Description",
                    "currentState": "Current State"
                  },
                  "id": "Id",
                  "iconEmoji": "Icon Emoji",
                  "category": "Category"
                }
              ],
              "label": "Slots",
              "description": "The current sequence (sparse — undefined means empty slot)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "category": {
                    "name": "category",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "iconUrl": {
                    "name": "iconUrl",
                    "type": "string",
                    "required": false
                  },
                  "iconEmoji": {
                    "name": "iconEmoji",
                    "type": "string",
                    "required": false
                  },
                  "stateMachine": {
                    "name": "stateMachine",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "states": {
                        "name": "states",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "string"
                        }
                      },
                      "transitions": {
                        "name": "transitions",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "object",
                          "properties": {
                            "guardHint": {
                              "name": "guardHint",
                              "type": "string",
                              "required": false
                            },
                            "to": {
                              "name": "to",
                              "type": "string",
                              "required": true
                            },
                            "from": {
                              "name": "from",
                              "type": "string",
                              "required": true
                            },
                            "event": {
                              "name": "event",
                              "type": "string",
                              "required": true
                            }
                          }
                        }
                      },
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      "currentState": {
                        "name": "currentState",
                        "type": "string",
                        "required": true
                      },
                      "description": {
                        "name": "description",
                        "type": "string",
                        "required": false
                      }
                    }
                  }
                }
              }
            },
            "slotFeedback": {
              "type": "[string]",
              "default": [],
              "label": "Slot Feedback",
              "description": "Per-slot correctness feedback shown after a failed attempt",
              "tier": "presentation",
              "items": {
                "type": "string",
                "values": [
                  "correct",
                  "wrong"
                ]
              }
            },
            "playing": {
              "type": "boolean",
              "default": false,
              "label": "Playing",
              "description": "Whether the sequence is currently playing (disable interaction)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SequenceBarPage",
          "path": "/sequence-bar",
          "traits": [
            {
              "ref": "SequenceBarRender"
            }
          ]
        }
      ]
    }
  ]
}