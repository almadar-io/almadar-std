{
  "name": "ui-castle-board",
  "version": "1.0.0",
  "description": "CastleBoard — UI factory (1:1 with the @almadar/ui castle-board pattern).",
  "orbitals": [
    {
      "name": "CastleBoardOrbital",
      "entity": {
        "name": "CastleBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CastleBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CastleBoardItem",
          "emits": [
            {
              "event": "FEATURE_CLICK",
              "description": "-- Callback overrides --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "feature",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "x",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "y",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "z",
                      "type": "number"
                    },
                    {
                      "name": "type",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "sprite",
                      "type": "string"
                    },
                    {
                      "name": "assetUrl",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "elevation",
                      "type": "number"
                    }
                  ]
                },
                {
                  "name": "featureId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "featureType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "UNIT_CLICK",
              "description": "Called when a unit is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unit",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "position",
                      "type": "object",
                      "properties": [
                        {
                          "name": "x",
                          "type": "number",
                          "required": true
                        },
                        {
                          "name": "y",
                          "type": "number",
                          "required": true
                        }
                      ]
                    },
                    {
                      "name": "x",
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "type": "number"
                    },
                    {
                      "name": "z",
                      "type": "number"
                    },
                    {
                      "name": "sprite",
                      "type": "string"
                    },
                    {
                      "name": "unitType",
                      "type": "string"
                    },
                    {
                      "name": "heroId",
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "team",
                      "type": "string"
                    },
                    {
                      "name": "faction",
                      "type": "string"
                    },
                    {
                      "name": "health",
                      "type": "number"
                    },
                    {
                      "name": "maxHealth",
                      "type": "number"
                    },
                    {
                      "name": "traits",
                      "type": "[object]",
                      "properties": [
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "states",
                          "type": "[string]",
                          "required": true
                        },
                        {
                          "name": "cooldown",
                          "type": "number",
                          "required": true
                        }
                      ]
                    },
                    {
                      "name": "previousPosition",
                      "type": "object",
                      "properties": [
                        {
                          "name": "x",
                          "type": "number",
                          "required": true
                        },
                        {
                          "name": "y",
                          "type": "number",
                          "required": true
                        }
                      ]
                    },
                    {
                      "name": "elevation",
                      "type": "number"
                    }
                  ]
                },
                {
                  "name": "unitId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TILE_CLICK",
              "description": "Called when any tile is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FEATURE_CLICK",
                "name": "Feature Click",
                "description": "-- Callback overrides --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "feature",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "y",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "z",
                        "type": "number"
                      },
                      {
                        "name": "type",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "sprite",
                        "type": "string"
                      },
                      {
                        "name": "assetUrl",
                        "type": "string"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "elevation",
                        "type": "number"
                      }
                    ]
                  },
                  {
                    "name": "featureId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "featureType",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "description": "Called when a unit is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unit",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "position",
                        "type": "object",
                        "properties": [
                          {
                            "name": "x",
                            "type": "number",
                            "required": true
                          },
                          {
                            "name": "y",
                            "type": "number",
                            "required": true
                          }
                        ]
                      },
                      {
                        "name": "x",
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "type": "number"
                      },
                      {
                        "name": "z",
                        "type": "number"
                      },
                      {
                        "name": "sprite",
                        "type": "string"
                      },
                      {
                        "name": "unitType",
                        "type": "string"
                      },
                      {
                        "name": "heroId",
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "team",
                        "type": "string"
                      },
                      {
                        "name": "faction",
                        "type": "string"
                      },
                      {
                        "name": "health",
                        "type": "number"
                      },
                      {
                        "name": "maxHealth",
                        "type": "number"
                      },
                      {
                        "name": "traits",
                        "type": "[object]",
                        "properties": [
                          {
                            "name": "name",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "currentState",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "states",
                            "type": "[string]",
                            "required": true
                          },
                          {
                            "name": "cooldown",
                            "type": "number",
                            "required": true
                          }
                        ]
                      },
                      {
                        "name": "previousPosition",
                        "type": "object",
                        "properties": [
                          {
                            "name": "x",
                            "type": "number",
                            "required": true
                          },
                          {
                            "name": "y",
                            "type": "number",
                            "required": true
                          }
                        ]
                      },
                      {
                        "name": "elevation",
                        "type": "number"
                      }
                    ]
                  },
                  {
                    "name": "unitId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "Called when any tile is clicked",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CastleBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onTileClick": "TILE_CLICK",
                      "entity": "@entity",
                      "scale": "@config.scale",
                      "featureClickEvent": "FEATURE_CLICK",
                      "onFeatureClick": "FEATURE_CLICK",
                      "tileClickEvent": "TILE_CLICK",
                      "type": "castle-board",
                      "unitClickEvent": "UNIT_CLICK",
                      "className": "@config.className",
                      "onUnitClick": "UNIT_CLICK"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "scale": {
              "type": "number",
              "default": 0.45,
              "label": "Scale",
              "description": "Canvas render scale",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CastleBoardPage",
          "path": "/castle-board",
          "traits": [
            {
              "ref": "CastleBoardRender"
            }
          ]
        }
      ]
    }
  ]
}