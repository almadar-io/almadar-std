{
  "name": "ui-castle-board",
  "version": "1.0.0",
  "description": "CastleBoard — UI factory (1:1 with the @almadar/ui castle-board pattern).",
  "orbitals": [
    {
      "name": "CastleBoardOrbital",
      "entity": {
        "name": "CastleBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CastleBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CastleBoardItem",
          "emits": [
            {
              "event": "FEATURE_CLICK",
              "description": "-- Callback overrides --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "feature",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "x",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "y",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "z",
                      "type": "number"
                    },
                    {
                      "name": "type",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "sprite",
                      "type": "string"
                    },
                    {
                      "name": "assetUrl",
                      "type": "string"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "elevation",
                      "type": "number"
                    }
                  ]
                },
                {
                  "name": "featureId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "featureType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "UNIT_CLICK",
              "description": "Called when a unit is clicked",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unit",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "position",
                      "type": "object",
