                            "name": "x",
                            "type": "number",
                            "required": true
                          },
                          "y": {
                            "name": "y",
                            "type": "number",
                            "required": true
                          }
                        }
                      },
                      "faction": {
                        "name": "faction",
                        "type": "string",
                        "required": false,
                        "values": [
