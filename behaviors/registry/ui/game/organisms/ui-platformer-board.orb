{
  "description": "PlatformerBoard — gameflow layer (lives/score/win-lose) over PlatformerCanvas; canvas owns physics.",
  "name": "ui-platformer-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "level",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "score",
            "type": "number"
          },
          {
            "default": 3.0,
            "name": "lives",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "won",
              "lost"
            ]
          },
          {
            "default": {
              "facingRight": true,
              "grounded": false,
              "height": 48.0,
              "vx": 0.0,
              "vy": 0.0,
              "width": 32.0,
              "x": 80.0,
              "y": 320.0
            },
            "name": "player",
            "properties": {
              "facingRight": {
                "name": "facingRight",
                "required": false,
                "type": "boolean"
              },
              "grounded": {
                "name": "grounded",
                "required": false,
                "type": "boolean"
              },
              "height": {
                "name": "height",
                "required": false,
                "type": "number"
              },
              "vx": {
                "name": "vx",
                "required": false,
                "type": "number"
              },
              "vy": {
                "name": "vy",
                "required": false,
                "type": "number"
              },
              "width": {
                "name": "width",
                "required": false,
                "type": "number"
              },
              "x": {
                "name": "x",
                "required": true,
                "type": "number"
              },
              "y": {
                "name": "y",
                "required": true,
                "type": "number"
              }
            },
            "type": "object"
          },
          {
            "default": 720.0,
            "name": "goalX",
            "type": "number"
          },
          {
            "default": 800.0,
            "name": "worldWidth",
            "type": "number"
          },
          {
            "default": 400.0,
            "name": "worldHeight",
            "type": "number"
          }
        ],
        "name": "PlatformerBoardItem",
        "persistence": "runtime"
      },
      "name": "PlatformerBoardOrbital",
      "pages": [
        {
          "name": "PlatformerBoardPage",
          "path": "/platformer-board",
          "traits": [
            {
              "ref": "PlatformerBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "bgColor": {
              "default": "#5c94fc",
              "description": "Canvas background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "Canvas display height",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display width",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "goalX": {
              "default": 720.0,
              "description": "X pixel of the goal tile (used for display)",
              "label": "Goal X",
              "tier": "presentation",
              "type": "number"
            },
            "gravity": {
              "default": 0.6,
              "description": "vy delta per 33ms tick",
              "label": "Gravity",
              "tier": "presentation",
              "type": "number"
            },
            "jumpStrength": {
              "default": 12.0,
              "description": "vy set to -(jumpStrength) on JUMP",
              "label": "Jump Strength",
              "tier": "presentation",
              "type": "number"
            },
            "maxFallSpeed": {
              "default": 20.0,
              "description": "Terminal velocity cap",
              "label": "Max Fall Speed",
              "tier": "presentation",
              "type": "number"
            },
            "moveSpeed": {
              "default": 4.0,
              "description": "Horizontal vx magnitude",
              "label": "Move Speed",
              "tier": "presentation",
              "type": "number"
            },
            "platforms": {
              "default": [
                {
                  "height": 32.0,
                  "type": "ground",
                  "width": 800.0,
                  "x": 0.0,
                  "y": 368.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 150.0,
                  "y": 280.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "height": 16.0,
                  "type": "hazard",
                  "width": 80.0,
                  "x": 580.0,
                  "y": 300.0
                },
                {
                  "height": 28.0,
                  "type": "goal",
                  "width": 64.0,
                  "x": 700.0,
                  "y": 340.0
                }
              ],
              "description": "Level geometry including hazard and goal tiles",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerBoardPlatformsItem]"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kenney-vendored/toon/platformChar_idle.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": {
                "goal": "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kenney-vendored/flat/platformer/platformPack_tile058.png",
                "ground": "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kenney-vendored/flat/platformer/platformPack_tile029.png",
                "hazard": "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kenney-vendored/flat/platformer/platformPack_tile063.png",
                "platform": "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kenney-vendored/flat/platformer/platformPack_tile046.png"
              },
              "description": "Map of platform type to tile sprite URL",
              "items": {
                "type": "string"
              },
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "Map<string,asset>"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "World pixel height",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World pixel width",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emitted when result becomes won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Left arrow / A key pressed",
              "event": "LEFT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Right arrow / D key pressed",
              "event": "RIGHT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Up / Space pressed",
              "event": "JUMP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Horizontal key released",
              "event": "STOP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{playAgainEvent} on restart",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "goalX",
              "level",
              "lives",
              "player",
              "result",
              "score",
              "worldHeight",
              "worldWidth"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerBoardItem",
          "name": "PlatformerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Left arrow / A key pressed",
                "key": "LEFT",
                "name": "Left",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Right arrow / D key pressed",
                "key": "RIGHT",
                "name": "Right",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Up / Space pressed",
                "key": "JUMP",
                "name": "Jump",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Horizontal key released",
                "key": "STOP",
                "name": "Stop",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emitted when result becomes won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} on restart",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "won"
              },
              {
                "name": "lost"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "facingRight": true,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "set",
                    "@entity.goalX",
                    "@config.goalX"
                  ],
                  [
                    "set",
                    "@entity.worldWidth",
                    "@config.worldWidth"
                  ],
                  [
                    "set",
                    "@entity.worldHeight",
                    "@config.worldHeight"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "goalX": "@entity.goalX",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "level": "@entity.level",
                      "lives": "@entity.lives",
                      "platforms": "@config.platforms",
                      "playAgainEvent": "PLAY_AGAIN",
                      "player": "@entity.player",
                      "playerSprite": "@config.playerSprite",
                      "result": "@entity.result",
                      "rightEvent": "RIGHT",
                      "score": "@entity.score",
                      "stopEvent": "STOP",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-board",
                      "worldHeight": "@entity.worldHeight",
                      "worldWidth": "@entity.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "facingRight": false,
                        "vx": [
                          "-",
                          0.0,
                          "@config.moveSpeed"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "LEFT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "facingRight": true,
                        "vx": "@config.moveSpeed"
                      }
                    ]
                  ]
                ],
                "event": "RIGHT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "grounded": false,
                        "vy": [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "JUMP",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    "@entity.player.grounded",
                    true
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "vx": 0.0
                      }
                    ]
                  ]
                ],
                "event": "STOP",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "won"
                ],
                "to": "won"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "lost"
                ],
                "to": "lost"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    [
                      "+",
                      "@entity.level",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "facingRight": true,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "goalX": "@entity.goalX",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "level": "@entity.level",
                      "lives": "@entity.lives",
                      "platforms": "@config.platforms",
                      "playAgainEvent": "PLAY_AGAIN",
                      "player": "@entity.player",
                      "playerSprite": "@config.playerSprite",
                      "result": "@entity.result",
                      "rightEvent": "RIGHT",
                      "score": "@entity.score",
                      "stopEvent": "STOP",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-board",
                      "worldHeight": "@entity.worldHeight",
                      "worldWidth": "@entity.worldWidth"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "won",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "facingRight": true,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "goalX": "@entity.goalX",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "level": "@entity.level",
                      "lives": "@entity.lives",
                      "platforms": "@config.platforms",
                      "playAgainEvent": "PLAY_AGAIN",
                      "player": "@entity.player",
                      "playerSprite": "@config.playerSprite",
                      "result": "@entity.result",
                      "rightEvent": "RIGHT",
                      "score": "@entity.score",
                      "stopEvent": "STOP",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-board",
                      "worldHeight": "@entity.worldHeight",
                      "worldWidth": "@entity.worldWidth"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "lost",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "vy1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.vy",
                          "@config.gravity"
                        ],
                        [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ],
                        "@config.maxFallSpeed"
                      ]
                    ],
                    [
                      "px1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.x",
                          "@entity.player.vx"
                        ],
                        0.0,
                        [
                          "-",
                          "@entity.worldWidth",
                          "@entity.player.width"
                        ]
                      ]
                    ],
                    [
                      "py1",
                      [
                        "+",
                        "@entity.player.y",
                        "@vy1"
                      ]
                    ],
                    [
                      "pw",
                      "@entity.player.width"
                    ],
                    [
                      "ph",
                      "@entity.player.height"
                    ],
                    [
                      "playerRect",
                      {
                        "h": "@ph",
                        "w": "@pw",
                        "x": "@px1",
                        "y": "@py1"
                      }
                    ],
                    [
                      "hit",
                      [
                        "array/find",
                        "@config.platforms",
                        [
                          "fn",
                          "p",
                          [
                            "and",
                            [
                              "!=",
                              [
                                "object/get",
                                "@p",
                                "type"
                              ],
                              "goal"
                            ],
                            [
                              "geo/aabb-overlap",
                              "@playerRect",
                              {
                                "h": "@p.height",
                                "w": "@p.width",
                                "x": "@p.x",
                                "y": "@p.y"
                              }
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "hitY",
                      [
                        "object/get",
                        "@hit",
                        "y",
                        "@entity.worldHeight"
                      ]
                    ],
                    [
                      "landed",
                      [
                        "and",
                        [
                          "!=",
                          "@hit",
                          null
                        ],
                        [
                          ">",
                          "@vy1",
                          0.0
                        ]
                      ]
                    ],
                    [
                      "py2",
                      [
                        "if",
                        "@landed",
                        [
                          "-",
                          "@hitY",
                          "@ph"
                        ],
                        "@py1"
                      ]
                    ],
                    [
                      "vy2",
                      [
                        "if",
                        "@landed",
                        0.0,
                        "@vy1"
                      ]
                    ],
                    [
                      "atGround",
                      [
                        ">=",
                        [
                          "+",
                          "@py2",
                          "@ph"
                        ],
                        "@entity.worldHeight"
                      ]
                    ],
                    [
                      "py3",
                      [
                        "if",
                        "@atGround",
                        [
                          "-",
                          "@entity.worldHeight",
                          "@ph"
                        ],
                        "@py2"
                      ]
                    ],
                    [
                      "vy3",
                      [
                        "if",
                        "@atGround",
                        0.0,
                        "@vy2"
                      ]
                    ],
                    [
                      "grounded",
                      [
                        "or",
                        "@landed",
                        "@atGround"
                      ]
                    ],
                    [
                      "hazardHit",
                      [
                        "array/find",
                        "@config.platforms",
                        [
                          "fn",
                          "p",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@p",
                                "type"
                              ],
                              "hazard"
                            ],
                            [
                              "geo/aabb-overlap",
                              "@playerRect",
                              {
                                "h": "@p.height",
                                "w": "@p.width",
                                "x": "@p.x",
                                "y": "@p.y"
                              }
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "goalHit",
                      [
                        "array/find",
                        "@config.platforms",
                        [
                          "fn",
                          "p",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@p",
                                "type"
                              ],
                              "goal"
                            ],
                            [
                              "geo/aabb-overlap",
                              "@playerRect",
                              {
                                "h": "@p.height",
                                "w": "@p.width",
                                "x": "@p.x",
                                "y": "@p.y"
                              }
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "fell",
                      [
                        ">",
                        "@py3",
                        "@entity.worldHeight"
                      ]
                    ],
                    [
                      "damaged",
                      [
                        "or",
                        [
                          "!=",
                          "@hazardHit",
                          null
                        ],
                        "@fell"
                      ]
                    ],
                    [
                      "livesLeft",
                      [
                        "-",
                        "@entity.lives",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "do",
                    [
                      "set",
                      "@entity.player",
                      [
                        "object/merge",
                        "@entity.player",
                        {
                          "grounded": "@grounded",
                          "vy": "@vy3",
                          "x": "@px1",
                          "y": "@py3"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.result",
                      [
                        "if",
                        [
                          "!=",
                          "@goalHit",
                          null
                        ],
                        "won",
                        [
                          "if",
                          [
                            "and",
                            "@damaged",
                            [
                              "<=",
                              "@livesLeft",
                              0.0
                            ]
                          ],
                          "lost",
                          "none"
                        ]
                      ]
                    ],
                    [
                      "set",
                      "@entity.score",
                      [
                        "if",
                        [
                          "!=",
                          "@goalHit",
                          null
                        ],
                        [
                          "+",
                          "@entity.score",
                          100.0
                        ],
                        "@entity.score"
                      ]
                    ],
                    [
                      "set",
                      "@entity.lives",
                      [
                        "if",
                        [
                          "and",
                          "@damaged",
                          [
                            ">",
                            "@entity.lives",
                            0.0
                          ],
                          [
                            "==",
                            "@entity.result",
                            "none"
                          ]
                        ],
                        "@livesLeft",
                        "@entity.lives"
                      ]
                    ],
                    [
                      "set",
                      "@entity.player",
                      [
                        "if",
                        [
                          "and",
                          "@damaged",
                          [
                            "==",
                            "@entity.result",
                            "none"
                          ]
                        ],
                        {
                          "facingRight": true,
                          "grounded": false,
                          "height": 48.0,
                          "vx": 0.0,
                          "vy": 0.0,
                          "width": 32.0,
                          "x": 80.0,
                          "y": 320.0
                        },
                        "@entity.player"
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "bgColor": "@config.bgColor",
                        "canvasHeight": "@config.canvasHeight",
                        "canvasWidth": "@config.canvasWidth",
                        "entity": "@entity",
                        "gameEndEvent": "GAME_END",
                        "goalX": "@entity.goalX",
                        "jumpEvent": "JUMP",
                        "leftEvent": "LEFT",
                        "level": "@entity.level",
                        "lives": "@entity.lives",
                        "platforms": "@config.platforms",
                        "playAgainEvent": "PLAY_AGAIN",
                        "player": "@entity.player",
                        "playerSprite": "@config.playerSprite",
                        "result": "@entity.result",
                        "rightEvent": "RIGHT",
                        "score": "@entity.score",
                        "stopEvent": "STOP",
                        "tileSprites": "@config.tileSprites",
                        "type": "platformer-board",
                        "worldHeight": "@entity.worldHeight",
                        "worldWidth": "@entity.worldWidth"
                      }
                    ]
                  ]
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 33.0,
              "name": "gameflowTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}