{
  "description": "PlatformerBoard — game-shell composition with HUD (Score/Lives) over platformer-canvas; animTick advances frame and ages effects.",
  "name": "ui-platformer-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "level",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "score",
            "type": "number"
          },
          {
            "default": 3.0,
            "name": "lives",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "won",
              "lost"
            ]
          },
          {
            "default": {
              "animation": "idle",
              "facingRight": true,
              "frame": 0.0,
              "grounded": false,
              "height": 48.0,
              "vx": 0.0,
              "vy": 0.0,
              "width": 32.0,
              "x": 80.0,
              "y": 320.0
            },
            "name": "player",
            "properties": {
              "animation": {
                "name": "animation",
                "required": false,
                "type": "string"
              },
              "facingRight": {
                "name": "facingRight",
                "required": false,
                "type": "boolean"
              },
              "frame": {
                "name": "frame",
                "required": false,
                "type": "number"
              },
              "grounded": {
                "name": "grounded",
                "required": false,
                "type": "boolean"
              },
              "height": {
                "name": "height",
                "required": false,
                "type": "number"
              },
              "vx": {
                "name": "vx",
                "required": false,
                "type": "number"
              },
              "vy": {
                "name": "vy",
                "required": false,
                "type": "number"
              },
              "width": {
                "name": "width",
                "required": false,
                "type": "number"
              },
              "x": {
                "name": "x",
                "required": true,
                "type": "number"
              },
              "y": {
                "name": "y",
                "required": true,
                "type": "number"
              }
            },
            "type": "object"
          },
          {
            "default": 720.0,
            "name": "goalX",
            "type": "number"
          },
          {
            "default": 800.0,
            "name": "worldWidth",
            "type": "number"
          },
          {
            "default": 400.0,
            "name": "worldHeight",
            "type": "number"
          },
          {
            "default": [],
            "items": {
              "properties": {
                "key": {
                  "name": "key",
                  "required": true,
                  "type": "string"
                },
                "ttl": {
                  "name": "ttl",
                  "required": true,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "effects",
            "type": "array"
          }
        ],
        "name": "PlatformerBoardItem",
        "persistence": "runtime"
      },
      "name": "PlatformerBoardOrbital",
      "pages": [
        {
          "name": "PlatformerBoardPage",
          "path": "/platformer-board",
          "traits": [
            {
              "ref": "PlatformerBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetBaseUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "description": "Base URL prefix for asset URLs",
              "label": "Asset Base Url",
              "tier": "presentation",
              "type": "asset"
            },
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/terrain/ground.png",
              "description": "Background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "bgColor": {
              "default": "#5c94fc",
              "description": "Canvas background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "Canvas display height",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display width",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "followCamera": {
              "default": true,
              "description": "Camera follows player horizontally",
              "label": "Follow Camera",
              "tier": "presentation",
              "type": "boolean"
            },
            "goalX": {
              "default": 720.0,
              "description": "X pixel of the goal tile (used for display)",
              "label": "Goal X",
              "tier": "presentation",
              "type": "number"
            },
            "gravity": {
              "default": 0.6,
              "description": "vy delta per 33ms tick",
              "label": "Gravity",
              "tier": "presentation",
              "type": "number"
            },
            "jumpStrength": {
              "default": 12.0,
              "description": "vy set to -(jumpStrength) on JUMP",
              "label": "Jump Strength",
              "tier": "presentation",
              "type": "number"
            },
            "maxFallSpeed": {
              "default": 20.0,
              "description": "Terminal velocity cap",
              "label": "Max Fall Speed",
              "tier": "presentation",
              "type": "number"
            },
            "moveSpeed": {
              "default": 4.0,
              "description": "Horizontal vx magnitude",
              "label": "Move Speed",
              "tier": "presentation",
              "type": "number"
            },
            "platforms": {
              "default": [
                {
                  "height": 32.0,
                  "type": "ground",
                  "width": 800.0,
                  "x": 0.0,
                  "y": 368.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 150.0,
                  "y": 280.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "height": 16.0,
                  "type": "hazard",
                  "width": 80.0,
                  "x": 580.0,
                  "y": 300.0
                },
                {
                  "height": 28.0,
                  "type": "goal",
                  "width": 64.0,
                  "x": 700.0,
                  "y": 340.0
                }
              ],
              "description": "Level geometry including hazard and goal tiles",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerBoardPlatformsItem]"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/units/player.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": {
                "goal": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/terrain/goal.png",
                "ground": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/terrain/ground.png",
                "hazard": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/terrain/hazard.png",
                "platform": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/terrain/platform.png"
              },
              "description": "Map of platform type to tile sprite URL",
              "items": {
                "type": "string"
              },
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "Map<string,asset>"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "World pixel height",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World pixel width",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emitted when result becomes won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Left arrow / A key pressed",
              "event": "LEFT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Right arrow / D key pressed",
              "event": "RIGHT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Up / Space pressed",
              "event": "JUMP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Horizontal key released",
              "event": "STOP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{playAgainEvent} on restart",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "effects",
              "goalX",
              "level",
              "lives",
              "player",
              "result",
              "score",
              "worldHeight",
              "worldWidth"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerBoardItem",
          "name": "PlatformerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Left arrow / A key pressed",
                "key": "LEFT",
                "name": "Left",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Right arrow / D key pressed",
                "key": "RIGHT",
                "name": "Right",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Up / Space pressed",
                "key": "JUMP",
                "name": "Jump",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Horizontal key released",
                "key": "STOP",
                "name": "Stop",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emitted when result becomes won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} on restart",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "won"
              },
              {
                "name": "lost"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "set",
                    "@entity.goalX",
                    "@config.goalX"
                  ],
                  [
                    "set",
                    "@entity.worldWidth",
                    "@config.worldWidth"
                  ],
                  [
                    "set",
                    "@entity.worldHeight",
                    "@config.worldHeight"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetBaseUrl": "@config.assetBaseUrl",
                          "backgroundImage": "@config.backgroundImage",
                          "bgColor": "@config.bgColor",
                          "canvasHeight": "@config.canvasHeight",
                          "canvasWidth": "@config.canvasWidth",
                          "followCamera": "@config.followCamera",
                          "platforms": "@config.platforms",
                          "player": "@entity.player",
                          "playerSprite": "@config.playerSprite",
                          "tileSprites": "@config.tileSprites",
                          "type": "platformer-canvas",
                          "worldHeight": "@entity.worldHeight",
                          "worldWidth": "@entity.worldWidth"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Lives",
                            "value": "@entity.lives"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "facingRight": false,
                        "vx": [
                          "-",
                          0.0,
                          "@config.moveSpeed"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "LEFT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "facingRight": true,
                        "vx": "@config.moveSpeed"
                      }
                    ]
                  ]
                ],
                "event": "RIGHT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "jump",
                        "grounded": false,
                        "vy": [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "JUMP",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    "@entity.player.grounded",
                    true
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "idle",
                        "vx": 0.0
                      }
                    ]
                  ]
                ],
                "event": "STOP",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "won"
                ],
                "to": "won"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "lost"
                ],
                "to": "lost"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    [
                      "+",
                      "@entity.level",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetBaseUrl": "@config.assetBaseUrl",
                          "backgroundImage": "@config.backgroundImage",
                          "bgColor": "@config.bgColor",
                          "canvasHeight": "@config.canvasHeight",
                          "canvasWidth": "@config.canvasWidth",
                          "followCamera": "@config.followCamera",
                          "platforms": "@config.platforms",
                          "player": "@entity.player",
                          "playerSprite": "@config.playerSprite",
                          "tileSprites": "@config.tileSprites",
                          "type": "platformer-canvas",
                          "worldHeight": "@entity.worldHeight",
                          "worldWidth": "@entity.worldWidth"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Lives",
                            "value": "@entity.lives"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "won",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetBaseUrl": "@config.assetBaseUrl",
                          "backgroundImage": "@config.backgroundImage",
                          "bgColor": "@config.bgColor",
                          "canvasHeight": "@config.canvasHeight",
                          "canvasWidth": "@config.canvasWidth",
                          "followCamera": "@config.followCamera",
                          "platforms": "@config.platforms",
                          "player": "@entity.player",
                          "playerSprite": "@config.playerSprite",
                          "tileSprites": "@config.tileSprites",
                          "type": "platformer-canvas",
                          "worldHeight": "@entity.worldHeight",
                          "worldWidth": "@entity.worldWidth"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Lives",
                            "value": "@entity.lives"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "lost",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.player",
                  [
                    "object/merge",
                    "@entity.player",
                    {
                      "frame": [
                        "%",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "frame"
                          ],
                          1.0
                        ],
                        8.0
                      ]
                    }
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetBaseUrl": "@config.assetBaseUrl",
                        "backgroundImage": "@config.backgroundImage",
                        "bgColor": "@config.bgColor",
                        "canvasHeight": "@config.canvasHeight",
                        "canvasWidth": "@config.canvasWidth",
                        "followCamera": "@config.followCamera",
                        "platforms": "@config.platforms",
                        "player": "@entity.player",
                        "playerSprite": "@config.playerSprite",
                        "tileSprites": "@config.tileSprites",
                        "type": "platformer-canvas",
                        "worldHeight": "@entity.worldHeight",
                        "worldWidth": "@entity.worldWidth"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "label": "Lives",
                          "value": "@entity.lives"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            },
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "vy1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.vy",
                          "@config.gravity"
                        ],
                        [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ],
                        "@config.maxFallSpeed"
                      ]
                    ],
                    [
                      "px1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.x",
                          "@entity.player.vx"
                        ],
                        0.0,
                        [
                          "-",
                          "@entity.worldWidth",
                          "@entity.player.width"
                        ]
                      ]
                    ],
                    [
                      "pw",
                      "@entity.player.width"
                    ],
                    [
                      "ph",
                      "@entity.player.height"
                    ],
                    [
                      "livesLeft",
                      [
                        "-",
                        "@entity.lives",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "py1",
                        [
                          "+",
                          "@entity.player.y",
                          "@vy1"
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "playerRect",
                          {
                            "h": "@ph",
                            "w": "@pw",
                            "x": "@px1",
                            "y": "@py1"
                          }
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "hit",
                            [
                              "array/find",
                              "@config.platforms",
                              [
                                "fn",
                                "p",
                                [
                                  "and",
                                  [
                                    "!=",
                                    [
                                      "object/get",
                                      "@p",
                                      "type"
                                    ],
                                    "goal"
                                  ],
                                  [
                                    "geo/aabb-overlap",
                                    "@playerRect",
                                    {
                                      "h": "@p.height",
                                      "w": "@p.width",
                                      "x": "@p.x",
                                      "y": "@p.y"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "hazardHit",
                              [
                                "array/find",
                                "@config.platforms",
                                [
                                  "fn",
                                  "p",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@p",
                                        "type"
                                      ],
                                      "hazard"
                                    ],
                                    [
                                      "geo/aabb-overlap",
                                      "@playerRect",
                                      {
                                        "h": "@p.height",
                                        "w": "@p.width",
                                        "x": "@p.x",
                                        "y": "@p.y"
                                      }
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "goalHit",
                                [
                                  "array/find",
                                  "@config.platforms",
                                  [
                                    "fn",
                                    "p",
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@p",
                                          "type"
                                        ],
                                        "goal"
                                      ],
                                      [
                                        "geo/aabb-overlap",
                                        "@playerRect",
                                        {
                                          "h": "@p.height",
                                          "w": "@p.width",
                                          "x": "@p.x",
                                          "y": "@p.y"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "hitY",
                                  [
                                    "object/get",
                                    "@hit",
                                    "y",
                                    "@entity.worldHeight"
                                  ]
                                ],
                                [
                                  "landed",
                                  [
                                    "and",
                                    [
                                      "!=",
                                      "@hit",
                                      null
                                    ],
                                    [
                                      ">",
                                      "@vy1",
                                      0.0
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "py2",
                                    [
                                      "if",
                                      "@landed",
                                      [
                                        "-",
                                        "@hitY",
                                        "@ph"
                                      ],
                                      "@py1"
                                    ]
                                  ],
                                  [
                                    "vy2",
                                    [
                                      "if",
                                      "@landed",
                                      0.0,
                                      "@vy1"
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "atGround",
                                      [
                                        ">=",
                                        [
                                          "+",
                                          "@py2",
                                          "@ph"
                                        ],
                                        "@entity.worldHeight"
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "py3",
                                        [
                                          "if",
                                          "@atGround",
                                          [
                                            "-",
                                            "@entity.worldHeight",
                                            "@ph"
                                          ],
                                          "@py2"
                                        ]
                                      ],
                                      [
                                        "vy3",
                                        [
                                          "if",
                                          "@atGround",
                                          0.0,
                                          "@vy2"
                                        ]
                                      ],
                                      [
                                        "grounded",
                                        [
                                          "or",
                                          "@landed",
                                          "@atGround"
                                        ]
                                      ]
                                    ],
                                    [
                                      "let",
                                      [
                                        [
                                          "fell",
                                          [
                                            ">",
                                            "@py3",
                                            "@entity.worldHeight"
                                          ]
                                        ]
                                      ],
                                      [
                                        "let",
                                        [
                                          [
                                            "damaged",
                                            [
                                              "or",
                                              [
                                                "!=",
                                                "@hazardHit",
                                                null
                                              ],
                                              "@fell"
                                            ]
                                          ]
                                        ],
                                        [
                                          "do",
                                          [
                                            "set",
                                            "@entity.player",
                                            [
                                              "object/merge",
                                              "@entity.player",
                                              {
                                                "grounded": "@grounded",
                                                "vy": "@vy3",
                                                "x": "@px1",
                                                "y": "@py3"
                                              }
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.result",
                                            [
                                              "if",
                                              [
                                                "!=",
                                                "@goalHit",
                                                null
                                              ],
                                              "won",
                                              [
                                                "if",
                                                [
                                                  "and",
                                                  "@damaged",
                                                  [
                                                    "<=",
                                                    "@livesLeft",
                                                    0.0
                                                  ]
                                                ],
                                                "lost",
                                                "none"
                                              ]
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.score",
                                            [
                                              "if",
                                              [
                                                "!=",
                                                "@goalHit",
                                                null
                                              ],
                                              [
                                                "+",
                                                "@entity.score",
                                                100.0
                                              ],
                                              "@entity.score"
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.lives",
                                            [
                                              "if",
                                              [
                                                "and",
                                                "@damaged",
                                                [
                                                  ">",
                                                  "@entity.lives",
                                                  0.0
                                                ],
                                                [
                                                  "==",
                                                  "@entity.result",
                                                  "none"
                                                ]
                                              ],
                                              "@livesLeft",
                                              "@entity.lives"
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.player",
                                            [
                                              "if",
                                              [
                                                "and",
                                                "@damaged",
                                                [
                                                  "==",
                                                  "@entity.result",
                                                  "none"
                                                ]
                                              ],
                                              {
                                                "animation": "idle",
                                                "facingRight": true,
                                                "frame": 0.0,
                                                "grounded": false,
                                                "height": 48.0,
                                                "vx": 0.0,
                                                "vy": 0.0,
                                                "width": 32.0,
                                                "x": 80.0,
                                                "y": 320.0
                                              },
                                              "@entity.player"
                                            ]
                                          ],
                                          [
                                            "render-ui",
                                            "main",
                                            {
                                              "children": [
                                                {
                                                  "assetBaseUrl": "@config.assetBaseUrl",
                                                  "backgroundImage": "@config.backgroundImage",
                                                  "bgColor": "@config.bgColor",
                                                  "canvasHeight": "@config.canvasHeight",
                                                  "canvasWidth": "@config.canvasWidth",
                                                  "followCamera": "@config.followCamera",
                                                  "platforms": "@config.platforms",
                                                  "player": "@entity.player",
                                                  "playerSprite": "@config.playerSprite",
                                                  "tileSprites": "@config.tileSprites",
                                                  "type": "platformer-canvas",
                                                  "worldHeight": "@entity.worldHeight",
                                                  "worldWidth": "@entity.worldWidth"
                                                }
                                              ],
                                              "hud": {
                                                "stats": [
                                                  {
                                                    "label": "Score",
                                                    "value": "@entity.score"
                                                  },
                                                  {
                                                    "label": "Lives",
                                                    "value": "@entity.lives"
                                                  }
                                                ],
                                                "type": "game-hud"
                                              },
                                              "type": "game-shell"
                                            }
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 33.0,
              "name": "gameflowTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}