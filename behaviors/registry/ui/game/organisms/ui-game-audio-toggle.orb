{
  "name": "ui-game-audio-toggle",
  "version": "1.0.0",
  "description": "GameAudioToggle — UI factory (1:1 with the @almadar/ui game-audio-toggle pattern).",
  "orbitals": [
    {
      "name": "GameAudioToggleOrbital",
      "entity": {
        "name": "GameAudioToggleItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GameAudioToggleRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GameAudioToggleItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameAudioToggleItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "@config.size",
                      "type": "game-audio-toggle",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "entity": "GameAudioToggleItem",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "sm",
              "label": "Size",
              "description": "Button size",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state (passed through)",
              "tier": "presentation"
            },
            "error": {
              "type": "json",
              "label": "Error",
              "description": "Error state (passed through)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameAudioTogglePage",
          "path": "/game-audio-toggle",
          "traits": [
            {
              "ref": "GameAudioToggleRender"
            }
          ]
        }
      ]
    }
  ]
}