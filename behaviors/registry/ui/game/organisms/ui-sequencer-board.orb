          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04Z16KA5496FHHFSCMQTT",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "slotDropEvent prop — emitted when the player drops an action into a slot",
                "id": "evt_01KXG04Z191ZYSKH1RE7DQNC07",
                "key": "PLACE",
                "name": "Place",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "itemId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "slotRemoveEvent prop — emitted when the player clears a slot",
                "id": "evt_01KXG04Z19NRRDNEQCR5NAV7VD",
                "key": "REMOVE",
                "name": "Remove",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "playEvent prop — starts step-by-step playback of the current sequence",
                "id": "evt_01KXG04Z1984DGBJ5JM3A4DKQ5",
                "key": "PLAY",
                "name": "Play",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "checkEvent prop — submits the sequence for validation",
                "id": "evt_01KXG04Z19TG2MYYD0ZXGJ7FT8",
                "key": "CHECK",
                "name": "Check",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "playAgainEvent prop — reset slots and restart",
                "id": "evt_01KXG04Z19YD7CMT0K71RXZJVY",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "building"
              },
              {
                "name": "complete"
              }
            ],
