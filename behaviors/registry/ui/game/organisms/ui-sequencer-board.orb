{
  "name": "ui-sequencer-board",
  "version": "1.0.0",
  "description": "SequencerBoard — UI factory (1:1 with the @almadar/ui sequencer-board pattern).",
  "orbitals": [
    {
      "name": "SequencerBoardOrbital",
      "entity": {
        "name": "SequencerBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SequencerBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SequencerBoardItem",
          "emits": [
            {
              "event": "PLAY",
              "description": "Emits UI:{playEvent} with { sequence: string[] }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "sequence",
                  "type": "[object]",
                  "required": true
                }
              ]
            },
            {
              "event": "COMPLETE",
              "description": "Emits UI:{completeEvent} with { success: boolean }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "success",
                  "type": "boolean",
                  "required": true
                },
                {
                  "name": "sequence",
                  "type": "[object]",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAY",
                "name": "Play",
                "description": "Emits UI:{playEvent} with { sequence: string[] }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "sequence",
                    "type": "[object]",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "Emits UI:{completeEvent} with { success: boolean }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "success",
                    "type": "boolean",
                    "required": true
                  },
                  {
                    "name": "sequence",
                    "type": "[object]",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SequencerBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stepDurationMs": "@config.stepDurationMs",
                      "playEvent": "PLAY",
                      "pageSize": "@config.pageSize",
                      "entity": "@entity",
                      "sortDirection": "@config.sortDirection",
                      "page": "@config.pageProp",
                      "sortBy": "@config.sortBy",
                      "searchValue": "@config.searchValue",
                      "type": "sequencer-board",
                      "isLoading": "@config.isLoading",
                      "totalCount": "@config.totalCount",
                      "activeFilters": "@config.activeFilters",
                      "selectedIds": "@config.selectedIds",
                      "error": "@config.error",
                      "categoryColors": "@config.categoryColors",
                      "completeEvent": "COMPLETE",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "stepDurationMs": {
              "type": "number",
              "default": 1000.0,
              "label": "Step Duration Ms",
              "description": "Playback speed in ms per step",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "error": {
              "type": "SequencerBoardError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "categoryColors": {
              "type": "Map<string,SequencerBoardCategoryColorsValue>",
              "default": {},
              "label": "Category Colors",
              "description": "Category → color mapping",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "border": {
                    "name": "border",
                    "type": "string",
                    "required": true
                  },
                  "bg": {
                    "name": "bg",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SequencerBoardPage",
          "path": "/sequencer-board",
          "traits": [
            {
              "ref": "SequencerBoardRender"
            }
          ]
        }
      ]
    }
  ]
}