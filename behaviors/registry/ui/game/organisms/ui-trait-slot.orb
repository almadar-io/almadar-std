{
  "name": "ui-trait-slot",
  "version": "1.0.0",
  "description": "TraitSlot — UI factory (1:1 with the @almadar/ui trait-slot pattern).",
  "orbitals": [
    {
      "name": "TraitSlotOrbital",
      "entity": {
        "name": "TraitSlotItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "slotNumber",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "TraitSlotRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "slotNumber"
            ]
          },
          "category": "interaction",
          "linkedEntity": "TraitSlotItem",
          "emits": [
            {
              "event": "ITEM_DROP",
              "description": "-- Drag and drop --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "item",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "category",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "string"
                    },
                    {
                      "name": "stateMachine",
                      "type": "object",
                      "properties": [
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "states",
                          "type": "[string]",
                          "required": true
                        },
                        {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "transitions",
                          "type": "[object]",
                          "required": true,
                          "properties": [
                            {
                              "name": "from",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "to",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "event",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "guardHint",
                              "type": "string"
                            }
                          ]
                        },
                        {
                          "name": "description",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "event": "DRAG_START",
              "description": "Called when drag starts from this slot",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "item",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "category",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "string"
                    },
                    {
                      "name": "stateMachine",
                      "type": "object",
                      "properties": [
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "states",
                          "type": "[string]",
                          "required": true
                        },
                        {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "transitions",
                          "type": "[object]",
                          "required": true,
                          "properties": [
                            {
                              "name": "from",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "to",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "event",
                              "type": "string",
                              "required": true
                            },
                            {
                              "name": "guardHint",
                              "type": "string"
                            }
                          ]
                        },
                        {
                          "name": "description",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "event": "CLICK",
              "description": "-- Callbacks --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "slotNumber",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "REMOVE",
              "description": "Remove handler",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "slotNumber",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLICK",
                "name": "Click",
                "description": "-- Callbacks --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "REMOVE",
                "name": "Remove",
                "description": "Remove handler",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEM_DROP",
                "name": "Item Drop",
                "description": "-- Drag and drop --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "category",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "string"
                      },
                      {
                        "name": "stateMachine",
                        "type": "object",
                        "properties": [
                          {
                            "name": "name",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "states",
                            "type": "[string]",
                            "required": true
                          },
                          {
                            "name": "currentState",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "transitions",
                            "type": "[object]",
                            "required": true,
                            "properties": [
                              {
                                "name": "from",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "to",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "event",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "guardHint",
                                "type": "string"
                              }
                            ]
                          },
                          {
                            "name": "description",
                            "type": "string"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "key": "DRAG_START",
                "name": "Drag Start",
                "description": "Called when drag starts from this slot",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "category",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "string"
                      },
                      {
                        "name": "stateMachine",
                        "type": "object",
                        "properties": [
                          {
                            "name": "name",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "states",
                            "type": "[string]",
                            "required": true
                          },
                          {
                            "name": "currentState",
                            "type": "string",
                            "required": true
                          },
                          {
                            "name": "transitions",
                            "type": "[object]",
                            "required": true,
                            "properties": [
                              {
                                "name": "from",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "to",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "event",
                                "type": "string",
                                "required": true
                              },
                              {
                                "name": "guardHint",
                                "type": "string"
                              }
                            ]
                          },
                          {
                            "name": "description",
                            "type": "string"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TraitSlotItem",
                    {}
                  ],
                  [
                    "set",
                    "@entity.slotNumber",
                    "@config.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onClick": "CLICK",
                      "type": "trait-slot",
                      "slotNumber": "@entity.slotNumber",
                      "entity": "TraitSlotItem",
                      "className": "@config.className",
                      "selected": "@config.selected",
                      "removeEvent": "REMOVE",
                      "size": "@config.size",
                      "onItemDrop": "ITEM_DROP",
                      "lockLabel": "@config.lockLabel",
                      "draggable": "@config.draggable",
                      "isLoading": "@config.isLoading",
                      "equippedItem": "@config.equippedItem",
                      "showTooltip": "@config.showTooltip",
                      "onRemove": "REMOVE",
                      "locked": "@config.locked",
                      "clickEvent": "CLICK",
                      "categoryColors": "@config.categoryColors",
                      "feedback": "@config.feedback",
                      "onDragStart": "DRAG_START",
                      "error": "@config.error",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLICK",
                "effects": [
                  [
                    "set",
                    "@entity.slotNumber",
                    "@payload.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "trait-slot",
                      "selected": "@config.selected",
                      "className": "@config.className",
                      "onRemove": "REMOVE",
                      "onClick": "CLICK",
                      "categoryColors": "@config.categoryColors",
                      "equippedItem": "@config.equippedItem",
                      "removeEvent": "REMOVE",
                      "size": "@config.size",
                      "clickEvent": "CLICK",
                      "slotNumber": "@entity.slotNumber",
                      "lockLabel": "@config.lockLabel",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl",
                      "error": "@config.error",
                      "locked": "@config.locked",
                      "isLoading": "@config.isLoading",
                      "entity": "TraitSlotItem",
                      "onItemDrop": "ITEM_DROP",
                      "draggable": "@config.draggable",
                      "onDragStart": "DRAG_START",
                      "showTooltip": "@config.showTooltip",
                      "feedback": "@config.feedback"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "REMOVE",
                "effects": [
                  [
                    "set",
                    "@entity.slotNumber",
                    "@payload.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTooltip": "@config.showTooltip",
                      "entity": "TraitSlotItem",
                      "slotNumber": "@entity.slotNumber",
                      "onDragStart": "DRAG_START",
                      "error": "@config.error",
                      "size": "@config.size",
                      "lockLabel": "@config.lockLabel",
                      "onRemove": "REMOVE",
                      "isLoading": "@config.isLoading",
                      "onClick": "CLICK",
                      "equippedItem": "@config.equippedItem",
                      "categoryColors": "@config.categoryColors",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl",
                      "clickEvent": "CLICK",
                      "locked": "@config.locked",
                      "draggable": "@config.draggable",
                      "removeEvent": "REMOVE",
                      "type": "trait-slot",
                      "feedback": "@config.feedback",
                      "onItemDrop": "ITEM_DROP",
                      "selected": "@config.selected",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "error": {
              "type": "TraitSlotError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "draggable": {
              "type": "boolean",
              "default": false,
              "label": "Draggable",
              "description": "Whether this slot's equipped item is draggable",
              "tier": "presentation"
            },
            "categoryColors": {
              "type": "Map<string,TraitSlotCategoryColorsValue>",
              "default": {},
              "label": "Category Colors",
              "description": "Category → color mapping",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "border": {
                    "name": "border",
                    "type": "string",
                    "required": true
                  },
                  "bg": {
                    "name": "bg",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "tooltipFrameUrl": {
              "type": "string",
              "default": "Tooltip Frame Url",
              "label": "Tooltip Frame Url",
              "description": "Optional tooltip frame image URL",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state",
              "tier": "presentation"
            },
            "lockLabel": {
              "type": "string",
              "default": "Lock Label",
              "label": "Lock Label",
              "description": "Label shown when locked",
              "tier": "presentation"
            },
            "showTooltip": {
              "type": "boolean",
              "default": true,
              "label": "Show Tooltip",
              "description": "Show tooltip on hover",
              "tier": "presentation"
            },
            "feedback": {
              "type": "string",
              "default": "correct",
              "label": "Feedback",
              "description": "Per-slot correctness feedback after a failed attempt",
              "tier": "presentation",
              "values": [
                "correct",
                "wrong"
              ]
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "slotNumber": {
              "type": "number",
              "default": 0.0,
              "label": "Slot Number",
              "description": "Slot index (1-based)",
              "tier": "presentation"
            },
            "locked": {
              "type": "boolean",
              "default": false,
              "label": "Locked",
              "description": "Whether slot is locked",
              "tier": "presentation"
            },
            "selected": {
              "type": "boolean",
              "default": false,
              "label": "Selected",
              "description": "Whether slot is selected",
              "tier": "presentation"
            },
            "equippedItem": {
              "type": "TraitSlotEquippedItem",
              "label": "Equipped Item",
              "description": "Currently equipped item, if any",
              "tier": "presentation",
              "properties": {
                "stateMachine": {
                  "name": "stateMachine",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "transitions": {
                      "name": "transitions",
                      "type": "array",
                      "required": true,
                      "items": {
                        "type": "object",
                        "properties": {
                          "from": {
                            "name": "from",
                            "type": "string",
                            "required": true
                          },
                          "guardHint": {
                            "name": "guardHint",
                            "type": "string",
                            "required": false
                          },
                          "event": {
                            "name": "event",
                            "type": "string",
                            "required": true
                          },
                          "to": {
                            "name": "to",
                            "type": "string",
                            "required": true
                          }
                        }
                      }
                    },
                    "states": {
                      "name": "states",
                      "type": "array",
                      "required": true,
                      "items": {
                        "type": "string"
                      }
                    },
                    "description": {
                      "name": "description",
                      "type": "string",
                      "required": false
                    },
                    "currentState": {
                      "name": "currentState",
                      "type": "string",
                      "required": true
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    }
                  }
                },
                "category": {
                  "name": "category",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "iconEmoji": {
                  "name": "iconEmoji",
                  "type": "string",
                  "required": false
                },
                "iconUrl": {
                  "name": "iconUrl",
                  "type": "string",
                  "required": false
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TraitSlotPage",
          "path": "/trait-slot",
          "traits": [
            {
              "ref": "TraitSlotRender"
            }
          ]
        }
      ]
    }
  ]
}