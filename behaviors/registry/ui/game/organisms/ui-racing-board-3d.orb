                              20.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "road",
                                    [
                                      "let",
                                      [
                                        [
                                          "ex",
                                          [
                                            "/",
                                            [
                                              "-",
                                              "@gx",
                                              10.0
                                            ],
                                            7.0
                                          ]
                                        ],
                                        [
                                          "ey",
                                          [
                                            "/",
                                            [
                                              "-",
                                              "@gy",
                                              10.0
                                            ],
                                            5.0
                                          ]
                                        ]
                                      ],
                                      [
                                        "let",
                                        [
                                          [
                                            "d",
                                            [
                                              "math/sqrt",
                                              [
                                                "+",
                                                [
                                                  "*",
                                                  "@ex",
                                                  "@ex"
                                                ],
                                                [
                                                  "*",
                                                  "@ey",
                                                  "@ey"
                                                ]
                                              ]
                                            ]
                                          ]
                                        ],
                                        [
                                          "and",
                                          [
                                            ">=",
                                            "@d",
                                            0.72
                                          ],
                                          [
                                            "<=",
                                            "@d",
                                            1.3
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
