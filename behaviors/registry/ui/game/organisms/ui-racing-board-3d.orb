                          "dy",
                          [
                            "-",
                            [
                              "object/get",
                              "@tgt",
                              "y"
                            ],
                            "@entity.rivalCarY"
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "d",
                            [
                              "math/max",
                              0.001,
                              [
                                "math/sqrt",
                                [
                                  "+",
                                  [
                                    "*",
                                    "@dx",
                                    "@dx"
                                  ],
                                  [
                                    "*",
                                    "@dy",
                                    "@dy"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "+",
                          "@entity.rivalCarY",
                          [
                            "*",
                            [
                              "/",
                              "@dy",
                              "@d"
                            ],
                            "@config.rivalSpeed"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      ">",
                      "@entity.rivalLap",
                      "@config.totalLaps"
                    ],
                    "lost",
                    "@entity.result"
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ],
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "if",
                        [
                          "==",
                          "@u.id",
                          "rival"
                        ],
                        [
                          "object/merge",
                          "@u",
                          {
                            "position": {
                              "x": "@entity.rivalCarX",
                              "y": "@entity.rivalCarY"
                            }
                          }
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.phase",
                  "racing"
                ],
                [
                  "==",
                  "@entity.result",
                  "none"
                ]
              ],
              "interval": 130.0,
              "name": "rivalTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}