                                  "+",
                                  "@u.position.x",
                                  -1.0
                                ]
                              ],
                              [
                                "ny",
                                [
                                  "+",
                                  "@u.position.y",
                                  0.0
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "tile",
                                  [
                                    "array/find",
                                    "@config.tiles",
                                    [
                                      "fn",
                                      "t",
                                      [
                                        "and",
                                        [
                                          "==",
                                          "@t.x",
                                          "@nx"
                                        ],
                                        [
                                          "==",
                                          "@t.y",
                                          "@ny"
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "walkable",
                                    [
                                      "if",
                                      [
                                        "==",
                                        "@tile",
                                        null
                                      ],
                                      false,
                                      [
                                        "object/get",
                                        "@tile",
                                        "passable"
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "if",
                                  "@walkable",
                                  [
                                    "object/merge",
                                    "@u",
                                    {
                                      "animation": "walk",
                                      "facing": "left",
                                      "position": {
                                        "x": "@nx",
                                        "y": "@ny"
                                      },
                                      "previousPosition": "@u.position"
                                    }
                                  ],
                                  [
                                    "object/merge",
                                    "@u",
                                    {
                                      "facing": "left"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ],
