                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "racing"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
