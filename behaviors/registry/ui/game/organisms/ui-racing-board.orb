                }
              ],
              "scope": "external",
              "tier": "interaction"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click (inert, clears selection only)",
              "event": "UNIT_CLICK",
              "eventId": "evt_01KXG04YVP6JDDAC80ASKSZWV5",
              "payloadSchema": [
                {
                  "name": "unitId",
