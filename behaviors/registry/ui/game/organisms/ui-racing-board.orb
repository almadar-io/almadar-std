                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Lap",
