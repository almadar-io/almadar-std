            "states": [
              {
                "isInitial": true,
                "name": "racing"
              },
              {
                "name": "menu"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.lap",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.position",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "racing"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
