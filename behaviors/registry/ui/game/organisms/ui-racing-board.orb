                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "==",
                        "@entity.position",
                        1.0
                      ],
                      "victory",
                      "defeat"
                    ]
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "game_over"
                  ],
                  [
