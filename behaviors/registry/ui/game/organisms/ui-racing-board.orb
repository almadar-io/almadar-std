              "eventId": "evt_01KXG04YVPPAQGJKJN2ESDRW7Q",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Steer right one cell (keyboard keyMap or d-pad)",
