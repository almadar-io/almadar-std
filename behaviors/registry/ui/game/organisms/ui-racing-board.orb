                          },
                          {
                            "label": "Position",
                            "value": "@entity.position"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "racing",
                "to": "racing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "walk",
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              },
                              "previousPosition": [
                                "object/get",
                                "@u",
                                "position"
                              ]
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
