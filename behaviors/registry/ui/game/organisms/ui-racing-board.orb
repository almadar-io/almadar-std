                      "u",
                      [
                        "if",
                        [
                          "==",
                          "@u.team",
                          "player"
                        ],
                        [
                          "let",
                          [
                            [
                              "dx",
                              [
                                "if",
                                [
                                  "==",
                                  "@u.facing",
                                  "left"
                                ],
                                -1.0,
                                [
                                  "if",
                                  [
                                    "==",
                                    "@u.facing",
                                    "right"
                                  ],
                                  1.0,
                                  0.0
                                ]
