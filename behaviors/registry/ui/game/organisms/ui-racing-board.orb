                            "value": "@entity.lap"
                          },
                          {
                            "label": "Position",
                            "value": "@entity.position"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "MOVE",
                "from": "racing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "racing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lap",
                    [
                      "+",
                      "@entity.lap",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
