                                              "@u.position.y",
                                              "@ny"
                                            ],
                                            "@target.y"
                                          ],
                                          [
                                            ">=",
                                            [
                                              "math/max",
                                              "@u.position.y",
                                              "@ny"
                                            ],
                                            "@target.y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ],
                                  [
                                    "object/merge",
                                    "@u",
                                    {
                                      "animation": "walk",
                                      "facing": "@facing",
                                      "lap": [
                                        "if",
                                        [
                                          "and",
                                          "@passed",
                                          [
                                            "==",
                                            "@u.nextCheckpoint",
                                            4.0
                                          ]
                                        ],
                                        [
                                          "+",
                                          "@u.lap",
                                          1.0
                                        ],
                                        "@u.lap"
                                      ],
                                      "nextCheckpoint": [
                                        "if",
                                        "@passed",
                                        [
                                          "math/mod",
                                          [
                                            "+",
                                            "@u.nextCheckpoint",
                                            1.0
                                          ],
                                          5.0
                                        ],
                                        "@u.nextCheckpoint"
                                      ],
                                      "position": {
                                        "x": "@nx",
                                        "y": "@ny"
                                      },
                                      "previousPosition": "@u.position"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.position",
                  [
                    "let",
                    [
                      [
                        "rp",
                        [
                          "array/find",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "==",
                              "@u.team",
                              "rival"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "pp",
                          [
                            "+",
                            [
                              "*",
                              "@entity.lap",
                              4.0
                            ],
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    "@u.team",
                                    "player"
                                  ]
                                ]
                              ],
                              "nextCheckpoint"
                            ]
                          ]
                        ],
                        [
                          "rvp",
                          [
                            "+",
                            [
                              "*",
                              "@rp.lap",
                              4.0
                            ],
                            "@rp.nextCheckpoint"
                          ]
                        ]
                      ],
                      [
                        "if",
                        [
                          ">=",
                          "@pp",
                          "@rvp"
                        ],
                        1.0,
                        2.0
                      ]
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    ">=",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.team",
                            "rival"
                          ]
                        ]
                      ],
                      "lap"
                    ],
                    "@config.totalLaps"
                  ],
                  [
                    "do",
                    [
                      "set",
                      "@entity.result",
                      "defeat"
                    ],
                    [
                      "set",
                      "@entity.phase",
                      "game_over"
                    ],
                    [
                      "emit",
                      "GAME_END"
                    ]
                  ],
                  true
                ],
