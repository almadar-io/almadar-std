                "from": "racing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "racing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.position",
                    "@payload.newPosition"
                  ],
