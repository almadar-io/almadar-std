              "eventId": "evt_01KXG04YVPWPECW0ETD28SG04X",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Steer up one cell and accelerate (speed+1, cap 3)",
              "event": "MOVE_UP",
              "eventId": "evt_01KXG04YVPRSPK0Z0V1S48A94Q",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Steer down one cell and brake (speed-1, floor 0)",
              "event": "MOVE_DOWN",
              "eventId": "evt_01KXG04YVPMC1ZAQT97VJA2V52",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emitted when a car finishes totalLaps (victory) or the rival does (defeat)",
              "event": "GAME_END",
              "eventId": "evt_01KXG04YVPA77KZ6AJ12WX50VN",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resets the race to the start line",
              "event": "PLAY_AGAIN",
              "eventId": "evt_01KXG04YVPF87M2G54XAD09XSG",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
