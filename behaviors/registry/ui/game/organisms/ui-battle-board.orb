{
  "name": "ui-battle-board",
  "version": "1.0.0",
  "description": "BattleBoard — UI factory (1:1 with the @almadar/ui battle-board pattern).",
  "orbitals": [
    {
      "name": "BattleBoardOrbital",
      "entity": {
        "name": "BattleBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BattleBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BattleBoardItem",
          "emits": [
            {
              "event": "ATTACK",
              "description": "-- Callbacks --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "attacker",
                  "type": "object"
                },
                {
                  "name": "target",
                  "type": "object"
                },
                {
                  "name": "damage",
                  "type": "number"
                },
                {
                  "name": "attackerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "targetId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "GAME_END",
              "description": "Called when battle ends",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UNIT_MOVE",
              "description": "Called after a unit moves",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unit",
                  "type": "object"
                },
                {
                  "name": "to",
                  "type": "object",
                  "properties": [
                    {
                      "name": "x",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "y",
                      "type": "number",
                      "required": true
                    }
                  ]
                }
              ]
            },
            {
              "event": "TILE_CLICK",
              "description": "-- Declarative event props --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "UNIT_CLICK",
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "END_TURN",
              "description": "Emits UI:{endTurnEvent} with {} on end turn",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PLAY_AGAIN",
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ATTACK",
                "name": "Attack",
                "description": "-- Callbacks --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "attacker",
                    "type": "object"
                  },
                  {
                    "name": "target",
                    "type": "object"
                  },
                  {
                    "name": "damage",
                    "type": "number"
                  },
                  {
                    "name": "attackerId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GAME_END",
                "name": "Game End",
                "description": "Called when battle ends",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UNIT_MOVE",
                "name": "Unit Move",
                "description": "Called after a unit moves",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unit",
                    "type": "object"
                  },
                  {
                    "name": "to",
                    "type": "object",
                    "properties": [
                      {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    ]
                  }
                ]
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "-- Declarative event props --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "END_TURN",
                "name": "End Turn",
                "description": "Emits UI:{endTurnEvent} with {} on end turn",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BattleBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "sortDirection": "@config.sortDirection",
                      "features": "@config.features",
                      "unitScale": "@config.unitScale",
                      "searchValue": "@config.searchValue",
                      "playAgainEvent": "PLAY_AGAIN",
                      "onUnitMove": "UNIT_MOVE",
                      "units": "@config.units",
                      "attackEvent": "ATTACK",
                      "activeFilters": "@config.activeFilters",
                      "gameEndEvent": "GAME_END",
                      "onAttack": "ATTACK",
                      "error": "@config.error",
                      "scale": "@config.scale",
                      "selectedIds": "@config.selectedIds",
                      "tileClickEvent": "TILE_CLICK",
                      "page": "@config.pageProp",
                      "cancelEvent": "CANCEL",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "sortBy": "@config.sortBy",
                      "hasActiveEffects": "@config.hasActiveEffects",
                      "tiles": "@config.tiles",
                      "entity": "@entity",
                      "type": "battle-board",
                      "isLoading": "@config.isLoading",
                      "pageSize": "@config.pageSize",
                      "totalCount": "@config.totalCount",
                      "className": "@config.className",
                      "unitClickEvent": "UNIT_CLICK",
                      "endTurnEvent": "END_TURN",
                      "onGameEnd": "GAME_END",
                      "assetManifest": "@config.assetManifest"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "scale": {
              "type": "number",
              "default": 0.45,
              "label": "Scale",
              "description": "Canvas render scale",
              "tier": "presentation"
            },
            "hasActiveEffects": {
              "type": "boolean",
              "default": false,
              "label": "Has Active Effects",
              "description": "hasActiveEffects prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
