{
  "name": "ui-battle-board",
  "version": "1.0.0",
  "description": "BattleBoard — UI factory (1:1 with the @almadar/ui battle-board pattern).",
  "orbitals": [
    {
      "name": "BattleBoardOrbital",
      "entity": {
        "name": "BattleBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BattleBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BattleBoardItem",
          "emits": [
            {
              "event": "ATTACK",
              "description": "-- Callbacks --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "attacker",
                  "type": "object"
                },
                {
                  "name": "target",
                  "type": "object"
                },
                {
                  "name": "damage",
                  "type": "number"
                },
                {
                  "name": "attackerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "targetId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "GAME_END",
              "description": "Called when battle ends",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UNIT_MOVE",
              "description": "Called after a unit moves",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unit",
                  "type": "object"
                },
                {
                  "name": "to",
                  "type": "object",
                  "properties": [
                    {
                      "name": "x",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "y",
                      "type": "number",
                      "required": true
                    }
                  ]
                }
              ]
            },
            {
              "event": "TILE_CLICK",
              "description": "-- Declarative event props --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "UNIT_CLICK",
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "END_TURN",
              "description": "Emits UI:{endTurnEvent} with {} on end turn",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PLAY_AGAIN",
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ATTACK",
                "name": "Attack",
                "description": "-- Callbacks --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "attacker",
                    "type": "object"
                  },
                  {
                    "name": "target",
                    "type": "object"
                  },
                  {
                    "name": "damage",
                    "type": "number"
                  },
                  {
                    "name": "attackerId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GAME_END",
                "name": "Game End",
                "description": "Called when battle ends",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UNIT_MOVE",
                "name": "Unit Move",
                "description": "Called after a unit moves",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unit",
                    "type": "object"
                  },
                  {
                    "name": "to",
                    "type": "object",
                    "properties": [
                      {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    ]
                  }
                ]
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "-- Declarative event props --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "END_TURN",
                "name": "End Turn",
                "description": "Emits UI:{endTurnEvent} with {} on end turn",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BattleBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "hasActiveEffects": "@config.hasActiveEffects",
                      "tileClickEvent": "TILE_CLICK",
                      "endTurnEvent": "END_TURN",
                      "sortBy": "@config.sortBy",
                      "type": "battle-board",
                      "className": "@config.className",
                      "pageSize": "@config.pageSize",
                      "isLoading": "@config.isLoading",
                      "unitScale": "@config.unitScale",
                      "selectedIds": "@config.selectedIds",
                      "totalCount": "@config.totalCount",
                      "searchValue": "@config.searchValue",
                      "entity": "@entity",
                      "cancelEvent": "CANCEL",
                      "unitClickEvent": "UNIT_CLICK",
                      "sortDirection": "@config.sortDirection",
                      "gameEndEvent": "GAME_END",
                      "page": "@config.pageProp",
                      "activeFilters": "@config.activeFilters",
                      "onAttack": "ATTACK",
                      "onGameEnd": "GAME_END",
                      "attackEvent": "ATTACK",
                      "playAgainEvent": "PLAY_AGAIN",
                      "scale": "@config.scale",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "error": "@config.error",
                      "onUnitMove": "UNIT_MOVE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "error": {
              "type": "BattleBoardError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "unitScale": {
              "type": "number",
              "default": 1.0,
              "label": "Unit Scale",
              "description": "Unit draw-size multiplier",
              "tier": "presentation"
            },
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "hasActiveEffects": {
              "type": "boolean",
              "default": false,
              "label": "Has Active Effects",
              "description": "hasActiveEffects prop",
              "tier": "presentation"
            },
            "scale": {
              "type": "number",
              "default": 0.45,
              "label": "Scale",
              "description": "Canvas render scale",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "effectSpriteUrls": {
              "type": "[asset]",
              "default": [],
              "label": "Effect Sprite Urls",
              "description": "effectSpriteUrls prop",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BattleBoardPage",
          "path": "/battle-board",
          "traits": [
            {
              "ref": "BattleBoardRender"
            }
          ]
        }
      ]
    }
  ]
}