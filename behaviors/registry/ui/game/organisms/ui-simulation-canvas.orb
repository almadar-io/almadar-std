{
  "name": "ui-simulation-canvas",
  "version": "1.0.0",
  "description": "SimulationCanvas — UI factory (1:1 with the @almadar/ui simulation-canvas pattern).",
  "orbitals": [
    {
      "name": "SimulationCanvasOrbital",
      "entity": {
        "name": "SimulationCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SimulationCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SimulationCanvasItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "speed": "@config.speed",
                      "className": "@config.className",
                      "preset": "@config.preset",
                      "running": "@config.running",
                      "type": "simulation-canvas",
                      "width": "@config.width"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "preset": {
              "type": "SimulationCanvasPreset",
              "default": {
                "gravity": {
                  "x": 0.0,
                  "y": 9.81
                },
                "id": "demo",
                "name": "Demo Scene",
                "description": "Bouncing bodies with a spring",
                "bodies": [
                  {
                    "vx": 120.0,
                    "vy": 0.0,
                    "fixed": false,
                    "id": "b0",
                    "mass": 1.0,
                    "radius": 14.0,
                    "y": 80.0,
                    "x": 100.0,
                    "color": "#e94560"
                  },
                  {
                    "mass": 2.0,
                    "radius": 20.0,
                    "vy": 60.0,
                    "fixed": false,
                    "id": "b1",
                    "x": 300.0,
                    "y": 150.0,
                    "vx": -80.0,
                    "color": "#0f3460"
                  },
                  {
                    "vy": 90.0,
                    "y": 90.0,
                    "color": "#533483",
                    "fixed": false,
                    "x": 480.0,
                    "vx": 50.0,
                    "id": "b2",
                    "radius": 12.0,
                    "mass": 1.0
                  },
                  {
                    "id": "b3",
                    "x": 200.0,
                    "y": 300.0,
                    "color": "#16213e",
                    "mass": 3.0,
                    "vy": -70.0,
                    "vx": -40.0,
                    "radius": 22.0,
                    "fixed": false
                  },
                  {
                    "vx": 70.0,
                    "id": "b4",
                    "vy": -50.0,
                    "y": 280.0,
                    "x": 400.0,
                    "mass": 1.0,
                    "color": "#e94560",
                    "radius": 16.0,
                    "fixed": false
                  }
                ],
                "constraints": [
                  {
                    "bodyA": 1.0,
                    "bodyB": 3.0,
                    "length": 160.0,
                    "stiffness": 0.4
                  }
                ],
                "backgroundColor": "#1a1a2e",
                "showVelocity": true,
                "domain": "mechanics",
                "parameters": {}
              },
              "label": "Preset",
              "description": "preset prop",
              "tier": "presentation",
              "properties": {
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                "gravity": {
                  "name": "gravity",
