          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "let",
                  [
                    [
                      "ny",
                      [
                        "+",
                        "@entity.hero.y",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      "@ny",
                      "@entity.gridHeight"
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.score",
                        [
                          "+",
                          "@entity.score",
                          100.0
                        ]
                      ],
                      [
                        "set",
                        "@entity.runs",
                        [
                          "+",
                          "@entity.runs",
                          1.0
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            ">=",
                            "@entity.runs",
                            3.0
                          ],
                          "victory",
                          "@entity.result"
                        ]
                      ],
                      [
                        "set",
                        "@entity.hero",
                        [
                          "if",
                          [
                            "==",
                            "@entity.result",
                            "victory"
                          ],
                          "@entity.hero",
                          {
                            "x": 4.0,
                            "y": 0.0
                          }
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.hero",
                        {
                          "x": "@entity.hero.x",
                          "y": "@ny"
                        }
                      ],
                      [
                        "let",
                        [
                          [
                            "hit",
                            [
                              "array/find",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "or",
                                    [
                                      "==",
                                      "@f.type",
                                      "tree"
                                    ],
                                    [
                                      "==",
                                      "@f.type",
                                      "rock"
                                    ]
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      "@f.x",
                                      "@entity.hero.x"
                                    ],
                                    [
                                      "==",
                                      "@f.y",
                                      "@ny"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "do",
                          [
                            "set",
                            "@entity.lives",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  "@entity.lives",
                                  1.0
                                ]
                              ],
                              "@entity.lives"
                            ]
                          ],
                          [
                            "set",
                            "@entity.effects",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "array/append",
                                "@entity.effects",
                                {
                                  "key": "explosion",
                                  "ttl": 5.0,
                                  "x": "@entity.hero.x",
                                  "y": "@ny"
                                }
                              ],
                              "@entity.effects"
                            ]
                          ],
                          [
                            "set",
                            "@entity.features",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "array/filter",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  [
                                    "!=",
                                    "@f.id",
                                    [
                                      "object/get",
                                      "@hit",
                                      "id"
                                    ]
                                  ]
                                ]
                              ],
                              "@entity.features"
                            ]
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "redGate",
                            [
                              "array/find",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@f.type",
                                    "gate_red"
                                  ],
                                  [
                                    "==",
                                    "@f.y",
                                    "@ny"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "blueGate",
                            [
                              "array/find",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@f.type",
                                    "gate_blue"
                                  ],
                                  [
                                    "==",
                                    "@f.y",
                                    "@ny"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "set",
                          "@entity.score",
                          [
                            "if",
                            [
                              "and",
                              [
                                "!=",
                                "@redGate",
                                null
                              ],
                              [
                                "and",
                                [
                                  "!=",
                                  "@blueGate",
                                  null
                                ],
                                [
                                  "and",
                                  [
                                    ">",
                                    "@entity.hero.x",
                                    [
                                      "object/get",
                                      "@redGate",
                                      "x"
                                    ]
                                  ],
                                  [
                                    "<",
                                    "@entity.hero.x",
                                    [
                                      "object/get",
                                      "@blueGate",
                                      "x"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "+",
                              "@entity.score",
                              10.0
                            ],
                            "@entity.score"
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
