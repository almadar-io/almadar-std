                    "let",
                    [
                      [
                        "nx",
                        [
                          "math/clamp",
                          [
                            "+",
                            "@entity.hero.x",
                            1.0
                          ],
                          0.0,
                          [
                            "-",
                            "@entity.gridWidth",
                            1.0
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.hero",
                        {
                          "x": "@nx",
                          "y": "@entity.hero.y"
                        }
                      ],
                      [
                        "let",
                        [
                          [
                            "hit",
                            [
                              "array/find",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "or",
                                    [
                                      "==",
                                      "@f.type",
                                      "tree"
                                    ],
                                    [
                                      "==",
                                      "@f.type",
                                      "rock"
                                    ]
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      "@f.x",
                                      "@nx"
                                    ],
                                    [
                                      "==",
                                      "@f.y",
                                      "@entity.hero.y"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "do",
                          [
                            "set",
                            "@entity.lives",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  "@entity.lives",
                                  1.0
                                ]
                              ],
                              "@entity.lives"
                            ]
                          ],
                          [
                            "set",
                            "@entity.effects",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "array/append",
                                "@entity.effects",
                                {
                                  "key": "explosion",
                                  "ttl": 5.0,
                                  "x": "@nx",
                                  "y": "@entity.hero.y"
                                }
                              ],
                              "@entity.effects"
                            ]
                          ],
                          [
                            "set",
                            "@entity.features",
                            [
                              "if",
                              [
                                "!=",
                                "@hit",
                                null
                              ],
                              [
                                "array/filter",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  [
                                    "!=",
                                    "@f.id",
                                    [
                                      "object/get",
                                      "@hit",
                                      "id"
                                    ]
                                  ]
                                ]
                              ],
                              "@entity.features"
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            "<=",
