{
  "description": "VariablePanel — UI factory (1:1 with the @almadar/ui variable-panel pattern).",
  "name": "ui-variable-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "VariablePanelItem",
        "persistence": "runtime"
      },
      "name": "VariablePanelOrbital",
      "pages": [
        {
          "name": "VariablePanelPage",
          "path": "/variable-panel",
          "traits": [
            {
              "ref": "VariablePanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "entityName": {
              "default": "Entity Name",
              "description": "Entity name",
              "label": "Entity Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VariablePanelItem",
          "name": "VariablePanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "VariablePanelItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entityName": "@config.entityName",
                      "type": "variable-panel",
                      "variables": "@entity"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}