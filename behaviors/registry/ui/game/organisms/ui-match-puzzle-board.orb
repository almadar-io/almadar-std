                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.moves",
                    20.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@config.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.moves"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.moves",
                    [
                      "-",
                      "@entity.moves",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      10.0
                    ]
                  ],
                  [
                    "if",
                    [
                      ">",
                      [
                        "array/len",
                        [
                          "object/get",
                          "@config.assetManifest",
                          "effects"
                        ]
                      ],
                      0.0
                    ],
                    [
                      "set",
                      "@entity.effects",
                      [
                        "array/append",
                        "@entity.effects",
                        {
                          "key": "spark",
                          "ttl": 4.0,
                          "x": "@payload.x",
                          "y": "@payload.y"
                        }
                      ]
                    ],
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@config.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.moves"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  ">",
                  "@entity.moves",
                  0.0
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@config.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.moves"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "showMinimap": false,
                        "tileLayout": "flat",
                        "tiles": "@config.tiles",
                        "type": "isometric-canvas",
                        "units": "@config.units"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "label": "Moves",
                          "value": "@entity.moves"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}