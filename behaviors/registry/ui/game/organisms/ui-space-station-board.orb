                    "type": "array"
                  },
                  "unitType": {
                    "name": "unitType",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": false,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": false,
                    "type": "number"
                  },
                  "z": {
                    "name": "z",
