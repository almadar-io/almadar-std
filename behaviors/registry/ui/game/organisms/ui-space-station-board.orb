              "type": "[SpaceStationBoardUnitsItem]"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "crewCount",
              "effects",
              "gridHeight",
              "gridWidth",
              "oxygen",
              "phase",
              "selectedUnitId",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpaceStationBoardItem",
          "name": "SpaceStationBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.oxygen",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.crewCount",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    7.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    7.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "isometric",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Crew",
                            "value": "@entity.crewCount"
                          },
                          {
                            "label": "Oxygen",
                            "value": "@entity.oxygen"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "isometric",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Crew",
                            "value": "@entity.crewCount"
                          },
                          {
                            "label": "Oxygen",
                            "value": "@entity.oxygen"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "movement"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "isometric",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Crew",
                            "value": "@entity.crewCount"
                          },
                          {
                            "label": "Oxygen",
                            "value": "@entity.oxygen"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "object/get",
                    [
                      "array/find",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "==",
                          "@u.id",
                          "@payload.unitId"
                        ]
                      ]
                    ],
                    "team"
                  ],
                  "player"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedUnitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "walk",
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "isometric",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Crew",
                            "value": "@entity.crewCount"
                          },
                          {
                            "label": "Oxygen",
                            "value": "@entity.oxygen"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "!=",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      "@entity.gridWidth",
                      "@entity.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@entity.selectedUnitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.x",
                            "y": "@payload.y"
                          }
                        ],
                        2.0
                      ],
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "y"
                                  ],
                                  "@payload.y"
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": true,
                          "tileLayout": "isometric",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Crew",
                            "value": "@entity.crewCount"
                          },
                          {
                            "label": "Oxygen",
                            "value": "@entity.oxygen"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "animation": [
                            "if",
                            [
                              "==",
                              [
                                "object/get",
                                "@u",
                                "animation"
                              ],
                              "walk"
                            ],
                            "idle",
                            [
                              "object/get",
                              "@u",
                              "animation"
                            ]
                          ],
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "showMinimap": true,
                        "tileLayout": "isometric",
                        "tiles": "@config.tiles",
                        "type": "isometric-canvas",
                        "units": "@entity.units"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Crew",
                          "value": "@entity.crewCount"
                        },
                        {
                          "label": "Oxygen",
                          "value": "@entity.oxygen"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}