{
  "description": "ClassifierBoard — guarded classification puzzle: assign items to categories, win when every item's assigned category equals its correct category.",
  "name": "ui-classifier-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "assignedCategory": {
                  "name": "assignedCategory",
                  "required": false,
                  "type": "string"
                },
                "correctCategory": {
                  "name": "correctCategory",
                  "required": true,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "items",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "categories",
            "type": "array"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "hint",
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "attempts",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "win"
            ]
          }
        ],
        "name": "ClassifierBoardItem",
        "persistence": "runtime"
      },
      "name": "ClassifierBoardOrbital",
      "pages": [
        {
          "name": "ClassifierBoardPage",
          "path": "/classifier-board",
          "traits": [
            {
              "ref": "ClassifierBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeFilters": {
              "description": "Active filters",
              "label": "Active Filters",
              "tier": "presentation",
              "type": "json"
            },
            "categories": {
              "default": [
                {
                  "id": "fruit",
                  "label": "Fruit"
                },
                {
                  "id": "vegetable",
                  "label": "Vegetable"
                }
              ],
              "description": "Category buckets the player sorts items into.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Categories",
              "tier": "presentation",
              "type": "[ClassifierBoardCategoriesItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Drag each item into the correct category bucket.",
              "description": "One-line puzzle brief shown to the player.",
              "label": "Description",
              "tier": "domain",
              "type": "string"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ClassifierBoardError"
            },
            "hint": {
              "default": "Think about which foods grow on trees versus underground.",
              "description": "Optional hint the player can reveal.",
              "label": "Hint",
              "tier": "domain",
              "type": "string"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "items": {
              "default": [
                {
                  "assignedCategory": "",
                  "correctCategory": "fruit",
                  "id": "i1",
                  "label": "Apple"
                },
                {
                  "assignedCategory": "",
                  "correctCategory": "vegetable",
                  "id": "i2",
                  "label": "Carrot"
                },
                {
                  "assignedCategory": "",
                  "correctCategory": "fruit",
                  "id": "i3",
                  "label": "Banana"
                },
                {
                  "assignedCategory": "",
                  "correctCategory": "vegetable",
                  "id": "i4",
                  "label": "Potato"
                }
              ],
              "description": "Sortable items — each carries its correct category and the player's current assignment.",
              "items": {
                "properties": {
                  "assignedCategory": {
                    "name": "assignedCategory",
                    "required": false,
                    "type": "string"
                  },
                  "correctCategory": {
                    "name": "correctCategory",
                    "required": true,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[ClassifierBoardItemsItem]"
            },
            "pageProp": {
              "default": 0.0,
              "description": "Current page number",
              "label": "Page",
              "synonyms": "page",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 0.0,
              "description": "Number of items per page",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "searchValue": {
              "default": "Search Value",
              "description": "Current search query value",
              "label": "Search Value",
              "tier": "presentation",
              "type": "string"
            },
            "selectedIds": {
              "default": [],
              "description": "Currently selected item IDs",
              "items": {
                "type": "string"
              },
              "label": "Selected Ids",
              "tier": "presentation",
              "type": "[string]"
            },
            "sortBy": {
              "default": "Sort By",
              "description": "Current sort field",
              "label": "Sort By",
              "tier": "presentation",
              "type": "string"
            },
            "sortDirection": {
              "default": "asc",
              "description": "Current sort direction",
              "label": "Sort Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "asc",
                "desc"
              ]
            },
            "title": {
              "default": "Sort the Foods",
              "description": "Puzzle title shown above the board.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "totalCount": {
              "default": 0.0,
              "description": "Total number of items",
              "label": "Total Count",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "completeEvent prop",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "success",
                  "required": true,
                  "type": "boolean"
                },
                {
                  "name": "attempts",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{assignEvent} with { itemId, categoryId } when an item is dropped into a category",
              "event": "ASSIGN",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "categoryId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{checkEvent} with {} when the player submits their assignments",
              "event": "CHECK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "attempts",
              "categories",
              "description",
              "hint",
              "items",
              "result",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ClassifierBoardItem",
          "name": "ClassifierBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{assignEvent} with { itemId, categoryId } when an item is dropped into a category",
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "categoryId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{checkEvent} with {} when the player submits their assignments",
                "key": "CHECK",
                "name": "Check",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "completeEvent prop",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  },
                  {
                    "name": "attempts",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "set",
                    "@entity.categories",
                    "@config.categories"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "set",
                    "@entity.categories",
                    "@config.categories"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    [
                      "array/map",
                      "@entity.items",
                      [
                        "fn",
                        "i",
                        [
                          "if",
                          [
                            "==",
                            "@i.id",
                            "@payload.itemId"
                          ],
                          [
                            "object/merge",
                            "@i",
                            {
                              "assignedCategory": "@payload.categoryId"
                            }
                          ],
                          "@i"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "ASSIGN",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "win"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.items",
                      [
                        "fn",
                        "i",
                        [
                          "!=",
                          [
                            "object/get",
                            "@i",
                            "assignedCategory"
                          ],
                          [
                            "object/get",
                            "@i",
                            "correctCategory"
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  ">",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.items",
                      [
                        "fn",
                        "i",
                        [
                          "!=",
                          [
                            "object/get",
                            "@i",
                            "assignedCategory"
                          ],
                          [
                            "object/get",
                            "@i",
                            "correctCategory"
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "set",
                    "@entity.categories",
                    "@config.categories"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assignEvent": "ASSIGN",
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "type": "classifier-board"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "complete",
                "to": "menu"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}