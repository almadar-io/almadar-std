                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "team": {
                    "name": "team",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  },
                  "maxHealth": {
                    "name": "maxHealth",
                    "type": "number",
