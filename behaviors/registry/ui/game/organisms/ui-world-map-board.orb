{
  "name": "ui-world-map-board",
  "version": "1.0.0",
  "description": "WorldMapBoard — UI factory (1:1 with the @almadar/ui world-map-board pattern).",
  "orbitals": [
    {
      "name": "WorldMapBoardOrbital",
      "entity": {
        "name": "WorldMapBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "WorldMapBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "WorldMapBoardItem",
          "emits": [
            {
              "event": "HERO_SELECT",
              "description": "-- Declarative event props --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HERO_MOVE",
              "description": "Emits UI:{heroMoveEvent} with { heroId, toX, toY }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "toX",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "toY",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "BATTLE_ENCOUNTER",
              "description": "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "attackerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "defenderId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FEATURE_ENTER",
              "description": "Emits UI:{featureEnterEvent} with { heroId, feature, hex }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "feature",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "hex",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "TILE_CLICK",
              "description": "Emits UI:{tileClickEvent} with { x, y }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HERO_SELECT",
                "name": "Hero Select",
                "description": "-- Declarative event props --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HERO_MOVE",
                "name": "Hero Move",
                "description": "Emits UI:{heroMoveEvent} with { heroId, toX, toY }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toX",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "toY",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "BATTLE_ENCOUNTER",
                "name": "Battle Encounter",
                "description": "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "attackerId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "defenderId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FEATURE_ENTER",
                "name": "Feature Enter",
                "description": "Emits UI:{featureEnterEvent} with { heroId, feature, hex }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "feature",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "hex",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "Emits UI:{tileClickEvent} with { x, y }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldMapBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onHeroSelect": "HERO_SELECT",
                      "type": "world-map-board",
                      "assetManifest": "@config.assetManifest",
                      "scale": "@config.scale",
                      "onHeroMove": "HERO_MOVE",
                      "onFeatureEnter": "FEATURE_ENTER",
                      "diamondTopY": "@config.diamondTopY",
                      "battleEncounterEvent": "BATTLE_ENCOUNTER",
                      "features": "@config.features",
                      "error": "@config.error",
                      "units": "@config.units",
                      "className": "@config.className",
                      "tiles": "@config.tiles",
                      "featureEnterEvent": "FEATURE_ENTER",
                      "isLoading": "@config.isLoading",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "enableCamera": "@config.enableCamera",
                      "entity": "@entity",
                      "allowMoveAllHeroes": "@config.allowMoveAllHeroes",
                      "heroSelectEvent": "HERO_SELECT",
                      "tileClickEvent": "TILE_CLICK",
                      "onBattleEncounter": "BATTLE_ENCOUNTER",
                      "unitScale": "@config.unitScale",
                      "heroMoveEvent": "HERO_MOVE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "error": {
              "type": "WorldMapBoardError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                }
              }
            },
            "units": {
              "type": "[WorldMapBoardUnitsItem]",
              "default": [
                {
                  "position": {
                    "x": 1.0,
                    "y": 1.0
                  },
                  "unitType": "worker",
                  "team": "player",
                  "name": "Worker",
                  "health": 10.0,
                  "maxHealth": 10.0,
                  "id": "u1"
                },
                {
                  "health": 8.0,
                  "position": {
                    "x": 3.0,
                    "y": 3.0
                  },
                  "team": "enemy",
                  "name": "Guardian",
                  "unitType": "guardian",
                  "maxHealth": 10.0,
                  "id": "u2"
                }
              ],
              "label": "Units",
              "description": "Direct unit data — takes priority over entity-derived units.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "position": {
                    "name": "position",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": false
                  },
                  "unitType": {
                    "name": "unitType",
                    "type": "string",
                    "required": false
                  },
                  "sprite": {
                    "name": "sprite",
                    "type": "string",
                    "required": false
                  },
                  "elevation": {
                    "name": "elevation",
                    "type": "number",
                    "required": false
                  },
                  "heroId": {
                    "name": "heroId",
                    "type": "string",
                    "required": false
                  },
                  "faction": {
                    "name": "faction",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  },
                  "previousPosition": {
                    "name": "previousPosition",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      },
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "traits": {
                    "name": "traits",
