                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "health": [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  [
                                    "object/get",
                                    "@u",
                                    "health"
                                  ],
                                  3.0
                                ]
                              ]
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
