                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.toX",
                            "y": "@payload.toY"
                          }
                        ],
                        "@entity.movementRange"
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "@payload.toX"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ],
                                    "@payload.toY"
                                  ]
                                ]
                              ]
                            ],
                            "passable"
                          ],
                          true
                        ],
                        [
                          "==",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "x"
                                    ],
                                    "@payload.toX"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "y"
                                    ],
                                    "@payload.toY"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
