                  [
                    "!=",
                    "@entity.selectedHeroId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.toX",
                        "y": "@payload.toY"
                      },
                      "@entity.gridWidth",
                      "@entity.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
