                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedHeroId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "position": {
                                "x": "@payload.toX",
                                "y": "@payload.toY"
