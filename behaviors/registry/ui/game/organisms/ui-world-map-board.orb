{
  "name": "ui-world-map-board",
  "version": "1.0.0",
  "description": "WorldMapBoard — UI factory (1:1 with the @almadar/ui world-map-board pattern).",
  "orbitals": [
    {
      "name": "WorldMapBoardOrbital",
      "entity": {
        "name": "WorldMapBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "WorldMapBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "WorldMapBoardItem",
          "emits": [
            {
              "event": "HERO_SELECT",
              "description": "-- Declarative event props --",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HERO_MOVE",
              "description": "Emits UI:{heroMoveEvent} with { heroId, toX, toY }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "toX",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "toY",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "BATTLE_ENCOUNTER",
              "description": "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "attackerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "defenderId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FEATURE_ENTER",
              "description": "Emits UI:{featureEnterEvent} with { heroId, feature, hex }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "heroId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "feature",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "hex",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "TILE_CLICK",
              "description": "Emits UI:{tileClickEvent} with { x, y }",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HERO_SELECT",
                "name": "Hero Select",
                "description": "-- Declarative event props --",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HERO_MOVE",
                "name": "Hero Move",
                "description": "Emits UI:{heroMoveEvent} with { heroId, toX, toY }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toX",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "toY",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "BATTLE_ENCOUNTER",
                "name": "Battle Encounter",
                "description": "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "attackerId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "defenderId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FEATURE_ENTER",
                "name": "Feature Enter",
                "description": "Emits UI:{featureEnterEvent} with { heroId, feature, hex }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "heroId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "feature",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "hex",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "Emits UI:{tileClickEvent} with { x, y }",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldMapBoardItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity",
                      "allowMoveAllHeroes": "@config.allowMoveAllHeroes",
                      "heroSelectEvent": "HERO_SELECT",
                      "onFeatureEnter": "FEATURE_ENTER",
                      "onHeroMove": "HERO_MOVE",
                      "unitScale": "@config.unitScale",
                      "battleEncounterEvent": "BATTLE_ENCOUNTER",
                      "isLoading": "@config.isLoading",
                      "className": "@config.className",
                      "enableCamera": "@config.enableCamera",
                      "type": "world-map-board",
                      "onBattleEncounter": "BATTLE_ENCOUNTER",
                      "error": "@config.error",
                      "featureEnterEvent": "FEATURE_ENTER",
                      "diamondTopY": "@config.diamondTopY",
                      "onHeroSelect": "HERO_SELECT",
                      "tileClickEvent": "TILE_CLICK",
                      "heroMoveEvent": "HERO_MOVE",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "scale": "@config.scale"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "allowMoveAllHeroes": {
              "type": "boolean",
              "default": false,
              "label": "Allow Move All Heroes",
              "description": "Allow selecting / moving ALL heroes (including enemy). For testing.",
              "tier": "presentation"
            },
            "scale": {
              "type": "number",
              "default": 0.4,
              "label": "Scale",
              "description": "Canvas render scale",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "unitScale": {
              "type": "number",
              "default": 2.5,
              "label": "Unit Scale",
              "description": "Unit draw-size multiplier",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "error": {
              "type": "WorldMapBoardError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "diamondTopY": {
              "type": "number",
              "default": 0.0,
              "label": "Diamond Top Y",
              "description": "-- Canvas pass-through --",
              "tier": "presentation"
            },
            "enableCamera": {
              "type": "boolean",
              "default": false,
              "label": "Enable Camera",
              "description": "Disable pan/zoom camera (default: true). Set false for fixed maps where overlay labels need stable positions.",
              "tier": "presentation"
            },
            "effectSpriteUrls": {
              "type": "[string]",
              "default": [],
              "label": "Effect Sprite Urls",
              "description": "effectSpriteUrls prop",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WorldMapBoardPage",
          "path": "/world-map-board",
          "traits": [
            {
              "ref": "WorldMapBoardRender"
            }
          ]
        }
      ]
    }
  ]
}