{
  "description": "SimulatorBoard — parameter-tuning puzzle: adjust params until output is within tolerance of target.",
  "name": "ui-simulator-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "paramA",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "paramB",
            "type": "number"
          },
          {
            "default": 10.0,
            "name": "target",
            "type": "number"
          },
          {
            "default": 1.0,
            "name": "tolerance",
            "type": "number"
          },
          {
            "intrinsic": true,
            "name": "output",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "attempts",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "win"
            ]
          }
        ],
        "name": "SimulatorBoardItem",
        "persistence": "runtime"
      },
      "name": "SimulatorBoardOrbital",
      "pages": [
        {
          "name": "SimulatorBoardPage",
          "path": "/simulator-board",
          "traits": [
            {
              "ref": "SimulatorBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeFilters": {
              "description": "Active filters",
              "label": "Active Filters",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SimulatorBoardError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "pageProp": {
              "default": 0.0,
              "description": "Current page number",
              "label": "Page",
              "synonyms": "page",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 0.0,
              "description": "Number of items per page",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "searchValue": {
              "default": "Search Value",
              "description": "Current search query value",
              "label": "Search Value",
              "tier": "presentation",
              "type": "string"
            },
            "selectedIds": {
              "default": [],
              "description": "Currently selected item IDs",
              "items": {
                "type": "string"
              },
              "label": "Selected Ids",
              "tier": "presentation",
              "type": "[string]"
            },
            "sortBy": {
              "default": "Sort By",
              "description": "Current sort field",
              "label": "Sort By",
              "tier": "presentation",
              "type": "string"
            },
            "sortDirection": {
              "default": "asc",
              "description": "Current sort direction",
              "label": "Sort Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "asc",
                "desc"
              ]
            },
            "totalCount": {
              "default": 0.0,
              "description": "Total number of items",
              "label": "Total Count",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "completeEvent prop",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "success",
                  "required": true,
                  "type": "boolean"
                },
                {
                  "name": "attempts",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Sets parameter A from { value } during play.",
              "event": "SET_A",
              "payloadSchema": [
                {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Sets parameter B from { value } during play.",
              "event": "SET_B",
              "payloadSchema": [
                {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Evaluates output vs target/tolerance; wins or retries.",
              "event": "CHECK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Resets the puzzle back to the menu.",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "attempts",
              "paramA",
              "paramB",
              "result",
              "target",
              "tolerance"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SimulatorBoardItem",
          "name": "SimulatorBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "description": "Sets parameter A from { value } during play.",
                "key": "SET_A",
                "name": "Set A",
                "payloadSchema": [
                  {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Sets parameter B from { value } during play.",
                "key": "SET_B",
                "name": "Set B",
                "payloadSchema": [
                  {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Evaluates output vs target/tolerance; wins or retries.",
                "key": "CHECK",
                "name": "Check",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Resets the puzzle back to the menu.",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "completeEvent prop",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  },
                  {
                    "name": "attempts",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "menu"
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.target",
                    10.0
                  ],
                  [
                    "set",
                    "@entity.tolerance",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "activeFilters": "@config.activeFilters",
                      "className": "@config.className",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "error": "@config.error",
                      "isLoading": "@config.isLoading",
                      "page": "@config.pageProp",
                      "pageSize": "@config.pageSize",
                      "searchValue": "@config.searchValue",
                      "selectedIds": "@config.selectedIds",
                      "sortBy": "@config.sortBy",
                      "sortDirection": "@config.sortDirection",
                      "totalCount": "@config.totalCount",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "menu",
                "to": "menu"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "SET_A",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramB",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "SET_B",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "win"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  "<=",
                  [
                    "math/abs",
                    [
                      "-",
                      "@entity.output",
                      "@entity.target"
                    ]
                  ],
                  "@entity.tolerance"
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  ">",
                  [
                    "math/abs",
                    [
                      "-",
                      "@entity.output",
                      "@entity.target"
                    ]
                  ],
                  "@entity.tolerance"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "complete",
                "to": "menu"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}