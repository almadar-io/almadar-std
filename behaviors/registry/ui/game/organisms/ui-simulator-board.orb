{
  "name": "ui-simulator-board",
  "version": "1.0.0",
  "description": "SimulatorBoard — UI factory (1:1 with the @almadar/ui simulator-board pattern).",
  "orbitals": [
    {
      "name": "SimulatorBoardOrbital",
      "entity": {
        "name": "SimulatorBoardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SimulatorBoardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SimulatorBoardItem",
          "emits": [
            {
              "event": "COMPLETE",
              "description": "completeEvent prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "success",
                  "type": "boolean",
                  "required": true
                },
                {
                  "name": "attempts",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "completeEvent prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "success",
                    "type": "boolean",
                    "required": true
                  },
                  {
                    "name": "attempts",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@config.entityProp",
                      "completeEvent": "COMPLETE",
                      "type": "simulator-board"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "entityProp": {
              "type": "SimulatorBoardEntity",
              "label": "Entity",
              "description": "The compiler binds the generic `EntityRow`, so the inlet accepts it (and",
              "synonyms": "entity",
              "tier": "presentation",
              "properties": {
                "outputUnit": {
                  "name": "outputUnit",
                  "type": "string",
                  "required": true
                },
                "successMessage": {
                  "name": "successMessage",
                  "type": "string",
                  "required": false
                },
                "outputLabel": {
                  "name": "outputLabel",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "computeExpression": {
                  "name": "computeExpression",
                  "type": "string",
                  "required": true
                },
                "failMessage": {
                  "name": "failMessage",
                  "type": "string",
                  "required": false
                },
                "hint": {
                  "name": "hint",
                  "type": "string",
                  "required": false
                },
                "headerImage": {
                  "name": "headerImage",
                  "type": "string",
                  "required": false
                },
                "theme": {
                  "name": "theme",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "accentColor": {
                      "name": "accentColor",
                      "type": "string",
                      "required": false
                    },
                    "background": {
                      "name": "background",
                      "type": "string",
                      "required": false
                    }
                  }
                },
                "parameters": {
                  "name": "parameters",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "unit": {
                        "name": "unit",
                        "type": "string",
                        "required": true
                      },
                      "min": {
                        "name": "min",
                        "type": "number",
                        "required": true
                      },
                      "max": {
                        "name": "max",
                        "type": "number",
                        "required": true
                      },
                      "initial": {
                        "name": "initial",
                        "type": "number",
                        "required": true
                      },
                      "label": {
                        "name": "label",
                        "type": "string",
                        "required": true
                      },
                      "tolerance": {
                        "name": "tolerance",
                        "type": "number",
                        "required": true
                      },
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "correct": {
                        "name": "correct",
                        "type": "number",
                        "required": true
                      },
                      "step": {
                        "name": "step",
                        "type": "number",
                        "required": true
                      }
                    }
                  }
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "targetValue": {
                  "name": "targetValue",
                  "type": "number",
                  "required": true
                },
                "targetTolerance": {
                  "name": "targetTolerance",
                  "type": "number",
                  "required": true
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SimulatorBoardPage",
          "path": "/simulator-board",
          "traits": [
            {
              "ref": "SimulatorBoardRender"
            }
          ]
        }
      ]
    }
  ]
}