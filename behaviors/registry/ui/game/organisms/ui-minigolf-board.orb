                        },
                        "currentState": {
                          "name": "currentState",
                          "required": true,
                          "type": "string"
                        },
                        "name": {
                          "name": "name",
                          "required": true,
                          "type": "string"
                        },
                        "states": {
                          "items": {
                            "type": "string"
                          },
                          "name": "states",
                          "required": true,
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "name": "traits",
                    "required": false,
                    "type": "array"
                  },
                  "unitType": {
                    "name": "unitType",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": false,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": false,
                    "type": "number"
                  },
                  "z": {
                    "name": "z",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Units",
              "tier": "presentation",
              "type": "[MinigolfBoardUnitsItem]"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits when ball reaches the hole",
              "event": "HOLE_IN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits to advance to the next hole",
              "event": "NEXT_HOLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits to restart from hole 1",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "effects",
              "hole",
              "result",
              "strokes",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MinigolfBoardItem",
          "name": "MinigolfBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits when ball reaches the hole",
                "key": "HOLE_IN",
                "name": "Hole In",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits to advance to the next hole",
                "key": "NEXT_HOLE",
                "name": "Next Hole",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits to restart from hole 1",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.hole",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.strokes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Hole",
                            "value": "@entity.hole"
                          },
                          {
                            "label": "Strokes",
                            "value": "@entity.strokes"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.unitType",
                            "ball"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "roll",
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.strokes",
                    [
                      "+",
                      "@entity.strokes",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Hole",
                            "value": "@entity.hole"
                          },
                          {
                            "label": "Strokes",
                            "value": "@entity.strokes"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Hole",
                            "value": "@entity.hole"
                          },
                          {
                            "label": "Strokes",
                            "value": "@entity.strokes"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "HOLE_IN",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.hole",
                    [
                      "+",
                      "@entity.hole",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.strokes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Hole",
                            "value": "@entity.hole"
                          },
                          {
                            "label": "Strokes",
                            "value": "@entity.strokes"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "NEXT_HOLE",
                "from": "complete",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.hole",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.strokes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tileLayout": "flat",
                          "tiles": "@config.tiles",
                          "type": "isometric-canvas",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Hole",
                            "value": "@entity.hole"
                          },
                          {
                            "label": "Strokes",
                            "value": "@entity.strokes"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "complete",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "showMinimap": false,
                        "tileLayout": "flat",
                        "tiles": "@config.tiles",
                        "type": "isometric-canvas",
                        "units": "@entity.units"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Hole",
                          "value": "@entity.hole"
                        },
                        {
                          "label": "Strokes",
                          "value": "@entity.strokes"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}