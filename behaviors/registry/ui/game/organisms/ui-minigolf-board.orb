                                    "let",
                                    [
                                      [
                                        "inBounds",
                                        [
                                          "grid/in-bounds",
                                          {
                                            "x": "@nx",
                                            "y": "@ny"
                                          },
                                          "@entity.gridWidth",
                                          "@entity.gridHeight"
                                        ]
                                      ],
                                      [
                                        "tile",
                                        [
                                          "array/find",
                                          "@entity.tiles",
                                          [
                                            "fn",
                                            "t",
                                            [
                                              "and",
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "x"
                                                ],
                                                "@nx"
                                              ],
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "y"
                                                ],
                                                "@ny"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "if",
                                      [
                                        "and",
                                        "@inBounds",
                                        [
                                          "if",
                                          [
                                            "==",
                                            "@tile",
                                            null
                                          ],
                                          false,
                                          [
                                            "object/get",
                                            "@tile",
                                            "passable"
                                          ]
                                        ]
                                      ],
                                      {
                                        "moving": true,
                                        "x": "@nx",
                                        "y": "@ny"
                                      },
                                      [
                                        "object/merge",
                                        "@acc",
                                        {
                                          "moving": false
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            {
                              "moving": true,
                              "x": [
                                "object/get",
                                "@ballPos",
                                "x"
                              ],
                              "y": [
                                "object/get",
                                "@ballPos",
                                "y"
                              ]
                            }
                          ]
                        ]
                      ],
                      [
                        "do",
                        [
                          "set",
                          "@entity.units",
                          [
                            "array/map",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "object/merge",
                                "@u",
                                {
                                  "animation": "roll",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@rolled",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@rolled",
                                      "y"
                                    ]
                                  }
                                }
                              ]
                            ]
                          ]
                        ],
                        [
                          "set",
                          "@entity.strokes",
                          [
                            "+",
                            "@entity.strokes",
                            1.0
                          ]
                        ],
                        [
                          "if",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@rolled",
                                "x"
                              ],
                              [
                                "object/get",
                                "@entity.holeCell",
                                "x"
                              ]
                            ],
                            [
                              "==",
                              [
                                "object/get",
                                "@rolled",
                                "y"
                              ],
                              [
                                "object/get",
                                "@entity.holeCell",
                                "y"
                              ]
                            ]
                          ],
                          [
                            "do",
                            [
                              "set",
                              "@entity.total",
                              [
                                "+",
                                "@entity.total",
                                "@entity.strokes"
                              ]
                            ],
                            [
                              "set",
                              "@entity.totalPar",
                              [
                                "+",
                                "@entity.totalPar",
                                "@entity.par"
                              ]
                            ],
                            [
                              "set",
                              "@entity.result",
                              [
                                "if",
                                [
                                  "==",
                                  "@entity.hole",
                                  3.0
                                ],
                                "final",
                                "complete"
                              ]
                            ],
                            [
                              "emit",
                              "HOLE_IN"
                            ]
                          ],
                          true
                        ]
                      ]
                    ]
