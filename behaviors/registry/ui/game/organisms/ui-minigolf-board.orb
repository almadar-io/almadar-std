                                      ]
                                    ],
                                    [
                                      "ny",
                                      [
                                        "+",
                                        [
                                          "object/get",
                                          "@acc",
                                          "y"
                                        ],
                                        -1.0
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "inBounds",
                                        [
                                          "grid/in-bounds",
                                          {
                                            "x": "@nx",
                                            "y": "@ny"
                                          },
                                          "@entity.gridWidth",
                                          "@entity.gridHeight"
                                        ]
                                      ],
                                      [
                                        "tile",
                                        [
                                          "array/find",
                                          "@entity.tiles",
                                          [
                                            "fn",
                                            "t",
                                            [
                                              "and",
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "x"
                                                ],
                                                "@nx"
                                              ],
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "y"
                                                ],
                                                "@ny"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "if",
                                      [
                                        "and",
                                        "@inBounds",
                                        [
                                          "if",
                                          [
                                            "==",
                                            "@tile",
                                            null
                                          ],
                                          false,
                                          [
                                            "object/get",
                                            "@tile",
                                            "passable"
                                          ]
                                        ]
                                      ],
                                      {
                                        "moving": true,
                                        "x": "@nx",
                                        "y": "@ny"
                                      },
                                      [
                                        "object/merge",
                                        "@acc",
                                        {
                                          "moving": false
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            {
                              "moving": true,
                              "x": [
                                "object/get",
                                "@ballPos",
                                "x"
                              ],
                              "y": [
                                "object/get",
                                "@ballPos",
                                "y"
                              ]
                            }
                          ]
                        ]
                      ],
                      [
                        "do",
                        [
                          "set",
                          "@entity.units",
                          [
                            "array/map",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
