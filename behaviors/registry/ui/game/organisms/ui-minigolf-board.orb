                              [
                                "object/get",
                                "@entity.holeCell",
                                "x"
                              ]
                            ],
                            [
                              "==",
                              [
                                "object/get",
                                "@rolled",
                                "y"
                              ],
                              [
                                "object/get",
                                "@entity.holeCell",
                                "y"
                              ]
                            ]
                          ],
                          [
                            "do",
                            [
                              "set",
                              "@entity.total",
                              [
                                "+",
                                "@entity.total",
                                "@entity.strokes"
                              ]
                            ],
                            [
                              "set",
                              "@entity.totalPar",
                              [
                                "+",
                                "@entity.totalPar",
                                "@entity.par"
                              ]
                            ],
                            [
                              "set",
                              "@entity.result",
                              [
                                "if",
                                [
                                  "==",
                                  "@entity.hole",
                                  3.0
                                ],
                                "final",
                                "complete"
                              ]
                            ],
                            [
                              "emit",
                              "HOLE_IN"
                            ]
                          ],
                          true
                        ]
