{
  "name": "ui-object-rule-panel",
  "version": "1.0.0",
  "description": "ObjectRulePanel — UI factory (1:1 with the @almadar/ui object-rule-panel pattern).",
  "orbitals": [
    {
      "name": "ObjectRulePanelOrbital",
      "entity": {
        "name": "ObjectRulePanelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ObjectRulePanelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ObjectRulePanelItem",
          "emits": [
            {
              "event": "RULES_CHANGE",
              "description": "Called when rules change",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "objectId",
                  "type": "string"
                },
                {
                  "name": "rules",
                  "type": "[object]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RULES_CHANGE",
                "name": "Rules Change",
                "description": "Called when rules change",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "objectId",
                    "type": "string"
                  },
                  {
                    "name": "rules",
                    "type": "[object]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ObjectRulePanelItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "object": "@entity",
                      "type": "object-rule-panel",
                      "disabled": "@config.disabled",
                      "onRulesChange": "RULES_CHANGE",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Whether editing is disabled",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ObjectRulePanelPage",
          "path": "/object-rule-panel",
          "traits": [
            {
              "ref": "ObjectRulePanelRender"
            }
          ]
        }
      ]
    }
  ]
}