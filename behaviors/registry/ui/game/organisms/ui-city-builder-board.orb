                }
              ],
              "description": "Direct tile data — takes priority over entity-derived tiles.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "passable": {
                    "name": "passable",
                    "required": false,
                    "type": "boolean"
                  },
                  "terrain": {
                    "name": "terrain",
                    "required": false,
                    "type": "string"
                  },
                  "terrainSprite": {
                    "name": "terrainSprite",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[CityBuilderBoardTilesItem]"
            },
            "unitScale": {
              "default": 0.6,
              "description": "Unit draw-size multiplier",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            },
            "wood": {
              "default": 80.0,
              "description": "Wood the player starts each game with",
              "label": "Starting Wood",
              "tier": "presentation",
              "type": "number"
            },
            "woodPerBuilding": {
              "default": 1.0,
              "description": "Wood income per building per tick",
              "label": "Wood Per Building",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{selectBuildTypeEvent} with {buildType} when player picks a building from the palette",
              "event": "SELECT_BUILD_TYPE",
              "payloadSchema": [
                {
                  "name": "buildType",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{placeBuildingEvent} with {x,y} on tile click when player places a building",
              "event": "PLACE_BUILDING",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{gameEndEvent} with {result} when the city reaches its goal or collapses",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "buildings",
              "gold",
              "pendingBuildType",
              "population",
              "result",
              "tick",
              "wood"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CityBuilderBoardItem",
          "name": "CityBuilderBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{selectBuildTypeEvent} with {buildType} when player picks a building from the palette",
                "key": "SELECT_BUILD_TYPE",
                "name": "Select Build Type",
                "payloadSchema": [
                  {
                    "name": "buildType",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{placeBuildingEvent} with {x,y} on tile click when player places a building",
                "key": "PLACE_BUILDING",
                "name": "Place Building",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{gameEndEvent} with {result} when the city reaches its goal or collapses",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "building"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    "@config.gold"
                  ],
                  [
                    "set",
                    "@entity.wood",
                    "@config.wood"
                  ],
                  [
                    "set",
                    "@entity.population",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.buildings",
                    "@config.buildings"
                  ],
                  [
                    "set",
                    "@entity.pendingBuildType",
                    "@config.pendingBuildType"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.tick",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "buildTypes": "@config.buildTypes",
                      "buildings": "@entity.buildings",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "pendingBuildType": "@entity.pendingBuildType",
                      "placeBuildingEvent": "PLACE_BUILDING",
                      "population": "@entity.population",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "selectBuildTypeEvent": "SELECT_BUILD_TYPE",
                      "tiles": "@config.tiles",
                      "type": "city-builder-board",
                      "unitScale": "@config.unitScale",
                      "wood": "@entity.wood"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "building",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.pendingBuildType",
                    "@payload.buildType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "buildTypes": "@config.buildTypes",
                      "buildings": "@entity.buildings",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "pendingBuildType": "@entity.pendingBuildType",
                      "placeBuildingEvent": "PLACE_BUILDING",
                      "population": "@entity.population",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "selectBuildTypeEvent": "SELECT_BUILD_TYPE",
                      "tiles": "@config.tiles",
                      "type": "city-builder-board",
                      "unitScale": "@config.unitScale",
                      "wood": "@entity.wood"
                    }
                  ]
                ],
                "event": "SELECT_BUILD_TYPE",
                "from": "building",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    [
                      "-",
                      "@entity.gold",
                      [
                        "object/get",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@config.buildTypes",
                            [
                              "fn",
                              "b",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@b",
                                  "type"
                                ],
                                "@entity.pendingBuildType"
                              ]
                            ]
                          ]
                        ],
                        "cost"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.buildings",
                    [
                      "array/concat",
                      "@entity.buildings",
                      [
                        {
                          "id": [
                            "string/concat",
                            "bld-",
                            [
                              "string/from-number",
                              [
                                "array/len",
                                "@entity.buildings"
                              ]
                            ]
                          ],
                          "type": "@entity.pendingBuildType",
                          "x": "@payload.x",
                          "y": "@payload.y"
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.population",
                    [
                      "+",
                      "@entity.population",
                      "@config.populationPerBuilding"
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.population",
                        "@config.targetPopulation"
                      ],
                      "won",
                      "@entity.result"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "buildTypes": "@config.buildTypes",
                      "buildings": "@entity.buildings",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "pendingBuildType": "@entity.pendingBuildType",
                      "placeBuildingEvent": "PLACE_BUILDING",
                      "population": "@entity.population",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "selectBuildTypeEvent": "SELECT_BUILD_TYPE",
                      "tiles": "@config.tiles",
                      "type": "city-builder-board",
                      "unitScale": "@config.unitScale",
                      "wood": "@entity.wood"
                    }
                  ]
                ],
                "event": "PLACE_BUILDING",
                "from": "building",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      ">=",
                      "@entity.gold",
                      [
                        "object/get",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@config.buildTypes",
                            [
                              "fn",
                              "b",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@b",
                                  "type"
                                ],
                                "@entity.pendingBuildType"
                              ]
                            ]
                          ]
                        ],
                        "cost"
                      ]
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.y"
                        },
                        "@config.gridWidth",
                        "@config.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@entity.buildings",
                              [
                                "fn",
                                "b",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@b.x",
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    "@b.y",
                                    "@payload.y"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ],
                        [
                          "==",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@config.tiles",
                              [
                                "fn",
                                "tl",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@tl",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@tl",
                                        "y"
                                      ],
                                      "@payload.y"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@tl",
                                        "passable"
                                      ],
                                      false
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "building"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "buildTypes": "@config.buildTypes",
                      "buildings": "@entity.buildings",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "pendingBuildType": "@entity.pendingBuildType",
                      "placeBuildingEvent": "PLACE_BUILDING",
                      "population": "@entity.population",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "selectBuildTypeEvent": "SELECT_BUILD_TYPE",
                      "tiles": "@config.tiles",
                      "type": "city-builder-board",
                      "unitScale": "@config.unitScale",
                      "wood": "@entity.wood"
                    }
                  ]
                ],
                "event": "GAME_END",
                "from": "building",
                "guard": [
                  "or",
                  [
                    "==",
                    "@entity.result",
                    "won"
                  ],
                  [
                    "==",
                    "@entity.result",
                    "lost"
                  ]
                ],
                "to": "gameover"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.tick",
                  [
                    "+",
                    "@entity.tick",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.gold",
                  [
                    "+",
                    "@entity.gold",
                    [
                      "*",
                      [
                        "array/len",
                        "@entity.buildings"
                      ],
                      "@config.goldPerBuilding"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.wood",
                  [
                    "+",
                    "@entity.wood",
                    [
                      "*",
                      [
                        "array/len",
                        "@entity.buildings"
                      ],
                      "@config.woodPerBuilding"
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "assetManifest": "@config.assetManifest",
                    "buildTypes": "@config.buildTypes",
                    "buildings": "@entity.buildings",
                    "entity": "@entity",
                    "gameEndEvent": "GAME_END",
                    "gold": "@entity.gold",
                    "pendingBuildType": "@entity.pendingBuildType",
                    "placeBuildingEvent": "PLACE_BUILDING",
                    "population": "@entity.population",
                    "result": "@entity.result",
                    "scale": "@config.scale",
                    "selectBuildTypeEvent": "SELECT_BUILD_TYPE",
                    "tiles": "@config.tiles",
                    "type": "city-builder-board",
                    "unitScale": "@config.unitScale",
                    "wood": "@entity.wood"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1000.0,
              "name": "resourceIncomeTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}