                                      [
                                        "geo/aabb-overlap",
                                        "@playerRect",
                                        {
                                          "h": "@p.height",
                                          "w": "@p.width",
                                          "x": "@p.x",
                                          "y": "@p.y"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "hitY",
                                  [
                                    "object/get",
                                    "@hit",
                                    "y",
                                    "@entity.worldHeight"
                                  ]
                                ],
                                [
                                  "landed",
                                  [
                                    "and",
                                    [
                                      "!=",
                                      "@hit",
                                      null
                                    ],
                                    [
                                      ">",
                                      "@vy1",
                                      0.0
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "py2",
                                    [
                                      "if",
                                      "@landed",
                                      [
                                        "-",
                                        "@hitY",
                                        "@ph"
                                      ],
                                      "@py1"
                                    ]
                                  ],
                                  [
                                    "vy2",
                                    [
                                      "if",
                                      "@landed",
                                      0.0,
                                      "@vy1"
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "atGround",
                                      [
                                        ">=",
                                        [
                                          "+",
                                          "@py2",
                                          "@ph"
                                        ],
                                        "@entity.worldHeight"
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "py3",
                                        [
                                          "if",
                                          "@atGround",
                                          [
                                            "-",
                                            "@entity.worldHeight",
                                            "@ph"
                                          ],
                                          "@py2"
                                        ]
                                      ],
                                      [
                                        "vy3",
                                        [
                                          "if",
                                          "@atGround",
                                          0.0,
                                          "@vy2"
                                        ]
                                      ],
                                      [
                                        "grounded",
                                        [
                                          "or",
                                          "@landed",
                                          "@atGround"
                                        ]
                                      ]
                                    ],
                                    [
                                      "let",
                                      [
                                        [
                                          "fell",
                                          [
                                            "and",
                                            "@atGround",
                                            [
                                              "==",
                                              "@landed",
                                              false
                                            ]
                                          ]
                                        ]
                                      ],
                                      [
                                        "let",
                                        [
                                          [
                                            "damaged",
                                            [
                                              "or",
                                              [
                                                "!=",
                                                "@hazardHit",
                                                null
                                              ],
                                              "@fell"
                                            ]
                                          ]
                                        ],
                                        [
                                          "let",
                                          [
                                            [
                                              "coinHits",
                                              [
                                                "array/filter",
                                                "@entity.coins",
                                                [
                                                  "fn",
                                                  "c",
                                                  [
                                                    "and",
                                                    [
                                                      "==",
                                                      "@c.taken",
                                                      false
                                                    ],
                                                    [
                                                      "geo/aabb-overlap",
                                                      "@playerRect",
                                                      {
                                                        "h": 24.0,
                                                        "w": 24.0,
                                                        "x": "@c.x",
                                                        "y": "@c.y"
                                                      }
                                                    ]
                                                  ]
                                                ]
                                              ]
                                            ],
                                            [
                                              "updatedCoins",
                                              [
                                                "array/map",
                                                "@entity.coins",
                                                [
                                                  "fn",
                                                  "c",
                                                  [
                                                    "if",
                                                    [
                                                      "and",
                                                      [
                                                        "==",
                                                        "@c.taken",
                                                        false
                                                      ],
                                                      [
                                                        "geo/aabb-overlap",
                                                        "@playerRect",
                                                        {
                                                          "h": 24.0,
                                                          "w": 24.0,
                                                          "x": "@c.x",
                                                          "y": "@c.y"
                                                        }
                                                      ]
                                                    ],
                                                    [
                                                      "object/merge",
                                                      "@c",
                                                      {
                                                        "taken": true
                                                      }
                                                    ],
                                                    "@c"
                                                  ]
                                                ]
                                              ]
                                            ],
                                            [
                                              "newResult",
                                              [
                                                "if",
                                                [
                                                  "!=",
                                                  "@goalHit",
                                                  null
                                                ],
                                                "won",
                                                [
                                                  "if",
                                                  [
                                                    "and",
                                                    "@damaged",
                                                    [
                                                      "<=",
                                                      "@livesLeft",
                                                      0.0
                                                    ]
                                                  ],
                                                  "lost",
                                                  "none"
                                                ]
                                              ]
                                            ]
                                          ],
                                          [
                                            "let",
                                            [
                                              [
                                                "coinGain",
                                                [
                                                  "*",
                                                  [
                                                    "array/len",
                                                    "@coinHits"
                                                  ],
                                                  10.0
                                                ]
                                              ],
                                              [
                                                "pickupFx",
                                                [
                                                  "array/map",
                                                  "@coinHits",
                                                  [
                                                    "fn",
                                                    "c",
                                                    {
                                                      "id": [
                                                        "str/concat",
                                                        "fx-coin-",
                                                        "@c.id"
                                                      ],
                                                      "message": "+10",
                                                      "ttl": 20.0,
                                                      "type": "pickup",
                                                      "x": "@c.x",
                                                      "y": "@c.y"
                                                    }
                                                  ]
                                                ]
                                              ],
                                              [
                                                "damageFx",
                                                [
                                                  "if",
                                                  [
                                                    "and",
                                                    "@damaged",
                                                    [
                                                      "==",
                                                      "@newResult",
                                                      "none"
                                                    ]
                                                  ],
                                                  [
                                                    {
                                                      "id": [
                                                        "str/concat",
                                                        "fx-dmg-",
                                                        "@entity.lives"
                                                      ],
                                                      "message": "-1",
                                                      "ttl": 20.0,
                                                      "type": "damage",
                                                      "x": "@px1",
                                                      "y": "@py3"
                                                    }
                                                  ],
                                                  []
                                                ]
                                              ],
                                              [
                                                "winFx",
                                                [
                                                  "if",
                                                  [
                                                    "==",
                                                    "@newResult",
                                                    "won"
                                                  ],
                                                  [
                                                    {
                                                      "id": "fx-win",
                                                      "message": "You Win!",
                                                      "ttl": 40.0,
                                                      "type": "win",
                                                      "x": "@px1",
                                                      "y": "@py3"
                                                    }
                                                  ],
                                                  []
                                                ]
                                              ]
                                            ],
                                            [
                                              "let",
                                              [
                                                [
                                                  "newFx",
                                                  [
                                                    "array/concat",
                                                    "@entity.fx",
                                                    [
                                                      "array/concat",
                                                      "@pickupFx",
                                                      [
                                                        "array/concat",
                                                        "@damageFx",
                                                        "@winFx"
                                                      ]
                                                    ]
                                                  ]
                                                ]
                                              ],
                                              [
                                                "do",
                                                [
                                                  "set",
                                                  "@entity.player",
                                                  [
                                                    "object/merge",
                                                    "@entity.player",
                                                    {
                                                      "grounded": "@grounded",
                                                      "vy": "@vy3",
                                                      "x": "@px1",
                                                      "y": "@py3"
                                                    }
                                                  ]
                                                ],
                                                [
                                                  "set",
                                                  "@entity.result",
                                                  "@newResult"
                                                ],
                                                [
                                                  "set",
                                                  "@entity.score",
                                                  [
                                                    "+",
                                                    [
                                                      "+",
                                                      "@entity.score",
                                                      "@coinGain"
                                                    ],
                                                    [
                                                      "if",
                                                      [
                                                        "!=",
                                                        "@goalHit",
                                                        null
                                                      ],
                                                      100.0,
                                                      0.0
                                                    ]
                                                  ]
                                                ],
                                                [
                                                  "set",
                                                  "@entity.lives",
                                                  [
                                                    "if",
                                                    [
                                                      "and",
                                                      "@damaged",
                                                      [
                                                        ">",
                                                        "@entity.lives",
                                                        0.0
                                                      ],
                                                      [
                                                        "==",
                                                        "@newResult",
                                                        "none"
                                                      ]
                                                    ],
                                                    "@livesLeft",
                                                    "@entity.lives"
                                                  ]
                                                ],
                                                [
                                                  "set",
                                                  "@entity.coins",
                                                  "@updatedCoins"
                                                ],
                                                [
                                                  "set",
                                                  "@entity.fx",
                                                  "@newFx"
                                                ],
                                                [
                                                  "set",
                                                  "@entity.player",
                                                  [
                                                    "if",
                                                    [
                                                      "and",
                                                      "@damaged",
                                                      [
                                                        "==",
                                                        "@newResult",
                                                        "none"
                                                      ]
                                                    ],
                                                    {
                                                      "animation": "idle",
                                                      "facingRight": true,
                                                      "frame": 0.0,
                                                      "grounded": false,
                                                      "height": 48.0,
                                                      "vx": 0.0,
                                                      "vy": 0.0,
                                                      "width": 32.0,
                                                      "x": 80.0,
                                                      "y": 320.0
                                                    },
                                                    "@entity.player"
                                                  ]
                                                ]
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 33.0,
              "name": "gameflowTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.player",
                  [
                    "object/merge",
                    "@entity.player",
                    {
                      "frame": [
