                            "dimension": "2d",
                            "name": "icon-dice",
                            "role": "ui",
                            "sprite": [
                              "if",
                              [
                                "==",
                                "@entity.rolled",
                                true
                              ],
                              [
                                "if",
                                [
                                  "==",
                                  "@entity.result",
                                  "none"
                                ],
                                [
                                  "str/concat",
                                  "dieWhite_border",
                                  [
                                    "+",
                                    "@entity.diceFrame",
                                    1.0
                                  ],
                                  ".png"
                                ],
                                [
                                  "if",
                                  [
                                    ">",
                                    "@entity.dice",
                                    0.0
                                  ],
                                  [
                                    "str/concat",
                                    "dieWhite_border",
                                    "@entity.dice",
                                    ".png"
                                  ],
                                  "dieWhite_border6.png"
                                ]
                              ],
                              [
                                "if",
                                [
                                  ">",
                                  "@entity.dice",
                                  0.0
                                ],
                                [
                                  "str/concat",
                                  "dieWhite_border",
                                  "@entity.dice",
                                  ".png"
                                ],
                                "dieWhite_border6.png"
                              ]
                            ],
                            "style": "vector",
                            "thumbnailUrl": "",
                            "url": "https://almadar-kflow-assets.web.app/shared/ui-boardgame-board/kenney-boardgame-pack/ui/diceWhite_border.png",
                            "variant": ""
                          },
                          "label": "Dice",
                          "value": "@entity.dice"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "hudBackgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel-frame",
                      "role": "ui",
                      "sprite": "blue_panel.png",
                      "style": "vector",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png",
                      "variant": ""
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 100.0,
              "name": "effectsTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.dice",
                  [
                    "math/randomInt",
                    1.0,
                    6.0
                  ]
                ],
                [
                  "set",
                  "@entity.landingIndex",
                  [
                    "math/min",
                    "@entity.lastIndex",
                    [
                      "+",
                      "@entity.rivalIndex",
                      "@entity.dice"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.landingType",
                  [
                    "object/get",
                    [
                      "array/nth",
                      "@config.track",
                      "@entity.landingIndex"
                    ],
                    "type"
                  ]
                ],
                [
                  "set",
                  "@entity.rivalIndex",
                  [
                    "if",
                    [
                      "==",
                      "@entity.landingType",
                      "bonus"
                    ],
                    [
                      "math/min",
                      "@entity.lastIndex",
                      [
                        "+",
                        "@entity.landingIndex",
                        2.0
                      ]
                    ],
                    [
                      "if",
                      [
                        "==",
                        "@entity.landingType",
                        "trap"
                      ],
                      [
                        "math/max",
                        0.0,
                        [
                          "-",
                          "@entity.landingIndex",
                          2.0
                        ]
                      ],
                      "@entity.landingIndex"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.pieces",
                  [
                    "array/map",
                    "@entity.pieces",
                    [
                      "fn",
                      "p",
                      [
                        "if",
                        [
                          "==",
                          "@p.id",
                          "rival"
                        ],
                        [
                          "object/merge",
                          "p",
                          {
                            "position": {
                              "x": [
                                "object/get",
                                [
                                  "array/nth",
                                  "@config.track",
                                  "@entity.rivalIndex"
                                ],
                                "x"
                              ],
                              "y": [
                                "object/get",
                                [
                                  "array/nth",
                                  "@config.track",
                                  "@entity.rivalIndex"
                                ],
                                "y"
                              ]
                            },
                            "trackIndex": "@entity.rivalIndex"
                          }
                        ],
                        "p"
                      ]
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    "or",
                    [
                      "==",
                      "@entity.landingType",
                      "bonus"
                    ],
                    [
                      "==",
                      "@entity.landingType",
                      "trap"
                    ]
                  ],
                  [
                    "set",
                    "@entity.effects",
                    [
                      "array/append",
                      "@entity.effects",
                      {
                        "key": "@entity.landingType",
                        "ttl": 6.0,
                        "x": [
                          "object/get",
                          [
                            "array/nth",
                            "@config.track",
                            "@entity.landingIndex"
                          ],
                          "x"
                        ],
                        "y": [
                          "object/get",
                          [
                            "array/nth",
                            "@config.track",
                            "@entity.landingIndex"
                          ],
                          "y"
                        ]
                      }
                    ]
                  ],
                  true
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "==",
                      "@entity.rivalIndex",
                      "@entity.lastIndex"
                    ],
                    "defeat",
                    "none"
                  ]
                ],
                [
                  "if",
                  [
                    "==",
                    "@entity.result",
                    "defeat"
                  ],
                  [
                    "emit",
                    "GAME_END"
                  ],
                  true
                ],
                [
                  "set",
                  "@entity.currentPlayer",
                  [
                    "if",
                    [
                      "==",
                      "@entity.result",
                      "none"
                    ],
                    "you",
                    "@entity.currentPlayer"
                  ]
                ],
                [
                  "set",
                  "@entity.rolled",
                  [
                    "if",
                    [
                      "==",
                      "@entity.result",
                      "none"
                    ],
                    false,
                    "@entity.rolled"
                  ]
                ],
                [
                  "set",
                  "@entity.turn",
                  [
                    "+",
                    "@entity.turn",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "action": "ROLL_DICE",
                      "iconAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/ui-boardgame-board/kenney-boardgame-pack/ui/diceRed_border.json",
