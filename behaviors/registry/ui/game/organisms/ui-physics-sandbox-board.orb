          },
          "emits": [
            {
              "description": "Drops a new block of the selected kind into a random top column (Spawn button / Space key).",
              "event": "SPAWN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Cycles the selected block kind through grass/dirt/rock/sand.",
              "event": "CYCLE_KIND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Clears every block and resets the sandbox.",
              "event": "CLEAR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "blocks",
              "blocksPlaced",
              "gridHeight",
              "gridWidth",
              "nextId",
              "rowsCleared",
              "score",
              "selectedKind"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PhysicsSandboxBoardItem",
          "name": "PhysicsSandboxBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Drops a new block of the selected kind into a random top column (Spawn button / Space key).",
