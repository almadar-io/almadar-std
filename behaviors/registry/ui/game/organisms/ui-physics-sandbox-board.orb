                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Cycles the selected block kind through grass/dirt/rock/sand.",
                "key": "CYCLE_KIND",
                "name": "Cycle Kind",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears every block and resets the sandbox.",
                "key": "CLEAR",
                "name": "Clear",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
