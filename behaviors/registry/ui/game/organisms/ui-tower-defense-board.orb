                      "unitScale": "@config.unitScale",
                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    [
                      "-",
                      "@entity.gold",
                      "@config.towerCost"
                    ]
                  ],
                  [
                    "set",
                    "@entity.towers",
                    [
                      "array/concat",
                      "@entity.towers",
                      [
                        {
                          "cooldown": "@config.towerCooldown",
                          "damage": "@config.towerDamage",
                          "id": [
                            "str/concat",
                            "tower-",
                            [
                              "array/len",
                              "@entity.towers"
                            ]
                          ],
                          "lastFiredAt": 0.0,
                          "range": "@config.towerRange",
                          "x": "@payload.x",
                          "y": "@payload.y"
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "creeps": "@entity.creeps",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "hero": "@entity.hero",
                      "lives": "@entity.lives",
                      "maxWaves": "@entity.maxWaves",
                      "moveHeroEvent": "MOVE_HERO",
                      "path": "@config.path",
                      "placeTowerEvent": "PLACE_TOWER",
                      "playAgainEvent": "PLAY_AGAIN",
                      "result": "@entity.result",
                      "scale": "@config.scale",
