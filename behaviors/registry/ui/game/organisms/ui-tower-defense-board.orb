                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "PLACE_TOWER",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    ">=",
                    "@entity.gold",
                    "@config.towerCost"
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      "@config.gridWidth",
                      "@config.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.towers",
                            [
                              "fn",
                              "t",
                              [
                                "and",
                                [
                                  "==",
                                  "@t.x",
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  "@t.y",
                                  "@payload.y"
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ],
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@config.path",
                            [
                              "fn",
                              "p",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@p",
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@p",
                                    "y"
                                  ],
                                  "@payload.y"
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.waveActive",
                    true
                  ],
                  [
                    "set",
                    "@entity.creeps",
                    [
                      "array/map",
                      [
                        "array/range",
                        0.0,
                        "@config.creepsPerWave"
                      ],
                      [
                        "fn",
                        "i",
                        {
                          "hp": [
                            "+",
                            "@config.creepBaseHp",
                            [
                              "*",
                              "@i",
                              "@config.creepHpScaling"
                            ]
                          ],
                          "id": [
                            "str/concat",
                            "creep-",
                            "@i"
                          ],
                          "maxHp": [
                            "+",
                            "@config.creepBaseHp",
                            [
                              "*",
                              "@i",
                              "@config.creepHpScaling"
                            ]
                          ],
                          "pathIndex": 0.0,
                          "speed": "@config.creepSpeed",
                          "x": [
                            "object/get",
                            [
                              "array/first",
                              "@config.path"
                            ],
                            "x"
                          ],
                          "y": [
                            "object/get",
                            [
                              "array/first",
                              "@config.path"
                            ],
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "creeps": "@entity.creeps",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "hero": "@entity.hero",
                      "lives": "@entity.lives",
                      "maxWaves": "@entity.maxWaves",
                      "moveHeroEvent": "MOVE_HERO",
                      "path": "@config.path",
                      "placeTowerEvent": "PLACE_TOWER",
                      "playAgainEvent": "PLAY_AGAIN",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "startWaveEvent": "START_WAVE",
                      "tiles": "@config.tiles",
                      "towerCost": "@config.towerCost",
                      "towers": "@entity.towers",
                      "type": "tower-defense-board",
                      "unitScale": "@config.unitScale",
                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "START_WAVE",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.waveActive",
                    false
                  ],
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.hero",
                    [
                      "object/merge",
                      "@entity.hero",
                      {
                        "x": [
                          "math/max",
                          0.0,
                          [
                            "math/min",
                            [
                              "-",
                              "@config.gridWidth",
                              1.0
                            ],
                            [
                              "+",
                              [
                                "object/get",
                                "@entity.hero",
                                "x"
                              ],
                              "@payload.dx"
                            ]
                          ]
                        ],
                        "y": [
                          "math/max",
                          0.0,
                          [
                            "math/min",
                            [
                              "-",
                              "@config.gridHeight",
                              1.0
                            ],
                            [
                              "+",
                              [
                                "object/get",
                                "@entity.hero",
                                "y"
                              ],
                              "@payload.dy"
                            ]
                          ]
                        ]
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "creeps": "@entity.creeps",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "hero": "@entity.hero",
                      "lives": "@entity.lives",
                      "maxWaves": "@entity.maxWaves",
                      "moveHeroEvent": "MOVE_HERO",
                      "path": "@config.path",
                      "placeTowerEvent": "PLACE_TOWER",
                      "playAgainEvent": "PLAY_AGAIN",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "startWaveEvent": "START_WAVE",
                      "tiles": "@config.tiles",
                      "towerCost": "@config.towerCost",
                      "towers": "@entity.towers",
                      "type": "tower-defense-board",
                      "unitScale": "@config.unitScale",
                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "MOVE_HERO",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "creeps": "@entity.creeps",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "hero": "@entity.hero",
                      "lives": "@entity.lives",
                      "maxWaves": "@entity.maxWaves",
                      "moveHeroEvent": "MOVE_HERO",
                      "path": "@config.path",
                      "placeTowerEvent": "PLACE_TOWER",
                      "playAgainEvent": "PLAY_AGAIN",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "startWaveEvent": "START_WAVE",
                      "tiles": "@config.tiles",
                      "towerCost": "@config.towerCost",
                      "towers": "@entity.towers",
                      "type": "tower-defense-board",
                      "unitScale": "@config.unitScale",
                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "or",
                  [
                    "==",
                    "@entity.result",
                    "won"
                  ],
                  [
                    "==",
                    "@entity.result",
                    "lost"
                  ]
                ],
                "to": "gameover"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    "@config.gold"
                  ],
                  [
                    "set",
                    "@entity.lives",
                    "@config.lives"
                  ],
                  [
                    "set",
                    "@entity.wave",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.tick",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.waveActive",
                    false
                  ],
                  [
                    "set",
                    "@entity.towers",
                    "@config.towers"
                  ],
                  [
                    "set",
                    "@entity.creeps",
                    []
                  ],
                  [
                    "set",
                    "@entity.hero",
                    "@config.hero"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "creeps": "@entity.creeps",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "gold": "@entity.gold",
                      "hero": "@entity.hero",
                      "lives": "@entity.lives",
                      "maxWaves": "@entity.maxWaves",
                      "moveHeroEvent": "MOVE_HERO",
                      "path": "@config.path",
                      "placeTowerEvent": "PLACE_TOWER",
                      "playAgainEvent": "PLAY_AGAIN",
                      "result": "@entity.result",
                      "scale": "@config.scale",
                      "startWaveEvent": "START_WAVE",
                      "tiles": "@config.tiles",
                      "towerCost": "@config.towerCost",
                      "towers": "@entity.towers",
                      "type": "tower-defense-board",
                      "unitScale": "@config.unitScale",
                      "wave": "@entity.wave",
                      "waveActive": "@entity.waveActive"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "gameover",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.tick",
                  [
                    "+",
                    "@entity.tick",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.creeps",
                  [
                    "array/map",
                    "@entity.creeps",
                    [
                      "fn",
                      "c",
                      [
                        "let",
                        [
                          [
                            "nextIndex",
                            [
                              "math/min",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@c",
                                  "pathIndex"
                                ],
                                1.0
                              ],
                              [
                                "-",
                                [
                                  "array/len",
                                  "@config.path"
                                ],
                                1.0
                              ]
                            ]
                          ],
                          [
                            "nextWaypoint",
                            [
                              "array/nth",
                              "@config.path",
                              [
                                "math/min",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@c",
                                    "pathIndex"
                                  ],
                                  1.0
                                ],
                                [
                                  "-",
                                  [
                                    "array/len",
                                    "@config.path"
                                  ],
                                  1.0
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "object/merge",
                          "@c",
                          {
                            "pathIndex": "@nextIndex",
                            "x": [
                              "object/get",
                              "@nextWaypoint",
                              "x"
                            ],
                            "y": [
                              "object/get",
                              "@nextWaypoint",
                              "y"
                            ]
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.lives",
                  [
                    "-",
                    "@entity.lives",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@entity.creeps",
                        [
                          "fn",
                          "c",
                          [
                            "==",
                            [
                              "object/get",
                              "@c",
                              "pathIndex"
                            ],
                            [
                              "-",
                              [
                                "array/len",
                                "@config.path"
                              ],
                              1.0
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.creeps",
                  [
                    "array/filter",
                    "@entity.creeps",
                    [
                      "fn",
                      "c",
                      [
                        "<",
                        [
                          "object/get",
                          "@c",
                          "pathIndex"
                        ],
                        [
                          "-",
                          [
                            "array/len",
                            "@config.path"
                          ],
                          1.0
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "<=",
                      "@entity.lives",
                      0.0
                    ],
                    "lost",
                    "@entity.result"
                  ]
                ],
                [
                  "set",
                  "@entity.waveActive",
                  [
                    "if",
                    [
                      "<=",
                      "@entity.lives",
                      0.0
                    ],
                    false,
                    [
                      "if",
                      [
                        "==",
                        [
                          "array/len",
                          "@entity.creeps"
                        ],
                        0.0
                      ],
                      false,
                      "@entity.waveActive"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.wave",
                  [
                    "if",
                    [
                      "and",
                      [
                        "==",
                        [
                          "array/len",
                          "@entity.creeps"
                        ],
                        0.0
                      ],
                      [
                        "and",
                        [
                          ">",
                          "@entity.lives",
                          0.0
                        ],
                        [
                          "==",
                          "@entity.result",
                          "none"
                        ]
                      ]
                    ],
                    [
                      "+",
                      "@entity.wave",
                      1.0
                    ],
                    "@entity.wave"
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "and",
                      [
                        "==",
                        [
                          "array/len",
                          "@entity.creeps"
                        ],
                        0.0
                      ],
                      [
                        "and",
                        [
                          ">",
                          "@entity.lives",
                          0.0
                        ],
                        [
                          ">=",
                          "@entity.wave",
                          "@entity.maxWaves"
                        ]
                      ]
                    ],
                    "won",
                    "@entity.result"
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "assetManifest": "@config.assetManifest",
                    "creeps": "@entity.creeps",
                    "entity": "@entity",
                    "gameEndEvent": "GAME_END",
                    "gold": "@entity.gold",
                    "hero": "@entity.hero",
                    "lives": "@entity.lives",
                    "maxWaves": "@entity.maxWaves",
                    "moveHeroEvent": "MOVE_HERO",
                    "path": "@config.path",
                    "placeTowerEvent": "PLACE_TOWER",
                    "playAgainEvent": "PLAY_AGAIN",
                    "result": "@entity.result",
                    "scale": "@config.scale",
                    "startWaveEvent": "START_WAVE",
                    "tiles": "@config.tiles",
                    "towerCost": "@config.towerCost",
                    "towers": "@entity.towers",
                    "type": "tower-defense-board",
                    "unitScale": "@config.unitScale",
                    "wave": "@entity.wave",
                    "waveActive": "@entity.waveActive"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.waveActive",
                  true
                ],
                [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    ">",
                    [
                      "array/len",
                      "@entity.creeps"
                    ],
                    0.0
                  ]
                ]
              ],
              "interval": 1000.0,
              "name": "creepMoveTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.creeps",
                  [
                    "array/map",
                    "@entity.creeps",
                    [
                      "fn",
                      "c",
                      [
                        "let",
                        [
                          [
                            "inRangeTowers",
                            [
                              "array/filter",
                              "@entity.towers",
                              [
                                "fn",
                                "t",
                                [
                                  "<=",
                                  [
                                    "vec/distance",
                                    {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    {
                                      "x": [
                                        "object/get",
                                        "@c",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@c",
                                        "y"
                                      ]
                                    }
                                  ],
                                  [
                                    "object/get",
                                    "@t",
                                    "range"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "if",
                          [
                            ">",
                            [
                              "array/len",
                              "@inRangeTowers"
                            ],
                            0.0
                          ],
                          [
                            "object/merge",
                            "@c",
                            {
                              "hp": [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  [
                                    "object/get",
                                    "@c",
                                    "hp"
                                  ],
                                  [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@inRangeTowers"
                                    ],
                                    "damage"
                                  ]
                                ]
                              ]
                            }
                          ],
                          "@c"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.gold",
                  [
                    "+",
                    "@entity.gold",
                    [
                      "*",
                      "@config.goldPerKill",
                      [
                        "array/len",
                        [
                          "array/filter",
                          "@entity.creeps",
                          [
                            "fn",
                            "c",
                            [
                              "<=",
                              [
                                "object/get",
                                "@c",
                                "hp"
                              ],
                              0.0
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.creeps",
                  [
                    "array/filter",
                    "@entity.creeps",
                    [
                      "fn",
                      "c",
                      [
                        ">",
                        [
                          "object/get",
                          "@c",
                          "hp"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "assetManifest": "@config.assetManifest",
                    "creeps": "@entity.creeps",
                    "entity": "@entity",
                    "gameEndEvent": "GAME_END",
                    "gold": "@entity.gold",
                    "hero": "@entity.hero",
                    "lives": "@entity.lives",
                    "maxWaves": "@entity.maxWaves",
                    "moveHeroEvent": "MOVE_HERO",
                    "path": "@config.path",
                    "placeTowerEvent": "PLACE_TOWER",
                    "playAgainEvent": "PLAY_AGAIN",
                    "result": "@entity.result",
                    "scale": "@config.scale",
                    "startWaveEvent": "START_WAVE",
                    "tiles": "@config.tiles",
                    "towerCost": "@config.towerCost",
                    "towers": "@entity.towers",
                    "type": "tower-defense-board",
                    "unitScale": "@config.unitScale",
                    "wave": "@entity.wave",
                    "waveActive": "@entity.waveActive"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.waveActive",
                  true
                ],
                [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    ">",
                    [
                      "array/len",
                      "@entity.creeps"
                    ],
                    0.0
                  ]
                ]
              ],
              "interval": 1000.0,
              "name": "towerFireTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}