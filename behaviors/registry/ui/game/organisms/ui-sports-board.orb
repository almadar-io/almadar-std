          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
