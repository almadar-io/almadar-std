                  "team": "enemy",
                  "unitType": "ship",
                  "x": 400.0,
                  "y": 80.0
                },
                {
                  "health": 1.0,
                  "id": "enemy3",
                  "maxHealth": 1.0,
                  "sprite": "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png",
                  "team": "enemy",
                  "unitType": "ship",
                  "x": 600.0,
                  "y": 100.0
                }
              ],
              "description": "Player ship + enemy ships on the field",
              "items": {
