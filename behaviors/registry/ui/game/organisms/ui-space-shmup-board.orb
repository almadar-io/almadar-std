{
  "description": "SpaceShmupBoard — UI factory (1:1 with the @almadar/ui space-shmup-board pattern).",
  "name": "ui-space-shmup-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SpaceShmupBoardItem",
        "persistence": "runtime"
      },
      "name": "SpaceShmupBoardOrbital",
      "pages": [
        {
          "name": "SpaceShmupBoardPage",
