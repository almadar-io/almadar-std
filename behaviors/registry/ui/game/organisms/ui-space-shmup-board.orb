            },
            "width": {
              "default": 800.0,
              "description": "Canvas width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpaceShmupBoardItem",
          "name": "SpaceShmupBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeFilters": "@config.activeFilters",
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "backgroundImage": "@config.backgroundImage",
                      "className": "@config.className",
                      "enemySprite": "@config.enemySprite",
                      "error": "@config.error",
                      "fps": "@config.fps",
                      "height": "@config.height",
                      "hudLifeSprite": "@config.hudLifeSprite",
                      "isLoading": "@config.isLoading",
                      "page": "@config.pageProp",
                      "pageSize": "@config.pageSize",
                      "playerSprite": "@config.playerSprite",
                      "searchValue": "@config.searchValue",
                      "selectedIds": "@config.selectedIds",
                      "sortBy": "@config.sortBy",
                      "sortDirection": "@config.sortDirection",
                      "tileClickEvent": "TILE_CLICK",
                      "totalCount": "@config.totalCount",
                      "type": "space-shmup-board",
                      "unitClickEvent": "UNIT_CLICK",
                      "units": "@config.units",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}