                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "x": [
                          "math/max",
                          0.0,
                          [
                            "-",
                            [
                              "object/get",
                              "@entity.player",
                              "x"
                            ],
                            "@config.moveStep"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                "event": "MOVE_LEFT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "x": [
                          "math/min",
                          "@config.width",
                          [
                            "+",
                            [
                              "object/get",
                              "@entity.player",
                              "x"
                            ],
                            "@config.moveStep"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                "event": "MOVE_RIGHT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
