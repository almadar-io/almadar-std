                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "y": [
                          "math/max",
                          "@config.playerMinY",
                          [
                            "-",
                            [
                              "object/get",
                              "@entity.player",
                              "y"
                            ],
                            "@config.moveStep"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                "event": "MOVE_UP",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "y": [
                          "math/min",
                          "@config.height",
                          [
                            "+",
                            [
                              "object/get",
                              "@entity.player",
                              "y"
                            ],
                            "@config.moveStep"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                "event": "MOVE_DOWN",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "attack"
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.projectiles",
                    [
                      "array/concat",
                      "@entity.projectiles",
                      [
                        {
                          "id": [
                            "str/concat",
                            "proj-",
                            "@entity.nextId"
                          ],
                          "vx": 0.0,
                          "vy": [
                            "-",
                            0.0,
                            "@config.projectileSpeed"
                          ],
                          "x": [
                            "object/get",
                            "@entity.player",
                            "x"
                          ],
                          "y": [
                            "object/get",
                            "@entity.player",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.nextId",
                    [
                      "+",
                      "@entity.nextId",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "SHOOT",
                            "iconAsset": {
