{
  "name": "ui-canvas-effect",
  "version": "1.0.0",
  "description": "CanvasEffect — UI factory (1:1 with the @almadar/ui canvas-effect pattern).",
  "orbitals": [
    {
      "name": "CanvasEffectOrbital",
      "entity": {
        "name": "CanvasEffectItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CanvasEffectRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CanvasEffectItem",
          "emits": [
            {
              "event": "COMPLETE",
              "description": "Callback when the effect animation completes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "Callback when the effect animation completes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "height": "@config.height",
                      "duration": "@config.duration",
                      "y": "@config.y",
                      "className": "@config.className",
                      "isLoading": "@config.isLoading",
                      "error": "@config.error",
                      "x": "@config.x",
                      "completeEvent": "COMPLETE",
                      "effectSpriteUrl": "@config.effectSpriteUrl",
                      "onComplete": "COMPLETE",
                      "intensity": "@config.intensity",
                      "actionType": "@config.actionType",
                      "type": "canvas-effect",
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "width": "@config.width"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "y": {
              "type": "number",
              "default": 0.0,
              "label": "Y",
              "description": "Screen-space Y position (center of the effect)",
              "tier": "presentation"
            },
            "actionType": {
              "type": "string",
              "default": "melee",
              "label": "Action Type",
              "description": "The type of combat action to visualise",
              "tier": "presentation",
              "values": [
                "melee",
                "ranged",
                "magic",
                "heal",
                "defend",
                "hit",
                "death",
                "buff",
                "debuff",
                "shield",
                "aoe",
                "critical"
              ]
            },
            "intensity": {
              "type": "number",
              "default": 1.0,
              "label": "Intensity",
              "description": "Optional intensity multiplier (1 = normal, 2 = double size/brightness)",
              "tier": "presentation"
            },
            "duration": {
              "type": "number",
              "default": 2000.0,
              "label": "Duration",
              "description": "Duration in ms before auto-dismiss (default 2000 for canvas, 800 for emoji)",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "effectSpriteUrl": {
              "type": "string",
              "default": "",
              "label": "Effect Sprite Url",
              "description": "--- Remote asset loading ---",
              "tier": "presentation"
            },
            "assetBaseUrl": {
              "type": "string",
              "default": "",
              "label": "Asset Base Url",
              "description": "Base URL for remote assets. Prepended to relative effectSpriteUrl paths.",
              "tier": "presentation"
            },
            "x": {
              "type": "number",
              "default": 0.0,
              "label": "X",
              "description": "Screen-space X position (center of the effect)",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 400.0,
              "label": "Width",
              "description": "Canvas width (default 400)",
              "tier": "presentation"
            },
            "error": {
              "type": "CanvasEffectError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "assetManifest": {
              "type": "CanvasEffectAssetManifest",
              "label": "Asset Manifest",
              "description": "Full effect asset manifest for the sprite particle engine. When provided, enables the canvas-based particle system.",
              "tier": "presentation",
              "properties": {
                "particles": {
                  "name": "particles",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "dirt": {
                      "name": "dirt",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "flare": {
                      "name": "flare",
                      "type": "string",
                      "required": false
                    },
                    "twirl": {
                      "name": "twirl",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "spark": {
                      "name": "spark",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "scratch": {
                      "name": "scratch",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "symbol": {
                      "name": "symbol",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "fire": {
                      "name": "fire",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "star": {
                      "name": "star",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "slash": {
                      "name": "slash",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "muzzle": {
                      "name": "muzzle",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "light": {
                      "name": "light",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "trace": {
                      "name": "trace",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "flame": {
                      "name": "flame",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "smoke": {
                      "name": "smoke",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "circle": {
                      "name": "circle",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "magic": {
                      "name": "magic",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "scorch": {
                      "name": "scorch",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "baseUrl": {
                  "name": "baseUrl",
                  "type": "string",
                  "required": true
                },
                "animations": {
                  "name": "animations",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "flash": {
                      "name": "flash",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "gasSmoke": {
                      "name": "gasSmoke",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "blackSmoke": {
                      "name": "blackSmoke",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "smokeExplosion": {
                      "name": "smokeExplosion",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "explosion": {
                      "name": "explosion",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "smokePuff": {
                      "name": "smokePuff",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "height": {
              "type": "number",
              "default": 300.0,
              "label": "Height",
              "description": "Canvas height (default 300)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CanvasEffectPage",
          "path": "/canvas-effect",
          "traits": [
            {
              "ref": "CanvasEffectRender"
            }
          ]
        }
      ]
    }
  ]
}
