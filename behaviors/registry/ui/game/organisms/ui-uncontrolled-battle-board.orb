              ],
              "description": "Battlefield tile grid.",
              "items": {
                "properties": {
                  "elevation": {
                    "name": "elevation",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "modelUrl": {
                    "name": "modelUrl",
                    "required": false,
                    "type": "string"
                  },
                  "movementCost": {
                    "name": "movementCost",
                    "required": false,
                    "type": "number"
                  },
                  "passable": {
                    "name": "passable",
                    "required": false,
                    "type": "boolean"
                  },
                  "terrain": {
                    "name": "terrain",
                    "required": false,
                    "type": "string"
                  },
                  "terrainSprite": {
                    "name": "terrainSprite",
                    "required": false,
                    "type": "string"
                  },
                  "tileType": {
                    "name": "tileType",
                    "required": false,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  },
                  "z": {
                    "name": "z",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[UncontrolledBattleBoardTilesItem]"
            },
            "title": {
              "default": "Auto Battle",
              "description": "Battle scenario title shown above the board.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "stepEvent prop — emitted each battle round with attack result",
              "event": "STEP",
              "payloadSchema": [
                {
                  "name": "attackerId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "targetId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "damage",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "playAgainEvent prop — reset + restart the battle",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "description",
              "result",
              "title",
              "turn",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "UncontrolledBattleBoardItem",
          "name": "UncontrolledBattleBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "stepEvent prop — emitted each battle round with attack result",
                "key": "STEP",
                "name": "Step",
                "payloadSchema": [
                  {
                    "name": "attackerId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "damage",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "playAgainEvent prop — reset + restart the battle",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.initialUnits"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "entity": "@entity",
                      "features": "@config.features",
                      "playAgainEvent": "PLAY_AGAIN",
                      "stepEvent": "STEP",
                      "tiles": "@config.tiles",
                      "type": "uncontrolled-battle-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.initialUnits"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "entity": "@entity",
                      "features": "@config.features",
                      "playAgainEvent": "PLAY_AGAIN",
                      "stepEvent": "STEP",
                      "tiles": "@config.tiles",
                      "type": "uncontrolled-battle-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "defeat"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "entity": "@entity",
                      "features": "@config.features",
                      "playAgainEvent": "PLAY_AGAIN",
                      "stepEvent": "STEP",
                      "tiles": "@config.tiles",
                      "type": "uncontrolled-battle-board"
                    }
                  ]
                ],
                "event": "STEP",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "and",
                          [
                            "==",
                            [
                              "object/get",
                              "u",
                              "team"
                            ],
                            "player"
                          ],
                          [
                            ">",
                            [
                              "object/get",
                              "u",
                              "hp"
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "victory"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "entity": "@entity",
                      "features": "@config.features",
                      "playAgainEvent": "PLAY_AGAIN",
                      "stepEvent": "STEP",
                      "tiles": "@config.tiles",
                      "type": "uncontrolled-battle-board"
                    }
                  ]
                ],
                "event": "STEP",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "and",
                          [
                            "==",
                            [
                              "object/get",
                              "u",
                              "team"
                            ],
                            "enemy"
                          ],
                          [
                            ">",
                            [
                              "object/get",
                              "u",
                              "hp"
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "u",
                              "id"
                            ],
                            "@payload.targetId"
                          ],
                          [
                            "object/merge",
                            "u",
                            {
                              "hp": [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  [
                                    "object/get",
                                    "u",
                                    "hp"
                                  ],
                                  "@payload.damage"
                                ]
                              ]
                            }
                          ],
                          "u"
                        ]
                      ]
                    ]
                  ],
                  [
