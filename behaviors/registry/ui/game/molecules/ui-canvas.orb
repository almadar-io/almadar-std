{
  "description": "Canvas — UI factory (1:1 with the @almadar/ui canvas pattern).",
  "name": "ui-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CanvasItem",
        "persistence": "runtime"
      },
      "name": "CanvasOrbital",
      "pages": [
        {
          "name": "CanvasPage",
          "path": "/canvas",
          "traits": [
            {
              "ref": "CanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "Background Color",
              "description": "Solid backdrop colour — 2D `side` fill and 3D scene clear colour.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundImage": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "backgroundImage",
                "dimension": "2d",
                "name": "backgroundImage",
                "role": "decoration",
                "style": "pixel",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
              },
              "description": "Backdrop image (2D iso/hex/flat/free/side).",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "camera": {
              "default": {},
              "description": "Neutral camera pose. Mapped to the underlying host's framing + zoom.",
              "label": "Camera",
              "tier": "presentation",
              "type": "json"
            },
            "children": {
              "default": [],
              "description": "Composed draw-host children (e.g. a `draw-shape-layer` trait). UISlotRenderer routes authored children into the `drawables` prop at render time.",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "--- Shared view config ---",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "drawables": {
              "default": [],
              "description": "Neutral drawable descriptors — the `draw-*` children. Routed to the host's painter.",
              "items": {
                "type": "string"
              },
              "label": "Drawables",
              "tier": "presentation",
              "type": "[json]"
            },
            "featureClickEvent": {
              "default": "FEATURE_CLICK",
              "description": "Feature-click event (3D only).",
              "label": "Feature Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "fogOfWar": {
              "default": [],
              "description": "fogOfWar prop",
              "items": {
                "items": {
                  "type": "boolean"
                },
                "type": "array"
              },
              "label": "Fog Of War",
              "tier": "presentation",
              "type": "[[boolean]]"
            },
            "isLoading": {
              "default": false,
              "description": "isLoading prop",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "keyMap": {
              "default": {
                "item": "Item"
              },
              "description": "keyMap prop",
              "items": {
                "type": "string"
              },
              "label": "Key Map",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "keyUpMap": {
              "default": {
                "item": "Item"
              },
              "description": "keyUpMap prop",
              "items": {
                "type": "string"
              },
              "label": "Key Up Map",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "mode": {
              "default": "2d",
              "description": "Painter: 2D sprite/shape/text raster, or 3D mesh. Default '2d'.",
              "label": "Mode",
              "tier": "presentation",
              "type": "string",
              "values": [
                "2d",
                "3d"
              ]
            },
            "pixelsPerUnit": {
              "default": 0.0,
              "description": "3D world-unit → pixel scale (perspective/side depth). 3D only.",
              "label": "Pixels Per Unit",
              "tier": "presentation",
              "type": "number"
            },
            "projection": {
              "default": "isometric",
              "description": "2D grid layout (2D mode only): isometric / hex / flat / free / side.",
              "label": "Projection",
              "tier": "presentation",
              "type": "string",
              "values": [
                "isometric",
                "hex",
                "flat",
                "free",
                "side"
              ]
            },
            "shadows": {
              "default": false,
              "description": "shadows prop",
              "label": "Shadows",
              "tier": "presentation",
              "type": "boolean"
            },
            "showCoordinates": {
              "default": false,
              "description": "showCoordinates prop",
              "label": "Show Coordinates",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": false,
              "description": "3D-only presentation.",
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "showMinimap": {
              "default": false,
              "description": "Minimap overlay (2D).",
              "label": "Show Minimap",
              "tier": "presentation",
              "type": "boolean"
            },
            "showTileInfo": {
              "default": false,
              "description": "showTileInfo prop",
              "label": "Show Tile Info",
              "tier": "presentation",
              "type": "boolean"
            },
            "tileClickEvent": {
              "default": "TILE_CLICK",
              "description": "--- Shared interaction (LOLO-owned). The painter emitted at runtime depends on",
              "label": "Tile Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "tileHoverEvent": {
              "default": "TILE_HOVER",
              "description": "tileHoverEvent prop",
              "label": "Tile Hover Event",
              "tier": "presentation",
              "type": "string"
            },
            "tileLeaveEvent": {
              "default": "TILE_LEAVE",
              "description": "tileLeaveEvent prop",
              "label": "Tile Leave Event",
              "tier": "presentation",
              "type": "string"
            },
            "unitClickEvent": {
              "default": "UNIT_CLICK",
              "description": "unitClickEvent prop",
              "label": "Unit Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "unitScale": {
              "default": 0.0,
              "description": "Unit draw-size multiplier (both painters).",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            },
            "worldHeight": {
              "default": 0.0,
              "description": "worldHeight prop",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 0.0,
              "description": "Side/free world bounds (2D `side`) and 3D world extent.",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "--- Shared interaction (LOLO-owned). The painter emitted at runtime depends on",
              "event": "@config.tileClickEvent",
              "payloadSchema": [
                {
                  "name": "_payload",
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "unitClickEvent prop",
              "event": "@config.unitClickEvent",
              "payloadSchema": [
                {
                  "name": "_payload",
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "tileHoverEvent prop",
              "event": "@config.tileHoverEvent",
              "payloadSchema": [
                {
                  "name": "_payload",
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "tileLeaveEvent prop",
              "event": "@config.tileLeaveEvent",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Feature-click event (3D only).",
              "event": "@config.featureClickEvent",
              "payloadSchema": [
                {
                  "name": "featureId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "elevation",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CanvasItem",
          "name": "CanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "--- Shared interaction (LOLO-owned). The painter emitted at runtime depends on",
                "key": "@config.tileClickEvent",
                "name": "@config.tile click event",
                "payloadSchema": [
                  {
                    "name": "_payload",
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "unitClickEvent prop",
                "key": "@config.unitClickEvent",
                "name": "@config.unit click event",
                "payloadSchema": [
                  {
                    "name": "_payload",
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "tileHoverEvent prop",
                "key": "@config.tileHoverEvent",
                "name": "@config.tile hover event",
                "payloadSchema": [
                  {
                    "name": "_payload",
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "tileLeaveEvent prop",
                "key": "@config.tileLeaveEvent",
                "name": "@config.tile leave event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Feature-click event (3D only).",
                "key": "@config.featureClickEvent",
                "name": "@config.feature click event",
                "payloadSchema": [
                  {
                    "name": "featureId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "elevation",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "backgroundImage": "@config.backgroundImage",
                      "camera": "@config.camera",
                      "children": "@config.children",
                      "className": "@config.className",
                      "drawables": "@config.drawables",
                      "featureClickEvent": "@config.featureClickEvent",
                      "fogOfWar": "@config.fogOfWar",
                      "isLoading": "@config.isLoading",
                      "keyMap": "@config.keyMap",
                      "keyUpMap": "@config.keyUpMap",
                      "mode": "@config.mode",
                      "pixelsPerUnit": "@config.pixelsPerUnit",
                      "projection": "@config.projection",
                      "shadows": "@config.shadows",
                      "showCoordinates": "@config.showCoordinates",
                      "showGrid": "@config.showGrid",
                      "showMinimap": "@config.showMinimap",
                      "showTileInfo": "@config.showTileInfo",
                      "tileClickEvent": "@config.tileClickEvent",
                      "tileHoverEvent": "@config.tileHoverEvent",
                      "tileLeaveEvent": "@config.tileLeaveEvent",
                      "type": "canvas",
                      "unitClickEvent": "@config.unitClickEvent",
                      "unitScale": "@config.unitScale",
                      "worldHeight": "@config.worldHeight",
                      "worldWidth": "@config.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}