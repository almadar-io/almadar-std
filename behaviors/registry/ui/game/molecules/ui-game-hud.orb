{
  "name": "ui-game-hud",
  "version": "1.0.0",
  "description": "GameHud — UI factory (1:1 with the @almadar/ui game-hud pattern).",
  "orbitals": [
    {
      "name": "GameHudOrbital",
      "entity": {
        "name": "GameHudItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GameHudRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GameHudItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": "@config.stats",
                      "transparent": "@config.transparent",
                      "size": "@config.size",
                      "className": "@config.className",
                      "type": "game-hud",
                      "position": "@config.position",
                      "items": "@config.items",
                      "elements": "@config.elements"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "transparent": {
              "type": "boolean",
              "default": true,
              "label": "Transparent",
              "description": "Whether to use a semi-transparent background",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "items": {
              "type": "[GameHudItemsItem]",
              "default": [
                {
                  "source": "Source",
                  "field": "Field"
                }
              ],
              "label": "Items",
              "description": "Alias for stats (schema compatibility)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  },
                  "source": {
                    "name": "source",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "position": {
              "type": "string",
              "default": "top",
              "label": "Position",
              "description": "Position of the HUD",
              "tier": "presentation",
              "values": [
                "top",
                "bottom",
                "corners"
              ]
            },
            "stats": {
              "type": "[GameHudStatsItem]",
              "default": [
                {
                  "field": "Field",
                  "source": "Source"
                }
              ],
              "label": "Stats",
              "description": "Stats to display - accepts readonly for compatibility with generated const arrays",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "source": {
                    "name": "source",
                    "type": "string",
                    "required": false
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "elements": {
              "type": "[GameHudElementsItem]",
              "default": [
                {
                  "label": "Label",
                  "bind": "Bind",
                  "value": "Value",
                  "format": "Format",
                  "position": "Position",
                  "max": 1.0,
                  "icon": "circle",
                  "type": "Type"
                }
              ],
              "label": "Elements",
              "description": "Schema-style elements array (alternative to stats). Converted to stats internally for backwards compatibility.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "position": {
                    "name": "position",
                    "type": "string",
                    "required": false
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": false
                  },
                  "max": {
                    "name": "max",
                    "type": "number",
                    "required": false
                  },
                  "bind": {
                    "name": "bind",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameHudPage",
          "path": "/game-hud",
          "traits": [
            {
              "ref": "GameHudRender"
            }
          ]
        }
      ]
    }
  ]
}