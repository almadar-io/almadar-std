                                  "fill": "rgba(0,0,0,0.6)",
                                  "height": 0.12,
                                  "offsetX": -0.25,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": 0.5
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "anchor": "ground",
                                  "fill": "#22c55e",
                                  "height": 0.12,
                                  "offsetX": -0.25,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": [
                                    "*",
                                    0.5,
                                    [
                                      "/",
                                      [
                                        "object/get",
                                        "@u",
                                        "health"
                                      ],
                                      [
                                        "object/get",
                                        "@u",
                                        "maxHealth"
                                      ]
                                    ]
                                  ]
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "color": "#ffffff",
                                  "offsetY": -0.85,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "text": [
                                    "object/get",
                                    "@u",
                                    "name"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.fx",
                              [
                                "fn",
                                "f",
                                {
                                  "color": "#ffe066",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ]
                                  },
                                  "text": [
                                    "object/get",
                                    "@f",
                                    "message"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          }
                        ],
                        "projection": "@config.projection",
                        "showMinimap": "@config.showMinimap",
                        "tileClickEvent": "TILE_CLICK",
                        "type": "canvas",
                        "unitClickEvent": "UNIT_CLICK"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            {
                              "iconUrl": "@config.crewIcon",
                              "label": "Crew",
                              "value": "@entity.crewCount"
                            },
                            {
                              "iconUrl": "@config.oxygenIcon",
                              "label": "Oxygen",
                              "value": "@entity.oxygen"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "content": "Status",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "label": "@entity.phase",
                              "type": "badge",
                              "variant": [
                                "if",
                                [
                                  "==",
                                  "@entity.phase",
                                  "movement"
                                ],
                                "info",
                                "neutral"
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "xs",
                          "type": "stack"
                        },
                        {
                          "label": "O2",
                          "type": "timer-display",
                          "value": "@entity.oxygen"
                        },
                        {
                          "action": "CANCEL",
                          "iconAsset": "@config.cancelIcon",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": "@config.hudBackgroundAsset",
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
