{
  "name": "ui-action-buttons",
  "version": "1.0.0",
  "description": "ActionButtons — UI factory (1:1 with the @almadar/ui action-buttons pattern).",
  "orbitals": [
    {
      "name": "ActionButtonsOrbital",
      "entity": {
        "name": "ActionButtonsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ActionButtonsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ActionButtonsItem",
          "emits": [
            {
              "event": "ACTION",
              "description": "Called when a button is pressed/released",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACTION",
                "name": "Action",
                "description": "Called when a button is pressed/released",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "buttons": "@config.buttons",
                      "actionEvent": "ACTION",
                      "onAction": "ACTION",
                      "className": "@config.className",
                      "type": "action-buttons",
                      "layout": "@config.layout",
                      "size": "@config.size",
                      "disabled": "@config.disabled"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "buttons": {
              "type": "[ActionButtonsButtonsItem]",
              "default": [
                {
                  "id": "Id",
                  "label": "Label",
                  "icon": "circle",
                  "variant": "primary"
                }
              ],
              "label": "Buttons",
              "description": "Button configurations",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "layout": {
              "type": "string",
              "default": "horizontal",
              "label": "Layout",
              "description": "Layout variant",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical",
                "diamond"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Disabled state",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ActionButtonsPage",
          "path": "/action-buttons",
          "traits": [
            {
              "ref": "ActionButtonsRender"
            }
          ]
        }
      ]
    }
  ]
}