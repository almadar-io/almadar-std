{
  "description": "ScoreBoard — UI factory (1:1 with the @almadar/ui score-board pattern).",
  "name": "ui-score-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ScoreBoardItem",
        "persistence": "runtime"
      },
      "name": "ScoreBoardOrbital",
      "pages": [
        {
          "name": "ScoreBoardPage",
          "path": "/score-board",
          "traits": [
            {
              "ref": "ScoreBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "combo": {
              "default": 0.0,
              "description": "Current combo count",
              "label": "Combo",
              "tier": "presentation",
              "type": "number"
            },
            "highScore": {
              "default": 0.0,
              "description": "All-time high score",
              "label": "High Score",
              "tier": "presentation",
              "type": "number"
            },
            "level": {
              "default": 0.0,
              "description": "Current level",
              "label": "Level",
              "tier": "presentation",
              "type": "number"
            },
            "multiplier": {
              "default": 0.0,
              "description": "Score multiplier",
              "label": "Multiplier",
              "tier": "presentation",
              "type": "number"
            },
            "score": {
              "default": 0.0,
              "description": "Current score",
              "label": "Score",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ScoreBoardItem",
          "name": "ScoreBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "combo": "@config.combo",
                      "highScore": "@config.highScore",
                      "level": "@config.level",
                      "multiplier": "@config.multiplier",
                      "score": "@config.score",
                      "type": "score-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}