              }
            },
            "type": "object"
          },
          {
            "default": [],
            "items": {
              "properties": {
                "height": {
                  "name": "height",
                  "required": true,
                  "type": "number"
                },
                "type": {
                  "name": "type",
                  "required": false,
                  "type": "string",
                  "values": [
                    "ground",
                    "platform",
                    "hazard",
                    "goal"
                  ]
                },
                "width": {
                  "name": "width",
                  "required": true,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "platforms",
            "type": "array"
          }
        ],
        "name": "PlatformerCanvasItem",
        "persistence": "runtime"
      },
      "name": "PlatformerCanvasOrbital",
      "pages": [
        {
          "name": "PlatformerCanvasPage",
          "path": "/platformer-canvas",
          "traits": [
            {
              "ref": "PlatformerCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetBaseUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "description": "Base URL prefix for asset URLs",
              "label": "Asset Base Url",
              "tier": "presentation",
              "type": "asset"
            },
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/scenes/world/streets.png",
              "description": "Background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "bgColor": {
              "default": "#5c94fc",
              "description": "Background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "canvasHeight prop",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display size",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "followCamera": {
              "default": true,
              "description": "Camera follows player",
              "label": "Follow Camera",
              "tier": "presentation",
              "type": "boolean"
            },
            "gravity": {
              "default": 0.6,
              "description": "vy delta applied each 33ms tick",
              "label": "Gravity",
              "tier": "presentation",
              "type": "number"
            },
            "jumpStrength": {
              "default": 12.0,
              "description": "vy set to -(jumpStrength) on JUMP",
              "label": "Jump Strength",
              "tier": "presentation",
              "type": "number"
            },
            "maxFallSpeed": {
              "default": 20.0,
              "description": "Terminal velocity cap downward",
              "label": "Max Fall Speed",
              "tier": "presentation",
              "type": "number"
            },
            "moveSpeed": {
              "default": 4.0,
              "description": "Horizontal vx magnitude on LEFT/RIGHT",
              "label": "Move Speed",
              "tier": "presentation",
              "type": "number"
            },
            "platforms": {
              "default": [
                {
                  "height": 32.0,
                  "type": "ground",
                  "width": 800.0,
                  "x": 0.0,
                  "y": 368.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 150.0,
                  "y": 280.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 140.0,
                  "x": 620.0,
                  "y": 300.0
                }
              ],
              "description": "Level geometry; ground at worldHeight-32",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerCanvasPlatformsItem]"
            },
            "player": {
              "default": {
                "facingRight": true,
                "grounded": false,
                "height": 48.0,
                "vx": 0.0,
                "vy": 0.0,
                "width": 32.0,
                "x": 80.0,
                "y": 320.0
              },
              "description": "Initial player state",
              "label": "Player",
              "properties": {
                "facingRight": {
                  "name": "facingRight",
                  "required": false,
                  "type": "boolean"
                },
                "grounded": {
                  "name": "grounded",
                  "required": false,
                  "type": "boolean"
                },
                "height": {
                  "name": "height",
                  "required": false,
                  "type": "number"
                },
                "vx": {
                  "name": "vx",
                  "required": false,
                  "type": "number"
                },
                "vy": {
                  "name": "vy",
                  "required": false,
                  "type": "number"
                },
                "width": {
                  "name": "width",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "tier": "presentation",
              "type": "PlatformerCanvasPlayer"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/platformer/characters/platformChar_idle.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": {
                "goal": "https://almadar-kflow-assets.web.app/shared/platformer/tiles/platformPack_tile058.png",
                "ground": "https://almadar-kflow-assets.web.app/shared/platformer/tiles/platformPack_tile029.png",
                "hazard": "https://almadar-kflow-assets.web.app/shared/platformer/tiles/platformPack_tile063.png",
                "platform": "https://almadar-kflow-assets.web.app/shared/platformer/tiles/platformPack_tile046.png"
              },
              "description": "Map of platform type to tile sprite URL",
              "items": {
                "type": "string"
              },
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "Map<string,asset>"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "worldHeight prop",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World dimensions in pixels",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Left arrow / A key pressed",
              "event": "LEFT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Right arrow / D key pressed",
              "event": "RIGHT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Up / Space pressed; model checks grounded guard",
              "event": "JUMP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Horizontal key released",
              "event": "STOP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "platforms",
              "player"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerCanvasItem",
          "name": "PlatformerCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Left arrow / A key pressed",
                "key": "LEFT",
                "name": "Left",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Right arrow / D key pressed",
                "key": "RIGHT",
                "name": "Right",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Up / Space pressed; model checks grounded guard",
                "key": "JUMP",
                "name": "Jump",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Horizontal key released",
                "key": "STOP",
                "name": "Stop",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    "@config.player"
                  ],
                  [
                    "set",
                    "@entity.platforms",
                    "@config.platforms"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "backgroundImage": "@config.backgroundImage",
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "className": "@config.className",
                      "followCamera": "@config.followCamera",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "platforms": "@entity.platforms",
                      "player": "@entity.player",
                      "playerSprite": "@config.playerSprite",
                      "rightEvent": "RIGHT",
                      "stopEvent": "STOP",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-canvas",
                      "worldHeight": "@config.worldHeight",
                      "worldWidth": "@config.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "facingRight": false,
                        "vx": [
                          "-",
                          0.0,
                          "@config.moveSpeed"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "LEFT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "facingRight": true,
                        "vx": "@config.moveSpeed"
                      }
                    ]
                  ]
                ],
                "event": "RIGHT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "grounded": false,
                        "vy": [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "JUMP",
                "from": "idle",
                "guard": [
                  "==",
                  "@entity.player.grounded",
                  true
                ],
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "vx": 0.0
                      }
                    ]
                  ]
                ],
                "event": "STOP",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "vy1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.vy",
                          "@config.gravity"
                        ],
                        [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ],
                        "@config.maxFallSpeed"
                      ]
                    ],
                    [
                      "px1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.x",
                          "@entity.player.vx"
                        ],
                        0.0,
                        [
                          "-",
                          "@config.worldWidth",
                          "@entity.player.width"
                        ]
                      ]
                    ],
                    [
                      "py1",
                      [
                        "+",
                        "@entity.player.y",
                        "@vy1"
                      ]
                    ],
                    [
                      "pw",
                      "@entity.player.width"
                    ],
                    [
                      "ph",
                      "@entity.player.height"
                    ],
                    [
                      "playerRect",
                      {
                        "h": "@ph",
                        "w": "@pw",
                        "x": "@px1",
                        "y": "@py1"
                      }
                    ],
                    [
                      "hit",
                      [
                        "array/find",
                        "@entity.platforms",
                        [
                          "fn",
                          "p",
                          [
                            "geo/aabb-overlap",
                            "@playerRect",
                            {
                              "h": "@p.height",
                              "w": "@p.width",
                              "x": "@p.x",
                              "y": "@p.y"
                            }
                          ]
                        ]
                      ]
                    ],
                    [
                      "hitY",
                      [
                        "object/get",
                        "@hit",
                        "y",
                        "@config.worldHeight"
                      ]
                    ],
                    [
                      "landed",
                      [
                        "and",
                        [
                          "!=",
                          "@hit",
                          null
                        ],
                        [
                          ">",
                          "@vy1",
                          0.0
                        ]
                      ]
                    ],
                    [
                      "py2",
                      [
                        "if",
                        "@landed",
                        [
                          "-",
                          "@hitY",
                          "@ph"
                        ],
                        "@py1"
                      ]
                    ],
                    [
                      "vy2",
                      [
                        "if",
                        "@landed",
                        0.0,
                        "@vy1"
                      ]
                    ],
                    [
                      "atGround",
                      [
                        ">=",
                        [
                          "+",
                          "@py2",
                          "@ph"
                        ],
                        "@config.worldHeight"
                      ]
                    ],
                    [
                      "py3",
                      [
                        "if",
                        "@atGround",
                        [
                          "-",
                          "@config.worldHeight",
                          "@ph"
                        ],
                        "@py2"
                      ]
                    ],
                    [
                      "vy3",
                      [
                        "if",
                        "@atGround",
                        0.0,
                        "@vy2"
                      ]
                    ],
                    [
                      "grounded",
                      [
                        "or",
                        "@landed",
                        "@atGround"
                      ]
                    ]
                  ],
                  [
                    "do",
                    [
                      "set",
                      "@entity.player",
                      [
                        "object/merge",
                        "@entity.player",
                        {
                          "grounded": "@grounded",
                          "vy": "@vy3",
                          "x": "@px1",
                          "y": "@py3"
                        }
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "assetBaseUrl": "@config.assetBaseUrl",
                        "backgroundImage": "@config.backgroundImage",
                        "bgColor": "@config.bgColor",
                        "canvasHeight": "@config.canvasHeight",
                        "canvasWidth": "@config.canvasWidth",
                        "className": "@config.className",
                        "followCamera": "@config.followCamera",
                        "jumpEvent": "JUMP",
                        "leftEvent": "LEFT",
                        "platforms": "@entity.platforms",
                        "player": "@entity.player",
                        "playerSprite": "@config.playerSprite",
                        "rightEvent": "RIGHT",
                        "stopEvent": "STOP",
                        "tileSprites": "@config.tileSprites",
                        "type": "platformer-canvas",
                        "worldHeight": "@config.worldHeight",
                        "worldWidth": "@config.worldWidth"
                      }
                    ]
                  ]
                ]
              ],
              "interval": 33.0,
              "name": "physicsStep"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.1.0"
}