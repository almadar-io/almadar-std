{
  "description": "PlatformerCanvas — UI factory (1:1 with the @almadar/ui platformer-canvas pattern).",
  "name": "ui-platformer-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PlatformerCanvasItem",
        "persistence": "runtime"
      },
      "name": "PlatformerCanvasOrbital",
      "pages": [
        {
          "name": "PlatformerCanvasPage",
          "path": "/platformer-canvas",
          "traits": [
            {
              "ref": "PlatformerCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetBaseUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "description": "Base URL prefix for asset URLs",
              "label": "Asset Base Url",
              "tier": "presentation",
              "type": "asset"
            },
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/scenes/court.png",
              "description": "Background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "bgColor": {
              "default": "Bg Color",
              "description": "Background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "canvasHeight prop",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display size",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "followCamera": {
              "default": true,
              "description": "Camera follows player",
              "label": "Follow Camera",
              "tier": "presentation",
              "type": "boolean"
            },
            "platforms": {
              "default": [
                {
                  "height": 1.0,
                  "type": "ground",
                  "width": 1.0,
                  "x": 1.0,
                  "y": 1.0
                }
              ],
              "description": "Static platforms / level geometry",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerCanvasPlatformsItem]"
            },
            "player": {
              "default": {
                "facingRight": false,
                "grounded": false,
                "height": 1.0,
                "vx": 1.0,
                "vy": 1.0,
                "width": 1.0,
                "x": 1.0,
                "y": 1.0
              },
              "description": "Player state data",
              "label": "Player",
              "properties": {
                "facingRight": {
                  "name": "facingRight",
                  "required": false,
                  "type": "boolean"
                },
                "grounded": {
                  "name": "grounded",
                  "required": false,
                  "type": "boolean"
                },
                "height": {
                  "name": "height",
                  "required": false,
                  "type": "number"
                },
                "vx": {
                  "name": "vx",
                  "required": false,
                  "type": "number"
                },
                "vy": {
                  "name": "vy",
                  "required": false,
                  "type": "number"
                },
                "width": {
                  "name": "width",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "tier": "presentation",
              "type": "PlatformerCanvasPlayer"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/platformer/characters/platformChar_idle.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": {},
              "description": "Map of platform type to tile sprite URL",
              "items": {
                "type": "string"
              },
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "Map<string,asset>"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "worldHeight prop",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World dimensions",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Event names for keyboard controls",
              "event": "LEFT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "rightEvent prop",
              "event": "RIGHT",
              "payloadSchema": [
                {
                  "name": "direction",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "jumpEvent prop",
              "event": "JUMP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "stopEvent prop",
              "event": "STOP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerCanvasItem",
          "name": "PlatformerCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Event names for keyboard controls",
                "key": "LEFT",
                "name": "Left",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "rightEvent prop",
                "key": "RIGHT",
                "name": "Right",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "jumpEvent prop",
                "key": "JUMP",
                "name": "Jump",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "stopEvent prop",
                "key": "STOP",
                "name": "Stop",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "backgroundImage": "@config.backgroundImage",
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "className": "@config.className",
                      "followCamera": "@config.followCamera",
                      "jumpEvent": "JUMP",
                      "leftEvent": "LEFT",
                      "platforms": "@config.platforms",
                      "player": "@config.player",
                      "playerSprite": "@config.playerSprite",
                      "rightEvent": "RIGHT",
                      "stopEvent": "STOP",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-canvas",
                      "worldHeight": "@config.worldHeight",
                      "worldWidth": "@config.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}