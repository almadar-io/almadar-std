{
  "description": "PlatformerCanvas — model-authoritative platformer physics; 33ms tick owns gravity+integration+AABB collision; canvas interpolates from player/platforms props.",
  "name": "ui-platformer-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
