                                  "fill": "#22c55e",
                                  "height": 0.12,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": [
                                    "*",
                                    0.8,
                                    [
                                      "/",
                                      [
                                        "object/get",
                                        "@u",
                                        "health"
                                      ],
                                      [
                                        "object/get",
                                        "@u",
                                        "maxHealth"
                                      ]
                                    ]
                                  ]
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "color": "#ffffff",
                                  "offsetY": -0.85,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "text": [
                                    "object/get",
                                    "@u",
                                    "name"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.fx",
                              [
                                "fn",
                                "f",
                                {
                                  "color": "#ffe066",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ]
                                  },
                                  "text": [
                                    "object/get",
                                    "@f",
                                    "message"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          }
                        ],
                        "mode": "3d",
                        "tileClickEvent": "TILE_CLICK",
                        "type": "canvas",
                        "unitClickEvent": "UNIT_CLICK",
                        "unitScale": "@config.unitScale"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            "array/concat",
                            [
                              {
                                "label": "Wood",
                                "value": "@entity.wood"
                              },
                              {
                                "label": "Stone",
                                "value": "@entity.stone"
                              },
                              {
                                "label": "Energy",
                                "value": "@entity.movesLeft"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "@config.extraStats"
                          ],
                          "type": "game-hud"
                        },
                        {
                          "action": "BUILD_CAMP",
                          "label": "Build Camp",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            },
            {
              "effects": [
                [
                  "emit",
                  "WANDER",
                  {
                    "tick": 1.0
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 900.0,
              "name": "wanderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Harvest",
          "from": "std/behaviors/std-gather"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        },
        {
          "as": "Survival",
          "from": "std/behaviors/std-survival-flow"
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}