                {
                  "name": "z",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "elevation",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CANVAS_CLICK",
              "description": "Declarative event: canvas click",
              "tier": "essential",
