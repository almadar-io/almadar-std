{
  "name": "ui-game-canvas-3d",
  "version": "1.0.0",
  "description": "GameCanvas3d — UI factory (1:1 with the @almadar/ui game-canvas-3d pattern).",
  "orbitals": [
    {
      "name": "GameCanvas3dOrbital",
      "entity": {
        "name": "GameCanvas3dItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "GameCanvas3dRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "GameCanvas3dItem",
          "emits": [
            {
              "event": "UNIT_ANIMATION",
              "description": "Callback for unit animation state change",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "type": "string"
                },
                {
                  "name": "state",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "TILE_CLICK",
