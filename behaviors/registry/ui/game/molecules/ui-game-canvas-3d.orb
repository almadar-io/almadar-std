                  "required": true
                },
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "z",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "terrain",
                  "type": "string"
                },
                {
                  "name": "elevation",
