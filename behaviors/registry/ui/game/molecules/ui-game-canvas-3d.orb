                },
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "z",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "unitType",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "team",
                  "type": "string"
                },
                {
                  "name": "faction",
                  "type": "string"
                },
                {
                  "name": "health",
                  "type": "number"
                },
                {
                  "name": "maxHealth",
                  "type": "number"
                }
              ]
            },
            {
              "event": "FEATURE_CLICK",
