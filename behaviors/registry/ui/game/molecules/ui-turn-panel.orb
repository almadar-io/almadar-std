{
  "name": "ui-turn-panel",
  "version": "1.0.0",
  "description": "TurnPanel — UI factory (1:1 with the @almadar/ui turn-panel pattern).",
  "orbitals": [
    {
      "name": "TurnPanelOrbital",
      "entity": {
        "name": "TurnPanelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TurnPanelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TurnPanelItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "maxTurns": "@config.maxTurns",
                      "activeTeam": "@config.activeTeam",
                      "className": "@config.className",
                      "currentTurn": "@config.currentTurn",
                      "phase": "@config.phase",
                      "type": "turn-panel"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "maxTurns": {
              "type": "number",
              "default": 0.0,
              "label": "Max Turns",
              "description": "Maximum number of turns",
              "tier": "presentation"
            },
            "currentTurn": {
              "type": "number",
              "default": 0.0,
              "label": "Current Turn",
              "description": "Current turn number",
              "tier": "presentation"
            },
            "activeTeam": {
              "type": "string",
              "default": "Active Team",
              "label": "Active Team",
              "description": "Active team name",
              "tier": "presentation"
            },
            "phase": {
              "type": "string",
              "default": "Phase",
              "label": "Phase",
              "description": "Current phase label",
              "tier": "presentation"
            },
            "actions": {
              "type": "[TurnPanelActionsItem]",
              "default": [
                {
                  "label": "Label",
                  "disabled": false,
                  "icon": "circle"
                }
              ],
              "label": "Actions",
              "description": "Action buttons to display",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "disabled": {
                    "name": "disabled",
                    "type": "boolean",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TurnPanelPage",
          "path": "/turn-panel",
          "traits": [
            {
              "ref": "TurnPanelRender"
            }
          ]
        }
      ]
    }
  ]
}