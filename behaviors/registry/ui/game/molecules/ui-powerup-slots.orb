{
  "description": "PowerupSlots — UI factory (1:1 with the @almadar/ui powerup-slots pattern).",
  "name": "ui-powerup-slots",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PowerupSlotsItem",
        "persistence": "runtime"
      },
      "name": "PowerupSlotsOrbital",
      "pages": [
        {
          "name": "PowerupSlotsPage",
          "path": "/powerup-slots",
          "traits": [
            {
              "ref": "PowerupSlotsRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "active": {
              "default": [
                {
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "remainingTime": 1.0
                }
              ],
              "description": "Array of active powerups",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "remainingTime": {
                    "name": "remainingTime",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Active",
              "tier": "presentation",
              "type": "[PowerupSlotsActiveItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "maxSlots": {
              "default": 4.0,
              "description": "Maximum number of powerup slots",
              "label": "Max Slots",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PowerupSlotsItem",
          "name": "PowerupSlotsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "active": "@config.active",
                      "className": "@config.className",
                      "maxSlots": "@config.maxSlots",
                      "type": "powerup-slots"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}