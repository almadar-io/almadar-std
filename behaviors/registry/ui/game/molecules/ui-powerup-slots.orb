{
  "description": "PowerupSlots — ticks down remainingTime on each active powerup; drops expired ones.",
  "name": "ui-powerup-slots",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "remainingTime": {
                  "name": "remainingTime",
                  "required": false,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "active",
            "type": "array"
          }
        ],
        "name": "PowerupSlotsItem",
        "persistence": "runtime"
      },
      "name": "PowerupSlotsOrbital",
      "pages": [
        {
          "name": "PowerupSlotsPage",
          "path": "/powerup-slots",
          "traits": [
            {
              "ref": "PowerupSlotsRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "active": {
              "default": [
                {
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "remainingTime": 1.0
                }
              ],
              "description": "Array of active powerups",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "remainingTime": {
                    "name": "remainingTime",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Active",
              "tier": "presentation",
              "type": "[PowerupSlotsActiveItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "maxSlots": {
              "default": 4.0,
              "description": "Maximum number of powerup slots",
              "label": "Max Slots",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "active"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PowerupSlotsItem",
          "name": "PowerupSlotsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.active",
                    "@config.active"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "active": "@entity.active",
                      "className": "@config.className",
                      "maxSlots": "@config.maxSlots",
                      "type": "powerup-slots"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.active",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.active",
                      [
                        "fn",
                        "p",
                        [
                          "object/merge",
                          "@p",
                          {
                            "remainingTime": [
                              "-",
                              [
                                "object/get",
                                "@p",
                                "remainingTime"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "p",
                      [
                        ">",
                        [
                          "object/get",
                          "@p",
                          "remainingTime"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "active": "@entity.active",
                    "className": "@config.className",
                    "maxSlots": "@config.maxSlots",
                    "type": "powerup-slots"
                  }
                ]
              ],
              "guard": [
                ">",
                [
                  "array/len",
                  "@entity.active"
                ],
                0.0
              ],
              "interval": 1000.0,
              "name": "powerupTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}