                  },
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "assetUrl": {
                    "animations": [
                      "idle",
                      "walk",
                      "attack",
                      "hit",
                      "death"
                    ],
                    "aspect": "1:1",
                    "category": "assetUrl",
                    "dimension": "2d",
                    "name": "assetUrl",
                    "role": "npc",
                    "style": "pixel",
