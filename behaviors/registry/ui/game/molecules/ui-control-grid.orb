                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Buttons",
              "tier": "presentation",
              "type": "[ControlGridButtonsItem]"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "directionAssets": {
              "default": {
                "item": {
                  "animations": [
                    "static"
                  ],
                  "aspect": "1:1",
                  "category": "item",
                  "dimension": "2d",
                  "name": "item",
                  "role": "item",
                  "style": "pixel",
                  "thumbnailUrl": "",
                  "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png"
                }
              },
              "description": "Per-direction sprite assets for kind='dpad' buttons (e.g. Kenny arrow PNGs). Falls back to arrow emoji.",
              "items": {
                "properties": {
                  "animations": {
                    "items": {
                      "type": "string"
                    },
                    "name": "animations",
                    "required": false,
                    "type": "array"
                  },
                  "aspect": {
                    "name": "aspect",
                    "required": false,
                    "type": "string",
                    "values": [
                      "1:1",
                      "16:9",
                      "5:7",
                      "8:1"
                    ]
                  },
                  "category": {
                    "name": "category",
                    "required": false,
                    "type": "string"
                  },
                  "dimension": {
                    "name": "dimension",
                    "required": false,
                    "type": "string",
                    "values": [
                      "2d",
                      "3d"
                    ]
                  },
                  "name": {
                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "role": {
                    "name": "role",
                    "required": false,
                    "type": "string",
                    "values": [
                      "player",
                      "enemy",
                      "npc",
                      "item",
                      "tile",
                      "projectile",
                      "effect",
                      "ui",
                      "decoration",
                      "vehicle"
                    ]
                  },
                  "style": {
                    "name": "style",
                    "required": false,
                    "type": "string",
                    "values": [
                      "pixel",
                      "vector",
                      "hd",
                      "1-bit",
                      "isometric"
                    ]
                  },
                  "thumbnailUrl": {
                    "name": "thumbnailUrl",
                    "required": false,
                    "type": "string"
                  },
                  "url": {
                    "name": "url",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Direction Assets",
              "tier": "presentation",
              "type": "Map<string,ControlGridDirectionAssetsValue>"
            },
            "directionEvent": {
              "default": "DIRECTION",
              "description": "Event-bus event emitted with `{ direction, pressed }` (kind='dpad')",
              "label": "Direction Event",
              "tier": "presentation",
              "type": "string"
            },
            "directionEvents": {
              "default": {
                "item": "Item"
              },
              "description": "Per-direction PRESS → the board's SEMANTIC event (kind='dpad'), e.g. `{ left: 'LEFT', right: 'RIGHT', up: 'JUMP' }`. Lets the d-pad emit the SAME intent events as the keyboard so the FSM stays device-agnostic.",
              "items": {
                "type": "string"
              },
              "label": "Direction Events",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "directionReleaseEvents": {
              "default": {
                "item": "Item"
              },
              "description": "Per-direction RELEASE → semantic event, e.g. `{ left: 'STOP', right: 'STOP' }`. Omit a direction to ignore its release.",
              "items": {
                "type": "string"
              },
              "label": "Direction Release Events",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "disabled": {
              "default": false,
              "description": "disabled prop",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "includeDiagonals": {
              "default": false,
              "description": "Whether to include diagonal buttons (kind='dpad')",
              "label": "Include Diagonals",
              "tier": "presentation",
              "type": "boolean"
            },
            "kind": {
              "default": "dpad",
              "description": "kind prop",
              "label": "Kind",
              "tier": "presentation",
              "type": "string",
              "values": [
                "dpad",
                "actions"
              ]
            },
            "layout": {
              "default": "horizontal",
              "description": "Layout for kind='actions'",
              "label": "Layout",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical",
                "diamond"
              ]
            },
            "onAction": {
              "default": "ACTION",
              "description": "Called when a button/direction is pressed or released",
              "label": "On Action",
              "tier": "presentation",
              "type": "string"
            },
            "onDirection": {
              "default": "DIRECTION",
              "description": "Called when a direction is pressed or released (kind='dpad' convenience overload)",
              "label": "On Direction",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when a button/direction is pressed or released",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when a direction is pressed or released (kind='dpad' convenience overload)",
              "event": "DIRECTION",
              "payloadSchema": [
                {
                  "name": "direction",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ControlGridItem",
          "name": "ControlGridRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when a button/direction is pressed or released",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when a direction is pressed or released (kind='dpad' convenience overload)",
                "key": "DIRECTION",
                "name": "Direction",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actionEvent": "@config.actionEvent",
                      "buttons": "@config.buttons",
                      "className": "@config.className",
                      "directionAssets": "@config.directionAssets",
                      "directionEvent": "@config.directionEvent",
                      "directionEvents": "@config.directionEvents",
                      "directionReleaseEvents": "@config.directionReleaseEvents",
                      "disabled": "@config.disabled",
                      "includeDiagonals": "@config.includeDiagonals",
                      "kind": "@config.kind",
                      "layout": "@config.layout",
                      "onAction": "@config.onAction",
                      "onDirection": "@config.onDirection",
                      "size": "@config.size",
                      "type": "control-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}