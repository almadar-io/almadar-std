                    "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "action buttons (kind='actions')",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
