{
  "description": "ControlGrid — UI factory (1:1 with the @almadar/ui control-grid pattern).",
  "name": "ui-control-grid",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ControlGridItem",
        "persistence": "runtime"
      },
      "name": "ControlGridOrbital",
      "pages": [
        {
          "name": "ControlGridPage",
          "path": "/control-grid",
          "traits": [
            {
              "ref": "ControlGridRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actionEvent": {
              "default": "ACTION",
              "description": "Event-bus event emitted with `{ id, pressed }` on press/release",
              "label": "Action Event",
              "tier": "presentation",
              "type": "string"
