                          "npc",
                          "item",
                          "tile",
                          "projectile",
                          "effect",
                          "ui",
                          "decoration",
                          "vehicle"
                        ]
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string",
                        "values": [
                          "pixel",
                          "vector",
                          "hd",
                          "1-bit",
                          "isometric"
                        ]
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
