                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "atlas": {
                        "name": "atlas",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "sprite": {
                        "name": "sprite",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": false,
                        "type": "string"
                      },
                      "variant": {
                        "name": "variant",
                        "required": false,
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "name": "units",
                  "required": false,
                  "type": "object"
                }
              },
              "tier": "presentation",
              "type": "AssetManifest"
            },
            "bgColor": {
              "default": "#0a0f1a",
              "description": "Canvas background color.",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "cameraMode": {
              "default": "top-down",
              "description": "3D canvas camera mode.",
              "label": "Camera Mode",
              "tier": "presentation",
              "type": "string"
            },
            "extraStats": {
              "default": [],
              "description": "Board-specific HUD stats appended after the standard set.",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Extra Stats",
              "tier": "presentation",
              "type": "[HudStat]"
            },
            "gridHeight": {
              "default": 12.0,
              "description": "Grid row count (matches HeroAuthority.gridHeight).",
              "label": "Grid Height",
              "tier": "domain",
              "type": "number"
            },
            "gridWidth": {
              "default": 12.0,
              "description": "Grid column count (matches HeroAuthority.gridWidth).",
              "label": "Grid Width",
              "tier": "domain",
              "type": "number"
            },
            "movementRange": {
              "default": 1.0,
              "description": "Max manhattan distance the hero may step per move.",
              "label": "Movement Range",
              "tier": "domain",
              "type": "number"
            },
            "objectiveLabel": {
              "default": "Objectives Left",
              "description": "HUD label for the remaining-objective counter.",
              "label": "Objective Label",
              "tier": "presentation",
              "type": "string"
            },
            "scale": {
              "default": 0.45,
              "description": "Canvas render scale.",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "scoreLabel": {
              "default": "Score",
              "description": "HUD label for the score/progress counter (e.g. Deliveries counting up).",
              "label": "Score Label",
              "tier": "presentation",
              "type": "string"
            },
            "unitScale": {
              "default": 1.0,
              "description": "Unit draw-size multiplier.",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Hero move intent applied by the hero-nav authority",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Advances neutral NPCs one random step via the hero-nav authority",
              "event": "WANDER",
              "payloadSchema": [
                {
                  "name": "tick",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resets every mechanic (units/budget, objectives, result) for a new round",
              "event": "RESTART",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "tileClickEvent prop",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "tileId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "unitClickEvent prop",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Clears the current selection",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GameState",
          "name": "HeroIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "unitClickEvent prop",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "tileClickEvent prop",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears the current selection",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              },
              {
                "description": "Hero move intent applied by the hero-nav authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Advances neutral NPCs one random step via the hero-nav authority",
                "key": "WANDER",
                "name": "Wander",
                "payloadSchema": [
                  {
                    "name": "tick",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets every mechanic (units/budget, objectives, result) for a new round",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "backgroundColor": "@config.bgColor",
                          "camera": {
                            "mode": "@config.cameraMode",
                            "zoom": "@config.scale"
                          },
                          "children": [
                            {
                              "items": [
                                "array/filter",
                                [
                                  "array/map",
                                  "@entity.tiles",
                                  [
                                    "fn",
                                    "t",
                                    {
                                      "asset": [
                                        "if",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@t",
                                            "modelUrl"
                                          ],
                                          "url"
                                        ],
                                        [
                                          "object/get",
                                          "@t",
                                          "modelUrl"
                                        ],
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@config.assetManifest",
                                            "terrains"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "terrain"
                                          ]
                                        ]
                                      ],
                                      "position": {
                                        "x": [
                                          "object/get",
                                          "@t",
                                          "x"
                                        ],
                                        "y": [
                                          "object/get",
                                          "@t",
                                          "y"
                                        ]
                                      },
                                      "type": "draw-sprite"
                                    }
                                  ]
                                ],
                                [
                                  "fn",
                                  "s",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@s",
                                      "asset"
                                    ],
                                    "url"
                                  ]
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@f",
                                      "assetUrl"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.validMoves",
                                [
                                  "fn",
                                  "m",
                                  {
                                    "fill": "rgba(74,222,128,0.4)",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@m",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@m",
                                        "z"
                                      ]
                                    },
                                    "shape": "cell",
                                    "type": "draw-shape"
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/filter",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@u",
                                        "id"
                                      ],
                                      "@entity.selectedUnitId"
                                    ]
                                  ]
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "radiusX": 0.5,
                                    "radiusY": 0.2,
                                    "shape": "ellipse",
                                    "stroke": "rgba(0,200,255,0.8)",
                                    "strokeWidth": 3.0,
                                    "type": "draw-shape"
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "anchor": "ground",
                                    "asset": [
                                      "object/get",
                                      "@u",
                                      "modelUrl"
                                    ],
                                    "height": 0.8,
                                    "id": [
                                      "object/get",
                                      "@u",
                                      "id"
                                    ],
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "type": "draw-sprite",
                                    "width": 0.8
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "rgba(0,0,0,0.6)",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": 0.8
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "#22c55e",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": [
                                      "*",
                                      0.8,
                                      [
                                        "/",
                                        [
                                          "object/get",
                                          "@u",
                                          "health"
                                        ],
                                        [
                                          "object/get",
                                          "@u",
                                          "maxHealth"
                                        ]
                                      ]
                                    ]
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "color": "#ffffff",
                                    "offsetY": -0.85,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "text": [
                                      "object/get",
                                      "@u",
                                      "name"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.fx",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "color": "#ffe066",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    "text": [
                                      "object/get",
                                      "@f",
                                      "message"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            }
                          ],
                          "mode": "3d",
                          "tileClickEvent": "TILE_CLICK",
                          "type": "canvas",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale"
                        }
                      ],
                      "hud": {
                        "stats": [
                          "array/concat",
                          [
                            {
                              "label": "@config.scoreLabel",
                              "value": "@entity.score"
                            },
                            {
                              "label": "@config.objectiveLabel",
                              "value": "@entity.objectivesLeft"
                            },
                            {
                              "label": "Moves",
                              "value": "@entity.movesLeft"
                            },
                            {
                              "label": "Result",
                              "value": "@entity.result"
                            }
                          ],
                          "@config.extraStats"
                        ],
                        "type": "game-hud"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "align": "center",
                          "children": [
                            {
                              "stats": [
                                {
                                  "label": "Result",
                                  "value": "@entity.result"
                                }
                              ],
                              "type": "game-hud"
                            },
                            {
                              "action": "PLAY_AGAIN",
                              "label": "Play Again",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        },
                        null
                      ],
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@config.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "MOVE",
                    {
                      "unitId": "@entity.selectedUnitId",
                      "x": "@payload.x",
                      "y": "@payload.z"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
                        },
                        "@config.gridWidth",
                        "@config.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "<=",
                          [
                            "grid/manhattan-distance",
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    "@u.id",
                                    "@entity.selectedUnitId"
                                  ]
                                ]
                              ],
                              "position"
                            ],
                            {
                              "x": "@payload.x",
                              "y": "@payload.z"
                            }
                          ],
                          "@config.movementRange"
                        ],
                        [
                          "and",
                          [
                            "==",
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ],
                              "passable"
                            ],
                            true
                          ],
                          [
                            "==",
                            [
                              "array/len",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "RESTART",
                    {
                      "id": "board"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "CANCEL",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        },
                        {
                          "action": "PLAY_AGAIN",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "children": [
                      {
                        "backgroundColor": "@config.bgColor",
                        "camera": {
                          "mode": "@config.cameraMode",
                          "zoom": "@config.scale"
                        },
                        "children": [
                          {
                            "items": [
                              "array/filter",
                              [
                                "array/map",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  {
                                    "asset": [
                                      "if",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@t",
                                          "modelUrl"
                                        ],
                                        "url"
                                      ],
                                      [
                                        "object/get",
                                        "@t",
                                        "modelUrl"
                                      ],
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@config.assetManifest",
                                          "terrains"
                                        ],
                                        [
                                          "object/get",
                                          "@t",
                                          "terrain"
                                        ]
                                      ]
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              [
                                "fn",
                                "s",
                                [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@s",
                                    "asset"
                                  ],
                                  "url"
                                ]
                              ]
                            ],
                            "type": "draw-sprite-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                {
                                  "asset": [
                                    "object/get",
                                    "@f",
                                    "assetUrl"
                                  ],
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ]
                                  },
                                  "type": "draw-sprite"
                                }
                              ]
                            ],
                            "type": "draw-sprite-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.validMoves",
                              [
                                "fn",
                                "m",
                                {
                                  "fill": "rgba(74,222,128,0.4)",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@m",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@m",
                                      "z"
                                    ]
                                  },
                                  "shape": "cell",
                                  "type": "draw-shape"
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@u",
                                      "id"
                                    ],
                                    "@entity.selectedUnitId"
                                  ]
                                ]
                              ],
                              [
                                "fn",
                                "u",
                                {
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "radiusX": 0.5,
                                  "radiusY": 0.2,
                                  "shape": "ellipse",
                                  "stroke": "rgba(0,200,255,0.8)",
                                  "strokeWidth": 3.0,
                                  "type": "draw-shape"
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "anchor": "ground",
                                  "asset": [
                                    "object/get",
                                    "@u",
                                    "modelUrl"
                                  ],
                                  "height": 0.8,
                                  "id": [
                                    "object/get",
                                    "@u",
                                    "id"
                                  ],
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "type": "draw-sprite",
                                  "width": 0.8
                                }
                              ]
                            ],
                            "type": "draw-sprite-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "fill": "rgba(0,0,0,0.6)",
                                  "height": 0.12,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": 0.8
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "fill": "#22c55e",
                                  "height": 0.12,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": [
                                    "*",
                                    0.8,
                                    [
                                      "/",
                                      [
                                        "object/get",
                                        "@u",
                                        "health"
                                      ],
                                      [
                                        "object/get",
                                        "@u",
                                        "maxHealth"
                                      ]
                                    ]
                                  ]
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "color": "#ffffff",
                                  "offsetY": -0.85,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "text": [
                                    "object/get",
                                    "@u",
                                    "name"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.fx",
                              [
                                "fn",
                                "f",
                                {
                                  "color": "#ffe066",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ]
                                  },
                                  "text": [
                                    "object/get",
                                    "@f",
                                    "message"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          }
                        ],
                        "mode": "3d",
                        "tileClickEvent": "TILE_CLICK",
                        "type": "canvas",
                        "unitClickEvent": "UNIT_CLICK",
                        "unitScale": "@config.unitScale"
                      }
                    ],
                    "hud": {
                      "stats": [
                        "array/concat",
                        [
                          {
                            "label": "@config.scoreLabel",
                            "value": "@entity.score"
                          },
                          {
                            "label": "@config.objectiveLabel",
                            "value": "@entity.objectivesLeft"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "@config.extraStats"
                      ],
                      "type": "game-hud"
                    },
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            },
            {
              "effects": [
                [
                  "emit",
                  "WANDER",
                  {
                    "tick": 1.0
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 900.0,
              "name": "wanderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Objective",
          "from": "std/behaviors/std-objective-reach"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        },
        {
          "as": "Gate",
          "from": "std/behaviors/std-objective-flow"
        }
      ]
    }
  ],
  "version": "1.0.0"
}