{
  "description": "CardHand — UI factory (1:1 with the @almadar/ui card-hand pattern).",
  "name": "ui-card-hand",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CardHandItem",
        "persistence": "runtime"
      },
      "name": "CardHandOrbital",
      "pages": [
        {
          "name": "CardHandPage",
          "path": "/card-hand",
          "traits": [
            {
              "ref": "CardHandRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "cards": {
              "default": [
                {
                  "attack": 1.0,
                  "cost": 1.0,
                  "defense": 1.0,
                  "disabled": false,
                  "iconUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "id": "Id",
                  "title": "Title"
                },
                {
                  "attack": 2.0,
                  "cost": 2.0,
                  "defense": 2.0,
                  "disabled": true,
                  "iconUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "id": "Id 2",
                  "title": "Title 2"
                }
              ],
              "description": "Cards to lay out as a horizontal hand (or grid when wrapped).",
              "items": {
                "properties": {
                  "attack": {
                    "name": "attack",
                    "required": false,
                    "type": "number"
                  },
                  "cost": {
                    "name": "cost",
                    "required": false,
                    "type": "number"
                  },
                  "defense": {
                    "name": "defense",
                    "required": false,
                    "type": "number"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "iconUrl": {
                    "name": "iconUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "title": {
                    "name": "title",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Cards",
              "tier": "presentation",
              "type": "[CardHandCardsItem]"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "emptyLabel": {
              "default": "No cards in hand",
              "description": "Empty-state label when there are no cards.",
              "label": "Empty Label",
              "tier": "presentation",
              "type": "string"
            },
            "selectedId": {
              "default": "Selected Id",
              "description": "Currently selected card id.",
              "label": "Selected Id",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Card-art size variant.",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Direct callback when a (non-disabled) card is clicked.",
              "event": "CARD_CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "cardId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CardHandItem",
          "name": "CardHandRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Direct callback when a (non-disabled) card is clicked.",
                "key": "CARD_CLICK",
                "name": "Card Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "cardId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "cardClickEvent": "CARD_CLICK",
                      "cards": "@config.cards",
                      "className": "@config.className",
                      "emptyLabel": "@config.emptyLabel",
                      "onCardClick": "CARD_CLICK",
                      "selectedId": "@config.selectedId",
                      "size": "@config.size",
                      "type": "card-hand"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}