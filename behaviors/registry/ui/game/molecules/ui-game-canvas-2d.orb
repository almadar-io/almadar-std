{
  "description": "GameCanvas2d — UI factory (1:1 with the @almadar/ui game-canvas-2d pattern).",
  "name": "ui-game-canvas-2d",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameCanvas2dItem",
        "persistence": "runtime"
      },
      "name": "GameCanvas2dOrbital",
      "pages": [
        {
          "name": "GameCanvas2dPage",
          "path": "/game-canvas-2d",
          "traits": [
            {
              "ref": "GameCanvas2dRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetBaseUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "description": "Base URL prefix for asset URLs",
              "label": "Asset Base Url",
              "tier": "presentation",
              "type": "asset"
            },
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/trait-wars/citizens/archetypes/00_base_model.png",
              "description": "Background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "drawEvent": {
              "default": "Draw Event",
              "description": "Event name emitted each draw frame with { frame } — for closed-circuit .orb integration",
              "label": "Draw Event",
              "tier": "presentation",
              "type": "string"
            },
            "fps": {
              "default": 60.0,
              "description": "Target frames per second",
              "label": "Fps",
              "tier": "presentation",
              "type": "number"
            },
            "height": {
              "default": 600.0,
              "description": "Canvas height in pixels",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "tickEvent": {
              "default": "Tick Event",
              "description": "Event name emitted each tick with { dt, frame } — for closed-circuit .orb integration",
              "label": "Tick Event",
              "tier": "presentation",
              "type": "string"
            },
            "width": {
              "default": 800.0,
              "description": "Canvas width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Called each tick with delta time in seconds",
              "event": "TICK",
              "payloadSchema": [
                {
                  "name": "dt",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameCanvas2dItem",
          "name": "GameCanvas2dRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called each tick with delta time in seconds",
                "key": "TICK",
                "name": "Tick",
                "payloadSchema": [
                  {
                    "name": "dt",
                    "type": "number"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "backgroundImage": "@config.backgroundImage",
                      "className": "@config.className",
                      "drawEvent": "@config.drawEvent",
                      "fps": "@config.fps",
                      "height": "@config.height",
                      "onTick": "TICK",
                      "tickEvent": "@config.tickEvent",
                      "type": "game-canvas-2d",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}