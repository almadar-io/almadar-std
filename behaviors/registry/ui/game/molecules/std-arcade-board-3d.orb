                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "MOVE",
                    {
                      "unitId": "@entity.selectedUnitId",
                      "x": "@payload.x",
                      "y": "@payload.z"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
