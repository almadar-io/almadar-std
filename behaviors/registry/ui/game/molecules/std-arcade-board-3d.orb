                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@config.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
