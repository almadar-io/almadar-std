                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "@config.tokensLabel",
                          "value": "@entity.tokens"
                        },
                        {
                          "label": "@config.ticketsLabel",
                          "value": "@entity.tickets"
                        },
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        },
                        {
                          "label": "Goal",
                          "value": "@config.goalText"
                        },
                        {
                          "label": "How",
                          "value": "@config.howText"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              },
                              {
                                "label": "@config.ticketsLabel",
                                "value": "@entity.tickets"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            },
            {
              "effects": [
                [
                  "emit",
                  "WANDER",
                  {
                    "tick": 1.0
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1500.0,
              "name": "wanderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Play",
          "from": "std/behaviors/std-arcade-play"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        },
        {
