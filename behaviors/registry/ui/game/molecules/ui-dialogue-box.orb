{
  "name": "ui-dialogue-box",
  "version": "1.0.0",
  "description": "DialogueBox — UI factory (1:1 with the @almadar/ui dialogue-box pattern).",
  "orbitals": [
    {
      "name": "DialogueBoxOrbital",
      "entity": {
        "name": "DialogueBoxItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DialogueBoxRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "DialogueBoxItem",
          "emits": [
            {
              "event": "COMPLETE",
              "description": "Called when text animation completes",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CHOICE",
              "description": "Called when a choice is selected",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "choice",
                  "type": "object",
                  "properties": [
                    {
                      "name": "text",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "action",
                      "type": "string"
                    },
                    {
                      "name": "next",
                      "type": "string"
                    },
                    {
                      "name": "disabled",
                      "type": "boolean"
                    }
                  ]
                }
              ]
            },
            {
              "event": "ADVANCE",
              "description": "Called when dialogue is advanced (no choices)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "description": "Called when text animation completes",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHOICE",
                "name": "Choice",
                "description": "Called when a choice is selected",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "choice",
                    "type": "object",
                    "properties": [
                      {
                        "name": "text",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "action",
                        "type": "string"
                      },
                      {
                        "name": "next",
                        "type": "string"
                      },
                      {
                        "name": "disabled",
                        "type": "boolean"
                      }
                    ]
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "description": "Called when dialogue is advanced (no choices)",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "choiceEvent": "CHOICE",
                      "onChoice": "CHOICE",
                      "position": "@config.position",
                      "className": "@config.className",
                      "dialogue": "@config.dialogue",
                      "onComplete": "COMPLETE",
                      "type": "dialogue-box",
                      "onAdvance": "ADVANCE",
                      "advanceEvent": "ADVANCE",
                      "typewriterSpeed": "@config.typewriterSpeed",
                      "completeEvent": "COMPLETE"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "typewriterSpeed": {
              "type": "number",
              "default": 30.0,
              "label": "Typewriter Speed",
              "description": "Typewriter speed in ms per character (0 = instant)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Optional className",
              "tier": "presentation"
            },
            "dialogue": {
              "type": "DialogueBoxDialogue",
              "default": {
                "id": "Id",
                "portrait": "Portrait",
                "text": "Text",
                "speaker": "Speaker",
                "choices": [
                  {
                    "disabled": false,
                    "next": "Next",
                    "action": "Action",
                    "text": "Text"
                  }
                ],
                "autoAdvance": 1.0
              },
              "label": "Dialogue",
              "description": "Current dialogue node to display",
              "tier": "presentation",
              "properties": {
                "speaker": {
                  "name": "speaker",
                  "type": "string",
                  "required": true
                },
                "choices": {
                  "name": "choices",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "name": "text",
                        "type": "string",
                        "required": true
                      },
                      "action": {
                        "name": "action",
                        "type": "string",
                        "required": false
                      },
                      "next": {
                        "name": "next",
                        "type": "string",
                        "required": false
                      },
                      "disabled": {
                        "name": "disabled",
                        "type": "boolean",
                        "required": false
                      }
                    }
                  }
                },
                "autoAdvance": {
                  "name": "autoAdvance",
                  "type": "number",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": false
                },
                "text": {
                  "name": "text",
                  "type": "string",
                  "required": true
                },
                "portrait": {
                  "name": "portrait",
                  "type": "string",
                  "required": false
                }
              }
            },
            "position": {
              "type": "string",
              "default": "bottom",
              "label": "Position",
              "description": "Position of dialogue box",
              "tier": "presentation",
              "values": [
                "top",
                "bottom"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DialogueBoxPage",
          "path": "/dialogue-box",
          "traits": [
            {
              "ref": "DialogueBoxRender"
            }
          ]
        }
      ]
    }
  ]
}