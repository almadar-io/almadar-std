{
  "description": "DialogueBox — UI factory (1:1 with the @almadar/ui dialogue-box pattern).",
  "name": "ui-dialogue-box",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DialogueBoxItem",
        "persistence": "runtime"
      },
      "name": "DialogueBoxOrbital",
      "pages": [
        {
          "name": "DialogueBoxPage",
          "path": "/dialogue-box",
          "traits": [
            {
              "ref": "DialogueBoxRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png",
              "description": "Optional full-frame scene image rendered behind the dialogue (visual-novel mode).",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Optional className",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "dialogue": {
              "default": {
                "autoAdvance": 1.0,
                "choices": [
                  {
                    "action": "Action",
                    "disabled": false,
                    "next": "Next",
                    "text": "Text"
                  }
                ],
                "id": "Id",
                "portrait": "Portrait",
                "speaker": "Speaker",
                "text": "Text"
              },
              "description": "Current dialogue node to display",
              "label": "Dialogue",
              "properties": {
                "autoAdvance": {
                  "name": "autoAdvance",
                  "required": false,
                  "type": "number"
                },
                "choices": {
                  "items": {
                    "properties": {
                      "action": {
                        "name": "action",
                        "required": false,
                        "type": "string"
                      },
                      "disabled": {
                        "name": "disabled",
                        "required": false,
                        "type": "boolean"
                      },
                      "next": {
                        "name": "next",
                        "required": false,
                        "type": "string"
                      },
                      "text": {
                        "name": "text",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "name": "choices",
                  "required": false,
                  "type": "array"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "portrait": {
                  "name": "portrait",
                  "required": false,
                  "type": "string"
                },
                "speaker": {
                  "name": "speaker",
                  "required": true,
                  "type": "string"
                },
                "text": {
                  "name": "text",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "DialogueBoxDialogue"
            },
            "portraitScale": {
              "default": 1.0,
              "description": "Multiplier for the large `portraitUrl` height relative to its default (default 1).",
              "label": "Portrait Scale",
              "tier": "presentation",
              "type": "number"
            },
            "portraitUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png",
              "description": "Optional larger character portrait rendered standing over the scene (visual-novel mode).",
              "label": "Portrait Url",
              "tier": "presentation",
              "type": "asset"
            },
            "position": {
              "default": "bottom",
              "description": "Position of dialogue box",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom"
              ]
            },
            "typewriterSpeed": {
              "default": 30.0,
              "description": "Typewriter speed in ms per character (0 = instant)",
              "label": "Typewriter Speed",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Called when text animation completes",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when a choice is selected",
              "event": "CHOICE",
              "payloadSchema": [
                {
                  "name": "choice",
                  "properties": [
                    {
                      "name": "text",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "action",
                      "type": "string"
                    },
                    {
                      "name": "next",
                      "type": "string"
                    },
                    {
                      "name": "disabled",
                      "type": "boolean"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when dialogue is advanced (no choices)",
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DialogueBoxItem",
          "name": "DialogueBoxRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when text animation completes",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when a choice is selected",
                "key": "CHOICE",
                "name": "Choice",
                "payloadSchema": [
                  {
                    "name": "choice",
                    "properties": [
                      {
                        "name": "text",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "action",
                        "type": "string"
                      },
                      {
                        "name": "next",
                        "type": "string"
                      },
                      {
                        "name": "disabled",
                        "type": "boolean"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when dialogue is advanced (no choices)",
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "backgroundImage": "@config.backgroundImage",
                      "choiceEvent": "CHOICE",
                      "className": "@config.className",
                      "completeEvent": "COMPLETE",
                      "dialogue": "@config.dialogue",
                      "onAdvance": "ADVANCE",
                      "onChoice": "CHOICE",
                      "onComplete": "COMPLETE",
                      "portraitScale": "@config.portraitScale",
                      "portraitUrl": "@config.portraitUrl",
                      "position": "@config.position",
                      "type": "dialogue-box",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}