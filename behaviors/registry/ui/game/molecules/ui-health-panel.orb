{
  "description": "HealthPanel — UI factory (1:1 with the @almadar/ui health-panel pattern).",
  "name": "ui-health-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "HealthPanelItem",
        "persistence": "runtime"
      },
      "name": "HealthPanelOrbital",
      "pages": [
        {
          "name": "HealthPanelPage",
          "path": "/health-panel",
          "traits": [
            {
              "ref": "HealthPanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "current": {
              "default": 75.0,
              "description": "Current health value",
              "label": "Current",
              "tier": "presentation",
              "type": "number"
            },
            "effects": {
              "default": [
                {
                  "icon": "circle",
                  "label": "Label",
                  "variant": "buff"
                },
                {
                  "icon": "circle",
                  "label": "Label 2",
                  "variant": "debuff"
                }
              ],
              "description": "Active status effects displayed as small badges",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "buff",
                      "debuff",
                      "neutral"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Effects",
              "tier": "presentation",
              "type": "[HealthPanelEffectsItem]"
            },
            "label": {
              "default": "Player HP",
              "description": "Label shown above the bar",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "max": {
              "default": 100.0,
              "description": "Maximum health value",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "shield": {
              "default": 20.0,
              "description": "Shield/armor points",
              "label": "Shield",
              "tier": "presentation",
              "type": "number"
            },
            "showNumbers": {
              "default": true,
              "description": "Whether to display numeric HP values",
              "label": "Show Numbers",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HealthPanelItem",
          "name": "HealthPanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "current": "@config.current",
                      "effects": "@config.effects",
                      "label": "@config.label",
                      "max": "@config.max",
                      "shield": "@config.shield",
                      "showNumbers": "@config.showNumbers",
                      "size": "@config.size",
                      "type": "health-panel"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}