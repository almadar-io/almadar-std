{
  "description": "CraftingRecipe — UI factory (1:1 with the @almadar/ui crafting-recipe pattern).",
  "name": "ui-crafting-recipe",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CraftingRecipeItem",
        "persistence": "runtime"
      },
      "name": "CraftingRecipeOrbital",
      "pages": [
        {
          "name": "CraftingRecipePage",
          "path": "/crafting-recipe",
          "traits": [
            {
              "ref": "CraftingRecipeRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "canCraft": {
              "default": true,
              "description": "Whether the player has enough ingredients to craft",
              "label": "Can Craft",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "inputs": {
              "default": [
                {
                  "available": 1.0,
                  "icon": "circle",
                  "label": "Label",
                  "required": 1.0
                }
              ],
              "description": "Input ingredients for the recipe",
              "items": {
                "properties": {
                  "available": {
                    "name": "available",
                    "required": true,
                    "type": "number"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "required": {
                    "name": "required",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Inputs",
              "tier": "presentation",
              "type": "[CraftingRecipeInputsItem]"
            },
            "output": {
              "default": {
                "icon": "circle",
                "label": "Label",
                "rarity": "Rarity"
              },
              "description": "Output item produced by the recipe",
              "label": "Output",
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "rarity": {
                  "name": "rarity",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "CraftingRecipeOutput"
            }
          },
          "emits": [
            {
              "description": "Callback when the craft button is clicked",
              "event": "CRAFT",
              "payloadSchema": [
                {
                  "name": "output",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CraftingRecipeItem",
          "name": "CraftingRecipeRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when the craft button is clicked",
                "key": "CRAFT",
                "name": "Craft",
                "payloadSchema": [
                  {
                    "name": "output",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "canCraft": "@config.canCraft",
                      "className": "@config.className",
                      "craftEvent": "CRAFT",
                      "inputs": "@config.inputs",
                      "onCraft": "CRAFT",
                      "output": "@config.output",
                      "type": "crafting-recipe"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}