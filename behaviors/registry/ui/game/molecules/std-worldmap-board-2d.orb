          "emits": [
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on hero selection or attack-target click",
              "event": "HERO_SELECT",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{tileClickEvent} with { x, y }",
              "event": "HERO_MOVE",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{advanceTurnEvent} with {} when the player passes the turn without moving",
              "event": "ADVANCE_TURN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Hero travel intent applied by the grid-tactics authority",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Hero attack intent applied by the grid-tactics authority",
              "event": "ATTACK",
              "payloadSchema": [
                {
                  "name": "targetId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Hero landed on a gold-mine feature tile; the gold atom adds its yield",
              "event": "MINE_HIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GameState",
          "name": "WorldMapIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on hero selection or attack-target click",
                "key": "HERO_SELECT",
                "name": "Hero Select",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y }",
                "key": "HERO_MOVE",
                "name": "Hero Move",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{advanceTurnEvent} with {} when the player passes the turn without moving",
                "key": "ADVANCE_TURN",
                "name": "Advance Turn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Hero travel intent applied by the grid-tactics authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Hero attack intent applied by the grid-tactics authority",
                "key": "ATTACK",
                "name": "Attack",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Hero landed on a gold-mine feature tile; the gold atom adds its yield",
                "key": "MINE_HIT",
                "name": "Mine Hit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedHeroId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.waypoints",
                    []
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          "array/concat",
                          [
                            {
                              "action": "ADVANCE_TURN",
                              "iconAsset": "@config.travelIconAsset",
                              "label": "Pass Turn",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "@config.extraAddons"
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": [
                        {
                          "camera": {
                            "zoom": "@config.scale"
                          },
                          "children": [
                            {
                              "items": [
                                "array/map",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@t",
                                      "terrainSprite"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@config.features",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@f",
                                      "sprite"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.validMoves",
                                [
                                  "fn",
                                  "m",
                                  {
                                    "fill": "rgba(74,222,128,0.4)",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@m",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@m",
                                        "y"
                                      ]
                                    },
                                    "shape": "cell",
                                    "type": "draw-shape"
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/filter",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@u",
                                        "id"
                                      ],
                                      "@entity.selectedHeroId"
                                    ]
                                  ]
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "radiusX": 0.5,
                                    "radiusY": 0.2,
                                    "shape": "ellipse",
                                    "stroke": "rgba(0,200,255,0.8)",
                                    "strokeWidth": 3.0,
                                    "type": "draw-shape"
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@u",
                                      "sprite"
                                    ],
                                    "id": [
                                      "object/get",
                                      "@u",
                                      "id"
                                    ],
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "rgba(0,0,0,0.6)",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": 0.8
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "#22c55e",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": [
                                      "*",
                                      0.8,
                                      [
                                        "/",
                                        [
                                          "object/get",
                                          "@u",
                                          "health"
                                        ],
                                        [
                                          "object/get",
                                          "@u",
                                          "maxHealth"
                                        ]
                                      ]
                                    ]
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "color": "#ffffff",
                                    "offsetY": -0.85,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "text": [
                                      "object/get",
                                      "@u",
                                      "name"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.effects",
                                [
                                  "fn",
                                  "e",
                                  {
                                    "asset": [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@config.assetManifest",
                                        "effects"
                                      ],
                                      [
                                        "object/get",
                                        "@e",
                                        "key"
                                      ]
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@e",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@e",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            }
                          ],
                          "projection": "isometric",
                          "showMinimap": true,
                          "tileClickEvent": "HERO_MOVE",
                          "type": "canvas",
                          "unitClickEvent": "HERO_SELECT"
                        }
                      ],
                      "fontFamily": "@config.fontFamily",
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              "array/concat",
                              [
                                {
                                  "iconUrl": "@config.regionIconAsset",
                                  "label": "Region",
                                  "value": "@config.region"
                                },
                                {
                                  "iconUrl": "@config.turnIconAsset",
                                  "label": "Turn",
                                  "value": "@entity.turn"
                                },
                                {
                                  "iconUrl": "@config.goldIconAsset",
                                  "label": "Gold",
                                  "value": "@entity.gold"
                                }
                              ],
                              "@config.extraStats"
                            ],
                            "type": "game-hud"
                          },
                          {
                            "camera": {
                              "zoom": 0.08
                            },
                            "children": [
                              {
                                "items": [
                                  "array/map",
                                  "@entity.tiles",
                                  [
                                    "fn",
                                    "t",
                                    {
                                      "fill": [
                                        "if",
                                        [
                                          "object/get",
                                          "@t",
                                          "passable"
                                        ],
                                        "rgba(120,140,120,0.75)",
                                        "rgba(50,50,55,0.85)"
                                      ],
                                      "position": {
                                        "x": [
                                          "object/get",
                                          "@t",
                                          "x"
                                        ],
                                        "y": [
                                          "object/get",
                                          "@t",
                                          "y"
                                        ]
                                      },
                                      "shape": "cell",
                                      "type": "draw-shape"
                                    }
                                  ]
                                ],
                                "type": "draw-shape-layer"
                              },
                              {
                                "items": [
                                  "array/map",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    {
                                      "fill": [
                                        "if",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            "@u",
                                            "team"
                                          ],
                                          "player"
                                        ],
                                        "#4ade80",
                                        "#f87171"
                                      ],
                                      "position": [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "radiusX": 0.35,
