                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": "@config.hudBackgroundAsset",
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "options": [],
                        "subtitle": [
                          "if",
                          [
                            "==",
                            "@entity.result",
                            "victory"
                          ],
                          "The realm is secured",
                          "Your heroes have fallen"
                        ],
                        "title": [
                          "if",
                          [
                            "==",
                            "@entity.result",
                            "victory"
                          ],
                          "VICTORY",
                          "DEFEAT"
                        ],
                        "type": "game-menu"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Tactics",
          "from": "std/behaviors/std-grid-tactics"
        },
        {
          "as": "Round",
          "from": "std/behaviors/std-round-flow"
        },
        {
          "as": "Gold",
          "from": "std/behaviors/std-gold"
        }
      ]
    }
  ],
  "version": "1.0.0"
}