{
  "name": "ui-inventory-panel",
  "version": "1.0.0",
  "description": "InventoryPanel — UI factory (1:1 with the @almadar/ui inventory-panel pattern).",
  "orbitals": [
    {
      "name": "InventoryPanelOrbital",
      "entity": {
        "name": "InventoryPanelItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "InventoryPanelRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "InventoryPanelItem",
          "emits": [
            {
              "event": "SELECT_SLOT",
              "description": "Called when a slot is selected",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "index",
                  "type": "number"
                }
              ]
            },
            {
              "event": "USE_ITEM",
              "description": "Called when an item is used (double-click or Enter)",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "item",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "type",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "quantity",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "sprite",
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    }
                  ]
                }
              ]
            },
            {
              "event": "DROP_ITEM",
              "description": "Called when an item is dropped",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "item",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "type",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "quantity",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "sprite",
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    }
                  ]
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "description": "Called when a slot is selected",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "USE_ITEM",
                "name": "Use Item",
                "description": "Called when an item is used (double-click or Enter)",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "type",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "quantity",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "sprite",
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "description",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "key": "DROP_ITEM",
                "name": "Drop Item",
                "description": "Called when an item is dropped",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "type",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "quantity",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "sprite",
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "description",
                        "type": "string"
                      }
                    ]
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "selectedSlot": "@config.selectedSlot",
                      "columns": "@config.columns",
                      "onUseItem": "USE_ITEM",
                      "type": "inventory-panel",
                      "showTooltips": "@config.showTooltips",
                      "onDropItem": "DROP_ITEM",
                      "useItemEvent": "USE_ITEM",
                      "className": "@config.className",
                      "items": "@config.items",
                      "slots": "@config.slots",
                      "dropItemEvent": "DROP_ITEM",
                      "selectSlotEvent": "SELECT_SLOT",
                      "slotSize": "@config.slotSize",
                      "onSelectSlot": "SELECT_SLOT"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[InventoryPanelItemsItem]",
              "default": [
                {
                  "sprite": "Sprite",
                  "name": "Name",
                  "id": "Id",
                  "type": "Type",
                  "quantity": 1.0,
                  "description": "Description"
                }
              ],
              "label": "Items",
              "description": "Array of items in inventory",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "quantity": {
                    "name": "quantity",
                    "type": "number",
                    "required": true
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true
                  },
                  "sprite": {
                    "name": "sprite",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "selectedSlot": {
              "type": "number",
              "default": 0.0,
              "label": "Selected Slot",
              "description": "Currently selected slot index",
              "tier": "presentation"
            },
            "showTooltips": {
              "type": "boolean",
              "default": true,
              "label": "Show Tooltips",
              "description": "Show item tooltips on hover",
              "tier": "presentation"
            },
            "slots": {
              "type": "number",
              "default": 0.0,
              "label": "Slots",
              "description": "Total number of slots",
              "tier": "presentation"
            },
            "slotSize": {
              "type": "number",
              "default": 48.0,
              "label": "Slot Size",
              "description": "Slot size in pixels",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Optional className",
              "tier": "presentation"
            },
            "columns": {
              "type": "number",
              "default": 0.0,
              "label": "Columns",
              "description": "Number of columns in grid",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InventoryPanelPage",
          "path": "/inventory-panel",
          "traits": [
            {
              "ref": "InventoryPanelRender"
            }
          ]
        }
      ]
    }
  ]
}