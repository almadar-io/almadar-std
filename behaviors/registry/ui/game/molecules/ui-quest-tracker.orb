{
  "description": "QuestTracker — UI factory (1:1 with the @almadar/ui quest-tracker pattern).",
  "name": "ui-quest-tracker",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "QuestTrackerItem",
        "persistence": "runtime"
      },
      "name": "QuestTrackerOrbital",
      "pages": [
        {
          "name": "QuestTrackerPage",
          "path": "/quest-tracker",
          "traits": [
            {
              "ref": "QuestTrackerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeQuestId": {
              "default": "Active Quest Id",
              "description": "ID of the currently active quest",
              "label": "Active Quest Id",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "quests": {
              "default": [
                {
                  "active": false,
                  "completed": false,
                  "id": "Id",
                  "maxProgress": 1.0,
                  "progress": 1.0,
                  "title": "Title"
                }
              ],
              "description": "Array of quests to display",
              "items": {
                "properties": {
                  "active": {
                    "name": "active",
                    "required": false,
                    "type": "boolean"
                  },
                  "completed": {
                    "name": "completed",
                    "required": false,
                    "type": "boolean"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "maxProgress": {
                    "name": "maxProgress",
                    "required": true,
                    "type": "number"
                  },
                  "progress": {
                    "name": "progress",
                    "required": true,
                    "type": "number"
                  },
                  "title": {
                    "name": "title",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Quests",
              "tier": "presentation",
              "type": "[QuestTrackerQuestsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "QuestTrackerItem",
          "name": "QuestTrackerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeQuestId": "@config.activeQuestId",
                      "className": "@config.className",
                      "quests": "@config.quests",
                      "type": "quest-tracker"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}