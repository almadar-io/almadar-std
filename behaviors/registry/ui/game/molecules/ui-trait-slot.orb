{
  "description": "TraitSlot — UI factory (1:1 with the @almadar/ui trait-slot pattern).",
  "name": "ui-trait-slot",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "slotNumber",
            "type": "number"
          }
        ],
        "name": "TraitSlotItem",
        "persistence": "runtime"
      },
      "name": "TraitSlotOrbital",
      "pages": [
        {
          "name": "TraitSlotPage",
          "path": "/trait-slot",
          "traits": [
            {
              "ref": "TraitSlotRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "categoryColors": {
              "default": {},
              "description": "Category → color mapping",
              "items": {
                "properties": {
                  "bg": {
                    "name": "bg",
                    "required": true,
                    "type": "string"
                  },
                  "border": {
                    "name": "border",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Category Colors",
              "tier": "presentation",
              "type": "Map<string,TraitSlotCategoryColorsValue>"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "clickEvent": {
              "default": "CLICK",
              "description": "-- Declarative events --",
              "label": "Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "draggable": {
              "default": false,
              "description": "Whether this slot's equipped item is draggable",
              "label": "Draggable",
              "tier": "presentation",
              "type": "boolean"
            },
            "dropEvent": {
              "default": "DROP",
              "description": "Emits UI:{dropEvent} with { slotNumber, itemId } when an item is dropped into this slot",
              "label": "Drop Event",
              "tier": "presentation",
              "type": "string"
            },
            "equippedItem": {
              "default": {
                "category": "Category",
                "description": "Description",
                "iconEmoji": "Icon Emoji",
                "iconUrl": {
                  "animations": [
                    "static"
                  ],
                  "aspect": "1:1",
                  "category": "iconUrl",
                  "dimension": "2d",
                  "name": "iconUrl",
                  "role": "ui",
                  "style": "pixel",
                  "thumbnailUrl": "",
                  "url": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png"
                },
                "id": "Id",
                "name": "Name"
              },
              "description": "Currently equipped item, if any",
              "label": "Equipped Item",
              "properties": {
                "category": {
                  "name": "category",
                  "required": true,
                  "type": "string"
                },
                "description": {
                  "name": "description",
                  "required": false,
                  "type": "string"
                },
                "iconEmoji": {
                  "name": "iconEmoji",
                  "required": false,
                  "type": "string"
                },
                "iconUrl": {
                  "name": "iconUrl",
                  "properties": {
                    "animations": {
                      "items": {
                        "type": "string"
                      },
                      "name": "animations",
                      "required": false,
                      "type": "array"
                    },
                    "aspect": {
                      "name": "aspect",
                      "required": false,
                      "type": "string",
                      "values": [
                        "1:1",
                        "16:9",
                        "5:7",
                        "8:1"
                      ]
                    },
                    "category": {
                      "name": "category",
                      "required": false,
                      "type": "string"
                    },
                    "dimension": {
                      "name": "dimension",
                      "required": false,
                      "type": "string",
                      "values": [
                        "2d",
                        "3d"
                      ]
                    },
                    "name": {
                      "name": "name",
                      "required": false,
                      "type": "string"
                    },
                    "role": {
                      "name": "role",
                      "required": false,
                      "type": "string",
                      "values": [
                        "player",
                        "enemy",
                        "npc",
                        "item",
                        "tile",
                        "projectile",
                        "effect",
                        "ui",
                        "decoration",
                        "vehicle"
                      ]
                    },
                    "style": {
                      "name": "style",
                      "required": false,
                      "type": "string",
                      "values": [
                        "pixel",
                        "vector",
                        "hd",
                        "1-bit",
                        "isometric"
                      ]
                    },
                    "thumbnailUrl": {
                      "name": "thumbnailUrl",
                      "required": false,
                      "type": "string"
                    },
                    "url": {
                      "name": "url",
                      "required": true,
                      "type": "string"
                    }
                  },
                  "required": false,
                  "type": "object"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "stateMachine": {
                  "name": "stateMachine",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "TraitSlotEquippedItem"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "TraitSlotError"
            },
            "feedback": {
              "default": "correct",
              "description": "Per-slot correctness feedback after a failed attempt",
              "label": "Feedback",
              "tier": "presentation",
              "type": "string",
              "values": [
                "correct",
                "wrong"
              ]
            },
            "isLoading": {
              "default": false,
