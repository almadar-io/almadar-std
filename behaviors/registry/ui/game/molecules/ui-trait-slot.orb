              "label": "On Item Drop",
              "tier": "presentation",
              "type": "string"
            },
            "onRemove": {
              "default": "REMOVE",
              "description": "Remove handler",
              "label": "On Remove",
              "tier": "presentation",
              "type": "string"
            },
            "removeEvent": {
              "default": "REMOVE",
              "description": "Emits UI:{removeEvent} with { slotNumber }",
              "label": "Remove Event",
              "tier": "presentation",
              "type": "string"
            },
            "selected": {
              "default": false,
              "description": "Whether slot is selected",
              "label": "Selected",
              "tier": "presentation",
              "type": "boolean"
            },
            "showTooltip": {
              "default": true,
              "description": "Show tooltip on hover",
              "label": "Show Tooltip",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "slotNumber": {
              "default": 1.0,
              "description": "Slot index (1-based)",
              "label": "Slot Number",
              "tier": "presentation",
              "type": "number"
            },
            "tooltipFrameUrl": {
              "default": {
