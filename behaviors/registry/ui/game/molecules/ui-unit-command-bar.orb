{
  "description": "UnitCommandBar — UI factory (1:1 with the @almadar/ui unit-command-bar pattern).",
  "name": "ui-unit-command-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "UnitCommandBarItem",
        "persistence": "runtime"
      },
      "name": "UnitCommandBarOrbital",
      "pages": [
        {
          "name": "UnitCommandBarPage",
          "path": "/unit-command-bar",
          "traits": [
            {
              "ref": "UnitCommandBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "commands": {
              "default": [
                {
                  "disabled": false,
                  "hotkey": "Hotkey",
                  "icon": "circle",
                  "label": "Label"
                }
              ],
              "description": "Available commands",
              "items": {
                "properties": {
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "hotkey": {
                    "name": "hotkey",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Commands",
              "tier": "presentation",
              "type": "[UnitCommandBarCommandsItem]"
            },
            "selectedUnitId": {
              "default": "unit-1",
              "description": "ID of the currently selected unit",
              "label": "Selected Unit Id",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "UnitCommandBarItem",
          "name": "UnitCommandBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "commands": "@config.commands",
                      "selectedUnitId": "@config.selectedUnitId",
                      "type": "unit-command-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}