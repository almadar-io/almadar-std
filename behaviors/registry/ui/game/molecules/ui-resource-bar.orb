{
  "description": "ResourceBar — UI factory (1:1 with the @almadar/ui resource-bar pattern).",
  "name": "ui-resource-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ResourceBarItem",
        "persistence": "runtime"
      },
      "name": "ResourceBarOrbital",
      "pages": [
        {
          "name": "ResourceBarPage",
          "path": "/resource-bar",
          "traits": [
            {
              "ref": "ResourceBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "resources": {
              "default": [
                {
                  "icon": "circle",
                  "label": "Label",
                  "max": 1.0,
                  "value": 1.0
                }
              ],
              "description": "Resources to display",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "max": {
                    "name": "max",
                    "required": false,
                    "type": "number"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Resources",
              "tier": "presentation",
              "type": "[ResourceBarResourcesItem]"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ResourceBarItem",
          "name": "ResourceBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "resources": "@config.resources",
                      "size": "@config.size",
                      "type": "resource-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}