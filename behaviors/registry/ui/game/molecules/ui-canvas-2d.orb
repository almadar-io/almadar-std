            "projection": {
              "default": "isometric",
              "description": "--- Projection ---",
              "label": "Projection",
              "tier": "presentation",
              "type": "string",
              "values": [
                "isometric",
                "hex",
                "flat",
                "free",
                "side"
              ]
            },
            "scale": {
              "default": 0.4,
              "description": "Render scale (0.4 = 40% zoom). Ignored by `free`/`side` (world-pixel-direct).",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "showMinimap": {
              "default": true,
              "description": "Toggle minimap overlay.",
              "label": "Show Minimap",
              "tier": "presentation",
              "type": "boolean"
