{
  "name": "ui-isometric-canvas",
  "version": "1.0.0",
  "description": "IsometricCanvas — UI factory (1:1 with the @almadar/ui isometric-canvas pattern).",
  "orbitals": [
    {
      "name": "IsometricCanvasOrbital",
      "entity": {
        "name": "IsometricCanvasItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "IsometricCanvasRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "IsometricCanvasItem",
          "emits": [
            {
              "event": "TILE_CLICK",
              "description": "--- Event handlers (legacy callbacks — prefer declarative event string props below) ---",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ]
            },
            {
              "event": "UNIT_CLICK",
              "description": "onUnitClick prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TILE_HOVER",
              "description": "onTileHover prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TILE_LEAVE",
              "description": "onTileLeave prop",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "description": "--- Event handlers (legacy callbacks — prefer declarative event string props below) ---",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "description": "onUnitClick prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TILE_HOVER",
                "name": "Tile Hover",
                "description": "onTileHover prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TILE_LEAVE",
                "name": "Tile Leave",
                "description": "onTileLeave prop",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "tileHoverEvent": "TILE_HOVER",
                      "className": "@config.className",
                      "enableCamera": "@config.enableCamera",
                      "tileClickEvent": "TILE_CLICK",
                      "hoveredTile": "@config.hoveredTile",
                      "debug": "@config.debug",
                      "unitScale": "@config.unitScale",
                      "assetBaseUrl": "@config.assetBaseUrl",
                      "onTileHover": "TILE_HOVER",
                      "tiles": "@config.tiles",
                      "onUnitClick": "UNIT_CLICK",
                      "error": "@config.error",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "assetManifest": "@config.assetManifest",
                      "isLoading": "@config.isLoading",
                      "onTileLeave": "TILE_LEAVE",
                      "boardWidth": "@config.boardWidth",
                      "boardHeight": "@config.boardHeight",
                      "showMinimap": "@config.showMinimap",
                      "diamondTopY": "@config.diamondTopY",
                      "type": "isometric-canvas",
                      "validMoves": "@config.validMoves",
                      "onTileClick": "TILE_CLICK",
                      "backgroundImage": "@config.backgroundImage",
                      "attackTargets": "@config.attackTargets",
                      "features": "@config.features",
                      "scale": "@config.scale",
                      "units": "@config.units",
                      "selectedUnitId": "@config.selectedUnitId",
                      "unitClickEvent": "UNIT_CLICK",
                      "tileLeaveEvent": "TILE_LEAVE",
                      "hasActiveEffects": "@config.hasActiveEffects"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "error": {
              "type": "IsometricCanvasError",
              "label": "Error",
              "description": "Error state",
              "tier": "presentation",
              "properties": {
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                },
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                }
              }
            },
            "features": {
              "type": "[IsometricCanvasFeaturesItem]",
              "default": [],
              "label": "Features",
              "description": "Array of features (resources, portals, buildings, etc.)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "z": {
                    "name": "z",
                    "type": "number",
                    "required": false
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  "sprite": {
                    "name": "sprite",
                    "type": "string",
                    "required": false
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "assetUrl": {
                    "name": "assetUrl",
                    "type": "string",
                    "required": false
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "elevation": {
                    "name": "elevation",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "attackTargets": {
              "type": "[IsometricCanvasAttackTargetsItem]",
              "default": [],
              "label": "Attack Targets",
              "description": "Attack target positions (shown as pulsing red highlights)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "validMoves": {
              "type": "[IsometricCanvasValidMovesItem]",
              "default": [],
              "label": "Valid Moves",
              "description": "Valid move positions (shown as pulsing green highlights)",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "showMinimap": {
              "type": "boolean",
              "default": true,
              "label": "Show Minimap",
              "description": "Toggle minimap overlay",
              "tier": "presentation"
            },
            "boardHeight": {
              "type": "number",
              "default": 0.0,
              "label": "Board Height",
              "description": "Board height in tiles (overrides tile-derived size)",
              "tier": "presentation"
            },
            "hasActiveEffects": {
              "type": "boolean",
              "default": false,
              "label": "Has Active Effects",
              "description": "Whether there are active effects — keeps RAF loop alive",
              "tier": "presentation"
            },
            "effectSpriteUrls": {
              "type": "[string]",
              "default": [],
              "label": "Effect Sprite Urls",
              "description": "Additional sprite URLs to preload (e.g., effect sprites)",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "debug": {
              "type": "boolean",
              "default": false,
              "label": "Debug",
              "description": "Show debug grid lines and coordinates",
              "tier": "presentation"
            },
            "hoveredTile": {
              "type": "IsometricCanvasHoveredTile",
              "label": "Hovered Tile",
              "description": "Hovered tile position",
              "tier": "presentation",
              "properties": {
                "y": {
                  "name": "y",
                  "type": "number",
                  "required": true
                },
                "x": {
                  "name": "x",
                  "type": "number",
                  "required": true
                }
              }
            },
            "units": {
              "type": "[IsometricCanvasUnitsItem]",
              "default": [],
              "label": "Units",
              "description": "Array of units on the board",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": false
                  },
                  "traits": {
                    "name": "traits",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "states": {
                          "name": "states",
                          "type": "array",
                          "required": true,
                          "items": {
                            "type": "string"
                          }
                        },
                        "currentState": {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        "cooldown": {
                          "name": "cooldown",
                          "type": "number",
                          "required": true
                        },
                        "name": {
                          "name": "name",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  },
                  "elevation": {
                    "name": "elevation",
                    "type": "number",
                    "required": false
                  },
                  "previousPosition": {
                    "name": "previousPosition",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      },
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "unitType": {
                    "name": "unitType",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "team": {
                    "name": "team",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  },
                  "position": {
                    "name": "position",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "z": {
                    "name": "z",
                    "type": "number",
                    "required": false
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": false
                  },
                  "sprite": {
                    "name": "sprite",
                    "type": "string",
                    "required": false
                  },
                  "heroId": {
                    "name": "heroId",
                    "type": "string",
                    "required": false
                  },
                  "maxHealth": {
                    "name": "maxHealth",
                    "type": "number",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "health": {
                    "name": "health",
                    "type": "number",
                    "required": false
                  },
                  "faction": {
                    "name": "faction",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  }
                }
              }
            },
            "backgroundImage": {
              "type": "string",
              "default": "https://almadar-kflow-assets.web.app/shared/isometric-blocks/Preview.png",
              "label": "Background Image",
              "description": "Background image URL tiled behind the isometric grid",
              "tier": "presentation"
            },
            "unitScale": {
              "type": "number",
              "default": 1.0,
              "label": "Unit Scale",
              "description": "Extra scale multiplier for unit draw size. 1 = default.",
              "tier": "presentation"
            },
            "diamondTopY": {
              "type": "number",
              "default": 0.0,
              "label": "Diamond Top Y",
              "description": "Override for the diamond-top Y offset within the tile sprite (default: 374). This controls where the flat diamond face sits vertically inside the tile image.",
              "tier": "presentation"
            },
            "assetBaseUrl": {
              "type": "string",
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "label": "Asset Base Url",
              "description": "--- Remote asset loading ---",
              "tier": "presentation"
            },
            "assetManifest": {
              "type": "IsometricCanvasAssetManifest",
              "label": "Asset Manifest",
              "description": "Manifest mapping entity keys to relative sprite paths. Combined with assetBaseUrl to produce full URLs. Used as a fallback when inline URLs and callbacks don't resolve.",
              "tier": "presentation",
              "properties": {
                "units": {
                  "name": "units",
                  "type": "object",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                },
                "terrains": {
                  "name": "terrains",
                  "type": "object",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                },
                "features": {
                  "name": "features",
                  "type": "object",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                },
                "effects": {
                  "name": "effects",
                  "type": "object",
                  "required": false,
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "tiles": {
              "type": "[IsometricCanvasTilesItem]",
              "default": [],
              "label": "Tiles",
              "description": "--- Grid data ---",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": false
                  },
                  "terrain": {
                    "name": "terrain",
                    "type": "string",
                    "required": false
                  },
                  "movementCost": {
                    "name": "movementCost",
                    "type": "number",
                    "required": false
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "z": {
                    "name": "z",
                    "type": "number",
                    "required": false
                  },
                  "terrainSprite": {
                    "name": "terrainSprite",
                    "type": "string",
                    "required": false
                  },
                  "passable": {
                    "name": "passable",
                    "type": "boolean",
                    "required": false
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  "elevation": {
                    "name": "elevation",
                    "type": "number",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "tileType": {
                    "name": "tileType",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "scale": {
              "type": "number",
              "default": 0.4,
              "label": "Scale",
              "description": "--- Rendering options ---",
              "tier": "presentation"
            },
            "boardWidth": {
              "type": "number",
              "default": 0.0,
              "label": "Board Width",
              "description": "Board width in tiles (overrides tile-derived size)",
              "tier": "presentation"
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            },
            "selectedUnitId": {
              "type": "string",
              "default": "Selected Unit Id",
              "label": "Selected Unit Id",
              "description": "--- Interaction state ---",
              "tier": "presentation"
            },
            "enableCamera": {
              "type": "boolean",
              "default": true,
              "label": "Enable Camera",
              "description": "Enable camera pan/zoom controls",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "IsometricCanvasPage",
          "path": "/isometric-canvas",
          "traits": [
            {
              "ref": "IsometricCanvasRender"
            }
          ]
        }
      ]
    }
  ]
}