                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@m",
                                      "z"
                                    ]
                                  },
                                  "shape": "cell",
                                  "type": "draw-shape"
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.attackTargets",
                              [
                                "fn",
                                "a",
                                {
                                  "fill": "rgba(239,68,68,0.4)",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@a",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@a",
                                      "z"
                                    ]
                                  },
                                  "shape": "cell",
                                  "type": "draw-shape"
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@u",
                                      "id"
                                    ],
                                    "@entity.selectedUnitId"
                                  ]
                                ]
                              ],
                              [
                                "fn",
                                "u",
                                {
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "radiusX": 0.5,
                                  "radiusY": 0.2,
                                  "shape": "ellipse",
                                  "stroke": "rgba(0,200,255,0.8)",
                                  "strokeWidth": 3.0,
                                  "type": "draw-shape"
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/filter",
                              [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  {
                                    "anchor": "ground",
                                    "asset": [
                                      "if",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "modelUrl"
                                        ],
                                        "url"
                                      ],
                                      [
                                        "object/get",
                                        "@u",
                                        "modelUrl"
                                      ],
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@config.assetManifest",
                                          "units"
                                        ],
                                        [
                                          "object/get",
                                          "@u",
                                          "unitType"
                                        ]
                                      ]
                                    ],
                                    "height": 0.5,
                                    "id": [
                                      "object/get",
                                      "@u",
                                      "id"
                                    ],
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "type": "draw-sprite",
                                    "width": 0.5
                                  }
                                ]
                              ],
                              [
                                "fn",
                                "s",
                                [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@s",
                                    "asset"
                                  ],
                                  "url"
                                ]
                              ]
                            ],
                            "type": "draw-sprite-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "anchor": "ground",
                                  "fill": "rgba(0,0,0,0.6)",
                                  "height": 0.12,
                                  "offsetX": -0.25,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": 0.5
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "anchor": "ground",
                                  "fill": "#22c55e",
                                  "height": 0.12,
                                  "offsetX": -0.25,
                                  "offsetY": -0.6,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "shape": "rect",
                                  "type": "draw-shape",
                                  "width": [
                                    "*",
                                    0.5,
                                    [
                                      "/",
                                      [
                                        "object/get",
                                        "@u",
                                        "health"
                                      ],
                                      [
                                        "object/get",
                                        "@u",
                                        "maxHealth"
                                      ]
                                    ]
                                  ]
                                }
                              ]
                            ],
                            "type": "draw-shape-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                {
                                  "color": "#ffffff",
                                  "offsetY": -0.85,
                                  "position": [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "text": [
                                    "object/get",
                                    "@u",
                                    "name"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          },
                          {
                            "items": [
                              "array/map",
                              "@entity.fx",
                              [
                                "fn",
                                "f",
                                {
                                  "color": "#ffe066",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ]
                                  },
                                  "text": [
                                    "object/get",
                                    "@f",
                                    "message"
                                  ],
                                  "type": "draw-text"
                                }
                              ]
                            ],
                            "type": "draw-text-layer"
                          }
                        ],
                        "projection": "@config.projection",
                        "showMinimap": "@config.showMinimap",
                        "tileClickEvent": "TILE_CLICK",
                        "type": "canvas",
                        "unitClickEvent": "UNIT_CLICK"
                      }
                    ],
                    "hud": {
                      "stats": [
                        "array/concat",
                        [
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.uiPhase"
                          },
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          }
                        ],
                        "@config.extraStats"
                      ],
                      "type": "game-hud"
                    },
                    "hudBackgroundAsset": "@config.hudBackgroundAsset",
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Tactics",
          "from": "std/behaviors/std-grid-tactics"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        },
        {
          "as": "Round",
          "from": "std/behaviors/std-round-flow"
        },
        {
          "as": "Score",
          "from": "std/behaviors/std-score"
        }
      ]
    }
  ],
  "version": "1.0.0"
}