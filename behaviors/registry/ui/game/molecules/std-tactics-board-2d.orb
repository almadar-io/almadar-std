          "linkedEntity": "GameState",
          "name": "PlayerIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "unitClickEvent prop",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "tileClickEvent prop",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears the current selection",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "key": "END_TURN",
                "name": "End Turn"
              },
              {
                "description": "Player move intent applied by the grid-tactics authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Player attack intent applied by the grid-tactics authority",
                "key": "ATTACK",
                "name": "Attack",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Ends the player turn; the grid-tactics authority runs the enemy AI pipeline",
                "key": "AI_TURN",
                "name": "Ai Turn",
                "payloadSchema": [
                  {
                    "name": "turn",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Board-declared event name for the `extraAddons` action (e.g. Produce). Registers the call-site literal used inside `extraAddons` button descriptors in this trait's own event set.",
                "key": "@config.extraAddonEvent",
                "name": "@config.extra addon event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          "array/concat",
                          [
                            {
                              "action": "END_TURN",
                              "label": "End Turn",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "action": "CANCEL",
                              "label": "Cancel",
                              "type": "button",
                              "variant": "secondary"
                            }
                          ],
                          "@config.extraAddons"
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": [
                        {
                          "camera": {
                            "pos": {
                              "x": [
                                "/",
                                [
                                  "+",
                                  [
                                    "array/min",
                                    "@entity.tiles",
                                    "x"
                                  ],
                                  [
                                    "array/max",
                                    "@entity.tiles",
                                    "x"
                                  ]
                                ],
                                2.0
                              ],
                              "y": [
                                "/",
                                [
                                  "+",
                                  [
                                    "array/min",
                                    "@entity.tiles",
                                    "y"
                                  ],
                                  [
                                    "array/max",
                                    "@entity.tiles",
                                    "y"
                                  ]
                                ],
                                2.0
                              ]
                            },
                            "zoom": [
                              "math/min",
                              1.0,
                              [
                                "/",
                                5.0,
                                [
                                  "+",
                                  1.0,
                                  [
                                    "math/max",
                                    [
                                      "array/max",
                                      "@entity.tiles",
                                      "x"
                                    ],
                                    [
                                      "array/max",
                                      "@entity.tiles",
                                      "y"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          },
                          "children": [
                            {
                              "items": [
                                "array/map",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  {
                                    "fill": "#5c94fc",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    "shape": "cell",
                                    "stroke": "rgba(255,255,255,0.35)",
                                    "strokeWidth": 1.0,
                                    "type": "draw-shape"
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/filter",
                                [
                                  "array/map",
                                  "@entity.tiles",
                                  [
                                    "fn",
                                    "t",
                                    {
                                      "anchor": "center",
                                      "asset": [
                                        "if",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@t",
                                            "terrainSprite"
                                          ],
                                          "url"
                                        ],
                                        [
                                          "object/get",
                                          "@t",
                                          "terrainSprite"
                                        ],
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@config.assetManifest",
                                            "terrains"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "terrain"
                                          ]
                                        ]
                                      ],
                                      "height": 0.5,
                                      "position": {
                                        "x": [
                                          "object/get",
                                          "@t",
                                          "x"
                                        ],
                                        "y": [
                                          "object/get",
                                          "@t",
                                          "y"
                                        ]
                                      },
                                      "type": "draw-sprite",
                                      "width": 0.5
                                    }
                                  ]
                                ],
                                [
                                  "fn",
                                  "s",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@s",
                                      "asset"
                                    ],
                                    "url"
                                  ]
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/filter",
                                [
                                  "array/map",
                                  "@config.features",
                                  [
                                    "fn",
                                    "f",
                                    {
                                      "asset": [
                                        "object/get",
                                        "@f",
                                        "assetUrl"
                                      ],
