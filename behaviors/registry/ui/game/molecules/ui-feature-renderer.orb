{
  "description": "FeatureRenderer — UI factory (1:1 with the @almadar/ui feature-renderer pattern).",
  "name": "ui-feature-renderer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FeatureRendererItem",
        "persistence": "runtime"
      },
      "name": "FeatureRendererOrbital",
      "pages": [
        {
          "name": "FeatureRendererPage",
          "path": "/feature-renderer",
          "traits": [
            {
              "ref": "FeatureRendererRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "cellSize": {
              "default": 1.0,
              "description": "Grid cell size",
              "label": "Cell Size",
              "tier": "presentation",
              "type": "number"
            },
            "featureColors": {
              "default": {},
              "description": "Feature color overrides",
              "items": {
                "type": "string"
              },
              "label": "Feature Colors",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "features": {
              "default": [
                {
                  "assetUrl": "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/medieval/props/barrels.glb",
                  "id": "f1",
                  "type": "gold_mine",
                  "x": 2.0,
                  "y": 2.0
                },
                {
                  "assetUrl": "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/gates/gate-door.glb",
                  "id": "f2",
                  "type": "portal",
                  "x": 3.0,
                  "y": 1.0
                }
              ],
              "description": "Array of features to render",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "required": false,
                    "type": "string"
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "elevation": {
                    "name": "elevation",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "sprite": {
                    "name": "sprite",
                    "required": false,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  },
                  "z": {
                    "name": "z",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Features",
              "tier": "presentation",
              "type": "[FeatureRendererFeaturesItem]"
            },
            "offsetX": {
              "default": 0.0,
              "description": "Grid offset X",
              "label": "Offset X",
              "tier": "presentation",
              "type": "number"
            },
            "offsetZ": {
              "default": 0.0,
              "description": "Grid offset Z",
              "label": "Offset Z",
              "tier": "presentation",
              "type": "number"
            },
            "selectedFeatureIds": {
              "default": [],
              "description": "Selected feature IDs",
              "items": {
                "type": "string"
              },
              "label": "Selected Feature Ids",
              "tier": "presentation",
              "type": "[string]"
            }
          },
          "emits": [
            {
              "description": "Called when feature is clicked",
              "event": "FEATURE_CLICK",
              "payloadSchema": [
                {
                  "name": "feature",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "x",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "z",
                      "type": "number"
                    },
                    {
                      "name": "type",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "sprite",
                      "type": "json"
                    },
                    {
                      "name": "assetUrl",
                      "type": "json"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "elevation",
                      "type": "number"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when feature is hovered",
              "event": "FEATURE_HOVER",
              "payloadSchema": [
                {
                  "name": "feature",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "x",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "y",
                      "required": true,
                      "type": "number"
                    },
                    {
                      "name": "z",
                      "type": "number"
                    },
                    {
                      "name": "type",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "sprite",
                      "type": "json"
                    },
                    {
                      "name": "assetUrl",
                      "type": "json"
                    },
                    {
                      "name": "color",
                      "type": "string"
                    },
                    {
                      "name": "elevation",
                      "type": "number"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FeatureRendererItem",
          "name": "FeatureRendererRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when feature is clicked",
                "key": "FEATURE_CLICK",
                "name": "Feature Click",
                "payloadSchema": [
                  {
                    "name": "feature",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "z",
                        "type": "number"
                      },
                      {
                        "name": "type",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "sprite",
                        "type": "json"
                      },
                      {
                        "name": "assetUrl",
                        "type": "json"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "elevation",
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when feature is hovered",
                "key": "FEATURE_HOVER",
                "name": "Feature Hover",
                "payloadSchema": [
                  {
                    "name": "feature",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "z",
                        "type": "number"
                      },
                      {
                        "name": "type",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "sprite",
                        "type": "json"
                      },
                      {
                        "name": "assetUrl",
                        "type": "json"
                      },
                      {
                        "name": "color",
                        "type": "string"
                      },
                      {
                        "name": "elevation",
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "cellSize": "@config.cellSize",
                      "featureColors": "@config.featureColors",
                      "features": "@config.features",
                      "offsetX": "@config.offsetX",
                      "offsetZ": "@config.offsetZ",
                      "onFeatureClick": "FEATURE_CLICK",
                      "onFeatureHover": "FEATURE_HOVER",
                      "selectedFeatureIds": "@config.selectedFeatureIds",
                      "type": "feature-renderer"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}