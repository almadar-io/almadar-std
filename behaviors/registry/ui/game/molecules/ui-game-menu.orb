{
  "description": "GameMenu — UI factory (1:1 with the @almadar/ui game-menu pattern).",
  "name": "ui-game-menu",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameMenuItem",
        "persistence": "runtime"
      },
      "name": "GameMenuOrbital",
      "pages": [
        {
          "name": "GameMenuPage",
          "path": "/game-menu",
          "traits": [
            {
              "ref": "GameMenuRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "background": {
              "default": "Background",
              "description": "Background image or gradient",
              "label": "Background",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "logo": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "logo",
                "dimension": "2d",
                "name": "logo",
                "role": "npc",
                "style": "pixel",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Logo asset",
              "label": "Logo",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GameMenuLogo"
            },
            "menuItems": {
              "default": [
                {
                  "action": "Action",
                  "disabled": false,
                  "id": "Id",
                  "label": "Label",
                  "navigatesTo": "Navigates To",
                  "subLabel": "Sub Label",
                  "variant": "primary"
                },
                {
                  "action": "Action 2",
                  "disabled": true,
                  "id": "Id 2",
                  "label": "Label 2",
                  "navigatesTo": "Navigates To 2",
                  "subLabel": "Sub Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Alias for options (schema compatibility)",
              "items": {
                "properties": {
                  "action": {
                    "name": "action",
                    "required": false,
                    "type": "string"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "subLabel": {
                    "name": "subLabel",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Menu Items",
              "tier": "presentation",
              "type": "[GameMenuMenuItemsItem]"
            },
            "onSelect": {
              "default": "SELECT",
              "description": "Called when an option is selected (legacy callback, prefer event bus)",
              "label": "On Select",
              "tier": "presentation",
              "type": "string"
            },
            "options": {
              "default": [
                {
                  "action": "Action",
                  "disabled": false,
                  "id": "Id",
                  "label": "Label",
                  "navigatesTo": "Navigates To",
                  "subLabel": "Sub Label",
                  "variant": "primary"
                },
                {
                  "action": "Action 2",
                  "disabled": true,
                  "id": "Id 2",
                  "label": "Label 2",
                  "navigatesTo": "Navigates To 2",
                  "subLabel": "Sub Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Menu options - accepts readonly for compatibility with generated const arrays",
              "items": {
                "properties": {
                  "action": {
                    "name": "action",
                    "required": false,
                    "type": "string"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "navigatesTo": {
                    "name": "navigatesTo",
                    "required": false,
                    "type": "string"
                  },
                  "subLabel": {
                    "name": "subLabel",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Options",
              "tier": "presentation",
              "type": "[GameMenuOptionsItem]"
            },
            "subtitle": {
              "default": "Subtitle",
              "description": "Optional subtitle or version",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Epic Quest",
              "description": "Menu title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Called when an option is selected (legacy callback, prefer event bus)",
              "event": "@config.onSelect",
              "payloadSchema": [
                {
                  "name": "option",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "event",
                      "type": "string"
                    },
                    {
                      "name": "navigatesTo",
                      "type": "string"
                    },
                    {
                      "name": "variant",
                      "type": "string"
                    },
                    {
                      "name": "disabled",
                      "type": "boolean"
                    },
                    {
                      "name": "subLabel",
                      "type": "string"
                    },
                    {
                      "name": "action",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameMenuItem",
          "name": "GameMenuRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when an option is selected (legacy callback, prefer event bus)",
                "key": "@config.onSelect",
                "name": "@config.on select",
                "payloadSchema": [
                  {
                    "name": "option",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "label",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "event",
                        "type": "string"
                      },
                      {
                        "name": "navigatesTo",
                        "type": "string"
                      },
                      {
                        "name": "variant",
                        "type": "string"
                      },
                      {
                        "name": "disabled",
                        "type": "boolean"
                      },
                      {
                        "name": "subLabel",
                        "type": "string"
                      },
                      {
                        "name": "action",
                        "type": "string"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "background": "@config.background",
                      "className": "@config.className",
                      "logo": "@config.logo",
                      "menuItems": "@config.menuItems",
                      "onSelect": "@config.onSelect",
                      "options": "@config.options",
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "type": "game-menu"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}