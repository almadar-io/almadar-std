{
  "description": "StatusEffect — counts down duration every second; re-renders on each tick.",
  "name": "ui-status-effect",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 30.0,
            "name": "duration",
            "type": "number"
          }
        ],
        "name": "StatusEffectItem",
        "persistence": "runtime"
      },
      "name": "StatusEffectOrbital",
      "pages": [
        {
          "name": "StatusEffectPage",
          "path": "/status-effect",
          "traits": [
            {
              "ref": "StatusEffectRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/effects/fx-particle/kflow/particle/flame_01.png",
              "description": "Sprite image URL — takes precedence over icon when provided",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "duration": {
              "default": 30.0,
              "description": "Remaining duration in seconds",
              "label": "Duration",
              "tier": "presentation",
              "type": "number"
            },
            "icon": {
              "default": "shield",
              "description": "Lucide icon name for the status effect",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Shield",
              "description": "Label describing the effect",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "stacks": {
              "default": 0.0,
              "description": "Number of stacks",
              "label": "Stacks",
              "tier": "presentation",
              "type": "number"
            },
            "variant": {
              "default": "buff",
              "description": "Effect type",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "buff",
                "debuff",
                "neutral"
              ]
            }
          },
          "entityContract": {
            "provides": [
              "duration"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StatusEffectItem",
          "name": "StatusEffectRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.duration",
                    "@config.duration"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "duration": "@entity.duration",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "size": "@config.size",
                      "stacks": "@config.stacks",
                      "type": "status-effect",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.duration",
                  [
                    "-",
                    "@entity.duration",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "assetUrl": "@config.assetUrl",
                    "className": "@config.className",
                    "duration": "@entity.duration",
                    "icon": "@config.icon",
                    "label": "@config.label",
                    "size": "@config.size",
                    "stacks": "@config.stacks",
                    "type": "status-effect",
                    "variant": "@config.variant"
                  }
                ]
              ],
              "guard": [
                ">",
                "@entity.duration",
                0.0
              ],
              "interval": 1000.0,
              "name": "durationTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}