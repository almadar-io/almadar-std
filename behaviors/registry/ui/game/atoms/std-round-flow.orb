  "name": "std-round-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04TNC4MHVDJM20C3DJKX1",
        "name": "RoundState",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TNCH3KS970CPFP6W35Z",
      "name": "RoundFlowOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TNCGEGEWAATWQRX9K4J",
          "name": "RoundFlowPage",
          "path": "/round-flow",
          "traits": [
            {
              "ref": "RoundFlow",
              "refId": "trt_01KXG04TNCJQBQBHH17BMMRPXT"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, incoming unit-count changes are evaluated for win/lose; toggle to freeze.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Called when the round resolves to a win or loss",
              "event": "GAME_END",
              "eventId": "evt_01KXG04TNC7DTY67YA1T49Z41M",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "RoundState": "ent_01KXG04TNC4MHVDJM20C3DJKX1"
          },
          "id": "trt_01KXG04TNCJQBQBHH17BMMRPXT",
          "linkedEntity": "RoundState",
          "linkedEntityId": "ent_01KXG04TNC4MHVDJM20C3DJKX1",
          "name": "RoundFlow",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TNCJ6PM96MXCY7E71KQ",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TNCQAJVK266BC1FPQWM",
                "key": "UNITS_CHANGED",
                "name": "Units Changed",
                "payloadSchema": [
                  {
                    "name": "playersAlive",
                    "type": "number"
                  },
                  {
                    "name": "enemiesAlive",
                    "type": "number"
                  }
                ]
              },
              {
                "description": "Called when the round resolves to a win or loss",
                "id": "evt_01KXG04TNC7DTY67YA1T49Z41M",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TNCJ6PM96MXCY7E71KQ",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "==",
                        "@payload.playersAlive",
                        0.0
                      ],
                      "defeat",
                      [
                        "if",
                        [
                          "==",
                          "@payload.enemiesAlive",
                          0.0
                        ],
                        "victory",
                        "none"
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "UNITS_CHANGED",
                "eventId": "evt_01KXG04TNCQAJVK266BC1FPQWM",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}