{
  "description": "HealthBar — UI factory (1:1 with the @almadar/ui health-bar pattern).",
  "name": "ui-health-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "HealthBarItem",
        "persistence": "runtime"
      },
      "name": "HealthBarOrbital",
      "pages": [
        {
          "name": "HealthBarPage",
          "path": "/health-bar",
          "traits": [
            {
              "ref": "HealthBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": true,
              "description": "Animation on change",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "current": {
              "default": 0.0,
              "description": "Current health value",
              "label": "Current",
              "tier": "presentation",
              "type": "number"
            },
            "format": {
              "default": "hearts",
              "description": "Display format",
              "label": "Format",
              "tier": "presentation",
              "type": "string",
              "values": [
                "hearts",
                "bar",
                "numeric"
              ]
            },
            "max": {
              "default": 0.0,
              "description": "Maximum health value",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HealthBarItem",
          "name": "HealthBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "className": "@config.className",
                      "current": "@config.current",
                      "format": "@config.format",
                      "max": "@config.max",
                      "size": "@config.size",
                      "type": "health-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}