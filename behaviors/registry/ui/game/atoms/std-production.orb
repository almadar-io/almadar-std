  },
  "name": "std-production",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "productionPoints",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "spawnCount",
            "type": "number"
          }
        ],
        "id": "ent_01KXG04TMX5VXK8YE9TAHMXSMW",
        "name": "ProductionState",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TMXFCCQKZTCY20W4SWR",
      "name": "ProductionOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TMX44ECSYHK48NSMEPJ",
          "name": "ProductionPage",
          "path": "/production",
          "traits": [
            {
              "ref": "Producer",
              "refId": "trt_01KXG04TMXS8KCA3A7G1YKMC10"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "pointsPerTurn": {
              "default": 2.0,
              "description": "Points accrued each AI_TURN (turn advance).",
              "label": "Points Per Turn",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true, turns accrue points and PRODUCE spends them; toggle to freeze production.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "spawnCost": {
              "default": 3.0,
              "description": "Points spent per produced unit; PRODUCE only fires when affordable.",
              "label": "Spawn Cost",
              "tier": "domain",
              "type": "number"
            },
            "spawnHealth": {
              "default": 3.0,
              "description": "Health/maxHealth of produced units.",
              "label": "Spawn Health",
              "tier": "domain",
              "type": "number"
            },
            "spawnTeam": {
              "default": "player",
              "description": "Team of produced units.",
              "label": "Spawn Team",
              "tier": "domain",
              "type": "string"
            },
            "spawnUnitType": {
              "default": "unit",
              "description": "unitType of produced units (drives the asset-manifest sprite).",
              "label": "Spawn Unit Type",
              "tier": "domain",
              "type": "string"
            },
            "spawnX": {
              "default": 0.0,
              "description": "Grid column where produced units appear (rally point).",
              "label": "Spawn X",
              "tier": "domain",
              "type": "number"
            },
            "spawnY": {
              "default": 0.0,
              "description": "Grid row where produced units appear (rally point).",
              "label": "Spawn Y",
              "tier": "domain",
              "type": "number"
            },
            "startPoints": {
              "default": 0.0,
              "description": "Production points set on INIT.",
              "label": "Start Points",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "New-unit intent applied by the grid-tactics authority (the sole units writer)",
              "event": "SPAWN",
              "eventId": "evt_01KXG04TMXDA86Z05D4DT11QBA",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "team",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "health",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "maxHealth",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "unitType",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "productionPoints",
              "spawnCount"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "ProductionState": "ent_01KXG04TMX5VXK8YE9TAHMXSMW"
          },
          "id": "trt_01KXG04TMXS8KCA3A7G1YKMC10",
          "linkedEntity": "ProductionState",
          "linkedEntityId": "ent_01KXG04TMX5VXK8YE9TAHMXSMW",
          "name": "Producer",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TMXJN72S5JPGRSV9T8M",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TMXAS1GKX7KZS7CY2SS",
                "key": "AI_TURN",
                "name": "Ai Turn",
                "payloadSchema": [
                  {
                    "name": "turn",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TMX9E9GFEE4PTCNDF8K",
                "key": "PRODUCE",
                "name": "Produce",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "New-unit intent applied by the grid-tactics authority (the sole units writer)",
                "id": "evt_01KXG04TMXDA86Z05D4DT11QBA",
                "key": "SPAWN",
                "name": "Spawn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "team",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "health",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "maxHealth",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "unitType",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.productionPoints",
                    "@config.startPoints"
                  ],
                  [
                    "set",
                    "@entity.spawnCount",
                    0.0
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TMXJN72S5JPGRSV9T8M",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.productionPoints",
                    [
                      "+",
                      "@entity.productionPoints",
                      "@config.pointsPerTurn"
                    ]
                  ]
                ],
                "event": "AI_TURN",
                "eventId": "evt_01KXG04TMXAS1GKX7KZS7CY2SS",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "emit",
                    "SPAWN",
                    {
                      "health": "@config.spawnHealth",
                      "id": [
                        "str/concat",
                        "prod-u-",
                        "@entity.spawnCount"
                      ],
                      "maxHealth": "@config.spawnHealth",
                      "team": "@config.spawnTeam",
                      "unitType": "@config.spawnUnitType",
                      "x": "@config.spawnX",
                      "y": "@config.spawnY"
                    }
                  ],
                  [
                    "set",
                    "@entity.spawnCount",
                    [
                      "+",
                      "@entity.spawnCount",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.productionPoints",
                    [
                      "-",
                      "@entity.productionPoints",
                      "@config.spawnCost"
                    ]
                  ]
                ],
                "event": "PRODUCE",
                "eventId": "evt_01KXG04TMX9E9GFEE4PTCNDF8K",
                "from": "active",
                "guard": [
                  "and",
                  "@config.running",
                  [
                    ">=",
                    "@entity.productionPoints",
                    "@config.spawnCost"
                  ]
                ],
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}