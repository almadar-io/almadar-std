    "schemaVersion": 1
  },
  "name": "std-arcade-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04TDX07HTCNYVNDHC53RK",
        "name": "ArcadeFlowData",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TDXRZ6R91KVPFJSDJYX",
      "name": "ArcadeFlowOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TDXK4JRD68PCBESHGQT",
          "name": "ArcadeFlowPage",
          "path": "/arcade-flow",
          "traits": [
            {
              "ref": "ArcadeFlow",
              "refId": "trt_01KXG04TDX1HTTKS1GM6Q2593N"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, SCORE_CHANGED signals resolve win/lose; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "ticketsToWin": {
              "default": 5.0,
              "description": "Ticket count that ends the round in a win",
              "label": "Tickets To Win",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emitted when the play loop resolves to won or lost",
              "event": "GAME_END",
              "eventId": "evt_01KXG04TDXCZZGJC01VE1AN2J6",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "ArcadeFlowData": "ent_01KXG04TDX07HTCNYVNDHC53RK"
          },
          "id": "trt_01KXG04TDX1HTTKS1GM6Q2593N",
          "linkedEntity": "ArcadeFlowData",
          "linkedEntityId": "ent_01KXG04TDX07HTCNYVNDHC53RK",
          "name": "ArcadeFlow",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TDXJHKBDEC9XZ0DJDP4",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TDXC1KEDRGZFY6D1XQC",
                "key": "SCORE_CHANGED",
                "name": "Score Changed",
                "payloadSchema": [
                  {
                    "name": "tickets",
                    "type": "number"
                  },
                  {
                    "name": "tokens",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TDX09EXRXWGB6VGV90H",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Emitted when the play loop resolves to won or lost",
                "id": "evt_01KXG04TDXCZZGJC01VE1AN2J6",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TDXJHKBDEC9XZ0DJDP4",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@payload.tickets",
                        "@config.ticketsToWin"
                      ],
                      "won",
                      [
                        "if",
                        [
                          "<=",
                          "@payload.tokens",
                          0.0
                        ],
                        "lost",
                        "none"
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "SCORE_CHANGED",
                "eventId": "evt_01KXG04TDXC1KEDRGZFY6D1XQC",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "RESTART",
                "eventId": "evt_01KXG04TDX09EXRXWGB6VGV90H",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}