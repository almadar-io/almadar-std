            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "FxState": "ent_01KXG04TFZP9QXE9KF516SP9KC"
          },
          "id": "trt_01KXG04TFZQZVT3F7J3DTM2PXF",
          "linkedEntity": "FxState",
          "linkedEntityId": "ent_01KXG04TFZP9QXE9KF516SP9KC",
          "name": "FxParticles",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TFZPVWV1QJ0VNE89MJ2",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TFZ6CNYD7941WGQW3A6",
                "key": "BURST",
                "name": "Burst",
                "payloadSchema": [
                  {
                    "name": "particles",
                    "type": "[Fx]"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.fx",
                    "@config.fx"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TFZPVWV1QJ0VNE89MJ2",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.fx",
                    [
                      "array/concat",
                      "@entity.fx",
                      "@payload.particles"
                    ]
                  ]
                ],
                "event": "BURST",
                "eventId": "evt_01KXG04TFZ6CNYD7941WGQW3A6",
                "from": "active",
                "to": "active"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.fx",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.fx",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              "@config.decayRate"
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ]
              ],
              "guard": [
                "and",
                "@config.running",
                [
                  ">",
                  [
                    "array/len",
                    "@entity.fx"
                  ],
                  0.0
                ]
              ],
              "interval": 500.0,
              "name": "fxTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}