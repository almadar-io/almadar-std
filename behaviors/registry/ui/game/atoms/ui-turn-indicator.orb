{
  "description": "TurnIndicator — UI factory (1:1 with the @almadar/ui turn-indicator pattern).",
  "name": "ui-turn-indicator",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TurnIndicatorItem",
        "persistence": "runtime"
      },
      "name": "TurnIndicatorOrbital",
      "pages": [
        {
          "name": "TurnIndicatorPage",
          "path": "/turn-indicator",
          "traits": [
            {
              "ref": "TurnIndicatorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeTeam": {
              "default": "Active Team",
              "description": "Name of the active team",
              "label": "Active Team",
              "tier": "presentation",
              "type": "string"
            },
            "assetUrl": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "asset",
                "dimension": "2d",
                "name": "asset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
              },
              "description": "Sprite asset — takes precedence over the dot indicator when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "TurnIndicatorAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentTurn": {
              "default": 1.0,
              "description": "Current turn number",
              "label": "Current Turn",
              "tier": "presentation",
              "type": "number"
            },
            "maxTurns": {
              "default": 0.0,
              "description": "Maximum number of turns",
              "label": "Max Turns",
              "tier": "presentation",
              "type": "number"
            },
            "phase": {
              "default": "Phase",
              "description": "Current phase label",
              "label": "Phase",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TurnIndicatorItem",
          "name": "TurnIndicatorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeTeam": "@config.activeTeam",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "currentTurn": "@config.currentTurn",
                      "maxTurns": "@config.maxTurns",
                      "phase": "@config.phase",
                      "size": "@config.size",
                      "type": "turn-indicator"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}