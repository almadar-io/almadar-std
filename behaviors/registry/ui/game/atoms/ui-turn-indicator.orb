{
  "description": "TurnIndicator — UI factory (1:1 with the @almadar/ui turn-indicator pattern).",
  "name": "ui-turn-indicator",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TurnIndicatorItem",
        "persistence": "runtime"
      },
      "name": "TurnIndicatorOrbital",
      "pages": [
        {
          "name": "TurnIndicatorPage",
          "path": "/turn-indicator",
          "traits": [
            {
              "ref": "TurnIndicatorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeTeam": {
              "default": "Active Team",
              "description": "Name of the active team",
              "label": "Active Team",
              "tier": "presentation",
              "type": "string"
            },
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png",
              "description": "Sprite image URL — takes precedence over the dot indicator when provided",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentTurn": {
              "default": 1.0,
              "description": "Current turn number",
              "label": "Current Turn",
              "tier": "presentation",
              "type": "number"
            },
            "maxTurns": {
              "default": 0.0,
              "description": "Maximum number of turns",
              "label": "Max Turns",
              "tier": "presentation",
              "type": "number"
            },
            "phase": {
              "default": "Phase",
              "description": "Current phase label",
              "label": "Phase",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TurnIndicatorItem",
          "name": "TurnIndicatorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "activeTeam": "@config.activeTeam",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "currentTurn": "@config.currentTurn",
                      "maxTurns": "@config.maxTurns",
                      "phase": "@config.phase",
                      "size": "@config.size",
                      "type": "turn-indicator"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}