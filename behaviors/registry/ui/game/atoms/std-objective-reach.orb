              "tier": "domain",
              "type": "number"
            },
            "removeOnReach": {
              "default": true,
              "description": "When true the target model is removed once reached (collect); when false it is flagged done and stays (visit/deliver)",
              "label": "Remove On Reach",
              "tier": "domain",
              "type": "boolean"
            },
            "running": {
              "default": true,
              "description": "When true, hero steps onto targets are scored; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startScore": {
              "default": 0.0,
              "description": "Score set on INIT",
              "label": "Start Score",
              "tier": "domain",
              "type": "number"
            },
            "targetType": {
              "default": "gift",
              "description": "Feature type counted as a collectible objective",
              "label": "Target Type",
              "tier": "domain",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Pickup particle produced when a target is reached; a fx-particles listener spawns it",
              "event": "BURST",
              "eventId": "evt_01KXG04TKVJCPMRKT6W4F5KMVM",
              "payloadSchema": [
                {
                  "name": "particles",
                  "type": "[Fx]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Objectives remaining + moves remaining after this step; a round-flow listener decides win/lose",
              "event": "PROGRESS",
              "eventId": "evt_01KXG04TKV4VB015DMEE0DCNNY",
              "payloadSchema": [
                {
                  "name": "objectivesLeft",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "movesLeft",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "features",
              "objectivesLeft",
              "score"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TKVF4P1VR3W6BFJ78NH",
          "linkedEntity": "ObjectiveState",
          "linkedEntityId": "ent_01KXG04TKT589Q8E6DEHJMMF61",
          "name": "ObjectiveReach",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TKVM1M107EZZT6ZH2M6",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TKVEGRGWD8GPSF7KZCC",
                "key": "HERO_STEPPED",
                "name": "Hero Stepped",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TKVAAE9N8B39BJJMFN1",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Pickup particle produced when a target is reached; a fx-particles listener spawns it",
                "id": "evt_01KXG04TKVJCPMRKT6W4F5KMVM",
                "key": "BURST",
                "name": "Burst",
                "payloadSchema": [
                  {
                    "name": "particles",
                    "type": "[Fx]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Objectives remaining + moves remaining after this step; a round-flow listener decides win/lose",
                "id": "evt_01KXG04TKV4VB015DMEE0DCNNY",
                "key": "PROGRESS",
                "name": "Progress",
                "payloadSchema": [
                  {
                    "name": "objectivesLeft",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@config.startScore"
                  ],
                  [
                    "set",
                    "@entity.objectivesLeft",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@config.features",
                        [
                          "fn",
                          "f",
                          [
                            "==",
                            [
                              "object/get",
                              "@f",
                              "type"
                            ],
                            "@config.targetType"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TKVM1M107EZZT6ZH2M6",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "matched",
                        [
                          "array/filter",
                          "@entity.features",
                          [
                            "fn",
                            "f",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@f",
                                  "type"
                                ],
                                "@config.targetType"
                              ],
                              [
                                "and",
                                [
                                  "!=",
                                  [
                                    "object/get",
                                    "@f",
                                    "done"
                                  ],
                                  true
                                ],
                                [
                                  "<=",
                                  [
                                    "grid/manhattan-distance",
                                    {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    {
                                      "x": "@payload.x",
                                      "y": "@payload.z"
                                    }
                                  ],
                                  "@config.reachRadius"
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "hitCount",
                          [
                            "array/len",
                            "@matched"
                          ]
                        ]
                      ],
                      [
                        "do",
                        [
                          "set",
                          "@entity.score",
                          [
                            "+",
                            "@entity.score",
                            [
                              "*",
                              "@config.pointsPerTarget",
                              "@hitCount"
                            ]
                          ]
                        ],
                        [
                          "set",
                          "@entity.objectivesLeft",
                          [
                            "-",
                            "@entity.objectivesLeft",
                            "@hitCount"
                          ]
                        ],
                        [
                          "set",
                          "@entity.features",
                          [
                            "if",
                            "@config.removeOnReach",
                            [
                              "array/filter",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "not",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "type"
                                      ],
                                      "@config.targetType"
                                    ],
                                    [
                                      "and",
                                      [
                                        "!=",
                                        [
                                          "object/get",
                                          "@f",
                                          "done"
                                        ],
                                        true
                                      ],
                                      [
                                        "<=",
                                        [
                                          "grid/manhattan-distance",
                                          {
                                            "x": [
                                              "object/get",
                                              "@f",
                                              "x"
                                            ],
                                            "y": [
                                              "object/get",
                                              "@f",
                                              "y"
                                            ]
                                          },
                                          {
                                            "x": "@payload.x",
                                            "y": "@payload.z"
                                          }
                                        ],
                                        "@config.reachRadius"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "array/map",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "if",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "type"
                                      ],
                                      "@config.targetType"
                                    ],
                                    [
                                      "and",
                                      [
                                        "!=",
                                        [
                                          "object/get",
                                          "@f",
                                          "done"
                                        ],
                                        true
                                      ],
                                      [
                                        "<=",
                                        [
                                          "grid/manhattan-distance",
                                          {
                                            "x": [
                                              "object/get",
                                              "@f",
                                              "x"
                                            ],
                                            "y": [
                                              "object/get",
                                              "@f",
                                              "y"
                                            ]
                                          },
                                          {
                                            "x": "@payload.x",
                                            "y": "@payload.z"
                                          }
                                        ],
                                        "@config.reachRadius"
                                      ]
                                    ]
                                  ],
                                  [
                                    "object/merge",
                                    "@f",
                                    {
                                      "done": true
                                    }
                                  ],
                                  "@f"
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "emit",
                          "BURST",
                          {
                            "particles": [
                              "array/map",
                              "@matched",
                              [
                                "fn",
                                "f",
                                {
                                  "id": [
                                    "str/concat",
                                    "fx-obj-",
                                    [
                                      "object/get",
                                      "@f",
                                      "id"
                                    ]
                                  ],
                                  "message": "+1",
                                  "ttl": 3.0,
                                  "type": "pickup",
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ]
                                }
                              ]
                            ]
                          }
                        ],
                        [
                          "emit",
                          "PROGRESS",
                          {
                            "movesLeft": "@payload.movesLeft",
                            "objectivesLeft": "@entity.objectivesLeft"
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "HERO_STEPPED",
                "eventId": "evt_01KXG04TKVEGRGWD8GPSF7KZCC",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@config.startScore"
                  ],
                  [
                    "set",
                    "@entity.objectivesLeft",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@config.features",
                        [
                          "fn",
                          "f",
                          [
                            "==",
                            [
                              "object/get",
                              "@f",
                              "type"
                            ],
                            "@config.targetType"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "RESTART",
                "eventId": "evt_01KXG04TKVAAE9N8B39BJJMFN1",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}