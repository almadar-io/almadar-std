{
  "description": "Headless win/lose authority for the nature-survival board: owns only result. Listens RESOURCES (movesLeft) and sets result to lost when the move budget runs out before the camp is built; listens BUILD_CAMP (the render-gated win intent) and sets result to won. Renders nothing.",
  "name": "std-survival-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "name": "SurvivalFlowData",
        "persistence": "runtime",
        "shared": true
      },
      "name": "SurvivalFlowOrbital",
      "pages": [
        {
          "name": "SurvivalFlowPage",
          "path": "/survival-flow",
          "traits": [
            {
              "ref": "SurvivalFlow"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, RESOURCES/BUILD_CAMP signals resolve win/lose; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Emitted once the match resolves to won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SurvivalFlowData",
          "name": "SurvivalFlow",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RESOURCES",
                "name": "Resources",
                "payloadSchema": [
                  {
                    "name": "wood",
                    "type": "number"
                  },
                  {
                    "name": "stone",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "BUILD_CAMP",
                "name": "Build Camp",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Emitted once the match resolves to won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "and",
                        [
                          "<=",
                          "@payload.movesLeft",
                          0.0
                        ],
                        [
                          "!=",
                          "@entity.result",
                          "won"
                        ]
                      ],
                      "lost",
                      "@entity.result"
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "RESOURCES",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "won"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ]
                ],
                "event": "BUILD_CAMP",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "RESTART",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}