  "name": "std-survival-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04TP606Z9Y15XFV49JRM1",
        "name": "SurvivalFlowData",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TP63MGTX1X460SC0BYC",
      "name": "SurvivalFlowOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TP7ZYKHCQJZ0JZ0YJZW",
          "name": "SurvivalFlowPage",
          "path": "/survival-flow",
          "traits": [
            {
              "ref": "SurvivalFlow",
              "refId": "trt_01KXG04TP6E5JMZ7QFF41F69Y8"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, RESOURCES/BUILD_CAMP signals resolve win/lose; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Emitted once the match resolves to won or lost",
              "event": "GAME_END",
              "eventId": "evt_01KXG04TP7C5BMCZFMDX3QPQAJ",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "SurvivalFlowData": "ent_01KXG04TP606Z9Y15XFV49JRM1"
          },
          "id": "trt_01KXG04TP6E5JMZ7QFF41F69Y8",
          "linkedEntity": "SurvivalFlowData",
          "linkedEntityId": "ent_01KXG04TP606Z9Y15XFV49JRM1",
          "name": "SurvivalFlow",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TP6J5FE40M1YQV9VA07",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TP721PV00N6M3YKS1HK",
                "key": "RESOURCES",
                "name": "Resources",
                "payloadSchema": [
                  {
                    "name": "wood",
                    "type": "number"
                  },
                  {
                    "name": "stone",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TP7EHQ70A2ZFR7W5PA1",
                "key": "BUILD_CAMP",
                "name": "Build Camp",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TP7CWSFCQJMY8CAEM9B",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Emitted once the match resolves to won or lost",
                "id": "evt_01KXG04TP7C5BMCZFMDX3QPQAJ",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TP6J5FE40M1YQV9VA07",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "and",
                        [
                          "<=",
                          "@payload.movesLeft",
                          0.0
                        ],
                        [
                          "!=",
                          "@entity.result",
                          "won"
                        ]
                      ],
                      "lost",
                      "@entity.result"
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "RESOURCES",
                "eventId": "evt_01KXG04TP721PV00N6M3YKS1HK",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "won"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ]
                ],
                "event": "BUILD_CAMP",
                "eventId": "evt_01KXG04TP7EHQ70A2ZFR7W5PA1",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "RESTART",
                "eventId": "evt_01KXG04TP7CWSFCQJMY8CAEM9B",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}