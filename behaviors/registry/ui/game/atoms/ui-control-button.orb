{
  "name": "ui-control-button",
  "version": "1.0.0",
  "description": "ControlButton — UI factory (1:1 with the @almadar/ui control-button pattern).",
  "orbitals": [
    {
      "name": "ControlButtonOrbital",
      "entity": {
        "name": "ControlButtonItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ControlButtonRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ControlButtonItem",
          "emits": [
            {
              "event": "PRESS",
              "description": "Called when button is pressed",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RELEASE",
              "description": "Called when button is released",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PRESS",
                "name": "Press",
                "description": "Called when button is pressed",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RELEASE",
                "name": "Release",
                "description": "Called when button is released",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "onPress": "PRESS",
                      "onRelease": "RELEASE",
                      "pressEvent": "PRESS",
                      "disabled": "@config.disabled",
                      "type": "control-button",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "shape": "@config.shape",
                      "releaseEvent": "RELEASE",
                      "pressed": "@config.pressed",
                      "className": "@config.className",
                      "size": "@config.size",
                      "variant": "@config.variant"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "shape": {
              "type": "string",
              "default": "circle",
              "label": "Shape",
              "description": "Shape variant",
              "tier": "presentation",
              "values": [
                "circle",
                "rounded",
                "square"
              ]
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "label": "Disabled",
              "description": "Whether the button is disabled",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "secondary",
              "label": "Variant",
              "description": "Visual variant",
              "tier": "presentation",
              "values": [
                "primary",
                "secondary",
                "ghost"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "Label",
              "label": "Label",
              "description": "Button label text",
              "tier": "presentation"
            },
            "pressed": {
              "type": "boolean",
              "default": false,
              "label": "Pressed",
              "description": "Whether the button is currently pressed",
              "tier": "presentation"
            },
            "icon": {
              "type": "icon",
              "default": "circle",
              "label": "Icon",
              "description": "Icon component or emoji",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ControlButtonPage",
          "path": "/control-button",
          "traits": [
            {
              "ref": "ControlButtonRender"
            }
          ]
        }
      ]
    }
  ]
}