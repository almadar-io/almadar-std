{
  "description": "ControlButton — UI factory (1:1 with the @almadar/ui control-button pattern).",
  "name": "ui-control-button",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ControlButtonItem",
        "persistence": "runtime"
      },
      "name": "ControlButtonOrbital",
      "pages": [
        {
          "name": "ControlButtonPage",
          "path": "/control-button",
          "traits": [
            {
              "ref": "ControlButtonRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "assetUrl",
                "dimension": "2d",
                "name": "assetUrl",
                "role": "npc",
                "style": "pixel",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite asset — takes precedence over icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ControlButtonAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Whether the button is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "icon": {
              "default": "circle",
              "description": "Icon component or emoji",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Button label text",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "onPress": {
              "default": "PRESS",
              "description": "Called when button is pressed",
              "label": "On Press",
              "tier": "presentation",
              "type": "string"
            },
            "onRelease": {
              "default": "RELEASE",
              "description": "Called when button is released",
              "label": "On Release",
              "tier": "presentation",
              "type": "string"
            },
            "pressEvent": {
              "default": "PRESS",
              "description": "Declarative event name emitted on press via useEventBus",
              "label": "Press Event",
              "tier": "presentation",
              "type": "string"
            },
            "pressed": {
              "default": false,
              "description": "Whether the button is currently pressed",
              "label": "Pressed",
              "tier": "presentation",
              "type": "boolean"
            },
            "releaseEvent": {
              "default": "RELEASE",
              "description": "Declarative event name emitted on release via useEventBus",
              "label": "Release Event",
              "tier": "presentation",
              "type": "string"
            },
            "shape": {
              "default": "circle",
              "description": "Shape variant",
              "label": "Shape",
              "tier": "presentation",
              "type": "string",
              "values": [
                "circle",
                "rounded",
                "square"
              ]
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "variant": {
              "default": "secondary",
              "description": "Visual variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "primary",
                "secondary",
                "ghost"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when button is pressed",
              "event": "PRESS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Called when button is released",
              "event": "RELEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ControlButtonItem",
          "name": "ControlButtonRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when button is pressed",
                "key": "PRESS",
                "name": "Press",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Called when button is released",
                "key": "RELEASE",
                "name": "Release",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "onPress": "@config.onPress",
                      "onRelease": "@config.onRelease",
                      "pressEvent": "@config.pressEvent",
                      "pressed": "@config.pressed",
                      "releaseEvent": "@config.releaseEvent",
                      "shape": "@config.shape",
                      "size": "@config.size",
                      "type": "control-button",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}