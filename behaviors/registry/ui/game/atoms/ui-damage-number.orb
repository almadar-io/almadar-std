{
  "description": "DamageNumber — UI factory (1:1 with the @almadar/ui damage-number pattern).",
  "name": "ui-damage-number",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DamageNumberItem",
        "persistence": "runtime"
      },
      "name": "DamageNumberOrbital",
      "pages": [
        {
          "name": "DamageNumberPage",
          "path": "/damage-number",
          "traits": [
            {
              "ref": "DamageNumberRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/guardian.png",
              "description": "Sprite image URL — displayed as a hit-effect icon alongside the number",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "value": {
              "default": 42.0,
              "description": "The damage/heal value to display",
              "label": "Value",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DamageNumberItem",
          "name": "DamageNumberRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "size": "@config.size",
                      "type": "damage-number",
                      "value": "@config.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}