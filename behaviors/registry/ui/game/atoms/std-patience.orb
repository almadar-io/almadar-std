          }
        ],
        "id": "ent_01KXG04TMDA7KDAZVATM3XK8K0",
        "name": "PatienceData",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TMDXCMNX9PXJBXDYESZ",
      "name": "PatienceOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TMDSHVG2GD8AHHJEMY8",
          "name": "PatiencePage",
          "path": "/patience",
          "traits": [
            {
              "ref": "Patience",
              "refId": "trt_01KXG04TMD0MRDA57C85WD13VD"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "customers": {
              "default": [],
              "description": "Seed roster of stationary customers, each with their own position + patience/maxPatience",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "maxPatience": {
                    "name": "maxPatience",
                    "required": false,
                    "type": "number"
                  },
                  "modelUrl": {
                    "name": "modelUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
