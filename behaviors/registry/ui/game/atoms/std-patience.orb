{
  "description": "Headless customer-service mechanic: owns a stationary customer roster with per-customer patience. Decrements patience every tick, serves nearby customers on HERO_STEPPED (resets their patience + scores), and emits CUSTOMER_LOST when a timer expires. Never writes units.",
  "ledger": {
    "entries": {
      "ent_01KXG04TMDA7KDAZVATM3XK8K0": {
        "bakedName": "PatienceData",
        "curName": "PatienceData",
