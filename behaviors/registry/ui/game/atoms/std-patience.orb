                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "patience": {
                    "name": "patience",
                    "required": false,
                    "type": "number"
                  },
                  "position": {
                    "name": "position",
                    "properties": {
                      "x": {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      "y": {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      }
                    },
                    "required": false,
