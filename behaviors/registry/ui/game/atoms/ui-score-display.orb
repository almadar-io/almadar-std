{
  "description": "ScoreDisplay — UI factory (1:1 with the @almadar/ui score-display pattern).",
  "name": "ui-score-display",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ScoreDisplayItem",
        "persistence": "runtime"
      },
      "name": "ScoreDisplayOrbital",
      "pages": [
        {
          "name": "ScoreDisplayPage",
          "path": "/score-display",
          "traits": [
            {
              "ref": "ScoreDisplayRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": true,
              "description": "Animation on value change",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/citizens/archetypes/00_base_model.png",
              "description": "Sprite image URL — takes precedence over icon when provided",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Icon component or emoji",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Label to display before score",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "locale": {
              "default": "en-US",
              "description": "Number formatting locale",
              "label": "Locale",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg",
                "xl"
              ]
            },
            "value": {
              "default": 0.0,
              "description": "Current score value",
              "label": "Value",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ScoreDisplayItem",
          "name": "ScoreDisplayRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "locale": "@config.locale",
                      "size": "@config.size",
                      "type": "score-display",
                      "value": "@config.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}