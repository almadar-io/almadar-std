            {
              "description": "Hero moved onto tile (x,z) with movesLeft remaining; objective mechanics listen to score progress and round-flow to decide win/lose",
              "event": "HERO_STEPPED",
              "eventId": "evt_01KXG04TJBDMZ5SW1X527TFFJ9",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "movesLeft",
                  "required": true,
                  "type": "number"
                }
              ],
