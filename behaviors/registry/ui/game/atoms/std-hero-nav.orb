              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "movesLeft",
              "tiles",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TJB91GE3PMCMF5EBAQX",
          "linkedEntity": "HeroNavData",
          "linkedEntityId": "ent_01KXG04TJB0VKAFAXTSAQ751BT",
          "name": "HeroNav",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TJBD2NEA65VD64MCQ7J",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TJBAN53EW8B98K3FKDE",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TJB35PKXVGZMA86BB04",
                "key": "WANDER",
                "name": "Wander",
                "payloadSchema": [
                  {
                    "name": "tick",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TJBGGE4S9GKMANC6SSJ",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Hero moved onto tile (x,z) with movesLeft remaining; objective mechanics listen to score progress and round-flow to decide win/lose",
                "id": "evt_01KXG04TJBDMZ5SW1X527TFFJ9",
                "key": "HERO_STEPPED",
                "name": "Hero Stepped",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "if",
                      [
                        ">",
                        [
                          "array/len",
                          "@config.tiles"
                        ],
                        0.0
                      ],
                      "@config.tiles",
                      [
                        "array/flatten",
                        [
                          "array/map",
                          [
                            "array/range",
                            0.0,
                            "@config.gridHeight"
                          ],
                          [
                            "fn",
                            "gy",
                            [
                              "array/map",
                              [
                                "array/range",
                                0.0,
                                "@config.gridWidth"
                              ],
                              [
                                "fn",
                                "gx",
                                {
                                  "id": [
                                    "str/concat",
                                    "t-",
                                    "@gx",
                                    "-",
                                    "@gy"
                                  ],
                                  "passable": true,
                                  "x": "@gx",
                                  "y": "@gy"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.movesLeft",
                    "@config.moveBudget"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TJBD2NEA65VD64MCQ7J",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.movesLeft",
                    [
                      "-",
                      "@entity.movesLeft",
                      1.0
                    ]
                  ],
                  [
                    "emit",
                    "HERO_STEPPED",
                    {
                      "movesLeft": "@entity.movesLeft",
                      "unitId": "@payload.unitId",
                      "x": "@payload.x",
                      "z": "@payload.y"
                    }
                  ]
                ],
                "event": "MOVE",
                "eventId": "evt_01KXG04TJBAN53EW8B98K3FKDE",
                "from": "active",
                "guard": [
                  "and",
                  "@config.running",
                  [
                    ">",
                    "@entity.movesLeft",
                    0.0
                  ]
                ],
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.team",
                            "neutral"
                          ],
                          [
                            "let",
                            [
                              [
                                "cell",
                                [
                                  "object/get",
                                  "@u",
                                  "position"
                                ]
                              ],
                              [
                                "dir",
                                [
                                  "math/floor",
                                  [
                                    "*",
                                    [
                                      "math/random"
                                    ],
                                    4.0
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "nc",
                                  [
                                    "if",
                                    [
                                      "==",
                                      "@dir",
                                      0.0
                                    ],
                                    {
                                      "x": [
                                        "+",
                                        [
                                          "object/get",
                                          "@cell",
                                          "x"
                                        ],
                                        1.0
                                      ],
                                      "y": [
                                        "object/get",
                                        "@cell",
                                        "y"
                                      ]
                                    },
                                    [
                                      "if",
                                      [
                                        "==",
                                        "@dir",
                                        1.0
                                      ],
                                      {
                                        "x": [
                                          "-",
                                          [
                                            "object/get",
                                            "@cell",
                                            "x"
                                          ],
                                          1.0
                                        ],
                                        "y": [
                                          "object/get",
                                          "@cell",
                                          "y"
                                        ]
                                      },
                                      [
                                        "if",
                                        [
                                          "==",
                                          "@dir",
                                          2.0
                                        ],
                                        {
                                          "x": [
                                            "object/get",
                                            "@cell",
                                            "x"
                                          ],
                                          "y": [
                                            "+",
                                            [
                                              "object/get",
                                              "@cell",
                                              "y"
                                            ],
                                            1.0
                                          ]
                                        },
                                        {
                                          "x": [
                                            "object/get",
                                            "@cell",
                                            "x"
                                          ],
                                          "y": [
                                            "-",
                                            [
                                              "object/get",
                                              "@cell",
                                              "y"
                                            ],
                                            1.0
                                          ]
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "if",
                                [
                                  "and",
                                  [
                                    "grid/in-bounds",
                                    "@nc",
                                    "@config.gridWidth",
                                    "@config.gridHeight"
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "array/find",
                                          "@entity.tiles",
                                          [
                                            "fn",
                                            "t",
                                            [
                                              "and",
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "x"
                                                ],
                                                [
                                                  "object/get",
                                                  "@nc",
                                                  "x"
                                                ]
                                              ],
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "y"
                                                ],
                                                [
                                                  "object/get",
                                                  "@nc",
                                                  "y"
                                                ]
                                              ]
                                            ]
                                          ]
                                        ],
                                        "passable"
                                      ],
                                      true
                                    ],
                                    [
                                      "==",
                                      [
                                        "array/len",
                                        [
                                          "array/filter",
                                          "@entity.units",
                                          [
                                            "fn",
                                            "o",
                                            [
                                              "and",
                                              [
                                                "!=",
                                                "@o.id",
                                                "@u.id"
                                              ],
                                              [
                                                "and",
                                                [
                                                  "==",
                                                  [
                                                    "object/get",
                                                    [
                                                      "object/get",
                                                      "@o",
                                                      "position"
                                                    ],
                                                    "x"
                                                  ],
                                                  [
                                                    "object/get",
                                                    "@nc",
                                                    "x"
                                                  ]
                                                ],
                                                [
                                                  "==",
                                                  [
                                                    "object/get",
                                                    [
                                                      "object/get",
                                                      "@o",
                                                      "position"
                                                    ],
                                                    "y"
                                                  ],
                                                  [
                                                    "object/get",
                                                    "@nc",
                                                    "y"
                                                  ]
                                                ]
                                              ]
                                            ]
                                          ]
                                        ]
                                      ],
                                      0.0
                                    ]
                                  ]
                                ],
                                [
                                  "object/merge",
                                  "@u",
                                  {
                                    "position": "@nc"
                                  }
                                ],
                                "@u"
                              ]
                            ]
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "WANDER",
                "eventId": "evt_01KXG04TJB35PKXVGZMA86BB04",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.movesLeft",
                    "@config.moveBudget"
                  ]
                ],
                "event": "RESTART",
                "eventId": "evt_01KXG04TJBGGE4S9GKMANC6SSJ",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}