  "name": "std-objective-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04TKBJ5BFB1E634XZRG5Z",
        "name": "FlowState",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TKBGM96E3HRYPXKM494",
      "name": "ObjectiveFlowOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TKBTW0GVJQBW5YFC594",
          "name": "ObjectiveFlowPage",
          "path": "/objective-flow",
          "traits": [
            {
              "ref": "ObjectiveFlow",
              "refId": "trt_01KXG04TKBC6DPS2TWD1P0Z0K5"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, PROGRESS signals resolve win/lose; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Emitted for parity with round-flow when the round resolves; listeners may react to end-of-round",
              "event": "GAME_END",
              "eventId": "evt_01KXG04TKBJ5K7YRKQ6VWFTYB6",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "FlowState": "ent_01KXG04TKBJ5BFB1E634XZRG5Z"
          },
          "id": "trt_01KXG04TKBC6DPS2TWD1P0Z0K5",
          "linkedEntity": "FlowState",
          "linkedEntityId": "ent_01KXG04TKBJ5BFB1E634XZRG5Z",
          "name": "ObjectiveFlow",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TKB5JDYZ5M3XFQ29B0Y",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TKBYREWC2M92NBD54JB",
                "key": "PROGRESS",
                "name": "Progress",
                "payloadSchema": [
                  {
                    "name": "objectivesLeft",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "id": "evt_01KXG04TKBGTT7C9XQ6KFDHEG5",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Emitted for parity with round-flow when the round resolves; listeners may react to end-of-round",
                "id": "evt_01KXG04TKBJ5K7YRKQ6VWFTYB6",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TKB5JDYZ5M3XFQ29B0Y",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "<=",
                        "@payload.objectivesLeft",
                        0.0
                      ],
                      "won",
                      [
                        "if",
                        [
                          "<=",
                          "@payload.movesLeft",
                          0.0
                        ],
                        "lost",
                        "none"
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "PROGRESS",
                "eventId": "evt_01KXG04TKBYREWC2M92NBD54JB",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "RESTART",
                "eventId": "evt_01KXG04TKBGTT7C9XQ6KFDHEG5",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}