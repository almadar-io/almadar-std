  "name": "std-xp",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "xp",
            "type": "number"
          },
          {
            "default": 100.0,
            "name": "xpToNext",
            "type": "number"
          },
          {
            "default": 1.0,
            "name": "level",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "xpBaseline",
            "type": "number"
          }
        ],
        "id": "ent_01KXG04TPPCTES5FATA48QHG9W",
        "name": "XpState",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TPPGXBBRCYGSKTTME5N",
      "name": "XpOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TPPB7WDBVAK0M4GHZSM",
          "name": "XpPage",
          "path": "/xp",
          "traits": [
            {
              "ref": "XpProgression",
              "refId": "trt_01KXG04TPP033D67MD7YG4C8AY"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "baseXpToNext": {
              "default": 100.0,
              "description": "XP threshold for the first level-up.",
              "label": "Base XP To Next",
              "tier": "domain",
              "type": "number"
            },
            "healTeam": {
              "default": "player",
              "description": "Team whose units are healed on level-up.",
              "label": "Heal Team",
              "tier": "domain",
              "type": "string"
            },
            "initialEnemies": {
              "default": 0.0,
              "description": "Enemy count at start; the kill baseline so the first kill grants xp correctly.",
              "label": "Initial Enemies",
              "tier": "domain",
              "type": "number"
            },
            "levelUpHeal": {
              "default": 2.0,
              "description": "Health restored to the healTeam's units on each level-up.",
              "label": "Level-Up Heal",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true, enemy-count drops grant xp and trigger level-ups; toggle to freeze.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startXp": {
              "default": 0.0,
              "description": "XP set on INIT.",
              "label": "Start XP",
              "tier": "domain",
              "type": "number"
            },
            "xpPerKill": {
              "default": 25.0,
              "description": "XP awarded for each enemy removed since the last signal.",
              "label": "XP Per Kill",
              "tier": "domain",
              "type": "number"
            },
            "xpToNextIncrement": {
              "default": 50.0,
              "description": "Amount the threshold rises by on each level-up.",
              "label": "XP To Next Increment",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Level-up heal reward applied by the grid-tactics authority (the sole units writer)",
              "event": "HEAL",
              "eventId": "evt_01KXG04TPPQ2ZPE51A59BK69S6",
              "payloadSchema": [
                {
                  "name": "team",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "amount",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "level",
              "xp",
              "xpBaseline",
              "xpToNext"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "XpState": "ent_01KXG04TPPCTES5FATA48QHG9W"
          },
          "id": "trt_01KXG04TPP033D67MD7YG4C8AY",
          "linkedEntity": "XpState",
          "linkedEntityId": "ent_01KXG04TPPCTES5FATA48QHG9W",
          "name": "XpProgression",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04TPPM7CAHCET41Y5ZP5P",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "id": "evt_01KXG04TPPWHWFVPXMN7C3M6W0",
                "key": "UNITS_CHANGED",
                "name": "Units Changed",
                "payloadSchema": [
                  {
                    "name": "playersAlive",
                    "type": "number"
                  },
                  {
                    "name": "enemiesAlive",
                    "type": "number"
                  }
                ]
              },
              {
                "description": "Level-up heal reward applied by the grid-tactics authority (the sole units writer)",
                "id": "evt_01KXG04TPPQ2ZPE51A59BK69S6",
                "key": "HEAL",
                "name": "Heal",
                "payloadSchema": [
                  {
                    "name": "team",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "amount",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.xp",
                    "@config.startXp"
                  ],
                  [
                    "set",
                    "@entity.xpToNext",
                    "@config.baseXpToNext"
                  ],
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.xpBaseline",
                    "@config.initialEnemies"
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04TPPM7CAHCET41Y5ZP5P",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.xp",
                    [
                      "if",
                      [
                        "<",
                        "@payload.enemiesAlive",
                        "@entity.xpBaseline"
                      ],
                      [
                        "+",
                        "@entity.xp",
                        [
                          "*",
                          [
                            "-",
                            "@entity.xpBaseline",
                            "@payload.enemiesAlive"
                          ],
                          "@config.xpPerKill"
                        ]
                      ],
                      "@entity.xp"
                    ]
                  ],
                  [
                    "set",
                    "@entity.xpBaseline",
                    "@payload.enemiesAlive"
                  ],
                  [
                    "if",
                    [
                      ">=",
                      "@entity.xp",
                      "@entity.xpToNext"
                    ],
                    [
                      "emit",
                      "HEAL",
                      {
                        "amount": "@config.levelUpHeal",
                        "team": "@config.healTeam"
                      }
                    ],
                    null
                  ],
                  [
                    "set",
                    "@entity.level",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.xp",
                        "@entity.xpToNext"
                      ],
                      [
                        "+",
                        "@entity.level",
                        1.0
                      ],
                      "@entity.level"
                    ]
                  ],
                  [
                    "set",
                    "@entity.xpToNext",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.xp",
                        "@entity.xpToNext"
                      ],
                      [
                        "+",
                        "@entity.xpToNext",
                        "@config.xpToNextIncrement"
                      ],
                      "@entity.xpToNext"
                    ]
                  ]
                ],
                "event": "UNITS_CHANGED",
                "eventId": "evt_01KXG04TPPWHWFVPXMN7C3M6W0",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}