{
  "description": "DrawText — UI factory (1:1 with the @almadar/ui draw-text pattern).",
  "name": "ui-draw-text",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DrawTextItem",
        "persistence": "runtime"
      },
      "name": "DrawTextOrbital",
      "pages": [
        {
          "name": "DrawTextPage",
          "path": "/draw-text",
          "traits": [
            {
              "ref": "DrawTextRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "align": {
              "default": {},
              "description": "align prop",
              "label": "Align",
              "tier": "presentation",
              "type": "json"
            },
            "anchor": {
              "default": {},
              "description": "anchor prop",
              "label": "Anchor",
              "tier": "presentation",
              "type": "json"
            },
            "baseline": {
              "default": {},
              "description": "baseline prop",
              "label": "Baseline",
              "tier": "presentation",
              "type": "json"
            },
            "color": {
              "default": "Color",
              "description": "color prop",
              "label": "Color",
              "tier": "presentation",
              "type": "string"
            },
            "font": {
              "default": "Font",
              "description": "font prop",
              "label": "Font",
              "tier": "presentation",
              "type": "string"
            },
            "offsetX": {
              "default": 0.0,
              "description": "offsetX prop",
              "label": "Offset X",
              "tier": "presentation",
              "type": "number"
            },
            "offsetY": {
              "default": 0.0,
              "description": "offsetY prop",
              "label": "Offset Y",
              "tier": "presentation",
              "type": "number"
            },
            "opacity": {
              "default": 0.0,
              "description": "opacity prop",
              "label": "Opacity",
              "tier": "presentation",
              "type": "number"
            },
            "position": {
              "default": {
                "x": 1.0,
                "y": 1.0,
                "z": 1.0
              },
              "description": "Logical scene position; the projector maps it to pixels / world.",
              "label": "Position",
              "properties": {
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                },
                "z": {
                  "name": "z",
                  "required": false,
                  "type": "number"
                }
              },
              "tier": "presentation",
              "type": "DrawTextPosition"
            },
            "text": {
              "default": "Text",
              "description": "text prop",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DrawTextItem",
          "name": "DrawTextRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "@config.align",
                      "anchor": "@config.anchor",
                      "baseline": "@config.baseline",
                      "color": "@config.color",
                      "font": "@config.font",
                      "offsetX": "@config.offsetX",
                      "offsetY": "@config.offsetY",
                      "opacity": "@config.opacity",
                      "position": "@config.position",
                      "text": "@config.text",
                      "type": "draw-text"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}