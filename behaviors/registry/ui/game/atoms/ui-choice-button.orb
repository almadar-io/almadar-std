{
  "description": "ChoiceButton — UI factory (1:1 with the @almadar/ui choice-button pattern).",
  "name": "ui-choice-button",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ChoiceButtonItem",
        "persistence": "runtime"
      },
      "name": "ChoiceButtonOrbital",
      "pages": [
        {
          "name": "ChoiceButtonPage",
          "path": "/choice-button",
          "traits": [
            {
              "ref": "ChoiceButtonRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Whether the choice is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "index": {
              "default": 0.0,
              "description": "Choice index number (displayed as prefix)",
              "label": "Index",
              "tier": "presentation",
              "type": "number"
            },
            "selected": {
              "default": false,
              "description": "Whether the choice is currently selected",
              "label": "Selected",
              "tier": "presentation",
              "type": "boolean"
            },
            "text": {
              "default": "Charge forward into the fray",
              "description": "Choice text content",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Click handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ChoiceButtonItem",
          "name": "ChoiceButtonRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "index": "@config.index",
                      "onClick": "CLICK",
                      "selected": "@config.selected",
                      "text": "@config.text",
                      "type": "choice-button"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}