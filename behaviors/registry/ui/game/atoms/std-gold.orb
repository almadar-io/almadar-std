  "name": "std-gold",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "gold",
            "type": "number"
          }
        ],
        "id": "ent_01KXG04TH3Y6NVBGH0NAHJSXNN",
        "name": "GoldData",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TH3BEDA00J97F2NP6PZ",
      "name": "GoldOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TH3NS8QTAZR4QM6WQ28",
          "name": "GoldPage",
          "path": "/gold",
          "traits": [
            {
              "ref": "GoldMine",
              "refId": "trt_01KXG04TH34ES2DPDMM3BSZE0W"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "running": {
              "default": true,
              "description": "When true, mine-hit signals add gold; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startGold": {
              "default": 0.0,
              "description": "Gold set on INIT/RESTART",
              "label": "Start Gold",
              "tier": "domain",
              "type": "number"
            },
            "yieldAmount": {
              "default": 25.0,
              "description": "Gold added per mine-hit signal",
              "label": "Yield Amount",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Current gold total after a mine-hit; a HUD stat listens to display it",
              "event": "GOLD_CHANGED",
              "eventId": "evt_01KXG04TH3CH4P3XZPFBW6NQT8",
              "payloadSchema": [
                {
                  "name": "gold",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "gold"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TH34ES2DPDMM3BSZE0W",
          "linkedEntity": "GoldData",
          "linkedEntityId": "ent_01KXG04TH3Y6NVBGH0NAHJSXNN",
          "name": "GoldMine",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MINE_HIT",
                "name": "Mine Hit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Current gold total after a mine-hit; a HUD stat listens to display it",
                "key": "GOLD_CHANGED",
                "name": "Gold Changed",
                "payloadSchema": [
                  {
                    "name": "gold",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    "@config.startGold"
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    [
                      "+",
                      "@entity.gold",
                      "@config.yieldAmount"
                    ]
                  ],
                  [
                    "emit",
                    "GOLD_CHANGED",
                    {
                      "gold": "@entity.gold"
                    }
                  ]
                ],
                "event": "MINE_HIT",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.gold",
                    "@config.startGold"
                  ]
                ],
                "event": "RESTART",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}