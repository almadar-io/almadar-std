      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "features": {
              "default": [],
              "description": "Board features — resource nodes (matched by woodType/stoneType) plus decorations",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
