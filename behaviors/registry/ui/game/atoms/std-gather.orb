                  }
                },
                "type": "object"
              },
              "label": "Features",
              "tier": "domain",
              "type": "[Feature]"
            },
            "running": {
              "default": true,
              "description": "When true, hero steps onto resource nodes are gathered; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startStone": {
              "default": 0.0,
              "description": "Stone set on INIT",
              "label": "Start Stone",
              "tier": "domain",
              "type": "number"
            },
            "startWood": {
              "default": 0.0,
              "description": "Wood set on INIT",
              "label": "Start Wood",
              "tier": "domain",
              "type": "number"
            },
            "stoneType": {
              "default": "rock",
              "description": "Feature type counted as a stone resource node",
              "label": "Stone Type",
              "tier": "domain",
              "type": "string"
            },
            "woodType": {
              "default": "tree",
              "description": "Feature type counted as a wood resource node",
              "label": "Wood Type",
              "tier": "domain",
              "type": "string"
            },
            "yieldPerNode": {
              "default": 1.0,
              "description": "Wood or stone gained per node gathered",
              "label": "Yield Per Node",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Pickup particle produced when a resource node is gathered; a fx-particles listener spawns it",
              "event": "BURST",
              "eventId": "evt_01KXG04TGGFYSNBXWZJPRA89EC",
              "payloadSchema": [
                {
                  "name": "particles",
                  "type": "[Fx]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Wood/stone totals and moves remaining after this step; a survival-flow listener decides loss",
              "event": "RESOURCES",
              "eventId": "evt_01KXG04TGGE5BST9P155QY49WW",
              "payloadSchema": [
                {
                  "name": "wood",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "stone",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "movesLeft",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "features",
              "stone",
              "wood"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TGG6JKGWFNS68C642NS",
          "linkedEntity": "GatherData",
          "linkedEntityId": "ent_01KXG04TGGZJHPYRRS81F9PP09",
          "name": "Gather",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HERO_STEPPED",
                "name": "Hero Stepped",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Pickup particle produced when a resource node is gathered; a fx-particles listener spawns it",
                "key": "BURST",
                "name": "Burst",
                "payloadSchema": [
                  {
                    "name": "particles",
                    "type": "[Fx]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Wood/stone totals and moves remaining after this step; a survival-flow listener decides loss",
                "key": "RESOURCES",
                "name": "Resources",
                "payloadSchema": [
                  {
                    "name": "wood",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "stone",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.wood",
                    "@config.startWood"
                  ],
                  [
                    "set",
                    "@entity.stone",
                    "@config.startStone"
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "matched",
                        [
                          "array/filter",
                          "@entity.features",
                          [
                            "fn",
                            "f",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@f",
                                  "x"
                                ],
                                "@payload.x"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ],
                                  "@payload.z"
                                ],
                                [
                                  "or",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "type"
                                    ],
                                    "@config.woodType"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "type"
                                    ],
                                    "@config.stoneType"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "woodHits",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@matched",
                              [
                                "fn",
                                "f",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "type"
                                  ],
                                  "@config.woodType"
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "stoneHits",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@matched",
                              [
                                "fn",
                                "f",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "type"
                                  ],
                                  "@config.stoneType"
                                ]
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "do",
                        [
                          "set",
                          "@entity.wood",
                          [
                            "+",
                            "@entity.wood",
                            [
                              "*",
                              "@config.yieldPerNode",
                              "@woodHits"
                            ]
                          ]
                        ],
                        [
                          "set",
                          "@entity.stone",
                          [
                            "+",
                            "@entity.stone",
                            [
                              "*",
                              "@config.yieldPerNode",
                              "@stoneHits"
                            ]
                          ]
                        ],
                        [
                          "set",
                          "@entity.features",
                          [
                            "array/filter",
                            "@entity.features",
                            [
                              "fn",
                              "f",
                              [
                                "not",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ],
                                      "@payload.z"
                                    ],
                                    [
                                      "or",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@f",
                                          "type"
                                        ],
                                        "@config.woodType"
                                      ],
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@f",
                                          "type"
                                        ],
                                        "@config.stoneType"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "emit",
                          "BURST",
                          {
                            "particles": [
                              "array/map",
                              "@matched",
                              [
                                "fn",
                                "f",
                                {
                                  "id": [
                                    "str/concat",
                                    "fx-gather-",
                                    [
                                      "object/get",
                                      "@f",
                                      "id"
                                    ]
                                  ],
                                  "message": [
                                    "if",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "type"
                                      ],
                                      "@config.woodType"
                                    ],
                                    "+1 wood",
                                    "+1 stone"
                                  ],
                                  "ttl": 3.0,
                                  "type": "pickup",
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ]
                                }
                              ]
                            ]
                          }
                        ],
                        [
                          "emit",
                          "RESOURCES",
                          {
                            "movesLeft": "@payload.movesLeft",
                            "stone": "@entity.stone",
                            "wood": "@entity.wood"
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "HERO_STEPPED",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.wood",
                    "@config.startWood"
                  ],
                  [
                    "set",
                    "@entity.stone",
                    "@config.startStone"
                  ]
                ],
                "event": "RESTART",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}