{
  "name": "ui-state-indicator",
  "version": "1.0.0",
  "description": "StateIndicator — UI factory (1:1 with the @almadar/ui state-indicator pattern).",
  "orbitals": [
    {
      "name": "StateIndicatorOrbital",
      "entity": {
        "name": "StateIndicatorItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StateIndicatorRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StateIndicatorItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "@config.label",
                      "state": "@config.stateProp",
                      "size": "@config.size",
                      "className": "@config.className",
                      "type": "state-indicator",
                      "stateStyles": "@config.stateStyles",
                      "animated": "@config.animated"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "Optional label override (defaults to capitalized state name)",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "stateProp": {
              "type": "string",
              "default": "",
              "label": "State",
              "description": "The current state name",
              "synonyms": "state",
              "tier": "presentation"
            },
            "stateStyles": {
              "type": "json",
              "label": "State Styles",
              "description": "Custom state styles to extend/override defaults",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "animated": {
              "type": "boolean",
              "default": true,
              "label": "Animated",
              "description": "Whether to show pulse animation on non-idle states",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StateIndicatorPage",
          "path": "/state-indicator",
          "traits": [
            {
              "ref": "StateIndicatorRender"
            }
          ]
        }
      ]
    }
  ]
}