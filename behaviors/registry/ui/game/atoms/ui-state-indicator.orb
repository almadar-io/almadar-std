{
  "description": "StateIndicator — UI factory (1:1 with the @almadar/ui state-indicator pattern).",
  "name": "ui-state-indicator",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StateIndicatorItem",
        "persistence": "runtime"
      },
      "name": "StateIndicatorOrbital",
      "pages": [
        {
          "name": "StateIndicatorPage",
          "path": "/state-indicator",
          "traits": [
            {
              "ref": "StateIndicatorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": true,
              "description": "Whether to show pulse animation on non-idle states",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Optional label override (defaults to capitalized state name)",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "stateProp": {
              "default": "State",
              "description": "The current state name",
              "label": "State",
              "synonyms": "state",
              "tier": "presentation",
              "type": "string"
            },
            "stateStyles": {
              "default": {},
              "description": "Custom state styles to extend/override defaults",
              "items": {
                "properties": {
                  "bgClass": {
                    "name": "bgClass",
                    "required": true,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "State Styles",
              "tier": "presentation",
              "type": "Map<string,StateIndicatorStateStylesValue>"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StateIndicatorItem",
          "name": "StateIndicatorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "className": "@config.className",
                      "label": "@config.label",
                      "size": "@config.size",
                      "state": "@config.stateProp",
                      "stateStyles": "@config.stateStyles",
                      "type": "state-indicator"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}