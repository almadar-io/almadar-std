{
  "description": "Headless win/lose authority for market-service boards: owns only result. Listens SERVICE_CHANGED (served + lost) and sets result to won when enough customers are served, lost when too many patience timers expire, else none. Renders nothing.",
  "ledger": {
    "entries": {
      "ent_01KXG04TJW5RCS4DQVWH384F5W": {
        "bakedName": "MarketFlowData",
        "curName": "MarketFlowData",
        "id": "ent_01KXG04TJW5RCS4DQVWH384F5W",
        "kind": "entity",
        "owner": "workspace",
        "renames": []
      },
      "evt_01KXG04TJW2FB7YC0Z746KK22V": {
        "bakedName": "SERVICE_CHANGED",
        "curName": "SERVICE_CHANGED",
        "id": "evt_01KXG04TJW2FB7YC0Z746KK22V",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
        "renames": []
      },
      "evt_01KXG04TJWH140C1WHZK5WZWGD": {
        "bakedName": "RESTART",
        "curName": "RESTART",
        "id": "evt_01KXG04TJWH140C1WHZK5WZWGD",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
        "renames": []
      },
      "evt_01KXG04TJWMPDNXJZNGQYSGWG8": {
        "bakedName": "GAME_END",
        "curName": "GAME_END",
        "id": "evt_01KXG04TJWMPDNXJZNGQYSGWG8",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
        "renames": []
      },
      "evt_01KXG04TJWX7GCSWHETKKWT4CM": {
        "bakedName": "INIT",
        "curName": "INIT",
        "id": "evt_01KXG04TJWX7GCSWHETKKWT4CM",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
        "renames": []
      },
      "orb_01KXG04TJWH2RV1EX7RT1FE10N": {
        "bakedName": "MarketFlowOrbital",
        "curName": "MarketFlowOrbital",
        "id": "orb_01KXG04TJWH2RV1EX7RT1FE10N",
        "kind": "orbital",
        "owner": "workspace",
        "renames": []
      },
      "pag_01KXG04TJWRHK7EQM0NFGTY4RW": {
        "bakedName": "MarketFlowPage",
        "curName": "MarketFlowPage",
        "id": "pag_01KXG04TJWRHK7EQM0NFGTY4RW",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG04TJW9DXPV5MNGPMXCSRA": {
        "bakedName": "MarketFlow",
        "curName": "MarketFlow",
        "id": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
        "kind": "trait",
        "owner": "workspace",
        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "std-market-flow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string"
          }
        ],
        "id": "ent_01KXG04TJW5RCS4DQVWH384F5W",
        "name": "MarketFlowData",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TJWH2RV1EX7RT1FE10N",
      "name": "MarketFlowOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TJWRHK7EQM0NFGTY4RW",
          "name": "MarketFlowPage",
          "path": "/market-flow",
          "traits": [
            {
              "ref": "MarketFlow",
              "refId": "trt_01KXG04TJW9DXPV5MNGPMXCSRA"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "maxLost": {
              "default": 3.0,
              "description": "Cumulative starved-customer count that ends the round in a loss",
              "label": "Max Lost",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true, SERVICE_CHANGED signals resolve win/lose; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "targetServed": {
              "default": 10.0,
              "description": "Cumulative customers served needed to win",
              "label": "Target Served",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Emitted when result becomes won or lost",
              "event": "GAME_END",
              "eventId": "evt_01KXG04TJWMPDNXJZNGQYSGWG8",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TJW9DXPV5MNGPMXCSRA",
          "linkedEntity": "MarketFlowData",
          "linkedEntityId": "ent_01KXG04TJW5RCS4DQVWH384F5W",
          "name": "MarketFlow",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SERVICE_CHANGED",
                "name": "Service Changed",
                "payloadSchema": [
                  {
                    "name": "served",
                    "type": "number"
                  },
                  {
                    "name": "pending",
                    "type": "number"
                  },
                  {
                    "name": "lost",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Emitted when result becomes won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@payload.served",
                        "@config.targetServed"
                      ],
                      "won",
                      [
                        "if",
                        [
                          ">=",
                          "@payload.lost",
                          "@config.maxLost"
                        ],
                        "lost",
                        "none"
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ]
                ],
                "event": "SERVICE_CHANGED",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ]
                ],
                "event": "RESTART",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}