{
  "description": "WaypointMarker — UI factory (1:1 with the @almadar/ui waypoint-marker pattern).",
  "name": "ui-waypoint-marker",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "WaypointMarkerItem",
        "persistence": "runtime"
      },
      "name": "WaypointMarkerOrbital",
      "pages": [
        {
          "name": "WaypointMarkerPage",
          "path": "/waypoint-marker",
          "traits": [
            {
              "ref": "WaypointMarkerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "active": {
              "default": true,
              "description": "Whether this waypoint is currently active",
              "label": "Active",
              "tier": "presentation",
              "type": "boolean"
            },
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png",
              "description": "Sprite image URL — takes precedence over icon when provided",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "completed": {
              "default": false,
              "description": "Whether this waypoint has been completed",
              "label": "Completed",
              "tier": "presentation",
              "type": "boolean"
            },
            "icon": {
              "default": "circle",
              "description": "Custom icon to render inside the marker",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Label",
              "description": "Label text below the marker",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "WaypointMarkerItem",
          "name": "WaypointMarkerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "active": "@config.active",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "completed": "@config.completed",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "size": "@config.size",
                      "type": "waypoint-marker"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}