{
  "description": "ComboCounter — UI factory (1:1 with the @almadar/ui combo-counter pattern).",
  "name": "ui-combo-counter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ComboCounterItem",
        "persistence": "runtime"
      },
      "name": "ComboCounterOrbital",
      "pages": [
        {
          "name": "ComboCounterPage",
          "path": "/combo-counter",
          "traits": [
            {
              "ref": "ComboCounterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/units/chars-toon/trait-wars/citizens/archetypes/00_base_model.png",
              "description": "Sprite image URL displayed alongside the combo number",
              "label": "Asset Url",
              "tier": "presentation",
              "type": "asset"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "combo": {
              "default": 5.0,
              "description": "Current combo count",
              "label": "Combo",
              "tier": "presentation",
              "type": "number"
            },
            "multiplier": {
              "default": 0.0,
              "description": "Score multiplier",
              "label": "Multiplier",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "streak": {
              "default": 0.0,
              "description": "Current streak",
              "label": "Streak",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ComboCounterItem",
          "name": "ComboCounterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "combo": "@config.combo",
                      "multiplier": "@config.multiplier",
                      "size": "@config.size",
                      "streak": "@config.streak",
                      "type": "combo-counter"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}