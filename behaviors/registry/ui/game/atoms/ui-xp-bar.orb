{
  "name": "ui-xp-bar",
  "version": "1.0.0",
  "description": "XpBar — UI factory (1:1 with the @almadar/ui xp-bar pattern).",
  "orbitals": [
    {
      "name": "XpBarOrbital",
      "entity": {
        "name": "XpBarItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "XpBarRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "XpBarItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "xp-bar",
                      "max": "@config.max",
                      "level": "@config.level",
                      "animated": "@config.animated",
                      "size": "@config.size",
                      "className": "@config.className",
                      "current": "@config.current",
                      "showLabel": "@config.showLabel"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "animated": {
              "type": "boolean",
              "default": true,
              "label": "Animated",
              "description": "Animate the fill bar",
              "tier": "presentation"
            },
            "current": {
              "type": "number",
              "default": 0.0,
              "label": "Current",
              "description": "Current XP value",
              "tier": "presentation"
            },
            "showLabel": {
              "type": "boolean",
              "default": false,
              "label": "Show Label",
              "description": "Whether to show the XP label",
              "tier": "presentation"
            },
            "max": {
              "type": "number",
              "default": 0.0,
              "label": "Max",
              "description": "XP needed for next level",
              "tier": "presentation"
            },
            "level": {
              "type": "number",
              "default": 0.0,
              "label": "Level",
              "description": "Current level",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size variant",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "XpBarPage",
          "path": "/xp-bar",
          "traits": [
            {
              "ref": "XpBarRender"
            }
          ]
        }
      ]
    }
  ]
}