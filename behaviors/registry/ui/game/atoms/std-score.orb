{
  "description": "Headless scoring mechanic: awards points when the enemy survivor count drops on a UNITS_CHANGED signal. Owns only score (+ its kill baseline); renders nothing.",
  "ledger": {
    "entries": {
      "ent_01KXG04TNSC9WJATDGG5AES67C": {
        "bakedName": "ScoreState",
        "curName": "ScoreState",
        "id": "ent_01KXG04TNSC9WJATDGG5AES67C",
        "kind": "entity",
        "owner": "workspace",
        "renames": []
      },
      "evt_01KXG04TNS5RA9J5C624Q3R86F": {
        "bakedName": "UNITS_CHANGED",
        "curName": "UNITS_CHANGED",
        "id": "evt_01KXG04TNS5RA9J5C624Q3R86F",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ",
        "renames": []
      },
      "evt_01KXG04TNSAGYTF6VM8CSJKDXQ": {
        "bakedName": "INIT",
        "curName": "INIT",
        "id": "evt_01KXG04TNSAGYTF6VM8CSJKDXQ",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ",
        "renames": []
      },
      "orb_01KXG04TNSAEYH5FDR87RPC3DZ": {
        "bakedName": "ScoreOrbital",
        "curName": "ScoreOrbital",
        "id": "orb_01KXG04TNSAEYH5FDR87RPC3DZ",
        "kind": "orbital",
        "owner": "workspace",
        "renames": []
      },
      "pag_01KXG04TNS0R6A94WZGSQC70H9": {
        "bakedName": "ScorePage",
        "curName": "ScorePage",
        "id": "pag_01KXG04TNS0R6A94WZGSQC70H9",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ": {
        "bakedName": "ScoreKeeper",
        "curName": "ScoreKeeper",
        "id": "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ",
        "kind": "trait",
        "owner": "workspace",
        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "std-score",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "score",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "scoreBaseline",
            "type": "number"
          }
        ],
        "id": "ent_01KXG04TNSC9WJATDGG5AES67C",
        "name": "ScoreState",
        "persistence": "runtime",
        "shared": true
      },
      "id": "orb_01KXG04TNSAEYH5FDR87RPC3DZ",
      "name": "ScoreOrbital",
      "pages": [
        {
          "id": "pag_01KXG04TNS0R6A94WZGSQC70H9",
          "name": "ScorePage",
          "path": "/score",
          "traits": [
            {
              "ref": "ScoreKeeper",
              "refId": "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "initialEnemies": {
              "default": 0.0,
              "description": "Enemy count at start; the kill baseline so the first kill scores correctly.",
              "label": "Initial Enemies",
              "tier": "domain",
              "type": "number"
            },
            "pointsPerKill": {
              "default": 10.0,
              "description": "Points awarded for each enemy removed since the last signal.",
              "label": "Points Per Kill",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true, enemy-count drops award points; toggle to freeze scoring.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startScore": {
              "default": 0.0,
              "description": "Initial score set on INIT.",
              "label": "Start Score",
              "tier": "domain",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "score",
              "scoreBaseline"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04TNS3RZ75H9PBTJ6F5HQ",
          "linkedEntity": "ScoreState",
          "linkedEntityId": "ent_01KXG04TNSC9WJATDGG5AES67C",
          "name": "ScoreKeeper",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UNITS_CHANGED",
                "name": "Units Changed",
                "payloadSchema": [
                  {
                    "name": "playersAlive",
                    "type": "number"
                  },
                  {
                    "name": "enemiesAlive",
                    "type": "number"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    "@config.startScore"
                  ],
                  [
                    "set",
                    "@entity.scoreBaseline",
                    "@config.initialEnemies"
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "if",
                      [
                        "<",
                        "@payload.enemiesAlive",
                        "@entity.scoreBaseline"
                      ],
                      [
                        "+",
                        "@entity.score",
                        [
                          "*",
                          [
                            "-",
                            "@entity.scoreBaseline",
                            "@payload.enemiesAlive"
                          ],
                          "@config.pointsPerKill"
                        ]
                      ],
                      "@entity.score"
                    ]
                  ],
                  [
                    "set",
                    "@entity.scoreBaseline",
                    "@payload.enemiesAlive"
                  ]
                ],
                "event": "UNITS_CHANGED",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}