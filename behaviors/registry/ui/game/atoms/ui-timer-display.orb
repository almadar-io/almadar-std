        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "ui-timer-display",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 90.0,
            "name": "seconds",
            "type": "number"
          },
          {
            "default": true,
            "name": "running",
            "type": "boolean"
          }
        ],
        "id": "ent_01KXG04V4ATZ8PN1561E3E9N4R",
        "name": "TimerDisplayItem",
        "persistence": "runtime"
      },
      "id": "orb_01KXG04V4A3R1749H5PVZKPYKF",
      "name": "TimerDisplayOrbital",
      "pages": [
        {
          "id": "pag_01KXG04V4D0ARZ88B3FG6MAT6F",
          "name": "TimerDisplayPage",
          "path": "/timer-display",
          "traits": [
            {
              "ref": "TimerDisplayRender",
              "refId": "trt_01KXG04V4AGBD72W4ZB4ZC052Z"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "format": {
              "default": "mm:ss",
              "description": "Display format",
              "label": "Format",
              "tier": "presentation",
              "type": "string",
              "values": [
                "mm:ss",
                "ss",
                "countdown"
              ]
            },
            "lowThreshold": {
              "default": 0.0,
              "description": "Seconds below which to pulse red",
              "label": "Low Threshold",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "Whether the timer is running",
              "label": "Running",
              "tier": "presentation",
              "type": "boolean"
            },
            "seconds": {
              "default": 90.0,
              "description": "Time in seconds",
              "label": "Seconds",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [
              "running",
              "seconds"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG04V4AGBD72W4ZB4ZC052Z",
          "linkedEntity": "TimerDisplayItem",
          "linkedEntityId": "ent_01KXG04V4ATZ8PN1561E3E9N4R",
          "name": "TimerDisplayRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG04V4AYGD0V2TBB3J2C45V",
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.seconds",
                    "@config.seconds"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "format": "@config.format",
                      "lowThreshold": "@config.lowThreshold",
                      "running": "@entity.running",
                      "seconds": "@entity.seconds",
                      "size": "@config.size",
                      "type": "timer-display"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG04V4AYGD0V2TBB3J2C45V",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.seconds",
                  [
                    "-",
                    "@entity.seconds",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "className": "@config.className",
                    "format": "@config.format",
                    "lowThreshold": "@config.lowThreshold",
                    "running": "@entity.running",
                    "seconds": "@entity.seconds",
                    "size": "@config.size",
                    "type": "timer-display"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.running",
                  true
                ],
                [
                  ">",
                  "@entity.seconds",
                  0.0
                ]
              ],
              "interval": 1000.0,
              "name": "timerTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}