{
  "description": "TimerDisplay — counts down every second while running; re-renders on each tick.",
  "name": "ui-timer-display",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 90.0,
            "name": "seconds",
            "type": "number"
          },
          {
            "default": true,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "TimerDisplayItem",
        "persistence": "runtime"
      },
      "name": "TimerDisplayOrbital",
      "pages": [
        {
          "name": "TimerDisplayPage",
          "path": "/timer-display",
          "traits": [
            {
              "ref": "TimerDisplayRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "format": {
              "default": "mm:ss",
              "description": "Display format",
              "label": "Format",
              "tier": "presentation",
              "type": "string",
              "values": [
                "mm:ss",
                "ss",
                "countdown"
              ]
            },
            "lowThreshold": {
              "default": 0.0,
              "description": "Seconds below which to pulse red",
              "label": "Low Threshold",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "Whether the timer is running",
              "label": "Running",
              "tier": "presentation",
              "type": "boolean"
            },
            "seconds": {
              "default": 90.0,
              "description": "Time in seconds",
              "label": "Seconds",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [
              "running",
              "seconds"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TimerDisplayItem",
          "name": "TimerDisplayRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.seconds",
                    "@config.seconds"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "format": "@config.format",
                      "lowThreshold": "@config.lowThreshold",
                      "running": "@entity.running",
                      "seconds": "@entity.seconds",
                      "size": "@config.size",
                      "type": "timer-display"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.seconds",
                  [
                    "-",
                    "@entity.seconds",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "className": "@config.className",
                    "format": "@config.format",
                    "lowThreshold": "@config.lowThreshold",
                    "running": "@entity.running",
                    "seconds": "@entity.seconds",
                    "size": "@config.size",
                    "type": "timer-display"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.running",
                  true
                ],
                [
                  ">",
                  "@entity.seconds",
                  0.0
                ]
              ],
              "interval": 1000.0,
              "name": "timerTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}