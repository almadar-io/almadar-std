{
  "description": "DialogueBubble — UI factory (1:1 with the @almadar/ui dialogue-bubble pattern).",
  "name": "ui-dialogue-bubble",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DialogueBubbleItem",
        "persistence": "runtime"
      },
      "name": "DialogueBubbleOrbital",
      "pages": [
        {
          "name": "DialogueBubblePage",
          "path": "/dialogue-bubble",
          "traits": [
            {
              "ref": "DialogueBubbleRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "portrait": {
              "default": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/04_hero.png",
              "description": "URL for the speaker portrait image",
              "label": "Portrait",
              "tier": "presentation",
              "type": "asset"
            },
            "position": {
              "default": "bottom",
              "description": "Position of the bubble on screen",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom"
              ]
            },
            "speaker": {
              "default": "Speaker",
              "description": "Speaker name displayed at the top",
              "label": "Speaker",
              "tier": "presentation",
              "type": "string"
            },
            "text": {
              "default": "Text",
              "description": "Dialogue text content",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DialogueBubbleItem",
          "name": "DialogueBubbleRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "portrait": "@config.portrait",
                      "position": "@config.position",
                      "speaker": "@config.speaker",
                      "text": "@config.text",
                      "type": "dialogue-bubble"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}