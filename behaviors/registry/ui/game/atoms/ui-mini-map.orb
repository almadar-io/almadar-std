{
  "name": "ui-mini-map",
  "version": "1.0.0",
  "description": "MiniMap — UI factory (1:1 with the @almadar/ui mini-map pattern).",
  "orbitals": [
    {
      "name": "MiniMapOrbital",
      "entity": {
        "name": "MiniMapItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MiniMapRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "MiniMapItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "units": "@config.units",
                      "className": "@config.className",
                      "type": "mini-map",
                      "mapHeight": "@config.mapHeight",
                      "mapWidth": "@config.mapWidth",
                      "tiles": "@config.tiles",
                      "width": "@config.width",
                      "height": "@config.height",
                      "viewportRect": "@config.viewportRect"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "tiles": {
              "type": "[MiniMapTilesItem]",
              "default": [
                {
                  "x": 1.0,
                  "y": 1.0,
                  "color": "Color"
                }
              ],
              "label": "Tiles",
              "description": "Tile data: each tile renders as a 1px dot at (x,y) with the given color",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": true
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "units": {
              "type": "[MiniMapUnitsItem]",
              "default": [
                {
                  "color": "Color",
                  "x": 1.0,
                  "y": 1.0,
                  "isPlayer": false
                }
              ],
              "label": "Units",
              "description": "Unit positions: each unit renders as a 2px dot",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "isPlayer": {
                    "name": "isPlayer",
                    "type": "boolean",
                    "required": false
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": true
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "mapWidth": {
              "type": "number",
              "default": 100.0,
              "label": "Map Width",
              "description": "Logical map width (for coordinate scaling)",
              "tier": "presentation"
            },
            "width": {
              "type": "number",
              "default": 150.0,
              "label": "Width",
              "description": "Canvas display width in pixels",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 150.0,
              "label": "Height",
              "description": "Canvas display height in pixels",
              "tier": "presentation"
            },
            "mapHeight": {
              "type": "number",
              "default": 100.0,
              "label": "Map Height",
              "description": "Logical map height (for coordinate scaling)",
              "tier": "presentation"
            },
            "viewportRect": {
              "type": "MiniMapViewportRect",
              "default": {
                "x": 1.0,
                "y": 1.0,
                "w": 1.0,
                "h": 1.0
              },
              "label": "Viewport Rect",
              "description": "Viewport rectangle outline",
              "tier": "presentation",
              "properties": {
                "x": {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                "w": {
                  "name": "w",
                  "type": "number",
                  "required": true
                },
                "h": {
                  "name": "h",
                  "type": "number",
                  "required": true
                },
                "y": {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MiniMapPage",
          "path": "/mini-map",
          "traits": [
            {
              "ref": "MiniMapRender"
            }
          ]
        }
      ]
    }
  ]
}