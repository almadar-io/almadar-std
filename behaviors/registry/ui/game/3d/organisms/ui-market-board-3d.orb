          "linkedEntity": "MarketBoard3DItem",
          "name": "MarketBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Moves the shopkeeper toward the clicked tile",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Serves the clicked customer when the shopkeeper is adjacent",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emitted when result becomes won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "u1"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          14.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              14.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "cover",
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "math/mod",
                                          "@gy",
                                          3.0
                                        ],
                                        1.0
                                      ],
                                      [
                                        "==",
                                        [
                                          "math/mod",
                                          "@gx",
                                          4.0
                                        ],
                                        2.0
                                      ]
                                    ]
                                  ]
                                ],
                                {
                                  "id": [
                                    "str/concat",
                                    "t-",
                                    "@gx",
                                    "-",
                                    "@gy"
                                  ],
                                  "modelUrl": [
                                    "if",
                                    "@cover",
                                    "@config.shelfAsset",
                                    "@config.floorAsset"
                                  ],
                                  "passable": [
                                    "if",
                                    "@cover",
                                    false,
                                    true
                                  ],
                                  "terrain": [
                                    "if",
                                    "@cover",
                                    "shelf",
                                    "floor"
                                  ],
                                  "x": "@gx",
                                  "y": "@gy"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.scoreTarget",
                    "@config.scoreTarget"
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "u1"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@entity.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
