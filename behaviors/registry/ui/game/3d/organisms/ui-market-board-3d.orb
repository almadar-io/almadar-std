                                      [
                                        "and",
                                        [
                                          "!=",
                                          "@o.id",
                                          "@u.id"
                                        ],
                                        [
                                          "and",
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              [
                                                "object/get",
                                                "@o",
                                                "position"
                                              ],
                                              "x"
                                            ],
                                            "@nx"
                                          ],
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              [
                                                "object/get",
                                                "@o",
                                                "position"
                                              ],
                                              "y"
                                            ],
                                            "@ny"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "if",
                                [
                                  "and",
                                  [
                                    "grid/in-bounds",
                                    {
                                      "x": "@nx",
                                      "y": "@ny"
                                    },
                                    "@entity.gridWidth",
                                    "@entity.gridHeight"
                                  ],
                                  [
                                    "and",
                                    [
                                      "!=",
                                      "@ntile",
                                      null
                                    ],
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@ntile",
                                          "passable"
                                        ],
                                        true
                                      ],
                                      [
                                        "==",
                                        "@occupied",
                                        null
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "object/merge",
                                  "@u",
                                  {
                                    "position": {
                                      "x": "@nx",
                                      "y": "@ny"
                                    }
                                  }
                                ],
                                "@u"
                              ]
                            ]
                          ]
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "PLAY_AGAIN",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "children": [
                      {
                        "attackTargets": "@entity.attackTargets",
                        "cameraMode": "top-down",
                        "events": "@entity.fx",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "game-canvas-3d",
                        "unitClickEvent": "UNIT_CLICK",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "label": "Lives",
                          "value": "@entity.lives"
                        },
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        },
                        {
                          "label": "Goal",
                          "value": "Serve customers before patience runs out"
                        },
                        {
                          "label": "How",
                          "value": "Click a floor tile to walk → click an adjacent customer to serve them"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1500.0,
              "name": "wanderTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}