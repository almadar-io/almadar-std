                      "addons": {
                        "children": [
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "cameraMode": "top-down",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
