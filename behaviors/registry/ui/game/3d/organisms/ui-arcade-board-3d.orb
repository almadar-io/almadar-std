            {
              "effects": [
                [
                  "set",
                  "@entity.npcTick",
                  [
                    "+",
                    "@entity.npcTick",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "if",
                        [
                          "==",
                          "@u.team",
                          "neutral"
                        ],
                        [
                          "object/merge",
                          "@u",
                          {
                            "position": {
                              "x": [
                                "+",
                                1.0,
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "%",
                                      "@entity.npcTick",
                                      4.0
                                    ],
                                    2.0
                                  ]
                                ]
                              ],
                              "y": [
                                "object/get",
                                [
                                  "object/get",
                                  "@u",
                                  "position"
                                ],
                                "y"
                              ]
                            }
                          }
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.fx",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.fx",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              "@e.ttl",
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        "@e.ttl",
                        0.0
                      ]
                    ]
                  ]
