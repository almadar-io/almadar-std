          "emits": [
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } — selects the player kid",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{tileClickEvent} with { x, z } — moves the selected kid one step",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "tileId",
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{featureClickEvent} with { x, z, type } — plays a machine or claims the prize counter",
              "event": "FEATURE_CLICK",
              "payloadSchema": [
                {
                  "name": "featureId",
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                },
                {
                  "name": "type",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Deselects the current unit",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when the match ends (won or lost)",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
