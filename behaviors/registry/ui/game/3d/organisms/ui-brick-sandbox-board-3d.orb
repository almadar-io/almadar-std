              "description": "6x6 flat baseplate — one plate model per cell.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "modelUrl": {
                    "name": "modelUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": false,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "passable": {
                    "name": "passable",
                    "required": false,
                    "type": "boolean"
                  },
                  "terrain": {
                    "name": "terrain",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[BrickSandboxBoard3DTilesItem]"
            }
          },
          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with {tileId,x,z} on grid cell click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "tileId",
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "blueprint",
              "features",
              "fx",
              "mistakes",
              "placed",
              "result"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "BrickSandboxBoard3DItem",
          "name": "BrickSandboxBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{tileClickEvent} with {tileId,x,z} on grid cell click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "tileId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.blueprint",
                    [
                      "array/map",
                      "@config.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "object/merge",
                          "@b",
                          {
                            "filled": false
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.placed",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.mistakes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.features",
                    [
                      "array/map",
                      "@entity.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "if",
                          [
                            "==",
                            "@b.filled",
                            true
                          ],
                          {
                            "assetUrl": "@b.brickModel",
                            "id": "@b.id",
                            "type": "brick",
                            "x": "@b.x",
                            "y": "@b.y"
                          },
                          {
                            "assetUrl": "@config.markerModel",
                            "id": "@b.id",
                            "type": "marker",
                            "x": "@b.x",
                            "y": "@b.y"
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "backgroundColor": "@config.bgColor",
                          "events": "@entity.fx",
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "units": []
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Placed",
                                "value": "@entity.placed"
                              },
                              {
                                "label": "Mistakes",
                                "value": "@entity.mistakes"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "options": [
                            {
                              "event": "PLAY_AGAIN",
                              "id": "again",
                              "label": "Play Again",
                              "variant": "primary"
                            }
                          ],
                          "subtitle": [
                            "str/concat",
                            "Placed ",
                            "@entity.placed"
                          ],
                          "title": [
                            "if",
                            [
                              "==",
                              "@entity.result",
                              "won"
                            ],
                            "BUILD COMPLETE",
                            "OUT OF TRIES"
                          ],
                          "type": "game-menu"
                        },
                        null
                      ],
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "hit",
                        [
                          "array/find",
                          "@entity.blueprint",
                          [
                            "fn",
                            "b",
                            [
                              "and",
                              [
                                "==",
                                "@b.x",
                                "@payload.x"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  "@b.y",
                                  "@payload.z"
                                ],
                                [
                                  "==",
                                  "@b.filled",
                                  false
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.blueprint",
                        [
                          "if",
                          [
                            "!=",
                            "@hit",
                            null
                          ],
                          [
                            "array/map",
                            "@entity.blueprint",
                            [
                              "fn",
                              "b",
                              [
                                "if",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@b.x",
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    "@b.y",
                                    "@payload.z"
                                  ]
                                ],
                                [
                                  "object/merge",
                                  "@b",
                                  {
                                    "filled": true
                                  }
                                ],
                                "@b"
                              ]
                            ]
                          ],
                          "@entity.blueprint"
                        ]
                      ],
                      [
                        "set",
                        "@entity.placed",
                        [
                          "if",
                          [
                            "!=",
                            "@hit",
                            null
                          ],
                          [
                            "+",
                            "@entity.placed",
                            1.0
                          ],
                          "@entity.placed"
                        ]
                      ],
                      [
                        "set",
                        "@entity.mistakes",
                        [
                          "if",
                          [
                            "==",
                            "@hit",
                            null
                          ],
                          [
                            "+",
                            "@entity.mistakes",
                            1.0
                          ],
                          "@entity.mistakes"
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            ">=",
                            "@entity.placed",
                            [
                              "array/len",
                              "@entity.blueprint"
                            ]
                          ],
                          "won",
                          [
                            "if",
                            [
                              ">=",
                              "@entity.mistakes",
                              3.0
                            ],
                            "lost",
                            "none"
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.features",
                        [
                          "array/map",
                          "@entity.blueprint",
                          [
                            "fn",
                            "b",
                            [
                              "if",
                              [
                                "==",
                                "@b.filled",
                                true
                              ],
                              {
                                "assetUrl": "@b.brickModel",
                                "id": "@b.id",
                                "type": "brick",
                                "x": "@b.x",
                                "y": "@b.y"
                              },
                              {
                                "assetUrl": "@config.markerModel",
                                "id": "@b.id",
                                "type": "marker",
                                "x": "@b.x",
                                "y": "@b.y"
                              }
                            ]
                          ]
                        ]
                      ],
                      [
                        "render-ui",
                        "main",
                        {
                          "children": [
                            {
                              "backgroundColor": "@config.bgColor",
                              "events": "@entity.fx",
                              "features": "@entity.features",
                              "scale": "@config.scale",
                              "tileClickEvent": "TILE_CLICK",
                              "tiles": "@config.tiles",
                              "type": "game-canvas-3d",
                              "units": []
                            }
                          ],
                          "hud": {
                            "children": [
                              {
                                "stats": [
                                  {
                                    "label": "Placed",
                                    "value": "@entity.placed"
                                  },
                                  {
                                    "label": "Mistakes",
                                    "value": "@entity.mistakes"
                                  },
                                  {
                                    "label": "Result",
                                    "value": "@entity.result"
                                  }
                                ],
                                "type": "game-hud"
                              },
                              {
                                "action": "PLAY_AGAIN",
                                "label": "Restart",
                                "type": "button",
                                "variant": "secondary"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "md",
                            "justify": "between",
                            "type": "stack"
                          },
                          "overlay": [
                            "if",
                            [
                              "!=",
                              "@entity.result",
                              "none"
                            ],
                            {
                              "options": [
                                {
                                  "event": "PLAY_AGAIN",
                                  "id": "again",
                                  "label": "Play Again",
                                  "variant": "primary"
                                }
                              ],
                              "subtitle": [
                                "str/concat",
                                "Placed ",
                                "@entity.placed"
                              ],
                              "title": [
                                "if",
                                [
                                  "==",
                                  "@entity.result",
                                  "won"
                                ],
                                "BUILD COMPLETE",
                                "OUT OF TRIES"
                              ],
                              "type": "game-menu"
                            },
                            null
                          ],
                          "type": "game-shell"
                        }
                      ]
                    ]
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.blueprint",
                    [
                      "array/map",
                      "@config.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "object/merge",
                          "@b",
                          {
                            "filled": false
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.placed",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.mistakes",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.features",
                    [
                      "array/map",
                      "@entity.blueprint",
                      [
                        "fn",
                        "b",
                        [
                          "if",
                          [
                            "==",
                            "@b.filled",
                            true
                          ],
                          {
                            "assetUrl": "@b.brickModel",
                            "id": "@b.id",
                            "type": "brick",
                            "x": "@b.x",
                            "y": "@b.y"
                          },
                          {
                            "assetUrl": "@config.markerModel",
                            "id": "@b.id",
                            "type": "marker",
                            "x": "@b.x",
                            "y": "@b.y"
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "backgroundColor": "@config.bgColor",
                          "events": "@entity.fx",
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "units": []
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Placed",
                                "value": "@entity.placed"
                              },
                              {
                                "label": "Mistakes",
                                "value": "@entity.mistakes"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "options": [
                            {
                              "event": "PLAY_AGAIN",
                              "id": "again",
                              "label": "Play Again",
                              "variant": "primary"
                            }
                          ],
                          "subtitle": [
                            "str/concat",
                            "Placed ",
                            "@entity.placed"
                          ],
                          "title": [
                            "if",
                            [
                              "==",
                              "@entity.result",
                              "won"
                            ],
                            "BUILD COMPLETE",
                            "OUT OF TRIES"
                          ],
                          "type": "game-menu"
                        },
                        null
                      ],
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "playing",
                "to": "playing"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
