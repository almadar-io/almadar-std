                    "set",
                    "@entity.gridHeight",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          16.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              16.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "cover",
                                    [
                                      "and",
                                      [
                                        ">=",
                                        "@gy",
                                        3.0
                                      ],
                                      [
                                        "and",
                                        [
                                          "<=",
                                          "@gy",
                                          12.0
                                        ],
                                        [
                                          "==",
                                          [
                                            "math/mod",
                                            [
                                              "+",
                                              [
                                                "*",
                                                "@gx",
                                                3.0
                                              ],
                                              [
                                                "*",
                                                "@gy",
                                                7.0
                                              ]
                                            ],
                                            8.0
                                          ],
                                          0.0
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                {
                                  "id": [
                                    "str/concat",
                                    "t-",
                                    "@gx",
                                    "-",
                                    "@gy"
                                  ],
                                  "modelUrl": [
                                    "if",
                                    "@cover",
                                    "@config.coverAsset",
                                    "@config.groundAsset"
                                  ],
                                  "passable": [
                                    "if",
                                    "@cover",
                                    false,
                                    true
                                  ],
                                  "terrain": [
                                    "if",
                                    "@cover",
                                    "wall",
                                    "stone"
                                  ],
                                  "x": "@gx",
                                  "y": "@gy"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
