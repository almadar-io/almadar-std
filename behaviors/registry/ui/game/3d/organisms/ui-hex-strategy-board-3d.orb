                "from": "gameover",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.fx",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.fx",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.turnsLeft",
                  [
                    "math/max",
                    0.0,
                    [
                      "-",
                      "@entity.turnsLeft",
                      1.0
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "<=",
                      "@entity.turnsLeft",
                      0.0
                    ],
                    "lost",
                    "@entity.result"
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ],
                [
                  "render-ui",
                  "main",
