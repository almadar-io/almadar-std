                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets the board for a new match",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.claimed",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.claimedIds",
                    []
                  ],
                  [
                    "set",
                    "@entity.totalBuildings",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.turnsLeft",
                    "@config.startingTurns"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    14.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    2.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          14.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              14.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "obstacle",
                                    [
                                      "and",
                                      [
                                        ">=",
                                        "@gy",
                                        3.0
                                      ],
                                      [
                                        "and",
                                        [
                                          "<=",
                                          "@gy",
                                          10.0
                                        ],
                                        [
                                          "==",
                                          [
                                            "math/mod",
                                            [
                                              "+",
                                              [
                                                "*",
                                                "@gx",
                                                5.0
                                              ],
                                              [
                                                "*",
                                                "@gy",
                                                3.0
                                              ]
                                            ],
                                            7.0
                                          ],
                                          0.0
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "isWater",
                                      [
                                        "==",
                                        [
                                          "math/mod",
                                          "@gx",
                                          2.0
                                        ],
                                        0.0
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "isVillage",
                                        [
                                          "and",
                                          [
                                            "==",
                                            "@gx",
                                            4.0
                                          ],
                                          [
                                            "==",
                                            "@gy",
                                            3.0
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "let",
                                      [
                                        [
                                          "isMarket",
                                          [
                                            "and",
                                            [
                                              "==",
                                              "@gx",
                                              9.0
                                            ],
                                            [
                                              "==",
                                              "@gy",
                                              7.0
                                            ]
                                          ]
                                        ]
                                      ],
                                      [
                                        "let",
                                        [
                                          [
                                            "isWindmill",
                                            [
                                              "and",
                                              [
                                                "==",
                                                "@gx",
                                                5.0
                                              ],
                                              [
                                                "==",
                                                "@gy",
                                                10.0
                                              ]
                                            ]
                                          ]
                                        ],
                                        {
                                          "claimable": [
                                            "if",
                                            "@isVillage",
                                            true,
                                            [
                                              "if",
                                              "@isMarket",
                                              true,
                                              [
                                                "if",
                                                "@isWindmill",
                                                true,
                                                false
                                              ]
                                            ]
                                          ],
                                          "id": [
                                            "str/concat",
                                            "t-",
                                            "@gx",
                                            "-",
                                            "@gy"
                                          ],
                                          "modelUrl": [
                                            "if",
                                            "@isVillage",
                                            "@config.villageAsset",
                                            [
                                              "if",
                                              "@isMarket",
                                              "@config.marketAsset",
                                              [
                                                "if",
                                                "@isWindmill",
                                                "@config.windmillAsset",
                                                [
                                                  "if",
                                                  "@obstacle",
                                                  [
                                                    "if",
                                                    "@isWater",
                                                    "@config.waterAsset",
                                                    "@config.mountainAsset"
                                                  ],
                                                  "@config.grassAsset"
                                                ]
                                              ]
                                            ]
                                          ],
                                          "passable": [
                                            "if",
                                            [
                                              "or",
                                              "@isVillage",
                                              [
                                                "or",
                                                "@isMarket",
                                                "@isWindmill"
                                              ]
                                            ],
                                            true,
                                            [
                                              "if",
                                              "@obstacle",
                                              false,
                                              true
                                            ]
                                          ],
                                          "terrain": [
                                            "if",
                                            "@isVillage",
                                            "village",
                                            [
                                              "if",
                                              "@isMarket",
                                              "market",
                                              [
                                                "if",
                                                "@isWindmill",
                                                "windmill",
                                                [
                                                  "if",
                                                  "@obstacle",
                                                  [
                                                    "if",
                                                    "@isWater",
                                                    "water",
                                                    "mountain"
                                                  ],
                                                  "grass"
                                                ]
                                              ]
                                            ]
                                          ],
                                          "x": "@gx",
                                          "y": "@gy"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "cameraMode": "top-down",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Claimed",
                            "value": "@entity.claimed"
                          },
                          {
                            "label": "Turns Left",
                            "value": "@entity.turnsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          },
                          {
                            "label": "Goal",
                            "value": "Claim the village, market & windmill"
                          },
                          {
                            "label": "How",
                            "value": "Click your settler, then click a highlighted hex to move"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@entity.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "cameraMode": "top-down",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Claimed",
                            "value": "@entity.claimed"
                          },
                          {
                            "label": "Turns Left",
                            "value": "@entity.turnsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          },
                          {
                            "label": "Goal",
                            "value": "Claim the village, market & windmill"
                          },
                          {
                            "label": "How",
                            "value": "Click your settler, then click a highlighted hex to move"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedUnitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.z"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "let",
                    [
                      [
                        "tile",
                        [
                          "array/find",
                          "@entity.tiles",
                          [
                            "fn",
                            "t",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "x"
                                ],
                                "@payload.x"
                              ],
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "y"
                                ],
                                "@payload.z"
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "isNewClaim",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@tile",
                                "claimable"
                              ],
                              true
                            ],
                            [
                              "not",
                              [
                                "array/includes",
                                "@entity.claimedIds",
                                [
                                  "object/get",
                                  "@tile",
                                  "id"
                                ]
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "do",
                        [
                          "set",
                          "@entity.claimedIds",
                          [
                            "if",
                            "@isNewClaim",
                            [
                              "array/append",
                              "@entity.claimedIds",
                              [
                                "object/get",
                                "@tile",
                                "id"
                              ]
                            ],
                            "@entity.claimedIds"
                          ]
                        ],
                        [
                          "set",
                          "@entity.claimed",
                          [
                            "array/len",
                            "@entity.claimedIds"
                          ]
                        ],
                        [
                          "set",
                          "@entity.fx",
                          [
                            "if",
                            "@isNewClaim",
                            [
                              "array/append",
                              "@entity.fx",
                              {
                                "id": [
                                  "str/concat",
                                  "fx-claim-",
                                  [
                                    "object/get",
                                    "@tile",
                                    "id"
                                  ]
                                ],
                                "message": "+1",
                                "ttl": 3.0,
                                "type": "score",
                                "x": "@payload.x",
                                "z": "@payload.z"
                              }
                            ],
                            "@entity.fx"
                          ]
                        ],
                        [
                          "set",
                          "@entity.result",
                          [
                            "if",
                            [
                              "==",
                              "@entity.claimed",
                              "@entity.totalBuildings"
                            ],
                            "won",
                            "@entity.result"
                          ]
                        ],
                        [
                          "if",
                          [
                            "!=",
                            "@entity.result",
                            "none"
                          ],
                          [
                            "emit",
                            "GAME_END",
                            {
                              "result": "@entity.result"
                            }
                          ],
                          null
                        ]
                      ]
                    ]
                  ],
                  [
