                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
                        },
                        "@entity.gridWidth",
                        "@entity.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ],
                            "passable"
                          ],
                          true
                        ],
                        [
                          "and",
                          [
                            "<=",
                            [
                              "grid/manhattan-distance",
                              [
                                "object/get",
                                [
                                  "array/find",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "==",
                                      "@u.id",
                                      "@entity.selectedUnitId"
                                    ]
                                  ]
                                ],
                                "position"
                              ],
                              {
                                "x": "@payload.x",
                                "y": "@payload.z"
                              }
                            ],
                            "@entity.movementRange"
                          ],
                          [
                            "==",
                            [
                              "array/len",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
