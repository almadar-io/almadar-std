            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HexStrategyBoard3DItem",
          "name": "HexStrategyBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "description": "Initializes the board on first mount",
                "key": "INIT",
                "name": "Initialize",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Selects the settler on click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "-- Declarative event props --",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "tileId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
