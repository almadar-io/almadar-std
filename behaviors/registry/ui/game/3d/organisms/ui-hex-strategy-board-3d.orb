                              "==",
                              [
                                "object/get",
                                "@tile",
                                "claimable"
                              ],
                              true
                            ],
                            [
                              "not",
                              [
                                "array/includes",
                                "@entity.claimedIds",
                                [
                                  "object/get",
                                  "@tile",
                                  "id"
                                ]
                              ]
                            ]
                          ],
                          [
                            "array/append",
                            "@entity.claimedIds",
                            [
                              "object/get",
                              "@tile",
                              "id"
                            ]
                          ],
                          "@entity.claimedIds"
                        ]
                      ],
                      [
                        "set",
                        "@entity.claimed",
                        [
                          "array/len",
                          "@entity.claimedIds"
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            "==",
                            "@entity.claimed",
                            "@entity.totalBuildings"
                          ],
                          "won",
                          "@entity.result"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
