                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Claimed",
                            "value": "@entity.claimed"
                          },
                          {
                            "label": "Turns Left",
                            "value": "@entity.turnsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
                        },
                        "@entity.gridWidth",
                        "@entity.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@config.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ],
                            "passable"
                          ],
                          true
                        ],
                        [
                          "and",
                          [
                            "<=",
                            [
                              "grid/manhattan-distance",
                              [
                                "object/get",
                                [
                                  "array/find",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "==",
                                      "@u.id",
                                      "@entity.selectedUnitId"
                                    ]
                                  ]
                                ],
                                "position"
                              ],
                              {
                                "x": "@payload.x",
                                "y": "@payload.z"
                              }
                            ],
                            "@entity.movementRange"
                          ],
                          [
                            "==",
                            [
                              "array/len",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
