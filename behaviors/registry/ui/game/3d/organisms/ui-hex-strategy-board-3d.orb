                          },
                          {
                            "label": "Turns Left",
                            "value": "@entity.turnsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedUnitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.z"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "let",
                    [
                      [
                        "tile",
                        [
                          "array/find",
                          "@config.tiles",
                          [
                            "fn",
                            "t",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "x"
                                ],
                                "@payload.x"
                              ],
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "y"
                                ],
                                "@payload.z"
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
