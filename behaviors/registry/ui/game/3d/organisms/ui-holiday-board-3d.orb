          "emits": [
            {
              "description": "Move the selected unit onto a tile; collects a gift if one is present",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "tileId",
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Select the player unit and compute adjacent valid moves",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Deselect the current unit",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Reset the board for a new round",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "features",
              "giftsLeft",
              "gridHeight",
              "gridWidth",
              "movementRange",
              "phase",
              "result",
              "score",
              "selectedUnitId",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HolidayBoard3DItem",
          "name": "HolidayBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Select the player unit and compute adjacent valid moves",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Move the selected unit onto a tile; collects a gift if one is present",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "tileId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Deselect the current unit",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Reset the board for a new round",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.giftsLeft",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    5.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    5.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Gifts Left",
                            "value": "@entity.giftsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@config.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@entity.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Gifts Left",
                            "value": "@entity.giftsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "matches",
                        [
                          "array/filter",
                          "@entity.features",
                          [
                            "fn",
                            "f",
                            [
                              "and",
                              [
                                "==",
                                "@f.type",
                                "gift"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  "@f.x",
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  "@f.y",
                                  "@payload.z"
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "hasGift",
                          [
                            ">",
                            [
                              "array/len",
                              "@matches"
                            ],
                            0.0
                          ]
                        ],
                        [
                          "hitId",
                          [
                            "object/get",
                            [
                              "array/first",
                              "@matches"
                            ],
                            "id"
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "newGiftsLeft",
                            [
                              "if",
                              "@hasGift",
                              [
                                "-",
                                "@entity.giftsLeft",
                                1.0
                              ],
                              "@entity.giftsLeft"
                            ]
                          ]
                        ],
                        [
                          "do",
                          [
                            "set",
                            "@entity.units",
                            [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "if",
                                  [
                                    "==",
                                    "@u.id",
                                    "@entity.selectedUnitId"
                                  ],
                                  [
                                    "object/merge",
                                    "@u",
                                    {
                                      "position": {
                                        "x": "@payload.x",
                                        "y": "@payload.z"
                                      }
                                    }
                                  ],
                                  "@u"
                                ]
                              ]
                            ]
                          ],
                          [
                            "set",
                            "@entity.features",
                            [
                              "if",
                              "@hasGift",
                              [
                                "array/filter",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  [
                                    "!=",
                                    "@f.id",
                                    "@hitId"
                                  ]
                                ]
                              ],
                              "@entity.features"
                            ]
                          ],
                          [
                            "set",
                            "@entity.score",
                            [
                              "if",
                              "@hasGift",
                              [
                                "+",
                                "@entity.score",
                                1.0
                              ],
                              "@entity.score"
                            ]
                          ],
                          [
                            "set",
                            "@entity.giftsLeft",
                            "@newGiftsLeft"
                          ],
                          [
                            "set",
                            "@entity.selectedUnitId",
                            ""
                          ],
                          [
                            "set",
                            "@entity.validMoves",
                            []
                          ],
                          [
                            "set",
                            "@entity.phase",
                            "observation"
                          ],
                          [
                            "set",
                            "@entity.result",
                            [
                              "if",
                              [
                                "<=",
                                "@newGiftsLeft",
                                0.0
                              ],
                              "won",
                              "none"
                            ]
                          ],
                          [
                            "render-ui",
                            "main",
                            {
                              "children": [
                                {
                                  "features": "@entity.features",
                                  "scale": "@config.scale",
                                  "selectedUnitId": "@entity.selectedUnitId",
                                  "tileClickEvent": "TILE_CLICK",
                                  "tiles": "@config.tiles",
                                  "type": "game-canvas-3d",
                                  "unitClickEvent": "UNIT_CLICK",
                                  "unitScale": "@config.unitScale",
                                  "units": "@entity.units",
                                  "validMoves": "@entity.validMoves"
                                }
                              ],
                              "hud": {
                                "stats": [
                                  {
                                    "label": "Score",
                                    "value": "@entity.score"
                                  },
                                  {
                                    "label": "Gifts Left",
                                    "value": "@entity.giftsLeft"
                                  },
                                  {
                                    "label": "Result",
                                    "value": "@entity.result"
                                  }
                                ],
                                "type": "game-hud"
                              },
                              "type": "game-shell"
                            }
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
                        },
                        "@entity.gridWidth",
                        "@entity.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "<=",
                          [
                            "grid/manhattan-distance",
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    "@u.id",
                                    "@entity.selectedUnitId"
                                  ]
                                ]
                              ],
                              "position"
                            ],
                            {
                              "x": "@payload.x",
                              "y": "@payload.z"
                            }
                          ],
                          "@entity.movementRange"
                        ],
                        [
                          "==",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Gifts Left",
                            "value": "@entity.giftsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.giftsLeft",
                    4.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          },
                          {
                            "label": "Gifts Left",
                            "value": "@entity.giftsLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "npc",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.team",
                            "neutral"
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "cell",
                        [
                          "object/get",
                          "@npc",
                          "position"
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "dir",
                          [
                            "math/floor",
                            [
                              "*",
                              [
                                "math/random"
                              ],
                              4.0
                            ]
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "nextCell",
                            [
                              "if",
                              [
                                "==",
                                "@dir",
                                0.0
                              ],
                              {
                                "x": [
                                  "+",
                                  [
                                    "object/get",
                                    "@cell",
                                    "x"
                                  ],
                                  1.0
                                ],
                                "y": [
                                  "object/get",
                                  "@cell",
                                  "y"
                                ]
                              },
                              [
                                "if",
                                [
                                  "==",
                                  "@dir",
                                  1.0
                                ],
                                {
                                  "x": [
                                    "-",
                                    [
                                      "object/get",
                                      "@cell",
                                      "x"
                                    ],
                                    1.0
                                  ],
                                  "y": [
                                    "object/get",
                                    "@cell",
                                    "y"
                                  ]
                                },
                                [
                                  "if",
                                  [
                                    "==",
                                    "@dir",
                                    2.0
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@cell",
                                      "x"
                                    ],
                                    "y": [
                                      "+",
                                      [
                                        "object/get",
                                        "@cell",
                                        "y"
                                      ],
                                      1.0
                                    ]
                                  },
                                  {
                                    "x": [
                                      "object/get",
                                      "@cell",
                                      "x"
                                    ],
                                    "y": [
                                      "-",
                                      [
                                        "object/get",
                                        "@cell",
                                        "y"
                                      ],
                                      1.0
                                    ]
                                  }
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "valid",
                              [
                                "and",
                                [
                                  "grid/in-bounds",
                                  "@nextCell",
                                  "@entity.gridWidth",
                                  "@entity.gridHeight"
                                ],
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "array/find",
                                        "@config.tiles",
                                        [
                                          "fn",
                                          "t",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "x"
                                              ],
                                              [
                                                "object/get",
                                                "@nextCell",
                                                "x"
                                              ]
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "y"
                                              ],
                                              [
                                                "object/get",
                                                "@nextCell",
                                                "y"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ],
                                      "passable"
                                    ],
                                    true
                                  ],
                                  [
                                    "==",
                                    [
                                      "array/len",
                                      [
                                        "array/filter",
                                        "@entity.units",
                                        [
                                          "fn",
                                          "u",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                [
                                                  "object/get",
                                                  "@u",
                                                  "position"
                                                ],
                                                "x"
                                              ],
                                              [
                                                "object/get",
                                                "@nextCell",
                                                "x"
                                              ]
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                [
                                                  "object/get",
                                                  "@u",
                                                  "position"
                                                ],
                                                "y"
                                              ],
                                              [
                                                "object/get",
                                                "@nextCell",
                                                "y"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    0.0
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "do",
                            [
                              "set",
                              "@entity.units",
                              [
                                "if",
                                "@valid",
                                [
                                  "array/map",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "if",
                                      [
                                        "==",
                                        "@u.id",
                                        "@npc.id"
                                      ],
                                      [
                                        "object/merge",
                                        "@u",
                                        {
                                          "position": "@nextCell"
                                        }
                                      ],
                                      "@u"
                                    ]
                                  ]
                                ],
                                "@entity.units"
                              ]
                            ],
                            [
                              "render-ui",
                              "main",
                              {
                                "children": [
                                  {
                                    "features": "@entity.features",
                                    "scale": "@config.scale",
                                    "selectedUnitId": "@entity.selectedUnitId",
                                    "tileClickEvent": "TILE_CLICK",
                                    "tiles": "@config.tiles",
                                    "type": "game-canvas-3d",
                                    "unitClickEvent": "UNIT_CLICK",
                                    "unitScale": "@config.unitScale",
                                    "units": "@entity.units",
                                    "validMoves": "@entity.validMoves"
                                  }
                                ],
                                "hud": {
                                  "stats": [
                                    {
                                      "label": "Score",
                                      "value": "@entity.score"
                                    },
                                    {
                                      "label": "Gifts Left",
                                      "value": "@entity.giftsLeft"
                                    },
                                    {
                                      "label": "Result",
                                      "value": "@entity.result"
                                    }
                                  ],
                                  "type": "game-hud"
                                },
                                "type": "game-shell"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 900.0,
              "name": "reindeerWanderTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}