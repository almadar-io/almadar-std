                              "@u",
                              {
                                "position": {
                                  "x": [
                                    "math/clamp",
                                    [
                                      "+",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "x"
                                      ],
                                      [
                                        "math/sign",
                                        [
                                          "-",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@target",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ]
                                        ]
                                      ]
                                    ],
                                    0.0,
                                    [
                                      "-",
                                      "@entity.gridWidth",
                                      1.0
                                    ]
                                  ],
                                  "y": [
                                    "math/clamp",
                                    [
                                      "+",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "y"
                                      ],
                                      [
                                        "math/sign",
                                        [
                                          "-",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@target",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ],
                                    0.0,
                                    [
                                      "-",
                                      "@entity.gridHeight",
                                      1.0
                                    ]
                                  ]
                                }
                              }
                            ]
                          ],
                          "@u"
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.result",
                  [
                    "if",
                    [
                      "==",
                      [
                        "array/len",
                        [
                          "array/filter",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "and",
                              [
                                "==",
                                "@u.team",
                                "player"
                              ],
                              [
                                ">",
                                "@u.health",
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      0.0
                    ],
                    "defeat",
                    [
                      "if",
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  "@u.team",
                                  "enemy"
                                ],
                                [
                                  ">",
                                  "@u.health",
                                  0.0
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ],
                      "victory",
                      "none"
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ],
                [
                  "set",
                  "@entity.enemyTurn",
                  false
                ],
                [
                  "set",
                  "@entity.currentTeam",
                  "player"
                ],
                [
                  "set",
                  "@entity.phase",
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    "game_over",
                    "observation"
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "attackTargets": "@entity.attackTargets",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@config.tiles",
                        "type": "game-canvas-3d",
                        "unitClickEvent": "UNIT_CLICK",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Turn",
                          "value": "@entity.turn"
                        },
                        {
                          "label": "Phase",
                          "value": "@entity.phase"
                        },
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.enemyTurn",
                  true
                ],
                [
                  "==",
                  "@entity.result",
                  "none"
                ]
              ],
              "interval": 1000.0,
              "name": "enemyAiTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}