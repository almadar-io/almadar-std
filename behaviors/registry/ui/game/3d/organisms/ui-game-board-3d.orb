                    5.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    5.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    2.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.phase"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "action"
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "and",
                            [
                              "==",
                              "@u.team",
                              "enemy"
                            ],
                            [
                              ">",
                              "@u.health",
                              0.0
                            ],
                            [
                              "<=",
                              [
                                "grid/manhattan-distance",
                                [
                                  "object/get",
                                  [
                                    "array/find",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "s",
                                      [
                                        "==",
                                        "@s.id",
                                        "@entity.selectedUnitId"
                                      ]
                                    ]
                                  ],
                                  "position"
                                ],
                                [
                                  "object/get",
                                  "@u",
                                  "position"
                                ]
                              ],
                              1.0
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "u",
                        {
                          "x": [
                            "object/get",
                            [
                              "object/get",
                              "@u",
                              "position"
                            ],
                            "x"
                          ],
                          "z": [
                            "object/get",
                            [
                              "object/get",
                              "@u",
                              "position"
                            ],
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.phase"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@config.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "<=",
                              [
                                "grid/manhattan-distance",
                                [
                                  "object/get",
                                  [
                                    "array/find",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "==",
                                        "@u.id",
                                        "@payload.unitId"
                                      ]
                                    ]
                                  ],
                                  "position"
                                ],
                                {
                                  "x": [
                                    "object/get",
                                    "@t",
                                    "x"
                                  ],
