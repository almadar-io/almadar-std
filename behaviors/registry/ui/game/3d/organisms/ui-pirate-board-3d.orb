              "turn",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PirateBoard3DItem",
          "name": "PirateBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on ship click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Sea tile clicked",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{endTurnEvent} with {} on end turn",
                "key": "END_TURN",
                "name": "End Turn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when the naval skirmish ends",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called after a ship moves",
                "key": "UNIT_MOVE",
                "name": "Unit Move",
                "payloadSchema": [
                  {
                    "name": "unit",
                    "type": "object"
                  },
                  {
                    "name": "to",
                    "properties": [
                      {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      {
                        "name": "z",
                        "required": true,
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.currentTeam",
                    "player"
                  ],
                  [
                    "set",
                    "@entity.enemyTurn",
                    false
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    3.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "END_TURN",
                            "label": "End Turn",
                            "type": "button",
                            "variant": "primary"
                          },
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "backgroundColor": "@config.bgColor",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.phase"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "health": [
                                "math/max",
                                0.0,
                                [
                                  "-",
                                  "@u.health",
                                  "@config.attackDamage"
                                ]
                              ]
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  "@u.team",
                                  "enemy"
                                ],
                                [
                                  ">",
                                  "@u.health",
                                  0.0
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ],
                      "victory",
                      "none"
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
                    null
                  ],
                  [
                    "set",
                    "@entity.fx",
                    [
                      "array/append",
                      "@entity.fx",
                      {
                        "id": [
                          "str/concat",
                          "fx-atk-",
                          "@entity.turn"
                        ],
                        "message": [
                          "str/concat",
                          "-",
                          "@config.attackDamage"
                        ],
                        "ttl": 3.0,
                        "type": "hit",
                        "x": [
                          "object/get",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@payload.unitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "x"
                        ],
                        "z": [
                          "object/get",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@payload.unitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "y"
                        ]
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "END_TURN",
                            "label": "End Turn",
                            "type": "button",
                            "variant": "primary"
                          },
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "backgroundColor": "@config.bgColor",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.phase"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
