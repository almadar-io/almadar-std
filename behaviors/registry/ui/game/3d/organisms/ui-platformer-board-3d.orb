                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "hudBackgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "hud-panel",
                        "role": "ui",
                        "sprite": "panelInset_beigeLight.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "facingRight": false,
                        "vx": [
                          "-",
                          0.0,
                          "@config.moveSpeed"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "LEFT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "facingRight": true,
                        "vx": "@config.moveSpeed"
                      }
                    ]
                  ]
                ],
                "event": "RIGHT",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "jump",
                        "grounded": false,
                        "vy": [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ]
                      }
                    ]
                  ]
                ],
                "event": "JUMP",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    "@entity.player.grounded",
                    true
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "idle",
                        "vx": 0.0
                      }
                    ]
                  ]
                ],
                "event": "STOP",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "to": "playing"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "won"
                ],
                "to": "won"
              },
              {
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "lost"
                ],
                "to": "lost"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    [
                      "+",
                      "@entity.level",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "won",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "lost",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "vy1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.vy",
                          "@config.gravity"
                        ],
                        [
                          "-",
                          0.0,
                          "@config.jumpStrength"
                        ],
                        "@config.maxFallSpeed"
                      ]
                    ],
                    [
                      "px1",
                      [
                        "math/clamp",
                        [
                          "+",
                          "@entity.player.x",
                          "@entity.player.vx"
                        ],
                        0.0,
                        [
                          "-",
                          "@entity.worldWidth",
                          "@entity.player.width"
                        ]
                      ]
                    ],
                    [
                      "pw",
                      "@entity.player.width"
                    ],
                    [
                      "ph",
                      "@entity.player.height"
                    ],
                    [
                      "livesLeft",
                      [
                        "-",
                        "@entity.lives",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "py1",
                        [
                          "+",
                          "@entity.player.y",
                          "@vy1"
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "playerRect",
                          {
                            "h": "@ph",
                            "w": "@pw",
                            "x": "@px1",
                            "y": "@py1"
                          }
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "hit",
                            [
                              "array/find",
                              "@config.platforms",
                              [
                                "fn",
                                "p",
                                [
                                  "and",
                                  [
                                    "!=",
                                    [
                                      "object/get",
                                      "@p",
                                      "type"
                                    ],
                                    "goal"
                                  ],
                                  [
                                    "geo/aabb-overlap",
                                    "@playerRect",
                                    {
                                      "h": "@p.height",
                                      "w": "@p.width",
                                      "x": "@p.x",
                                      "y": "@p.y"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "hazardHit",
                              [
                                "array/find",
                                "@config.platforms",
                                [
                                  "fn",
                                  "p",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@p",
                                        "type"
                                      ],
                                      "hazard"
                                    ],
                                    [
                                      "geo/aabb-overlap",
                                      "@playerRect",
                                      {
                                        "h": "@p.height",
                                        "w": "@p.width",
                                        "x": "@p.x",
                                        "y": "@p.y"
                                      }
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "goalHit",
                                [
                                  "array/find",
                                  "@config.platforms",
                                  [
                                    "fn",
                                    "p",
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@p",
                                          "type"
                                        ],
                                        "goal"
                                      ],
                                      [
                                        "geo/aabb-overlap",
                                        "@playerRect",
                                        {
                                          "h": "@p.height",
                                          "w": "@p.width",
                                          "x": "@p.x",
                                          "y": "@p.y"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "hitY",
                                  [
                                    "object/get",
                                    "@hit",
                                    "y",
                                    "@entity.worldHeight"
                                  ]
                                ],
                                [
                                  "landed",
                                  [
                                    "and",
                                    [
                                      "!=",
                                      "@hit",
                                      null
                                    ],
                                    [
                                      ">",
                                      "@vy1",
                                      0.0
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "py2",
                                    [
                                      "if",
                                      "@landed",
                                      [
                                        "-",
                                        "@hitY",
                                        "@ph"
                                      ],
                                      "@py1"
                                    ]
                                  ],
                                  [
                                    "vy2",
                                    [
                                      "if",
                                      "@landed",
                                      0.0,
                                      "@vy1"
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "atGround",
                                      [
                                        ">=",
                                        [
                                          "+",
                                          "@py2",
                                          "@ph"
                                        ],
                                        "@entity.worldHeight"
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "py3",
                                        [
                                          "if",
                                          "@atGround",
                                          [
                                            "-",
                                            "@entity.worldHeight",
                                            "@ph"
                                          ],
                                          "@py2"
                                        ]
                                      ],
                                      [
                                        "vy3",
                                        [
                                          "if",
                                          "@atGround",
                                          0.0,
                                          "@vy2"
                                        ]
                                      ],
                                      [
                                        "grounded",
                                        [
                                          "or",
                                          "@landed",
                                          "@atGround"
                                        ]
                                      ]
                                    ],
                                    [
                                      "let",
                                      [
                                        [
                                          "fell",
                                          [
                                            ">",
                                            "@py3",
                                            "@entity.worldHeight"
                                          ]
                                        ]
                                      ],
                                      [
                                        "let",
                                        [
                                          [
                                            "damaged",
                                            [
                                              "or",
                                              [
                                                "!=",
                                                "@hazardHit",
                                                null
                                              ],
                                              "@fell"
                                            ]
                                          ]
                                        ],
                                        [
                                          "do",
                                          [
                                            "set",
                                            "@entity.player",
                                            [
                                              "object/merge",
                                              "@entity.player",
                                              {
                                                "grounded": "@grounded",
                                                "vy": "@vy3",
                                                "x": "@px1",
                                                "y": "@py3"
                                              }
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.result",
                                            [
                                              "if",
                                              [
                                                "!=",
                                                "@goalHit",
                                                null
                                              ],
                                              "won",
                                              [
                                                "if",
                                                [
                                                  "and",
                                                  "@damaged",
                                                  [
                                                    "<=",
                                                    "@livesLeft",
                                                    0.0
                                                  ]
                                                ],
                                                "lost",
                                                "none"
                                              ]
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.score",
                                            [
                                              "if",
                                              [
                                                "!=",
                                                "@goalHit",
                                                null
                                              ],
                                              [
                                                "+",
                                                "@entity.score",
                                                100.0
                                              ],
                                              "@entity.score"
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.lives",
                                            [
                                              "if",
                                              [
                                                "and",
                                                "@damaged",
                                                [
                                                  ">",
                                                  "@entity.lives",
                                                  0.0
                                                ],
                                                [
                                                  "==",
                                                  "@entity.result",
                                                  "none"
                                                ]
                                              ],
                                              "@livesLeft",
                                              "@entity.lives"
                                            ]
                                          ],
                                          [
                                            "set",
                                            "@entity.player",
                                            [
                                              "if",
                                              [
                                                "and",
                                                "@damaged",
                                                [
                                                  "==",
                                                  "@entity.result",
                                                  "none"
                                                ]
                                              ],
                                              {
                                                "animation": "idle",
                                                "facingRight": true,
                                                "frame": 0.0,
                                                "grounded": false,
                                                "height": 48.0,
                                                "vx": 0.0,
                                                "vy": 0.0,
                                                "width": 32.0,
                                                "x": 80.0,
                                                "y": 320.0
                                              },
                                              "@entity.player"
                                            ]
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 33.0,
              "name": "gameflowTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.player",
                  [
                    "object/merge",
                    "@entity.player",
                    {
                      "frame": [
                        "%",
                        [
                          "+",
                          [
                            "object/get",
                            "@entity.player",
                            "frame"
                          ],
                          1.0
                        ],
                        8.0
                      ]
                    }
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
