          "emits": [
            {
              "description": "Tile click passthrough — platformer is keyboard-driven; click coordinates for jump target",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "tileId",
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                }
              ],
              "scope": "external",
