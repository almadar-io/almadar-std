            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "won"
              },
              {
                "name": "lost"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "set",
                    "@entity.goalX",
                    "@config.goalX"
                  ],
                  [
                    "set",
                    "@entity.worldWidth",
                    "@config.worldWidth"
                  ],
                  [
                    "set",
                    "@entity.worldHeight",
                    "@config.worldHeight"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel",
                        "role": "ui",
                        "sprite": "panelInset_beige.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "children": [
                        {
                          "backgroundColor": "@config.bgColor",
                          "cameraMode": "follow",
                          "interpolateUnits": true,
                          "keyMap": {
                            "ArrowLeft": "LEFT",
                            "ArrowRight": "RIGHT",
                            "ArrowUp": "JUMP",
                            "KeyA": "LEFT",
                            "KeyD": "RIGHT",
                            "KeyW": "JUMP",
                            "Space": "JUMP"
                          },
                          "keyUpMap": {
                            "ArrowLeft": "STOP",
                            "ArrowRight": "STOP",
                            "KeyA": "STOP",
                            "KeyD": "STOP"
                          },
                          "pixelsPerUnit": 32.0,
                          "platforms": "@config.platforms",
                          "player": "@entity.player",
                          "playerSprite": "@config.playerSprite",
                          "tileClickEvent": "TILE_CLICK",
                          "tileSprites": "@config.tileSprites",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "worldHeight": "@entity.worldHeight",
                          "worldWidth": "@entity.worldWidth"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Score",
                                "value": "@entity.score"
                              },
                              {
                                "label": "Lives",
                                "value": "@entity.lives"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "directionAssets": {
