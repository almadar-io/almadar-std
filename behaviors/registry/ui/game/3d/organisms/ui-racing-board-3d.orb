                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Lap",
                                "value": [
                                  "str/concat",
                                  "@entity.lap",
                                  "/",
                                  "@config.totalLaps"
                                ]
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "directionEvents": {
