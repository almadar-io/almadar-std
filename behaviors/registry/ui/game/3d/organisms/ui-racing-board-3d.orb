                            "type": "control-grid"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "racing",
                "to": "racing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "player"
                          ],
                          [
                            "let",
                            [
                              [
                                "cur",
                                [
                                  "array/find",
                                  "@config.trackOrder",
                                  [
                                    "fn",
                                    "t",
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@t",
                                          "x"
                                        ],
                                        [
                                          "object/get",
                                          "@u.position",
                                          "x"
                                        ]
                                      ],
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@t",
                                          "y"
                                        ],
                                        [
                                          "object/get",
                                          "@u.position",
                                          "y"
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@u",
                              {
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@cur",
                                    "nextX"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@cur",
                                    "nextY"
                                  ]
                                }
                              }
                            ]
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.playerProgress",
                    [
                      "+",
                      "@entity.playerProgress",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.canAdvance",
                    false
                  ],
                  [
                    "set",
                    "@entity.lap",
                    [
                      "+",
                      [
                        "math/floor",
                        [
                          "/",
                          "@entity.playerProgress",
                          [
                            "array/len",
                            "@config.trackOrder"
                          ]
                        ]
                      ],
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.fx",
                    [
                      "if",
                      [
                        "==",
                        [
                          "%",
                          "@entity.playerProgress",
                          [
                            "array/len",
                            "@config.trackOrder"
                          ]
                        ],
                        0.0
                      ],
                      [
                        "array/append",
                        "@entity.fx",
                        {
                          "id": [
                            "str/concat",
                            "lap-",
                            "@entity.playerProgress"
                          ],
                          "message": "Lap!",
                          "ttl": 5.0,
                          "type": "score",
                          "x": 0.0,
                          "z": 0.0
                        }
                      ],
                      "@entity.fx"
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.playerProgress",
                        [
                          "*",
                          "@config.totalLaps",
                          [
                            "array/len",
                            "@config.trackOrder"
                          ]
                        ]
                      ],
                      "won",
                      "@entity.result"
                    ]
                  ],
                  [
                    "if",
                    [
                      "!=",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "emit",
                      "GAME_END",
                      {
                        "result": "@entity.result"
                      }
                    ],
