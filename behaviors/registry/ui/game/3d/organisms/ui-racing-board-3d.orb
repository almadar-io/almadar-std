          },
          "emits": [
            {
              "description": "Accelerate intent (keyboard keyMap or d-pad directionEvents) — advances one track cell when paced",
              "event": "ACCELERATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when the lap race ends",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "canAdvance",
              "fx",
              "gridHeight",
              "gridWidth",
              "lap",
              "phase",
              "playerProgress",
              "result",
              "rivalProgress",
              "selectedUnitId",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RacingBoard3DItem",
          "name": "RacingBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Accelerate intent (keyboard keyMap or d-pad directionEvents) — advances one track cell when paced",
                "key": "ACCELERATE",
                "name": "Accelerate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when the lap race ends",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "racing"
              },
              {
                "name": "finished"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "player"
                  ],
                  [
                    "set",
                    "@entity.playerProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rivalProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lap",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.canAdvance",
                    true
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "racing"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "cameraMode": "follow",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "keyMap": {
                            "ArrowUp": "ACCELERATE",
