          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with { x, z } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when all delivery targets are reached",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attackTargets",
              "deliveries",
              "fx",
              "gridHeight",
              "gridWidth",
              "movementRange",
              "movesLeft",
              "result",
              "selectedUnitId",
              "targets",
              "totalTargets",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CityBoard3DItem",
          "name": "CityBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, z } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when all delivery targets are reached",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.targets",
                    "@config.targets"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.deliveries",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalTargets",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.movesLeft",
                    "@config.moveBudget"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.selectedUnitId",
                  "@payload.unitId"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@config.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@entity.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "o",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "o",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "o",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "object/get",
                    [
                      "array/find",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "==",
                          "@u.id",
                          "@payload.unitId"
                        ]
                      ]
                    ],
                    "team"
                  ],
                  "player"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "newlyDelivered",
                        [
                          "array/filter",
                          "@entity.targets",
                          [
                            "fn",
                            "t",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "delivered"
                                ],
                                false
                              ],
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  {
                                    "x": "@payload.x",
                                    "y": "@payload.z"
                                  },
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                1.0
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.units",
                        [
                          "array/map",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "if",
                              [
                                "==",
                                "@u.id",
                                "@entity.selectedUnitId"
                              ],
                              [
                                "object/merge",
                                "@u",
                                {
                                  "position": {
                                    "x": "@payload.x",
                                    "y": "@payload.z"
                                  }
                                }
                              ],
                              "@u"
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.targets",
                        [
                          "array/map",
                          "@entity.targets",
                          [
                            "fn",
                            "t",
                            [
                              "if",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@t",
                                    "delivered"
                                  ],
                                  false
                                ],
                                [
                                  "<=",
                                  [
                                    "grid/manhattan-distance",
                                    {
                                      "x": "@payload.x",
                                      "y": "@payload.z"
                                    },
                                    {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    }
                                  ],
                                  1.0
                                ]
                              ],
                              [
                                "object/merge",
                                "@t",
                                {
                                  "delivered": true
                                }
                              ],
                              "@t"
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.deliveries",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.targets",
                            [
                              "fn",
                              "t",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "delivered"
                                ],
                                true
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.movesLeft",
                        [
                          "math/max",
                          0.0,
                          [
                            "-",
                            "@entity.movesLeft",
                            1.0
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.fx",
                        [
                          "array/reduce",
                          "@newlyDelivered",
                          [
                            "fn",
                            [
                              "acc",
                              "t"
                            ],
                            [
                              "array/append",
                              "@acc",
                              {
                                "id": [
                                  "str/concat",
                                  "fx-deliver-",
                                  [
                                    "object/get",
                                    "@t",
                                    "id"
                                  ]
                                ],
                                "message": "Delivered",
                                "ttl": 3.0,
                                "type": "pickup",
                                "x": [
                                  "object/get",
                                  "@t",
                                  "x"
                                ],
                                "z": [
                                  "object/get",
                                  "@t",
                                  "y"
                                ]
                              }
                            ]
                          ],
                          "@entity.fx"
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            "==",
                            "@entity.deliveries",
                            "@entity.totalTargets"
                          ],
                          "won",
                          [
                            "if",
                            [
                              "<=",
                              "@entity.movesLeft",
                              0.0
                            ],
                            "lost",
                            "none"
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.fx",
                        [
                          "if",
                          [
                            "==",
                            "@entity.result",
                            "lost"
                          ],
                          [
                            "array/append",
                            "@entity.fx",
                            {
                              "id": [
                                "str/concat",
                                "fx-fail-",
                                "@payload.x"
                              ],
                              "message": "Out of moves",
                              "ttl": 3.0,
                              "type": "lose",
                              "x": "@payload.x",
                              "z": "@payload.z"
                            }
                          ],
                          "@entity.fx"
                        ]
                      ],
                      [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        [
                          "emit",
                          "GAME_END",
                          {
                            "result": "@entity.result"
                          }
                        ],
                        null
                      ],
                      [
                        "set",
                        "@entity.selectedUnitId",
                        ""
                      ],
                      [
                        "set",
                        "@entity.validMoves",
                        []
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "!=",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.z"
                      },
                      "@entity.gridWidth",
                      "@entity.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@entity.selectedUnitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.x",
                            "y": "@payload.z"
                          }
                        ],
                        "@entity.movementRange"
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@config.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "t",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "t",
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ],
                            "passable"
                          ],
                          true
                        ],
                        [
                          "==",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@entity.units",
                              [
                                "fn",
                                "o",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "o",
                                        "position"
                                      ],
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "o",
                                        "position"
                                      ],
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "overlay": {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "GAME_END",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.result",
                  "none"
                ],
                "to": "gameover"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.targets",
                    "@config.targets"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.deliveries",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.movesLeft",
                    "@config.moveBudget"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "events": "@entity.fx",
                          "features": "@config.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Deliveries",
                            "value": "@entity.deliveries"
                          },
                          {
                            "label": "Moves",
                            "value": "@entity.movesLeft"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "gameover",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.fx",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.fx",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "if",
                        [
                          "==",
                          [
                            "object/get",
                            "@u",
                            "team"
                          ],
                          "neutral"
                        ],
                        [
                          "let",
                          [
                            [
                              "cur",
                              [
                                "object/get",
                                "@u",
                                "position"
                              ]
                            ],
                            [
                              "headingB",
                              [
                                "object/get",
                                "@u",
                                "headingToB"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "tgt",
                                [
                                  "if",
                                  "@headingB",
                                  [
                                    "object/get",
                                    "@u",
                                    "routeB"
                                  ],
                                  [
                                    "object/get",
                                    "@u",
                                    "routeA"
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "atTarget",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@cur",
                                        "x"
                                      ],
                                      [
                                        "object/get",
                                        "@tgt",
                                        "x"
                                      ]
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@cur",
                                        "y"
                                      ],
                                      [
                                        "object/get",
                                        "@tgt",
                                        "y"
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "nextHeading",
                                    [
                                      "if",
                                      "@atTarget",
                                      [
                                        "if",
                                        "@headingB",
                                        false,
                                        true
                                      ],
                                      "@headingB"
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "step",
                                      {
                                        "x": [
                                          "math/clamp",
                                          [
                                            "+",
                                            [
                                              "object/get",
                                              "@cur",
                                              "x"
                                            ],
                                            [
                                              "math/sign",
                                              [
                                                "-",
                                                [
                                                  "object/get",
                                                  "@tgt",
                                                  "x"
                                                ],
                                                [
                                                  "object/get",
                                                  "@cur",
                                                  "x"
                                                ]
                                              ]
                                            ]
                                          ],
                                          0.0,
                                          [
                                            "-",
                                            "@entity.gridWidth",
                                            1.0
                                          ]
                                        ],
                                        "y": [
                                          "math/clamp",
                                          [
                                            "+",
                                            [
                                              "object/get",
                                              "@cur",
                                              "y"
                                            ],
                                            [
                                              "math/sign",
                                              [
                                                "-",
                                                [
                                                  "object/get",
                                                  "@tgt",
                                                  "y"
                                                ],
                                                [
                                                  "object/get",
                                                  "@cur",
                                                  "y"
                                                ]
                                              ]
                                            ]
                                          ],
                                          0.0,
                                          [
                                            "-",
                                            "@entity.gridHeight",
                                            1.0
                                          ]
                                        ]
                                      }
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "ntile",
                                        [
                                          "array/find",
                                          "@config.tiles",
                                          [
                                            "fn",
                                            "t",
                                            [
                                              "and",
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "x"
                                                ],
                                                [
                                                  "object/get",
                                                  "@step",
                                                  "x"
                                                ]
                                              ],
                                              [
                                                "==",
                                                [
                                                  "object/get",
                                                  "@t",
                                                  "y"
                                                ],
                                                [
                                                  "object/get",
                                                  "@step",
                                                  "y"
                                                ]
                                              ]
                                            ]
                                          ]
                                        ]
                                      ],
                                      [
                                        "occupied",
                                        [
                                          "array/find",
                                          "@entity.units",
                                          [
                                            "fn",
                                            "o",
                                            [
                                              "and",
                                              [
                                                "!=",
                                                "@o.id",
                                                "@u.id"
                                              ],
                                              [
                                                "and",
                                                [
                                                  "==",
                                                  [
                                                    "object/get",
                                                    [
                                                      "object/get",
                                                      "@o",
                                                      "position"
                                                    ],
                                                    "x"
                                                  ],
                                                  [
                                                    "object/get",
                                                    "@step",
                                                    "x"
                                                  ]
                                                ],
                                                [
                                                  "==",
                                                  [
                                                    "object/get",
                                                    [
                                                      "object/get",
                                                      "@o",
                                                      "position"
                                                    ],
                                                    "y"
                                                  ],
                                                  [
                                                    "object/get",
                                                    "@step",
                                                    "y"
                                                  ]
                                                ]
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "if",
                                      [
                                        "and",
                                        [
                                          "!=",
                                          "@ntile",
                                          null
                                        ],
                                        [
                                          "and",
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@ntile",
                                              "passable"
                                            ],
                                            true
                                          ],
                                          [
                                            "==",
                                            "@occupied",
                                            null
                                          ]
                                        ]
                                      ],
                                      [
                                        "object/merge",
                                        "@u",
                                        {
                                          "headingToB": "@nextHeading",
                                          "position": "@step"
                                        }
                                      ],
                                      [
                                        "object/merge",
                                        "@u",
                                        {
                                          "headingToB": "@nextHeading"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        "@u"
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "CANCEL",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        },
                        {
                          "action": "PLAY_AGAIN",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "children": [
                      {
                        "attackTargets": "@entity.attackTargets",
                        "events": "@entity.fx",
                        "features": "@config.features",
                        "interpolateUnits": true,
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tiles": "@config.tiles",
                        "type": "game-canvas-3d",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Deliveries",
                          "value": "@entity.deliveries"
                        },
                        {
                          "label": "Moves",
                          "value": "@entity.movesLeft"
                        },
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1200.0,
              "name": "trafficTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}