              "tier": "domain"
            },
            {
              "description": "Resets the board after victory or defeat",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attackTargets",
              "energyLeft",
              "features",
              "fx",
              "gridHeight",
              "gridWidth",
              "movementRange",
              "result",
              "selectedUnitId",
              "stone",
              "stoneGoal",
              "tiles",
              "units",
              "validMoves",
              "wood",
              "woodGoal"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "NatureSurvivalBoard3DItem",
          "name": "NatureSurvivalBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Selects the survivor unit and computes valid move tiles",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Gathers an adjacent resource, or moves the survivor to a valid tile",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears the current unit selection",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Builds the camp (campfire + tent) once wood/stone goals are met",
                "key": "BUILD_CAMP",
                "name": "Build Camp",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when the match ends in victory or defeat",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets the board after victory or defeat",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "set",
                    "@entity.wood",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.stone",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.woodGoal",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.stoneGoal",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.energyLeft",
                    "@config.turnBudget"
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    16.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.tiles",
                    [
                      "array/flatten",
                      [
                        "array/map",
                        [
                          "array/range",
                          0.0,
                          16.0
                        ],
                        [
                          "fn",
                          "gy",
                          [
                            "array/map",
                            [
                              "array/range",
                              0.0,
                              16.0
                            ],
                            [
                              "fn",
                              "gx",
                              [
                                "let",
                                [
                                  [
                                    "obstacle",
                                    [
                                      "==",
                                      [
                                        "math/mod",
                                        [
                                          "+",
                                          [
                                            "*",
                                            "@gx",
                                            5.0
                                          ],
                                          [
                                            "*",
                                            "@gy",
                                            3.0
                                          ]
                                        ],
                                        11.0
                                      ],
                                      0.0
                                    ]
                                  ],
                                  [
                                    "isRiver",
                                    [
                                      "==",
                                      [
                                        "math/mod",
                                        "@gy",
                                        2.0
                                      ],
                                      0.0
                                    ]
                                  ]
                                ],
                                {
                                  "id": [
                                    "str/concat",
                                    "t-",
                                    "@gx",
                                    "-",
                                    "@gy"
                                  ],
                                  "modelUrl": [
                                    "if",
                                    "@obstacle",
                                    [
                                      "if",
                                      "@isRiver",
                                      "@config.riverAsset",
                                      "@config.cliffAsset"
                                    ],
                                    "@config.groundAsset"
                                  ],
                                  "passable": [
                                    "if",
                                    "@obstacle",
                                    false,
                                    true
                                  ],
                                  "terrain": [
                                    "if",
                                    "@obstacle",
                                    [
                                      "if",
                                      "@isRiver",
                                      "river",
                                      "cliff"
                                    ],
                                    "grass"
                                  ],
                                  "x": "@gx",
                                  "y": "@gy"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "cameraMode": "top-down",
                          "events": "@entity.fx",
                          "features": "@entity.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Wood",
                                "value": "@entity.wood"
                              },
                              {
                                "label": "Stone",
                                "value": "@entity.stone"
                              },
                              {
                                "label": "Energy",
                                "value": "@entity.energyLeft"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              },
                              {
                                "label": "Goal",
                                "value": "Gather 4 wood + 4 stone, then build camp"
                              },
                              {
                                "label": "How",
                                "value": "Click survivor, then click an adjacent tile to move or gather"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "BUILD_CAMP",
                            "label": "Build Camp",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "align": "center",
                          "children": [
                            {
                              "stats": [
                                {
                                  "label": "Result",
                                  "value": "@entity.result"
                                }
                              ],
                              "type": "game-hud"
                            },
                            {
                              "action": "PLAY_AGAIN",
                              "label": "Play Again",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        },
                        null
                      ],
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              "@t.passable",
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": "@t.x",
                                    "y": "@t.y"
                                  }
                                ],
                                "@entity.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          "@t.x"
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          "@t.y"
                                        ]
                                      ]
