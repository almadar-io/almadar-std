                                            ],
                                            [
                                              "+",
                                              [
                                                "-",
                                                "@config.roamMaxY",
                                                "@config.roamMinY"
                                              ],
                                              1.0
                                            ]
                                          ]
                                        ]
                                      ],
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "y"
                                      ]
                                    ]
                                  ]
                                ],
                                "@config.roamMinY",
                                "@config.roamMaxY"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "valid",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      [
                                        "array/find",
                                        "@entity.tiles",
                                        [
                                          "fn",
                                          "t",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "t",
                                                "x"
                                              ],
                                              "@nx"
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "t",
                                                "y"
                                              ],
                                              "@ny"
                                            ]
                                          ]
                                        ]
                                      ],
                                      "passable"
                                    ],
                                    true
                                  ],
                                  [
                                    "==",
                                    [
                                      "array/len",
                                      [
                                        "array/filter",
                                        "@entity.units",
                                        [
                                          "fn",
                                          "o",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                [
                                                  "object/get",
                                                  "o",
                                                  "position"
                                                ],
                                                "x"
                                              ],
                                              "@nx"
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                [
                                                  "object/get",
                                                  "o",
                                                  "position"
                                                ],
                                                "y"
                                              ],
                                              "@ny"
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    0.0
                                  ]
                                ]
                              ]
                            ],
                            [
                              "if",
                              "@valid",
                              [
                                "object/merge",
                                "@u",
                                {
                                  "position": {
                                    "x": "@nx",
                                    "y": "@ny"
                                  }
                                }
                              ],
                              "@u"
                            ]
                          ]
                        ],
                        "@u"
