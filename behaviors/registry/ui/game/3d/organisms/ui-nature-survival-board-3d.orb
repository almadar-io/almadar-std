            },
            {
              "description": "Gathers an adjacent resource, or moves the survivor to a valid tile",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "type": "number"
                },
                {
                  "name": "tileId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Clears the current unit selection",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Builds the camp (campfire + tent) once wood/stone goals are met",
              "event": "BUILD_CAMP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when the match ends in victory or defeat",
              "event": "GAME_END",
              "payloadSchema": [
                {
