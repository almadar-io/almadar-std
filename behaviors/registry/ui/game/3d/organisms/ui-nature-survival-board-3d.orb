                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "x"
                                  ],
                                  [
                                    "math/sign",
                                    [
                                      "-",
                                      [
                                        "math/floor",
                                        [
                                          "+",
                                          "@config.roamMinX",
