          },
          "emits": [
            {
              "description": "Accelerate intent (keyboard keyMap or d-pad directionEvents) — advances one track cell when paced, collecting a coin if present",
              "event": "ACCELERATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when the lap race ends",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "canAdvance",
              "features",
              "fx",
              "gridHeight",
              "gridWidth",
              "lap",
              "playerProgress",
              "result",
              "rivalProgress",
              "score",
              "selectedUnitId",
              "trackLength",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ToyTrackBoard3DItem",
          "name": "ToyTrackBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Accelerate intent (keyboard keyMap or d-pad directionEvents) — advances one track cell when paced, collecting a coin if present",
                "key": "ACCELERATE",
                "name": "Accelerate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when the lap race ends",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.playerProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rivalProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.trackLength",
                    20.0
                  ],
                  [
                    "set",
                    "@entity.lap",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.canAdvance",
                    true
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "player-car"
                  ],
                  [
                    "set",
                    "@entity.fx",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "backgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel",
                        "role": "ui",
