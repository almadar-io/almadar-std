                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "nextOrder",
                        [
                          "%",
                          [
                            "+",
                            "@entity.playerProgress",
                            1.0
                          ],
                          "@entity.trackLength"
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "target",
                          [
                            "array/find",
                            "@config.tiles",
                            [
                              "fn",
                              "t",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "order"
                                ],
                                "@nextOrder"
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "coinHit",
                            [
                              "array/find",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "type"
                                    ],
                                    "coin"
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      [
                                        "object/get",
                                        "@target",
                                        "x"
                                      ]
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ],
                                      [
                                        "object/get",
                                        "@target",
                                        "y"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "do",
                          [
                            "set",
                            "@entity.units",
                            [
                              "array/map",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "if",
                                  [
                                    "==",
                                    "@u.id",
                                    "player-car"
                                  ],
                                  [
                                    "object/merge",
                                    "@u",
                                    {
                                      "position": {
                                        "x": [
                                          "object/get",
                                          "@target",
                                          "x"
                                        ],
                                        "y": [
                                          "object/get",
                                          "@target",
                                          "y"
                                        ]
                                      }
                                    }
                                  ],
                                  "@u"
                                ]
                              ]
                            ]
                          ],
                          [
                            "set",
                            "@entity.features",
                            [
                              "if",
                              [
                                "!=",
                                "@coinHit",
                                null
                              ],
                              [
                                "array/filter",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  [
                                    "or",
                                    [
                                      "!=",
                                      [
                                        "object/get",
                                        "@f",
                                        "type"
                                      ],
                                      "coin"
                                    ],
                                    [
                                      "or",
                                      [
                                        "!=",
                                        [
                                          "object/get",
                                          "@f",
                                          "x"
                                        ],
                                        [
                                          "object/get",
                                          "@target",
                                          "x"
                                        ]
                                      ],
                                      [
                                        "!=",
                                        [
                                          "object/get",
                                          "@f",
                                          "y"
                                        ],
                                        [
                                          "object/get",
                                          "@target",
                                          "y"
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              "@entity.features"
                            ]
                          ],
                          [
                            "set",
                            "@entity.score",
                            [
                              "if",
                              [
                                "!=",
                                "@coinHit",
                                null
                              ],
                              [
                                "+",
                                "@entity.score",
                                5.0
                              ],
                              "@entity.score"
                            ]
                          ],
                          [
                            "set",
                            "@entity.playerProgress",
                            [
                              "+",
                              "@entity.playerProgress",
                              1.0
                            ]
                          ],
                          [
                            "set",
                            "@entity.canAdvance",
                            false
                          ],
                          [
                            "set",
                            "@entity.lap",
                            [
                              "+",
                              [
                                "math/floor",
                                [
                                  "/",
                                  "@entity.playerProgress",
                                  "@entity.trackLength"
                                ]
                              ],
                              1.0
                            ]
                          ],
                          [
                            "set",
                            "@entity.fx",
                            [
                              "if",
                              [
                                "!=",
                                "@coinHit",
                                null
                              ],
                              [
                                "array/append",
                                "@entity.fx",
                                {
                                  "id": [
                                    "str/concat",
                                    "pickup-",
                                    "@entity.playerProgress"
                                  ],
                                  "message": "+5",
                                  "ttl": 5.0,
                                  "type": "pickup",
                                  "x": [
                                    "object/get",
                                    "@target",
                                    "x"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@target",
                                    "y"
                                  ]
                                }
                              ],
                              "@entity.fx"
                            ]
                          ],
                          [
                            "set",
                            "@entity.fx",
                            [
                              "if",
                              [
                                "==",
                                [
                                  "%",
                                  "@entity.playerProgress",
                                  "@entity.trackLength"
                                ],
                                0.0
                              ],
                              [
                                "array/append",
                                "@entity.fx",
                                {
                                  "id": [
                                    "str/concat",
                                    "lap-",
                                    "@entity.playerProgress"
                                  ],
                                  "message": "Lap!",
                                  "ttl": 5.0,
                                  "type": "score",
                                  "x": 0.0,
                                  "z": 0.0
                                }
                              ],
                              "@entity.fx"
                            ]
                          ],
                          [
                            "set",
                            "@entity.result",
                            [
                              "if",
                              [
                                ">=",
                                "@entity.playerProgress",
                                [
                                  "*",
                                  "@config.totalLaps",
                                  "@entity.trackLength"
                                ]
                              ],
                              "victory",
                              "@entity.result"
                            ]
                          ],
                          [
                            "set",
                            "@entity.fx",
                            [
                              "if",
                              [
                                "!=",
                                "@entity.result",
                                "none"
                              ],
                              [
                                "array/append",
                                "@entity.fx",
                                {
                                  "id": "result-fx",
