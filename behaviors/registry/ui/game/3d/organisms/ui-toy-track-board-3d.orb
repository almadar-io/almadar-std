          },
          "emits": [
            {
              "description": "Player advances to the next track cell along the loop",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "z",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "tileId",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attackTargets",
              "gridHeight",
              "gridWidth",
              "playerProgress",
              "result",
              "rivalProgress",
              "selectedUnitId",
              "trackLength",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ToyTrackBoard3DItem",
          "name": "ToyTrackBoard3DRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Player advances to the next track cell along the loop",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.playerProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rivalProgress",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.trackLength",
                    20.0
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    6.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.attackTargets",
                    []
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@config.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "==",
                            [
                              "object/get",
                              "@t",
                              "order"
                            ],
                            [
                              "%",
                              [
                                "+",
                                "@entity.playerProgress",
                                1.0
                              ],
                              "@entity.trackLength"
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel",
                        "role": "ui",
                        "sprite": "panelInset_beige.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Progress",
                            "value": "@entity.playerProgress"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "hudBackgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "hud-panel",
                        "role": "ui",
                        "sprite": "panelInset_beigeLight.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.playerProgress",
                    [
                      "+",
                      "@entity.playerProgress",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "player-car"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.z"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.playerProgress",
                        "@entity.trackLength"
                      ],
                      "victory",
                      "@entity.result"
                    ]
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@config.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "==",
                            [
                              "object/get",
                              "@t",
                              "order"
                            ],
                            [
                              "%",
                              [
                                "+",
                                "@entity.playerProgress",
                                1.0
                              ],
                              "@entity.trackLength"
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel",
                        "role": "ui",
                        "sprite": "panelInset_beige.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "children": [
                        {
                          "attackTargets": "@entity.attackTargets",
                          "features": "@config.features",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "game-canvas-3d",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Progress",
                            "value": "@entity.playerProgress"
                          },
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "hudBackgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "hud-panel",
                        "role": "ui",
                        "sprite": "panelInset_beigeLight.png",
                        "style": "vector-flat",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                        "variant": ""
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "let",
                    [
                      [
                        "target",
                        [
                          "array/find",
                          "@config.tiles",
                          [
                            "fn",
                            "t",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "x"
                                ],
                                "@payload.x"
                              ],
                              [
                                "==",
                                [
                                  "object/get",
                                  "@t",
                                  "y"
                                ],
                                "@payload.z"
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "and",
                      [
                        "!=",
                        "@target",
                        null
                      ],
                      [
                        "and",
                        [
                          "==",
                          [
                            "object/get",
                            "@target",
                            "passable"
                          ],
                          true
                        ],
                        [
                          "==",
                          [
                            "object/get",
                            "@target",
                            "order"
                          ],
                          [
                            "%",
                            [
                              "+",
                              "@entity.playerProgress",
                              1.0
                            ],
                            "@entity.trackLength"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "nextOrder",
                      [
                        "%",
                        [
                          "+",
                          "@entity.rivalProgress",
                          1.0
                        ],
                        "@entity.trackLength"
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "target",
                        [
                          "array/find",
                          "@config.tiles",
                          [
                            "fn",
                            "t",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "order"
                              ],
                              "@nextOrder"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.rivalProgress",
                        [
                          "+",
                          "@entity.rivalProgress",
                          1.0
                        ]
                      ],
                      [
                        "set",
                        "@entity.units",
                        [
                          "array/map",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "if",
                              [
                                "==",
                                "@u.id",
                                "rival-car"
                              ],
                              [
                                "object/merge",
                                "@u",
                                {
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@target",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@target",
                                      "y"
                                    ]
                                  }
                                }
                              ],
                              "@u"
                            ]
                          ]
                        ]
                      ],
                      [
                        "set",
                        "@entity.result",
                        [
                          "if",
                          [
                            ">=",
                            "@entity.rivalProgress",
                            "@entity.trackLength"
                          ],
                          "defeat",
                          "@entity.result"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel",
                      "role": "ui",
                      "sprite": "panelInset_beige.png",
                      "style": "vector-flat",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                      "variant": ""
                    },
                    "children": [
                      {
                        "attackTargets": "@entity.attackTargets",
                        "features": "@config.features",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@config.tiles",
                        "type": "game-canvas-3d",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Progress",
                          "value": "@entity.playerProgress"
                        },
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "hudBackgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "hud-panel",
                      "role": "ui",
                      "sprite": "panelInset_beigeLight.png",
                      "style": "vector-flat",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                      "variant": ""
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1200.0,
              "name": "rivalAdvanceTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}