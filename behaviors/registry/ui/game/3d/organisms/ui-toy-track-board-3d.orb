                              "id": "result-fx",
                              "message": [
                                "if",
                                [
                                  "==",
                                  "@entity.result",
                                  "victory"
                                ],
                                "You Win!",
                                "You Lose!"
                              ],
                              "ttl": 999.0,
                              "type": [
                                "if",
                                [
                                  "==",
                                  "@entity.result",
                                  "victory"
                                ],
                                "win",
                                "lose"
                              ],
                              "x": 0.0,
                              "z": 0.0
                            }
                          ],
                          "@entity.fx"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "if",
                  [
                    "!=",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "emit",
                    "GAME_END",
                    {
                      "result": "@entity.result"
                    }
                  ],
                  null
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "PLAY_AGAIN",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "backgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel",
                      "role": "ui",
                      "sprite": "panelInset_beige.png",
                      "style": "vector-flat",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                      "variant": ""
                    },
                    "children": [
                      {
                        "cameraMode": "follow",
                        "events": "@entity.fx",
                        "features": "@entity.features",
                        "interpolateUnits": true,
                        "keyMap": {
                          "ArrowUp": "ACCELERATE",
                          "KeyW": "ACCELERATE",
                          "Space": "ACCELERATE"
                        },
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tiles": "@config.tiles",
                        "type": "game-canvas-3d",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "Lap",
                              "value": [
                                "str/concat",
                                "@entity.lap",
                                "/",
                                "@config.totalLaps"
                              ]
                            },
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            },
                            {
                              "label": "Result",
                              "value": "@entity.result"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "directionEvents": {
                            "up": "ACCELERATE"
                          },
                          "kind": "dpad",
                          "type": "control-grid"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "atlas": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "hud-panel",
                      "role": "ui",
                      "sprite": "panelInset_beigeLight.png",
                      "style": "vector-flat",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png",
                      "variant": ""
                    },
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1200.0,
              "name": "rivalAdvanceTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}