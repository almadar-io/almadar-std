                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears the current selection",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Requests building the camp once wood/stone goals are met; survival-flow resolves the win",
                "key": "BUILD_CAMP",
                "name": "Build Camp",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              },
              {
                "description": "Hero move intent applied by the hero-nav authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Advances neutral NPCs one random step via the hero-nav authority",
                "key": "WANDER",
                "name": "Wander",
                "payloadSchema": [
                  {
                    "name": "tick",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets every mechanic (units/budget, resources, result) for a new round",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "backgroundColor": "@config.bgColor",
                          "cameraMode": "@config.cameraMode",
                          "events": "@entity.fx",
                          "features": "@entity.features",
                          "interpolateUnits": true,
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "game-canvas-3d",
                          "unitClickEvent": "UNIT_CLICK",
                          "unitScale": "@config.unitScale",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              "array/concat",
                              [
                                {
                                  "label": "Wood",
                                  "value": "@entity.wood"
                                },
                                {
                                  "label": "Stone",
                                  "value": "@entity.stone"
                                },
                                {
                                  "label": "Energy",
                                  "value": "@entity.movesLeft"
                                },
                                {
                                  "label": "Result",
                                  "value": "@entity.result"
                                }
                              ],
                              "@config.extraStats"
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "BUILD_CAMP",
                            "label": "Build Camp",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "align": "center",
                          "children": [
                            {
                              "stats": [
                                {
                                  "label": "Result",
                                  "value": "@entity.result"
                                }
                              ],
                              "type": "game-hud"
                            },
                            {
                              "action": "PLAY_AGAIN",
                              "label": "Play Again",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        },
                        null
                      ],
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@config.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "MOVE",
                    {
                      "unitId": "@entity.selectedUnitId",
                      "x": "@payload.x",
                      "y": "@payload.z"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      "!=",
                      "@entity.selectedUnitId",
                      ""
                    ],
                    [
                      "and",
                      [
                        "grid/in-bounds",
                        {
                          "x": "@payload.x",
                          "y": "@payload.z"
                        },
                        "@config.gridWidth",
                        "@config.gridHeight"
                      ],
                      [
                        "and",
                        [
                          "<=",
                          [
                            "grid/manhattan-distance",
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "==",
                                    "@u.id",
                                    "@entity.selectedUnitId"
                                  ]
                                ]
                              ],
                              "position"
                            ],
                            {
                              "x": "@payload.x",
                              "y": "@payload.z"
                            }
                          ],
                          "@config.movementRange"
                        ],
                        [
                          "and",
                          [
                            "==",
                            [
                              "object/get",
                              [
                                "array/find",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ],
                              "passable"
                            ],
                            true
                          ],
                          [
                            "==",
                            [
                              "array/len",
                              [
                                "array/filter",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        [
                                          "object/get",
                                          "@u",
                                          "position"
                                        ],
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "BUILD_CAMP",
                    {
                      "id": "board"
                    }
                  ]
                ],
                "event": "BUILD_CAMP",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "and",
                    [
                      ">=",
                      "@entity.wood",
                      "@config.campWood"
                    ],
                    [
                      ">=",
                      "@entity.stone",
                      "@config.campStone"
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "RESTART",
                    {
                      "id": "board"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "CANCEL",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        },
                        {
                          "action": "PLAY_AGAIN",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "backgroundColor": "@config.bgColor",
                        "cameraMode": "@config.cameraMode",
                        "events": "@entity.fx",
                        "features": "@entity.features",
                        "interpolateUnits": true,
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "game-canvas-3d",
                        "unitClickEvent": "UNIT_CLICK",
                        "unitScale": "@config.unitScale",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            "array/concat",
                            [
                              {
                                "label": "Wood",
                                "value": "@entity.wood"
                              },
                              {
                                "label": "Stone",
                                "value": "@entity.stone"
                              },
                              {
                                "label": "Energy",
                                "value": "@entity.movesLeft"
                              },
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "@config.extraStats"
                          ],
                          "type": "game-hud"
                        },
                        {
                          "action": "BUILD_CAMP",
                          "label": "Build Camp",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "overlay": [
                      "if",
                      [
                        "!=",
                        "@entity.result",
                        "none"
                      ],
                      {
                        "align": "center",
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Result",
                                "value": "@entity.result"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "label": "Play Again",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      },
                      null
                    ],
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            },
            {
              "effects": [
                [
                  "emit",
                  "WANDER",
                  {
                    "tick": 1.0
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 900.0,
              "name": "wanderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Harvest",
          "from": "std/behaviors/std-gather"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        },
        {
          "as": "Survival",
          "from": "std/behaviors/std-survival-flow"
        }
      ]
    }
  ],
  "version": "1.0.0"
}