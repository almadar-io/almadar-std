                                "array/len",
                                [
                                  "array/filter",
                                  "@entity.customers",
                                  [
                                    "fn",
                                    "c",
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@c",
                                            "position"
                                          ],
                                          "x"
                                        ],
                                        "@payload.x"
                                      ],
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@c",
                                            "position"
                                          ],
                                          "y"
                                        ],
                                        "@payload.z"
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              0.0
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "RESTART",
                    {
                      "id": "board"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
