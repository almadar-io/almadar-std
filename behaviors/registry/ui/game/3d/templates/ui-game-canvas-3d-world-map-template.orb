{
  "description": "GameCanvas3dWorldMapTemplate — UI factory (1:1 with the @almadar/ui game-canvas-3d-world-map-template pattern).",
  "name": "ui-game-canvas-3d-world-map-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameCanvas3dWorldMapTemplateItem",
        "persistence": "runtime"
      },
      "name": "GameCanvas3dWorldMapTemplateOrbital",
      "pages": [
        {
          "name": "GameCanvas3dWorldMapTemplatePage",
          "path": "/game-canvas-3d-world-map-template",
          "traits": [
            {
              "ref": "GameCanvas3dWorldMapTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetManifest": {
              "default": {},
              "description": "GLB model URLs keyed by terrain — owns all asset choice (no hardcoded URLs in this template).",
              "label": "Asset Manifest",
              "tier": "presentation",
              "type": "json"
            },
            "attackEvent": {
              "default": "Attack Event",
              "description": "Event name for attack emission",
              "label": "Attack Event",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundColor": {
              "default": "#1a1a2e",
              "description": "Background color",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "cameraChangeEvent": {
              "default": "Camera Change Event",
              "description": "Event name for camera changes",
              "label": "Camera Change Event",
              "tier": "presentation",
              "type": "string"
            },
            "cameraMode": {
              "default": "isometric",
              "description": "3D camera mode",
              "label": "Camera Mode",
              "tier": "presentation",
              "type": "string",
              "values": [
                "isometric",
                "perspective",
                "top-down"
              ]
            },
            "cancelEvent": {
              "default": "Cancel Event",
              "description": "Event name for cancel/deselect",
              "label": "Cancel Event",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "endTurnEvent": {
              "default": "End Turn Event",
              "description": "Event name for ending turn",
              "label": "End Turn Event",
              "tier": "presentation",
              "type": "string"
            },
            "exitEvent": {
              "default": "Exit Event",
              "description": "Exit/back event name",
              "label": "Exit Event",
              "tier": "presentation",
              "type": "string"
            },
            "featureClickEvent": {
              "default": "Feature Click Event",
              "description": "Event name for feature clicks",
              "label": "Feature Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "features": {
              "default": [],
              "description": "Fallback feature data when no entity is present",
              "items": {
                "type": "string"
              },
              "label": "Features",
              "tier": "presentation",
              "type": "[json]"
            },
            "gameEndEvent": {
              "default": "Game End Event",
              "description": "Event name for game end detection",
              "label": "Game End Event",
              "tier": "presentation",
              "type": "string"
            },
            "playAgainEvent": {
              "default": "Play Again Event",
              "description": "Event name for play again / reset",
              "label": "Play Again Event",
              "tier": "presentation",
              "type": "string"
            },
            "scale": {
              "default": 0.0,
              "description": "Board zoom/group scale forwarded to GameBoard3D. Default 0.45.",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "shadows": {
              "default": false,
              "description": "Enable shadows",
              "label": "Shadows",
              "tier": "presentation",
              "type": "boolean"
            },
            "showCoordinates": {
              "default": false,
              "description": "Show coordinate overlay",
              "label": "Show Coordinates",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": false,
              "description": "Show grid helper",
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "showTileInfo": {
              "default": false,
              "description": "Show tile info on hover",
              "label": "Show Tile Info",
              "tier": "presentation",
              "type": "boolean"
            },
            "tileClickEvent": {
              "default": "Tile Click Event",
              "description": "Event name for tile clicks — forwarded to the model",
              "label": "Tile Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "tileHoverEvent": {
              "default": "Tile Hover Event",
              "description": "Event name for tile hover",
              "label": "Tile Hover Event",
              "tier": "presentation",
              "type": "string"
            },
            "tileLeaveEvent": {
              "default": "Tile Leave Event",
              "description": "Event name for tile leave",
              "label": "Tile Leave Event",
              "tier": "presentation",
              "type": "string"
            },
            "tiles": {
              "default": [],
              "description": "Fallback tile data when no entity is present (layout only — model URLs resolve from assetManifest)",
              "items": {
                "type": "string"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[json]"
            },
            "unitClickEvent": {
              "default": "Unit Click Event",
              "description": "Event name for unit clicks — forwarded to the model",
              "label": "Unit Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "unitScale": {
              "default": 0.0,
              "description": "Unit draw-size multiplier forwarded to GameBoard3D. Default 1.",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "GameCanvas3dWorldMapTemplate rows finished loading; payload.data holds the collection.",
              "event": "GameCanvas3dWorldMapTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GameCanvas3dWorldMapTemplateItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameCanvas3dWorldMapTemplateItem",
          "name": "GameCanvas3dWorldMapTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "GameCanvas3dWorldMapTemplate rows finished loading; payload.data holds the collection.",
                "key": "GameCanvas3dWorldMapTemplateLoaded",
                "name": "Game canvas3d world map template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GameCanvas3dWorldMapTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GameCanvas3dWorldMapTemplateItem",
                    {
                      "emit": {
                        "success": "GameCanvas3dWorldMapTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "attackEvent": "@config.attackEvent",
                      "backgroundColor": "@config.backgroundColor",
                      "cameraChangeEvent": "@config.cameraChangeEvent",
                      "cameraMode": "@config.cameraMode",
                      "cancelEvent": "@config.cancelEvent",
                      "className": "@config.className",
                      "endTurnEvent": "@config.endTurnEvent",
                      "entity": "@entity",
                      "exitEvent": "@config.exitEvent",
                      "featureClickEvent": "@config.featureClickEvent",
                      "features": "@config.features",
                      "gameEndEvent": "@config.gameEndEvent",
                      "playAgainEvent": "@config.playAgainEvent",
                      "scale": "@config.scale",
                      "shadows": "@config.shadows",
                      "showCoordinates": "@config.showCoordinates",
                      "showGrid": "@config.showGrid",
                      "showTileInfo": "@config.showTileInfo",
                      "tileClickEvent": "@config.tileClickEvent",
                      "tileHoverEvent": "@config.tileHoverEvent",
                      "tileLeaveEvent": "@config.tileLeaveEvent",
                      "tiles": "@config.tiles",
                      "type": "game-canvas-3d-world-map-template",
                      "unitClickEvent": "@config.unitClickEvent",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "attackEvent": "@config.attackEvent",
                      "backgroundColor": "@config.backgroundColor",
                      "cameraChangeEvent": "@config.cameraChangeEvent",
                      "cameraMode": "@config.cameraMode",
                      "cancelEvent": "@config.cancelEvent",
                      "className": "@config.className",
                      "endTurnEvent": "@config.endTurnEvent",
                      "entity": "@payload.data",
                      "exitEvent": "@config.exitEvent",
                      "featureClickEvent": "@config.featureClickEvent",
                      "features": "@config.features",
                      "gameEndEvent": "@config.gameEndEvent",
                      "playAgainEvent": "@config.playAgainEvent",
                      "scale": "@config.scale",
                      "shadows": "@config.shadows",
                      "showCoordinates": "@config.showCoordinates",
                      "showGrid": "@config.showGrid",
                      "showTileInfo": "@config.showTileInfo",
                      "tileClickEvent": "@config.tileClickEvent",
                      "tileHoverEvent": "@config.tileHoverEvent",
                      "tileLeaveEvent": "@config.tileLeaveEvent",
                      "tiles": "@config.tiles",
                      "type": "game-canvas-3d-world-map-template",
                      "unitClickEvent": "@config.unitClickEvent",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "GameCanvas3dWorldMapTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}