          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "GameCanvas3dWorldMapTemplate rows finished loading; payload.data holds the collection.",
                "key": "GameCanvas3dWorldMapTemplateLoaded",
                "name": "Game canvas3d world map template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GameCanvas3dWorldMapTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GameCanvas3dWorldMapTemplateItem",
                    {
                      "emit": {
                        "success": "GameCanvas3dWorldMapTemplateLoaded"
                      }
                    }
                  ],
                  [
