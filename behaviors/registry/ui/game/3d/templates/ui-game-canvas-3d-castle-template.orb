{
  "description": "GameCanvas3dCastleTemplate — UI factory (1:1 with the @almadar/ui game-canvas-3d-castle-template pattern).",
  "name": "ui-game-canvas-3d-castle-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameCanvas3dCastleTemplateItem",
        "persistence": "runtime"
      },
      "name": "GameCanvas3dCastleTemplateOrbital",
      "pages": [
        {
          "name": "GameCanvas3dCastleTemplatePage",
          "path": "/game-canvas-3d-castle-template",
          "traits": [
            {
              "ref": "GameCanvas3dCastleTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetManifest": {
              "default": {},
              "description": "GLB model URLs keyed by terrain — owns all asset choice (no hardcoded URLs in this template).",
              "label": "Asset Manifest",
              "tier": "presentation",
              "type": "json"
            },
            "attackEvent": {
              "default": "Attack Event",
              "description": "Event name for attack emission",
              "label": "Attack Event",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundColor": {
              "default": "#1e1e2e",
              "description": "Background color",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "buildEvent": {
              "default": "Build Event",
              "description": "Event name for build action",
              "label": "Build Event",
              "tier": "presentation",
              "type": "string"
            },
            "buildingClickEvent": {
              "default": "Building Click Event",
              "description": "Event name for building (feature) clicks",
              "label": "Building Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "cameraMode": {
              "default": "isometric",
              "description": "3D camera mode",
              "label": "Camera Mode",
              "tier": "presentation",
              "type": "string",
              "values": [
                "isometric",
                "perspective",
                "top-down"
              ]
            },
            "cancelEvent": {
              "default": "Cancel Event",
              "description": "Event name for cancel/deselect",
              "label": "Cancel Event",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "endTurnEvent": {
              "default": "End Turn Event",
              "description": "Event name for ending turn",
              "label": "End Turn Event",
              "tier": "presentation",
              "type": "string"
            },
            "exitEvent": {
              "default": "Exit Event",
              "description": "Event name for exit",
              "label": "Exit Event",
              "tier": "presentation",
              "type": "string"
            },
            "features": {
              "default": [],
              "description": "Fallback feature data when no entity is present",
              "items": {
                "type": "string"
              },
              "label": "Features",
              "tier": "presentation",
              "type": "[json]"
            },
            "gameEndEvent": {
              "default": "Game End Event",
              "description": "Event name for game end detection",
              "label": "Game End Event",
              "tier": "presentation",
              "type": "string"
            },
            "playAgainEvent": {
              "default": "Play Again Event",
              "description": "Event name for play again / reset",
              "label": "Play Again Event",
              "tier": "presentation",
              "type": "string"
            },
            "recruitEvent": {
              "default": "Recruit Event",
              "description": "Event name for recruit action",
              "label": "Recruit Event",
              "tier": "presentation",
              "type": "string"
            },
            "scale": {
              "default": 0.0,
              "description": "Board zoom/group scale forwarded to GameBoard3D. Default 0.45.",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "shadows": {
              "default": false,
              "description": "Enable shadows",
              "label": "Shadows",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": false,
              "description": "Show grid helper",
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "showHeader": {
              "default": true,
              "description": "Show castle name header",
              "label": "Show Header",
              "tier": "presentation",
              "type": "boolean"
            },
            "tiles": {
              "default": [],
              "description": "Fallback tile data when no entity is present (layout only — model URLs resolve from assetManifest)",
              "items": {
                "type": "string"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[json]"
            },
            "unitClickEvent": {
              "default": "Unit Click Event",
              "description": "Event name for unit clicks",
              "label": "Unit Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "unitScale": {
              "default": 0.0,
              "description": "Unit draw-size multiplier forwarded to GameBoard3D. Default 1.",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "GameCanvas3dCastleTemplate rows finished loading; payload.data holds the collection.",
              "event": "GameCanvas3dCastleTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GameCanvas3dCastleTemplateItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameCanvas3dCastleTemplateItem",
          "name": "GameCanvas3dCastleTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "GameCanvas3dCastleTemplate rows finished loading; payload.data holds the collection.",
                "key": "GameCanvas3dCastleTemplateLoaded",
                "name": "Game canvas3d castle template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GameCanvas3dCastleTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GameCanvas3dCastleTemplateItem",
                    {
                      "emit": {
                        "success": "GameCanvas3dCastleTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "cameraMode": "@config.cameraMode",
                      "children": [
                        {
                          "items": [
                            "array/map",
                            "@config.tiles",
                            [
                              "fn",
                              "t",
                              {
                                "asset": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "terrains"
                                  ],
                                  [
                                    "object/get",
                                    "@t",
                                    "terrain"
                                  ]
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@t",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@t",
                                    "y"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@t",
                                    "z"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.features",
                            [
                              "fn",
                              "f",
                              {
                                "asset": [
                                  "object/get",
                                  "@f",
                                  "assetUrl"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@f",
                                    "z"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        }
                      ],
                      "className": "@config.className",
                      "scale": "@config.scale",
                      "shadows": "@config.shadows",
                      "showGrid": "@config.showGrid",
                      "type": "game-canvas-3d",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "cameraMode": "@config.cameraMode",
                      "children": [
                        {
                          "items": [
                            "array/map",
                            "@config.tiles",
                            [
                              "fn",
                              "t",
                              {
                                "asset": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "terrains"
                                  ],
                                  [
                                    "object/get",
                                    "@t",
                                    "terrain"
                                  ]
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@t",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@t",
                                    "y"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@t",
                                    "z"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.features",
                            [
                              "fn",
                              "f",
                              {
                                "asset": [
                                  "object/get",
                                  "@f",
                                  "assetUrl"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ],
                                  "z": [
                                    "object/get",
                                    "@f",
                                    "z"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        }
                      ],
                      "className": "@config.className",
                      "scale": "@config.scale",
                      "shadows": "@config.shadows",
                      "showGrid": "@config.showGrid",
                      "type": "game-canvas-3d",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "GameCanvas3dCastleTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}