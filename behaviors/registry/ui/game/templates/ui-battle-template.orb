          "entityRebindable": true,
          "linkedEntity": "BattleTemplateItem",
          "name": "BattleTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "BattleTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "className": "@config.className",
                      "entity": "@entity",
                      "features": "@config.features",
                      "scale": "@config.scale",
                      "tiles": "@config.tiles",
                      "type": "battle-template",
                      "unitScale": "@config.unitScale",
                      "units": "@config.units"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
