              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "RoguelikeTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "enemies": "@config.enemies",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "items": "@config.items",
                      "scale": "@config.scale",
                      "stairsX": "@config.stairsX",
                      "stairsY": "@config.stairsY",
                      "tiles": "@config.tiles",
                      "type": "roguelike-template",
                      "unitScale": "@config.unitScale"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
