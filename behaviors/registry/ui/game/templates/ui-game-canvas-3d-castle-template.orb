{
  "description": "GameCanvas3dCastleTemplate — UI factory (1:1 with the @almadar/ui game-canvas-3d-castle-template pattern).",
  "name": "ui-game-canvas-3d-castle-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameCanvas3dCastleTemplateItem",
        "persistence": "runtime"
      },
      "name": "GameCanvas3dCastleTemplateOrbital",
      "pages": [
        {
          "name": "GameCanvas3dCastleTemplatePage",
          "path": "/game-canvas-3d-castle-template",
          "traits": [
            {
              "ref": "GameCanvas3dCastleTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetManifest": {
              "description": "GLB model URLs keyed by terrain — owns all asset choice (no hardcoded URLs in this template).",
