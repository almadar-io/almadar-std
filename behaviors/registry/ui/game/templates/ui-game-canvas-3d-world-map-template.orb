            },
            "featureClickEvent": {
              "default": "Feature Click Event",
              "description": "Event name for feature clicks",
              "label": "Feature Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "selectedUnitId": {
              "default": "Selected Unit Id",
              "description": "Currently selected unit ID",
              "label": "Selected Unit Id",
              "tier": "presentation",
              "type": "string"
            },
