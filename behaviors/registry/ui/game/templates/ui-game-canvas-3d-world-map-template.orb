                "isometric",
                "perspective",
                "top-down"
              ]
            },
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "exitEvent": {
              "default": "Exit Event",
              "description": "Exit/back event name",
              "label": "Exit Event",
              "tier": "presentation",
