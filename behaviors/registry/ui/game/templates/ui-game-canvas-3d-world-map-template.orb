            },
            "tileClickEvent": {
              "default": "Tile Click Event",
              "description": "Event name for tile clicks",
              "label": "Tile Click Event",
              "tier": "presentation",
              "type": "string"
            },
            "tileHoverEvent": {
              "default": "Tile Hover Event",
