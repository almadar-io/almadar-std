                  }
                },
                "type": "object"
              },
              "label": "Attack Targets",
              "tier": "presentation",
              "type": "[GameCanvas3dWorldMapTemplateAttackTargetsItem]"
            },
            "backgroundColor": {
              "default": "#1a1a2e",
              "description": "Background color",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "cameraChangeEvent": {
              "default": "Camera Change Event",
              "description": "Event name for camera changes",
              "label": "Camera Change Event",
              "tier": "presentation",
              "type": "string"
            },
            "cameraMode": {
