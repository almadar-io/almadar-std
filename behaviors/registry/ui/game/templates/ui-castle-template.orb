            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "CastleTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "className": "@config.className",
                      "entity": "@entity",
                      "features": "@config.features",
                      "scale": "@config.scale",
                      "tiles": "@config.tiles",
                      "type": "castle-template",
                      "units": "@config.units"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
