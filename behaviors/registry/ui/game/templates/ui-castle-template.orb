{
  "name": "ui-castle-template",
  "version": "1.0.0",
  "description": "CastleTemplate — UI factory (1:1 with the @almadar/ui castle-template pattern).",
  "orbitals": [
    {
      "name": "CastleTemplateOrbital",
      "entity": {
        "name": "CastleTemplateItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CastleTemplateRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CastleTemplateItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CastleTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "scale": "@config.scale",
                      "features": "@config.features",
                      "assetManifest": "@config.assetManifest",
                      "tiles": "@config.tiles",
                      "type": "castle-template",
                      "className": "@config.className",
                      "entity": "@entity",
                      "units": "@config.units"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "scale": {
              "type": "number",
              "default": 0.45,
              "label": "Scale",
              "description": "Canvas render scale",
              "tier": "presentation"
            },
            "units": {
              "type": "[CastleTemplateUnitsItem]",
              "default": [
                {
                  "name": "Worker",
                  "unitType": "worker",
                  "maxHealth": 10.0,
                  "position": {
                    "x": 1.0,
                    "y": 1.0
                  },
                  "id": "u1",
                  "team": "player",
                  "health": 10.0
                },
                {
                  "id": "u2",
                  "position": {
                    "x": 3.0,
                    "y": 3.0
                  },
                  "name": "Guardian",
                  "team": "enemy",
                  "health": 8.0,
                  "maxHealth": 10.0,
                  "unitType": "guardian"
                }
              ],
              "label": "Units",
              "description": "Direct unit data — forwarded to CastleBoard; takes priority over entity.",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "elevation": {
                    "name": "elevation",
                    "type": "number",
                    "required": false
                  },
                  "health": {
                    "name": "health",
                    "type": "number",
                    "required": false
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": false
                  },
                  "position": {
                    "name": "position",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      },
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "previousPosition": {
                    "name": "previousPosition",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "y": {
                        "name": "y",
                        "type": "number",
                        "required": true
                      },
                      "x": {
                        "name": "x",
                        "type": "number",
                        "required": true
                      }
                    }
                  },
                  "traits": {
                    "name": "traits",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "currentState": {
                          "name": "currentState",
                          "type": "string",
                          "required": true
                        },
                        "name": {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        "states": {
                          "name": "states",
                          "type": "array",
                          "required": true,
                          "items": {
                            "type": "string"
                          }
                        },
                        "cooldown": {
                          "name": "cooldown",
                          "type": "number",
                          "required": true
                        }
                      }
                    }
                  },
                  "heroId": {
                    "name": "heroId",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "maxHealth": {
                    "name": "maxHealth",
                    "type": "number",
                    "required": false
                  },
                  "unitType": {
                    "name": "unitType",
                    "type": "string",
                    "required": false
                  },
                  "team": {
                    "name": "team",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  },
                  "sprite": {
                    "name": "sprite",
                    "type": "string",
                    "required": false
                  },
                  "faction": {
                    "name": "faction",
                    "type": "string",
                    "required": false,
                    "values": [
                      "player",
                      "enemy",
                      "neutral"
                    ]
                  },
                  "z": {
                    "name": "z",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
