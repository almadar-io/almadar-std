            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "CardBattlerTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "assetManifest": "@config.assetManifest",
                      "className": "@config.className",
                      "deck": "@config.deck",
                      "endTurnEvent": "END_TURN",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "hand": "@config.hand",
                      "maxMana": "@config.maxMana",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playCardEvent": "PLAY_CARD",
                      "title": "@config.title",
                      "type": "card-battler-template"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
