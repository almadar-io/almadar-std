{
  "description": "GameShell — UI factory (1:1 with the @almadar/ui game-shell pattern).",
  "name": "ui-game-shell",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameShellItem",
        "persistence": "runtime"
      },
      "name": "GameShellOrbital",
      "pages": [
        {
          "name": "GameShellPage",
          "path": "/game-shell",
          "traits": [
            {
              "ref": "GameShellRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "appName": {
              "default": "Game",
              "description": "Application / game title shown as a floating chip",
              "label": "App Name",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundAsset": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "backgroundAsset",
                "dimension": "2d",
                "name": "backgroundAsset",
                "role": "decoration",
                "style": "pixel",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
              },
              "description": "Pattern slice tiled at low opacity across the surface (never cover-stretched).",
              "label": "Background Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GameShellBackgroundAsset"
            },
            "children": {
              "default": [
                {
                  "type": "canvas-2d"
                }
              ],
              "description": "Game content — fills the whole surface underneath the overlays",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Extra class name on the root container",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "fontFamily": {
              "default": "future",
              "description": "Game font key (future | future-narrow | pixel | blocks | mini) or a CSS font-family.",
              "label": "Font Family",
              "tier": "presentation",
              "type": "string"
            },
            "hudBackgroundAsset": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "hudBackgroundAsset",
                "dimension": "2d",
                "name": "hudBackgroundAsset",
                "role": "decoration",
                "style": "pixel",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
              },
              "description": "9-sliced panel skin for the HUD chips row + title chip.",
              "label": "Hud Background Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GameShellHudBackgroundAsset"
            },
            "showTopBar": {
              "default": true,
              "description": "Whether to show the title chip (default: true)",
              "label": "Show Top Bar",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameShellItem",
          "name": "GameShellRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": [
                        {
                          "content": "Addons",
                          "type": "typography"
                        }
                      ],
                      "appName": "@config.appName",
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": "@config.children",
                      "className": "@config.className",
                      "controls": [
                        {
                          "content": "Controls",
                          "type": "typography"
                        }
                      ],
                      "fontFamily": "@config.fontFamily",
                      "hud": [
                        {
                          "content": "Hud",
                          "type": "typography"
                        }
                      ],
                      "hudBackgroundAsset": "@config.hudBackgroundAsset",
                      "overlay": [
                        {
                          "content": "Overlay",
                          "type": "typography"
                        }
                      ],
                      "showTopBar": "@config.showTopBar",
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}