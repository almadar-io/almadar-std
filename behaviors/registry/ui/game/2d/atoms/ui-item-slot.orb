{
  "description": "ItemSlot — UI factory (1:1 with the @almadar/ui item-slot pattern).",
  "name": "ui-item-slot",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ItemSlotItem",
        "persistence": "runtime"
      },
      "name": "ItemSlotOrbital",
      "pages": [
        {
          "name": "ItemSlotPage",
          "path": "/item-slot",
          "traits": [
            {
              "ref": "ItemSlotRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "asset",
                "dimension": "2d",
                "name": "asset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
              },
              "description": "Sprite asset — takes precedence over icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ItemSlotAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "empty": {
              "default": false,
              "description": "Whether the slot is empty",
              "label": "Empty",
              "tier": "presentation",
              "type": "boolean"
            },
            "icon": {
              "default": "circle",
              "description": "Icon component or emoji — shown only when assetUrl is absent",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Iron Sword",
              "description": "Item label",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "quantity": {
              "default": 0.0,
              "description": "Stack quantity",
              "label": "Quantity",
              "tier": "presentation",
              "type": "number"
            },
            "rarity": {
              "default": "uncommon",
              "description": "Rarity tier affecting border color",
              "label": "Rarity",
              "tier": "presentation",
              "type": "string",
              "values": [
                "common",
                "uncommon",
                "rare",
                "epic",
                "legendary"
              ]
            },
            "selected": {
              "default": false,
              "description": "Whether the slot is selected",
              "label": "Selected",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Click handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ItemSlotItem",
          "name": "ItemSlotRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "empty": "@config.empty",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "onClick": "CLICK",
                      "quantity": "@config.quantity",
                      "rarity": "@config.rarity",
                      "selected": "@config.selected",
                      "size": "@config.size",
                      "type": "item-slot"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}