{
  "description": "Headless reach-the-objective mechanic: owns features + score + objectivesLeft. Listens HERO_STEPPED and, when the hero lands on a target-type feature, scores it (optionally removing the model), emits a BURST pickup particle, and emits PROGRESS so round-flow can decide win/lose. Never writes units.",
  "name": "std-objective-reach",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "assetUrl": {
                  "name": "assetUrl",
                  "properties": {
                    "animations": {
                      "items": {
                        "type": "string"
                      },
                      "name": "animations",
                      "required": false,
                      "type": "array"
                    },
                    "aspect": {
                      "name": "aspect",
                      "required": false,
                      "type": "string"
                    },
                    "category": {
                      "name": "category",
                      "required": false,
                      "type": "string"
                    },
                    "dimension": {
                      "name": "dimension",
                      "required": false,
                      "type": "string"
                    },
                    "name": {
                      "name": "name",
                      "required": false,
                      "type": "string"
                    },
                    "role": {
                      "name": "role",
                      "required": false,
                      "type": "string"
                    },
                    "style": {
                      "name": "style",
                      "required": false,
                      "type": "string"
                    },
                    "thumbnailUrl": {
                      "name": "thumbnailUrl",
                      "required": false,
                      "type": "string"
                    },
                    "url": {
                      "name": "url",
                      "required": false,
                      "type": "string"
                    },
                    "variant": {
                      "name": "variant",
                      "required": false,
                      "type": "string"
                    }
                  },
                  "required": false,
                  "type": "object"
                },
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "elevation": {
                  "name": "elevation",
                  "required": false,
                  "type": "number"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "type": {
                  "name": "type",
                  "required": true,
                  "type": "string"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                },
                "z": {
                  "name": "z",
                  "required": false,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "features",
            "type": "array"
          },
          {
            "default": 0.0,
            "name": "score",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "objectivesLeft",
            "type": "number"
          }
        ],
        "name": "ObjectiveState",
        "persistence": "runtime",
        "shared": true
      },
      "name": "ObjectiveReachOrbital",
      "pages": [
        {
          "name": "ObjectiveReachPage",
          "path": "/objective-reach",
          "traits": [
            {
              "ref": "ObjectiveReach"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "config": {
            "features": {
              "default": [],
              "description": "Board features — collectible targets (matched by targetType) plus decorations",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": false,
                        "type": "string"
                      },
                      "variant": {
                        "name": "variant",
                        "required": false,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "elevation": {
                    "name": "elevation",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  },
                  "z": {
                    "name": "z",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Features",
              "tier": "domain",
              "type": "[Feature]"
            },
            "pointsPerTarget": {
              "default": 1.0,
              "description": "Score awarded per objective reached",
              "label": "Points Per Target",
              "tier": "domain",
              "type": "number"
            },
            "removeOnReach": {
              "default": true,
              "description": "When true the target model is removed once reached (collect); when false it stays (visit/deliver)",
              "label": "Remove On Reach",
              "tier": "domain",
              "type": "boolean"
            },
            "running": {
              "default": true,
              "description": "When true, hero steps onto targets are scored; toggle to freeze",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startScore": {
              "default": 0.0,
              "description": "Score set on INIT",
              "label": "Start Score",
              "tier": "domain",
              "type": "number"
            },
            "targetType": {
              "default": "gift",
              "description": "Feature type counted as a collectible objective",
              "label": "Target Type",
              "tier": "domain",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Pickup particle produced when a target is reached; a fx-particles listener spawns it",
              "event": "BURST",
              "payloadSchema": [
                {
                  "name": "particles",
                  "type": "[Fx]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Objectives remaining + moves remaining after this step; a round-flow listener decides win/lose",
              "event": "PROGRESS",
              "payloadSchema": [
                {
                  "name": "objectivesLeft",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "movesLeft",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "features",
              "objectivesLeft",
              "score"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ObjectiveState",
          "name": "ObjectiveReach",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HERO_STEPPED",
                "name": "Hero Stepped",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "z",
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "Pickup particle produced when a target is reached; a fx-particles listener spawns it",
                "key": "BURST",
                "name": "Burst",
                "payloadSchema": [
                  {
                    "name": "particles",
                    "type": "[Fx]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Objectives remaining + moves remaining after this step; a round-flow listener decides win/lose",
                "key": "PROGRESS",
                "name": "Progress",
                "payloadSchema": [
                  {
                    "name": "objectivesLeft",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "movesLeft",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@config.startScore"
                  ],
                  [
                    "set",
                    "@entity.objectivesLeft",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@config.features",
                        [
                          "fn",
                          "f",
                          [
                            "==",
                            [
                              "object/get",
                              "@f",
                              "type"
                            ],
                            "@config.targetType"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "if",
                      [
                        ">",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.features",
                            [
                              "fn",
                              "f",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "type"
                                  ],
                                  "@config.targetType"
                                ],
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ],
                      [
                        "+",
                        "@entity.score",
                        "@config.pointsPerTarget"
                      ],
                      "@entity.score"
                    ]
                  ],
                  [
                    "set",
                    "@entity.objectivesLeft",
                    [
                      "if",
                      [
                        ">",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.features",
                            [
                              "fn",
                              "f",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "type"
                                  ],
                                  "@config.targetType"
                                ],
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "x"
                                    ],
                                    "@payload.x"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "y"
                                    ],
                                    "@payload.z"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ],
                      [
                        "-",
                        "@entity.objectivesLeft",
                        1.0
                      ],
                      "@entity.objectivesLeft"
                    ]
                  ],
                  [
                    "emit",
                    "BURST",
                    {
                      "particles": [
                        "array/map",
                        [
                          "array/filter",
                          "@entity.features",
                          [
                            "fn",
                            "f",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@f",
                                  "type"
                                ],
                                "@config.targetType"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ],
                                  "@payload.z"
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "fn",
                          "f",
                          {
                            "id": [
                              "str/concat",
                              "fx-obj-",
                              [
                                "object/get",
                                "@f",
                                "id"
                              ]
                            ],
                            "message": "+1",
                            "ttl": 3.0,
                            "type": "pickup",
                            "x": "@payload.x",
                            "z": "@payload.z"
                          }
                        ]
                      ]
                    }
                  ],
                  [
                    "set",
                    "@entity.features",
                    [
                      "if",
                      [
                        "and",
                        "@config.removeOnReach",
                        [
                          ">",
                          [
                            "array/len",
                            [
                              "array/filter",
                              "@entity.features",
                              [
                                "fn",
                                "f",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@f",
                                      "type"
                                    ],
                                    "@config.targetType"
                                  ],
                                  [
                                    "and",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "@payload.x"
                                    ],
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ],
                                      "@payload.z"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          0.0
                        ]
                      ],
                      [
                        "array/filter",
                        "@entity.features",
                        [
                          "fn",
                          "f",
                          [
                            "not",
                            [
                              "and",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@f",
                                  "type"
                                ],
                                "@config.targetType"
                              ],
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ],
                                  "@payload.z"
                                ]
                              ]
                            ]
                          ]
                        ]
                      ],
                      "@entity.features"
                    ]
                  ],
                  [
                    "emit",
                    "PROGRESS",
                    {
                      "movesLeft": "@payload.movesLeft",
                      "objectivesLeft": "@entity.objectivesLeft"
                    }
                  ]
                ],
                "event": "HERO_STEPPED",
                "from": "active",
                "guard": "@config.running",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    "@config.features"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@config.startScore"
                  ],
                  [
                    "set",
                    "@entity.objectivesLeft",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@config.features",
                        [
                          "fn",
                          "f",
                          [
                            "==",
                            [
                              "object/get",
                              "@f",
                              "type"
                            ],
                            "@config.targetType"
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                "event": "RESTART",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}