{
  "description": "MiniMap — UI factory (1:1 with the @almadar/ui mini-map pattern).",
  "name": "ui-mini-map",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MiniMapItem",
        "persistence": "runtime"
      },
      "name": "MiniMapOrbital",
      "pages": [
        {
          "name": "MiniMapPage",
          "path": "/mini-map",
          "traits": [
            {
              "ref": "MiniMapRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "height": {
              "default": 150.0,
              "description": "Canvas display height in pixels",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "mapHeight": {
              "default": 100.0,
              "description": "Logical map height (for coordinate scaling)",
              "label": "Map Height",
              "tier": "presentation",
              "type": "number"
            },
            "mapWidth": {
              "default": 100.0,
              "description": "Logical map width (for coordinate scaling)",
              "label": "Map Width",
              "tier": "presentation",
              "type": "number"
            },
            "tileAssets": {
              "default": {
                "item": {
                  "animations": [
                    "static"
                  ],
                  "aspect": "1:1",
                  "category": "item",
                  "dimension": "2d",
                  "name": "item",
                  "role": "item",
                  "style": "",
                  "thumbnailUrl": "",
                  "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png"
                }
              },
              "description": "Map of terrain key → Asset; when present, draws sprites instead of flat hex colors for tiles.",
              "items": {
                "properties": {
                  "animations": {
                    "items": {
                      "type": "string"
                    },
                    "name": "animations",
                    "required": false,
                    "type": "array"
                  },
                  "aspect": {
                    "name": "aspect",
                    "required": false,
                    "type": "string",
                    "values": [
                      "1:1",
                      "16:9",
                      "5:7",
                      "8:1"
                    ]
                  },
                  "category": {
                    "name": "category",
                    "required": false,
                    "type": "string"
                  },
                  "dimension": {
                    "name": "dimension",
                    "required": false,
                    "type": "string",
                    "values": [
                      "2d",
                      "3d"
                    ]
                  },
                  "name": {
                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "role": {
                    "name": "role",
                    "required": false,
                    "type": "string",
                    "values": [
                      "player",
                      "enemy",
                      "npc",
                      "item",
                      "tile",
                      "projectile",
                      "effect",
                      "ui",
                      "decoration",
                      "vehicle"
                    ]
                  },
                  "style": {
                    "name": "style",
                    "required": false,
                    "type": "string",
                    "values": [
                      "pixel",
                      "vector",
                      "hd",
                      "1-bit",
                      "isometric"
                    ]
                  },
                  "thumbnailUrl": {
                    "name": "thumbnailUrl",
                    "required": false,
                    "type": "string"
                  },
                  "url": {
                    "name": "url",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Tile Assets",
              "tier": "presentation",
              "type": "Map<string,MiniMapTileAssetsValue>"
            },
            "tiles": {
              "default": [
                {
                  "color": "Color",
                  "x": 1.0,
                  "y": 1.0
                },
                {
                  "color": "Color 2",
                  "x": 2.0,
                  "y": 2.0
                }
              ],
              "description": "Tile data: each tile renders as a 1px dot at (x,y) with the given color",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": true,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[MiniMapTilesItem]"
            },
            "unitAssets": {
              "default": {
                "item": {
                  "animations": [
                    "static"
                  ],
                  "aspect": "1:1",
                  "category": "item",
                  "dimension": "2d",
                  "name": "item",
                  "role": "item",
                  "style": "",
                  "thumbnailUrl": "",
                  "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png"
                }
              },
              "description": "Map of unit id or unit type → Asset; when present, draws sprites instead of flat dots for units.",
              "items": {
                "properties": {
                  "animations": {
                    "items": {
                      "type": "string"
                    },
                    "name": "animations",
                    "required": false,
                    "type": "array"
                  },
                  "aspect": {
                    "name": "aspect",
                    "required": false,
                    "type": "string",
                    "values": [
                      "1:1",
                      "16:9",
                      "5:7",
                      "8:1"
                    ]
                  },
                  "category": {
                    "name": "category",
                    "required": false,
                    "type": "string"
                  },
                  "dimension": {
                    "name": "dimension",
                    "required": false,
                    "type": "string",
                    "values": [
                      "2d",
                      "3d"
                    ]
                  },
                  "name": {
                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "role": {
                    "name": "role",
                    "required": false,
                    "type": "string",
                    "values": [
                      "player",
                      "enemy",
                      "npc",
                      "item",
                      "tile",
                      "projectile",
                      "effect",
                      "ui",
                      "decoration",
                      "vehicle"
                    ]
                  },
                  "style": {
                    "name": "style",
                    "required": false,
                    "type": "string",
                    "values": [
                      "pixel",
                      "vector",
                      "hd",
                      "1-bit",
                      "isometric"
                    ]
                  },
                  "thumbnailUrl": {
                    "name": "thumbnailUrl",
                    "required": false,
                    "type": "string"
                  },
                  "url": {
                    "name": "url",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Unit Assets",
              "tier": "presentation",
              "type": "Map<string,MiniMapUnitAssetsValue>"
            },
            "units": {
              "default": [
                {
                  "color": "Color",
                  "isPlayer": false,
                  "x": 1.0,
                  "y": 1.0
                },
                {
                  "color": "Color 2",
                  "isPlayer": true,
                  "x": 2.0,
                  "y": 2.0
                }
              ],
              "description": "Unit positions: each unit renders as a 2px dot",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": true,
                    "type": "string"
                  },
                  "isPlayer": {
                    "name": "isPlayer",
                    "required": false,
                    "type": "boolean"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Units",
              "tier": "presentation",
              "type": "[MiniMapUnitsItem]"
            },
            "viewportRect": {
              "default": {
                "h": 1.0,
                "w": 1.0,
                "x": 1.0,
                "y": 1.0
              },
              "description": "Viewport rectangle outline",
              "label": "Viewport Rect",
              "properties": {
                "h": {
                  "name": "h",
                  "required": true,
                  "type": "number"
                },
                "w": {
                  "name": "w",
                  "required": true,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "tier": "presentation",
              "type": "MiniMapViewportRect"
            },
            "width": {
              "default": 150.0,
              "description": "Canvas display width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MiniMapItem",
          "name": "MiniMapRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "height": "@config.height",
                      "mapHeight": "@config.mapHeight",
                      "mapWidth": "@config.mapWidth",
                      "tileAssets": "@config.tileAssets",
                      "tiles": "@config.tiles",
                      "type": "mini-map",
                      "unitAssets": "@config.unitAssets",
                      "units": "@config.units",
                      "viewportRect": "@config.viewportRect",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}