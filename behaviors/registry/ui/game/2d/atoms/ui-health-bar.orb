{
  "description": "HealthBar — UI factory (1:1 with the @almadar/ui health-bar pattern).",
  "name": "ui-health-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "HealthBarItem",
        "persistence": "runtime"
      },
      "name": "HealthBarOrbital",
      "pages": [
        {
          "name": "HealthBarPage",
          "path": "/health-bar",
          "traits": [
            {
              "ref": "HealthBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": true,
              "description": "Animation on change",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "current": {
              "default": 3.0,
              "description": "Current value",
              "label": "Current",
              "tier": "presentation",
              "type": "number"
            },
            "fillAsset": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "fillAsset",
                "dimension": "2d",
                "name": "fillAsset",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite image tiled across the filled portion of bar/progress formats. Falls back to CSS color gradient.",
              "label": "Fill Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "HealthBarFillAsset"
            },
            "format": {
              "default": "hearts",
              "description": "Display format. - `hearts` / `bar` / `numeric` — health display - `progress` — XP / generic progress bar with optional level badge and value label",
              "label": "Format",
              "tier": "presentation",
              "type": "string",
              "values": [
                "hearts",
                "bar",
                "numeric",
                "progress"
              ]
            },
            "frameAsset": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "frameAsset",
                "dimension": "2d",
                "name": "frameAsset",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite image used as the bar track/frame border for bar/progress formats. Falls back to CSS rounded bg-muted.",
              "label": "Frame Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "HealthBarFrameAsset"
            },
            "labelSuffix": {
              "default": "Label Suffix",
              "description": "Label suffix shown next to the value (e.g. 'XP') when showLabel=true",
              "label": "Label Suffix",
              "tier": "presentation",
              "type": "string"
            },
            "level": {
              "default": 0.0,
              "description": "Current level — shown as 'Lv.N' badge when format='progress'",
              "label": "Level",
              "tier": "presentation",
              "type": "number"
            },
            "max": {
              "default": 5.0,
              "description": "Maximum value",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "showLabel": {
              "default": true,
              "description": "Show value label below bar when format='progress'",
              "label": "Show Label",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HealthBarItem",
          "name": "HealthBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "className": "@config.className",
                      "current": "@config.current",
                      "fillAsset": "@config.fillAsset",
                      "format": "@config.format",
                      "frameAsset": "@config.frameAsset",
                      "labelSuffix": "@config.labelSuffix",
                      "level": "@config.level",
                      "max": "@config.max",
                      "showLabel": "@config.showLabel",
                      "size": "@config.size",
                      "type": "health-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}