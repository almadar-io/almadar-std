{
  "description": "ChoiceButton — UI factory (1:1 with the @almadar/ui choice-button pattern).",
  "name": "ui-choice-button",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ChoiceButtonItem",
        "persistence": "runtime"
      },
      "name": "ChoiceButtonOrbital",
      "pages": [
        {
          "name": "ChoiceButtonPage",
          "path": "/choice-button",
          "traits": [
            {
              "ref": "ChoiceButtonRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "asset",
                "dimension": "2d",
                "name": "asset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
              },
              "description": "Sprite asset — takes precedence over icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ChoiceButtonAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Whether the choice is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "icon": {
              "default": "circle",
              "description": "Icon displayed before the text",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "index": {
              "default": 0.0,
              "description": "Choice index number (displayed as prefix)",
              "label": "Index",
              "tier": "presentation",
              "type": "number"
            },
            "selected": {
              "default": false,
              "description": "Whether the choice is currently selected",
              "label": "Selected",
              "tier": "presentation",
              "type": "boolean"
            },
            "text": {
              "default": "Charge forward into the fray",
              "description": "Choice text content",
              "label": "Text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Click handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ChoiceButtonItem",
          "name": "ChoiceButtonRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "icon": "@config.icon",
                      "index": "@config.index",
                      "onClick": "CLICK",
                      "selected": "@config.selected",
                      "text": "@config.text",
                      "type": "choice-button"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}