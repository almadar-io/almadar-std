{
  "description": "StateIndicator — UI factory (1:1 with the @almadar/ui state-indicator pattern).",
  "name": "ui-state-indicator",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StateIndicatorItem",
        "persistence": "runtime"
      },
      "name": "StateIndicatorOrbital",
      "pages": [
        {
          "name": "StateIndicatorPage",
          "path": "/state-indicator",
          "traits": [
            {
              "ref": "StateIndicatorRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animated": {
              "default": true,
              "description": "Whether to show pulse animation on non-idle states",
              "label": "Animated",
              "tier": "presentation",
              "type": "boolean"
            },
            "assetUrl": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "assetUrl",
                "dimension": "2d",
                "name": "assetUrl",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite image URL — takes precedence over the state icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "StateIndicatorAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Optional label override",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "stateProp": {
              "default": "idle",
              "description": "The current state — known values get a styled indicator, unknown values fall back to default",
              "label": "State",
              "synonyms": "state",
              "tier": "presentation",
              "type": "string",
              "values": [
                "idle",
                "active",
                "sleeping",
                "moving",
                "eating",
                "waiting",
                "happy",
                "scared",
                "done",
                "error",
                "ready",
                "cooldown"
              ]
            },
            "stateStyles": {
              "default": {},
              "description": "Custom state styles to extend/override defaults",
              "items": {
                "properties": {
                  "bgClass": {
                    "name": "bgClass",
                    "required": true,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "State Styles",
              "tier": "presentation",
              "type": "Map<string,StateIndicatorStateStylesValue>"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StateIndicatorItem",
          "name": "StateIndicatorRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animated": "@config.animated",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "label": "@config.label",
                      "size": "@config.size",
                      "state": "@config.stateProp",
                      "stateStyles": "@config.stateStyles",
                      "type": "state-indicator"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}