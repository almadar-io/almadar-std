{
  "description": "XpBar — XP progress display via resource-bar.",
  "name": "ui-xp-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "XpBarItem",
        "persistence": "runtime"
      },
      "name": "XpBarOrbital",
      "pages": [
        {
          "name": "XpBarPage",
          "path": "/xp-bar",
          "traits": [
            {
              "ref": "XpBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "current": {
              "default": 350.0,
              "description": "Current XP value",
              "label": "Current",
              "tier": "presentation",
              "type": "number"
            },
            "level": {
              "default": 5.0,
              "description": "Current level (informational)",
              "label": "Level",
              "tier": "presentation",
              "type": "number"
            },
            "max": {
              "default": 1000.0,
              "description": "XP needed for next level",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "XpBarItem",
          "name": "XpBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "resources": [
                        {
                          "icon": "star",
                          "label": "XP",
                          "max": "@config.max",
                          "value": "@config.current"
                        }
                      ],
                      "size": "@config.size",
                      "type": "resource-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}