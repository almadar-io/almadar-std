{
  "description": "ComboCounter — UI factory (1:1 with the @almadar/ui combo-counter pattern).",
  "name": "ui-combo-counter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ComboCounterItem",
        "persistence": "runtime"
      },
      "name": "ComboCounterOrbital",
      "pages": [
        {
          "name": "ComboCounterPage",
          "path": "/combo-counter",
          "traits": [
            {
              "ref": "ComboCounterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "assetUrl",
                "dimension": "2d",
                "name": "assetUrl",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite asset displayed alongside the combo number",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ComboCounterAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "combo": {
              "default": 5.0,
              "description": "Current combo count",
              "label": "Combo",
              "tier": "presentation",
              "type": "number"
            },
            "multiplier": {
              "default": 0.0,
              "description": "Score multiplier",
              "label": "Multiplier",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "streak": {
              "default": 0.0,
              "description": "Current streak",
              "label": "Streak",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ComboCounterItem",
          "name": "ComboCounterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "combo": "@config.combo",
                      "multiplier": "@config.multiplier",
                      "size": "@config.size",
                      "streak": "@config.streak",
                      "type": "combo-counter"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}