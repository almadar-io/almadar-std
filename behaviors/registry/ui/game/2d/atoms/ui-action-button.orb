{
  "description": "ActionButton — UI factory (1:1 with the @almadar/ui action-button pattern).",
  "name": "ui-action-button",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ActionButtonItem",
        "persistence": "runtime"
      },
      "name": "ActionButtonOrbital",
      "pages": [
        {
          "name": "ActionButtonPage",
          "path": "/action-button",
          "traits": [
            {
              "ref": "ActionButtonRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "assetUrl",
                "dimension": "2d",
                "name": "assetUrl",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite asset — takes precedence over icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ActionButtonAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "cooldown": {
              "default": 0.0,
              "description": "Cooldown progress from 0 (ready) to 1 (full cooldown)",
              "label": "Cooldown",
              "tier": "presentation",
              "type": "number"
            },
            "disabled": {
              "default": false,
              "description": "Whether the button is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "hotkey": {
              "default": "Hotkey",
              "description": "Keyboard hotkey to display as a badge",
              "label": "Hotkey",
              "tier": "presentation",
              "type": "string"
            },
            "icon": {
              "default": "circle",
              "description": "Icon displayed before the label",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Attack",
              "description": "Button label text",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "variant": {
              "default": "primary",
              "description": "Visual variant",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "primary",
                "secondary",
                "danger"
              ]
            }
          },
          "emits": [
            {
              "description": "Click handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Declarative event name — emits UI:{action} via eventBus on click",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ActionButtonItem",
          "name": "ActionButtonRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Click handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "cooldown": "@config.cooldown",
                      "disabled": "@config.disabled",
                      "hotkey": "@config.hotkey",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "onClick": "CLICK",
                      "size": "@config.size",
                      "type": "action-button",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}