{
  "description": "Sprite — UI factory (1:1 with the @almadar/ui sprite pattern).",
  "name": "ui-sprite",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SpriteItem",
        "persistence": "runtime"
      },
      "name": "SpriteOrbital",
      "pages": [
        {
          "name": "SpritePage",
          "path": "/sprite",
          "traits": [
            {
              "ref": "SpriteRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animState": {
              "default": {},
              "description": "Animation state name — drives lolo-ui config knob for animation selection",
              "label": "Anim State",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Optional className",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "columns": {
              "default": 16.0,
              "description": "Number of columns in spritesheet (for frame calculation)",
              "label": "Columns",
              "tier": "presentation",
              "type": "number"
            },
            "flipX": {
              "default": false,
              "description": "Flip horizontally",
              "label": "Flip X",
              "tier": "presentation",
              "type": "boolean"
            },
            "flipY": {
              "default": false,
              "description": "Flip vertically",
              "label": "Flip Y",
              "tier": "presentation",
              "type": "boolean"
            },
            "frame": {
              "default": 0.0,
              "description": "Frame index to display (0-based, left-to-right, top-to-bottom)",
              "label": "Frame",
              "tier": "presentation",
              "type": "number"
            },
            "frameHeight": {
              "default": 64.0,
              "description": "Height of each frame in pixels",
              "label": "Frame Height",
              "tier": "presentation",
              "type": "number"
            },
            "frameRate": {
              "default": 0.0,
              "description": "Frames per second — drives lolo-ui config knob for animation speed",
              "label": "Frame Rate",
              "tier": "presentation",
              "type": "number"
            },
            "frameWidth": {
              "default": 64.0,
              "description": "Width of each frame in pixels",
              "label": "Frame Width",
              "tier": "presentation",
              "type": "number"
            },
            "opacity": {
              "default": 1.0,
              "description": "Opacity (0-1)",
              "label": "Opacity",
              "tier": "presentation",
              "type": "number"
            },
            "rotation": {
              "default": 0.0,
              "description": "Rotation in degrees",
              "label": "Rotation",
              "tier": "presentation",
              "type": "number"
            },
            "scale": {
              "default": 1.0,
              "description": "Scale factor (default: 1)",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "spritesheet": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "asset",
                "dimension": "2d",
                "name": "asset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
              },
              "description": "Spritesheet asset",
              "label": "Spritesheet",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SpriteSpritesheet"
            },
            "x": {
              "default": 0.0,
              "description": "X position in pixels",
              "label": "X",
              "tier": "presentation",
              "type": "number"
            },
            "y": {
              "default": 0.0,
              "description": "Y position in pixels",
              "label": "Y",
              "tier": "presentation",
              "type": "number"
            },
            "zIndex": {
              "default": 0.0,
              "description": "Z-index for layering",
              "label": "Z Index",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Optional onClick handler",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Declarative event name emitted on click via useEventBus",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpriteItem",
          "name": "SpriteRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Optional onClick handler",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Declarative event name emitted on click via useEventBus",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "ACTION",
                      "animState": "@config.animState",
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "flipX": "@config.flipX",
                      "flipY": "@config.flipY",
                      "frame": "@config.frame",
                      "frameHeight": "@config.frameHeight",
                      "frameRate": "@config.frameRate",
                      "frameWidth": "@config.frameWidth",
                      "onClick": "CLICK",
                      "opacity": "@config.opacity",
                      "rotation": "@config.rotation",
                      "scale": "@config.scale",
                      "spritesheet": "@config.spritesheet",
                      "type": "sprite",
                      "x": "@config.x",
                      "y": "@config.y",
                      "zIndex": "@config.zIndex"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}