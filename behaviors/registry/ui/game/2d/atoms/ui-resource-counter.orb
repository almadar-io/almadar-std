{
  "description": "ResourceCounter — UI factory (1:1 with the @almadar/ui resource-counter pattern).",
  "name": "ui-resource-counter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ResourceCounterItem",
        "persistence": "runtime"
      },
      "name": "ResourceCounterOrbital",
      "pages": [
        {
          "name": "ResourceCounterPage",
          "path": "/resource-counter",
          "traits": [
            {
              "ref": "ResourceCounterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "idle",
                  "walk",
                  "attack",
                  "hit",
                  "death"
                ],
                "aspect": "1:1",
                "category": "assetUrl",
                "dimension": "2d",
                "name": "assetUrl",
                "role": "npc",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "Sprite asset — takes precedence over icon when provided",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string",
                  "values": [
                    "1:1",
                    "16:9",
                    "5:7",
                    "8:1"
                  ]
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ResourceCounterAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "color": {
              "default": "primary",
              "description": "Semantic palette token or an arbitrary Tailwind color class.",
              "label": "Color",
              "tier": "presentation",
              "type": "string",
              "values": [
                "primary",
                "secondary",
                "success",
                "warning",
                "error",
                "muted"
              ]
            },
            "icon": {
              "default": "circle",
              "description": "Icon component or emoji",
              "label": "Icon",
              "tier": "presentation",
              "type": "icon"
            },
            "label": {
              "default": "Gold",
              "description": "Resource label",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "max": {
              "default": 0.0,
              "description": "Maximum value",
              "label": "Max",
              "tier": "presentation",
              "type": "number"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "value": {
              "default": 250.0,
              "description": "Current value",
              "label": "Value",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ResourceCounterItem",
          "name": "ResourceCounterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "color": "@config.color",
                      "icon": "@config.icon",
                      "label": "@config.label",
                      "max": "@config.max",
                      "size": "@config.size",
                      "type": "resource-counter",
                      "value": "@config.value"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}