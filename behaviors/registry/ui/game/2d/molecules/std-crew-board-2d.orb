                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "sprite": {
                  "name": "sprite",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "Asset"
            },
            "movementRange": {
              "default": 2.0,
              "description": "Max manhattan distance a selected crew unit may move.",
              "label": "Movement Range",
              "tier": "domain",
              "type": "number"
            },
            "oxygen": {
              "default": 100.0,
              "description": "Initial HUD oxygen display value. Cosmetic only: the source board never depletes it, so no atom writes it after INIT.",
              "label": "Oxygen",
              "tier": "domain",
              "type": "number"
            },
            "oxygenIcon": {
              "default": {},
              "description": "Icon asset for the Oxygen HUD stat.",
              "label": "Oxygen Icon",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "atlas": {
                  "name": "atlas",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "sprite": {
                  "name": "sprite",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "Asset"
            },
            "projection": {
              "default": "flat",
              "description": "canvas-2d projection: flat or isometric.",
              "label": "Projection",
              "tier": "presentation",
              "type": "string"
            },
            "scale": {
              "default": 1.0,
              "description": "Canvas render scale.",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "showMinimap": {
              "default": false,
              "description": "Whether the canvas draws a minimap.",
              "label": "Show Minimap",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Crew move intent applied by the hero-nav authority",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GameState",
          "name": "CrewIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Crew move intent applied by the hero-nav authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.oxygen",
                    "@config.oxygen"
                  ],
                  [
                    "set",
                    "@entity.crewCount",
                    "@config.crewCount"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.fx",
                          "features": "@config.features",
                          "projection": "@config.projection",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "showMinimap": "@config.showMinimap",
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "canvas-2d",
                          "unitClickEvent": "UNIT_CLICK",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "iconUrl": "@config.crewIcon",
                                "label": "Crew",
                                "value": "@entity.crewCount"
                              },
                              {
                                "iconUrl": "@config.oxygenIcon",
                                "label": "Oxygen",
                                "value": "@entity.oxygen"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "label": "Status",
                            "type": "state-indicator",
                            "value": "@entity.phase"
                          },
                          {
                            "label": "O2",
                            "type": "timer-display",
                            "value": "@entity.oxygen"
                          },
                          {
                            "action": "CANCEL",
                            "iconAsset": "@config.cancelIcon",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "hudBackgroundAsset": "@config.hudBackgroundAsset",
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "==",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.units",
                        [
                          "fn",
                          "u",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ]
                        ]
                      ],
                      "team"
                    ],
                    "player"
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "grid/in-bounds",
                              {
                                "x": [
                                  "object/get",
                                  "@t",
                                  "x"
                                ],
                                "y": [
                                  "object/get",
                                  "@t",
                                  "y"
                                ]
                              },
                              "@config.gridWidth",
                              "@config.gridHeight"
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@config.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "movement"
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "object/get",
                    [
                      "array/find",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "==",
                          "@u.id",
                          "@payload.unitId"
                        ]
                      ]
                    ],
                    "team"
                  ],
                  "player"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "MOVE",
                    {
                      "unitId": "@entity.selectedUnitId",
                      "x": "@payload.x",
                      "y": "@payload.y"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "!=",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      "@config.gridWidth",
                      "@config.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@entity.selectedUnitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.x",
                            "y": "@payload.y"
                          }
                        ],
                        "@config.movementRange"
                      ],
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "y"
                                  ],
                                  "@payload.y"
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundAsset": "@config.backgroundAsset",
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.fx",
                        "features": "@config.features",
                        "projection": "@config.projection",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": "@config.showMinimap",
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "UNIT_CLICK",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            {
                              "iconUrl": "@config.crewIcon",
                              "label": "Crew",
                              "value": "@entity.crewCount"
                            },
                            {
                              "iconUrl": "@config.oxygenIcon",
                              "label": "Oxygen",
                              "value": "@entity.oxygen"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "label": "Status",
                          "type": "state-indicator",
                          "value": "@entity.phase"
                        },
                        {
                          "label": "O2",
                          "type": "timer-display",
                          "value": "@entity.oxygen"
                        },
                        {
                          "action": "CANCEL",
                          "iconAsset": "@config.cancelIcon",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": "@config.hudBackgroundAsset",
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Nav",
          "from": "std/behaviors/std-hero-nav"
        },
        {
          "as": "Particles",
          "from": "std/behaviors/std-fx-particles"
        }
      ]
    }
  ],
  "version": "1.0.0"
}