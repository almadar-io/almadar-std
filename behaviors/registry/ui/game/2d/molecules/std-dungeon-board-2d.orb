          "emits": [
            {
              "description": "Hero move intent applied by the hero-nav authority",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Bump-attack intent applied by the dungeon-combat authority",
              "event": "ATTACK",
              "payloadSchema": [
                {
                  "name": "targetId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Advances enemy chase AI and applies hero contact damage via the dungeon-combat authority",
              "event": "MONSTER_TICK",
              "payloadSchema": [
                {
                  "name": "heroX",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "heroY",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Step north (keyMap or d-pad directionEvents)",
              "event": "MOVE_UP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Step south (keyMap or d-pad directionEvents)",
              "event": "MOVE_DOWN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Step west (keyMap or d-pad directionEvents)",
              "event": "MOVE_LEFT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Step east (keyMap or d-pad directionEvents)",
              "event": "MOVE_RIGHT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resets every mechanic (units/enemies/HP, objectives, result) for a new run",
