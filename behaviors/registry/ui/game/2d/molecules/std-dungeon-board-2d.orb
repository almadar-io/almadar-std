                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GameState",
          "name": "DungeonIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Step north (keyMap or d-pad directionEvents)",
                "key": "MOVE_UP",
                "name": "Move Up",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Step south (keyMap or d-pad directionEvents)",
                "key": "MOVE_DOWN",
                "name": "Move Down",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Step west (keyMap or d-pad directionEvents)",
                "key": "MOVE_LEFT",
                "name": "Move Left",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Step east (keyMap or d-pad directionEvents)",
                "key": "MOVE_RIGHT",
                "name": "Move Right",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets every mechanic (units/enemies/HP, objectives, result) for a new run",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Hero move intent applied by the hero-nav authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Bump-attack intent applied by the dungeon-combat authority",
                "key": "ATTACK",
                "name": "Attack",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Advances enemy chase AI and applies hero contact damage via the dungeon-combat authority",
                "key": "MONSTER_TICK",
                "name": "Monster Tick",
                "payloadSchema": [
                  {
                    "name": "heroX",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "heroY",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Broadcast reset consumed by hero-nav/dungeon-combat/objective-reach/objective-flow",
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": [
                        {
                          "camera": {
                            "zoom": "@config.scale"
                          },
                          "children": [
                            {
                              "items": [
                                "array/map",
                                "@entity.tiles",
                                [
                                  "fn",
                                  "t",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@t",
                                      "terrainSprite"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@t",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@t",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.features",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@f",
                                      "sprite"
                                    ],
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "y"
                                      ]
                                    },
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/concat",
                                  "@entity.units",
                                  "@entity.enemies"
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "asset": [
                                      "object/get",
                                      "@u",
                                      "sprite"
                                    ],
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "type": "draw-sprite"
                                  }
                                ]
                              ],
                              "type": "draw-sprite-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/concat",
                                  "@entity.units",
                                  "@entity.enemies"
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "rgba(0,0,0,0.6)",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": 0.8
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/concat",
                                  "@entity.units",
                                  "@entity.enemies"
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "fill": "#22c55e",
                                    "height": 0.12,
                                    "offsetY": -0.6,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "shape": "rect",
                                    "type": "draw-shape",
                                    "width": [
                                      "*",
                                      0.8,
                                      [
                                        "/",
                                        [
                                          "object/get",
                                          "@u",
                                          "health"
                                        ],
                                        [
                                          "object/get",
                                          "@u",
                                          "maxHealth"
                                        ]
                                      ]
                                    ]
                                  }
                                ]
                              ],
                              "type": "draw-shape-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                [
                                  "array/concat",
                                  "@entity.units",
                                  "@entity.enemies"
                                ],
                                [
                                  "fn",
                                  "u",
                                  {
                                    "color": "#ffffff",
                                    "offsetY": -0.85,
                                    "position": [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "text": [
                                      "object/get",
                                      "@u",
                                      "name"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            },
                            {
                              "items": [
                                "array/map",
                                "@entity.fx",
                                [
                                  "fn",
                                  "f",
                                  {
                                    "color": "#ffe066",
                                    "position": {
                                      "x": [
                                        "object/get",
                                        "@f",
                                        "x"
                                      ],
                                      "y": [
                                        "object/get",
                                        "@f",
                                        "z"
                                      ]
                                    },
                                    "text": [
                                      "object/get",
                                      "@f",
                                      "message"
                                    ],
                                    "type": "draw-text"
                                  }
                                ]
                              ],
                              "type": "draw-text-layer"
                            }
                          ],
                          "keyMap": {
                            "ArrowDown": "MOVE_DOWN",
                            "ArrowLeft": "MOVE_LEFT",
                            "ArrowRight": "MOVE_RIGHT",
                            "ArrowUp": "MOVE_UP",
                            "KeyA": "MOVE_LEFT",
                            "KeyD": "MOVE_RIGHT",
                            "KeyS": "MOVE_DOWN",
                            "KeyW": "MOVE_UP"
                          },
                          "projection": "flat",
                          "showMinimap": false,
                          "type": "canvas"
                        }
                      ],
                      "controls": {
                        "directionAssets": "@config.directionAssets",
                        "directionEvents": {
                          "down": "MOVE_DOWN",
                          "left": "MOVE_LEFT",
                          "right": "MOVE_RIGHT",
                          "up": "MOVE_UP"
                        },
                        "kind": "dpad",
                        "type": "control-grid"
                      },
                      "fontFamily": "@config.fontFamily",
                      "hud": {
                        "stats": [
                          {
                            "format": "hearts",
                            "label": "HP",
                            "max": "@entity.maxHp",
                            "value": "@entity.hp"
                          },
                          {
                            "label": "Score",
                            "value": [
                              "+",
                              "@entity.score",
                              "@entity.combatScore"
                            ]
                          }
                        ],
                        "type": "game-hud"
                      },
                      "hudBackgroundAsset": "@config.hudBackgroundAsset",
                      "overlay": [
                        "if",
                        [
                          "!=",
                          "@entity.result",
                          "none"
                        ],
                        {
                          "options": [
                            {
                              "event": "PLAY_AGAIN",
                              "id": "again",
                              "label": "Play Again",
                              "variant": "primary"
                            }
                          ],
                          "subtitle": "You found the chest!",
                          "title": "VICTORY",
                          "type": "game-menu"
                        },
                        [
                          "if",
                          [
