{
  "description": "InventoryGrid — UI factory (1:1 with the @almadar/ui inventory-grid pattern).",
  "name": "ui-inventory-grid",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "InventoryGridItem",
        "persistence": "runtime"
      },
      "name": "InventoryGridOrbital",
      "pages": [
        {
          "name": "InventoryGridPage",
          "path": "/inventory-grid",
          "traits": [
            {
              "ref": "InventoryGridRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "columns": {
              "default": 4.0,
              "description": "Number of columns in the grid",
              "label": "Columns",
              "tier": "presentation",
              "type": "number"
            },
            "items": {
              "default": [
                {
                  "assetUrl": {
                    "animations": [
                      "idle",
                      "walk",
                      "attack",
                      "hit",
                      "death"
                    ],
                    "aspect": "1:1",
                    "category": "assetUrl",
                    "dimension": "2d",
                    "name": "assetUrl",
                    "role": "npc",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "quantity": 1.0,
                  "rarity": "common"
                },
                {
                  "assetUrl": {
                    "animations": [
                      "idle",
                      "walk",
                      "attack",
                      "hit",
                      "death"
                    ],
                    "aspect": "1:1",
                    "category": "assetUrl",
                    "dimension": "2d",
                    "name": "assetUrl",
                    "role": "npc",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "quantity": 2.0,
                  "rarity": "uncommon"
                }
              ],
              "description": "Array of items to display in the grid",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "quantity": {
                    "name": "quantity",
                    "required": false,
                    "type": "number"
                  },
                  "rarity": {
                    "name": "rarity",
                    "required": false,
                    "type": "string",
                    "values": [
                      "common",
                      "uncommon",
                      "rare",
                      "epic",
                      "legendary"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[InventoryGridItemsItem]"
            },
            "selectedId": {
              "default": "Selected Id",
              "description": "Currently selected item ID",
              "label": "Selected Id",
              "tier": "presentation",
              "type": "string"
            },
            "size": {
              "default": "md",
              "description": "Size variant for all item slots",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "totalSlots": {
              "default": 12.0,
              "description": "Total number of slots (empty slots fill remaining space)",
              "label": "Total Slots",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Callback when an item is selected",
              "event": "SELECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "InventoryGridItem",
          "name": "InventoryGridRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Callback when an item is selected",
                "key": "SELECT",
                "name": "Select",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "items": "@config.items",
                      "onSelect": "SELECT",
                      "selectEvent": "SELECT",
                      "selectedId": "@config.selectedId",
                      "size": "@config.size",
                      "totalSlots": "@config.totalSlots",
                      "type": "inventory-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}