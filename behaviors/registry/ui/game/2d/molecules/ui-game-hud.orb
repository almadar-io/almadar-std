      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameHudItem",
        "persistence": "runtime"
      },
      "name": "GameHudOrbital",
      "pages": [
        {
          "name": "GameHudPage",
          "path": "/game-hud",
          "traits": [
            {
              "ref": "GameHudRender"
            }
          ]
