                    "name": "position",
                    "required": false,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Elements",
              "tier": "presentation",
              "type": "[GameHudElementsItem]"
            },
            "items": {
              "default": [
                {
                  "field": "Field",
                  "source": "Source"
                },
                {
                  "field": "Field 2",
                  "source": "Source 2"
                }
              ],
              "description": "Alias for stats (schema compatibility)",
              "items": {
                "properties": {
                  "field": {
                    "name": "field",
                    "required": false,
                    "type": "string"
                  },
                  "source": {
                    "name": "source",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Items",
              "tier": "presentation",
              "type": "[GameHudItemsItem]"
            },
            "position": {
              "default": "top",
              "description": "Position of the HUD",
              "label": "Position",
              "tier": "presentation",
              "type": "string",
              "values": [
                "top",
                "bottom",
                "corners"
              ]
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "stats": {
              "default": [
                {
                  "field": "Field",
                  "source": "Source"
                },
                {
                  "field": "Field 2",
                  "source": "Source 2"
                }
              ],
              "description": "Stats to display - accepts readonly for compatibility with generated const arrays",
              "items": {
                "properties": {
                  "field": {
                    "name": "field",
                    "required": false,
                    "type": "string"
                  },
                  "source": {
                    "name": "source",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Stats",
              "tier": "presentation",
              "type": "[GameHudStatsItem]"
            },
            "transparent": {
              "default": true,
              "description": "Whether to use a semi-transparent background",
              "label": "Transparent",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameHudItem",
          "name": "GameHudRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "elements": "@config.elements",
                      "items": "@config.items",
                      "position": "@config.position",
                      "size": "@config.size",
                      "stats": "@config.stats",
                      "transparent": "@config.transparent",
                      "type": "game-hud"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}