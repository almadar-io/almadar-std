{
  "description": "ResourceBar — UI factory (1:1 with the @almadar/ui resource-bar pattern).",
  "name": "ui-resource-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ResourceBarItem",
        "persistence": "runtime"
      },
      "name": "ResourceBarOrbital",
      "pages": [
        {
          "name": "ResourceBarPage",
          "path": "/resource-bar",
          "traits": [
            {
              "ref": "ResourceBarRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "resources": {
              "default": [
                {
                  "assetUrl": {
                    "animations": [
                      "idle",
                      "walk",
                      "attack",
                      "hit",
                      "death"
                    ],
                    "aspect": "1:1",
                    "category": "assetUrl",
                    "dimension": "2d",
                    "name": "assetUrl",
                    "role": "npc",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  "icon": "circle",
                  "label": "Label",
                  "max": 1.0,
                  "value": 1.0
                },
                {
                  "assetUrl": {
                    "animations": [
                      "idle",
                      "walk",
                      "attack",
                      "hit",
                      "death"
                    ],
                    "aspect": "1:1",
                    "category": "assetUrl",
                    "dimension": "2d",
                    "name": "assetUrl",
                    "role": "npc",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  "icon": "circle",
                  "label": "Label 2",
                  "max": 2.0,
                  "value": 2.0
                }
              ],
              "description": "Resources to display",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string",
                        "values": [
                          "1:1",
                          "16:9",
                          "5:7",
                          "8:1"
                        ]
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string",
                        "values": [
                          "2d",
                          "3d"
                        ]
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string",
                        "values": [
                          "player",
                          "enemy",
                          "npc",
                          "item",
                          "tile",
                          "projectile",
                          "effect",
                          "ui",
                          "decoration",
                          "vehicle"
                        ]
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string",
                        "values": [
                          "pixel",
                          "vector",
                          "hd",
                          "1-bit",
                          "isometric"
                        ]
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "max": {
                    "name": "max",
                    "required": false,
                    "type": "number"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Resources",
              "tier": "presentation",
              "type": "[ResourceBarResourcesItem]"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ResourceBarItem",
          "name": "ResourceBarRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "resources": "@config.resources",
                      "size": "@config.size",
                      "type": "resource-bar"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}