{
  "description": "EnemyPlate — UI factory (1:1 with the @almadar/ui enemy-plate pattern).",
  "name": "ui-enemy-plate",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "EnemyPlateItem",
        "persistence": "runtime"
      },
      "name": "EnemyPlateOrbital",
      "pages": [
        {
          "name": "EnemyPlatePage",
          "path": "/enemy-plate",
          "traits": [
            {
              "ref": "EnemyPlateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetUrl": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "asset",
                "dimension": "2d",
                "name": "asset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
              },
              "description": "Portrait sprite asset — takes precedence over the default avatar slot",
              "label": "Asset Url",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "EnemyPlateAssetUrl"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "effects": {
              "default": [
                {
                  "icon": "circle",
                  "label": "Label",
                  "variant": "buff"
                },
                {
                  "icon": "circle",
                  "label": "Label 2",
                  "variant": "debuff"
                }
              ],
              "description": "Active status effects",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "buff",
                      "debuff",
                      "neutral"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Effects",
              "tier": "presentation",
              "type": "[EnemyPlateEffectsItem]"
            },
            "health": {
              "default": 80.0,
              "description": "Current health",
              "label": "Health",
              "tier": "presentation",
              "type": "number"
            },
            "level": {
              "default": 5.0,
              "description": "Enemy level",
              "label": "Level",
              "tier": "presentation",
              "type": "number"
            },
            "maxHealth": {
              "default": 100.0,
              "description": "Maximum health",
              "label": "Max Health",
              "tier": "presentation",
              "type": "number"
            },
            "name": {
              "default": "Shadow Guard",
              "description": "Enemy name",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "EnemyPlateItem",
          "name": "EnemyPlateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "assetUrl": "@config.assetUrl",
                      "className": "@config.className",
                      "effects": "@config.effects",
                      "health": "@config.health",
                      "level": "@config.level",
                      "maxHealth": "@config.maxHealth",
                      "name": "@config.name",
                      "type": "enemy-plate"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}