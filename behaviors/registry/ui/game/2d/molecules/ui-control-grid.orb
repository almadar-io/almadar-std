{
  "description": "ControlGrid — UI factory (1:1 with the @almadar/ui control-grid pattern).",
  "name": "ui-control-grid",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ControlGridItem",
        "persistence": "runtime"
      },
      "name": "ControlGridOrbital",
      "pages": [
        {
          "name": "ControlGridPage",
          "path": "/control-grid",
          "traits": [
            {
              "ref": "ControlGridRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "buttons": {
              "default": [
                {
                  "assetUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "assetUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "action buttons (kind='actions')",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Buttons",
              "tier": "presentation",
              "type": "[ControlGridButtonsItem]"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "disabled prop",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "includeDiagonals": {
              "default": false,
              "description": "Whether to include diagonal buttons (kind='dpad')",
              "label": "Include Diagonals",
              "tier": "presentation",
              "type": "boolean"
            },
            "kind": {
              "default": "dpad",
              "description": "kind prop",
              "label": "Kind",
              "tier": "presentation",
              "type": "string",
              "values": [
                "dpad",
                "actions"
              ]
            },
            "layout": {
              "default": "horizontal",
              "description": "Layout for kind='actions'",
              "label": "Layout",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical",
                "diamond"
              ]
            },
            "size": {
              "default": "md",
              "description": "size prop",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when a button/direction is pressed or released",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when a direction is pressed or released (kind='dpad' convenience overload)",
              "event": "DIRECTION",
              "payloadSchema": [
                {
                  "name": "direction",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ControlGridItem",
          "name": "ControlGridRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when a button/direction is pressed or released",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when a direction is pressed or released (kind='dpad' convenience overload)",
                "key": "DIRECTION",
                "name": "Direction",
                "payloadSchema": [
                  {
                    "name": "direction",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actionEvent": "ACTION",
                      "buttons": "@config.buttons",
                      "className": "@config.className",
                      "directionEvent": "DIRECTION",
                      "disabled": "@config.disabled",
                      "includeDiagonals": "@config.includeDiagonals",
                      "kind": "@config.kind",
                      "layout": "@config.layout",
                      "onAction": "ACTION",
                      "onDirection": "DIRECTION",
                      "size": "@config.size",
                      "type": "control-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}