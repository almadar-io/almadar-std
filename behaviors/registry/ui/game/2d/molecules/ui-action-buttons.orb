{
  "description": "ActionButtons — configurable button set via control-grid (kind=actions).",
  "name": "ui-action-buttons",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ActionButtonsItem",
        "persistence": "runtime"
      },
      "name": "ActionButtonsOrbital",
      "pages": [
        {
          "name": "ActionButtonsPage",
          "path": "/action-buttons",
          "traits": [
            {
              "ref": "ActionButtonsRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "buttons": {
              "default": [
                {
                  "icon": "circle",
                  "id": "Id",
                  "label": "Label",
                  "variant": "primary"
                },
                {
                  "icon": "circle",
                  "id": "Id 2",
                  "label": "Label 2",
                  "variant": "secondary"
                }
              ],
              "description": "Button configurations",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string",
                    "values": [
                      "primary",
                      "secondary",
                      "ghost"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Buttons",
              "tier": "presentation",
              "type": "[ActionButtonsButtonsItem]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Disabled state",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            },
            "layout": {
              "default": "horizontal",
              "description": "Layout variant",
              "label": "Layout",
              "tier": "presentation",
              "type": "string",
              "values": [
                "horizontal",
                "vertical",
                "diamond"
              ]
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "emits": [
            {
              "description": "Called when a button is pressed/released",
              "event": "ACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "pressed",
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ActionButtonsItem",
          "name": "ActionButtonsRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Called when a button is pressed/released",
                "key": "ACTION",
                "name": "Action",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "pressed",
                    "type": "boolean"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actionEvent": "ACTION",
                      "buttons": "@config.buttons",
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "kind": "actions",
                      "layout": "@config.layout",
                      "onAction": "ACTION",
                      "size": "@config.size",
                      "type": "control-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}