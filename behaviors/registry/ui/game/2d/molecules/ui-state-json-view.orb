{
  "description": "StateJsonView — UI factory (1:1 with the @almadar/ui state-json-view pattern).",
  "name": "ui-state-json-view",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StateJsonViewItem",
        "persistence": "runtime"
      },
      "name": "StateJsonViewOrbital",
      "pages": [
        {
          "name": "StateJsonViewPage",
          "path": "/state-json-view",
          "traits": [
            {
              "ref": "StateJsonViewRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "defaultExpanded": {
              "default": false,
              "description": "Whether the code block is expanded by default",
              "label": "Default Expanded",
              "tier": "presentation",
              "type": "boolean"
            },
            "initialState": {
              "default": "Initial State",
              "description": "Initial state",
              "label": "Initial State",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Header label",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            },
            "name": {
              "default": "Name",
              "description": "Machine name",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            },
            "states": {
              "default": [
                "Item",
                "Item 2"
              ],
              "description": "All state names",
              "items": {
                "type": "string"
              },
              "label": "States",
              "tier": "presentation",
              "type": "[string]"
            },
            "transitions": {
              "default": [
                {
                  "event": "Event",
                  "from": "From",
                  "to": "To"
                },
                {
                  "event": "Event 2",
                  "from": "From 2",
                  "to": "To 2"
                }
              ],
              "description": "The player's wired transitions",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Transitions",
              "tier": "presentation",
              "type": "[StateJsonViewTransitionsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StateJsonViewItem",
          "name": "StateJsonViewRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "defaultExpanded": "@config.defaultExpanded",
                      "initialState": "@config.initialState",
                      "label": "@config.label",
                      "name": "@config.name",
                      "states": "@config.states",
                      "transitions": "@config.transitions",
                      "type": "state-json-view"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}