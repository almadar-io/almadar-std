{
  "description": "TurnPanel — UI factory (1:1 with the @almadar/ui turn-panel pattern).",
  "name": "ui-turn-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TurnPanelItem",
        "persistence": "runtime"
      },
      "name": "TurnPanelOrbital",
      "pages": [
        {
          "name": "TurnPanelPage",
          "path": "/turn-panel",
          "traits": [
            {
              "ref": "TurnPanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "actions": {
              "default": [
                {
                  "assetUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "disabled": false,
                  "icon": "circle",
                  "label": "Label"
                },
                {
                  "assetUrl": {
                    "animations": [
                      "static"
                    ],
                    "aspect": "1:1",
                    "category": "asset",
                    "dimension": "2d",
                    "name": "asset",
                    "role": "decoration",
                    "style": "",
                    "thumbnailUrl": "",
                    "url": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png"
                  },
                  "disabled": true,
                  "icon": "circle",
                  "label": "Label 2"
                }
              ],
              "description": "Action buttons to display",
              "items": {
                "properties": {
                  "assetUrl": {
                    "name": "assetUrl",
                    "properties": {
                      "animations": {
                        "items": {
                          "type": "string"
                        },
                        "name": "animations",
                        "required": false,
                        "type": "array"
                      },
                      "aspect": {
                        "name": "aspect",
                        "required": false,
                        "type": "string"
                      },
                      "category": {
                        "name": "category",
                        "required": false,
                        "type": "string"
                      },
                      "dimension": {
                        "name": "dimension",
                        "required": false,
                        "type": "string"
                      },
                      "name": {
                        "name": "name",
                        "required": false,
                        "type": "string"
                      },
                      "role": {
                        "name": "role",
                        "required": false,
                        "type": "string"
                      },
                      "style": {
                        "name": "style",
                        "required": false,
                        "type": "string"
                      },
                      "thumbnailUrl": {
                        "name": "thumbnailUrl",
                        "required": false,
                        "type": "string"
                      },
                      "url": {
                        "name": "url",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "required": false,
                    "type": "object"
                  },
                  "disabled": {
                    "name": "disabled",
                    "required": false,
                    "type": "boolean"
                  },
                  "event": {
                    "name": "event",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Actions",
              "tier": "presentation",
              "type": "[TurnPanelActionsItem]"
            },
            "activeTeam": {
              "default": "Heroes",
              "description": "Active team name",
              "label": "Active Team",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentTurn": {
              "default": 3.0,
              "description": "Current turn number",
              "label": "Current Turn",
              "tier": "presentation",
              "type": "number"
            },
            "maxTurns": {
              "default": 10.0,
              "description": "Maximum number of turns",
              "label": "Max Turns",
              "tier": "presentation",
              "type": "number"
            },
            "phase": {
              "default": "Attack",
              "description": "Current phase label",
              "label": "Phase",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TurnPanelItem",
          "name": "TurnPanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": "@config.actions",
                      "activeTeam": "@config.activeTeam",
                      "className": "@config.className",
                      "currentTurn": "@config.currentTurn",
                      "maxTurns": "@config.maxTurns",
                      "phase": "@config.phase",
                      "type": "turn-panel"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}