{
  "description": "CombatLog — UI factory (1:1 with the @almadar/ui combat-log pattern).",
  "name": "ui-combat-log",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CombatLogItem",
        "persistence": "runtime"
      },
      "name": "CombatLogOrbital",
      "pages": [
        {
          "name": "CombatLogPage",
          "path": "/combat-log",
          "traits": [
            {
              "ref": "CombatLogRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "autoScroll": {
              "default": true,
              "description": "autoScroll prop",
              "label": "Auto Scroll",
              "tier": "presentation",
              "type": "boolean"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "events": {
              "default": [
                {
                  "actorName": "Actor Name",
                  "id": "Id",
                  "message": "Message",
                  "targetName": "Target Name",
                  "timestamp": 1.0,
                  "turn": 1.0,
                  "type": "attack",
                  "value": 1.0
                },
                {
                  "actorName": "Actor Name 2",
                  "id": "Id 2",
                  "message": "Message 2",
                  "targetName": "Target Name 2",
                  "timestamp": 2.0,
                  "turn": 2.0,
                  "type": "defend",
                  "value": 2.0
                }
              ],
              "description": "events prop",
              "items": {
                "properties": {
                  "actorName": {
                    "name": "actorName",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "message": {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  "targetName": {
                    "name": "targetName",
                    "required": false,
                    "type": "string"
                  },
                  "timestamp": {
                    "name": "timestamp",
                    "required": true,
                    "type": "number"
                  },
                  "turn": {
                    "name": "turn",
                    "required": false,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string",
                    "values": [
                      "attack",
                      "defend",
                      "heal",
                      "move",
                      "special",
                      "death",
                      "spawn"
                    ]
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Events",
              "tier": "presentation",
              "type": "[CombatLogEventsItem]"
            },
            "maxVisible": {
              "default": 50.0,
              "description": "maxVisible prop",
              "label": "Max Visible",
              "tier": "presentation",
              "type": "number"
            },
            "showTimestamps": {
              "default": false,
              "description": "showTimestamps prop",
              "label": "Show Timestamps",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Combat Log",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CombatLogItem",
          "name": "CombatLogRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "autoScroll": "@config.autoScroll",
                      "className": "@config.className",
                      "events": "@config.events",
                      "maxVisible": "@config.maxVisible",
                      "showTimestamps": "@config.showTimestamps",
                      "title": "@config.title",
                      "type": "combat-log"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}