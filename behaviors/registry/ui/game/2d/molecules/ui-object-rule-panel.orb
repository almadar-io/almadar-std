{
  "description": "ObjectRulePanel — UI factory (1:1 with the @almadar/ui object-rule-panel pattern).",
  "name": "ui-object-rule-panel",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ObjectRulePanelItem",
        "persistence": "runtime"
      },
      "name": "ObjectRulePanelOrbital",
      "pages": [
        {
          "name": "ObjectRulePanelPage",
          "path": "/object-rule-panel",
          "traits": [
            {
              "ref": "ObjectRulePanelRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "disabled": {
              "default": false,
              "description": "Whether editing is disabled",
              "label": "Disabled",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "emits": [
            {
              "description": "Called when rules change (callback path)",
              "event": "RULES_CHANGE",
              "payloadSchema": [
                {
                  "name": "objectId",
                  "type": "string"
                },
                {
                  "name": "rules",
                  "type": "[object]"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "ObjectRulePanel rows finished loading; payload.data holds the collection.",
              "event": "ObjectRulePanelLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectRulePanelItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ObjectRulePanelItem",
          "name": "ObjectRulePanelRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "ObjectRulePanel rows finished loading; payload.data holds the collection.",
                "key": "ObjectRulePanelLoaded",
                "name": "Object rule panel loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectRulePanelItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "Called when rules change (callback path)",
                "key": "RULES_CHANGE",
                "name": "Rules Change",
                "payloadSchema": [
                  {
                    "name": "objectId",
                    "type": "string"
                  },
                  {
                    "name": "rules",
                    "type": "[object]"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "ObjectRulePanelItem",
                    {
                      "emit": {
                        "success": "ObjectRulePanelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "object": "@entity",
                      "onRulesChange": "RULES_CHANGE",
                      "rulesChangeEvent": "RULES_CHANGE",
                      "type": "object-rule-panel"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "disabled": "@config.disabled",
                      "object": "@payload.data",
                      "onRulesChange": "RULES_CHANGE",
                      "rulesChangeEvent": "RULES_CHANGE",
                      "type": "object-rule-panel"
                    }
                  ]
                ],
                "event": "ObjectRulePanelLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}