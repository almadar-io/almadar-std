            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "features": "@config.features",
                      "projection": "isometric",
                      "scale": "@config.cellSize",
                      "tileClickEvent": "FEATURE_CLICK",
                      "tileHoverEvent": "FEATURE_HOVER",
                      "type": "canvas-2d"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
