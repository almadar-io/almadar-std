            "interpolateUnits": {
              "default": false,
              "description": "Opt-in: smooth-interpolate unit positions between LOLO tick snapshots via a `requestAnimationFrame` loop (same fixed-timestep technique `SideCanvas2D` already uses for the player), instead of the default tick-rate-cadence redraw. DEFAULT OFF — for continuous-movement boards only; tile-snapped boards see no behavior change.",
              "label": "Interpolate Units",
              "tier": "presentation",
              "type": "boolean"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "keyMap": {
              "default": {
                "item": "Item"
              },
              "description": "Maps a keydown `e.code` → the board's SEMANTIC event, e.g. `{ ArrowLeft: 'LEFT', KeyA: 'LEFT', Space: 'JUMP' }`. The input layer emits `UI:<event>` so the FSM stays device-agnostic — keyboard and d-pad converge on the same events.",
              "items": {
                "type": "string"
              },
              "label": "Key Map",
              "tier": "presentation",
              "type": "Map<string,string>"
            },
            "keyUpMap": {
              "default": {
                "item": "Item"
              },
              "description": "Maps a keyup `e.code` → the board's SEMANTIC event, e.g. `{ ArrowLeft: 'STOP' }`. Omit a key to ignore its release (e.g. jump).",
              "items": {
                "type": "string"
              },
              "label": "Key Up Map",
              "tier": "presentation",
              "type": "Map<string,string>"
