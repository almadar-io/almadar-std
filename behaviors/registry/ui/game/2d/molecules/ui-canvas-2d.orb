                  "name": "dimension",
                  "required": false,
                  "type": "string",
                  "values": [
                    "2d",
                    "3d"
                  ]
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string",
                  "values": [
                    "player",
                    "enemy",
                    "npc",
                    "item",
                    "tile",
                    "projectile",
                    "effect",
                    "ui",
                    "decoration",
                    "vehicle"
                  ]
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string",
                  "values": [
                    "pixel",
                    "vector",
                    "hd",
                    "1-bit",
                    "isometric"
                  ]
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "Canvas2dPlayerSprite"
            },
            "projection": {
              "default": "isometric",
              "description": "--- Projection ---",
              "label": "Projection",
              "tier": "presentation",
              "type": "string",
              "values": [
                "isometric",
                "hex",
                "flat",
                "free",
                "side"
              ]
            },
            "scale": {
              "default": 0.4,
              "description": "Render scale (0.4 = 40% zoom).",
              "label": "Scale",
              "tier": "presentation",
              "type": "number"
            },
            "selectedUnitId": {
              "default": "",
              "description": "--- Interaction state (LOLO-owned, passed in) ---",
              "label": "Selected Unit Id",
              "tier": "presentation",
              "type": "string"
            },
            "showMinimap": {
              "default": true,
              "description": "Toggle minimap overlay.",
              "label": "Show Minimap",
              "tier": "presentation",
              "type": "boolean"
            },
            "spriteHeightRatio": {
              "default": 1.5,
              "description": "Ratio of unit draw height to scaledFloorHeight. Default 1.5.",
              "label": "Sprite Height Ratio",
              "tier": "presentation",
              "type": "number"
            },
            "spriteMaxWidthRatio": {
              "default": 0.6,
              "description": "Max unit draw width as a ratio of scaledTileWidth. Default 0.6.",
              "label": "Sprite Max Width Ratio",
              "tier": "presentation",
              "type": "number"
            },
            "tileSprites": {
              "default": {},
              "description": "Platform-type → tile sprite URL map for `side`.",
              "items": {
                "properties": {
                  "animations": {
                    "items": {
                      "type": "string"
                    },
                    "name": "animations",
                    "required": false,
                    "type": "array"
                  },
                  "aspect": {
                    "name": "aspect",
                    "required": false,
                    "type": "string",
                    "values": [
                      "1:1",
                      "16:9",
                      "5:7",
                      "8:1"
                    ]
                  },
                  "category": {
                    "name": "category",
                    "required": false,
                    "type": "string"
                  },
                  "dimension": {
                    "name": "dimension",
                    "required": false,
                    "type": "string",
                    "values": [
                      "2d",
                      "3d"
                    ]
                  },
                  "name": {
                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "role": {
                    "name": "role",
                    "required": false,
                    "type": "string",
                    "values": [
                      "player",
                      "enemy",
                      "npc",
                      "item",
                      "tile",
                      "projectile",
                      "effect",
                      "ui",
                      "decoration",
                      "vehicle"
                    ]
                  },
                  "style": {
                    "name": "style",
                    "required": false,
                    "type": "string",
                    "values": [
                      "pixel",
                      "vector",
                      "hd",
                      "1-bit",
                      "isometric"
                    ]
                  },
                  "thumbnailUrl": {
                    "name": "thumbnailUrl",
                    "required": false,
                    "type": "string"
                  },
                  "url": {
                    "name": "url",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "Map<string,Canvas2dTileSpritesValue>"
            },
            "tiles": {
              "default": [],
              "description": "--- Layer data (each an optional render pass) ---",
              "items": {
                "type": "string"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[json]"
            },
            "unitScale": {
              "default": 1.0,
              "description": "Extra scale multiplier for unit draw size. 1 = default.",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            },
            "units": {
              "default": [],
              "description": "Units on the board",
              "items": {
                "type": "string"
              },
              "label": "Units",
              "tier": "presentation",
              "type": "[json]"
            },
            "validMoves": {
              "default": [
                {
                  "x": 1.0,
                  "y": 1.0
                },
                {
                  "x": 2.0,
                  "y": 2.0
                }
              ],
              "description": "Valid move positions (pulsing green highlights)",
              "items": {
                "properties": {
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Valid Moves",
              "tier": "presentation",
              "type": "[Canvas2dValidMovesItem]"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "worldHeight prop",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World dimensions for `side` follow-camera clamp.",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "--- Declarative events back to LOLO ---",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{tileHoverEvent} with { x, y } on tile hover",
              "event": "TILE_HOVER",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Emits UI:{tileLeaveEvent} with {} on tile leave",
              "event": "TILE_LEAVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "Canvas2dItem",
          "name": "Canvas2dRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "--- Declarative events back to LOLO ---",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{tileHoverEvent} with { x, y } on tile hover",
                "key": "TILE_HOVER",
                "name": "Tile Hover",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Emits UI:{tileLeaveEvent} with {} on tile leave",
                "key": "TILE_LEAVE",
                "name": "Tile Leave",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animate": "@config.animate",
                      "backgroundImage": "@config.backgroundImage",
                      "bgColor": "@config.bgColor",
                      "camera": "@config.camera",
                      "children": [
                        {
                          "items": [
                            "array/map",
                            "@config.tiles",
                            [
                              "fn",
                              "t",
                              {
                                "asset": [
                                  "object/get",
                                  "@t",
                                  "terrainSprite"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@t",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@t",
                                    "y"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.features",
                            [
                              "fn",
                              "f",
                              {
                                "asset": [
                                  "object/get",
                                  "@f",
                                  "assetUrl"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.validMoves",
                            [
                              "fn",
                              "m",
                              {
                                "fill": "rgba(74,222,128,0.4)",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@m",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@m",
                                    "y"
                                  ]
                                },
                                "shape": "cell",
                                "type": "draw-shape"
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.attackTargets",
                            [
                              "fn",
                              "a",
                              {
                                "fill": "rgba(239,68,68,0.4)",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@a",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@a",
                                    "y"
                                  ]
                                },
                                "shape": "cell",
                                "type": "draw-shape"
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            [
                              "array/filter",
                              "@config.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@u",
                                    "id"
                                  ],
                                  "@config.selectedUnitId"
                                ]
                              ]
                            ],
                            [
                              "fn",
                              "u",
                              {
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@u",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@u",
                                    "y"
                                  ]
                                },
                                "radiusX": 0.5,
                                "radiusY": 0.2,
                                "shape": "ellipse",
                                "stroke": "rgba(0,200,255,0.8)",
                                "strokeWidth": 3.0,
                                "type": "draw-shape"
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.units",
                            [
                              "fn",
                              "u",
                              {
                                "asset": [
                                  "object/get",
                                  "@u",
                                  "modelUrl"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@u",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@u",
                                    "y"
                                  ]
                                },
                                "type": "draw-sprite"
                              }
                            ]
                          ],
                          "type": "draw-sprite-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.units",
                            [
                              "fn",
                              "u",
                              {
                                "fill": "rgba(0,0,0,0.6)",
                                "height": 0.12,
                                "offsetY": -0.6,
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@u",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@u",
                                    "y"
                                  ]
                                },
                                "shape": "rect",
                                "type": "draw-shape",
                                "width": 0.8
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.units",
                            [
                              "fn",
                              "u",
                              {
                                "fill": "#22c55e",
                                "height": 0.12,
                                "offsetY": -0.6,
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@u",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@u",
                                    "y"
                                  ]
                                },
                                "shape": "rect",
                                "type": "draw-shape",
                                "width": [
                                  "*",
                                  0.8,
                                  [
                                    "/",
                                    [
                                      "object/get",
                                      "@u",
                                      "health"
                                    ],
                                    [
                                      "object/get",
                                      "@u",
                                      "maxHealth"
                                    ]
                                  ]
                                ]
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.units",
                            [
                              "fn",
                              "u",
                              {
                                "color": "#ffffff",
                                "offsetY": -0.85,
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@u",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@u",
                                    "y"
                                  ]
                                },
                                "text": [
                                  "object/get",
                                  "@u",
                                  "name"
                                ],
                                "type": "draw-text"
                              }
                            ]
                          ],
                          "type": "draw-text-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.effects",
                            [
                              "fn",
                              "f",
                              {
                                "color": "#ffe066",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@f",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@f",
                                    "y"
                                  ]
                                },
                                "text": [
                                  "object/get",
                                  "@f",
                                  "message"
                                ],
                                "type": "draw-text"
                              }
                            ]
                          ],
                          "type": "draw-text-layer"
                        },
                        {
                          "items": [
                            "array/map",
                            "@config.platforms",
                            [
                              "fn",
                              "p",
                              {
                                "fill": "#9ca3af",
                                "height": [
                                  "object/get",
                                  "@p",
                                  "height"
                                ],
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@p",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@p",
                                    "y"
                                  ]
                                },
                                "shape": "rect",
                                "type": "draw-shape",
                                "width": [
                                  "object/get",
                                  "@p",
                                  "width"
                                ]
                              }
                            ]
                          ],
                          "type": "draw-shape-layer"
                        },
                        {
                          "asset": "@config.playerSprite",
                          "position": {
                            "x": [
                              "object/get",
                              "@config.player",
                              "x"
                            ],
                            "y": [
                              "object/get",
                              "@config.player",
                              "y"
                            ]
                          },
                          "type": "draw-sprite"
                        }
                      ],
                      "className": "@config.className",
                      "debug": "@config.debug",
                      "diamondTopY": "@config.diamondTopY",
                      "effectSpriteUrls": "@config.effectSpriteUrls",
                      "error": "@config.error",
                      "interpolateUnits": "@config.interpolateUnits",
                      "isLoading": "@config.isLoading",
                      "keyMap": "@config.keyMap",
                      "keyUpMap": "@config.keyUpMap",
                      "playerSprite": "@config.playerSprite",
                      "projection": "@config.projection",
                      "scale": "@config.scale",
                      "showMinimap": "@config.showMinimap",
                      "spriteHeightRatio": "@config.spriteHeightRatio",
                      "spriteMaxWidthRatio": "@config.spriteMaxWidthRatio",
                      "tileClickEvent": "TILE_CLICK",
                      "tileHoverEvent": "TILE_HOVER",
                      "tileLeaveEvent": "TILE_LEAVE",
                      "type": "canvas-2d",
                      "unitClickEvent": "UNIT_CLICK",
                      "unitScale": "@config.unitScale",
                      "worldHeight": "@config.worldHeight",
                      "worldWidth": "@config.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}