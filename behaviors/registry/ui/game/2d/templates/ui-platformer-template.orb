{
  "description": "PlatformerTemplate — thin layout: PlatformerBoard + HUD (lives/score); config-driven.",
  "name": "ui-platformer-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PlatformerTemplateItem",
        "persistence": "runtime"
      },
      "name": "PlatformerTemplateOrbital",
      "pages": [
        {
          "name": "PlatformerTemplatePage",
          "path": "/platformer-template",
          "traits": [
            {
              "ref": "PlatformerTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "bgColor": {
              "default": "#5c94fc",
              "description": "Canvas background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "Canvas display height",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display width",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "goalX": {
              "default": 720.0,
              "description": "X pixel of the goal tile",
              "label": "Goal X",
              "tier": "presentation",
              "type": "number"
            },
            "platforms": {
              "default": [
                {
                  "height": 32.0,
                  "type": "ground",
                  "width": 800.0,
                  "x": 0.0,
                  "y": 368.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 150.0,
                  "y": 280.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "height": 16.0,
                  "type": "hazard",
                  "width": 80.0,
                  "x": 580.0,
                  "y": 300.0
                },
                {
                  "height": 28.0,
                  "type": "goal",
                  "width": 64.0,
                  "x": 700.0,
                  "y": 340.0
                }
              ],
              "description": "Level geometry including hazard and goal tiles",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerTemplatePlatformsItem]"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/units/player.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": "",
              "description": "Leave empty to use built-in platformer tile defaults",
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "string"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "World pixel height",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World pixel width",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerTemplateItem",
          "name": "PlatformerTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "PlatformerTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bgColor": "@config.bgColor",
                      "canvasHeight": "@config.canvasHeight",
                      "canvasWidth": "@config.canvasWidth",
                      "className": "@config.className",
                      "entity": "@entity",
                      "gameEndEvent": "GAME_END",
                      "goalX": "@config.goalX",
                      "platforms": "@config.platforms",
                      "playerSprite": "@config.playerSprite",
                      "tileSprites": "@config.tileSprites",
                      "type": "platformer-template",
                      "worldHeight": "@config.worldHeight",
                      "worldWidth": "@config.worldWidth"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}