{
  "description": "PlatformerTemplate — thin playable shell; renders game-shell + side-scrolling canvas-2d matching ui-platformer-board.",
  "name": "ui-platformer-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": {
              "animation": "idle",
              "facingRight": true,
              "frame": 0.0,
              "grounded": false,
              "height": 48.0,
              "vx": 0.0,
              "vy": 0.0,
              "width": 32.0,
              "x": 80.0,
              "y": 320.0
            },
            "name": "player",
            "properties": {
              "animation": {
                "name": "animation",
                "required": false,
                "type": "string"
              },
              "facingRight": {
                "name": "facingRight",
                "required": false,
                "type": "boolean"
              },
              "frame": {
                "name": "frame",
                "required": false,
                "type": "number"
              },
              "grounded": {
                "name": "grounded",
                "required": false,
                "type": "boolean"
              },
              "height": {
                "name": "height",
                "required": false,
                "type": "number"
              },
              "vx": {
                "name": "vx",
                "required": false,
                "type": "number"
              },
              "vy": {
                "name": "vy",
                "required": false,
                "type": "number"
              },
              "width": {
                "name": "width",
                "required": false,
                "type": "number"
              },
              "x": {
                "name": "x",
                "required": false,
                "type": "number"
              },
              "y": {
                "name": "y",
                "required": false,
                "type": "number"
              }
            },
            "type": "object"
          },
          {
            "default": 0.0,
            "name": "score",
            "type": "number"
          },
          {
            "default": 3.0,
            "name": "lives",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "won",
              "lost"
            ]
          },
          {
            "default": 800.0,
            "name": "worldWidth",
            "type": "number"
          },
          {
            "default": 400.0,
            "name": "worldHeight",
            "type": "number"
          },
          {
            "default": "",
            "name": "selectedUnitId",
            "type": "string"
          },
          {
            "default": [],
            "items": {
              "properties": {
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "validMoves",
            "type": "array"
          }
        ],
        "name": "PlatformerTemplateItem",
        "persistence": "runtime"
      },
      "name": "PlatformerTemplateOrbital",
      "pages": [
        {
          "name": "PlatformerTemplatePage",
          "path": "/platformer-template",
          "traits": [
            {
              "ref": "PlatformerTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "assetBaseUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/",
              "description": "Base URL prefix for asset lookups",
              "label": "Asset Base URL",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundImage": {
              "default": "",
              "description": "Optional parallax background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "bgColor": {
              "default": "#5c94fc",
              "description": "Canvas background color",
              "label": "Bg Color",
              "tier": "presentation",
              "type": "string"
            },
            "canvasHeight": {
              "default": 400.0,
              "description": "Canvas display height",
              "label": "Canvas Height",
              "tier": "presentation",
              "type": "number"
            },
            "canvasWidth": {
              "default": 800.0,
              "description": "Canvas display width",
              "label": "Canvas Width",
              "tier": "presentation",
              "type": "number"
            },
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "followCamera": {
              "default": true,
              "description": "Camera follows the player horizontally",
              "label": "Follow Camera",
              "tier": "presentation",
              "type": "boolean"
            },
            "goalX": {
              "default": 720.0,
              "description": "X pixel of the goal tile",
              "label": "Goal X",
              "tier": "presentation",
              "type": "number"
            },
            "platforms": {
              "default": [
                {
                  "height": 32.0,
                  "type": "ground",
                  "width": 800.0,
                  "x": 0.0,
                  "y": 368.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 150.0,
                  "y": 280.0
                },
                {
                  "height": 16.0,
                  "type": "platform",
                  "width": 160.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "height": 16.0,
                  "type": "hazard",
                  "width": 80.0,
                  "x": 580.0,
                  "y": 300.0
                },
                {
                  "height": 28.0,
                  "type": "goal",
                  "width": 64.0,
                  "x": 700.0,
                  "y": 340.0
                }
              ],
              "description": "Level geometry including hazard and goal tiles",
              "items": {
                "properties": {
                  "height": {
                    "name": "height",
                    "required": true,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "ground",
                      "platform",
                      "hazard",
                      "goal"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Platforms",
              "tier": "presentation",
              "type": "[PlatformerTemplatePlatformsItem]"
            },
            "playerSprite": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-platformer-board/default/units/player.png",
              "description": "Player sprite image URL",
              "label": "Player Sprite",
              "tier": "presentation",
              "type": "asset"
            },
            "tileSprites": {
              "default": "",
              "description": "Leave empty to use built-in platformer tile defaults",
              "label": "Tile Sprites",
              "tier": "presentation",
              "type": "string"
            },
            "worldHeight": {
              "default": 400.0,
              "description": "World pixel height",
              "label": "World Height",
              "tier": "presentation",
              "type": "number"
            },
            "worldWidth": {
              "default": 800.0,
              "description": "World pixel width",
              "label": "World Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ],
              "scope": "external"
            },
            {
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "type": "string"
                }
              ],
              "scope": "external"
            }
          ],
          "entityContract": {
            "provides": [
              "lives",
              "player",
              "result",
              "score",
              "selectedUnitId",
              "validMoves",
              "worldHeight",
              "worldWidth"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PlatformerTemplateItem",
          "name": "PlatformerTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              },
              {
                "key": "GAME_END",
                "name": "Game End"
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "facingRight": true,
                      "frame": 0.0,
                      "grounded": false,
                      "height": 48.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "width": 32.0,
                      "x": 80.0,
                      "y": 320.0
                    }
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.worldWidth",
                    "@config.worldWidth"
                  ],
                  [
                    "set",
                    "@entity.worldHeight",
                    "@config.worldHeight"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetBaseUrl": "@config.assetBaseUrl",
                          "backgroundImage": "@config.backgroundImage",
                          "bgColor": "@config.bgColor",
                          "canvasHeight": "@config.canvasHeight",
                          "canvasWidth": "@config.canvasWidth",
                          "followCamera": "@config.followCamera",
                          "platforms": "@config.platforms",
                          "player": "@entity.player",
                          "playerSprite": "@config.playerSprite",
                          "projection": "side",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "tileClickEvent": "TILE_CLICK",
                          "tileSprites": "@config.tileSprites",
                          "type": "canvas-2d",
                          "unitClickEvent": "UNIT_CLICK",
                          "validMoves": "@entity.validMoves",
                          "worldHeight": "@entity.worldHeight",
                          "worldWidth": "@entity.worldWidth"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Score",
                                "value": "@entity.score"
                              },
                              {
                                "label": "Lives",
                                "value": "@entity.lives"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "label": "Score",
                            "type": "score-display",
                            "value": "@entity.score"
                          },
                          {
                            "directionEvent": "DPAD",
                            "kind": "dpad",
                            "type": "control-grid"
                          },
                          {
                            "action": "PLAY_AGAIN",
                            "icon": "refresh",
                            "label": "Restart",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    [
                      "object/merge",
                      "@entity.player",
                      {
                        "animation": "walk",
                        "facingRight": false
