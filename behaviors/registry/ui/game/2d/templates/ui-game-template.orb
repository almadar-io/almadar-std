{
  "description": "GameTemplate — UI factory (1:1 with the @almadar/ui game-template pattern).",
  "name": "ui-game-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameTemplateItem",
        "persistence": "runtime"
      },
      "name": "GameTemplateOrbital",
      "pages": [
        {
          "name": "GameTemplatePage",
          "path": "/game-template",
          "traits": [
            {
              "ref": "GameTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class name",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "controls": {
              "default": {
                "isPlaying": false
              },
              "description": "Game controls",
              "label": "Controls",
              "properties": {
                "isPlaying": {
                  "name": "isPlaying",
                  "required": false,
                  "type": "boolean"
                }
              },
              "tier": "presentation",
              "type": "GameTemplateControls"
            },
            "debugPanel": {
              "description": "Debug panel content",
              "label": "Debug Panel",
              "tier": "presentation",
              "type": "node"
            },
            "showDebugPanel": {
              "default": false,
              "description": "Whether the debug panel is visible",
              "label": "Show Debug Panel",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Game",
              "description": "Title of the game",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "GameTemplate rows finished loading; payload.data holds the collection.",
              "event": "GameTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GameTemplateItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameTemplateItem",
          "name": "GameTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "GameTemplate rows finished loading; payload.data holds the collection.",
                "key": "GameTemplateLoaded",
                "name": "Game template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GameTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "GameTemplateItem",
                    {
                      "emit": {
                        "success": "GameTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "canvas-2d"
                        }
                      ],
                      "className": "@config.className",
                      "controls": "@config.controls",
                      "debugPanel": "@config.debugPanel",
                      "entity": "@entity",
                      "hud": [
                        {
                          "content": "Hud",
                          "type": "typography"
                        }
                      ],
                      "showDebugPanel": "@config.showDebugPanel",
                      "title": "@config.title",
                      "type": "game-template"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "canvas-2d"
                        }
                      ],
                      "className": "@config.className",
                      "controls": "@config.controls",
                      "debugPanel": "@config.debugPanel",
                      "entity": "@payload.data",
                      "hud": [
                        {
                          "content": "Hud",
                          "type": "typography"
                        }
                      ],
                      "showDebugPanel": "@config.showDebugPanel",
                      "title": "@config.title",
                      "type": "game-template"
                    }
                  ]
                ],
                "event": "GameTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}