{
  "description": "GameShell — UI factory (1:1 with the @almadar/ui game-shell pattern).",
  "name": "ui-game-shell",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameShellItem",
        "persistence": "runtime"
      },
      "name": "GameShellOrbital",
      "pages": [
        {
          "name": "GameShellPage",
          "path": "/game-shell",
          "traits": [
            {
              "ref": "GameShellRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "appName": {
              "default": "Game",
              "description": "Application / game title shown in the HUD bar",
              "label": "App Name",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Extra class name on the root container",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "showTopBar": {
              "default": true,
              "description": "Whether to show the minimal top bar (default: true)",
              "label": "Show Top Bar",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameShellItem",
          "name": "GameShellRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "@config.appName",
                      "children": [
                        {
                          "type": "canvas-2d"
                        }
                      ],
                      "className": "@config.className",
                      "hud": [
                        {
                          "content": "Hud",
                          "type": "typography"
                        }
                      ],
                      "showTopBar": "@config.showTopBar",
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}
