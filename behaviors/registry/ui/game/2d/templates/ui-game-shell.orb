{
  "description": "GameShell — UI factory (1:1 with the @almadar/ui game-shell pattern).",
  "name": "ui-game-shell",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "GameShellItem",
        "persistence": "runtime"
      },
      "name": "GameShellOrbital",
      "pages": [
        {
          "name": "GameShellPage",
          "path": "/game-shell",
          "traits": [
            {
              "ref": "GameShellRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "appName": {
              "default": "Game",
              "description": "Application / game title shown in the HUD bar",
              "label": "App Name",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundAsset": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "backgroundAsset",
                "dimension": "2d",
                "name": "backgroundAsset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
              },
              "description": "Background image for the shell/main area (e.g. Kenny panel frame). Falls back to CSS #0a0a0f.",
              "label": "Background Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GameShellBackgroundAsset"
            },
            "className": {
              "default": "",
              "description": "Extra class name on the root container",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "hudBackgroundAsset": {
              "default": {
                "animations": [
                  "static"
                ],
                "aspect": "1:1",
                "category": "hudBackgroundAsset",
                "dimension": "2d",
                "name": "hudBackgroundAsset",
                "role": "decoration",
                "style": "",
                "thumbnailUrl": "",
                "url": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
              },
              "description": "Background image for the HUD bar. Falls back to CSS #12121f surface color.",
              "label": "Hud Background Asset",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
                  "required": false,
                  "type": "string"
                },
                "category": {
                  "name": "category",
                  "required": false,
                  "type": "string"
                },
                "dimension": {
                  "name": "dimension",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "GameShellHudBackgroundAsset"
            },
            "showTopBar": {
              "default": true,
              "description": "Whether to show the minimal top bar (default: true)",
              "label": "Show Top Bar",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "GameShellItem",
          "name": "GameShellRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "@config.appName",
                      "backgroundAsset": "@config.backgroundAsset",
                      "children": [
                        {
                          "type": "canvas-2d"
                        }
                      ],
                      "className": "@config.className",
                      "hud": [
                        {
                          "content": "Hud",
                          "type": "typography"
                        }
                      ],
                      "hudBackgroundAsset": "@config.hudBackgroundAsset",
                      "showTopBar": "@config.showTopBar",
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}