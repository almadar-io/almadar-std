              "description": "Tile grid forwarded to CityBuilderBoard.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "passable": {
                    "name": "passable",
                    "required": false,
                    "type": "boolean"
                  },
                  "terrain": {
                    "name": "terrain",
                    "required": false,
                    "type": "string"
                  },
                  "terrainSprite": {
                    "name": "terrainSprite",
                    "required": false,
                    "type": "string"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Tiles",
              "tier": "presentation",
              "type": "[CityBuilderTemplateTilesItem]"
            },
            "title": {
              "default": "City Builder",
              "description": "Display title shown in the template header",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "unitScale": {
              "default": 0.6,
              "description": "Unit draw-size multiplier",
              "label": "Unit Scale",
              "tier": "presentation",
              "type": "number"
            },
            "wood": {
              "default": 80.0,
              "description": "Wood the player starts with",
              "label": "Starting Wood",
              "tier": "presentation",
              "type": "number"
            },
            "woodPerBuilding": {
              "default": 1.0,
              "description": "Wood income per building per tick",
              "label": "Wood Per Building",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "event": "PLACE_BUILDING",
              "payloadSchema": [
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ],
              "scope": "external"
            },
            {
              "event": "SELECT_BUILD_TYPE",
              "payloadSchema": [
                {
                  "name": "type",
                  "type": "string"
                }
              ],
              "scope": "external"
            }
          ],
          "entityContract": {
            "provides": [
              "citizens",
              "effects",
              "features",
              "gold",
              "pendingBuildType",
              "population",
              "result",
              "selectedUnitId",
              "validMoves",
              "wood"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CityBuilderTemplateItem",
          "name": "CityBuilderTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_BUILD_TYPE",
                "name": "Select Build Type",
                "payloadSchema": [
                  {
                    "name": "type",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLACE_BUILDING",
