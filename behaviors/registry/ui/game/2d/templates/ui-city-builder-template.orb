                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              },
              {
                "key": "GAME_END",
                "name": "Game End"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "building"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.features",
                    [
                      "array/map",
                      "@config.buildings",
                      [
                        "fn",
                        "b",
                        {
                          "id": "@b.id",
                          "sprite": [
                            "object/get",
                            "@config.featureSprites",
                            "@b.type"
                          ],
                          "type": "@b.type",
                          "x": "@b.x",
                          "y": "@b.y"
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.gold",
                    "@config.gold"
                  ],
                  [
                    "set",
                    "@entity.wood",
                    "@config.wood"
                  ],
                  [
                    "set",
                    "@entity.pendingBuildType",
                    "@config.pendingBuildType"
                  ],
                  [
                    "set",
                    "@entity.citizens",
