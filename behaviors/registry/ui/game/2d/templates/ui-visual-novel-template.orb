          },
          {
            "default": "",
            "name": "currentSpeaker",
            "type": "string"
          },
          {
            "default": "",
            "name": "currentText",
            "type": "string"
          },
          {
            "default": [],
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "nextId": {
                  "name": "nextId",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "currentChoices",
            "type": "array"
          }
        ],
        "name": "VisualNovelTemplateItem",
        "persistence": "runtime"
      },
      "name": "VisualNovelTemplateOrbital",
      "pages": [
        {
          "name": "VisualNovelTemplatePage",
          "path": "/visual-novel-template",
          "traits": [
            {
              "ref": "VisualNovelTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "currentNodeId": {
              "default": "start",
              "description": "Id of the dialogue node shown first",
              "label": "Current Node Id",
              "tier": "presentation",
              "type": "string"
            },
            "nodes": {
              "default": [
                {
                  "backgroundKey": "corridor",
                  "choices": [
                    {
                      "label": "Approach the sentinel.",
                      "nextId": "meet"
                    },
                    {
                      "label": "Turn back.",
                      "nextId": "retreat"
                    }
                  ],
                  "id": "start",
                  "portraitKey": "guide",
                  "speaker": "Narrator",
                  "text": "The corridor stretches into shadow. A lone sentinel blocks your path."
                },
                {
                  "backgroundKey": "forge",
                  "choices": [
                    {
                      "label": "I seek the core.",
                      "nextId": "end"
                    },
                    {
                      "label": "I am only passing through.",
                      "nextId": "retreat"
                    }
                  ],
                  "id": "meet",
                  "portraitKey": "rival",
                  "speaker": "Sentinel",
                  "text": "You carry the old marks. Speak your purpose, traveler."
                },
                {
                  "backgroundKey": "corridor",
                  "choices": [
                    {
                      "label": "Begin again.",
                      "nextId": "start"
                    }
                  ],
                  "id": "retreat",
                  "portraitKey": "guide",
                  "speaker": "Narrator",
                  "text": "You withdraw into the dark. The path will wait for braver feet."
                },
                {
                  "backgroundKey": "core",
                  "choices": [
                    {
                      "label": "Begin again.",
                      "nextId": "start"
                    }
                  ],
                  "id": "end",
                  "portraitKey": "rival",
                  "speaker": "Sentinel",
                  "text": "Then the way is open. Walk it well."
                }
              ],
              "description": "Dialogue graph forwarded to VisualNovelBoard.",
              "items": {
                "properties": {
                  "backgroundKey": {
                    "name": "backgroundKey",
                    "required": false,
                    "type": "string"
                  },
                  "choices": {
                    "items": {
                      "properties": {
                        "label": {
                          "name": "label",
                          "required": true,
                          "type": "string"
                        },
                        "nextId": {
                          "name": "nextId",
                          "required": true,
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "name": "choices",
                    "required": false,
                    "type": "array"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "portraitKey": {
                    "name": "portraitKey",
                    "required": false,
                    "type": "string"
                  },
                  "speaker": {
                    "name": "speaker",
                    "required": true,
                    "type": "string"
                  },
                  "text": {
                    "name": "text",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "presentation",
              "type": "[VisualNovelTemplateNodesItem]"
            },
            "portraitScale": {
              "default": 1.0,
              "description": "Character portrait draw-size multiplier",
              "label": "Portrait Scale",
              "tier": "presentation",
              "type": "number"
            },
            "title": {
              "default": "Visual Novel",
              "description": "Display title shown in the template header",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "typewriterSpeed": {
              "default": 30.0,
              "description": "Milliseconds per character of dialogue text reveal (0 = instant)",
              "label": "Typewriter Speed",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "event": "CHOOSE",
              "payloadSchema": [
                {
                  "name": "nextId",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "ADVANCE",
              "scope": "external"
            },
            {
              "event": "RESTART",
              "scope": "external"
            }
          ],
          "entityContract": {
            "provides": [
              "currentChoices",
              "currentNodeId",
              "currentSpeaker",
              "currentText",
              "nodes"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VisualNovelTemplateItem",
          "name": "VisualNovelTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHOOSE",
                "name": "Choose",
                "payloadSchema": [
                  {
                    "name": "nextId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@config.currentNodeId"
                  ],
                  [
                    "set",
                    "@entity.currentSpeaker",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@config.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "speaker"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentText",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@config.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "text"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentChoices",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@config.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "choices"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "choiceButton": {
                        "choices": "@entity.currentChoices",
                        "chooseEvent": "CHOOSE",
                        "type": "choice-button"
                      },
                      "chooseEvent": "CHOOSE",
                      "currentNodeId": "@entity.currentNodeId",
                      "dialogueBubble": {
                        "speaker": "@entity.currentSpeaker",
                        "text": "@entity.currentText",
                        "type": "dialogue-bubble"
                      },
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@payload.nextId"
                  ],
                  [
                    "set",
                    "@entity.currentSpeaker",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@payload.nextId"
                          ]
                        ]
                      ],
                      "speaker"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentText",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@payload.nextId"
                          ]
                        ]
                      ],
                      "text"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentChoices",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@payload.nextId"
                          ]
                        ]
                      ],
                      "choices"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "choiceButton": {
                        "choices": "@entity.currentChoices",
                        "chooseEvent": "CHOOSE",
                        "type": "choice-button"
                      },
                      "chooseEvent": "CHOOSE",
                      "currentNodeId": "@entity.currentNodeId",
                      "dialogueBubble": {
                        "speaker": "@entity.currentSpeaker",
                        "text": "@entity.currentText",
                        "type": "dialogue-bubble"
                      },
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "CHOOSE",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "choiceButton": {
                        "choices": "@entity.currentChoices",
                        "chooseEvent": "CHOOSE",
                        "type": "choice-button"
                      },
                      "chooseEvent": "CHOOSE",
                      "currentNodeId": "@entity.currentNodeId",
                      "dialogueBubble": {
                        "speaker": "@entity.currentSpeaker",
                        "text": "@entity.currentText",
                        "type": "dialogue-bubble"
                      },
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "ADVANCE",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentNodeId",
                    "@config.currentNodeId"
                  ],
                  [
                    "set",
                    "@entity.currentSpeaker",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "speaker"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentText",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "text"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentChoices",
                    [
                      "object/get",
                      [
                        "array/find",
                        "@entity.nodes",
                        [
                          "fn",
                          "n",
                          [
                            "==",
                            "@n.id",
                            "@config.currentNodeId"
                          ]
                        ]
                      ],
                      "choices"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "advanceEvent": "ADVANCE",
                      "choiceButton": {
                        "choices": "@entity.currentChoices",
                        "chooseEvent": "CHOOSE",
                        "type": "choice-button"
                      },
                      "chooseEvent": "CHOOSE",
                      "currentNodeId": "@entity.currentNodeId",
                      "dialogueBubble": {
                        "speaker": "@entity.currentSpeaker",
                        "text": "@entity.currentText",
                        "type": "dialogue-bubble"
                      },
                      "nodes": "@entity.nodes",
                      "portraitScale": "@config.portraitScale",
                      "restartEvent": "RESTART",
                      "type": "visual-novel-board",
                      "typewriterSpeed": "@config.typewriterSpeed"
                    }
                  ]
                ],
                "event": "RESTART",
                "from": "playing",
                "to": "playing"
              }
            ]
          }
        }
      ]
    }
