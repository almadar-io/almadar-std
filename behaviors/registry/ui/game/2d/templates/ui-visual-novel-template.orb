{
  "description": "VisualNovelTemplate — thin playable shell; renders visual-novel-board descriptor matching ui-visual-novel-board.",
  "name": "ui-visual-novel-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "backgroundKey": {
                  "name": "backgroundKey",
                  "required": false,
                  "type": "string"
                },
                "choices": {
                  "items": {
                    "properties": {
                      "label": {
                        "name": "label",
                        "required": true,
