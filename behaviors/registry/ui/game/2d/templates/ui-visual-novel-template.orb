                      },
                      "nextId": {
                        "name": "nextId",
                        "required": true,
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "name": "choices",
                  "required": false,
                  "type": "array"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "portraitKey": {
                  "name": "portraitKey",
                  "required": false,
                  "type": "string"
                },
                "speaker": {
                  "name": "speaker",
                  "required": true,
                  "type": "string"
                },
                "text": {
