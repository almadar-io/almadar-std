                                  "@entity.player",
                                  "frame"
                                ],
                                "id": "player",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@entity.player",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@entity.player",
                                    "y"
                                  ]
