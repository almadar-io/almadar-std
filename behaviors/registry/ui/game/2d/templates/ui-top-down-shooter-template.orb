          "entityRebindable": true,
          "linkedEntity": "TopDownShooterTemplateItem",
          "name": "TopDownShooterTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "vx",
                    "type": "number"
                  },
                  {
                    "name": "vy",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "FIRE",
                "name": "Fire"
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              },
              {
                "key": "GAME_END",
                "name": "Game End"
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.player",
                    {
                      "animation": "idle",
                      "frame": 0.0,
                      "vx": 0.0,
                      "vy": 0.0,
                      "x": 320.0,
                      "y": 400.0
                    }
                  ],
                  [
                    "set",
                    "@entity.enemies",
                    []
                  ],
                  [
                    "set",
                    "@entity.projectiles",
                    []
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.wave",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.lives",
                    "@config.lives"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": [
                            "array/map",
                            "@entity.projectiles",
                            [
                              "fn",
                              "p",
                              {
                                "id": "@p.id",
                                "sprite": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "features"
                                  ],
                                  "projectile"
                                ],
                                "type": "projectile",
                                "x": [
                                  "object/get",
                                  "@p",
                                  "x"
                                ],
                                "y": [
                                  "object/get",
                                  "@p",
                                  "y"
                                ]
                              }
                            ]
                          ],
                          "projection": "flat",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "showMinimap": false,
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": [],
                          "type": "canvas-2d",
                          "unitClickEvent": "UNIT_CLICK",
                          "units": [
                            "array/concat",
                            [
                              {
                                "animation": [
                                  "object/get",
                                  "@entity.player",
                                  "animation"
                                ],
                                "frame": [
                                  "object/get",
                                  "@entity.player",
                                  "frame"
                                ],
                                "id": "player",
                                "position": {
                                  "x": [
                                    "object/get",
                                    "@entity.player",
                                    "x"
                                  ],
                                  "y": [
                                    "object/get",
                                    "@entity.player",
                                    "y"
                                  ]
                                },
                                "sprite": [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@config.assetManifest",
                                    "units"
                                  ],
                                  "player"
                                ],
                                "team": "player"
                              }
                            ],
                            [
                              "array/map",
                              "@entity.enemies",
                              [
                                "fn",
                                "e",
                                {
                                  "animation": [
                                    "object/get",
                                    "@e",
                                    "animation"
                                  ],
                                  "frame": [
                                    "object/get",
                                    "@e",
                                    "frame"
                                  ],
                                  "id": "@e.id",
                                  "position": {
                                    "x": [
                                      "object/get",
                                      "@e",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@e",
                                      "y"
                                    ]
                                  },
                                  "sprite": [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@config.assetManifest",
                                      "units"
                                    ],
                                    "enemy"
                                  ],
                                  "team": "enemy"
                                }
                              ]
                            ]
                          ],
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "label": "Score",
                                "value": "@entity.score"
                              },
                              {
                                "label": "Wave",
                                "value": "@entity.wave"
                              },
                              {
                                "label": "Lives",
                                "value": "@entity.lives"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "label": "SCORE",
                            "score": "@entity.score",
                            "type": "score-display"
                          },
                          {
                            "action": "FIRE",
                            "iconAsset": {
                              "animations": [],
                              "aspect": "1:1",
                              "category": "ui",
                              "dimension": "2d",
                              "name": "icon-fire",
                              "role": "ui",
                              "style": "sci-fi",
                              "thumbnailUrl": "",
                              "url": "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/default/ui/icon-fire.png",
                              "variant": ""
                            },
                            "label": "Fire",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
