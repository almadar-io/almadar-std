              "scope": "external"
            },
            {
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "vx",
                  "type": "number"
                },
                {
                  "name": "vy",
                  "type": "number"
                }
              ],
              "scope": "external"
            },
            {
              "event": "FIRE",
              "scope": "external"
            }
