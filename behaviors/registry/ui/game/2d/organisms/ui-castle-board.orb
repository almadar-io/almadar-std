                          "label": "Gold",
                          "value": "@entity.gold"
                        },
                        {
                          "label": "Wave",
                          "value": "@entity.wave"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.gold",
                  [
                    "+",
                    "@entity.gold",
                    [
                      "+",
                      10.0,
                      [
                        "*",
                        [
                          "array/len",
                          "@entity.buildings"
                        ],
                        5.0
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.tickCount",
                  [
                    "+",
                    "@entity.tickCount",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@entity.features",
                        "projection": "isometric",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": true,
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "UNIT_CLICK",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Wall HP",
                          "value": "@entity.health"
                        },
                        {
                          "label": "Gold",
                          "value": "@entity.gold"
                        },
                        {
                          "label": "Wave",
                          "value": "@entity.wave"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                ">",
                "@entity.health",
                0.0
              ],
              "interval": 4000.0,
              "name": "incomeTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.wave",
                  [
                    "+",
                    "@entity.wave",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.lastWaveDamage",
                  [
                    "math/max",
                    0.0,
                    [
                      "-",
                      "@entity.wave",
                      [
                        "array/len",
                        "@entity.buildings"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.health",
                  [
                    "math/max",
                    0.0,
                    [
                      "-",
                      "@entity.health",
                      "@entity.lastWaveDamage"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "if",
                        [
                          "==",
                          "@u.team",
                          "enemy"
                        ],
                        [
                          "object/merge",
                          "@u",
                          {
                            "animation": "attack"
                          }
                        ],
                        [
                          "if",
                          [
                            "==",
                            "@u.team",
                            "player"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": [
                                "if",
                                [
                                  "<=",
                                  "@entity.health",
                                  0.0
                                ],
                                "hit",
                                "idle"
                              ]
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/append",
                    "@entity.effects",
                    {
                      "key": "slash",
                      "ttl": 4.0,
                      "x": [
                        "object/get",
                        [
                          "object/get",
                          [
                            "array/first",
                            [
                              "array/filter",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.team",
                                  "enemy"
                                ]
                              ]
                            ]
                          ],
                          "position"
                        ],
                        "x"
                      ],
                      "y": [
                        "object/get",
                        [
                          "object/get",
                          [
                            "array/first",
                            [
                              "array/filter",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.team",
                                  "enemy"
                                ]
                              ]
                            ]
                          ],
                          "position"
                        ],
                        "y"
                      ]
                    }
                  ]
                ],
                [
                  "if",
                  [
                    "<=",
                    "@entity.health",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    [
                      "array/append",
                      "@entity.effects",
                      {
                        "key": "explosion",
                        "ttl": 5.0,
                        "x": 4.0,
                        "y": 4.0
                      }
                    ]
                  ],
                  null
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@entity.features",
                        "projection": "isometric",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": true,
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "UNIT_CLICK",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Wall HP",
                          "value": "@entity.health"
                        },
                        {
                          "label": "Gold",
                          "value": "@entity.gold"
                        },
                        {
                          "label": "Wave",
                          "value": "@entity.wave"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ],
                [
                  "emit",
                  "CASTLE_HIT",
                  {
                    "damage": "@entity.lastWaveDamage"
                  }
                ],
                [
                  "emit",
                  "WAVE_DEFEATED",
                  {
                    "wave": "@entity.wave"
                  }
                ]
              ],
              "guard": [
                "and",
                [
                  ">",
                  "@entity.health",
                  0.0
                ],
                [
                  "<",
                  "@entity.wave",
                  3.0
                ]
              ],
              "interval": 8000.0,
              "name": "waveTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}