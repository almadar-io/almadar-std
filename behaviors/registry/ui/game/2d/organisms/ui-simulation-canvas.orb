        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "preset": {
              "default": {
                "backgroundColor": "#1a1a2e",
                "bodies": [
                  {
                    "color": "#e94560",
                    "fixed": false,
                    "id": "b0",
                    "mass": 1.0,
                    "radius": 14.0,
                    "vx": 120.0,
                    "vy": 0.0,
                    "x": 100.0,
                    "y": 80.0
                  },
                  {
                    "color": "#0f3460",
                    "fixed": false,
                    "id": "b1",
                    "mass": 2.0,
                    "radius": 20.0,
                    "vx": -80.0,
                    "vy": 60.0,
