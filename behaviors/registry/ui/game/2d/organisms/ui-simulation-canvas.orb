                      },
                      "y": {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      }
                    },
                    "type": "object"
                  },
                  "name": "bodies",
                  "required": true,
                  "type": "array"
                },
                "constraints": {
                  "items": {
                    "properties": {
                      "bodyA": {
                        "name": "bodyA",
