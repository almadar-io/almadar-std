                    "id": "b4",
                    "mass": 1.0,
                    "radius": 16.0,
                    "vx": 70.0,
                    "vy": -50.0,
                    "x": 400.0,
                    "y": 280.0
                  }
                ],
                "constraints": [],
                "description": "Bouncing bodies with wall reflection",
                "domain": "mechanics",
                "gravity": {
                  "x": 0.0,
                  "y": 9.81
                },
                "id": "demo",
                "name": "Demo Scene",
                "parameters": {},
                "showVelocity": true
              },
              "description": "Initial simulation preset; bodies are live-mutated each tick",
              "label": "Preset",
              "properties": {
                "backgroundColor": {
                  "name": "backgroundColor",
                  "required": false,
                  "type": "string"
                },
                "bodies": {
                  "items": {
                    "properties": {
                      "color": {
                        "name": "color",
                        "required": true,
                        "type": "string"
                      },
                      "fixed": {
                        "name": "fixed",
                        "required": true,
                        "type": "boolean"
                      },
                      "id": {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      "mass": {
                        "name": "mass",
                        "required": true,
                        "type": "number"
                      },
                      "radius": {
                        "name": "radius",
                        "required": true,
                        "type": "number"
                      },
                      "vx": {
                        "name": "vx",
                        "required": true,
                        "type": "number"
                      },
                      "vy": {
