                  "type": "object"
                },
                "showVelocity": {
                  "name": "showVelocity",
                  "required": false,
                  "type": "boolean"
                }
              },
              "tier": "presentation",
              "type": "SimulationCanvasPreset"
            },
            "running": {
              "default": true,
              "description": "Whether the simulation ticks on mount",
              "label": "Running",
              "tier": "presentation",
              "type": "boolean"
            },
            "speed": {
              "default": 1.0,
              "description": "Simulation speed multiplier (cosmetic)",
              "label": "Speed",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Pause simulation",
              "event": "PAUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resume simulation",
              "event": "RESUME",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Reset bodies to initial config",
              "event": "RESET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "preset",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SimulationCanvasItem",
          "name": "SimulationCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Pause simulation",
                "key": "PAUSE",
                "name": "Pause",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resume simulation",
                "key": "RESUME",
                "name": "Resume",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Reset bodies to initial config",
                "key": "RESET",
                "name": "Reset",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.preset",
                    "@config.preset"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bodies": "@entity.preset.bodies",
                      "className": "@config.className",
                      "height": "@config.height",
                      "preset": "@entity.preset",
                      "running": "@entity.running",
                      "speed": "@config.speed",
                      "type": "simulation-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bodies": "@entity.preset.bodies",
                      "className": "@config.className",
                      "height": "@config.height",
                      "preset": "@entity.preset",
                      "running": "@entity.running",
                      "speed": "@config.speed",
                      "type": "simulation-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "PAUSE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    true
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bodies": "@entity.preset.bodies",
                      "className": "@config.className",
                      "height": "@config.height",
                      "preset": "@entity.preset",
                      "running": "@entity.running",
                      "speed": "@config.speed",
                      "type": "simulation-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "RESUME",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.preset",
                    "@config.preset"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "bodies": "@entity.preset.bodies",
                      "className": "@config.className",
                      "height": "@config.height",
                      "preset": "@entity.preset",
                      "running": "@entity.running",
                      "speed": "@config.speed",
                      "type": "simulation-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.preset",
                  [
                    "object/merge",
                    "@entity.preset",
                    {
                      "bodies": [
                        "array/map",
                        "@entity.preset.bodies",
                        [
                          "fn",
                          "b",
                          [
                            "if",
                            "@b.fixed",
                            "@b",
                            [
                              "let",
                              [
                                [
                                  "vx1",
                                  [
                                    "math/clamp",
                                    [
                                      "+",
                                      "@b.vx",
                                      [
                                        "*",
                                        "@entity.preset.gravity.x",
                                        0.0333
                                      ]
                                    ],
                                    [
                                      "-",
                                      0.0,
                                      500.0
                                    ],
                                    500.0
                                  ]
                                ],
                                [
                                  "vy1",
                                  [
                                    "math/clamp",
                                    [
                                      "+",
                                      "@b.vy",
                                      [
                                        "*",
                                        "@entity.preset.gravity.y",
                                        0.0333
                                      ]
                                    ],
                                    [
                                      "-",
                                      0.0,
                                      500.0
                                    ],
                                    500.0
                                  ]
                                ],
                                [
                                  "x1",
                                  [
                                    "+",
                                    "@b.x",
                                    [
                                      "*",
                                      "vx1",
                                      0.0333
                                    ]
                                  ]
                                ],
                                [
                                  "y1",
                                  [
                                    "+",
                                    "@b.y",
                                    [
                                      "*",
                                      "vy1",
                                      0.0333
                                    ]
                                  ]
                                ],
                                [
                                  "hitR",
                                  [
                                    ">",
                                    [
                                      "+",
                                      "x1",
                                      "@b.radius"
                                    ],
                                    "@config.width"
                                  ]
                                ],
                                [
                                  "hitL",
                                  [
                                    "<",
                                    [
                                      "-",
                                      "x1",
                                      "@b.radius"
                                    ],
                                    0.0
                                  ]
                                ],
                                [
                                  "hitB",
                                  [
                                    ">",
                                    [
                                      "+",
                                      "y1",
                                      "@b.radius"
                                    ],
                                    "@config.height"
                                  ]
                                ],
                                [
                                  "hitT",
                                  [
                                    "<",
                                    [
                                      "-",
                                      "y1",
                                      "@b.radius"
                                    ],
                                    0.0
                                  ]
                                ],
                                [
                                  "vx2",
                                  [
                                    "if",
                                    [
                                      "or",
                                      "hitR",
                                      "hitL"
                                    ],
                                    [
                                      "*",
                                      [
                                        "-",
                                        0.0,
                                        "vx1"
                                      ],
                                      0.8
                                    ],
                                    "vx1"
                                  ]
                                ],
                                [
                                  "vy2",
                                  [
                                    "if",
                                    [
                                      "or",
                                      "hitB",
                                      "hitT"
                                    ],
                                    [
                                      "*",
                                      [
                                        "-",
                                        0.0,
                                        "vy1"
                                      ],
                                      0.8
                                    ],
                                    "vy1"
                                  ]
                                ],
                                [
                                  "x2",
                                  [
                                    "math/clamp",
                                    "x1",
                                    "@b.radius",
                                    [
                                      "-",
                                      "@config.width",
                                      "@b.radius"
                                    ]
                                  ]
                                ],
                                [
                                  "y2",
                                  [
                                    "math/clamp",
                                    "y1",
                                    "@b.radius",
                                    [
                                      "-",
                                      "@config.height",
                                      "@b.radius"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "object/merge",
                                "@b",
                                {
                                  "vx": "vx2",
                                  "vy": "vy2",
                                  "x": "x2",
                                  "y": "y2"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    }
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "bodies": "@entity.preset.bodies",
                    "className": "@config.className",
                    "height": "@config.height",
                    "preset": "@entity.preset",
                    "running": "@entity.running",
                    "speed": "@config.speed",
                    "type": "simulation-canvas",
                    "width": "@config.width"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.running",
                true
              ],
              "interval": 33.0,
              "name": "physicsStep"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.1.0"
}