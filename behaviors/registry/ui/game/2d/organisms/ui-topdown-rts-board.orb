                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      "@entity.gridWidth",
                      "@entity.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@entity.selectedUnitId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.x",
                            "y": "@payload.y"
                          }
                        ],
                        2.0
                      ],
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "y"
                                  ],
                                  "@payload.y"
