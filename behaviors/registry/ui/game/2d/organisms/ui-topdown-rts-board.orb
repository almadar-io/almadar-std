                                  "@t",
                                  "y"
                                ]
                              },
                              "@entity.gridWidth",
                              "@entity.gridHeight"
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
