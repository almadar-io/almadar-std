                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                2.0
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
