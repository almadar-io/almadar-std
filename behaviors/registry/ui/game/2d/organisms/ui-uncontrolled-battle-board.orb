          },
          "emits": [
            {
              "description": "stepEvent prop — emitted each battle round with attack result",
              "event": "STEP",
              "payloadSchema": [
                {
                  "name": "attackerId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "targetId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "damage",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "playAgainEvent prop — reset + restart the battle",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "tileClickEvent prop — emitted when a tile is clicked on the canvas",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "unitClickEvent prop — emitted when a unit is clicked on the canvas",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "description",
              "effects",
              "result",
              "selectedUnitId",
              "title",
              "turn",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "UncontrolledBattleBoardItem",
          "name": "UncontrolledBattleBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "playAgainEvent prop — reset + restart the battle",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "stepEvent prop — emitted each battle round with attack result",
                "key": "STEP",
                "name": "Step",
                "payloadSchema": [
                  {
                    "name": "attackerId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "damage",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "tileClickEvent prop — emitted when a tile is clicked on the canvas",
                "key": "TILE_CLICK",
                "name": "Tile Click",
