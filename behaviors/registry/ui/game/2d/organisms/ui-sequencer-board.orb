                },
                "role": {
                  "name": "role",
                  "required": false,
                  "type": "string"
                },
                "style": {
                  "name": "style",
                  "required": false,
                  "type": "string"
                },
                "thumbnailUrl": {
                  "name": "thumbnailUrl",
                  "required": false,
                  "type": "string"
                },
                "url": {
                  "name": "url",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "Asset"
            },
            "hint": {
              "default": "You always brush your teeth before breakfast.",
              "description": "Hint revealed after 3 failed attempts.",
              "label": "Hint",
              "tier": "domain",
              "type": "string"
            },
            "maxSlots": {
              "default": 3.0,
              "description": "Number of slots the player fills — must match the solution length.",
              "label": "Max Slots",
              "tier": "domain",
              "type": "number"
            },
            "slots": {
              "default": [
                {
                  "index": 0.0,
                  "placedActionId": ""
                },
                {
                  "index": 1.0,
                  "placedActionId": ""
                },
                {
                  "index": 2.0,
                  "placedActionId": ""
                }
              ],
              "description": "Initial empty slot positions; one entry per maxSlots step.",
              "items": {
                "properties": {
                  "index": {
                    "name": "index",
                    "required": true,
                    "type": "number"
                  },
                  "placedActionId": {
                    "name": "placedActionId",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Slots",
              "tier": "presentation",
              "type": "[SequencerBoardSlotsItem]"
            },
            "solutions": {
              "default": [
                [
                  "wake-up",
                  "brush-teeth",
                  "eat-breakfast"
                ]
              ],
              "description": "Accepted winning sequences — at least one must match the player's slot order.",
              "items": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "label": "Solutions",
              "tier": "domain",
              "type": "[[string]]"
            },
            "stepDurationMs": {
              "default": 1000.0,
              "description": "Playback speed in milliseconds per step.",
              "label": "Step Duration Ms",
              "tier": "presentation",
              "type": "number"
            },
            "successMessage": {
              "default": "Perfect sequence! Great job!",
              "description": "Message shown when the player wins.",
              "label": "Success Message",
              "tier": "domain",
              "type": "string"
            },
            "title": {
              "default": "Morning Routine",
              "description": "Puzzle title shown above the sequencer.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "placeEvent prop — emitted when player drops an action into a slot",
              "event": "PLACE",
              "payloadSchema": [
                {
                  "name": "slotIndex",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "actionId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "removeEvent prop — emitted when player removes an action from a slot",
              "event": "REMOVE",
              "payloadSchema": [
                {
                  "name": "slotIndex",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "playEvent prop — emitted with the current slot sequence on playback start",
              "event": "PLAY",
              "payloadSchema": [
                {
                  "name": "sequence",
                  "required": true,
                  "type": "[string]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Advances playback one step; entity.currentStep increments until maxSlots-1 then returns to building",
              "event": "STEP",
              "payloadSchema": [
                {
                  "name": "step",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "checkEvent prop — emitted when player submits the sequence for validation",
              "event": "CHECK",
              "payloadSchema": [
                {
                  "name": "sequence",
                  "required": true,
                  "type": "[string]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "playAgainEvent prop — reset slots and restart",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "allowDuplicates",
              "attempts",
              "availableActions",
              "currentStep",
              "description",
              "headerImage",
              "hint",
              "maxSlots",
              "result",
              "slots",
              "solutions",
              "successMessage",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SequencerBoardItem",
          "name": "SequencerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "placeEvent prop — emitted when player drops an action into a slot",
                "key": "PLACE",
                "name": "Place",
                "payloadSchema": [
                  {
                    "name": "slotIndex",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "actionId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "removeEvent prop — emitted when player removes an action from a slot",
                "key": "REMOVE",
                "name": "Remove",
                "payloadSchema": [
                  {
                    "name": "slotIndex",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "playEvent prop — emitted with the current slot sequence on playback start",
                "key": "PLAY",
                "name": "Play",
                "payloadSchema": [
                  {
                    "name": "sequence",
                    "required": true,
                    "type": "[string]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "checkEvent prop — emitted when player submits the sequence for validation",
                "key": "CHECK",
                "name": "Check",
                "payloadSchema": [
                  {
                    "name": "sequence",
                    "required": true,
                    "type": "[string]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Advances playback one step; entity.currentStep increments until maxSlots-1 then returns to building",
                "key": "STEP",
                "name": "Step",
                "payloadSchema": [
                  {
                    "name": "step",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "playAgainEvent prop — reset slots and restart",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "building"
              },
              {
                "name": "menu"
              },
              {
                "name": "playing-back"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.slots",
                    "@config.slots"
                  ],
                  [
                    "set",
                    "@entity.availableActions",
                    "@config.availableActions"
                  ],
                  [
                    "set",
                    "@entity.solutions",
                    "@config.solutions"
                  ],
                  [
                    "set",
                    "@entity.maxSlots",
                    "@config.maxSlots"
                  ],
                  [
                    "set",
                    "@entity.allowDuplicates",
                    "@config.allowDuplicates"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.successMessage",
                    "@config.successMessage"
                  ],
                  [
                    "set",
                    "@entity.headerImage",
                    "@config.headerImage"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    -1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "checkEvent": "CHECK",
                      "entity": "@entity",
                      "placeEvent": "PLACE",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "removeEvent": "REMOVE",
                      "stepDurationMs": "@config.stepDurationMs",
                      "type": "sequencer-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.slots",
                    "@config.slots"
                  ],
                  [
                    "set",
                    "@entity.availableActions",
                    "@config.availableActions"
                  ],
                  [
                    "set",
                    "@entity.solutions",
                    "@config.solutions"
                  ],
                  [
                    "set",
                    "@entity.maxSlots",
                    "@config.maxSlots"
                  ],
                  [
                    "set",
                    "@entity.allowDuplicates",
                    "@config.allowDuplicates"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.successMessage",
                    "@config.successMessage"
                  ],
                  [
                    "set",
                    "@entity.headerImage",
                    "@config.headerImage"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    -1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "checkEvent": "CHECK",
                      "entity": "@entity",
                      "placeEvent": "PLACE",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "removeEvent": "REMOVE",
                      "stepDurationMs": "@config.stepDurationMs",
                      "type": "sequencer-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "building",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.slots",
                    [
                      "array/map",
                      "@entity.slots",
                      [
                        "fn",
                        "s",
                        [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "s",
                              "index"
                            ],
                            "@payload.slotIndex"
                          ],
                          [
                            "object/merge",
                            "s",
                            {
                              "placedActionId": "@payload.actionId"
                            }
                          ],
                          "s"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "checkEvent": "CHECK",
                      "entity": "@entity",
                      "placeEvent": "PLACE",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "removeEvent": "REMOVE",
                      "stepDurationMs": "@config.stepDurationMs",
                      "type": "sequencer-board"
                    }
                  ]
                ],
                "event": "PLACE",
                "from": "building",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.slots",
                    [
                      "array/map",
                      "@entity.slots",
                      [
                        "fn",
                        "s",
                        [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "s",
                              "index"
                            ],
                            "@payload.slotIndex"
                          ],
                          [
                            "object/merge",
                            "s",
                            {
                              "placedActionId": ""
                            }
                          ],
                          "s"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "checkEvent": "CHECK",
                      "entity": "@entity",
                      "placeEvent": "PLACE",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "removeEvent": "REMOVE",
                      "stepDurationMs": "@config.stepDurationMs",
                      "type": "sequencer-board"
                    }
                  ]
                ],
                "event": "REMOVE",
                "from": "building",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "checkEvent": "CHECK",
                      "entity": "@entity",
                      "placeEvent": "PLACE",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "removeEvent": "REMOVE",
                      "stepDurationMs": "@config.stepDurationMs",
                      "type": "sequencer-board"
                    }
                  ]
                ],
                "event": "PLAY",
                "from": "building",
                "to": "playing-back"
