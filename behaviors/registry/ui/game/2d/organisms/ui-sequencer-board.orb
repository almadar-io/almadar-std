                    }
                  ]
                ],
                "event": "STEP",
                "from": "playing-back",
                "guard": [
                  ">=",
                  "@entity.currentStep",
                  [
                    "-",
                    "@entity.maxSlots",
                    1.0
                  ]
                ],
                "to": "building"
              },
              {
                "effects": [
                  [
