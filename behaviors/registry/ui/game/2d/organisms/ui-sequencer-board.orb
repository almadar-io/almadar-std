                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Available Actions",
              "tier": "domain",
              "type": "[SequencerBoardAvailableActionsItem]"
            },
            "categoryColors": {
              "default": {},
              "description": "Category → color mapping for action card tinting.",
              "items": {
                "properties": {
                  "bg": {
                    "name": "bg",
                    "required": true,
                    "type": "string"
                  },
                  "border": {
                    "name": "border",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Category Colors",
              "tier": "presentation",
              "type": "Map<string,SequencerBoardCategoryColorsValue>"
            },
            "description": {
              "default": "Put the steps in the right order to start the day right.",
              "description": "One-line puzzle brief shown to the player.",
              "label": "Description",
              "tier": "domain",
              "type": "string"
            },
            "headerImage": {
              "default": "",
              "description": "Optional banner image shown at the top of the board.",
              "label": "Header Image",
              "properties": {
                "animations": {
                  "items": {
                    "type": "string"
                  },
                  "name": "animations",
                  "required": false,
                  "type": "array"
                },
                "aspect": {
                  "name": "aspect",
