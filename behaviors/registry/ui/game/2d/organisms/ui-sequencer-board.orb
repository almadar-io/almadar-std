                  "name": "Eat Breakfast"
                },
                {
                  "category": "morning",
                  "description": "Put on your clothes",
                  "iconEmoji": "👕",
                  "id": "get-dressed",
                  "name": "Get Dressed"
                }
              ],
              "description": "Draggable action cards the player picks from.",
              "items": {
                "properties": {
                  "category": {
