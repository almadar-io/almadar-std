      },
      "name": "SequencerBoardOrbital",
      "pages": [
        {
          "name": "SequencerBoardPage",
          "path": "/sequencer-board",
          "traits": [
            {
              "ref": "SequencerBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "allowDuplicates": {
              "default": false,
              "description": "When true the same action can be placed in multiple slots.",
              "label": "Allow Duplicates",
              "tier": "domain",
              "type": "boolean"
            },
            "availableActions": {
              "default": [
                {
                  "category": "morning",
                  "description": "Get out of bed",
                  "iconEmoji": "🌅",
                  "id": "wake-up",
                  "name": "Wake Up"
                },
                {
                  "category": "hygiene",
                  "description": "Clean your teeth",
                  "iconEmoji": "🪥",
