                "name": "Initialize"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
