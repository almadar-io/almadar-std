                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.selectedUnitId",
                  "@payload.unitId"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "selected"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Home",
                            "value": "@entity.homeScore"
                          },
                          {
                            "label": "Away",
                            "value": "@entity.awayScore"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedUnitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "walk",
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "kickoff"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Home",
                            "value": "@entity.homeScore"
                          },
                          {
                            "label": "Away",
                            "value": "@entity.awayScore"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.homeScore",
                    [
                      "if",
                      [
                        "==",
                        "@payload.team",
                        "player"
                      ],
                      [
                        "+",
                        "@entity.homeScore",
                        1.0
                      ],
                      "@entity.homeScore"
                    ]
                  ],
                  [
                    "set",
                    "@entity.awayScore",
                    [
                      "if",
                      [
                        "==",
                        "@payload.team",
                        "enemy"
                      ],
                      [
                        "+",
                        "@entity.awayScore",
                        1.0
                      ],
                      "@entity.awayScore"
                    ]
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "kickoff"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Home",
                            "value": "@entity.homeScore"
                          },
                          {
                            "label": "Away",
                            "value": "@entity.awayScore"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "GOAL",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.homeScore",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.awayScore",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "kickoff"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Home",
                            "value": "@entity.homeScore"
                          },
                          {
                            "label": "Away",
                            "value": "@entity.awayScore"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "playing",
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
