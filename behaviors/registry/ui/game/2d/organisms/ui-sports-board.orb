          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Fired when a goal is scored; team is 'player' or 'enemy'",
              "event": "GOAL",
              "payloadSchema": [
                {
                  "name": "team",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resets the match to initial state",
              "event": "RESET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "awayScore",
              "effects",
              "homeScore",
              "phase",
              "selectedUnitId",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SportsBoardItem",
          "name": "SportsBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Fired when a goal is scored; team is 'player' or 'enemy'",
                "key": "GOAL",
                "name": "Goal",
                "payloadSchema": [
                  {
                    "name": "team",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets the match to initial state",
                "key": "RESET",
                "name": "Reset",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.homeScore",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.awayScore",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "kickoff"
                  ],
                  [
