                          },
                          {
                            "label": "Away",
                            "value": "@entity.awayScore"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "kickoff"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
