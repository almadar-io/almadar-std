              },
              {
                "effects": [
                  [
                    "let",
                    [
                      [
                        "hero",
                        [
                          "array/find",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "==",
                              "@u.id",
                              "hero"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "nx",
                          [
                            "object/get",
                            [
                              "object/get",
                              "@hero",
                              "position"
                            ],
                            "x"
                          ]
                        ],
                        [
                          "ny",
                          [
                            "-",
                            [
                              "object/get",
                              [
                                "object/get",
                                "@hero",
                                "position"
                              ],
                              "y"
                            ],
                            1.0
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "tile",
                            [
                              "array/find",
                              "@config.tiles",
                              [
                                "fn",
                                "t",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "@nx"
                                  ],
                                  [
                                    "==",
                                    [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ],
                                    "@ny"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "targetMonster",
                            [
                              "array/find",
                              "@entity.units",
                              [
                                "fn",
                                "u",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@u.team",
                                    "enemy"
                                  ],
                                  [
                                    "and",
                                    [
                                      ">",
                                      "@u.health",
                                      0.0
                                    ],
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@u",
                                            "position"
                                          ],
                                          "x"
                                        ],
                                        "@nx"
                                      ],
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          [
                                            "object/get",
                                            "@u",
                                            "position"
                                          ],
                                          "y"
                                        ],
                                        "@ny"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "if",
                          [
                            "!=",
                            "@targetMonster",
                            null
                          ],
                          [
                            "do",
                            [
                              "set",
                              "@entity.units",
                              [
                                "array/map",
                                "@entity.units",
                                [
                                  "fn",
                                  "u",
                                  [
                                    "if",
                                    [
                                      "==",
                                      "@u.id",
                                      [
                                        "object/get",
                                        "@targetMonster",
                                        "id"
                                      ]
                                    ],
                                    [
                                      "object/merge",
                                      "@u",
                                      {
                                        "animation": [
                                          "if",
                                          [
                                            "<=",
                                            [
                                              "math/max",
                                              0.0,
                                              [
                                                "-",
                                                [
                                                  "object/get",
                                                  "@targetMonster",
                                                  "health"
                                                ],
                                                1.0
                                              ]
                                            ],
                                            0.0
                                          ],
                                          "death",
                                          "hit"
                                        ],
                                        "health": [
                                          "math/max",
                                          0.0,
                                          [
                                            "-",
                                            [
                                              "object/get",
                                              "@targetMonster",
                                              "health"
                                            ],
                                            1.0
                                          ]
                                        ]
                                      }
                                    ],
                                    "u"
                                  ]
                                ]
                              ]
                            ],
                            [
                              "if",
                              [
                                "<=",
                                [
                                  "-",
                                  [
                                    "object/get",
                                    "@targetMonster",
                                    "health"
                                  ],
                                  1.0
                                ],
                                0.0
                              ],
                              [
                                "do",
                                [
                                  "set",
                                  "@entity.score",
                                  [
                                    "+",
                                    "@entity.score",
                                    50.0
                                  ]
                                ],
                                [
                                  "set",
                                  "@entity.effects",
                                  [
                                    "array/append",
                                    "@entity.effects",
                                    {
                                      "key": "explosion",
                                      "ttl": 5.0,
                                      "x": "@nx",
                                      "y": "@ny"
                                    }
                                  ]
                                ]
                              ],
                              true
                            ]
                          ],
                          [
                            "if",
                            [
                              "and",
                              [
                                "grid/in-bounds",
                                {
                                  "x": "@nx",
                                  "y": "@ny"
                                },
                                "@entity.gridWidth",
                                "@entity.gridHeight"
                              ],
                              [
                                "==",
                                [
                                  "if",
                                  [
                                    "==",
                                    "@tile",
                                    null
                                  ],
                                  false,
                                  [
                                    "object/get",
                                    "@tile",
                                    "passable"
                                  ]
                                ],
                                true
                              ]
                            ],
                            [
                              "do",
                              [
                                "set",
                                "@entity.units",
                                [
                                  "array/map",
                                  "@entity.units",
                                  [
                                    "fn",
                                    "u",
                                    [
                                      "if",
                                      [
                                        "==",
                                        "@u.id",
                                        "hero"
                                      ],
                                      [
                                        "object/merge",
                                        "@u",
                                        {
                                          "animation": "walk",
                                          "position": {
                                            "x": "@nx",
                                            "y": "@ny"
                                          }
                                        }
                                      ],
                                      "u"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "if",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@nx",
                                    "@entity.chestX"
                                  ],
                                  [
                                    "==",
                                    "@ny",
                                    "@entity.chestY"
                                  ]
                                ],
                                [
                                  "do",
                                  [
                                    "set",
                                    "@entity.score",
                                    [
                                      "+",
                                      "@entity.score",
                                      200.0
                                    ]
                                  ],
                                  [
                                    "set",
                                    "@entity.result",
                                    "victory"
                                  ],
                                  [
                                    "emit",
                                    "GAME_END"
                                  ]
                                ],
                                true
                              ]
                            ],
                            true
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
