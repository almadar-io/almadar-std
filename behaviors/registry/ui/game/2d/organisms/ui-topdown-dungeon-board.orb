                        "if",
                        [
                          "and",
                          [
                            "==",
                            "@u.team",
                            "enemy"
                          ],
                          [
                            ">",
                            "@u.health",
                            0.0
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "ux",
                              [
                                "object/get",
                                [
                                  "object/get",
                                  "@u",
                                  "position"
                                ],
                                "x"
                              ]
                            ],
                            [
                              "uy",
                              [
                                "object/get",
                                [
                                  "object/get",
                                  "@u",
                                  "position"
                                ],
                                "y"
                              ]
                            ],
                            [
                              "heroX",
                              [
                                "object/get",
                                [
                                  "object/get",
                                  [
                                    "array/find",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "h",
                                      [
                                        "==",
                                        "@h.id",
                                        "hero"
                                      ]
                                    ]
                                  ],
                                  "position"
                                ],
                                "x"
                              ]
                            ],
                            [
                              "heroY",
                              [
                                "object/get",
                                [
                                  "object/get",
                                  [
                                    "array/find",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "h",
                                      [
                                        "==",
                                        "@h.id",
                                        "hero"
                                      ]
                                    ]
                                  ],
                                  "position"
                                ],
                                "y"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "dx",
                                [
                                  "math/sign",
                                  [
                                    "-",
                                    "@heroX",
                                    "@ux"
                                  ]
                                ]
                              ],
                              [
                                "dy",
                                [
                                  "math/sign",
                                  [
                                    "-",
                                    "@heroY",
                                    "@uy"
                                  ]
                                ]
                              ],
                              [
                                "absDx",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    "@heroX",
                                    "@ux"
                                  ]
                                ]
                              ],
                              [
                                "absDy",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    "@heroY",
                                    "@uy"
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "moveX",
                                  [
                                    "and",
                                    [
                                      "!=",
                                      "@dx",
                                      0.0
                                    ],
                                    [
                                      ">=",
                                      "@absDx",
                                      "@absDy"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "nx",
                                    [
                                      "if",
                                      "@moveX",
                                      [
                                        "+",
                                        "@ux",
                                        "@dx"
                                      ],
                                      "@ux"
                                    ]
                                  ],
                                  [
                                    "ny",
                                    [
                                      "if",
                                      "@moveX",
                                      "@uy",
                                      [
                                        "+",
                                        "@uy",
                                        "@dy"
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "tile",
                                      [
                                        "array/find",
                                        "@config.tiles",
                                        [
                                          "fn",
                                          "t",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "x"
                                              ],
                                              "@nx"
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "y"
                                              ],
                                              "@ny"
                                            ]
