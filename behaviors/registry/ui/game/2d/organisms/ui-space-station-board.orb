          },
          "emits": [
            {
              "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{cancelEvent} with {} on cancel",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "crewCount",
              "effects",
              "gridHeight",
              "gridWidth",
              "oxygen",
              "phase",
              "selectedUnitId",
              "units",
              "validMoves"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SpaceStationBoardItem",
          "name": "SpaceStationBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.oxygen",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.crewCount",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    7.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    7.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel-frame",
                        "role": "ui",
                        "style": "sci-fi",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/panel-frame.png",
                        "variant": ""
                      },
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "isometric",
                          "scale": "@config.scale",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "showMinimap": true,
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "unitClickEvent": "UNIT_CLICK",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
                              {
                                "iconUrl": {
                                  "animations": [],
                                  "aspect": "1:1",
                                  "category": "ui",
                                  "dimension": "2d",
