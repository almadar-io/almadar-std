                              "animations": [],
                              "aspect": "1:1",
                              "category": "ui",
                              "dimension": "2d",
                              "name": "icon-cancel",
                              "role": "ui",
                              "style": "sci-fi",
                              "thumbnailUrl": "",
                              "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/icon-cancel.png",
                              "variant": ""
                            },
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "hudBackgroundAsset": {
                        "animations": [],
                        "aspect": "1:1",
                        "category": "ui",
                        "dimension": "2d",
                        "name": "panel-frame",
                        "role": "ui",
                        "style": "sci-fi",
                        "thumbnailUrl": "",
                        "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/panel-frame.png",
                        "variant": ""
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "animation": [
                            "if",
                            [
                              "==",
                              [
                                "object/get",
                                "@u",
                                "animation"
                              ],
                              "walk"
                            ],
                            "idle",
                            [
                              "object/get",
                              "@u",
                              "animation"
                            ]
                          ],
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel-frame",
                      "role": "ui",
                      "style": "sci-fi",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/panel-frame.png",
                      "variant": ""
                    },
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "projection": "isometric",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": true,
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@config.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "UNIT_CLICK",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            {
                              "iconUrl": {
                                "animations": [],
                                "aspect": "1:1",
                                "category": "ui",
                                "dimension": "2d",
                                "name": "icon-crew",
                                "role": "ui",
                                "style": "sci-fi",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/icon-crew.png",
                                "variant": ""
                              },
                              "label": "Crew",
                              "value": "@entity.crewCount"
                            },
                            {
                              "iconUrl": {
                                "animations": [],
                                "aspect": "1:1",
                                "category": "ui",
                                "dimension": "2d",
                                "name": "icon-oxygen",
                                "role": "ui",
                                "style": "sci-fi",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/icon-oxygen.png",
                                "variant": ""
                              },
                              "label": "Oxygen",
                              "value": "@entity.oxygen"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "label": "Status",
                          "type": "state-indicator",
                          "value": "@entity.phase"
                        },
                        {
                          "label": "O2",
                          "type": "timer-display",
                          "value": "@entity.oxygen"
                        },
                        {
                          "action": "CANCEL",
                          "iconAsset": {
                            "animations": [],
                            "aspect": "1:1",
                            "category": "ui",
                            "dimension": "2d",
                            "name": "icon-cancel",
                            "role": "ui",
                            "style": "sci-fi",
                            "thumbnailUrl": "",
                            "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/icon-cancel.png",
                            "variant": ""
                          },
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel-frame",
                      "role": "ui",
                      "style": "sci-fi",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/panel-frame.png",
                      "variant": ""
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}