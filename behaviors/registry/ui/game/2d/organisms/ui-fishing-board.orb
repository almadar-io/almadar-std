              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@payload.unitId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "cast"
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "if",
                    [
                      "==",
                      "@payload.hitFish",
                      true
                    ],
                    [
                      "set",
                      "@entity.catchCount",
                      [
                        "+",
                        "@entity.catchCount",
                        1.0
                      ]
                    ],
                    null
                  ],
                  [
                    "if",
                    [
                      "==",
                      "@payload.hitFish",
                      true
                    ],
                    [
