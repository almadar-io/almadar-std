              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 100.0,
              "name": "animTick"
            },
            {
              "effects": [
                [
                  "set",
                  "@entity.enemies",
                  [
                    "array/map",
                    "@entity.enemies",
                    [
                      "fn",
                      "e",
                      [
                        "if",
                        [
                          ">",
                          "@e.hp",
                          0.0
                        ],
                        [
                          "let",
                          [
                            [
                              "ex",
                              "@e.x"
                            ],
                            [
                              "ey",
                              "@e.y"
                            ],
                            [
                              "px",
                              [
                                "object/get",
                                "@entity.player",
                                "x"
                              ]
                            ],
                            [
                              "py",
                              [
                                "object/get",
                                "@entity.player",
                                "y"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "adjP",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@ex",
                                        "@px"
                                      ]
                                    ],
                                    1.0
                                  ],
                                  [
                                    "==",
                                    "@ey",
                                    "@py"
                                  ]
                                ]
                              ],
                              [
                                "adjQ",
                                [
                                  "and",
                                  [
                                    "==",
                                    "@ex",
                                    "@px"
                                  ],
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@ey",
                                        "@py"
                                      ]
                                    ],
                                    1.0
                                  ]
                                ]
                              ]
                            ],
                            [
                              "if",
                              [
                                "or",
                                "@adjP",
                                "@adjQ"
                              ],
                              "@e",
                              [
                                "let",
                                [
                                  [
                                    "cnx",
                                    [
                                      "math/clamp",
                                      [
                                        "+",
                                        "@ex",
                                        [
                                          "math/sign",
                                          [
                                            "-",
                                            "@px",
                                            "@ex"
                                          ]
                                        ]
                                      ],
                                      0.0,
                                      [
                                        "-",
                                        "@entity.gridWidth",
                                        1.0
                                      ]
                                    ]
                                  ],
                                  [
                                    "cny",
                                    [
                                      "math/clamp",
                                      [
                                        "+",
                                        "@ey",
                                        [
                                          "math/sign",
                                          [
                                            "-",
                                            "@py",
                                            "@ey"
                                          ]
                                        ]
                                      ],
                                      0.0,
                                      [
                                        "-",
                                        "@entity.gridHeight",
                                        1.0
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "ntile",
                                      [
                                        "array/find",
                                        "@entity.tiles",
                                        [
                                          "fn",
                                          "t",
                                          [
                                            "and",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "x"
                                              ],
                                              "@cnx"
                                            ],
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@t",
                                                "y"
                                              ],
                                              "@cny"
                                            ]
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "occupied",
                                      [
                                        "array/find",
                                        "@entity.enemies",
                                        [
                                          "fn",
                                          "o",
                                          [
                                            "and",
                                            [
                                              "!=",
                                              "@o.id",
                                              "@e.id"
                                            ],
                                            [
                                              "and",
                                              [
                                                "==",
                                                "@o.x",
                                                "@cnx"
                                              ],
                                              [
                                                "==",
                                                "@o.y",
                                                "@cny"
                                              ]
                                            ]
                                          ]
                                        ]
                                      ]
                                    ]
                                  ],
                                  [
                                    "if",
                                    [
                                      "and",
                                      [
                                        "and",
                                        [
                                          "!=",
                                          "@ntile",
                                          null
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            "@ntile",
                                            "passable"
                                          ],
                                          true
                                        ]
                                      ],
                                      [
                                        "and",
                                        [
                                          "==",
                                          "@occupied",
                                          null
                                        ],
                                        [
                                          "or",
                                          [
                                            "!=",
                                            "@cnx",
                                            "@px"
                                          ],
                                          [
                                            "!=",
                                            "@cny",
                                            "@py"
                                          ]
                                        ]
                                      ]
                                    ],
                                    [
                                      "object/merge",
                                      "@e",
                                      {
                                        "x": "@cnx",
                                        "y": "@cny"
                                      }
                                    ],
                                    "@e"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        "@e"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.playerHp",
                  [
                    "let",
                    [
                      [
                        "adjEnemies",
                        [
                          "array/filter",
                          "@entity.enemies",
                          [
                            "fn",
                            "e",
                            [
                              "and",
                              [
                                ">",
                                "@e.hp",
                                0.0
                              ],
                              [
                                "or",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@e.x",
                                        [
                                          "object/get",
                                          "@entity.player",
                                          "x"
                                        ]
                                      ]
                                    ],
                                    1.0
                                  ],
                                  [
                                    "==",
                                    "@e.y",
                                    [
                                      "object/get",
                                      "@entity.player",
                                      "y"
                                    ]
                                  ]
                                ],
                                [
                                  "and",
                                  [
                                    "==",
                                    "@e.x",
                                    [
                                      "object/get",
                                      "@entity.player",
                                      "x"
                                    ]
                                  ],
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@e.y",
                                        [
                                          "object/get",
                                          "@entity.player",
                                          "y"
                                        ]
                                      ]
                                    ],
                                    1.0
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "dmg",
                          [
                            "if",
                            [
                              "==",
                              [
                                "array/len",
                                "@adjEnemies"
                              ],
                              0.0
                            ],
                            0.0,
                            [
                              "array/reduce",
                              "@adjEnemies",
                              [
                                "fn",
                                [
                                  "acc",
                                  "e"
                                ],
                                [
                                  "+",
                                  "acc",
                                  "@e.attack"
                                ]
                              ],
                              0.0
                            ]
                          ]
                        ]
                      ],
                      [
                        "math/max",
                        0.0,
                        [
                          "-",
                          "@entity.playerHp",
                          "@dmg"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "if",
                    [
                      ">",
                      [
                        "array/len",
                        [
                          "array/filter",
                          "@entity.enemies",
                          [
                            "fn",
                            "e",
                            [
                              "and",
                              [
                                ">",
                                "@e.hp",
                                0.0
                              ],
                              [
                                "or",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@e.x",
                                        [
                                          "object/get",
                                          "@entity.player",
                                          "x"
                                        ]
                                      ]
                                    ],
                                    1.0
                                  ],
                                  [
                                    "==",
                                    "@e.y",
                                    [
                                      "object/get",
                                      "@entity.player",
                                      "y"
                                    ]
                                  ]
                                ],
                                [
                                  "and",
                                  [
                                    "==",
                                    "@e.x",
                                    [
                                      "object/get",
                                      "@entity.player",
                                      "x"
                                    ]
                                  ],
                                  [
                                    "==",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        "@e.y",
                                        [
                                          "object/get",
                                          "@entity.player",
                                          "y"
                                        ]
                                      ]
                                    ],
                                    1.0
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ],
                      0.0
                    ],
                    [
                      "array/append",
                      "@entity.effects",
                      {
                        "key": "slash",
                        "ttl": 4.0,
                        "x": [
                          "object/get",
                          "@entity.player",
                          "x"
                        ],
                        "y": [
                          "object/get",
                          "@entity.player",
                          "y"
                        ]
                      }
                    ],
                    "@entity.effects"
                  ]
                ],
                [
                  "if",
                  [
                    "<=",
                    "@entity.playerHp",
                    0.0
                  ],
                  [
                    "do",
                    [
                      "set",
                      "@entity.result",
                      "lost"
                    ],
                    [
                      "emit",
                      "GAME_END"
                    ]
                  ],
                  true
                ],
                [
                  "set",
                  "@entity.phase",
                  [
                    "if",
                    [
                      "==",
                      "@entity.result",
                      "none"
                    ],
                    "player_turn",
                    "game_over"
                  ]
                ]
              ],
              "guard": [
                "and",
                [
                  "==",
                  "@entity.phase",
                  "enemy_turn"
                ],
                [
                  "==",
                  "@entity.result",
                  "none"
                ]
              ],
              "interval": 1000.0,
              "name": "enemyAiTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}