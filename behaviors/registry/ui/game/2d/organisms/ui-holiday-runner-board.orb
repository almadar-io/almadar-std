          "emits": [
            {
              "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "distance",
              "effects",
              "score",
              "units"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "HolidayRunnerBoardItem",
          "name": "HolidayRunnerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "running"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    "@config.units"
                  ],
                  [
                    "set",
                    "@entity.distance",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Distance",
                            "value": "@entity.distance"
                          },
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "running",
                "to": "running"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Distance",
                            "value": "@entity.distance"
                          },
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "running",
                "to": "running"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.units"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Distance",
                            "value": "@entity.distance"
                          },
                          {
                            "label": "Score",
                            "value": "@entity.score"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "running",
                "to": "running"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.units",
                  [
                    "array/map",
                    "@entity.units",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.distance",
                  [
                    "+",
                    "@entity.distance",
                    1.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "projection": "flat",
                        "scale": "@config.scale",
                        "showMinimap": false,
                        "tiles": "@config.tiles",
                        "type": "canvas-2d",
                        "units": "@entity.units"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Distance",
                          "value": "@entity.distance"
                        },
                        {
                          "label": "Score",
                          "value": "@entity.score"
