            }
          },
          "linkedEntity": "GameState",
          "name": "FxDecay",
          "ref": "Particles.traits.FxParticles"
        },
        {
          "config": {
            "running": {
              "default": true,
              "type": "unknown"
            }
          },
          "linkedEntity": "GameState",
          "name": "RoundLogic",
          "ref": "Round.traits.RoundFlow"
        },
        {
          "category": "interaction",
          "config": {
            "movementRange": {
              "default": 3.0,
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Player move intent applied by the grid-tactics authority",
              "event": "MOVE",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player attack intent applied by the grid-tactics authority",
              "event": "ATTACK",
              "payloadSchema": [
                {
                  "name": "targetId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Ends the player turn; the grid-tactics authority runs the enemy AI pipeline",
              "event": "AI_TURN",
              "payloadSchema": [
                {
                  "name": "turn",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "tileClickEvent prop",
              "event": "TILE_CLICK",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "unitClickEvent prop",
              "event": "UNIT_CLICK",
              "payloadSchema": [
                {
                  "name": "unitId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Clears the current selection",
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GameState",
          "name": "PlayerIntent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "unitClickEvent prop",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "tileClickEvent prop",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Clears the current selection",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "key": "END_TURN",
                "name": "End Turn"
              },
              {
                "description": "Player move intent applied by the grid-tactics authority",
                "key": "MOVE",
                "name": "Move",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Player attack intent applied by the grid-tactics authority",
                "key": "ATTACK",
                "name": "Attack",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Ends the player turn; the grid-tactics authority runs the enemy AI pipeline",
                "key": "AI_TURN",
                "name": "Ai Turn",
                "payloadSchema": [
                  {
                    "name": "turn",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "addons": {
                        "children": [
                          {
                            "action": "END_TURN",
                            "label": "End Turn",
                            "type": "button",
                            "variant": "primary"
                          },
                          {
                            "action": "CANCEL",
                            "label": "Cancel",
                            "type": "button",
                            "variant": "secondary"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "children": [
                        {
                          "effects": "@entity.fx",
                          "projection": "flat",
                          "selectedUnitId": "@entity.selectedUnitId",
                          "showMinimap": false,
                          "tileClickEvent": "TILE_CLICK",
                          "tiles": "@entity.tiles",
                          "type": "canvas-2d",
                          "unitClickEvent": "UNIT_CLICK",
                          "units": "@entity.units",
                          "validMoves": "@entity.validMoves"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Result",
                            "value": "@entity.result"
                          },
                          {
                            "label": "Phase",
                            "value": "@entity.uiPhase"
                          },
                          {
                            "label": "Selected",
                            "value": "@entity.selectedUnitId"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "ATTACK",
                    {
                      "targetId": "@payload.unitId"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "observation"
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.uiPhase",
                    "action"
                  ],
                  [
                    "and",
                    [
                      "==",
                      [
                        "object/get",
                        [
                          "array/find",
                          "@entity.units",
                          [
                            "fn",
                            "u",
                            [
                              "==",
                              "@u.id",
                              "@payload.unitId"
                            ]
                          ]
                        ],
                        "team"
                      ],
                      "enemy"
                    ],
                    [
                      "<=",
                      [
                        "grid/manhattan-distance",
                        [
                          "object/get",
                          [
                            "array/find",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "==",
                                "@u.id",
                                "@entity.selectedUnitId"
                              ]
                            ]
                          ],
                          "position"
                        ],
                        [
                          "object/get",
                          [
                            "array/find",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "==",
                                "@u.id",
                                "@payload.unitId"
                              ]
                            ]
                          ],
                          "position"
                        ]
                      ],
                      1.0
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.uiPhase",
                    "action"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.selectedUnitId",
                  "@payload.unitId"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "selection"
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.tiles",
                        [
                          "fn",
                          "t",
                          [
                            "and",
                            [
                              "==",
                              [
                                "object/get",
                                "@t",
                                "passable"
                              ],
                              true
                            ],
                            [
                              "and",
                              [
                                "<=",
                                [
                                  "grid/manhattan-distance",
                                  [
                                    "object/get",
                                    [
                                      "array/find",
                                      "@entity.units",
                                      [
                                        "fn",
                                        "u",
                                        [
                                          "==",
                                          "@u.id",
                                          "@payload.unitId"
                                        ]
                                      ]
                                    ],
                                    "position"
                                  ],
                                  {
                                    "x": [
                                      "object/get",
                                      "@t",
                                      "x"
                                    ],
                                    "y": [
                                      "object/get",
                                      "@t",
                                      "y"
                                    ]
                                  }
                                ],
                                "@config.movementRange"
                              ],
                              [
                                "==",
                                [
                                  "array/len",
                                  [
                                    "array/filter",
                                    "@entity.units",
                                    [
                                      "fn",
                                      "u",
                                      [
                                        "and",
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "x"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "x"
                                          ]
                                        ],
                                        [
                                          "==",
                                          [
                                            "object/get",
                                            [
                                              "object/get",
                                              "@u",
                                              "position"
                                            ],
                                            "y"
                                          ],
                                          [
                                            "object/get",
                                            "@t",
                                            "y"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                0.0
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "t",
                        {
                          "x": [
                            "object/get",
                            "@t",
                            "x"
                          ],
                          "z": [
                            "object/get",
                            "@t",
                            "y"
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "object/get",
                    [
                      "array/find",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "==",
                          "@u.id",
                          "@payload.unitId"
                        ]
                      ]
                    ],
                    "team"
                  ],
                  "player"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "emit",
                    "MOVE",
                    {
                      "unitId": "@entity.selectedUnitId",
                      "x": "@payload.x",
                      "y": "@payload.y"
                    }
                  ],
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "observation"
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "!=",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      6.0,
                      6.0
                    ],
                    [
                      "<=",
                      [
                        "grid/manhattan-distance",
                        [
                          "object/get",
                          [
                            "array/find",
                            "@entity.units",
                            [
                              "fn",
                              "u",
                              [
                                "==",
                                "@u.id",
                                "@entity.selectedUnitId"
                              ]
                            ]
                          ],
                          "position"
                        ],
                        {
                          "x": "@payload.x",
                          "y": "@payload.y"
                        }
                      ],
                      "@config.movementRange"
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedUnitId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validMoves",
                    []
                  ],
                  [
                    "set",
                    "@entity.uiPhase",
                    "observation"
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedUnitId",
                  ""
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.turn",
                    [
                      "+",
                      "@entity.turn",
                      1.0
                    ]
                  ],
                  [
                    "emit",
                    "AI_TURN",
                    {
                      "turn": "@entity.turn"
                    }
                  ]
                ],
                "event": "END_TURN",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "render-ui",
                  "main",
                  {
                    "addons": {
                      "children": [
                        {
                          "action": "END_TURN",
                          "label": "End Turn",
                          "type": "button",
                          "variant": "primary"
                        },
                        {
                          "action": "CANCEL",
                          "label": "Cancel",
                          "type": "button",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "children": [
                      {
                        "effects": "@entity.fx",
                        "projection": "flat",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": false,
                        "tileClickEvent": "TILE_CLICK",
                        "tiles": "@entity.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "UNIT_CLICK",
                        "units": "@entity.units",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Result",
                          "value": "@entity.result"
                        },
                        {
                          "label": "Phase",
                          "value": "@entity.uiPhase"
                        },
                        {
                          "label": "Selected",
                          "value": "@entity.selectedUnitId"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "renderTick"
            }
          ]
        }
      ],
      "uses": [
        {
          "as": "Tactics",
          "from": "std/behaviors/std-grid-tactics"
        },
        {
          "as": "Particles",
