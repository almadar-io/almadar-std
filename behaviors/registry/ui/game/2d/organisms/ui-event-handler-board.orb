              "label": "Goal Condition",
              "tier": "domain",
              "type": "string"
            },
            "goalEvent": {
              "default": "ALERT_SENT",
              "description": "The event name that must appear in the simulated chain for the player to win.",
              "label": "Goal Event",
              "tier": "domain",
              "type": "string"
            },
            "hint": {
              "default": "The Alarm object needs to react to DOOR_OPEN and fire SIREN_ON. The Siren needs to react to SIREN_ON and fire ALERT_SENT.",
              "description": "Optional hint revealed after 3 failed attempts.",
              "label": "Hint",
              "tier": "domain",
              "type": "string"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "objects": {
              "default": [
                {
                  "availableActions": [
                    {
                      "id": "SIREN_ON",
                      "label": "SIREN_ON"
                    },
                    {
