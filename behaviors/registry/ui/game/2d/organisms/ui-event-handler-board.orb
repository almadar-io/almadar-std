                  ],
                  "currentState": "silent",
                  "icon": "🔔",
                  "id": "obj-alarm",
                  "maxRules": 2.0,
                  "name": "Alarm",
                  "rules": [],
                  "states": [
                    "silent",
                    "ringing"
                  ]
                }
              ],
              "description": "Puzzle world objects each with their editable WHEN/THEN rule slots.",
              "items": {
