                                              "action": "EDIT_RULE",
                                              "actionPayload": {
                                                "objectId": "@rule.objectId",
                                                "rules": [
                                                  "array/map",
                                                  [
                                                    "array/range",
                                                    0.0,
                                                    [
                                                      "array/len",
                                                      "@rule.totalRules"
                                                    ]
                                                  ],
                                                  [
                                                    "fn",
                                                    "j",
                                                    [
                                                      "if",
                                                      [
                                                        "==",
                                                        "@j",
                                                        "@rule.ruleIdx"
                                                      ],
                                                      [
                                                        "object/merge",
                                                        [
                                                          "array/nth",
                                                          "@rule.totalRules",
                                                          "@j"
                                                        ],
                                                        {
                                                          "thenAction": "@act.id"
                                                        }
                                                      ],
                                                      [
                                                        "array/nth",
                                                        "@rule.totalRules",
                                                        "@j"
                                                      ]
                                                    ]
                                                  ]
                                                ]
                                              },
                                              "label": "@act.label",
                                              "type": "button",
                                              "variant": [
                                                "if",
                                                [
                                                  "==",
                                                  "@act.id",
                                                  "@rule.thenAction"
                                                ],
                                                "primary",
                                                "ghost"
                                              ]
                                            }
                                          ],
                                          "type": "data-list"
                                        }
                                      ],
                                      "direction": "vertical",
                                      "gap": "xs",
                                      "type": "stack"
                                    }
                                  ],
                                  "type": "data-list"
                                },
                                {
                                  "action": "EDIT_RULE",
                                  "actionPayload": {
                                    "objectId": "@obj.id",
