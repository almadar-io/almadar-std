            },
            "totalCount": {
              "default": 0.0,
              "description": "Total number of items",
              "label": "Total Count",
              "tier": "presentation",
              "type": "number"
            },
            "triggerEvents": {
              "default": [
                "DOOR_OPEN"
              ],
              "description": "Events that fire automatically at the start of each simulation run.",
              "items": {
                "type": "string"
              },
              "label": "Trigger Events",
              "tier": "domain",
              "type": "[string]"
            }
          },
          "emits": [
            {
              "description": "Emitted by the component when the animated chain resolves (success or failure).",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "success",
                  "required": true,
                  "type": "boolean"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player hits Play; component runs the animated simulation and fires COMPLETE.",
              "event": "PLAY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player saves a WHEN/THEN rule set for one object.",
              "event": "EDIT_RULE",
              "payloadSchema": [
                {
                  "name": "objectId",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "rules",
                  "type": "[EventHandlerBoardRule]"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Reset to menu after completing the puzzle.",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attempts",
              "description",
              "goalCondition",
              "goalEvent",
              "hint",
              "objects",
              "result",
              "title",
              "triggerEvents"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "EventHandlerBoardItem",
          "name": "EventHandlerBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Player saves a WHEN/THEN rule set for one object.",
                "key": "EDIT_RULE",
                "name": "Edit Rule",
                "payloadSchema": [
                  {
                    "name": "objectId",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "rules",
                    "type": "[EventHandlerBoardRule]"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Player hits Play; component runs the animated simulation and fires COMPLETE.",
                "key": "PLAY",
                "name": "Play",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Reset to menu after completing the puzzle.",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emitted by the component when the animated chain resolves (success or failure).",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.objects",
                    "@config.objects"
                  ],
                  [
                    "set",
                    "@entity.triggerEvents",
                    "@config.triggerEvents"
                  ],
                  [
                    "set",
                    "@entity.goalEvent",
                    "@config.goalEvent"
                  ],
                  [
                    "set",
                    "@entity.goalCondition",
                    "@config.goalCondition"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.objects",
                    "@config.objects"
                  ],
                  [
                    "set",
                    "@entity.triggerEvents",
                    "@config.triggerEvents"
                  ],
                  [
                    "set",
                    "@entity.goalEvent",
                    "@config.goalEvent"
                  ],
                  [
                    "set",
                    "@entity.goalCondition",
                    "@config.goalCondition"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.objects",
                    [
                      "array/map",
                      "@entity.objects",
                      [
                        "fn",
                        "obj",
                        [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "obj",
                              "id"
                            ],
                            "@payload.objectId"
                          ],
                          [
                            "object/merge",
                            "obj",
                            {
                              "rules": "@payload.rules"
                            }
                          ],
                          "obj"
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "EDIT_RULE",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "win"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "PLAY",
                "from": "playing",
                "guard": [
                  ">",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.objects",
                      [
                        "fn",
                        "obj",
                        [
                          "array/some",
                          [
                            "object/get",
                            "obj",
                            "rules"
                          ],
                          [
                            "fn",
                            "rule",
                            [
                              "==",
                              [
                                "object/get",
                                "rule",
                                "thenAction"
                              ],
                              "@entity.goalEvent"
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "PLAY",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "array/len",
                    [
                      "array/filter",
                      "@entity.objects",
                      [
                        "fn",
                        "obj",
                        [
                          "array/some",
                          [
                            "object/get",
                            "obj",
                            "rules"
                          ],
                          [
                            "fn",
                            "rule",
                            [
                              "==",
                              [
                                "object/get",
                                "rule",
                                "thenAction"
                              ],
                              "@entity.goalEvent"
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  0.0
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.objects",
                    "@config.objects"
                  ],
                  [
                    "set",
                    "@entity.triggerEvents",
                    "@config.triggerEvents"
                  ],
                  [
                    "set",
                    "@entity.goalEvent",
                    "@config.goalEvent"
                  ],
                  [
                    "set",
                    "@entity.goalCondition",
                    "@config.goalCondition"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "complete",
                "to": "menu"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "completeEvent": "COMPLETE",
                      "editRuleEvent": "EDIT_RULE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "playEvent": "PLAY",
                      "type": "event-handler-board"
                    }
                  ]
                ],
                "event": "COMPLETE",
                "from": "complete",
                "to": "complete"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}