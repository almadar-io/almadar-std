                    }
                  ],
                  "availableEvents": [
                    {
                      "id": "DOOR_OPEN",
                      "label": "DOOR_OPEN"
                    },
                    {
                      "id": "DOOR_CLOSE",
                      "label": "DOOR_CLOSE"
                    }
                  ],
                  "currentState": "closed",
                  "icon": "🚪",
                  "id": "obj-door",
                  "maxRules": 2.0,
                  "name": "Door Sensor",
                  "rules": [],
                  "states": [
                    "closed",
                    "open"
                  ]
                },
                {
                  "availableActions": [
                    {
                      "id": "ALERT_SENT",
                      "label": "ALERT_SENT"
                    },
                    {
                      "id": "LOG_EVENT",
                      "label": "LOG_EVENT"
                    }
                  ],
                  "availableEvents": [
                    {
                      "id": "SIREN_ON",
                      "label": "SIREN_ON"
                    },
                    {
                      "id": "DOOR_OPEN",
                      "label": "DOOR_OPEN"
                    }
                  ],
                  "currentState": "silent",
                  "icon": "🔔",
                  "id": "obj-alarm",
                  "maxRules": 2.0,
                  "name": "Alarm",
                  "rules": [],
                  "states": [
                    "silent",
                    "ringing"
                  ]
                }
              ],
              "description": "Puzzle world objects each with their editable WHEN/THEN rule slots.",
              "items": {
                "properties": {
                  "availableActions": {
                    "items": {
                      "properties": {
