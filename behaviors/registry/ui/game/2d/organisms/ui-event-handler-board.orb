{
  "description": "EventHandlerBoard — wire WHEN/THEN rules on objects so a trigger event chain reaches the goal.",
  "name": "ui-event-handler-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
