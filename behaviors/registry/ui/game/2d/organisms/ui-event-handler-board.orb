                                              "variant": "caption"
                                            },
                                            {
                                              "label": "@rule.whenEvent",
                                              "type": "badge",
                                              "variant": "secondary"
                                            },
                                            {
                                              "content": "→ THEN",
                                              "type": "typography",
                                              "variant": "caption"
                                            },
                                            {
                                              "label": "@rule.thenAction",
                                              "type": "badge",
                                              "variant": "secondary"
                                            },
                                            {
                                              "action": "EDIT_RULE",
                                              "actionPayload": {
                                                "objectId": "@rule.objectId",
