                                      "array/range",
                                      0.0,
                                      [
                                        "array/len",
                                        "@obj.rules"
                                      ]
                                    ],
                                    [
                                      "fn",
                                      "i",
                                      [
                                        "object/merge",
                                        [
                                          "array/nth",
                                          "@obj.rules",
                                          "@i"
                                        ],
                                        {
                                          "availableActions": "@obj.availableActions",
                                          "availableEvents": "@obj.availableEvents",
                                          "objectId": "@obj.id",
                                          "ruleIdx": "@i",
