                                      "@obj.rules",
                                      {
                                        "thenAction": [
                                          "object/get",
                                          [
                                            "array/first",
                                            "@obj.availableActions"
                                          ],
                                          "id",
                                          ""
                                        ],
                                        "whenEvent": [
                                          "object/get",
                                          [
                                            "array/first",
                                            "@obj.availableEvents"
                                          ],
                                          "id",
                                          ""
                                        ]
                                      }
                                    ]
                                  },
                                  "disabled": [
                                    ">=",
                                    [
                                      "array/len",
                                      "@obj.rules"
                                    ],
                                    "@obj.maxRules"
                                  ],
                                  "label": "Add Rule",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
