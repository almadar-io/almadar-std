{
  "description": "TraitSlot — UI factory (1:1 with the @almadar/ui trait-slot pattern).",
  "name": "ui-trait-slot",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 1.0,
            "name": "slotNumber",
            "type": "number"
          }
        ],
        "name": "TraitSlotItem",
        "persistence": "runtime"
      },
      "name": "TraitSlotOrbital",
      "pages": [
        {
          "name": "TraitSlotPage",
          "path": "/trait-slot",
          "traits": [
            {
              "ref": "TraitSlotRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "categoryColors": {
              "default": {},
              "description": "Category → color mapping",
              "items": {
                "properties": {
                  "bg": {
                    "name": "bg",
                    "required": true,
                    "type": "string"
                  },
                  "border": {
                    "name": "border",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Category Colors",
              "tier": "presentation",
              "type": "Map<string,TraitSlotCategoryColorsValue>"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "draggable": {
              "default": false,
              "description": "Whether this slot's equipped item is draggable",
              "label": "Draggable",
              "tier": "presentation",
              "type": "boolean"
            },
            "equippedItem": {
              "default": {
                "category": "Category",
                "description": "Description",
                "iconEmoji": "Icon Emoji",
                "iconUrl": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png",
                "id": "Id",
                "name": "Name"
              },
              "description": "Currently equipped item, if any",
              "label": "Equipped Item",
              "properties": {
                "category": {
                  "name": "category",
                  "required": true,
                  "type": "string"
                },
                "description": {
                  "name": "description",
                  "required": false,
                  "type": "string"
                },
                "iconEmoji": {
                  "name": "iconEmoji",
                  "required": false,
                  "type": "string"
                },
                "iconUrl": {
                  "name": "iconUrl",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "stateMachine": {
                  "name": "stateMachine",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "TraitSlotEquippedItem"
            },
            "error": {
              "description": "Error state",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "TraitSlotError"
            },
            "feedback": {
              "default": "correct",
              "description": "Per-slot correctness feedback after a failed attempt",
              "label": "Feedback",
              "tier": "presentation",
              "type": "string",
              "values": [
                "correct",
                "wrong"
              ]
            },
            "isLoading": {
              "default": false,
              "description": "Loading state",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "lockLabel": {
              "default": "Lock Label",
              "description": "Label shown when locked",
              "label": "Lock Label",
              "tier": "presentation",
              "type": "string"
            },
            "locked": {
              "default": false,
              "description": "Whether slot is locked",
              "label": "Locked",
              "tier": "presentation",
              "type": "boolean"
            },
            "selected": {
              "default": false,
              "description": "Whether slot is selected",
              "label": "Selected",
              "tier": "presentation",
              "type": "boolean"
            },
            "showTooltip": {
              "default": true,
              "description": "Show tooltip on hover",
              "label": "Show Tooltip",
              "tier": "presentation",
              "type": "boolean"
            },
            "size": {
              "default": "md",
              "description": "Size variant",
              "label": "Size",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "slotNumber": {
              "default": 1.0,
              "description": "Slot index (1-based)",
              "label": "Slot Number",
              "tier": "presentation",
              "type": "number"
            },
            "tooltipFrameUrl": {
              "default": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png",
              "description": "Optional tooltip frame image URL",
              "label": "Tooltip Frame Url",
              "tier": "presentation",
              "type": "asset"
            }
          },
          "emits": [
            {
              "description": "-- Drag and drop --",
              "event": "ITEM_DROP",
              "payloadSchema": [
                {
                  "name": "item",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "category",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "asset"
                    },
                    {
                      "name": "stateMachine",
                      "type": "json"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Called when drag starts from this slot",
              "event": "DRAG_START",
              "payloadSchema": [
                {
                  "name": "item",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "category",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "iconEmoji",
                      "type": "string"
                    },
                    {
                      "name": "iconUrl",
                      "type": "asset"
                    },
                    {
                      "name": "stateMachine",
                      "type": "json"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "-- Callbacks --",
              "event": "CLICK",
              "payloadSchema": [
                {
                  "name": "slotNumber",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Remove handler",
              "event": "REMOVE",
              "payloadSchema": [
                {
                  "name": "slotNumber",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "slotNumber"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TraitSlotItem",
          "name": "TraitSlotRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "-- Callbacks --",
                "key": "CLICK",
                "name": "Click",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Remove handler",
                "key": "REMOVE",
                "name": "Remove",
                "payloadSchema": [
                  {
                    "name": "slotNumber",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "-- Drag and drop --",
                "key": "ITEM_DROP",
                "name": "Item Drop",
                "payloadSchema": [
                  {
                    "name": "item",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "category",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "asset"
                      },
                      {
                        "name": "stateMachine",
                        "type": "json"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Called when drag starts from this slot",
                "key": "DRAG_START",
                "name": "Drag Start",
                "payloadSchema": [
                  {
                    "name": "item",
                    "properties": [
                      {
                        "name": "id",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "name",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "category",
                        "required": true,
                        "type": "string"
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "asset"
                      },
                      {
                        "name": "stateMachine",
                        "type": "json"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "TraitSlotItem",
                    {}
                  ],
                  [
                    "set",
                    "@entity.slotNumber",
                    "@config.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "className": "@config.className",
                      "clickEvent": "CLICK",
                      "draggable": "@config.draggable",
                      "entity": "TraitSlotItem",
                      "equippedItem": "@config.equippedItem",
                      "error": "@config.error",
                      "feedback": "@config.feedback",
                      "isLoading": "@config.isLoading",
                      "lockLabel": "@config.lockLabel",
                      "locked": "@config.locked",
                      "onClick": "CLICK",
                      "onDragStart": "DRAG_START",
                      "onItemDrop": "ITEM_DROP",
                      "onRemove": "REMOVE",
                      "removeEvent": "REMOVE",
                      "selected": "@config.selected",
                      "showTooltip": "@config.showTooltip",
                      "size": "@config.size",
                      "slotNumber": "@entity.slotNumber",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl",
                      "type": "trait-slot"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.slotNumber",
                    "@payload.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "className": "@config.className",
                      "clickEvent": "CLICK",
                      "draggable": "@config.draggable",
                      "entity": "TraitSlotItem",
                      "equippedItem": "@config.equippedItem",
                      "error": "@config.error",
                      "feedback": "@config.feedback",
                      "isLoading": "@config.isLoading",
                      "lockLabel": "@config.lockLabel",
                      "locked": "@config.locked",
                      "onClick": "CLICK",
                      "onDragStart": "DRAG_START",
                      "onItemDrop": "ITEM_DROP",
                      "onRemove": "REMOVE",
                      "removeEvent": "REMOVE",
                      "selected": "@config.selected",
                      "showTooltip": "@config.showTooltip",
                      "size": "@config.size",
                      "slotNumber": "@entity.slotNumber",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl",
                      "type": "trait-slot"
                    }
                  ]
                ],
                "event": "CLICK",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.slotNumber",
                    "@payload.slotNumber"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColors": "@config.categoryColors",
                      "className": "@config.className",
                      "clickEvent": "CLICK",
                      "draggable": "@config.draggable",
                      "entity": "TraitSlotItem",
                      "equippedItem": "@config.equippedItem",
                      "error": "@config.error",
                      "feedback": "@config.feedback",
                      "isLoading": "@config.isLoading",
                      "lockLabel": "@config.lockLabel",
                      "locked": "@config.locked",
                      "onClick": "CLICK",
                      "onDragStart": "DRAG_START",
                      "onItemDrop": "ITEM_DROP",
                      "onRemove": "REMOVE",
                      "removeEvent": "REMOVE",
                      "selected": "@config.selected",
                      "showTooltip": "@config.showTooltip",
                      "size": "@config.size",
                      "slotNumber": "@entity.slotNumber",
                      "tooltipFrameUrl": "@config.tooltipFrameUrl",
                      "type": "trait-slot"
                    }
                  ]
                ],
                "event": "REMOVE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}