              "type": "object"
            },
            "name": "testCases",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
