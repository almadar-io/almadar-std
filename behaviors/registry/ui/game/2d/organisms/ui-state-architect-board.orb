                                "label": "Passed",
                                "value": "@entity.passedTests"
                              },
                              {
                                "label": "Total",
                                "value": "@entity.totalTests"
                              }
                            ],
                            "type": "game-hud"
                          },
                          {
                            "children": [
                              {
                                "action": "RUN_TESTS",
                                "label": "Run Tests",
                                "type": "button",
                                "variant": "primary"
                              },
                              {
                                "action": "PLAY_AGAIN",
                                "label": "Reset",
                                "type": "button",
                                "variant": "ghost"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "md",
                        "justify": "between",
                        "type": "stack"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
