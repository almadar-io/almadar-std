          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "hint",
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "attempts",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "win"
            ]
          }
        ],
        "name": "StateArchitectBoardItem",
        "persistence": "runtime"
      },
      "name": "StateArchitectBoardOrbital",
      "pages": [
        {
          "name": "StateArchitectBoardPage",
          "path": "/state-architect-board",
          "traits": [
            {
              "ref": "StateArchitectBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeFilters": {
              "description": "Active filters",
              "label": "Active Filters",
              "tier": "presentation",
              "type": "json"
            },
            "availableEvents": {
              "default": [
                "ADVANCE",
                "RESET"
              ],
              "description": "Events the player can assign to transitions they add.",
              "items": {
                "type": "string"
              },
              "label": "Available Events",
              "tier": "domain",
              "type": "[string]"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Wire transitions between states so every test case reaches the correct final state.",
              "description": "One-line puzzle brief shown to the player.",
              "label": "Description",
              "tier": "domain",
              "type": "string"
            },
            "entityName": {
              "default": "TrafficLight",
              "description": "Name of the machine being built, shown in the code view.",
              "label": "Entity Name",
              "tier": "domain",
              "type": "string"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "StateArchitectBoardError"
            },
            "hint": {
              "default": "Red must go to Green on ADVANCE. Green must go to Yellow on ADVANCE. Yellow must go back to Red on ADVANCE.",
              "description": "Optional hint revealed after 3 failed attempts.",
              "label": "Hint",
              "tier": "domain",
              "type": "string"
            },
            "initialState": {
              "default": "red",
              "description": "The state the machine starts in when a test begins.",
              "label": "Initial State",
              "tier": "domain",
              "type": "string"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "pageProp": {
              "default": 0.0,
              "description": "Current page number",
              "label": "Page",
              "synonyms": "page",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 0.0,
              "description": "Number of items per page",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "searchValue": {
              "default": "Search Value",
              "description": "Current search query value",
              "label": "Search Value",
              "tier": "presentation",
              "type": "string"
            },
            "selectedIds": {
              "default": [],
              "description": "Currently selected item IDs",
              "items": {
                "type": "string"
              },
              "label": "Selected Ids",
              "tier": "presentation",
              "type": "[string]"
            },
            "sortBy": {
              "default": "Sort By",
              "description": "Current sort field",
              "label": "Sort By",
              "tier": "presentation",
              "type": "string"
            },
            "sortDirection": {
              "default": "asc",
              "description": "Current sort direction",
              "label": "Sort Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "asc",
                "desc"
              ]
            },
            "states": {
              "default": [
                "red",
                "green",
                "yellow"
              ],
              "description": "All valid states in the puzzle's machine.",
              "items": {
                "type": "string"
              },
              "label": "States",
              "tier": "domain",
              "type": "[string]"
            },
            "stepDurationMs": {
              "default": 600.0,
              "description": "Playback speed",
              "label": "Step Duration Ms",
              "tier": "presentation",
              "type": "number"
            },
            "testCases": {
              "default": [
                {
                  "events": [
                    "ADVANCE"
                  ],
                  "expectedState": "green",
                  "label": "One ADVANCE from red → green"
                },
                {
                  "events": [
                    "ADVANCE",
                    "ADVANCE"
                  ],
                  "expectedState": "yellow",
                  "label": "Two ADVANCEs from red → yellow"
                },
                {
                  "events": [
                    "ADVANCE",
                    "ADVANCE",
                    "ADVANCE"
                  ],
                  "expectedState": "red",
                  "label": "Three ADVANCEs cycle back → red"
                }
              ],
              "description": "Ordered event sequences starting from initialState; must all reach expectedState for a win. Non-empty by default so an empty graph cannot win vacuously.",
              "items": {
                "properties": {
                  "events": {
                    "items": {
                      "type": "string"
                    },
                    "name": "events",
                    "required": false,
                    "type": "array"
                  },
                  "expectedState": {
                    "name": "expectedState",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Test Cases",
              "tier": "domain",
              "type": "[StateArchitectBoardTestCasesItem]"
            },
            "title": {
              "default": "Build the Traffic Light",
              "description": "Puzzle title shown above the board.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "totalCount": {
              "default": 0.0,
              "description": "Total number of items",
              "label": "Total Count",
              "tier": "presentation",
              "type": "number"
            },
            "transitions": {
              "default": [],
              "description": "The player's current transition graph; empty at puzzle start so they must build it.",
              "items": {
                "properties": {
                  "event": {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "guardHint": {
                    "name": "guardHint",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Transitions",
              "tier": "domain",
              "type": "[StateArchitectBoardTransitionsItem]"
            },
            "variables": {
              "default": [
                {
                  "id": "v1",
                  "name": "current",
                  "value": "red"
                }
              ],
              "description": "Variable panel entries shown in the side panel.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Variables",
              "tier": "domain",
              "type": "[StateArchitectBoardVariablesItem]"
            }
          },
          "emits": [
            {
              "description": "Emitted by the component when test-run completes; carries pass count.",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "success",
                  "required": true,
                  "type": "boolean"
                },
                {
                  "name": "passedTests",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player triggers the test runner; component evaluates each test case and fires COMPLETE.",
              "event": "RUN_TESTS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player wires a new transition in the graph editor.",
              "event": "ADD_TRANSITION",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "from",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "to",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "event",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Player removes a transition from the graph.",
              "event": "REMOVE_TRANSITION",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Reset the puzzle back to the menu.",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attempts",
              "availableEvents",
              "description",
              "entityName",
              "hint",
              "initialState",
              "passedTests",
              "result",
              "states",
              "testCases",
              "title",
              "totalTests",
              "transitions",
              "variables"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StateArchitectBoardItem",
          "name": "StateArchitectBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Player wires a new transition in the graph editor.",
                "key": "ADD_TRANSITION",
                "name": "Add Transition",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "event",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Player removes a transition from the graph.",
                "key": "REMOVE_TRANSITION",
                "name": "Remove Transition",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Player triggers the test runner; component evaluates each test case and fires COMPLETE.",
                "key": "RUN_TESTS",
                "name": "Run Tests",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emitted by the component when test-run completes; carries pass count.",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  },
                  {
                    "name": "passedTests",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Reset the puzzle back to the menu.",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.states",
                    "@config.states"
                  ],
                  [
                    "set",
                    "@entity.initialState",
                    "@config.initialState"
                  ],
                  [
                    "set",
                    "@entity.entityName",
                    "@config.entityName"
                  ],
                  [
                    "set",
                    "@entity.availableEvents",
                    "@config.availableEvents"
                  ],
                  [
                    "set",
                    "@entity.transitions",
                    "@config.transitions"
                  ],
                  [
                    "set",
                    "@entity.testCases",
                    "@config.testCases"
                  ],
                  [
                    "set",
                    "@entity.variables",
                    "@config.variables"
                  ],
                  [
                    "set",
                    "@entity.totalTests",
                    [
                      "array/len",
                      "@config.testCases"
                    ]
                  ],
                  [
                    "set",
                    "@entity.passedTests",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.hint",
                    "@config.hint"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "entity": "@entity.transitions",
                          "fields": [],
                          "gap": "sm",
                          "renderItem": [
                            "fn",
                            "tr",
                            {
                              "subtitle": [
                                "object/get",
                                "tr",
                                "to"
                              ],
                              "title": [
                                "object/get",
                                "tr",
                                "event"
                              ],
                              "type": "card"
                            }
                          ],
                          "type": "data-list"
                        },
                        {
                          "entity": "@entity.testCases",
                          "fields": [],
                          "gap": "sm",
                          "renderItem": [
