{
  "description": "StateArchitectBoard — build a state machine whose transitions pass every test case.",
  "name": "ui-state-architect-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
