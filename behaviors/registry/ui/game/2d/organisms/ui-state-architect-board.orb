                            "tc",
                            {
                              "subtitle": [
                                "object/get",
                                "tc",
                                "expectedState"
                              ],
                              "title": [
                                "object/get",
                                "tc",
                                "label"
                              ],
                              "type": "card"
                            }
                          ],
                          "type": "data-list"
                        }
                      ],
                      "hud": {
                        "children": [
                          {
                            "stats": [
