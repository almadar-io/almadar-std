{
  "description": "SimulatorBoard — parameter-tuning puzzle: adjust params until output is within tolerance of target.",
  "name": "ui-simulator-board",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "paramA",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "paramB",
            "type": "number"
          },
          {
            "default": 10.0,
            "name": "target",
            "type": "number"
          },
          {
            "default": 1.0,
            "name": "tolerance",
            "type": "number"
          },
          {
            "intrinsic": true,
            "name": "output",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "attempts",
            "type": "number"
          },
          {
            "default": "none",
            "name": "result",
            "type": "string",
            "values": [
              "none",
              "win"
            ]
          },
          {
            "items": {
              "properties": {
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "max": {
                  "name": "max",
                  "required": false,
                  "type": "number"
                },
                "min": {
                  "name": "min",
                  "required": false,
                  "type": "number"
                },
                "step": {
                  "name": "step",
                  "required": false,
                  "type": "number"
                },
                "unit": {
                  "name": "unit",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "parameters",
            "type": "array"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "outputLabel",
            "type": "string"
          }
        ],
        "name": "SimulatorBoardItem",
        "persistence": "runtime"
      },
      "name": "SimulatorBoardOrbital",
      "pages": [
        {
          "name": "SimulatorBoardPage",
          "path": "/simulator-board",
          "traits": [
            {
              "ref": "SimulatorBoardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "activeFilters": {
              "description": "Active filters",
              "label": "Active Filters",
              "tier": "presentation",
              "type": "json"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Adjust the sliders so the output lands within tolerance of the target.",
              "description": "One-line puzzle brief shown to the player.",
              "label": "Description",
              "tier": "domain",
              "type": "string"
            },
            "error": {
              "description": "Error state (UiError)",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "SimulatorBoardError"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state indicator",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "outputLabel": {
              "default": "Output = A + B × 2",
              "description": "Human-readable formula label shown next to the output value.",
              "label": "Output Label",
              "tier": "domain",
              "type": "string"
            },
            "pageProp": {
              "default": 0.0,
              "description": "Current page number",
              "label": "Page",
              "synonyms": "page",
              "tier": "presentation",
              "type": "number"
            },
            "pageSize": {
              "default": 0.0,
              "description": "Number of items per page",
              "label": "Page Size",
              "tier": "presentation",
              "type": "number"
            },
            "parameters": {
              "default": [
                {
                  "id": "paramA",
                  "label": "Base Value (A)",
                  "max": 10.0,
                  "min": 0.0,
                  "step": 1.0,
                  "unit": ""
                },
                {
                  "id": "paramB",
                  "label": "Multiplier (B)",
                  "max": 5.0,
                  "min": 0.0,
                  "step": 1.0,
                  "unit": ""
                }
              ],
              "description": "Slider descriptors — index 0 drives parameter A, index 1 drives parameter B.",
              "items": {
                "properties": {
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "max": {
                    "name": "max",
                    "required": false,
                    "type": "number"
                  },
                  "min": {
                    "name": "min",
                    "required": false,
                    "type": "number"
                  },
                  "step": {
                    "name": "step",
                    "required": false,
                    "type": "number"
                  },
                  "unit": {
                    "name": "unit",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Parameters",
              "tier": "domain",
              "type": "[SimulatorBoardParameterItem]"
            },
            "searchValue": {
              "default": "Search Value",
              "description": "Current search query value",
              "label": "Search Value",
              "tier": "presentation",
              "type": "string"
            },
            "selectedIds": {
              "default": [],
              "description": "Currently selected item IDs",
              "items": {
                "type": "string"
              },
              "label": "Selected Ids",
              "tier": "presentation",
              "type": "[string]"
            },
            "sortBy": {
              "default": "Sort By",
              "description": "Current sort field",
              "label": "Sort By",
              "tier": "presentation",
              "type": "string"
            },
            "sortDirection": {
              "default": "asc",
              "description": "Current sort direction",
              "label": "Sort Direction",
              "tier": "presentation",
              "type": "string",
              "values": [
                "asc",
                "desc"
              ]
            },
            "target": {
              "default": 10.0,
              "description": "The output value the player must reach (within tolerance).",
              "label": "Target",
              "tier": "domain",
              "type": "number"
            },
            "title": {
              "default": "Tune the Formula",
              "description": "Puzzle title shown above the board.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "tolerance": {
              "default": 1.0,
              "description": "Acceptable error margin around the target.",
              "label": "Tolerance",
              "tier": "domain",
              "type": "number"
            },
            "totalCount": {
              "default": 0.0,
              "description": "Total number of items",
              "label": "Total Count",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "completeEvent prop",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "success",
                  "required": true,
                  "type": "boolean"
                },
                {
                  "name": "attempts",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Sets parameter A from { value } during play.",
              "event": "SET_A",
              "payloadSchema": [
                {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Sets parameter B from { value } during play.",
              "event": "SET_B",
              "payloadSchema": [
                {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Evaluates output vs target/tolerance; wins or retries.",
              "event": "CHECK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Resets the puzzle back to the menu.",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "attempts",
              "description",
              "outputLabel",
              "paramA",
              "paramB",
              "parameters",
              "result",
              "target",
              "title",
              "tolerance"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "SimulatorBoardItem",
          "name": "SimulatorBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Sets parameter A from { value } during play.",
                "key": "SET_A",
                "name": "Set A",
                "payloadSchema": [
                  {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Sets parameter B from { value } during play.",
                "key": "SET_B",
                "name": "Set B",
                "payloadSchema": [
                  {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Evaluates output vs target/tolerance; wins or retries.",
                "key": "CHECK",
                "name": "Check",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Resets the puzzle back to the menu.",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "completeEvent prop",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "success",
                    "required": true,
                    "type": "boolean"
                  },
                  {
                    "name": "attempts",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              },
              {
                "name": "menu"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.parameters",
                    "@config.parameters"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.outputLabel",
                    "@config.outputLabel"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "START",
                "from": "menu",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.parameters",
                    "@config.parameters"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.outputLabel",
                    "@config.outputLabel"
                  ],
                  [
                    "set",
                    "@entity.target",
                    "@config.target"
                  ],
                  [
                    "set",
                    "@entity.tolerance",
                    "@config.tolerance"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "SET_A",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramB",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "SET_B",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.result",
                  "none"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.result",
                    "win"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  "<=",
                  [
                    "math/abs",
                    [
                      "-",
                      "@entity.output",
                      "@entity.target"
                    ]
                  ],
                  "@entity.tolerance"
                ],
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "CHECK",
                "from": "playing",
                "guard": [
                  ">",
                  [
                    "math/abs",
                    [
                      "-",
                      "@entity.output",
                      "@entity.target"
                    ]
                  ],
                  "@entity.tolerance"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.paramA",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.paramB",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.parameters",
                    "@config.parameters"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.outputLabel",
                    "@config.outputLabel"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.result",
                    "none"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "checkEvent": "CHECK",
                      "completeEvent": "COMPLETE",
                      "entity": "@entity",
                      "playAgainEvent": "PLAY_AGAIN",
                      "setAEvent": "SET_A",
                      "setBEvent": "SET_B",
                      "type": "simulator-board"
                    }
                  ]
                ],
                "event": "PLAY_AGAIN",
                "from": "complete",
                "to": "menu"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}