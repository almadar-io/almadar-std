          "entityRebindable": true,
          "linkedEntity": "BoardgameBoardItem",
          "name": "BoardgameBoardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Emits UI:{unitClickEvent} with { unitId } on unit click",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click",
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{endTurnEvent} with {} on end turn",
                "key": "END_TURN",
                "name": "End Turn",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{cancelEvent} with {} on cancel",
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "playing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.pieces",
                    "@config.pieces"
                  ],
                  [
                    "set",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.turn",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.currentPlayer",
                    "player"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "set",
                    "@entity.effects",
                    []
                  ],
                  [
                    "set",
                    "@entity.gridWidth",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.gridHeight",
                    4.0
                  ],
                  [
                    "set",
                    "@entity.movementRange",
                    2.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  "@entity.selectedPieceId",
                  "@payload.unitId"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedPieceId",
                    "@payload.unitId"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "movement"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "UNIT_CLICK",
                "from": "playing",
                "guard": [
                  "==",
                  [
                    "object/get",
                    [
                      "array/find",
                      "@entity.pieces",
                      [
                        "fn",
                        "u",
                        [
                          "==",
                          "@u.id",
                          "@payload.unitId"
                        ]
                      ]
                    ],
                    "team"
                  ],
                  "@entity.currentPlayer"
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.pieces",
                    [
                      "array/map",
                      "@entity.pieces",
                      [
                        "fn",
                        "u",
                        [
                          "if",
                          [
                            "==",
                            "@u.id",
                            "@entity.selectedPieceId"
                          ],
                          [
                            "object/merge",
                            "@u",
                            {
                              "animation": "walk",
                              "position": {
                                "x": "@payload.x",
                                "y": "@payload.y"
                              }
                            }
                          ],
                          "@u"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "TILE_CLICK",
                "from": "playing",
                "guard": [
                  "and",
                  [
                    "!=",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "and",
                    [
                      "grid/in-bounds",
                      {
                        "x": "@payload.x",
                        "y": "@payload.y"
                      },
                      "@entity.gridWidth",
                      "@entity.gridHeight"
                    ],
                    [
                      "and",
                      [
                        "<=",
                        [
                          "grid/manhattan-distance",
                          [
                            "object/get",
                            [
                              "array/find",
                              "@entity.pieces",
                              [
                                "fn",
                                "u",
                                [
                                  "==",
                                  "@u.id",
                                  "@entity.selectedPieceId"
                                ]
                              ]
                            ],
                            "position"
                          ],
                          {
                            "x": "@payload.x",
                            "y": "@payload.y"
                          }
                        ],
                        "@entity.movementRange"
                      ],
                      [
                        "==",
                        [
                          "array/len",
                          [
                            "array/filter",
                            "@entity.pieces",
                            [
                              "fn",
                              "u",
                              [
                                "and",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "x"
                                  ],
                                  "@payload.x"
                                ],
                                [
                                  "==",
                                  [
                                    "object/get",
                                    [
                                      "object/get",
                                      "@u",
                                      "position"
                                    ],
                                    "y"
                                  ],
                                  "@payload.y"
                                ]
                              ]
                            ]
                          ]
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.turn",
                    [
                      "+",
                      "@entity.turn",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentPlayer",
                    [
                      "if",
                      [
                        "==",
                        "@entity.currentPlayer",
                        "player"
                      ],
                      "enemy",
                      "player"
                    ]
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "END_TURN",
                "from": "playing",
                "to": "playing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.selectedPieceId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "observation"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "assetManifest": "@config.assetManifest",
                          "effects": "@entity.effects",
                          "features": "@config.features",
                          "projection": "flat",
                          "scale": "@config.scale",
                          "showMinimap": false,
                          "tiles": "@config.tiles",
                          "type": "canvas-2d",
                          "units": "@entity.pieces"
                        }
                      ],
                      "hud": {
                        "stats": [
                          {
                            "label": "Turn",
                            "value": "@entity.turn"
                          },
                          {
                            "label": "Player",
                            "value": "@entity.currentPlayer"
                          }
                        ],
                        "type": "game-hud"
                      },
                      "type": "game-shell"
                    }
                  ]
                ],
                "event": "CANCEL",
                "from": "playing",
                "guard": [
                  "!=",
                  "@entity.selectedPieceId",
                  ""
                ],
                "to": "playing"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.pieces",
                  [
                    "array/map",
                    "@entity.pieces",
                    [
                      "fn",
                      "u",
                      [
                        "object/merge",
                        "@u",
                        {
                          "frame": [
                            "%",
                            [
                              "+",
                              [
                                "object/get",
                                "@u",
                                "frame"
                              ],
                              1.0
                            ],
                            8.0
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.effects",
                  [
                    "array/filter",
                    [
                      "array/map",
                      "@entity.effects",
                      [
                        "fn",
                        "e",
                        [
                          "object/merge",
                          "@e",
                          {
                            "ttl": [
                              "-",
                              [
                                "object/get",
                                "@e",
                                "ttl"
                              ],
                              1.0
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "e",
                      [
                        ">",
                        [
                          "object/get",
                          "@e",
                          "ttl"
                        ],
                        0.0
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@config.features",
                        "projection": "flat",
                        "scale": "@config.scale",
                        "showMinimap": false,
                        "tiles": "@config.tiles",
                        "type": "canvas-2d",
                        "units": "@entity.pieces"
                      }
                    ],
                    "hud": {
                      "stats": [
                        {
                          "label": "Turn",
                          "value": "@entity.turn"
                        },
                        {
                          "label": "Player",
                          "value": "@entity.currentPlayer"
                        }
                      ],
                      "type": "game-hud"
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "interval": 100.0,
              "name": "animTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}