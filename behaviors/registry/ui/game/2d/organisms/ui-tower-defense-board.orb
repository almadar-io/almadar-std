          "emits": [
            {
              "description": "Emits UI:{placeTowerEvent} with {x,y} on tile click when player places a tower",
              "event": "PLACE_TOWER",
              "payloadSchema": [
                {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{startWaveEvent} with {wave} when player launches a creep wave",
              "event": "START_WAVE",
              "payloadSchema": [
                {
                  "name": "wave",
                  "type": "number"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost",
              "event": "GAME_END",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
              "event": "PLAY_AGAIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "tier": "domain"
            },
            {
              "description": "Emits UI:{moveHeroEvent} with {dx,dy} on arrow-key press to move the player hero",
              "event": "MOVE_HERO",
              "payloadSchema": [
                {
                  "name": "dx",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "dy",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "external",
