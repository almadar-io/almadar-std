              },
              {
                "description": "Emits UI:{startWaveEvent} with {wave} when player launches a creep wave",
                "key": "START_WAVE",
                "name": "Start Wave",
                "payloadSchema": [
                  {
                    "name": "wave",
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{moveHeroEvent} with {dx,dy} on arrow-key press to move the player hero",
                "key": "MOVE_HERO",
                "name": "Move Hero",
                "payloadSchema": [
                  {
                    "name": "dx",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "dy",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "key": "PLAY_AGAIN",
                "name": "Play Again",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "unitClickEvent prop — emitted when a creep is clicked on the canvas",
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payloadSchema": [
                  {
                    "name": "unitId",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              }
