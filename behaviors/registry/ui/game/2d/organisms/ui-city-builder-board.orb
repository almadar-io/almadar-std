                "name": "Select Build Type",
                "payloadSchema": [
                  {
                    "name": "buildType",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{placeBuildingEvent} with {x,y} on tile click when player places a building",
                "key": "PLACE_BUILDING",
                "name": "Place Building",
                "payloadSchema": [
                  {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                ],
                "tier": "domain"
              },
              {
                "description": "Emits UI:{gameEndEvent} with {result} when the city reaches its goal or collapses",
                "key": "GAME_END",
                "name": "Game End",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ],
                "tier": "domain"
              },
              {
                "key": "PLAY_AGAIN",
                "name": "Play Again"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "building"
              },
              {
                "name": "gameover"
              }
            ],
            "transitions": [
