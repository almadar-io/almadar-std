                                [
                                  "object/get",
                                  [
                                    "object/get",
                                    "@u",
                                    "position"
                                  ],
                                  "y"
                                ],
                                [
                                  "math/sign",
                                  [
                                    "-",
                                    [
                                      "math/floor",
                                      [
                                        "*",
                                        [
                                          "math/random"
                                        ],
                                        "@config.gridHeight"
                                      ]
                                    ],
                                    [
                                      "object/get",
                                      [
                                        "object/get",
                                        "@u",
                                        "position"
                                      ],
                                      "y"
                                    ]
                                  ]
                                ]
                              ],
                              0.0,
                              [
                                "-",
                                "@config.gridHeight",
                                1.0
                              ]
                            ]
                          ]
                        ],
                        [
                          "object/merge",
                          "@u",
                          {
                            "animation": "walk",
                            "position": {
                              "x": "@nx",
                              "y": "@ny"
                            }
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel-frame",
                      "role": "ui",
                      "style": "generic",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png",
                      "variant": ""
                    },
                    "children": [
                      {
                        "assetManifest": "@config.assetManifest",
                        "effects": "@entity.effects",
                        "features": "@entity.features",
                        "projection": "isometric",
                        "scale": "@config.scale",
                        "selectedUnitId": "@entity.selectedUnitId",
                        "showMinimap": true,
                        "tileClickEvent": "PLACE_BUILDING",
                        "tiles": "@config.tiles",
                        "type": "canvas-2d",
                        "unitClickEvent": "SELECT_BUILD_TYPE",
                        "units": "@entity.citizens",
                        "validMoves": "@entity.validMoves"
                      }
                    ],
                    "hud": {
                      "children": [
                        {
                          "stats": [
                            {
                              "iconUrl": {
                                "animations": [],
                                "aspect": "1:1",
                                "category": "ui",
                                "dimension": "2d",
                                "name": "icon-population",
                                "role": "ui",
                                "style": "generic",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png",
                                "variant": ""
                              },
                              "label": "Population",
                              "value": "@entity.population"
                            },
                            {
                              "iconUrl": {
                                "animations": [],
                                "aspect": "1:1",
                                "category": "ui",
                                "dimension": "2d",
                                "name": "icon-gold",
                                "role": "ui",
                                "style": "generic",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png",
                                "variant": ""
                              },
                              "label": "Gold",
                              "value": "@entity.gold"
                            },
                            {
                              "iconUrl": {
                                "animations": [],
                                "aspect": "1:1",
                                "category": "ui",
                                "dimension": "2d",
                                "name": "icon-wood",
                                "role": "ui",
                                "style": "generic",
                                "thumbnailUrl": "",
                                "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png",
                                "variant": ""
                              },
                              "label": "Wood",
                              "value": "@entity.wood"
                            },
                            {
                              "label": "Build",
                              "type": "resource-counter",
                              "value": "@entity.pendingBuildType"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "iconUrl": {
                            "animations": [],
                            "aspect": "1:1",
                            "category": "ui",
                            "dimension": "2d",
                            "name": "icon-gold",
                            "role": "ui",
                            "style": "generic",
                            "thumbnailUrl": "",
                            "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png",
                            "variant": ""
                          },
                          "label": "Gold",
                          "type": "stat-badge",
                          "value": "@entity.gold"
                        },
                        {
                          "iconUrl": {
                            "animations": [],
                            "aspect": "1:1",
                            "category": "ui",
                            "dimension": "2d",
                            "name": "icon-wood",
                            "role": "ui",
                            "style": "generic",
                            "thumbnailUrl": "",
                            "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png",
                            "variant": ""
                          },
                          "label": "Wood",
                          "type": "stat-badge",
                          "value": "@entity.wood"
                        },
                        {
                          "action": "SELECT_BUILD_TYPE",
                          "items": "@config.buildTypes",
                          "labelKey": "label",
                          "selected": "@entity.pendingBuildType",
                          "type": "control-grid",
                          "valueKey": "type"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "md",
                      "justify": "between",
                      "type": "stack"
                    },
                    "hudBackgroundAsset": {
                      "animations": [],
                      "aspect": "1:1",
                      "category": "ui",
                      "dimension": "2d",
                      "name": "panel-frame",
                      "role": "ui",
                      "style": "generic",
                      "thumbnailUrl": "",
                      "url": "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png",
                      "variant": ""
                    },
                    "type": "game-shell"
                  }
                ]
              ],
              "guard": [
                "==",
                "@entity.result",
                "none"
              ],
              "interval": 1000.0,
              "name": "resourceIncomeTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}