{
  "name": "ui-module-card",
  "version": "1.0.0",
  "description": "ModuleCard — UI factory (1:1 with the @almadar/ui module-card pattern).",
  "orbitals": [
    {
      "name": "ModuleCardOrbital",
      "entity": {
        "name": "ModuleCardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ModuleCardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ModuleCardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "data": "@config.data",
                      "type": "module-card"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "data": {
              "type": "ModuleCardData",
              "default": {
                "traits": [
                  {
                    "name": "Name",
                    "eventCount": 1.0,
                    "transitionCount": 1.0,
                    "stateCount": 1.0,
                    "emits": [
                      "Item"
                    ],
                    "listens": [
                      "Item"
                    ]
                  }
                ],
                "traitDetails": {},
                "entityName": "Entity Name",
                "persistence": "Persistence",
                "fields": [
                  {
                    "type": "Type",
                    "name": "Name",
                    "required": false,
                    "hasDefault": false
                  }
                ],
                "pages": [
                  {
                    "route": "Route",
                    "name": "Name"
                  }
                ],
                "externalLinks": [
                  {
                    "targetOrbital": "Target Orbital",
                    "eventName": "Event Name",
                    "direction": "out",
                    "traitName": "Trait Name"
                  }
                ],
                "orbitalName": "Orbital Name"
              },
              "label": "Data",
              "description": "data prop",
              "tier": "presentation",
              "properties": {
                "pages": {
                  "name": "pages",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      "route": {
                        "name": "route",
                        "type": "string",
                        "required": true
                      }
                    }
                  }
                },
                "traits": {
                  "name": "traits",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "stateCount": {
                        "name": "stateCount",
                        "type": "number",
                        "required": true
                      },
                      "emits": {
                        "name": "emits",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "string"
                        }
                      },
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      "eventCount": {
                        "name": "eventCount",
                        "type": "number",
                        "required": true
                      },
                      "transitionCount": {
                        "name": "transitionCount",
                        "type": "number",
                        "required": true
                      },
                      "listens": {
                        "name": "listens",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "persistence": {
                  "name": "persistence",
                  "type": "string",
                  "required": true
                },
                "traitDetails": {
                  "name": "traitDetails",
                  "type": "object",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "linkedEntity": {
                        "name": "linkedEntity",
                        "type": "string",
                        "required": true
                      },
                      "states": {
                        "name": "states",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "name": "name",
                              "type": "string",
                              "required": true
                            },
                            "isTerminal": {
                              "name": "isTerminal",
                              "type": "boolean",
                              "required": false
                            },
                            "isInitial": {
                              "name": "isInitial",
                              "type": "boolean",
                              "required": false
                            }
                          }
                        }
                      },
                      "transitions": {
                        "name": "transitions",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "object",
                          "properties": {
                            "event": {
                              "name": "event",
                              "type": "string",
                              "required": true
                            },
                            "to": {
                              "name": "to",
                              "type": "string",
                              "required": true
                            },
                            "guard": {
                              "name": "guard",
                              "type": "string",
                              "required": false
                            },
                            "from": {
                              "name": "from",
                              "type": "string",
                              "required": true
                            },
                            "index": {
                              "name": "index",
                              "type": "number",
                              "required": true
                            },
                            "effects": {
                              "name": "effects",
                              "type": "array",
                              "required": true,
                              "items": {
                                "type": "object",
                                "properties": {
                                  "args": {
                                    "name": "args",
                                    "type": "array",
                                    "required": true,
                                    "items": {
                                      "type": "string"
                                    }
                                  },
                                  "type": {
                                    "name": "type",
                                    "type": "string",
                                    "required": true
                                  }
                                }
                              }
                            }
                          }
                        }
                      },
                      "emittedEvents": {
                        "name": "emittedEvents",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "string"
                        }
                      },
                      "listenedEvents": {
                        "name": "listenedEvents",
                        "type": "array",
                        "required": true,
                        "items": {
                          "type": "string"
                        }
                      },
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      }
                    }
                  }
                },
                "externalLinks": {
                  "name": "externalLinks",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "traitName": {
                        "name": "traitName",
                        "type": "string",
                        "required": true
                      },
                      "targetOrbital": {
                        "name": "targetOrbital",
                        "type": "string",
                        "required": true
                      },
                      "direction": {
                        "name": "direction",
                        "type": "string",
                        "required": true,
                        "values": [
                          "out",
                          "in"
                        ]
                      },
                      "eventName": {
                        "name": "eventName",
                        "type": "string",
                        "required": true
                      }
                    }
                  }
                },
                "orbitalName": {
                  "name": "orbitalName",
                  "type": "string",
                  "required": true
                },
                "fields": {
                  "name": "fields",
                  "type": "array",
                  "required": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "required": {
                        "name": "required",
                        "type": "boolean",
                        "required": true
                      },
                      "name": {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      "type": {
                        "name": "type",
                        "type": "string",
                        "required": true
                      },
                      "hasDefault": {
                        "name": "hasDefault",
                        "type": "boolean",
                        "required": true
                      }
                    }
                  }
                },
                "entityName": {
                  "name": "entityName",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ModuleCardPage",
          "path": "/module-card",
          "traits": [
            {
              "ref": "ModuleCardRender"
            }
          ]
        }
      ]
    }
  ]
}