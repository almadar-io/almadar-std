{
  "description": "ModuleCard — UI factory (1:1 with the @almadar/ui module-card pattern).",
  "name": "ui-module-card",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ModuleCardItem",
        "persistence": "runtime"
      },
      "name": "ModuleCardOrbital",
      "pages": [
        {
          "name": "ModuleCardPage",
          "path": "/module-card",
          "traits": [
            {
              "ref": "ModuleCardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "data": {
              "default": {},
              "description": "data prop",
              "label": "Data",
              "tier": "presentation",
              "type": "json"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ModuleCardItem",
          "name": "ModuleCardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "data": "@config.data",
                      "type": "module-card"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}