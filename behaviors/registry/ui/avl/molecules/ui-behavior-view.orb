{
  "description": "BehaviorView — UI factory (1:1 with the @almadar/ui behavior-view pattern).",
  "name": "ui-behavior-view",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "BehaviorViewItem",
        "persistence": "runtime"
      },
      "name": "BehaviorViewOrbital",
      "pages": [
        {
          "name": "BehaviorViewPage",
          "path": "/behavior-view",
          "traits": [
            {
              "ref": "BehaviorViewRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "data": {
              "default": {},
              "description": "data prop",
              "label": "Data",
              "tier": "presentation",
              "type": "json"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "BehaviorViewItem",
          "name": "BehaviorViewRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "data": "@config.data",
                      "type": "behavior-view"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}