{
  "name": "ui-book-chapter-view",
  "version": "1.0.0",
  "description": "BookChapterView — UI factory (1:1 with the @almadar/ui book-chapter-view pattern).",
  "orbitals": [
    {
      "name": "BookChapterViewOrbital",
      "entity": {
        "name": "BookChapterViewItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "BookChapterViewRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "BookChapterViewItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "@config.direction",
                      "type": "book-chapter-view",
                      "chapter": "@config.chapter",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "chapter": {
              "type": "BookChapterViewChapter",
              "default": {
                "title": "",
                "content": "",
                "id": ""
              },
              "label": "Chapter",
              "description": "chapter prop",
              "tier": "presentation",
              "properties": {
                "content": {
                  "name": "content",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "orbitalSchema": {
                  "name": "orbitalSchema",
                  "type": "string",
                  "required": false
                }
              }
            },
            "direction": {
              "type": "string",
              "default": "rtl",
              "label": "Direction",
              "description": "direction prop",
              "tier": "presentation",
              "values": [
                "rtl",
                "ltr"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BookChapterViewPage",
          "path": "/book-chapter-view",
          "traits": [
            {
              "ref": "BookChapterViewRender"
            }
          ]
        }
      ]
    }
  ]
}