{
  "name": "ui-hero-organism",
  "version": "1.0.0",
  "description": "HeroOrganism — UI factory (1:1 with the @almadar/ui hero-organism pattern).",
  "orbitals": [
    {
      "name": "HeroOrganismOrbital",
      "entity": {
        "name": "HeroOrganismItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "tag",
            "type": "string",
            "default": ""
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "titleAccent",
            "type": "string",
            "default": ""
          },
          {
            "name": "subtitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "primaryAction",
            "type": "object",
            "properties": {
              "href": {
                "name": "href",
                "type": "string",
                "required": true
              },
              "label": {
                "name": "label",
                "type": "string",
                "required": true
              },
              "variant": {
                "name": "variant",
                "type": "string",
                "required": false,
                "values": [
                  "primary",
                  "secondary",
                  "ghost"
                ]
              }
            }
          },
          {
            "name": "secondaryAction",
            "type": "object",
            "properties": {
              "variant": {
                "name": "variant",
                "type": "string",
                "required": false,
                "values": [
                  "primary",
                  "secondary",
                  "ghost"
                ]
              },
              "label": {
                "name": "label",
                "type": "string",
                "required": true
              },
              "href": {
                "name": "href",
                "type": "string",
                "required": true
              }
            }
          },
          {
            "name": "installCommand",
            "type": "string",
            "default": ""
          },
          {
            "name": "image",
            "type": "object",
            "properties": {
              "alt": {
                "name": "alt",
                "type": "string",
                "required": true
              },
              "src": {
                "name": "src",
                "type": "string",
                "required": true
              }
            }
          },
          {
            "name": "imagePosition",
            "type": "string",
            "default": "below",
            "values": [
              "below",
              "right",
              "background"
            ]
          },
          {
            "name": "background",
            "type": "string",
            "default": "dark",
            "values": [
              "dark",
              "gradient",
              "subtle"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "HeroOrganismRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "HeroOrganismItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HeroOrganismItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "sortBy": "@config.sortBy",
                      "searchValue": "@config.searchValue",
                      "type": "hero-organism",
                      "isLoading": "@config.isLoading",
                      "className": "@config.className",
                      "page": "@config.pageProp",
                      "totalCount": "@config.totalCount",
                      "children": [
                        {
                          "type": "text",
                          "content": "Sample content"
                        }
                      ],
                      "sortDirection": "@config.sortDirection",
                      "error": "@config.error",
                      "selectedIds": "@config.selectedIds",
                      "entity": "@entity",
                      "pageSize": "@config.pageSize",
                      "activeFilters": "@config.activeFilters"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "pageProp": {
              "type": "number",
              "default": 0.0,
              "label": "Page",
              "description": "Current page number",
              "synonyms": "page",
              "tier": "presentation"
            },
            "sortDirection": {
              "type": "string",
              "default": "asc",
              "label": "Sort Direction",
              "description": "Current sort direction",
              "tier": "presentation",
              "values": [
                "asc",
                "desc"
              ]
            },
            "activeFilters": {
              "type": "json",
              "label": "Active Filters",
              "description": "Active filters",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes",
              "tier": "presentation"
            },
            "sortBy": {
              "type": "string",
              "default": "Sort By",
              "label": "Sort By",
              "description": "Current sort field",
              "tier": "presentation"
            },
            "searchValue": {
              "type": "string",
              "default": "Search Value",
              "label": "Search Value",
              "description": "Current search query value",
              "tier": "presentation"
            },
            "pageSize": {
              "type": "number",
              "default": 0.0,
              "label": "Page Size",
              "description": "Number of items per page",
              "tier": "presentation"
            },
            "error": {
              "type": "HeroOrganismError",
              "label": "Error",
              "description": "Error state (UiError)",
              "tier": "presentation",
              "properties": {
                "code": {
                  "name": "code",
                  "type": "string",
                  "required": false
                },
                "name": {
                  "name": "name",
                  "type": "string",
                  "required": false
                },
                "message": {
                  "name": "message",
                  "type": "string",
                  "required": true
                },
                "stack": {
                  "name": "stack",
                  "type": "string",
                  "required": false
                }
              }
            },
            "totalCount": {
              "type": "number",
              "default": 0.0,
              "label": "Total Count",
              "description": "Total number of items",
              "tier": "presentation"
            },
            "selectedIds": {
              "type": "[string]",
              "default": [],
              "label": "Selected Ids",
              "description": "Currently selected item IDs",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "isLoading": {
              "type": "boolean",
              "default": false,
              "label": "Is Loading",
              "description": "Loading state indicator",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "HeroOrganismPage",
          "path": "/hero-organism",
          "traits": [
            {
              "ref": "HeroOrganismRender"
            }
          ]
        }
      ]
    }
  ]
}