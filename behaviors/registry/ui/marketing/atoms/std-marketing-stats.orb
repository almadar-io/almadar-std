{
  "description": "Stats grid atom for marketing pages. Renders a responsive grid of key metrics with values and labels. Pick for social proof, traction, and credibility sections.",
  "name": "std-marketing-stats",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StatItem",
        "persistence": "runtime"
      },
      "name": "StatItemOrbital",
      "pages": [
        {
          "name": "StatItemStatsPage",
          "path": "/stats",
          "traits": [
            {
              "ref": "StatItemStats"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "columns": {
              "default": 4.0,
              "description": "Number of grid columns",
              "label": "Columns",
              "tier": "presentation",
              "type": "number"
            },
            "stats": {
              "default": [
                {
                  "label": "Developers",
                  "value": "10K+"
                },
                {
                  "label": "Uptime",
                  "value": "99.9%"
                },
                {
                  "label": "Requests served",
                  "value": "50M+"
                },
                {
                  "label": "Average rating",
                  "value": "4.9"
                }
              ],
              "description": "Array of stat value/label pairs",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Stats",
              "tier": "presentation",
              "type": "[StatCard]"
            }
          },
          "linkedEntity": "StatItem",
          "name": "StatItemStats",
          "ref": "StatsGrid.traits.StatsGridRender"
        }
      ],
      "uses": [
        {
          "as": "StatsGrid",
          "from": "std/behaviors/ui-stats-grid"
        }
      ]
    }
  ],
  "version": "1.0.0"
}