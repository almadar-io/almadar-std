            {
              "ref": "StepSectionItemSteps"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "orientation": {
              "default": "horizontal",
              "description": "horizontal or vertical",
              "label": "Orientation",
              "tier": "presentation",
              "type": "string"
            },
            "steps": {
              "default": [
                {
                  "description": "Describe your app in natural language.",
                  "icon": "pen-tool",
                  "id": "1",
                  "number": 1.0,
                  "title": "Design"
                },
                {
                  "description": "Almadar generates the full stack automatically.",
                  "icon": "hammer",
                  "id": "2",
                  "number": 2.0,
                  "title": "Build"
                },
                {
                  "description": "Deploy to production with one click.",
                  "icon": "rocket",
                  "id": "3",
                  "number": 3.0,
                  "title": "Ship"
                }
              ],
              "description": "Array of step items",
              "items": {
                "properties": {
                  "description": {
                    "name": "description",
                    "required": true,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "number": {
                    "name": "number",
                    "required": false,
                    "type": "number"
                  },
                  "title": {
                    "name": "title",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Steps",
              "tier": "presentation",
              "type": "[StepCard]"
            }
          },
          "linkedEntity": "StepSectionItem",
          "name": "StepSectionItemSteps",
          "ref": "StepFlowOrganism.traits.StepFlowOrganismRender"
        }
      ],
      "uses": [
        {
          "as": "StepFlowOrganism",
