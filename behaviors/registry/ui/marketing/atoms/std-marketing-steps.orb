{
  "description": "Step flow atom for marketing pages. Renders numbered steps horizontally or vertically. Pick for how-it-works sections and onboarding explainers.",
  "name": "std-marketing-steps",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "An ordered list of individual step components.",
            "items": {
              "properties": {
                "description": {
                  "name": "description",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "number": {
                  "name": "number",
                  "required": false,
                  "type": "number"
                },
                "title": {
                  "name": "title",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "steps",
            "synonyms": "items, sequence, stages",
            "type": "array"
          }
        ],
        "name": "StepSectionItem",
        "persistence": "runtime"
      },
      "name": "StepItemOrbital",
