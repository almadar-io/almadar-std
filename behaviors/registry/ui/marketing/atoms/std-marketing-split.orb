{
  "description": "Split section atom for marketing pages. Renders a two-column layout with text and image alternating sides. Pick for feature deep-dives and alternating content sections.",
  "name": "std-marketing-split",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "SplitItem",
        "persistence": "runtime"
      },
      "name": "SplitItemOrbital",
      "pages": [
        {
          "name": "SplitItemSplitPage",
          "path": "/split",
          "traits": [
            {
              "ref": "SplitItemSplit"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "background": {
              "default": "default",
              "description": "default or alt",
              "label": "Background",
              "tier": "presentation",
              "type": "string"
            },
            "bullets": {
              "default": [
                "Instant deployments",
                "Auto-scaling",
                "Global CDN"
              ],
              "description": "Feature bullet points",
              "items": {
                "type": "string"
              },
              "label": "Bullets",
              "tier": "presentation",
              "type": "[string]"
            },
            "description": {
              "default": "Everything you need to build, deploy, and scale.",
              "description": "Body text",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "image": {
              "default": {
                "alt": "@config.imageAlt",
                "src": "@config.imageSrc"
              },
              "type": "unknown"
            },
            "imageAlt": {
              "default": "",
              "label": "Image Alt Text",
              "tier": "presentation",
              "type": "string"
            },
            "imagePosition": {
              "default": "right",
              "description": "left or right",
              "label": "Image Position",
              "tier": "presentation",
              "type": "string"
            },
            "imageSrc": {
              "default": "",
              "label": "Image Source",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Powerful under the hood",
              "description": "Section headline",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "linkedEntity": "SplitItem",
          "name": "SplitItemSplit",
          "ref": "SplitSection.traits.SplitSectionRender"
        }
      ],
      "uses": [
        {
          "as": "SplitSection",
          "from": "std/behaviors/ui-split-section"
        }
      ]
    }
  ],
  "version": "1.0.0"
}