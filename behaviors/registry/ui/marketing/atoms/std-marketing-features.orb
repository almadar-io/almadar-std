  "name": "std-marketing-features",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "id": "ent_01KXG053JNX7C2CFMCSE1Y4E20",
        "name": "FeatureItem",
        "persistence": "runtime"
      },
      "id": "orb_01KXG053JNWFZB9FWX7KV1E871",
      "name": "FeatureItemOrbital",
      "pages": [
        {
          "id": "pag_01KXG053JRYEJ18DW1A71GBQNJ",
          "name": "FeatureItemFeaturesPage",
          "path": "/features",
          "traits": [
            {
              "ref": "FeatureItemFeatures",
              "refId": "trt_01KXG053JN7H86KPHSDNCM0SAC"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "columns": {
              "default": 3.0,
              "description": "Number of grid columns",
              "label": "Columns",
              "tier": "presentation",
              "type": "number"
            },
            "gap": {
              "default": "lg",
              "description": "Spacing between cards",
              "label": "Gap",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "description": "Build and deploy in minutes, not months.",
                  "href": "",
                  "icon": "zap",
                  "linkLabel": "Learn more",
                  "title": "Lightning Fast"
                },
                {
                  "description": "SOC-2 compliant with end-to-end encryption.",
                  "href": "",
                  "icon": "shield",
                  "linkLabel": "Learn more",
                  "title": "Enterprise Secure"
                },
                {
                  "description": "Plug in any service, any data source, any UI pattern.",
                  "href": "",
                  "icon": "puzzle",
                  "linkLabel": "Learn more",
                  "title": "Infinitely Extensible"
                }
              ],
              "description": "Array of feature cards",
              "items": {
                "properties": {
                  "description": {
                    "name": "description",
                    "required": true,
                    "type": "string"
                  },
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "required": false,
                    "type": "string"
                  },
                  "title": {
                    "name": "title",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Feature Items",
              "tier": "presentation",
              "type": "[FeatureCard]"
            }
          },
          "emits": [
            {
              "description": "A feature card was selected or activated.",
              "event": "FEATURE_CLICK",
              "eventId": "evt_01KXG053JR6Y8Y1F3J9C27PGW4",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "title",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "select, activate, tap, choose",
              "tier": "domain"
            }
          ],
          "id": "trt_01KXG053JN7H86KPHSDNCM0SAC",
          "linkedEntity": "FeatureItem",
          "linkedEntityId": "ent_01KXG053JNX7C2CFMCSE1Y4E20",
          "name": "FeatureItemFeatures",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "A feature card was selected or activated.",
                "key": "FEATURE_CLICK",
                "name": "Feature Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  }
                ],
                "synonyms": "select, activate, tap, choose",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "columns": "@config.columns",
                      "gap": "@config.gap",
                      "items": "@config.items",
                      "type": "feature-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "FEATURE_CLICK",
                    {
                      "id": "@payload.id",
                      "title": "@payload.title"
                    }
                  ]
                ],
                "event": "FEATURE_CLICK",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}