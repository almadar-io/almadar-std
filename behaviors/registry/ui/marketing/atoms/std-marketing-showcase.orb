          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals a user clicked on a showcase item.",
                "key": "SHOWCASE_CLICK",
                "name": "Showcase Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  }
                ],
                "synonyms": "select, tap, activate",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity.items",
                      "type": "showcase-organism"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "SHOWCASE_CLICK",
                    {
                      "id": "@payload.id",
                      "title": "@payload.title"
                    }
                  ]
                ],
                "event": "SHOWCASE_CLICK",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
