{
  "name": "ui-stats",
  "version": "1.0.0",
  "description": "Stats — UI factory (1:1 with the @almadar/ui stats pattern).",
  "orbitals": [
    {
      "name": "StatsOrbital",
      "entity": {
        "name": "StatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StatsRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StatsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "label": "@config.label",
                      "value": "@config.value",
                      "type": "stats",
                      "size": "@config.size"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            },
            "label": {
              "type": "string",
              "default": "",
              "label": "Label",
              "description": "Label describing the value",
              "tier": "presentation"
            },
            "value": {
              "type": "string",
              "default": "",
              "label": "Value",
              "description": "The stat value to display prominently",
              "tier": "presentation"
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Size of the value text",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsPage",
          "path": "/stats",
          "traits": [
            {
              "ref": "StatsRender"
            }
          ]
        }
      ]
    }
  ]
}