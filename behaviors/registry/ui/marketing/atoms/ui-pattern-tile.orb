{
  "name": "ui-pattern-tile",
  "version": "1.0.0",
  "description": "PatternTile — UI factory (1:1 with the @almadar/ui pattern-tile pattern).",
  "orbitals": [
    {
      "name": "PatternTileOrbital",
      "entity": {
        "name": "PatternTileItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PatternTileRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PatternTileItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "@config.size",
                      "strokeWidth": "@config.strokeWidth",
                      "variant": "@config.variant",
                      "type": "pattern-tile",
                      "className": "@config.className",
                      "color": "@config.color"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "variant": {
              "type": "string",
              "default": "star8",
              "label": "Variant",
              "description": "Which geometric pattern to render",
              "tier": "presentation",
              "values": [
                "star8",
                "star6",
                "khatam",
                "star10",
                "star12",
                "rosette-double",
                "rosette-filled",
                "seigaiha",
                "greek-key",
                "celtic-knot",
                "kolam",
                "arch",
                "arabesque-vine",
                "arabesque-net"
              ]
            },
            "strokeWidth": {
              "type": "number",
              "default": 0.5,
              "label": "Stroke Width",
              "description": "Line thickness",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "size": {
              "type": "number",
              "default": 60.0,
              "label": "Size",
              "description": "Tile unit size in SVG units",
              "tier": "presentation"
            },
            "color": {
              "type": "string",
              "default": "var(--color-primary)",
              "label": "Color",
              "description": "Stroke color (CSS variable or hex)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PatternTilePage",
          "path": "/pattern-tile",
          "traits": [
            {
              "ref": "PatternTileRender"
            }
          ]
        }
      ]
    }
  ]
}