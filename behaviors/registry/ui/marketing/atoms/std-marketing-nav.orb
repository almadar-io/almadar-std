        "id": "orb_01KXG053NV1N5NRKA95ZV7VTRR",
        "kind": "orbital",
        "owner": "workspace",
        "renames": []
      },
      "pag_01KXG053NW1VXJ4ZGGSXT8M144": {
        "bakedName": "NavItemNavPage",
        "curName": "NavItemNavPage",
        "id": "pag_01KXG053NW1VXJ4ZGGSXT8M144",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG053NVQ3H24F8CZFKKYRYW": {
        "bakedName": "NavItemNav",
        "curName": "NavItemNav",
        "id": "trt_01KXG053NVQ3H24F8CZFKKYRYW",
        "kind": "trait",
        "owner": "workspace",
        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "std-marketing-nav",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "id": "ent_01KXG053NVGCHS1ZF2QXTDFZF0",
        "name": "NavItem",
        "persistence": "runtime"
      },
      "id": "orb_01KXG053NV1N5NRKA95ZV7VTRR",
      "name": "NavItemOrbital",
      "pages": [
        {
          "id": "pag_01KXG053NW1VXJ4ZGGSXT8M144",
          "name": "NavItemNavPage",
          "path": "/nav",
          "traits": [
            {
              "ref": "NavItemNav",
              "refId": "trt_01KXG053NVQ3H24F8CZFKKYRYW"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "brandName": {
              "default": "Almadar",
              "label": "Brand Name",
              "tier": "presentation",
              "type": "string"
            },
            "items": {
              "default": [
                {
                  "href": "#product",
                  "label": "Product"
                },
                {
                  "href": "#pricing",
                  "label": "Pricing"
                },
                {
                  "href": "#about",
                  "label": "About"
                },
                {
                  "href": "#docs",
                  "label": "Docs"
                }
              ],
              "description": "Array of nav links",
              "items": {
                "properties": {
                  "href": {
                    "name": "href",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Navigation Items",
              "tier": "presentation",
              "type": "[NavLink]"
            },
            "logoSrc": {
              "default": "",
              "label": "Logo Source",
              "tier": "presentation",
              "type": "string"
            },
            "primaryActionHref": {
              "default": "#",
              "label": "Primary Action Link",
              "tier": "presentation",
              "type": "string"
            },
            "primaryActionLabel": {
              "default": "Get Started",
              "label": "Primary Action Label",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Indicates a navigation link was selected.",
              "event": "NAV_CLICK",
              "eventId": "evt_01KXG053NW51T77772ZD6ZXA9T",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "select, choose, activate",
              "tier": "domain"
            }
          ],
          "id": "trt_01KXG053NVQ3H24F8CZFKKYRYW",
          "linkedEntity": "NavItem",
          "linkedEntityId": "ent_01KXG053NVGCHS1ZF2QXTDFZF0",
          "name": "NavItemNav",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates a navigation link was selected.",
                "key": "NAV_CLICK",
                "name": "Nav Click",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ],
                "synonyms": "select, choose, activate",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "actions": {
                        "label": "@config.primaryActionLabel",
                        "type": "button",
                        "variant": "primary"
                      },
                      "brandName": "@config.brandName",
                      "logoSrc": "@config.logoSrc",
                      "navigationItems": "@config.items",
                      "type": "header"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "NAV_CLICK",
                    {
                      "href": "@payload.href",
                      "label": "@payload.label"
                    }
                  ]
                ],
                "event": "NAV_CLICK",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}