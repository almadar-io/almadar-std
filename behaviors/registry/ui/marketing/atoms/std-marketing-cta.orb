  "name": "std-marketing-cta",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "id": "ent_01KXG053HK9YA5XR9XWM2BD0YK",
        "name": "CTAItem",
        "persistence": "runtime"
      },
      "id": "orb_01KXG053HKYX7Z1BTT41MQEF3Z",
      "name": "CTAItemOrbital",
      "pages": [
        {
          "id": "pag_01KXG053HNZR2TYQVMZR1833SY",
          "name": "CTAItemCTAPage",
          "path": "/cta",
          "traits": [
            {
              "ref": "CTAItemCTA",
              "refId": "trt_01KXG053HKK35A9NMXCPPNE3NS"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "align": {
              "default": "center",
              "description": "center or left",
              "label": "Alignment",
              "tier": "presentation",
              "type": "string"
            },
            "background": {
              "default": "primary",
              "description": "default, alt, dark, gradient, or primary",
              "label": "Background",
              "tier": "presentation",
              "type": "string"
            },
            "primaryActionHref": {
              "default": "#",
              "label": "Primary Action Link",
              "tier": "presentation",
              "type": "string"
            },
            "primaryActionLabel": {
              "default": "Get Started",
              "label": "Primary Action Label",
              "tier": "presentation",
              "type": "string"
            },
            "secondaryActionHref": {
              "default": "",
              "label": "Secondary Action Link",
              "tier": "presentation",
              "type": "string"
            },
            "secondaryActionLabel": {
              "default": "Learn More",
              "label": "Secondary Action Label",
              "tier": "presentation",
              "type": "string"
            },
            "subtitle": {
              "default": "Join thousands of teams shipping faster.",
              "description": "Supporting text below the title",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Ready to get started?",
              "description": "Banner headline",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Signals the primary call-to-action has been triggered.",
              "event": "CTA_PRIMARY",
              "eventId": "evt_01KXG053HNX7KWNC6G4E3RH0PJ",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "click, select, submit, activate",
              "tier": "domain"
            },
            {
              "description": "Signals a secondary call to action was triggered.",
              "event": "CTA_SECONDARY",
              "eventId": "evt_01KXG053HNS3EYQ4TARA7Z6KPR",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "secondary action, alternate button, second click",
              "tier": "domain"
            }
          ],
          "id": "trt_01KXG053HKK35A9NMXCPPNE3NS",
          "linkedEntity": "CTAItem",
          "linkedEntityId": "ent_01KXG053HK9YA5XR9XWM2BD0YK",
          "name": "CTAItemCTA",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG053HKHXC8YDWH1Y4DE4YM",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals the primary call-to-action has been triggered.",
                "id": "evt_01KXG053HNX7KWNC6G4E3RH0PJ",
                "key": "CTA_PRIMARY",
                "name": "Cta Primary",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  }
                ],
                "synonyms": "click, select, submit, activate",
                "tier": "domain"
              },
              {
                "description": "Signals a secondary call to action was triggered.",
                "id": "evt_01KXG053HNS3EYQ4TARA7Z6KPR",
                "key": "CTA_SECONDARY",
                "name": "Cta Secondary",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  }
                ],
                "synonyms": "secondary action, alternate button, second click",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "@config.align",
                      "background": "@config.background",
                      "primaryAction": {
                        "href": "@config.primaryActionHref",
                        "label": "@config.primaryActionLabel"
                      },
                      "secondaryAction": {
                        "href": "@config.secondaryActionHref",
                        "label": "@config.secondaryActionLabel"
                      },
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "type": "cta-banner"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG053HKHXC8YDWH1Y4DE4YM",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "CTA_PRIMARY",
                    {
                      "href": "@config.primaryActionHref"
                    }
                  ]
                ],
                "event": "CTA_PRIMARY",
                "eventId": "evt_01KXG053HNX7KWNC6G4E3RH0PJ",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "CTA_SECONDARY",
                    {
                      "href": "@config.secondaryActionHref"
                    }
                  ]
                ],
                "event": "CTA_SECONDARY",
                "eventId": "evt_01KXG053HNS3EYQ4TARA7Z6KPR",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}