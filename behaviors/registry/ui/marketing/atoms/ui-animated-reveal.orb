{
  "name": "ui-animated-reveal",
  "version": "1.0.0",
  "description": "AnimatedReveal — UI factory (1:1 with the @almadar/ui animated-reveal pattern).",
  "orbitals": [
    {
      "name": "AnimatedRevealOrbital",
      "entity": {
        "name": "AnimatedRevealItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AnimatedRevealRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "AnimatedRevealItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "duration": "@config.duration",
                      "once": "@config.once",
                      "delay": "@config.delay",
                      "easing": "@config.easing",
                      "threshold": "@config.threshold",
                      "trigger": "@config.trigger",
                      "className": "@config.className",
                      "animate": "@config.animate",
                      "type": "animated-reveal",
                      "children": [
                        {
                          "type": "text",
                          "content": "Sample content"
                        }
                      ],
                      "animation": "@config.animation"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "animate": {
              "type": "boolean",
              "default": false,
              "label": "Animate",
              "description": "Manual control: when trigger='manual', set this to true to animate",
              "tier": "presentation"
            },
            "threshold": {
              "type": "number",
              "default": 0.15,
              "label": "Threshold",
              "description": "How much of the element must be visible before triggering, 0-1 (default: 0.15)",
              "tier": "presentation"
            },
            "easing": {
              "type": "string",
              "default": "cubic-bezier(0.16, 1, 0.3, 1)",
              "label": "Easing",
              "description": "Easing function (default: cubic-bezier(0.16, 1, 0.3, 1))",
              "tier": "presentation"
            },
            "delay": {
              "type": "number",
              "default": 0.0,
              "label": "Delay",
              "description": "Delay before animation starts in ms (default: 0)",
              "tier": "presentation"
            },
            "once": {
              "type": "boolean",
              "default": true,
              "label": "Once",
              "description": "Animate only the first time the element enters the viewport (default: true)",
              "tier": "presentation"
            },
            "animation": {
              "type": "string",
              "default": "fade-up",
              "label": "Animation",
              "description": "Built-in animation preset",
              "tier": "presentation",
              "values": [
                "fade-up",
                "fade-down",
                "fade-in",
                "fade-left",
                "fade-right",
                "scale",
                "scale-up",
                "none"
              ]
            },
            "duration": {
              "type": "number",
              "default": 600.0,
              "label": "Duration",
              "description": "Animation duration in ms (default: 600)",
              "tier": "presentation"
            },
            "trigger": {
              "type": "string",
              "default": "scroll",
              "label": "Trigger",
              "description": "What triggers the animation",
              "tier": "presentation",
              "values": [
                "scroll",
                "hover",
                "manual"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional CSS classes applied to the root element.",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AnimatedRevealPage",
          "path": "/animated-reveal",
          "traits": [
            {
              "ref": "AnimatedRevealRender"
            }
          ]
        }
      ]
    }
  ]
}