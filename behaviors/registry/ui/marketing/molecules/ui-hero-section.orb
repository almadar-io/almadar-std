{
  "name": "ui-hero-section",
  "version": "1.0.0",
  "description": "HeroSection — UI factory (1:1 with the @almadar/ui hero-section pattern).",
  "orbitals": [
    {
      "name": "HeroSectionOrbital",
      "entity": {
        "name": "HeroSectionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "HeroSectionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "HeroSectionItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "primaryAction": "@config.primaryAction",
                      "tag": "@config.tag",
                      "imagePosition": "@config.imagePosition",
                      "subtitle": "@config.subtitle",
                      "installCommand": "@config.installCommand",
                      "title": "@config.title",
                      "tagVariant": "@config.tagVariant",
                      "align": "@config.align",
                      "className": "@config.className",
                      "image": "@config.image",
                      "backgroundElement": "@config.backgroundElement",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sample content"
                        }
                      ],
                      "secondaryAction": "@config.secondaryAction",
                      "background": "@config.background",
                      "titleAccent": "@config.titleAccent",
                      "type": "hero-section"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "align": {
              "type": "string",
              "default": "center",
              "label": "Align",
              "description": "align prop",
              "tier": "presentation",
              "values": [
                "center",
                "left"
              ]
            },
            "backgroundElement": {
              "type": "node",
              "label": "Background Element",
              "description": "Background element (SVG animation, etc.) rendered behind hero content",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "tag": {
              "type": "string",
              "default": "Tag",
              "label": "Tag",
              "description": "tag prop",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "title prop",
              "tier": "presentation"
            },
            "tagVariant": {
              "type": "string",
              "default": "primary",
              "label": "Tag Variant",
              "description": "tagVariant prop",
              "tier": "presentation",
              "values": [
                "primary",
                "secondary",
                "accent"
              ]
            },
            "titleAccent": {
              "type": "string",
              "default": "Title Accent",
              "label": "Title Accent",
              "description": "titleAccent prop",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "Subtitle",
              "label": "Subtitle",
              "description": "subtitle prop",
              "tier": "presentation"
            },
            "primaryAction": {
              "type": "HeroSectionPrimaryAction",
              "default": {
                "label": "Label",
                "href": "Href"
              },
              "label": "Primary Action",
              "description": "primaryAction prop",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                }
              }
            },
            "secondaryAction": {
              "type": "HeroSectionSecondaryAction",
              "default": {
                "href": "Href",
                "label": "Label"
              },
              "label": "Secondary Action",
              "description": "secondaryAction prop",
              "tier": "presentation",
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            },
            "background": {
              "type": "string",
              "default": "subtle",
              "label": "Background",
              "description": "background prop",
              "tier": "presentation",
              "values": [
                "dark",
                "gradient",
                "subtle"
              ]
            },
            "installCommand": {
              "type": "string",
              "default": "Install Command",
              "label": "Install Command",
              "description": "installCommand prop",
              "tier": "presentation"
            },
            "image": {
              "type": "HeroSectionImage",
              "default": {
                "alt": "Alt",
                "src": "Src"
              },
              "label": "Image",
              "description": "image prop",
              "tier": "presentation",
              "properties": {
                "src": {
                  "name": "src",
                  "type": "string",
                  "required": true
                },
                "alt": {
                  "name": "alt",
                  "type": "string",
                  "required": true
                }
              }
            },
            "imagePosition": {
              "type": "string",
              "default": "below",
              "label": "Image Position",
              "description": "imagePosition prop",
              "tier": "presentation",
              "values": [
                "below",
                "right",
                "background"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "HeroSectionPage",
          "path": "/hero-section",
          "traits": [
            {
              "ref": "HeroSectionRender"
            }
          ]
        }
      ]
    }
  ]
}