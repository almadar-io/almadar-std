{
  "description": "TagCloud — UI factory (1:1 with the @almadar/ui tag-cloud pattern).",
  "name": "ui-tag-cloud",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TagCloudItem",
        "persistence": "runtime"
      },
      "name": "TagCloudOrbital",
      "pages": [
        {
          "name": "TagCloudPage",
          "path": "/tag-cloud",
          "traits": [
            {
              "ref": "TagCloudRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "tags": {
              "default": [
                {
                  "href": "Href",
                  "label": "Label",
                  "variant": "Variant"
                }
              ],
              "description": "tags prop",
              "items": {
                "properties": {
                  "href": {
                    "name": "href",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Tags",
              "tier": "presentation",
              "type": "[TagCloudTagsItem]"
            },
            "variant": {
              "default": "default",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "default",
                "primary",
                "accent"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "TagCloudItem",
          "name": "TagCloudRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "tags": "@config.tags",
                      "type": "tag-cloud",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}