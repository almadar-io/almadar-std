{
  "description": "ArticleSection — UI factory (1:1 with the @almadar/ui article-section pattern).",
  "name": "ui-article-section",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ArticleSectionItem",
        "persistence": "runtime"
      },
      "name": "ArticleSectionOrbital",
      "pages": [
        {
          "name": "ArticleSectionPage",
          "path": "/article-section",
          "traits": [
            {
              "ref": "ArticleSectionRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": [
                {
                  "content": "Sample content",
                  "type": "typography"
                }
              ],
              "description": "Section content",
              "label": "Children",
              "tier": "presentation",
              "type": "node"
            },
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "maxWidth": {
              "default": "md",
              "description": "Maximum width constraint",
              "label": "Max Width",
              "tier": "presentation",
              "type": "string",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "title": {
              "default": "Title",
              "description": "Section title",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ArticleSectionItem",
          "name": "ArticleSectionRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "maxWidth": "@config.maxWidth",
                      "title": "@config.title",
                      "type": "article-section"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}