{
  "name": "ui-split-section",
  "version": "1.0.0",
  "description": "SplitSection — UI factory (1:1 with the @almadar/ui split-section pattern).",
  "orbitals": [
    {
      "name": "SplitSectionOrbital",
      "entity": {
        "name": "SplitSectionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SplitSectionRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "SplitSectionItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sample content",
                          "type": "text"
                        }
                      ],
                      "bullets": "@config.bullets",
                      "description": "@config.description",
                      "title": "@config.title",
                      "image": "@config.image",
                      "type": "split-section",
                      "imagePosition": "@config.imagePosition",
                      "background": "@config.background",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "bullets": {
              "type": "[string]",
              "default": [],
              "label": "Bullets",
              "description": "bullets prop",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "imagePosition": {
              "type": "string",
              "default": "right",
              "label": "Image Position",
              "description": "imagePosition prop",
              "tier": "presentation",
              "values": [
                "left",
                "right"
              ]
            },
            "background": {
              "type": "string",
              "default": "default",
              "label": "Background",
              "description": "background prop",
              "tier": "presentation",
              "values": [
                "default",
                "alt"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "title prop",
              "tier": "presentation"
            },
            "description": {
              "type": "node",
              "label": "Description",
              "description": "description prop",
              "tier": "presentation"
            },
            "image": {
              "type": "SplitSectionImage",
              "label": "Image",
              "description": "image prop",
              "tier": "presentation",
              "properties": {
                "src": {
                  "name": "src",
                  "type": "string",
                  "required": true
                },
                "alt": {
                  "name": "alt",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SplitSectionPage",
          "path": "/split-section",
          "traits": [
            {
              "ref": "SplitSectionRender"
            }
          ]
        }
      ]
    }
  ]
}