{
  "name": "ui-case-study-card",
  "version": "1.0.0",
  "description": "CaseStudyCard — UI factory (1:1 with the @almadar/ui case-study-card pattern).",
  "orbitals": [
    {
      "name": "CaseStudyCardOrbital",
      "entity": {
        "name": "CaseStudyCardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CaseStudyCardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CaseStudyCardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "categoryColor": "@config.categoryColor",
                      "className": "@config.className",
                      "href": "@config.href",
                      "description": "@config.description",
                      "linkLabel": "@config.linkLabel",
                      "title": "@config.title",
                      "category": "@config.category",
                      "type": "case-study-card"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "category": {
              "type": "string",
              "default": "Category",
              "label": "Category",
              "description": "Category label shown as a badge",
              "tier": "presentation"
            },
            "categoryColor": {
              "type": "string",
              "default": "Category Color",
              "label": "Category Color",
              "description": "Custom background color for the category badge (CSS value)",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            },
            "description": {
              "type": "string",
              "default": "Description",
              "label": "Description",
              "description": "Short description of the case study",
              "tier": "presentation"
            },
            "href": {
              "type": "string",
              "default": "Href",
              "label": "Href",
              "description": "URL the card links to",
              "tier": "presentation"
            },
            "linkLabel": {
              "type": "string",
              "default": "Read more",
              "label": "Link Label",
              "description": "Label for the link button",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Case study title",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CaseStudyCardPage",
          "path": "/case-study-card",
          "traits": [
            {
              "ref": "CaseStudyCardRender"
            }
          ]
        }
      ]
    }
  ]
}