{
  "description": "MarketingFooter — UI factory (1:1 with the @almadar/ui marketing-footer pattern).",
  "name": "ui-marketing-footer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MarketingFooterItem",
        "persistence": "runtime"
      },
      "name": "MarketingFooterOrbital",
      "pages": [
        {
          "name": "MarketingFooterPage",
          "path": "/marketing-footer",
          "traits": [
            {
              "ref": "MarketingFooterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "columns": {
              "default": [
                {
                  "items": [
                    {
                      "href": "Href",
                      "label": "Label"
                    },
                    {
                      "href": "Href 2",
                      "label": "Label 2"
                    }
                  ],
                  "title": "Title"
                },
                {
                  "items": [
                    {
                      "href": "Href",
                      "label": "Label"
                    },
                    {
                      "href": "Href 2",
                      "label": "Label 2"
                    }
                  ],
                  "title": "Title 2"
                }
              ],
              "description": "columns prop",
              "items": {
                "properties": {
                  "items": {
                    "items": {
                      "properties": {
                        "href": {
                          "name": "href",
                          "required": true,
                          "type": "string"
                        },
                        "label": {
                          "name": "label",
                          "required": true,
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "name": "items",
                    "required": true,
                    "type": "array"
                  },
                  "title": {
                    "name": "title",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Columns",
              "tier": "presentation",
              "type": "[MarketingFooterColumnsItem]"
            },
            "copyright": {
              "default": "Copyright",
              "description": "copyright prop",
              "label": "Copyright",
              "tier": "presentation",
              "type": "string"
            },
            "logo": {
              "default": {
                "alt": "Alt",
                "href": "Href",
                "src": "https://almadar-kflow-assets.web.app/shared/units/citizens/archetypes/00_base_model.png"
              },
              "description": "logo prop",
              "label": "Logo",
              "properties": {
                "alt": {
                  "name": "alt",
                  "required": true,
                  "type": "string"
                },
                "href": {
                  "name": "href",
                  "required": false,
                  "type": "string"
                },
                "src": {
                  "name": "src",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "MarketingFooterLogo"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MarketingFooterItem",
          "name": "MarketingFooterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "copyright": "@config.copyright",
                      "logo": "@config.logo",
                      "type": "marketing-footer"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}