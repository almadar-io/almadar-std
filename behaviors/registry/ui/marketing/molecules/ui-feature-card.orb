{
  "name": "ui-feature-card",
  "version": "1.0.0",
  "description": "FeatureCard — UI factory (1:1 with the @almadar/ui feature-card pattern).",
  "orbitals": [
    {
      "name": "FeatureCardOrbital",
      "entity": {
        "name": "FeatureCardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "FeatureCardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "FeatureCardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "@config.size",
                      "linkLabel": "@config.linkLabel",
                      "type": "feature-card",
                      "variant": "@config.variant",
                      "description": "@config.description",
                      "title": "@config.title",
                      "icon": "@config.icon",
                      "href": "@config.href",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "",
              "label": "Title",
              "description": "Feature title",
              "tier": "presentation"
            },
            "variant": {
              "type": "string",
              "default": "bordered",
              "label": "Variant",
              "description": "Card visual variant",
              "tier": "presentation",
              "values": [
                "default",
                "bordered",
                "elevated",
                "interactive"
              ]
            },
            "size": {
              "type": "string",
              "default": "md",
              "label": "Size",
              "description": "Card size affecting icon and spacing",
              "tier": "presentation",
              "values": [
                "sm",
                "md",
                "lg"
              ]
            },
            "description": {
              "type": "string",
              "default": "",
              "label": "Description",
              "description": "Feature description",
              "tier": "presentation"
            },
            "icon": {
              "type": "string",
              "default": "circle",
              "label": "Icon",
              "description": "Icon name (Lucide string) or ReactNode",
              "tier": "presentation"
            },
            "href": {
              "type": "string",
              "default": "",
              "label": "Href",
              "description": "Optional link URL",
              "tier": "presentation"
            },
            "linkLabel": {
              "type": "string",
              "default": "Learn more",
              "label": "Link Label",
              "description": "Label for the link button",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FeatureCardPage",
          "path": "/feature-card",
          "traits": [
            {
              "ref": "FeatureCardRender"
            }
          ]
        }
      ]
    }
  ]
}