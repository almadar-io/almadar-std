{
  "name": "ui-pricing-grid",
  "version": "1.0.0",
  "description": "PricingGrid — UI factory (1:1 with the @almadar/ui pricing-grid pattern).",
  "orbitals": [
    {
      "name": "PricingGridOrbital",
      "entity": {
        "name": "PricingGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PricingGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PricingGridItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "plans": "@config.plans",
                      "className": "@config.className",
                      "type": "pricing-grid"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "plans": {
              "type": "[PricingGridPlansItem]",
              "default": [
                {
                  "badge": "Badge",
                  "highlighted": false,
                  "features": [
                    "Item"
                  ],
                  "description": "Description",
                  "price": "Price",
                  "action": {
                    "label": "Label",
                    "href": "Href"
                  },
                  "className": "Class Name",
                  "name": "Name"
                }
              ],
              "label": "Plans",
              "description": "plans prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "highlighted": {
                    "name": "highlighted",
                    "type": "boolean",
                    "required": false
                  },
                  "className": {
                    "name": "className",
                    "type": "string",
                    "required": false
                  },
                  "features": {
                    "name": "features",
                    "type": "array",
                    "required": true,
                    "items": {
                      "type": "string"
                    }
                  },
                  "action": {
                    "name": "action",
                    "type": "object",
                    "required": true,
                    "properties": {
                      "href": {
                        "name": "href",
                        "type": "string",
                        "required": true
                      },
                      "label": {
                        "name": "label",
                        "type": "string",
                        "required": true
                      }
                    }
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "price": {
                    "name": "price",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PricingGridPage",
          "path": "/pricing-grid",
          "traits": [
            {
              "ref": "PricingGridRender"
            }
          ]
        }
      ]
    }
  ]
}