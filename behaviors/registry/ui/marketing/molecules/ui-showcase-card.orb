{
  "description": "ShowcaseCard — UI factory (1:1 with the @almadar/ui showcase-card pattern).",
  "name": "ui-showcase-card",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ShowcaseCardItem",
        "persistence": "runtime"
      },
      "name": "ShowcaseCardOrbital",
      "pages": [
        {
          "name": "ShowcaseCardPage",
          "path": "/showcase-card",
          "traits": [
            {
              "ref": "ShowcaseCardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "accentColor": {
              "default": "Accent Color",
              "description": "accentColor prop",
              "label": "Accent Color",
              "tier": "presentation",
              "type": "string"
            },
            "badge": {
              "default": "Badge",
              "description": "badge prop",
              "label": "Badge",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Description",
              "description": "description prop",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "href": {
              "default": "Href",
              "description": "href prop",
              "label": "Href",
              "tier": "presentation",
              "type": "string"
            },
            "image": {
              "default": {
                "alt": "Alt",
                "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
              },
              "description": "image prop",
              "label": "Image",
              "properties": {
                "alt": {
                  "name": "alt",
                  "required": true,
                  "type": "string"
                },
                "src": {
                  "name": "src",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "ShowcaseCardImage"
            },
            "title": {
              "default": "Title",
              "description": "title prop",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ShowcaseCardItem",
          "name": "ShowcaseCardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "accentColor": "@config.accentColor",
                      "badge": "@config.badge",
                      "className": "@config.className",
                      "description": "@config.description",
                      "href": "@config.href",
                      "image": "@config.image",
                      "title": "@config.title",
                      "type": "showcase-card"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}