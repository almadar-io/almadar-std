{
  "description": "PullQuote — UI factory (1:1 with the @almadar/ui pull-quote pattern).",
  "name": "ui-pull-quote",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PullQuoteItem",
        "persistence": "runtime"
      },
      "name": "PullQuoteOrbital",
      "pages": [
        {
          "name": "PullQuotePage",
          "path": "/pull-quote",
          "traits": [
            {
              "ref": "PullQuoteRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "children": {
              "default": "Sample content",
              "description": "The quote text",
              "label": "Children",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PullQuoteItem",
          "name": "PullQuoteRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": "@config.children",
                      "className": "@config.className",
                      "type": "pull-quote"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}