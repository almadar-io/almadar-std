{
  "description": "InstallBox — UI factory (1:1 with the @almadar/ui install-box pattern).",
  "name": "ui-install-box",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "InstallBoxItem",
        "persistence": "runtime"
      },
      "name": "InstallBoxOrbital",
      "pages": [
        {
          "name": "InstallBoxPage",
          "path": "/install-box",
          "traits": [
            {
              "ref": "InstallBoxRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "command": {
              "default": "Command",
              "description": "The command to display and copy",
              "label": "Command",
              "tier": "presentation",
              "type": "string"
            },
            "label": {
              "default": "Label",
              "description": "Optional label above the command",
              "label": "Label",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "InstallBoxItem",
          "name": "InstallBoxRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "command": "@config.command",
                      "label": "@config.label",
                      "type": "install-box"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}