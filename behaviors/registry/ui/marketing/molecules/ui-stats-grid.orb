{
  "name": "ui-stats-grid",
  "version": "1.0.0",
  "description": "StatsGrid — UI factory (1:1 with the @almadar/ui stats-grid pattern).",
  "orbitals": [
    {
      "name": "StatsGridOrbital",
      "entity": {
        "name": "StatsGridItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StatsGridRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StatsGridItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": "@config.stats",
                      "columns": "@config.columns",
                      "type": "stats-grid",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "columns": {
              "type": "number",
              "default": 3.0,
              "label": "Columns",
              "description": "columns prop",
              "tier": "presentation"
            },
            "stats": {
              "type": "[StatsGridStatsItem]",
              "default": [],
              "label": "Stats",
              "description": "stats prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsGridPage",
          "path": "/stats-grid",
          "traits": [
            {
              "ref": "StatsGridRender"
            }
          ]
        }
      ]
    }
  ]
}