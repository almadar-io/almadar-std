{
  "description": "StatsGrid — UI factory (1:1 with the @almadar/ui stats-grid pattern).",
  "name": "ui-stats-grid",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "StatsGridItem",
        "persistence": "runtime"
      },
      "name": "StatsGridOrbital",
      "pages": [
        {
          "name": "StatsGridPage",
          "path": "/stats-grid",
          "traits": [
            {
              "ref": "StatsGridRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "columns": {
              "default": 3.0,
              "description": "columns prop",
              "label": "Columns",
              "tier": "presentation",
              "type": "number"
            },
            "stats": {
              "default": [
                {
                  "label": "Label",
                  "value": "Value"
                },
                {
                  "label": "Label 2",
                  "value": "Value 2"
                }
              ],
              "description": "stats prop",
              "items": {
                "properties": {
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Stats",
              "tier": "presentation",
              "type": "[StatsGridStatsItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "StatsGridItem",
          "name": "StatsGridRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "columns": "@config.columns",
                      "stats": "@config.stats",
                      "type": "stats-grid"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}