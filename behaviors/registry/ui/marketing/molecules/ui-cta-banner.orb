{
  "name": "ui-cta-banner",
  "version": "1.0.0",
  "description": "CtaBanner — UI factory (1:1 with the @almadar/ui cta-banner pattern).",
  "orbitals": [
    {
      "name": "CtaBannerOrbital",
      "entity": {
        "name": "CtaBannerItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CtaBannerRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CtaBannerItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "@config.align",
                      "className": "@config.className",
                      "secondaryAction": "@config.secondaryAction",
                      "type": "cta-banner",
                      "background": "@config.background",
                      "primaryAction": "@config.primaryAction",
                      "title": "@config.title",
                      "subtitle": "@config.subtitle"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "background": {
              "type": "string",
              "default": "alt",
              "label": "Background",
              "description": "Background style",
              "tier": "presentation",
              "values": [
                "default",
                "alt",
                "dark",
                "gradient",
                "primary"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            },
            "primaryAction": {
              "type": "CtaBannerPrimaryAction",
              "label": "Primary Action",
              "description": "Primary action button config",
              "tier": "presentation",
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            },
            "subtitle": {
              "type": "string",
              "default": "Subtitle",
              "label": "Subtitle",
              "description": "Supporting text below the title",
              "tier": "presentation"
            },
            "align": {
              "type": "string",
              "default": "center",
              "label": "Align",
              "description": "Content alignment",
              "tier": "presentation",
              "values": [
                "center",
                "left"
              ]
            },
            "title": {
              "type": "string",
              "default": "Title",
              "label": "Title",
              "description": "Banner headline",
              "tier": "presentation"
            },
            "secondaryAction": {
              "type": "CtaBannerSecondaryAction",
              "label": "Secondary Action",
              "description": "Secondary action button config",
              "tier": "presentation",
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CtaBannerPage",
          "path": "/cta-banner",
          "traits": [
            {
              "ref": "CtaBannerRender"
            }
          ]
        }
      ]
    }
  ]
}