{
  "name": "ui-team-card",
  "version": "1.0.0",
  "description": "TeamCard — UI factory (1:1 with the @almadar/ui team-card pattern).",
  "orbitals": [
    {
      "name": "TeamCardOrbital",
      "entity": {
        "name": "TeamCardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TeamCardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "TeamCardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "name": "@config.name",
                      "avatar": "@config.avatar",
                      "role": "@config.role",
                      "bio": "@config.bio",
                      "className": "@config.className",
                      "type": "team-card",
                      "nameAr": "@config.nameAr"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "role": {
              "type": "string",
              "default": "Role",
              "label": "Role",
              "description": "role prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "name": {
              "type": "string",
              "default": "Name",
              "label": "Name",
              "description": "name prop",
              "tier": "presentation"
            },
            "avatar": {
              "type": "TeamCardAvatar",
              "label": "Avatar",
              "description": "avatar prop",
              "tier": "presentation",
              "properties": {
                "initials": {
                  "name": "initials",
                  "type": "string",
                  "required": true
                }
              }
            },
            "bio": {
              "type": "string",
              "default": "Bio",
              "label": "Bio",
              "description": "bio prop",
              "tier": "presentation"
            },
            "nameAr": {
              "type": "string",
              "default": "Name Ar",
              "label": "Name Ar",
              "description": "nameAr prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TeamCardPage",
          "path": "/team-card",
          "traits": [
            {
              "ref": "TeamCardRender"
            }
          ]
        }
      ]
    }
  ]
}