{
  "name": "ui-step-flow",
  "version": "1.0.0",
  "description": "StepFlow — UI factory (1:1 with the @almadar/ui step-flow pattern).",
  "orbitals": [
    {
      "name": "StepFlowOrbital",
      "entity": {
        "name": "StepFlowItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StepFlowRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "StepFlowItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "step-flow",
                      "steps": "@config.steps",
                      "showConnectors": "@config.showConnectors",
                      "className": "@config.className",
                      "orientation": "@config.orientation"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showConnectors": {
              "type": "boolean",
              "default": true,
              "label": "Show Connectors",
              "description": "showConnectors prop",
              "tier": "presentation"
            },
            "steps": {
              "type": "[StepFlowStepsItem]",
              "default": [
                {
                  "number": 1.0,
                  "title": "Title",
                  "icon": "circle",
                  "description": "Description"
                }
              ],
              "label": "Steps",
              "description": "steps prop",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "number": {
                    "name": "number",
                    "type": "number",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "orientation prop",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StepFlowPage",
          "path": "/step-flow",
          "traits": [
            {
              "ref": "StepFlowRender"
            }
          ]
        }
      ]
    }
  ]
}