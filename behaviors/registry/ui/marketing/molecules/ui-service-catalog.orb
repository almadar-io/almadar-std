{
  "name": "ui-service-catalog",
  "version": "1.0.0",
  "description": "ServiceCatalog — UI factory (1:1 with the @almadar/ui service-catalog pattern).",
  "orbitals": [
    {
      "name": "ServiceCatalogOrbital",
      "entity": {
        "name": "ServiceCatalogItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCatalogRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "ServiceCatalogItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "services": "@config.services",
                      "className": "@config.className",
                      "type": "service-catalog"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "services": {
              "type": "[ServiceCatalogServicesItem]",
              "default": [],
              "label": "Services",
              "description": "List of services to display",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "layer": {
                    "name": "layer",
                    "type": "string",
                    "required": true
                  },
                  "layerColor": {
                    "name": "layerColor",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "Additional class names",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCatalogPage",
          "path": "/service-catalog",
          "traits": [
            {
              "ref": "ServiceCatalogRender"
            }
          ]
        }
      ]
    }
  ]
}
