{
  "description": "ServiceCatalog — UI factory (1:1 with the @almadar/ui service-catalog pattern).",
  "name": "ui-service-catalog",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "ServiceCatalogItem",
        "persistence": "runtime"
      },
      "name": "ServiceCatalogOrbital",
      "pages": [
        {
          "name": "ServiceCatalogPage",
          "path": "/service-catalog",
          "traits": [
            {
              "ref": "ServiceCatalogRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "Additional class names",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "services": {
              "default": [
                {
                  "layer": "Layer",
                  "layerColor": "Layer Color",
                  "name": "Name"
                }
              ],
              "description": "List of services to display",
              "items": {
                "properties": {
                  "layer": {
                    "name": "layer",
                    "required": true,
                    "type": "string"
                  },
                  "layerColor": {
                    "name": "layerColor",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Services",
              "tier": "presentation",
              "type": "[ServiceCatalogServicesItem]"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ServiceCatalogItem",
          "name": "ServiceCatalogRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "services": "@config.services",
                      "type": "service-catalog"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}