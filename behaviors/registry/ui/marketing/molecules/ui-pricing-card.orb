{
  "description": "PricingCard — UI factory (1:1 with the @almadar/ui pricing-card pattern).",
  "name": "ui-pricing-card",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PricingCardItem",
        "persistence": "runtime"
      },
      "name": "PricingCardOrbital",
      "pages": [
        {
          "name": "PricingCardPage",
          "path": "/pricing-card",
          "traits": [
            {
              "ref": "PricingCardRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "action": {
              "default": {
                "href": "Href",
                "label": "Label"
              },
              "description": "action prop",
              "label": "Action",
              "properties": {
                "href": {
                  "name": "href",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "PricingCardAction"
            },
            "badge": {
              "default": "Badge",
              "description": "badge prop",
              "label": "Badge",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "description": {
              "default": "Description",
              "description": "description prop",
              "label": "Description",
              "tier": "presentation",
              "type": "string"
            },
            "features": {
              "default": [
                "Item"
              ],
              "description": "features prop",
              "items": {
                "type": "string"
              },
              "label": "Features",
              "tier": "presentation",
              "type": "[string]"
            },
            "highlighted": {
              "default": false,
              "description": "highlighted prop",
              "label": "Highlighted",
              "tier": "presentation",
              "type": "boolean"
            },
            "name": {
              "default": "Name",
              "description": "name prop",
              "label": "Name",
              "tier": "presentation",
              "type": "string"
            },
            "price": {
              "default": "Price",
              "description": "price prop",
              "label": "Price",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PricingCardItem",
          "name": "PricingCardRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "action": "@config.action",
                      "badge": "@config.badge",
                      "className": "@config.className",
                      "description": "@config.description",
                      "features": "@config.features",
                      "highlighted": "@config.highlighted",
                      "name": "@config.name",
                      "price": "@config.price",
                      "type": "pricing-card"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}