{
  "name": "ui-pricing-card",
  "version": "1.0.0",
  "description": "PricingCard — UI factory (1:1 with the @almadar/ui pricing-card pattern).",
  "orbitals": [
    {
      "name": "PricingCardOrbital",
      "entity": {
        "name": "PricingCardItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PricingCardRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "PricingCardItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "highlighted": "@config.highlighted",
                      "badge": "@config.badge",
                      "type": "pricing-card",
                      "name": "@config.name",
                      "features": "@config.features",
                      "price": "@config.price",
                      "description": "@config.description",
                      "action": "@config.action",
                      "className": "@config.className"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "badge": {
              "type": "string",
              "default": "Badge",
              "label": "Badge",
              "description": "badge prop",
              "tier": "presentation"
            },
            "description": {
              "type": "string",
              "default": "Description",
              "label": "Description",
              "description": "description prop",
              "tier": "presentation"
            },
            "features": {
              "type": "[string]",
              "default": [
                "Item"
              ],
              "label": "Features",
              "description": "features prop",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "action": {
              "type": "PricingCardAction",
              "default": {
                "href": "Href",
                "label": "Label"
              },
              "label": "Action",
              "description": "action prop",
              "tier": "presentation",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                }
              }
            },
            "highlighted": {
              "type": "boolean",
              "default": false,
              "label": "Highlighted",
              "description": "highlighted prop",
              "tier": "presentation"
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            },
            "name": {
              "type": "string",
              "default": "Name",
              "label": "Name",
              "description": "name prop",
              "tier": "presentation"
            },
            "price": {
              "type": "string",
              "default": "Price",
              "label": "Price",
              "description": "price prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PricingCardPage",
          "path": "/pricing-card",
          "traits": [
            {
              "ref": "PricingCardRender"
            }
          ]
        }
      ]
    }
  ]
}