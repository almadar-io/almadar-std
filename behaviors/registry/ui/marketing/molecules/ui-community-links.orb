{
  "name": "ui-community-links",
  "version": "1.0.0",
  "description": "CommunityLinks — UI factory (1:1 with the @almadar/ui community-links pattern).",
  "orbitals": [
    {
      "name": "CommunityLinksOrbital",
      "entity": {
        "name": "CommunityLinksItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CommunityLinksRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "CommunityLinksItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "@config.subtitle",
                      "twitter": "@config.twitter",
                      "discord": "@config.discord",
                      "className": "@config.className",
                      "type": "community-links",
                      "github": "@config.github",
                      "heading": "@config.heading"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "discord": {
              "type": "CommunityLinksDiscord",
              "default": {
                "url": "Url",
                "members": 1.0
              },
              "label": "Discord",
              "description": "discord prop",
              "tier": "presentation",
              "properties": {
                "members": {
                  "name": "members",
                  "type": "number",
                  "required": false
                },
                "url": {
                  "name": "url",
                  "type": "string",
                  "required": true
                }
              }
            },
            "twitter": {
              "type": "CommunityLinksTwitter",
              "default": {
                "followers": 1.0,
                "url": "Url"
              },
              "label": "Twitter",
              "description": "twitter prop",
              "tier": "presentation",
              "properties": {
                "url": {
                  "name": "url",
                  "type": "string",
                  "required": true
                },
                "followers": {
                  "name": "followers",
                  "type": "number",
                  "required": false
                }
              }
            },
            "heading": {
              "type": "string",
              "default": "Heading",
              "label": "Heading",
              "description": "heading prop",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "Subtitle",
              "label": "Subtitle",
              "description": "subtitle prop",
              "tier": "presentation"
            },
            "github": {
              "type": "CommunityLinksGithub",
              "default": {
                "url": "Url",
                "stars": 1.0
              },
              "label": "Github",
              "description": "github prop",
              "tier": "presentation",
              "properties": {
                "stars": {
                  "name": "stars",
                  "type": "number",
                  "required": false
                },
                "url": {
                  "name": "url",
                  "type": "string",
                  "required": true
                }
              }
            },
            "className": {
              "type": "string",
              "default": "",
              "label": "Class Name",
              "description": "className prop",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CommunityLinksPage",
          "path": "/community-links",
          "traits": [
            {
              "ref": "CommunityLinksRender"
            }
          ]
        }
      ]
    }
  ]
}