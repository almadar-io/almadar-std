{
  "description": "CommunityLinks — UI factory (1:1 with the @almadar/ui community-links pattern).",
  "name": "ui-community-links",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CommunityLinksItem",
        "persistence": "runtime"
      },
      "name": "CommunityLinksOrbital",
      "pages": [
        {
          "name": "CommunityLinksPage",
          "path": "/community-links",
          "traits": [
            {
              "ref": "CommunityLinksRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "className prop",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "discord": {
              "default": {
                "members": 1.0,
                "url": "Url"
              },
              "description": "discord prop",
              "label": "Discord",
              "properties": {
                "members": {
                  "name": "members",
                  "required": false,
                  "type": "number"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "CommunityLinksDiscord"
            },
            "github": {
              "default": {
                "stars": 1.0,
                "url": "Url"
              },
              "description": "github prop",
              "label": "Github",
              "properties": {
                "stars": {
                  "name": "stars",
                  "required": false,
                  "type": "number"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "CommunityLinksGithub"
            },
            "heading": {
              "default": "Heading",
              "description": "heading prop",
              "label": "Heading",
              "tier": "presentation",
              "type": "string"
            },
            "subtitle": {
              "default": "Subtitle",
              "description": "subtitle prop",
              "label": "Subtitle",
              "tier": "presentation",
              "type": "string"
            },
            "twitter": {
              "default": {
                "followers": 1.0,
                "url": "Url"
              },
              "description": "twitter prop",
              "label": "Twitter",
              "properties": {
                "followers": {
                  "name": "followers",
                  "required": false,
                  "type": "number"
                },
                "url": {
                  "name": "url",
                  "required": true,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "CommunityLinksTwitter"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CommunityLinksItem",
          "name": "CommunityLinksRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "discord": "@config.discord",
                      "github": "@config.github",
                      "heading": "@config.heading",
                      "subtitle": "@config.subtitle",
                      "twitter": "@config.twitter",
                      "type": "community-links"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}