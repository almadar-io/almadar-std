{
  "name": "ui-auth-layout",
  "version": "1.0.0",
  "description": "AuthLayout — UI factory (1:1 with the @almadar/ui auth-layout pattern).",
  "orbitals": [
    {
      "name": "AuthLayoutOrbital",
      "entity": {
        "name": "AuthLayoutItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AuthLayoutRender",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": []
          },
          "category": "interaction",
          "linkedEntity": "AuthLayoutItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "auth-layout",
                      "logo": [
                        {
                          "content": "Logo",
                          "type": "typography"
                        }
                      ],
                      "backgroundImage": "@config.backgroundImage",
                      "appName": "@config.appName",
                      "brandingContent": "@config.brandingContent",
                      "showBranding": "@config.showBranding"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showBranding": {
              "type": "boolean",
              "default": true,
              "label": "Show Branding",
              "description": "Show branding panel on the side",
              "tier": "presentation"
            },
            "appName": {
              "type": "string",
              "default": "My App",
              "label": "App Name",
              "description": "App name",
              "tier": "presentation"
            },
            "backgroundImage": {
              "type": "asset",
              "default": "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png",
              "label": "Background Image",
              "description": "Background image URL",
              "tier": "presentation"
            },
            "brandingContent": {
              "type": "node",
              "label": "Branding Content",
              "description": "Branding panel content",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AuthLayoutPage",
          "path": "/auth-layout",
          "traits": [
            {
              "ref": "AuthLayoutRender"
            }
          ]
        }
      ]
    }
  ]
}