{
  "description": "AuthLayout — UI factory (1:1 with the @almadar/ui auth-layout pattern).",
  "name": "ui-auth-layout",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "AuthLayoutItem",
        "persistence": "runtime"
      },
      "name": "AuthLayoutOrbital",
      "pages": [
        {
          "name": "AuthLayoutPage",
          "path": "/auth-layout",
          "traits": [
            {
              "ref": "AuthLayoutRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "appName": {
              "default": "My App",
              "description": "App name",
              "label": "App Name",
              "tier": "presentation",
              "type": "string"
            },
            "backgroundImage": {
              "default": "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png",
              "description": "Background image URL",
              "label": "Background Image",
              "tier": "presentation",
              "type": "asset"
            },
            "brandingContent": {
              "description": "Branding panel content",
              "label": "Branding Content",
              "tier": "presentation",
              "type": "node"
            },
            "logo": {
              "default": [
                {
                  "content": "Logo",
                  "type": "typography"
                }
              ],
              "description": "Logo component or URL",
              "label": "Logo",
              "tier": "presentation",
              "type": "node"
            },
            "showBranding": {
              "default": true,
              "description": "Show branding panel on the side",
              "label": "Show Branding",
              "tier": "presentation",
              "type": "boolean"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AuthLayoutItem",
          "name": "AuthLayoutRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "@config.appName",
                      "backgroundImage": "@config.backgroundImage",
                      "brandingContent": "@config.brandingContent",
                      "logo": "@config.logo",
                      "showBranding": "@config.showBranding",
                      "type": "auth-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}