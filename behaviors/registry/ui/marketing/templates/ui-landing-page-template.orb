{
  "description": "LandingPageTemplate — UI factory (1:1 with the @almadar/ui landing-page-template pattern).",
  "name": "ui-landing-page-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LandingPageTemplateItem",
        "persistence": "runtime"
      },
      "name": "LandingPageTemplateOrbital",
      "pages": [
        {
          "name": "LandingPageTemplatePage",
          "path": "/landing-page-template",
          "traits": [
            {
              "ref": "LandingPageTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "featureColumns": {
              "default": 3.0,
              "description": "featureColumns prop",
              "label": "Feature Columns",
              "tier": "presentation",
              "type": "number"
            },
            "variant": {
              "default": "product",
              "description": "variant prop",
              "label": "Variant",
              "tier": "presentation",
              "type": "string",
              "values": [
                "product",
                "service",
                "platform"
              ]
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LandingPageTemplateItem",
          "name": "LandingPageTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "LandingPageTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entity": "@entity",
                      "featureColumns": "@config.featureColumns",
                      "type": "landing-page-template",
                      "variant": "@config.variant"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}