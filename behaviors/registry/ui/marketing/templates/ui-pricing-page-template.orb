{
  "description": "PricingPageTemplate — UI factory (1:1 with the @almadar/ui pricing-page-template pattern).",
  "name": "ui-pricing-page-template",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "PricingPageTemplateItem",
        "persistence": "runtime"
      },
      "name": "PricingPageTemplateOrbital",
      "pages": [
        {
          "name": "PricingPageTemplatePage",
          "path": "/pricing-page-template",
          "traits": [
            {
              "ref": "PricingPageTemplateRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "className": {
              "default": "",
              "description": "External styling override",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PricingPageTemplateItem",
          "name": "PricingPageTemplateRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "PricingPageTemplateItem",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entity": "@entity",
                      "type": "pricing-page-template"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}