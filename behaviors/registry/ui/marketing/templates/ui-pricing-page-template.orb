          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "PricingPageTemplate rows finished loading; payload.data holds the collection.",
                "key": "PricingPageTemplateLoaded",
                "name": "Pricing page template loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PricingPageTemplateItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "PricingPageTemplateItem",
                    {
                      "emit": {
                        "success": "PricingPageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entity": "@entity",
                      "type": "pricing-page-template"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "@config.className",
                      "entity": "@payload.data",
                      "type": "pricing-page-template"
                    }
                  ]
                ],
                "event": "PricingPageTemplateLoaded",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
