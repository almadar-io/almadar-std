                  "color": "#334155",
                  "id": 111.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 4.0,
                  "color": "#334155",
                  "id": 112.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 5.0,
                  "color": "#334155",
                  "id": 113.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 6.0,
                  "color": "#334155",
                  "id": 114.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 7.0,
                  "color": "#334155",
                  "id": 115.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 8.0,
                  "color": "#334155",
                  "id": 116.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 9.0,
                  "color": "#334155",
                  "id": 117.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 10.0,
                  "color": "#334155",
                  "id": 118.0,
                  "label": "",
                  "row": 9.0,
                  "value": 0.0
                },
                {
                  "col": 11.0,
                  "color": "#ef4444",
                  "id": 119.0,
                  "label": "",
                  "row": 9.0,
                  "value": 3.0
                }
              ],
              "description": "The 10x12 grid; value 0 = open, 1 = wall, 2 = start, 3 = target.",
              "items": {
                "properties": {
                  "col": {
                    "name": "col",
                    "required": true,
                    "type": "number"
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "g": {
                    "name": "g",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "number"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "row": {
                    "name": "row",
                    "required": true,
                    "type": "number"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Cells",
              "tier": "domain",
              "type": "[AlgoCell]"
            },
            "height": {
              "default": 600.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick expands one open cell per step; toggle to start/pause.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startId": {
              "default": 0.0,
              "description": "Id (row*cols+col) of the cell A* searches from.",
              "label": "Start Cell",
              "tier": "domain",
              "type": "number"
            },
            "targetId": {
              "default": 119.0,
              "description": "Id (row*cols+col) of the goal; A* stops when it is expanded.",
              "label": "Target Cell",
              "tier": "domain",
              "type": "number"
            },
            "width": {
              "default": 720.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The grid each expansion — a composed listener can subscribe; a harmless no-op standalone.",
              "event": "CELLS_UPDATED",
              "payloadSchema": [
                {
                  "name": "cells",
                  "type": "[AlgoCell]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, expand, path",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "cells",
              "closed",
              "cur",
              "done",
              "gcur",
              "open",
              "reached",
              "running",
              "tc",
              "tr"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AstarScene",
          "name": "AstarGridSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The grid each expansion — a composed listener can subscribe; a harmless no-op standalone.",
                "key": "CELLS_UPDATED",
                "name": "Cells Updated",
                "payloadSchema": [
                  {
                    "name": "cells",
                    "type": "[AlgoCell]"
                  }
                ],
                "synonyms": "tick, frame, step, expand, path",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.cells",
                    [
                      "array/map",
                      "@config.cells",
                      [
                        "object/merge",
                        "@item",
                        {
                          "g": [
                            "if",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@config.startId"
                            ],
                            0.0,
                            9999.0
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.open",
                    [
                      "@config.startId"
                    ]
                  ],
                  [
                    "set",
                    "@entity.closed",
                    []
                  ],
                  [
                    "set",
                    "@entity.cur",
                    "@config.startId"
                  ],
                  [
                    "set",
                    "@entity.gcur",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.tr",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@config.cells",
                          [
                            "==",
                            [
                              "object/get",
                              "@item",
                              "id"
                            ],
                            "@config.targetId"
                          ]
                        ]
                      ],
                      "row"
                    ]
                  ],
                  [
                    "set",
                    "@entity.tc",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@config.cells",
                          [
                            "==",
                            [
                              "object/get",
                              "@item",
                              "id"
                            ],
                            "@config.targetId"
                          ]
                        ]
                      ],
                      "col"
                    ]
                  ],
                  [
                    "set",
                    "@entity.reached",
                    false
                  ],
                  [
                    "set",
                    "@entity.done",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "cells": "@entity.cells",
                      "height": "@config.height",
                      "type": "algorithm-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "CELLS_UPDATED",
                    {
                      "cells": "@entity.cells"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.cur",
                  [
                    "let",
                    [
                      [
                        "fvals",
                        [
                          "array/map",
                          "@entity.open",
                          [
                            "let",
                            [
                              [
                                "nid",
                                "@item"
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "ncell",
                                  [
                                    "array/first",
                                    [
                                      "array/filter",
                                      "@entity.cells",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@item",
                                          "id"
                                        ],
                                        "@nid"
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "+",
                                [
                                  "object/get",
                                  "@ncell",
                                  "g"
                                ],
                                [
                                  "+",
                                  [
                                    "math/abs",
                                    [
                                      "-",
                                      [
                                        "object/get",
                                        "@ncell",
                                        "row"
                                      ],
                                      "@entity.tr"
                                    ]
                                  ],
                                  [
                                    "math/abs",
                                    [
                                      "-",
                                      [
                                        "object/get",
                                        "@ncell",
                                        "col"
                                      ],
                                      "@entity.tc"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "minf",
                          [
                            "array/first",
                            [
                              "array/filter",
                              "@fvals",
                              [
                                "let",
                                [
                                  [
                                    "x",
                                    "@item"
                                  ]
                                ],
                                [
                                  "==",
                                  [
                                    "array/len",
                                    [
                                      "array/filter",
                                      "@fvals",
                                      [
                                        "<",
                                        "@item",
                                        "@x"
                                      ]
                                    ]
                                  ],
                                  0.0
                                ]
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.open",
                          [
                            "let",
                            [
                              [
                                "nid",
                                "@item"
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "ncell",
                                  [
                                    "array/first",
                                    [
                                      "array/filter",
                                      "@entity.cells",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@item",
                                          "id"
                                        ],
                                        "@nid"
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "==",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@ncell",
                                    "g"
                                  ],
                                  [
                                    "+",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        [
                                          "object/get",
                                          "@ncell",
                                          "row"
                                        ],
                                        "@entity.tr"
                                      ]
                                    ],
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        [
                                          "object/get",
                                          "@ncell",
                                          "col"
                                        ],
                                        "@entity.tc"
                                      ]
                                    ]
                                  ]
                                ],
                                "@minf"
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.reached",
                  [
                    "==",
                    "@entity.cur",
                    "@config.targetId"
                  ]
                ],
                [
                  "set",
                  "@entity.gcur",
                  [
                    "object/get",
                    [
                      "array/first",
                      [
                        "array/filter",
                        "@entity.cells",
                        [
                          "==",
                          [
                            "object/get",
                            "@item",
                            "id"
                          ],
                          "@entity.cur"
                        ]
                      ]
                    ],
                    "g"
                  ]
                ],
                [
                  "set",
                  "@entity.cells",
                  [
                    "let",
                    [
                      [
                        "curcell",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@entity.cells",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@entity.cur"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "cr",
                          [
                            "object/get",
                            "@curcell",
                            "row"
                          ]
                        ],
                        [
                          "cc",
                          [
                            "object/get",
                            "@curcell",
                            "col"
                          ]
                        ]
                      ],
                      [
                        "array/map",
                        "@entity.cells",
                        [
                          "if",
                          [
                            "and",
                            [
                              "==",
                              [
                                "+",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "object/get",
                                      "@item",
                                      "row"
                                    ],
                                    "@cr"
                                  ]
                                ],
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "object/get",
                                      "@item",
                                      "col"
                                    ],
                                    "@cc"
                                  ]
                                ]
                              ],
                              1.0
                            ],
                            [
                              "and",
                              [
                                "not",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@item",
                                    "value"
                                  ],
                                  1.0
                                ]
                              ],
                              [
                                "and",
                                [
                                  "not",
                                  [
                                    "array/includes",
                                    "@entity.closed",
                                    [
                                      "object/get",
                                      "@item",
                                      "id"
                                    ]
                                  ]
                                ],
                                [
                                  "<",
                                  [
                                    "+",
                                    "@entity.gcur",
                                    1.0
                                  ],
                                  [
                                    "object/get",
                                    "@item",
                                    "g"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "object/merge",
                            "@item",
                            {
                              "g": [
                                "+",
                                "@entity.gcur",
                                1.0
                              ]
                            }
                          ],
                          "@item"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.open",
                  [
                    "let",
                    [
                      [
                        "curcell",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@entity.cells",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@entity.cur"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "cr",
                          [
                            "object/get",
                            "@curcell",
                            "row"
                          ]
                        ],
                        [
                          "cc",
                          [
                            "object/get",
                            "@curcell",
                            "col"
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "newn",
                            [
                              "array/map",
                              [
                                "array/filter",
                                "@entity.cells",
                                [
                                  "and",
                                  [
                                    "==",
                                    [
                                      "+",
                                      [
                                        "math/abs",
                                        [
                                          "-",
                                          [
                                            "object/get",
                                            "@item",
                                            "row"
                                          ],
                                          "@cr"
                                        ]
                                      ],
                                      [
                                        "math/abs",
                                        [
                                          "-",
                                          [
                                            "object/get",
                                            "@item",
                                            "col"
                                          ],
                                          "@cc"
                                        ]
                                      ]
                                    ],
                                    1.0
                                  ],
                                  [
                                    "and",
                                    [
                                      "not",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@item",
                                          "value"
                                        ],
                                        1.0
                                      ]
                                    ],
                                    [
                                      "and",
                                      [
                                        "not",
                                        [
                                          "array/includes",
                                          "@entity.closed",
                                          [
                                            "object/get",
                                            "@item",
                                            "id"
                                          ]
                                        ]
                                      ],
                                      [
                                        "not",
                                        [
                                          "array/includes",
                                          "@entity.open",
                                          [
                                            "object/get",
                                            "@item",
                                            "id"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "object/get",
                                "@item",
                                "id"
                              ]
                            ]
                          ]
                        ],
                        [
                          "array/concat",
                          "@entity.open",
                          "@newn"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.closed",
                  [
                    "array/append",
                    "@entity.closed",
                    "@entity.cur"
                  ]
                ],
                [
                  "set",
                  "@entity.open",
                  [
                    "array/filter",
                    "@entity.open",
                    [
                      "not",
                      [
                        "==",
                        "@item",
                        "@entity.cur"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    "or",
                    "@entity.reached",
                    [
                      "==",
                      [
                        "array/len",
                        "@entity.open"
                      ],
                      0.0
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.cells",
                  [
                    "array/map",
                    "@entity.cells",
                    [
                      "object/merge",
                      "@item",
                      {
                        "color": [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "@item",
                              "value"
                            ],
                            1.0
                          ],
                          "#0f172a",
                          [
                            "if",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@config.startId"
                            ],
                            "#3b82f6",
                            [
                              "if",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@item",
                                  "id"
                                ],
                                "@config.targetId"
                              ],
                              [
                                "if",
                                "@entity.reached",
                                "#22c55e",
                                "#ef4444"
                              ],
                              [
                                "if",
                                [
                                  "array/includes",
                                  "@entity.closed",
                                  [
                                    "object/get",
                                    "@item",
                                    "id"
                                  ]
                                ],
                                "#22c55e",
                                [
                                  "if",
                                  [
                                    "array/includes",
                                    "@entity.open",
                                    [
                                      "object/get",
                                      "@item",
                                      "id"
                                    ]
                                  ],
                                  "#f59e0b",
                                  "#334155"
                                ]
                              ]
                            ]
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "cells": "@entity.cells",
                    "height": "@config.height",
                    "type": "algorithm-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "CELLS_UPDATED",
                  {
                    "cells": "@entity.cells"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 250.0,
              "name": "astarTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}