                }
              ],
              "description": "The initial grid; value 0 = open, 1 = wall, 2 = start, 3 = target.",
              "items": {
                "properties": {
                  "col": {
                    "name": "col",
                    "required": true,
                    "type": "number"
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "number"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "row": {
                    "name": "row",
                    "required": true,
                    "type": "number"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Cells",
              "tier": "domain",
              "type": "[AlgoCell]"
            },
            "height": {
              "default": 600.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick expands the wavefront one cell per step; toggle to start/pause.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "startId": {
              "default": 0.0,
              "description": "Id (row*cols+col) of the cell BFS starts from.",
              "label": "Start Cell",
              "tier": "domain",
              "type": "number"
            },
            "targetId": {
              "default": 119.0,
              "description": "Id (row*cols+col) of the goal; BFS stops when its wavefront reaches it.",
              "label": "Target Cell",
              "tier": "domain",
              "type": "number"
            },
            "width": {
              "default": 720.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The grid each step — a composed listener can subscribe; a harmless no-op standalone.",
              "event": "CELLS_UPDATED",
              "eventId": "evt_01KXG050WY8V79QC3VM0R9CN1F",
              "payloadSchema": [
                {
                  "name": "cells",
                  "type": "[AlgoCell]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, wavefront, traverse",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "cells",
              "cur",
              "done",
              "newIds",
              "queue",
              "running",
              "seen",
              "visited"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG050WWTB1Q189J4Q89S2CW",
          "linkedEntity": "GridBfsScene",
          "linkedEntityId": "ent_01KXG050WWJKZRWCPZW8672HVK",
          "name": "GridBfsSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG050WWJPM7KKNXMN6Y89C7",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The grid each step — a composed listener can subscribe; a harmless no-op standalone.",
                "id": "evt_01KXG050WY8V79QC3VM0R9CN1F",
                "key": "CELLS_UPDATED",
                "name": "Cells Updated",
                "payloadSchema": [
                  {
                    "name": "cells",
                    "type": "[AlgoCell]"
                  }
                ],
                "synonyms": "tick, frame, step, wavefront, traverse",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.cells",
                    "@config.cells"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.queue",
                    [
                      "@config.startId"
                    ]
                  ],
                  [
                    "set",
                    "@entity.seen",
                    [
                      "@config.startId"
                    ]
                  ],
                  [
                    "set",
                    "@entity.visited",
                    []
                  ],
                  [
                    "set",
                    "@entity.done",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "cells": "@entity.cells",
                      "height": "@config.height",
                      "type": "algorithm-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "CELLS_UPDATED",
                    {
                      "cells": "@entity.cells"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG050WWJPM7KKNXMN6Y89C7",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.cur",
                  [
                    "array/first",
                    "@entity.queue"
                  ]
                ],
                [
                  "set",
                  "@entity.newIds",
                  [
                    "let",
                    [
                      [
                        "curcell",
                        [
                          "array/first",
                          [
                            "array/filter",
                            "@entity.cells",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@entity.cur"
                            ]
                          ]
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "cr",
                          [
                            "object/get",
                            "@curcell",
                            "row"
                          ]
                        ],
                        [
                          "cc",
                          [
                            "object/get",
                            "@curcell",
                            "col"
                          ]
                        ]
                      ],
                      [
                        "array/map",
                        [
                          "array/filter",
                          "@entity.cells",
                          [
                            "and",
                            [
                              "==",
                              [
                                "+",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "object/get",
                                      "@item",
                                      "row"
                                    ],
                                    "@cr"
                                  ]
                                ],
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "object/get",
                                      "@item",
                                      "col"
                                    ],
                                    "@cc"
                                  ]
                                ]
                              ],
                              1.0
                            ],
                            [
                              "and",
                              [
                                "not",
                                [
                                  "==",
                                  [
                                    "object/get",
                                    "@item",
                                    "value"
                                  ],
                                  1.0
                                ]
                              ],
                              [
                                "not",
                                [
                                  "array/includes",
                                  "@entity.seen",
                                  [
                                    "object/get",
                                    "@item",
                                    "id"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "object/get",
                          "@item",
                          "id"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.visited",
                  [
                    "array/append",
                    "@entity.visited",
                    "@entity.cur"
                  ]
                ],
                [
                  "set",
                  "@entity.seen",
                  [
                    "array/concat",
                    "@entity.seen",
                    "@entity.newIds"
                  ]
                ],
                [
                  "set",
                  "@entity.queue",
                  [
                    "array/concat",
                    [
                      "array/drop",
                      "@entity.queue",
                      1.0
                    ],
                    "@entity.newIds"
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    "or",
                    [
                      "==",
                      [
                        "array/len",
                        "@entity.queue"
                      ],
                      0.0
                    ],
                    [
                      "array/includes",
                      "@entity.visited",
                      "@config.targetId"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.cells",
                  [
                    "array/map",
                    "@entity.cells",
                    [
                      "object/merge",
                      "@item",
                      {
                        "color": [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "@item",
                              "value"
                            ],
                            1.0
                          ],
                          "#0f172a",
                          [
                            "if",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ],
                              "@config.startId"
                            ],
                            "#3b82f6",
                            [
                              "if",
                              [
                                "==",
                                [
                                  "object/get",
                                  "@item",
                                  "id"
                                ],
                                "@config.targetId"
                              ],
                              [
                                "if",
                                [
                                  "array/includes",
                                  "@entity.visited",
                                  [
                                    "object/get",
                                    "@item",
                                    "id"
                                  ]
                                ],
                                "#22c55e",
                                "#ef4444"
                              ],
                              [
                                "if",
                                [
                                  "array/includes",
                                  "@entity.visited",
                                  [
                                    "object/get",
                                    "@item",
                                    "id"
                                  ]
                                ],
                                "#22c55e",
                                [
                                  "if",
                                  [
                                    "array/includes",
                                    "@entity.seen",
                                    [
                                      "object/get",
                                      "@item",
                                      "id"
                                    ]
                                  ],
                                  "#f59e0b",
                                  "#334155"
                                ]
                              ]
                            ]
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "cells": "@entity.cells",
                    "height": "@config.height",
                    "type": "algorithm-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "CELLS_UPDATED",
                  {
                    "cells": "@entity.cells"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 300.0,
              "name": "bfsTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}