          "emits": [
            {
              "description": "The current scene each tick — a composed listener (histogram, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052PRKXA84EPSKYZ416QS",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[GaltonBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "GaltonState": "ent_01KXG052PPAN59HC0M6HRST8RP"
          },
          "id": "trt_01KXG052PPH0CZ1FRWM5KMBV43",
          "linkedEntity": "GaltonState",
          "linkedEntityId": "ent_01KXG052PPAN59HC0M6HRST8RP",
          "name": "GaltonSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052PPV70Z2YSAYSS6CAY1",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (histogram, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052PRKXA84EPSKYZ416QS",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[GaltonBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "shapes": "@config.shapes",
                      "showForces": false,
                      "showVelocity": false,
                      "type": "physics-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052PPV70Z2YSAYSS6CAY1",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "do",
                  [
                    "set",
                    "@entity.bodies",
                    [
                      "array/map",
                      "@entity.bodies",
                      [
                        "fn",
                        "b",
                        [
                          "let",
                          [
                            [
                              "y",
                              [
                                "object/get",
                                "@b",
                                "y"
                              ]
                            ],
                            [
                              "x",
                              [
                                "object/get",
                                "@b",
                                "x"
                              ]
                            ],
                            [
                              "vy",
                              [
                                "object/get",
                                "@b",
                                "vy"
                              ]
                            ],
                            [
                              "radius",
                              [
                                "object/get",
                                "@b",
                                "radius"
                              ]
                            ]
                          ],
                          [
                            "if",
                            [
                              ">=",
                              "@y",
                              "@config.floor"
                            ],
                            "@b",
                            [
                              "let",
                              [
                                [
                                  "nvy",
                                  [
                                    "+",
                                    "@vy",
                                    "@config.gravity"
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "ny",
                                    [
                                      "+",
                                      "@y",
                                      "@nvy"
                                    ]
                                  ],
                                  [
                                    "nx",
                                    [
                                      "math/clamp",
                                      [
                                        "+",
                                        "@x",
                                        [
                                          "-",
                                          [
                                            "*",
                                            [
                                              "math/random"
                                            ],
                                            [
                                              "*",
                                              2.0,
                                              "@config.jitter"
                                            ]
                                          ],
                                          "@config.jitter"
                                        ]
                                      ],
                                      "@radius",
                                      [
                                        "-",
                                        "@config.width",
                                        "@radius"
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "ny2",
                                      [
                                        "if",
                                        [
                                          ">=",
                                          "@ny",
                                          "@config.floor"
                                        ],
                                        "@config.floor",
                                        "@ny"
                                      ]
                                    ]
                                  ],
                                  [
                                    "object/merge",
                                    "@b",
                                    {
                                      "vy": "@nvy",
                                      "x": "@nx",
                                      "y": "@ny2"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "shapes": "@config.shapes",
                      "showForces": false,
                      "showVelocity": false,
                      "type": "physics-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "galtonTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}