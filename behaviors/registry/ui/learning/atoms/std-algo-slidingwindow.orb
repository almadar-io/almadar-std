  },
  "name": "std-algo-slidingwindow",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "bars",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "index": {
                  "name": "index",
                  "required": true,
                  "type": "number"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "pointers",
            "type": "array"
          },
          {
            "default": 0.0,
            "name": "l",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "r",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "bestL",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "bestSum",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "winSum",
            "type": "number"
          },
          {
            "default": false,
            "name": "done",
            "type": "boolean"
          },
          {
            "default": true,
            "name": "running",
            "type": "boolean"
          }
        ],
        "id": "ent_01KXG0518NPCS2TS9AAH9XG8G7",
        "name": "SlidingWindowScene",
        "persistence": "runtime"
      },
      "id": "orb_01KXG0518NGC5WGE0MANNZ7167",
      "name": "SlidingWindowEngineOrbital",
      "pages": [
        {
          "id": "pag_01KXG0518QYAHS66YM8G9B7SZV",
          "name": "SlidingWindowEnginePage",
          "path": "/algo-slidingwindow",
          "traits": [
            {
              "ref": "SlidingWindowSim",
              "refId": "trt_01KXG0518NS4DZYC0WPX3GQPTR"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "#f8fafc",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "bars": {
              "default": [
                {
                  "color": "#3b82f6",
                  "label": "3",
                  "value": 3.0
                },
                {
                  "color": "#3b82f6",
                  "label": "1",
                  "value": 1.0
                },
                {
                  "color": "#3b82f6",
                  "label": "4",
                  "value": 4.0
                },
                {
                  "color": "#3b82f6",
                  "label": "1",
                  "value": 1.0
                },
                {
                  "color": "#3b82f6",
                  "label": "5",
                  "value": 5.0
                },
                {
                  "color": "#3b82f6",
                  "label": "9",
                  "value": 9.0
                },
                {
                  "color": "#3b82f6",
                  "label": "2",
                  "value": 2.0
                },
                {
                  "color": "#3b82f6",
                  "label": "6",
                  "value": 6.0
                },
                {
                  "color": "#3b82f6",
                  "label": "5",
                  "value": 5.0
                },
                {
                  "color": "#3b82f6",
                  "label": "3",
                  "value": 3.0
                }
              ],
              "description": "Initial unsorted array; each bar's height is proportional to its value.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bars",
              "tier": "domain",
              "type": "[AlgoBar]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "k": {
              "default": 3.0,
              "description": "The fixed number of adjacent bars in each window.",
              "label": "Window Size",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick slides the window one position; toggle to start/pause the scan.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current bars + window L/R cursors each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone.",
              "event": "WINDOW_UPDATED",
              "eventId": "evt_01KXG0518QQC7VBQ70P05RXC73",
              "payloadSchema": [
                {
                  "name": "bars",
                  "type": "[AlgoBar]"
                },
                {
                  "name": "pointers",
                  "type": "[AlgoPointer]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, slide, window, max",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bars",
              "bestL",
              "bestSum",
              "done",
              "l",
              "pointers",
              "r",
              "running",
              "winSum"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG0518NS4DZYC0WPX3GQPTR",
          "linkedEntity": "SlidingWindowScene",
          "linkedEntityId": "ent_01KXG0518NPCS2TS9AAH9XG8G7",
          "name": "SlidingWindowSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG0518NR6JQNJTB9MXMR89M",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current bars + window L/R cursors each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone.",
                "id": "evt_01KXG0518QQC7VBQ70P05RXC73",
                "key": "WINDOW_UPDATED",
                "name": "Window Updated",
                "payloadSchema": [
                  {
                    "name": "bars",
                    "type": "[AlgoBar]"
                  },
                  {
                    "name": "pointers",
                    "type": "[AlgoPointer]"
                  }
                ],
                "synonyms": "tick, frame, step, slide, window, max",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bars",
                    "@config.bars"
                  ],
                  [
                    "set",
                    "@entity.l",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.bestL",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.bestSum",
                    [
                      "array/sum",
                      [
                        "array/slice",
                        "@config.bars",
                        0.0,
                        "@config.k"
                      ],
                      "value"
                    ]
                  ],
                  [
                    "set",
                    "@entity.r",
                    [
                      "-",
                      "@config.k",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.pointers",
                    [
                      {
                        "color": "#f59e0b",
                        "index": "@entity.l",
                        "label": "L"
                      },
                      {
                        "color": "#f59e0b",
                        "index": "@entity.r",
                        "label": "R"
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bars": "@entity.bars",
                      "height": "@config.height",
                      "pointers": "@entity.pointers",
                      "type": "algorithm-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "WINDOW_UPDATED",
                    {
                      "bars": "@entity.bars",
                      "pointers": "@entity.pointers"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG0518NR6JQNJTB9MXMR89M",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.l",
                  [
                    "+",
                    "@entity.l",
                    1.0
                  ]
                ],
                [
                  "set",
                  "@entity.winSum",
                  [
                    "array/sum",
                    [
                      "array/slice",
                      "@entity.bars",
                      "@entity.l",
                      [
                        "+",
                        "@entity.l",
                        "@config.k"
                      ]
                    ],
                    "value"
                  ]
                ],
                [
                  "set",
                  "@entity.bestL",
                  [
                    "if",
                    [
                      ">",
                      "@entity.winSum",
                      "@entity.bestSum"
                    ],
                    "@entity.l",
                    "@entity.bestL"
                  ]
                ],
                [
                  "set",
                  "@entity.bestSum",
                  [
                    "if",
                    [
                      ">",
                      "@entity.winSum",
                      "@entity.bestSum"
                    ],
                    "@entity.winSum",
                    "@entity.bestSum"
                  ]
                ],
                [
                  "set",
                  "@entity.r",
                  [
                    "+",
                    "@entity.l",
                    [
                      "-",
                      "@config.k",
                      1.0
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    ">=",
                    "@entity.l",
                    [
                      "-",
                      [
                        "array/len",
                        "@entity.bars"
                      ],
                      "@config.k"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.bars",
                  [
                    "array/map",
                    "@entity.bars",
                    [
                      "object/merge",
                      "@item",
                      {
                        "color": [
                          "if",
                          [
                            "and",
                            [
                              ">=",
                              "@index",
                              "@entity.bestL"
                            ],
                            [
                              "<",
                              "@index",
                              [
                                "+",
                                "@entity.bestL",
                                "@config.k"
                              ]
                            ]
                          ],
                          "#22c55e",
                          [
                            "if",
                            [
                              "and",
                              [
                                ">=",
                                "@index",
                                "@entity.l"
                              ],
                              [
                                "<",
                                "@index",
                                [
                                  "+",
                                  "@entity.l",
                                  "@config.k"
                                ]
                              ]
                            ],
                            "#f59e0b",
                            "#3b82f6"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.pointers",
                  [
                    {
                      "color": "#f59e0b",
                      "index": "@entity.l",
                      "label": "L"
                    },
                    {
                      "color": "#f59e0b",
                      "index": "@entity.r",
                      "label": "R"
                    }
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bars": "@entity.bars",
                    "height": "@config.height",
                    "pointers": "@entity.pointers",
                    "type": "algorithm-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "WINDOW_UPDATED",
                  {
                    "bars": "@entity.bars",
                    "pointers": "@entity.pointers"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 350.0,
              "name": "windowTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}