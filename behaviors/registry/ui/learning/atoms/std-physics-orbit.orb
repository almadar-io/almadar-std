              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[OrbitBody]"
            },
            "centerX": {
              "default": 300.0,
              "description": "X coordinate of the fixed central mass planets orbit.",
              "label": "Center X",
              "tier": "domain",
              "type": "number"
            },
            "centerY": {
              "default": 200.0,
              "description": "Y coordinate of the fixed central mass planets orbit.",
              "label": "Center Y",
              "tier": "domain",
              "type": "number"
            },
            "gm": {
              "default": 600.0,
              "description": "GM of the central mass; scales the inverse-square acceleration toward the center.",
              "label": "Gravitational Parameter",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Draw each body's velocity vector as an arrow.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "velocityScale": {
              "default": 14.0,
              "description": "Length multiplier for the velocity arrows.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052CQ7JVW6VCEH9KXC90W",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[OrbitBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "OrbitState": "ent_01KXG052CHFSQA9H6K249Y814N"
          },
          "id": "trt_01KXG052CH5WE3CQSY9NGDFFJD",
          "linkedEntity": "OrbitState",
          "linkedEntityId": "ent_01KXG052CHFSQA9H6K249Y814N",
          "name": "OrbitSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052CHRV2ESXB1ETD80REP",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052CQ7JVW6VCEH9KXC90W",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[OrbitBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052CHRV2ESXB1ETD80REP",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "if",
                        [
                          "=",
                          [
                            "object/get",
                            "@b",
                            "id"
                          ],
                          "sun"
                        ],
                        "@b",
                        [
                          "let",
                          [
                            [
                              "dx",
                              [
                                "-",
                                "@config.centerX",
                                [
                                  "object/get",
                                  "@b",
                                  "x"
                                ]
                              ]
                            ],
                            [
                              "dy",
                              [
                                "-",
                                "@config.centerY",
                                [
                                  "object/get",
                                  "@b",
                                  "y"
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "dist",
                                [
                                  "math/sqrt",
                                  [
                                    "+",
                                    [
                                      "*",
                                      "@dx",
                                      "@dx"
                                    ],
                                    [
                                      "*",
                                      "@dy",
                                      "@dy"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "distSafe",
                                  [
                                    "math/max",
                                    "@dist",
                                    6.0
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "invCube",
                                    [
                                      "/",
                                      "@config.gm",
                                      [
                                        "*",
                                        "@distSafe",
                                        [
                                          "*",
                                          "@distSafe",
                                          "@distSafe"
                                        ]
                                      ]
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "ax",
                                      [
                                        "*",
                                        "@invCube",
                                        "@dx"
                                      ]
                                    ],
                                    [
                                      "ay",
                                      [
                                        "*",
                                        "@invCube",
                                        "@dy"
                                      ]
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "nvx",
                                        [
                                          "+",
                                          [
                                            "object/get",
                                            "@b",
                                            "vx"
                                          ],
                                          "@ax"
                                        ]
                                      ],
                                      [
                                        "nvy",
                                        [
                                          "+",
                                          [
                                            "object/get",
                                            "@b",
                                            "vy"
                                          ],
                                          "@ay"
                                        ]
                                      ]
                                    ],
                                    [
                                      "let",
                                      [
                                        [
                                          "nx",
                                          [
                                            "+",
                                            [
                                              "object/get",
                                              "@b",
                                              "x"
                                            ],
                                            "@nvx"
                                          ]
                                        ],
                                        [
                                          "ny",
                                          [
                                            "+",
                                            [
                                              "object/get",
                                              "@b",
                                              "y"
                                            ],
                                            "@nvy"
                                          ]
                                        ]
                                      ],
                                      [
                                        "object/merge",
                                        "@b",
                                        {
                                          "vx": "@nvx",
                                          "vy": "@nvy",
                                          "x": "@nx",
                                          "y": "@ny"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "orbitTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}