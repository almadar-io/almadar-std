                  "x": 470.0,
                  "y": 200.0
                }
              ],
              "description": "Initial bodies; the sun is static, each planet starts with velocity perpendicular to its radius vector for a near-circular orbit.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
