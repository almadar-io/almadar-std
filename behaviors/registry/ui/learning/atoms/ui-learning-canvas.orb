{
  "description": "LearningCanvas — UI factory (1:1 with the @almadar/ui learning-canvas pattern).",
  "name": "ui-learning-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "LearningCanvasItem",
        "persistence": "runtime"
      },
      "name": "LearningCanvasOrbital",
      "pages": [
        {
          "name": "LearningCanvasPage",
          "path": "/learning-canvas",
          "traits": [
            {
              "ref": "LearningCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Enable continuous redraw loop.",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "backgroundColor": {
              "default": "Background Color",
              "description": "Background color (default transparent).",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "className": {
              "default": "",
              "description": "Additional CSS classes.",
              "label": "Class Name",
              "tier": "presentation",
              "type": "string"
            },
            "error": {
              "description": "Error state.",
              "label": "Error",
              "properties": {
                "code": {
                  "name": "code",
                  "required": false,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": false,
                  "type": "string"
                },
                "stack": {
                  "name": "stack",
                  "required": false,
                  "type": "string"
                }
              },
              "tier": "presentation",
              "type": "LearningCanvasError"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in CSS pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction (click/hover).",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "isLoading": {
              "default": false,
              "description": "Loading state.",
              "label": "Is Loading",
              "tier": "presentation",
              "type": "boolean"
            },
            "shapes": {
              "default": [
                {
                  "align": "left",
                  "axis": "x",
                  "color": "Color",
                  "fill": "Fill",
                  "fontSize": 1.0,
                  "height": 1.0,
                  "id": "Id",
                  "label": "Label",
                  "lineWidth": 1.0,
                  "max": 1.0,
                  "min": 1.0,
                  "opacity": 1.0,
                  "path": "Path",
                  "points": [
                    {
                      "x": 1.0,
                      "y": 1.0
                    },
                    {
                      "x": 2.0,
                      "y": 2.0
                    }
                  ],
                  "radius": 1.0,
                  "step": 1.0,
                  "text": "Text",
                  "type": "line",
                  "width": 1.0,
                  "x": 1.0,
                  "x1": 1.0,
                  "x2": 1.0,
                  "y": 1.0,
                  "y1": 1.0,
                  "y2": 1.0
                },
                {
                  "align": "center",
                  "axis": "y",
                  "color": "Color 2",
                  "fill": "Fill 2",
                  "fontSize": 2.0,
                  "height": 2.0,
                  "id": "Id 2",
                  "label": "Label 2",
                  "lineWidth": 2.0,
                  "max": 2.0,
                  "min": 2.0,
                  "opacity": 2.0,
                  "path": "Path 2",
                  "points": [
                    {
                      "x": 1.0,
                      "y": 1.0
                    },
                    {
                      "x": 2.0,
                      "y": 2.0
                    }
                  ],
                  "radius": 2.0,
                  "step": 2.0,
                  "text": "Text 2",
                  "type": "arrow",
                  "width": 2.0,
                  "x": 2.0,
                  "x1": 2.0,
                  "x2": 2.0,
                  "y": 2.0,
                  "y1": 2.0,
                  "y2": 2.0
                }
              ],
              "description": "Declarative shapes to draw.",
              "items": {
                "properties": {
                  "align": {
                    "name": "align",
                    "required": false,
                    "type": "string",
                    "values": [
                      "left",
                      "center",
                      "right"
                    ]
                  },
                  "axis": {
                    "name": "axis",
                    "required": false,
                    "type": "string",
                    "values": [
                      "x",
                      "y"
                    ]
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "fill": {
                    "name": "fill",
                    "required": false,
                    "type": "string"
                  },
                  "fontSize": {
                    "name": "fontSize",
                    "required": false,
                    "type": "number"
                  },
                  "height": {
                    "name": "height",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "lineWidth": {
                    "name": "lineWidth",
                    "required": false,
                    "type": "number"
                  },
                  "max": {
                    "name": "max",
                    "required": false,
                    "type": "number"
                  },
                  "min": {
                    "name": "min",
                    "required": false,
                    "type": "number"
                  },
                  "opacity": {
                    "name": "opacity",
                    "required": false,
                    "type": "number"
                  },
                  "path": {
                    "name": "path",
                    "required": false,
                    "type": "string"
                  },
                  "points": {
                    "items": {
                      "properties": {
                        "x": {
                          "name": "x",
                          "required": true,
                          "type": "number"
                        },
                        "y": {
                          "name": "y",
                          "required": true,
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "name": "points",
                    "required": false,
                    "type": "array"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "step": {
                    "name": "step",
                    "required": false,
                    "type": "number"
                  },
                  "text": {
                    "name": "text",
                    "required": false,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string",
                    "values": [
                      "line",
                      "arrow",
                      "circle",
                      "rect",
                      "polygon",
                      "path",
                      "text",
                      "axis",
                      "grid"
                    ]
                  },
                  "width": {
                    "name": "width",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": false,
                    "type": "number"
                  },
                  "x1": {
                    "name": "x1",
                    "required": false,
                    "type": "number"
                  },
                  "x2": {
                    "name": "x2",
                    "required": false,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": false,
                    "type": "number"
                  },
                  "y1": {
                    "name": "y1",
                    "required": false,
                    "type": "number"
                  },
                  "y2": {
                    "name": "y2",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Shapes",
              "tier": "presentation",
              "type": "[LearningCanvasShapesItem]"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in CSS pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "Clicked shape payload: { id?, type?, index }.",
              "event": "SHAPE_CLICK",
              "payloadSchema": [
                {
                  "name": "payload",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "type",
                      "type": "string"
                    },
                    {
                      "name": "index",
                      "required": true,
                      "type": "number"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            },
            {
              "description": "Hovered shape payload: { id?, type?, index }.",
              "event": "SHAPE_HOVER",
              "payloadSchema": [
                {
                  "name": "payload",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "type",
                      "type": "string"
                    },
                    {
                      "name": "index",
                      "required": true,
                      "type": "number"
                    }
                  ],
                  "type": "object"
                }
              ],
              "scope": "external",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LearningCanvasItem",
          "name": "LearningCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Live scene update; payload carries the current drawable state.",
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "shapes",
                    "type": "[LearningCanvasShapesItem]"
                  }
                ],
                "synonyms": "tick, redraw, animate, frame",
                "tier": "domain"
              },
              {
                "description": "Clicked shape payload: { id?, type?, index }.",
                "key": "SHAPE_CLICK",
                "name": "Shape Click",
                "payloadSchema": [
                  {
                    "name": "payload",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "type",
                        "type": "string"
                      },
                      {
                        "name": "index",
                        "required": true,
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              },
              {
                "description": "Hovered shape payload: { id?, type?, index }.",
                "key": "SHAPE_HOVER",
                "name": "Shape Hover",
                "payloadSchema": [
                  {
                    "name": "payload",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string"
                      },
                      {
                        "name": "type",
                        "type": "string"
                      },
                      {
                        "name": "index",
                        "required": true,
                        "type": "number"
                      }
                    ],
                    "type": "object"
                  }
                ],
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animate": "@config.animate",
                      "backgroundColor": "@config.backgroundColor",
                      "className": "@config.className",
                      "error": "@config.error",
                      "height": "@config.height",
                      "interactive": "@config.interactive",
                      "isLoading": "@config.isLoading",
                      "onShapeClick": "SHAPE_CLICK",
                      "onShapeHover": "SHAPE_HOVER",
                      "shapes": "@config.shapes",
                      "type": "learning-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "animate": "@config.animate",
                      "backgroundColor": "@config.backgroundColor",
                      "className": "@config.className",
                      "error": "@config.error",
                      "height": "@config.height",
                      "interactive": "@config.interactive",
                      "isLoading": "@config.isLoading",
                      "onShapeClick": "SHAPE_CLICK",
                      "onShapeHover": "SHAPE_HOVER",
                      "shapes": "@payload.shapes",
                      "type": "learning-canvas",
                      "width": "@config.width"
                    }
                  ]
                ],
                "event": "UPDATE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}