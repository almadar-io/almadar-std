                  "value": 0.0
                }
              ],
              "description": "The initial grid; value 1 = alive, 0 = dead.",
              "items": {
                "properties": {
                  "col": {
                    "name": "col",
                    "required": true,
                    "type": "number"
                  },
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "row": {
                    "name": "row",
                    "required": true,
                    "type": "number"
                  },
                  "value": {
                    "name": "value",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Cells",
              "tier": "domain",
              "type": "[AlgoCell]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick advances one generation; toggle to start/pause.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The grid each generation — a composed listener can subscribe; a harmless no-op standalone.",
              "event": "CELLS_UPDATED",
              "payloadSchema": [
                {
                  "name": "cells",
                  "type": "[AlgoCell]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, generation, step",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "cells",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "LifeScene",
          "name": "GameOfLifeSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The grid each generation — a composed listener can subscribe; a harmless no-op standalone.",
                "key": "CELLS_UPDATED",
                "name": "Cells Updated",
                "payloadSchema": [
                  {
                    "name": "cells",
                    "type": "[AlgoCell]"
                  }
                ],
                "synonyms": "tick, frame, generation, step",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.cells",
                    "@config.cells"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "cells": "@entity.cells",
                      "height": "@config.height",
                      "type": "algorithm-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "CELLS_UPDATED",
                    {
                      "cells": "@entity.cells"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.cells",
                  [
                    "array/map",
                    "@entity.cells",
                    [
                      "let",
                      [
                        [
                          "r",
                          [
                            "object/get",
                            "@item",
                            "row"
                          ]
                        ],
                        [
                          "c",
                          [
                            "object/get",
                            "@item",
                            "col"
                          ]
                        ],
                        [
                          "self",
                          [
                            "object/get",
                            "@item",
                            "value"
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "live",
                            [
                              "array/len",
                              [
                                "array/filter",
                                "@entity.cells",
                                [
                                  "and",
                                  [
                                    "<=",
                                    [
                                      "math/abs",
                                      [
                                        "-",
                                        [
                                          "object/get",
                                          "@item",
                                          "row"
                                        ],
                                        "@r"
                                      ]
                                    ],
                                    1.0
                                  ],
                                  [
                                    "and",
                                    [
                                      "<=",
                                      [
                                        "math/abs",
                                        [
                                          "-",
                                          [
                                            "object/get",
                                            "@item",
                                            "col"
                                          ],
                                          "@c"
                                        ]
                                      ],
                                      1.0
                                    ],
                                    [
                                      "and",
                                      [
                                        "==",
                                        [
                                          "object/get",
                                          "@item",
                                          "value"
                                        ],
                                        1.0
                                      ],
                                      [
                                        "not",
                                        [
                                          "and",
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@item",
                                              "row"
                                            ],
                                            "@r"
                                          ],
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@item",
                                              "col"
                                            ],
                                            "@c"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "next",
                              [
                                "if",
                                [
                                  "==",
                                  "@self",
                                  1.0
                                ],
                                [
                                  "if",
                                  [
                                    "or",
                                    [
                                      "==",
                                      "@live",
                                      2.0
                                    ],
                                    [
                                      "==",
                                      "@live",
                                      3.0
                                    ]
                                  ],
                                  1.0,
                                  0.0
                                ],
                                [
                                  "if",
                                  [
                                    "==",
                                    "@live",
                                    3.0
                                  ],
                                  1.0,
                                  0.0
                                ]
                              ]
                            ]
                          ],
                          [
                            "object/merge",
                            "@item",
                            {
                              "color": [
                                "if",
                                [
                                  "==",
                                  "@next",
                                  1.0
                                ],
                                "#22c55e",
                                "#1e293b"
                              ],
                              "value": "@next"
                            }
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "cells": "@entity.cells",
                    "height": "@config.height",
                    "type": "algorithm-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "CELLS_UPDATED",
                  {
                    "cells": "@entity.cells"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 500.0,
              "name": "lifeTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}