              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[WaveBody]"
            },
            "damping": {
              "default": 0.997,
              "description": "Fraction of vertical velocity retained each tick (energy loss as the wave propagates).",
              "label": "Damping",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": false,
              "description": "Draw each point's velocity vector as an arrow — off by default since 21 arrows clutter the waveform.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "spacing": {
              "default": 26.0,
              "description": "Horizontal distance between adjacent points.",
              "label": "Spacing",
              "tier": "domain",
              "type": "number"
            },
            "tension": {
              "default": 0.3,
              "description": "Coupling strength (k) pulling each point toward its neighbors' average height — the discrete wave equation's spring constant.",
              "label": "Tension",
              "tier": "domain",
              "type": "number"
            },
            "velocityScale": {
              "default": 6.0,
              "description": "Length multiplier for the velocity arrows, when shown.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            },
            "x0": {
              "default": 40.0,
              "description": "X coordinate of the first (fixed) point; used to derive each point's index from its x.",
              "label": "X Origin",
              "tier": "domain",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052NBDQD6C181WWT2K8AK",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[WaveBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "WaveState": "ent_01KXG052N8NK9W2QWNHRNHZ466"
          },
          "id": "trt_01KXG052N86BG5TJA20HFFR6WW",
          "linkedEntity": "WaveState",
          "linkedEntityId": "ent_01KXG052N8NK9W2QWNHRNHZ466",
          "name": "WaveSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052N81ACYT25WHXWGBK36",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052NBDQD6C181WWT2K8AK",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[WaveBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052N81ACYT25WHXWGBK36",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "i",
                            [
                              "math/round",
                              [
                                "/",
                                [
                                  "-",
                                  [
                                    "object/get",
                                    "@b",
                                    "x"
                                  ],
                                  "@config.x0"
                                ],
                                "@config.spacing"
                              ]
                            ]
                          ],
                          [
                            "last",
                            [
                              "-",
                              [
                                "array/len",
                                "@entity.bodies"
                              ],
                              1.0
                            ]
                          ]
                        ],
                        [
                          "if",
                          [
                            "or",
                            [
                              "=",
                              "@i",
                              0.0
                            ],
                            [
                              "=",
                              "@i",
                              "@last"
                            ]
                          ],
                          "@b",
                          [
                            "let",
                            [
                              [
                                "left",
                                [
                                  "array/nth",
                                  "@entity.bodies",
                                  [
                                    "-",
                                    "@i",
                                    1.0
                                  ]
                                ]
                              ],
                              [
                                "right",
                                [
                                  "array/nth",
                                  "@entity.bodies",
                                  [
                                    "+",
                                    "@i",
                                    1.0
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "accel",
                                  [
                                    "-",
                                    [
                                      "*",
                                      "@config.tension",
                                      [
                                        "+",
                                        [
                                          "object/get",
                                          "@left",
                                          "y"
                                        ],
                                        [
                                          "object/get",
                                          "@right",
                                          "y"
                                        ]
                                      ]
                                    ],
                                    [
                                      "*",
                                      "@config.tension",
                                      [
                                        "*",
                                        2.0,
                                        [
                                          "object/get",
                                          "@b",
                                          "y"
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "nvy",
                                    [
                                      "*",
                                      [
                                        "+",
                                        [
                                          "object/get",
                                          "@b",
                                          "vy"
                                        ],
                                        "@accel"
                                      ],
                                      "@config.damping"
                                    ]
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "ny",
                                      [
                                        "+",
                                        [
                                          "object/get",
                                          "@b",
                                          "y"
                                        ],
                                        "@nvy"
                                      ]
                                    ]
                                  ],
                                  [
                                    "object/merge",
                                    "@b",
                                    {
                                      "vy": "@nvy",
                                      "y": "@ny"
                                    }
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "waveTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}