                  "label": "G",
                  "radius": 20.0,
                  "x": 520.0,
                  "y": 300.0
                }
              ],
              "description": "Graph vertices; BFS recolours them slate→amber(frontier)→green(visited).",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "kind": {
                    "name": "kind",
                    "required": false,
                    "type": "string",
                    "values": [
                      "cell",
                      "organelle",
                      "molecule",
                      "organism"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "domain",
              "type": "[GraphNode]"
            },
            "running": {
              "default": true,
              "description": "When true the tick visits one node per step; toggle to start/pause the traversal.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "start": {
              "default": "A",
              "description": "Id of the node BFS starts from.",
              "label": "Start Node",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The graph each step — a composed listener can subscribe; a harmless no-op standalone.",
              "event": "NODES_UPDATED",
              "eventId": "evt_01KXG050JSG5Y3T4S6NZVY0WRW",
              "payloadSchema": [
                {
                  "name": "nodes",
                  "type": "[GraphNode]"
                },
                {
                  "name": "edges",
                  "type": "[GraphEdge]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, visit, traverse",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "cur",
              "done",
              "edges",
              "newIds",
              "nodes",
              "queue",
              "running",
              "seen",
              "visited"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG050JNJSQSN4KEZJFERW4N",
          "linkedEntity": "BfsScene",
          "linkedEntityId": "ent_01KXG050JN9PHV15AVK449DXBY",
          "name": "BfsSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The graph each step — a composed listener can subscribe; a harmless no-op standalone.",
                "key": "NODES_UPDATED",
                "name": "Nodes Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[GraphNode]"
                  },
                  {
                    "name": "edges",
                    "type": "[GraphEdge]"
                  }
                ],
                "synonyms": "tick, frame, step, visit, traverse",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.edges",
                    "@config.edges"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.queue",
                    [
                      "@config.start"
                    ]
                  ],
                  [
                    "set",
                    "@entity.seen",
                    [
                      "@config.start"
                    ]
                  ],
                  [
                    "set",
                    "@entity.visited",
                    []
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@entity.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "NODES_UPDATED",
                    {
                      "edges": "@entity.edges",
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.cur",
                  [
                    "array/first",
                    "@entity.queue"
                  ]
                ],
                [
                  "set",
                  "@entity.newIds",
                  [
                    "let",
                    [
                      [
                        "u",
                        "@entity.cur"
                      ]
                    ],
                    [
                      "array/filter",
                      [
                        "array/map",
                        [
                          "array/filter",
                          "@entity.edges",
                          [
                            "or",
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "from"
                              ],
                              "@u"
                            ],
                            [
                              "==",
                              [
                                "object/get",
                                "@item",
                                "to"
                              ],
                              "@u"
                            ]
                          ]
                        ],
                        [
                          "if",
                          [
                            "==",
                            [
                              "object/get",
                              "@item",
                              "from"
                            ],
                            "@u"
                          ],
                          [
                            "object/get",
                            "@item",
                            "to"
                          ],
                          [
                            "object/get",
                            "@item",
                            "from"
                          ]
                        ]
                      ],
                      [
                        "not",
                        [
                          "array/includes",
                          "@entity.seen",
                          "@item"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.visited",
                  [
                    "array/append",
                    "@entity.visited",
                    "@entity.cur"
                  ]
                ],
                [
                  "set",
                  "@entity.seen",
                  [
                    "array/concat",
                    "@entity.seen",
                    "@entity.newIds"
                  ]
                ],
                [
                  "set",
                  "@entity.queue",
                  [
                    "array/concat",
                    [
                      "array/drop",
                      "@entity.queue",
                      1.0
                    ],
                    "@entity.newIds"
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    "==",
                    [
                      "array/len",
                      "@entity.queue"
                    ],
                    0.0
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "object/merge",
                      "@item",
                      {
                        "color": [
                          "if",
                          [
                            "array/includes",
                            "@entity.visited",
                            [
                              "object/get",
                              "@item",
                              "id"
                            ]
                          ],
                          "#22c55e",
                          [
                            "if",
                            [
                              "array/includes",
                              "@entity.seen",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ]
                            ],
                            "#f59e0b",
                            "#cbd5e1"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@entity.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "NODES_UPDATED",
                  {
                    "edges": "@entity.edges",
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 400.0,
              "name": "bfsTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}