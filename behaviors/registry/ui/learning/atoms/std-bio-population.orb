                },
                {
                  "color": "#dc2626",
                  "id": "predator",
                  "kind": "organism",
                  "label": "Predator",
                  "radius": 20.0,
                  "x": 400.0,
                  "y": 200.0
                }
              ],
              "description": "Initial prey and predator population nodes; radius encodes population size.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "kind": {
                    "name": "kind",
                    "required": false,
                    "type": "string",
                    "values": [
                      "cell",
