                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "domain",
              "type": "[BioNode]"
            },
            "running": {
              "default": true,
              "description": "When true the tick advances the phase and recomputes both population radii; toggle to start/pause.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current population scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "POPULATION_UPDATED",
              "eventId": "evt_01KXG051GXA0AAA8H1B1TW4B53",
              "payloadSchema": [
                {
                  "name": "nodes",
                  "type": "[BioNode]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "nodes",
              "phase",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG051GT9AJMK7JQQRR7KR7C",
          "linkedEntity": "BioPopulationState",
          "linkedEntityId": "ent_01KXG051GTWJB4AY87NV05PF20",
          "name": "BioPopulationSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current population scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "POPULATION_UPDATED",
                "name": "Population Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[BioNode]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@config.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "POPULATION_UPDATED",
                    {
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.phase",
                  [
                    "+",
                    "@entity.phase",
                    3.0
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "fn",
                      "n",
                      [
                        "let",
                        [
                          [
                            "p",
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@n",
                                  "id"
                                ],
                                "predator"
                              ],
                              [
                                "+",
                                "@entity.phase",
                                80.0
                              ],
                              "@entity.phase"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "tw",
                              [
                                "math/abs",
                                [
                                  "-",
                                  [
                                    "math/mod",
                                    "@p",
                                    240.0
                                  ],
                                  120.0
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nr",
                                [
                                  "+",
                                  12.0,
                                  [
                                    "*",
                                    "@tw",
                                    0.2
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@n",
                              {
                                "radius": "@nr"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@config.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "POPULATION_UPDATED",
                  {
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "populationTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}