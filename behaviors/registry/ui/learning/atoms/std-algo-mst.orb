                },
                {
                  "color": "#64748b",
                  "id": "E",
                  "kind": "cell",
                  "label": "E",
                  "radius": 20.0,
                  "x": 240.0,
                  "y": 300.0
                },
                {
                  "color": "#64748b",
                  "id": "F",
