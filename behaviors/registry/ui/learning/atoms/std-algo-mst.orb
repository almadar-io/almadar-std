          },
          {
            "default": true,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "MstScene",
        "persistence": "runtime"
      },
      "name": "MstEngineOrbital",
      "pages": [
        {
          "name": "MstEnginePage",
          "path": "/algo-mst",
          "traits": [
            {
              "ref": "MstSim"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "#f8fafc",
