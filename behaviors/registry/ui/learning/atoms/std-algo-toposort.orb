                }
              ],
              "description": "DAG vertices; toposort recolours them slate→amber(ready)→green(ordered).",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  "kind": {
                    "name": "kind",
                    "required": false,
                    "type": "string",
                    "values": [
                      "cell",
                      "organelle",
                      "molecule",
                      "organism"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "domain",
              "type": "[GraphNode]"
            },
            "running": {
              "default": true,
              "description": "When true the tick emits one ready node per step; toggle to start/pause the sort.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The graph each step — a composed listener can subscribe; a harmless no-op standalone.",
              "event": "NODES_UPDATED",
              "eventId": "evt_01KXG051A1WVAFXPVE70D74CRA",
              "payloadSchema": [
                {
                  "name": "nodes",
                  "type": "[GraphNode]"
                },
                {
                  "name": "edges",
                  "type": "[GraphEdge]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, emit, order, sort",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "cur",
              "done",
              "edges",
              "nodes",
              "order",
              "ready",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG0519ZEG1Y0WMBQ9ZZPTVF",
          "linkedEntity": "ToposortScene",
          "linkedEntityId": "ent_01KXG0519ZVQD1P48EEJDCMVW9",
          "name": "ToposortSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The graph each step — a composed listener can subscribe; a harmless no-op standalone.",
                "key": "NODES_UPDATED",
                "name": "Nodes Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[GraphNode]"
                  },
                  {
                    "name": "edges",
                    "type": "[GraphEdge]"
                  }
                ],
                "synonyms": "tick, frame, step, emit, order, sort",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.edges",
                    "@config.edges"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.order",
                    []
                  ],
                  [
                    "set",
                    "@entity.ready",
                    []
                  ],
                  [
                    "set",
                    "@entity.cur",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@entity.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "NODES_UPDATED",
                    {
                      "edges": "@entity.edges",
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.ready",
                  [
                    "array/map",
                    [
                      "array/filter",
                      "@entity.nodes",
                      [
                        "let",
                        [
                          [
                            "nid",
                            [
                              "object/get",
                              "@item",
                              "id"
                            ]
                          ]
                        ],
                        [
                          "and",
                          [
                            "not",
                            [
                              "array/includes",
                              "@entity.order",
                              "@nid"
                            ]
                          ],
                          [
                            "==",
                            [
                              "array/len",
                              [
                                "array/filter",
                                [
                                  "array/map",
                                  [
                                    "array/filter",
                                    "@entity.edges",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@item",
                                        "to"
                                      ],
                                      "@nid"
                                    ]
                                  ],
                                  [
                                    "object/get",
                                    "@item",
                                    "from"
                                  ]
                                ],
                                [
                                  "not",
                                  [
                                    "array/includes",
                                    "@entity.order",
                                    "@item"
                                  ]
                                ]
                              ]
                            ],
                            0.0
                          ]
                        ]
                      ]
                    ],
                    [
                      "object/get",
                      "@item",
                      "id"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.cur",
                  [
                    "array/first",
                    "@entity.ready"
                  ]
                ],
                [
                  "set",
                  "@entity.order",
                  [
                    "array/append",
                    "@entity.order",
                    "@entity.cur"
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    "==",
                    [
                      "array/len",
                      "@entity.order"
                    ],
                    [
                      "array/len",
                      "@entity.nodes"
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "object/merge",
                      "@item",
                      {
                        "color": [
                          "if",
                          [
                            "array/includes",
                            "@entity.order",
                            [
                              "object/get",
                              "@item",
                              "id"
                            ]
                          ],
                          "#22c55e",
                          [
                            "if",
                            [
                              "array/includes",
                              "@entity.ready",
                              [
                                "object/get",
                                "@item",
                                "id"
                              ]
                            ],
                            "#f59e0b",
                            "#cbd5e1"
                          ]
                        ]
                      }
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@entity.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "NODES_UPDATED",
                  {
                    "edges": "@entity.edges",
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 400.0,
              "name": "topoTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}