            }
          },
          "emits": [
            {
              "description": "The current scene each tick.",
              "event": "CIRCLE_UPDATED",
              "payloadSchema": [
                {
                  "name": "curves",
                  "type": "[MathCurve]"
                },
                {
                  "name": "points",
                  "type": "[MathPoint]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "curves",
              "phase",
              "points",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MathUnitCircleState",
          "name": "MathUnitCircleSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick.",
                "key": "CIRCLE_UPDATED",
                "name": "Circle Updated",
                "payloadSchema": [
                  {
                    "name": "curves",
                    "type": "[MathCurve]"
                  },
                  {
                    "name": "points",
                    "type": "[MathPoint]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.curves",
                    "@config.curves"
                  ],
                  [
                    "set",
                    "@entity.points",
                    "@config.points"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "curves": "@entity.curves",
                      "height": "@config.height",
                      "points": "@entity.points",
                      "type": "math-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "CIRCLE_UPDATED",
                    {
                      "curves": "@entity.curves",
                      "points": "@entity.points"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "np",
                      [
                        "+",
                        "@entity.phase",
                        0.04
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "px",
                        [
                          "*",
                          6.0,
                          [
                            "math/cos",
                            "@np"
                          ]
                        ]
                      ],
                      [
                        "py",
                        [
                          "*",
                          6.0,
                          [
                            "math/sin",
                            "@np"
                          ]
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.phase",
                        "@np"
                      ],
                      [
                        "set",
                        "@entity.curves",
                        [
                          "@config.circle",
                          {
                            "color": "#dc2626",
                            "label": "r",
                            "samples": [
                              {
                                "x": 0.0,
                                "y": 0.0
                              },
                              {
                                "x": "@px",
                                "y": "@py"
                              }
                            ]
                          },
                          {
                            "color": "#16a34a",
                            "label": "sin",
                            "samples": [
                              {
                                "x": "@px",
                                "y": "@py"
                              },
                              {
                                "x": "@px",
                                "y": 0.0
                              }
                            ]
                          },
                          {
                            "color": "#2563eb",
                            "label": "cos",
                            "samples": [
                              {
                                "x": 0.0,
                                "y": 0.0
                              },
                              {
                                "x": "@px",
                                "y": 0.0
                              }
                            ]
                          }
                        ]
                      ],
                      [
                        "set",
                        "@entity.points",
                        [
                          {
                            "color": "#dc2626",
                            "label": "P",
                            "radius": 6.0,
                            "x": "@px",
                            "y": "@py"
                          },
                          {
                            "color": "#2563eb",
                            "label": "cos",
                            "radius": 4.0,
                            "x": "@px",
                            "y": 0.0
                          }
                        ]
                      ],
                      [
                        "render-ui",
                        "main",
                        {
                          "curves": "@entity.curves",
                          "height": "@config.height",
                          "points": "@entity.points",
                          "type": "math-canvas",
                          "width": "@config.width"
                        }
                      ],
                      [
                        "emit",
                        "CIRCLE_UPDATED",
                        {
                          "curves": "@entity.curves",
                          "points": "@entity.points"
                        }
                      ]
                    ]
                  ]
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "circleTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}