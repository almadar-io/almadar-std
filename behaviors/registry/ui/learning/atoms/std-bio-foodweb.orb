{
  "description": "Food-web / ecosystem engine — five trophic species whose radii breathe at staggered phases (trophic lag) on biology-canvas.",
  "name": "std-bio-foodweb",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "phase",
            "type": "number"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "kind": {
                  "name": "kind",
                  "required": false,
                  "type": "string",
                  "values": [
                    "cell",
                    "organelle",
                    "molecule",
                    "organism"
                  ]
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "radius": {
                  "name": "radius",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "nodes",
            "type": "array"
          },
          {
            "default": false,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "BioFoodwebState",
        "persistence": "runtime"
      },
      "name": "BioFoodwebEngineOrbital",
      "pages": [
        {
          "name": "BioFoodwebEnginePage",
          "path": "/bio-foodweb",
          "traits": [
            {
              "ref": "BioFoodwebSim"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "#f0fdf4",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "edges": {
              "default": [
                {
                  "color": "#94a3b8",
                  "from": "rabbit",
                  "label": "eats",
                  "to": "grass"
                },
                {
                  "color": "#94a3b8",
                  "from": "insect",
                  "label": "eats",
                  "to": "grass"
                },
                {
                  "color": "#94a3b8",
                  "from": "fox",
                  "label": "eats",
                  "to": "rabbit"
                },
                {
                  "color": "#94a3b8",
                  "from": "fox",
                  "label": "eats",
                  "to": "insect"
                },
                {
                  "color": "#94a3b8",
                  "from": "hawk",
                  "label": "eats",
                  "to": "fox"
                }
              ],
              "description": "Directed predation links (from eater to prey) forming the food web.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Edges",
              "tier": "domain",
              "type": "[BioEdge]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "nodes": {
              "default": [
                {
                  "color": "#16a34a",
                  "id": "grass",
                  "kind": "organism",
                  "label": "Grass",
                  "radius": 20.0,
                  "x": 300.0,
                  "y": 340.0
                },
                {
                  "color": "#a16207",
                  "id": "rabbit",
                  "kind": "organism",
                  "label": "Rabbit",
                  "radius": 18.0,
                  "x": 180.0,
                  "y": 220.0
                },
                {
                  "color": "#0891b2",
                  "id": "insect",
                  "kind": "organism",
                  "label": "Insect",
                  "radius": 14.0,
                  "x": 420.0,
                  "y": 220.0
                },
                {
                  "color": "#dc2626",
                  "id": "fox",
                  "kind": "organism",
                  "label": "Fox",
                  "radius": 20.0,
                  "x": 220.0,
                  "y": 90.0
                },
                {
                  "color": "#7c3aed",
                  "id": "hawk",
                  "kind": "organism",
                  "label": "Hawk",
                  "radius": 22.0,
                  "x": 400.0,
                  "y": 60.0
                }
              ],
              "description": "Five trophic species — producer (grass), herbivores (rabbit, insect), carnivore (fox), apex (hawk); radius encodes population size.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "kind": {
                    "name": "kind",
                    "required": false,
                    "type": "string",
                    "values": [
                      "cell",
                      "organelle",
                      "molecule",
                      "organism"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "domain",
              "type": "[BioNode]"
            },
            "running": {
              "default": true,
              "description": "When true the tick advances the phase and recomputes every species radius; toggle to start/pause.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current food-web scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "POPULATION_UPDATED",
              "payloadSchema": [
                {
                  "name": "nodes",
                  "type": "[BioNode]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "nodes",
              "phase",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "BioFoodwebState",
          "name": "BioFoodwebSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current food-web scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "POPULATION_UPDATED",
                "name": "Population Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[BioNode]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@config.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "POPULATION_UPDATED",
                    {
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.phase",
                  [
                    "+",
                    "@entity.phase",
                    3.0
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "fn",
                      "n",
                      [
                        "let",
                        [
                          [
                            "off",
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@n",
                                  "id"
                                ],
                                "grass"
                              ],
                              0.0,
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@n",
                                    "id"
                                  ],
                                  "rabbit"
                                ],
                                48.0,
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@n",
                                      "id"
                                    ],
                                    "insect"
                                  ],
                                  96.0,
                                  [
                                    "if",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@n",
                                        "id"
                                      ],
                                      "fox"
                                    ],
                                    144.0,
                                    192.0
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "tw",
                              [
                                "math/abs",
                                [
                                  "-",
                                  [
                                    "math/mod",
                                    [
                                      "+",
                                      "@entity.phase",
                                      "@off"
                                    ],
                                    240.0
                                  ],
                                  120.0
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nr",
                                [
                                  "+",
                                  12.0,
                                  [
                                    "*",
                                    "@tw",
                                    0.2
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@n",
                              {
                                "radius": "@nr"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@config.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "POPULATION_UPDATED",
                  {
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "foodwebTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}
