            "type": "boolean"
          }
        ],
        "name": "MathNumberlineState",
        "persistence": "runtime"
      },
      "name": "MathNumberlineEngineOrbital",
      "pages": [
        {
          "name": "MathNumberlineEnginePage",
          "path": "/math-numberline",
          "traits": [
            {
              "ref": "MathNumberlineSim"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "curves": {
              "default": [
                {
                  "color": "#94a3b8",
                  "label": "",
                  "samples": [
                    {
                      "x": -9.0,
                      "y": 0.0
                    },
                    {
                      "x": 9.0,
                      "y": 0.0
                    }
                  ]
                }
              ],
              "description": "The number line itself: a single horizontal segment along y=0 from x=-9 to x=9 in data coordinates.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "samples": {
                    "items": {
                      "properties": {
                        "x": {
                          "name": "x",
                          "required": true,
                          "type": "number"
                        },
                        "y": {
                          "name": "y",
                          "required": true,
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "name": "samples",
                    "required": false,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Curves",
              "tier": "domain",
              "type": "[MathCurve]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "points": {
              "default": [
                {
                  "color": "#94a3b8",
                  "label": "-9",
                  "radius": 2.0,
                  "x": -9.0,
                  "y": 0.0
                },
                {
