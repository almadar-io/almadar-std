                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "q2",
                  "label": "",
                  "radius": 10.0,
                  "vx": 0.0,
                  "vy": -3.0,
                  "x": 420.0,
                  "y": 150.0
                },
                {
                  "color": "#16a34a",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "q3",
                  "label": "",
                  "radius": 8.0,
                  "vx": 5.0,
                  "vy": 0.0,
                  "x": 320.0,
                  "y": 300.0
                }
              ],
              "description": "Initial charges; each traces its own circle of radius speed / qB — opposite-sign velocities give opposite rotation sense.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
