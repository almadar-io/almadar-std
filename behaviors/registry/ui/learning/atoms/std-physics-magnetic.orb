                  }
                },
                "type": "object"
              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[MagneticBody]"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "qB": {
              "default": 0.03,
              "description": "Charge times field strength; the perpendicular force it drives turns velocity into circular motion — circle radius equals speed divided by qB.",
              "label": "Magnetic Force (qB)",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Draw each body's velocity vector as an arrow.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "velocityScale": {
              "default": 10.0,
              "description": "Length multiplier for the velocity arrows.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052A82CJQTDBAMX28Q43X",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[MagneticBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG052A2WRJCTX2BKHRGTWAN",
          "linkedEntity": "MagneticState",
          "linkedEntityId": "ent_01KXG052A280CW1P9HMQE3EG5T",
          "name": "MagneticSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052A2VA61HHAQA0C279P7",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052A82CJQTDBAMX28Q43X",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[MagneticBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052A2VA61HHAQA0C279P7",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "ax",
                            [
                              "*",
                              "@config.qB",
                              [
                                "object/get",
                                "@b",
                                "vy"
                              ]
                            ]
                          ],
                          [
                            "ay",
                            [
                              "*",
                              [
                                "*",
                                -1.0,
                                "@config.qB"
                              ],
                              [
                                "object/get",
                                "@b",
                                "vx"
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nvx",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "vx"
                                ],
                                "@ax"
                              ]
                            ],
                            [
                              "nvy",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "vy"
                                ],
                                "@ay"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nx",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@b",
                                    "x"
                                  ],
                                  "@nvx"
                                ]
                              ],
                              [
                                "ny",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@b",
                                    "y"
                                  ],
                                  "@nvy"
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": "@nvx",
                                "vy": "@nvy",
                                "x": "@nx",
                                "y": "@ny"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "magneticTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}