              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current sequence scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "SEQUENCE_UPDATED",
              "eventId": "evt_01KXG051SZ2SMF84KXX2MSPD1C",
              "payloadSchema": [
                {
                  "name": "curves",
                  "type": "[MathCurve]"
                },
                {
                  "name": "points",
                  "type": "[MathPoint]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "curves",
              "phase",
              "points",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG051SXT6QAKDR41XYNDY56",
          "linkedEntity": "MathSequenceState",
          "linkedEntityId": "ent_01KXG051SX7PBV22HFQ1P41176",
          "name": "MathSequenceSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG051SX13M8C2Q1PT73WS3T",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current sequence scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG051SZ2SMF84KXX2MSPD1C",
                "key": "SEQUENCE_UPDATED",
                "name": "Sequence Updated",
                "payloadSchema": [
                  {
                    "name": "curves",
                    "type": "[MathCurve]"
                  },
                  {
                    "name": "points",
                    "type": "[MathPoint]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.curves",
                    "@config.curves"
                  ],
                  [
                    "set",
                    "@entity.points",
                    "@config.points"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "curves": "@entity.curves",
                      "height": "@config.height",
                      "points": "@entity.points",
                      "type": "math-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "SEQUENCE_UPDATED",
                    {
                      "curves": "@entity.curves",
                      "points": "@entity.points"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG051SX13M8C2Q1PT73WS3T",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "nphase",
                      [
                        "+",
                        "@entity.phase",
                        4.0
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "idx",
                        [
                          "math/mod",
                          [
                            "math/round",
                            [
                              "/",
                              "@nphase",
                              12.0
                            ]
                          ],
                          9.0
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "my",
                          [
                            "+",
                            "@config.a0",
                            [
                              "*",
                              "@idx",
                              "@config.d"
                            ]
                          ]
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "marker",
                            {
                              "color": "#dc2626",
                              "label": "term",
                              "radius": 8.0,
                              "x": "@idx",
                              "y": "@my"
                            }
                          ]
                        ],
                        [
                          "do",
                          [
                            "set",
                            "@entity.phase",
                            "@nphase"
                          ],
                          [
                            "set",
                            "@entity.points",
                            [
                              "array/append",
                              "@config.points",
                              "@marker"
                            ]
                          ],
                          [
                            "render-ui",
                            "main",
                            {
                              "curves": "@entity.curves",
                              "height": "@config.height",
                              "points": "@entity.points",
                              "type": "math-canvas",
                              "width": "@config.width"
                            }
                          ],
                          [
                            "emit",
                            "SEQUENCE_UPDATED",
                            {
                              "curves": "@entity.curves",
                              "points": "@entity.points"
                            }
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "sequenceTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}