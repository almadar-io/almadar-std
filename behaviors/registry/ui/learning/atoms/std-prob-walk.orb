{
  "description": "Random-walk engine — a cloud of walkers starts at the origin and random-steps each tick into a widening Gaussian on math-canvas.",
  "name": "std-prob-walk",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "radius": {
