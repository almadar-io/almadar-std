              },
              "type": "object"
            },
            "name": "points",
            "type": "array"
          },
          {
            "default": false,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "WalkState",
        "persistence": "runtime"
      },
      "name": "WalkEngineOrbital",
      "pages": [
        {
          "name": "WalkEnginePage",
          "path": "/prob-walk",
          "traits": [
            {
              "ref": "WalkSim"
            }
