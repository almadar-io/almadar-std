                  "x": 0.0,
                  "y": 0.0
                },
                {
                  "color": "#2563eb",
                  "label": "",
                  "radius": 4.0,
                  "x": 0.0,
                  "y": 0.0
                },
                {
                  "color": "#2563eb",
                  "label": "",
                  "radius": 4.0,
                  "x": 0.0,
                  "y": 0.0
                },
                {
                  "color": "#2563eb",
                  "label": "",
                  "radius": 4.0,
                  "x": 0.0,
                  "y": 0.0
                }
              ],
              "description": "24 walkers all seeded at the origin; the widening cloud IS the visual — one red walker tracks a single trajectory.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Points",
              "tier": "domain",
              "type": "[WalkPoint]"
            },
            "running": {
              "default": true,
              "description": "When true the tick random-walks every walker; toggle to start/pause the diffusion.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "step": {
              "default": 0.35,
              "description": "Half-width of each per-tick random displacement in data units; larger diffuses faster.",
              "label": "Step",
              "tier": "domain",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current walker cloud each tick — a composed listener (histogram, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "POINTS_UPDATED",
              "payloadSchema": [
                {
                  "name": "points",
                  "type": "[WalkPoint]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "points",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "WalkState",
          "name": "WalkSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current walker cloud each tick — a composed listener (histogram, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "POINTS_UPDATED",
                "name": "Points Updated",
                "payloadSchema": [
                  {
                    "name": "points",
                    "type": "[WalkPoint]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.points",
                    "@config.points"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "points": "@entity.points",
                      "type": "math-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "POINTS_UPDATED",
                    {
                      "points": "@entity.points"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "do",
                  [
                    "set",
                    "@entity.points",
                    [
                      "array/map",
                      "@entity.points",
                      [
                        "fn",
                        "p",
                        [
                          "let",
                          [
                            [
                              "nx",
                              [
                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@p",
                                    "x"
                                  ],
                                  [
                                    "-",
                                    [
                                      "*",
                                      [
                                        "math/random"
                                      ],
                                      [
                                        "*",
                                        2.0,
                                        "@config.step"
                                      ]
                                    ],
                                    "@config.step"
                                  ]
                                ],
                                -9.0,
                                9.0
                              ]
                            ],
                            [
                              "ny",
                              [
                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@p",
                                    "y"
                                  ],
                                  [
                                    "-",
                                    [
                                      "*",
                                      [
                                        "math/random"
                                      ],
                                      [
                                        "*",
                                        2.0,
                                        "@config.step"
                                      ]
                                    ],
                                    "@config.step"
                                  ]
                                ],
                                -9.0,
                                9.0
                              ]
                            ]
                          ],
                          [
                            "object/merge",
                            "@p",
                            {
                              "x": "@nx",
                              "y": "@ny"
                            }
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "points": "@entity.points",
                      "type": "math-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "POINTS_UPDATED",
                    {
                      "points": "@entity.points"
                    }
                  ]
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "walkTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}
