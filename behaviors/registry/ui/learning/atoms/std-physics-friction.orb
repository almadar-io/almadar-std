{
  "description": "Friction engine — decelerates sliding bodies via kinetic friction each tick and renders a physics-canvas.",
  "name": "std-physics-friction",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "fx": {
                  "name": "fx",
                  "required": false,
                  "type": "number"
                },
                "fy": {
                  "name": "fy",
                  "required": false,
                  "type": "number"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "radius": {
                  "name": "radius",
                  "required": false,
                  "type": "number"
                },
                "vx": {
                  "name": "vx",
                  "required": false,
                  "type": "number"
                },
                "vy": {
                  "name": "vy",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "bodies",
            "type": "array"
          },
          {
            "default": false,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "FrictionState",
        "persistence": "runtime"
      },
      "name": "FrictionEngineOrbital",
      "pages": [
        {
          "name": "FrictionEnginePage",
          "path": "/physics-friction",
          "traits": [
            {
              "ref": "FrictionSim"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "#f8fafc",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "bodies": {
              "default": [
                {
                  "color": "#2563eb",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-a",
                  "label": "A",
                  "radius": 14.0,
                  "vx": 6.0,
                  "vy": 0.0,
                  "x": 60.0,
                  "y": 386.0
                },
                {
                  "color": "#16a34a",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-b",
                  "label": "B",
                  "radius": 14.0,
                  "vx": 9.0,
                  "vy": 0.0,
                  "x": 85.0,
                  "y": 386.0
                },
                {
                  "color": "#dc2626",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-c",
                  "label": "C",
                  "radius": 14.0,
                  "vx": 13.0,
                  "vy": 0.0,
                  "x": 110.0,
                  "y": 386.0
                }
              ],
              "description": "Initial bodies; each carries position (x,y) and horizontal velocity (vx) sliding on the floor.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "fx": {
                    "name": "fx",
                    "required": false,
                    "type": "number"
                  },
                  "fy": {
                    "name": "fy",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "vx": {
                    "name": "vx",
                    "required": false,
                    "type": "number"
                  },
                  "vy": {
                    "name": "vy",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[FrictionBody]"
            },
            "friction": {
              "default": 0.12,
              "description": "Deceleration subtracted from each body's |vx| every tick until it reaches zero.",
              "label": "Friction",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels; sets the floor level.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Draw each body's velocity vector as an arrow.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "velocityScale": {
              "default": 8.0,
              "description": "Length multiplier for the velocity arrows.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels; bounds body movement.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[FrictionBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FrictionState",
          "name": "FrictionSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[FrictionBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@b",
                              "radius"
                            ]
                          ],
                          [
                            "d",
                            "@config.friction"
                          ],
                          [
                            "vx0",
                            [
                              "object/get",
                              "@b",
                              "vx"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nvx",
                              [
                                "if",
                                [
                                  ">",
                                  "@vx0",
                                  "@d"
                                ],
                                [
                                  "-",
                                  "@vx0",
                                  "@d"
                                ],
                                [
                                  "if",
                                  [
                                    "<",
                                    "@vx0",
                                    [
                                      "*",
                                      -1.0,
                                      "@d"
                                    ]
                                  ],
                                  [
                                    "+",
                                    "@vx0",
                                    "@d"
                                  ],
                                  0.0
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nx",
                                [
                                  "math/clamp",
                                  [
                                    "+",
                                    [
                                      "object/get",
                                      "@b",
                                      "x"
                                    ],
                                    "@nvx"
                                  ],
                                  "@r",
                                  [
                                    "-",
                                    "@config.width",
                                    "@r"
                                  ]
                                ]
                              ],
                              [
                                "ny",
                                [
                                  "-",
                                  "@config.height",
                                  "@r"
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": "@nvx",
                                "vy": 0.0,
                                "x": "@nx",
                                "y": "@ny"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "frictionTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}