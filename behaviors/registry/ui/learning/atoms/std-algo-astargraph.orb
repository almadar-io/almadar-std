                    "@config.goal"
                  ],
                  [
                    "set",
                    "@entity.goalX",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "nd",
                            [
                              "==",
                              [
                                "object/get",
                                "@nd",
                                "id"
                              ],
                              "@config.goal"
                            ]
                          ]
                        ]
                      ],
                      "x"
                    ]
                  ],
                  [
                    "set",
                    "@entity.goalY",
                    [
                      "object/get",
                      [
                        "array/first",
                        [
                          "array/filter",
                          "@entity.nodes",
                          [
                            "fn",
                            "nd",
                            [
                              "==",
                              [
                                "object/get",
                                "@nd",
                                "id"
                              ],
                              "@config.goal"
                            ]
                          ]
                        ]
