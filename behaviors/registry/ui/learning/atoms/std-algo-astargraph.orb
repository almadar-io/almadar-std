                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.openF",
                  [
                    "array/map",
                    [
                      "array/filter",
                      "@entity.gscore",
                      [
                        "fn",
                        "gs",
                        [
                          "and",
                          [
                            "not",
                            [
                              "array/includes",
                              "@entity.visited",
                              [
                                "object/get",
                                "@gs",
                                "id"
                              ]
                            ]
                          ],
                          [
                            "<",
                            [
                              "object/get",
                              "@gs",
                              "d"
                            ],
                            9999.0
                          ]
                        ]
                      ]
                    ],
                    [
                      "fn",
                      "gs",
                      [
                        "let",
                        [
                          [
                            "gid",
                            [
                              "object/get",
                              "@gs",
                              "id"
                            ]
                          ],
                          [
                            "gd",
                            [
                              "object/get",
                              "@gs",
                              "d"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nd",
                              [
                                "array/first",
                                [
                                  "array/filter",
                                  "@entity.nodes",
                                  [
                                    "fn",
                                    "n2",
                                    [
                                      "==",
                                      [
                                        "object/get",
                                        "@n2",
                                        "id"
                                      ],
                                      "@gid"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nx",
                                [
                                  "object/get",
                                  "@nd",
                                  "x"
                                ]
                              ],
                              [
                                "ny",
                                [
                                  "object/get",
                                  "@nd",
                                  "y"
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "hh",
                                  [
                                    "math/round",
                                    [
                                      "math/sqrt",
                                      [
                                        "+",
                                        [
                                          "*",
                                          [
                                            "-",
                                            "@nx",
                                            "@entity.goalX"
                                          ],
                                          [
                                            "-",
                                            "@nx",
                                            "@entity.goalX"
                                          ]
                                        ],
                                        [
                                          "*",
                                          [
