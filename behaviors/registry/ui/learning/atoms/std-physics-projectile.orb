                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[ProjectileBody]"
            },
            "damping": {
              "default": 0.995,
              "description": "Fraction of velocity retained each tick (air resistance).",
              "label": "Damping",
              "tier": "domain",
              "type": "number"
            },
            "gravity": {
              "default": 0.4,
              "description": "Downward acceleration added to each body's vy every tick.",
              "label": "Gravity",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels; bounds the bounce.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "restitution": {
              "default": 0.78,
              "description": "Fraction of speed kept when a body bounces off a wall.",
              "label": "Restitution",
              "tier": "domain",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Draw each body's velocity vector as an arrow.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "velocityScale": {
              "default": 8.0,
              "description": "Length multiplier for the velocity arrows.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels; bounds the bounce.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052GVJD1GY4DFPCQP553Q",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[ProjectileBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG052GQ9WVM6QVYCMTGHR30",
          "linkedEntity": "ProjectileState",
          "linkedEntityId": "ent_01KXG052GQCD90PRXJMB4KSKKA",
          "name": "ProjectileSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052GQ5A73VVQ28KMZ4FY6",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052GVJD1GY4DFPCQP553Q",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[ProjectileBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052GQ5A73VVQ28KMZ4FY6",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@b",
                              "radius"
                            ]
                          ],
                          [
                            "nvx",
                            [
                              "*",
                              [
                                "object/get",
                                "@b",
                                "vx"
                              ],
                              "@config.damping"
                            ]
                          ],
                          [
                            "nvy",
                            [
                              "*",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "vy"
                                ],
                                "@config.gravity"
                              ],
                              "@config.damping"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nx",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "x"
                                ],
                                "@nvx"
                              ]
                            ],
                            [
                              "ny",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "y"
                                ],
                                "@nvy"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "hitx",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@nx",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@nx",
                                    [
                                      "-",
                                      "@config.width",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "hity",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@ny",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@ny",
                                    [
                                      "-",
                                      "@config.height",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": [
                                  "if",
                                  "@hitx",
                                  [
                                    "*",
                                    "@nvx",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvx"
                                ],
                                "vy": [
                                  "if",
                                  "@hity",
                                  [
                                    "*",
                                    "@nvy",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvy"
                                ],
                                "x": [
                                  "math/clamp",
                                  "@nx",
                                  "@r",
                                  [
                                    "-",
                                    "@config.width",
                                    "@r"
                                  ]
                                ],
                                "y": [
                                  "math/clamp",
                                  "@ny",
                                  "@r",
                                  [
                                    "-",
                                    "@config.height",
                                    "@r"
                                  ]
                                ]
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "physicsTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}