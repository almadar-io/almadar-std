{
  "description": "Projectile-motion engine — integrates bodies under constant gravity with wall-bounce every tick and slots a canvas + controls. Composed by a learning orbital via `uses`.",
  "name": "std-physics-projectile",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "fx": {
