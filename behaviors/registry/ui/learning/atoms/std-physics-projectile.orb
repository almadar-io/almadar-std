                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "bodies",
            "type": "array"
          },
          {
            "default": false,
            "name": "running",
            "type": "boolean"
          }
        ],
        "name": "ProjectileState",
        "persistence": "runtime"
      },
      "name": "ProjectileEngineOrbital",
      "pages": [
        {
          "name": "ProjectileEnginePage",
          "path": "/physics-projectile",
          "traits": [
            {
              "ref": "ProjectileSim"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "bodies": {
              "default": [
                {
                  "color": "#2563eb",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-a",
                  "label": "A",
                  "radius": 16.0,
                  "vx": 5.0,
                  "vy": 0.0,
                  "x": 90.0,
                  "y": 70.0
                },
                {
                  "color": "#16a34a",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-b",
                  "label": "B",
                  "radius": 11.0,
                  "vx": -4.0,
                  "vy": 3.0,
                  "x": 320.0,
                  "y": 50.0
                }
              ],
              "description": "Initial bodies; each carries position (x,y) and velocity (vx,vy).",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "fx": {
                    "name": "fx",
                    "required": false,
                    "type": "number"
                  },
                  "fy": {
                    "name": "fy",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "vx": {
                    "name": "vx",
                    "required": false,
                    "type": "number"
                  },
                  "vy": {
                    "name": "vy",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[ProjectileBody]"
            },
            "damping": {
              "default": 0.995,
              "description": "Fraction of velocity retained each tick (air resistance).",
              "label": "Damping",
              "tier": "domain",
              "type": "number"
            },
            "gravity": {
              "default": 0.4,
              "description": "Downward acceleration added to each body's vy every tick.",
              "label": "Gravity",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels; bounds the bounce.",
              "label": "Height",
              "tier": "domain",
              "type": "number"
            },
            "restitution": {
              "default": 0.78,
              "description": "Fraction of speed kept when a body bounces off a wall.",
              "label": "Restitution",
              "tier": "domain",
              "type": "number"
            },
            "title": {
              "default": "Projectile Motion",
              "description": "Heading shown above the simulation.",
              "label": "Title",
              "tier": "presentation",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels; bounds the bounce.",
              "label": "Width",
              "tier": "domain",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ProjectileState",
          "name": "ProjectileSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "backgroundColor": "#f8fafc",
                              "bodies": "@entity.bodies",
                              "height": "@config.height",
                              "showForces": false,
                              "showVelocity": true,
                              "type": "physics-canvas",
                              "velocityScale": 8.0,
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    true
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "backgroundColor": "#f8fafc",
                              "bodies": "@entity.bodies",
                              "height": "@config.height",
                              "showForces": false,
                              "showVelocity": true,
                              "type": "physics-canvas",
                              "velocityScale": 8.0,
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "backgroundColor": "#f8fafc",
                              "bodies": "@entity.bodies",
                              "height": "@config.height",
                              "showForces": false,
                              "showVelocity": true,
                              "type": "physics-canvas",
                              "velocityScale": 8.0,
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "PAUSE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "backgroundColor": "#f8fafc",
                              "bodies": "@entity.bodies",
                              "height": "@config.height",
                              "showForces": false,
                              "showVelocity": true,
                              "type": "physics-canvas",
                              "velocityScale": 8.0,
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@b",
                              "radius"
                            ]
                          ],
                          [
                            "nvx",
                            [
                              "*",
                              [
                                "object/get",
                                "@b",
                                "vx"
                              ],
                              "@config.damping"
                            ]
                          ],
                          [
                            "nvy",
                            [
                              "*",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "vy"
                                ],
                                "@config.gravity"
                              ],
                              "@config.damping"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nx",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "x"
                                ],
                                "@nvx"
                              ]
                            ],
                            [
                              "ny",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "y"
                                ],
                                "@nvy"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "hitx",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@nx",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@nx",
                                    [
                                      "-",
                                      "@config.width",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "hity",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@ny",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@ny",
                                    [
                                      "-",
                                      "@config.height",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": [
                                  "if",
                                  "@hitx",
                                  [
                                    "*",
                                    "@nvx",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvx"
                                ],
                                "vy": [
                                  "if",
                                  "@hity",
                                  [
                                    "*",
                                    "@nvy",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvy"
                                ],
                                "x": [
                                  "math/clamp",
                                  "@nx",
                                  "@r",
                                  [
                                    "-",
                                    "@config.width",
                                    "@r"
                                  ]
                                ],
                                "y": [
                                  "math/clamp",
                                  "@ny",
                                  "@r",
                                  [
                                    "-",
                                    "@config.height",
                                    "@r"
                                  ]
                                ]
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "children": [
                          {
                            "content": "@config.title",
                            "type": "typography",
                            "variant": "h4"
                          },
                          {
                            "children": [
                              {
                                "action": "START",
                                "label": "Start",
                                "type": "button",
                                "variant": "primary"
                              },
                              {
                                "action": "PAUSE",
                                "label": "Pause",
                                "type": "button",
                                "variant": "secondary"
                              },
                              {
                                "action": "RESET",
                                "label": "Reset",
                                "type": "button",
                                "variant": "ghost"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "backgroundColor": "#f8fafc",
                            "bodies": "@entity.bodies",
                            "height": "@config.height",
                            "showForces": false,
                            "showVelocity": true,
                            "type": "physics-canvas",
                            "velocityScale": 8.0,
                            "width": "@config.width"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ],
                    "padding": "md",
                    "type": "box"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "physicsTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}