          "emits": [
            {
              "description": "The current cell scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "CELL_UPDATED",
              "eventId": "evt_01KXG051D1A87DR8YPF2PZ1QWM",
              "payloadSchema": [
                {
                  "name": "nodes",
                  "type": "[BioNode]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "nodes",
              "phase",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG051CYK5P0PQAWJMZ2GWD7",
          "linkedEntity": "BioCellState",
          "linkedEntityId": "ent_01KXG051CYPV2T3P7HNF8Q4VPW",
          "name": "BioCellSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG051CY6QPVRXPJ4X9ZSJHM",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current cell scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG051D1A87DR8YPF2PZ1QWM",
                "key": "CELL_UPDATED",
                "name": "Cell Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[BioNode]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@config.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "CELL_UPDATED",
                    {
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG051CY6QPVRXPJ4X9ZSJHM",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.phase",
                  [
                    "+",
                    "@entity.phase",
                    3.0
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "fn",
                      "n",
                      [
                        "if",
                        [
                          "=",
                          [
                            "object/get",
                            "@n",
                            "kind"
                          ],
                          "cell"
                        ],
                        "@n",
                        [
                          "let",
                          [
                            [
                              "off",
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@n",
                                    "id"
                                  ],
                                  "mitochondria"
                                ],
                                0.0,
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@n",
                                      "id"
                                    ],
                                    "ribosome"
                                  ],
                                  40.0,
                                  [
                                    "if",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@n",
                                        "id"
                                      ],
                                      "golgi"
                                    ],
                                    80.0,
                                    [
                                      "if",
                                      [
                                        "=",
                                        [
                                          "object/get",
                                          "@n",
                                          "id"
                                        ],
                                        "vacuole"
                                      ],
                                      120.0,
                                      160.0
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "tw",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    [
                                      "math/mod",
                                      [
                                        "+",
                                        "@entity.phase",
                                        "@off"
                                      ],
                                      240.0
                                    ],
                                    120.0
                                  ]
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "nr",
                                  [
                                    "+",
                                    12.0,
                                    [
                                      "*",
                                      "@tw",
                                      0.05
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "object/merge",
                                "@n",
                                {
                                  "radius": "@nr"
                                }
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@config.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "CELL_UPDATED",
                  {
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "cellTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}