              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "SYSTEM_UPDATED",
              "eventId": "evt_01KXG051Q3A5VF6B2E6T5XP1JJ",
              "payloadSchema": [
                {
                  "name": "curves",
                  "type": "[MathCurve]"
                },
                {
                  "name": "points",
                  "type": "[MathPoint]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "curves",
              "phase",
              "points",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG051Q1C92MBZ7RB9FD67ZV",
          "linkedEntity": "MathLinearState",
          "linkedEntityId": "ent_01KXG051Q17EEGJECYZV2425AH",
          "name": "MathLinearSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "SYSTEM_UPDATED",
                "name": "System Updated",
                "payloadSchema": [
                  {
                    "name": "curves",
                    "type": "[MathCurve]"
                  },
                  {
                    "name": "points",
                    "type": "[MathPoint]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.curves",
                    "@config.curves"
                  ],
                  [
                    "set",
                    "@entity.points",
                    "@config.points"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "curves": "@entity.curves",
                      "height": "@config.height",
                      "points": "@entity.points",
                      "type": "math-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "SYSTEM_UPDATED",
                    {
                      "curves": "@entity.curves",
                      "points": "@entity.points"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "let",
                  [
                    [
                      "nphase",
                      [
                        "+",
                        "@entity.phase",
                        3.0
                      ]
                    ]
                  ],
                  [
                    "let",
                    [
                      [
                        "tw",
                        [
                          "-",
                          [
                            "/",
                            [
                              "math/abs",
                              [
                                "-",
                                [
                                  "math/mod",
                                  "@nphase",
                                  240.0
                                ],
                                120.0
                              ]
                            ],
                            120.0
                          ],
                          0.5
                        ]
                      ]
                    ],
                    [
                      "let",
                      [
                        [
                          "mA",
                          [
                            "*",
                            "@tw",
                            1.2
                          ]
                        ],
                        [
                          "mB",
                          "@config.mB"
                        ]
                      ],
                      [
                        "let",
                        [
                          [
                            "denom",
                            [
                              "if",
                              [
                                "<",
                                [
                                  "math/abs",
                                  [
                                    "-",
                                    "@mA",
                                    "@mB"
                                  ]
                                ],
                                0.05
                              ],
                              0.05,
                              [
                                "-",
                                "@mA",
                                "@mB"
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "aInt",
                              [
                                "+",
                                -2.0,
                                [
                                  "*",
                                  3.0,
                                  "@mA"
                                ]
                              ]
                            ],
                            [
                              "bInt",
                              [
                                "-",
                                2.0,
                                [
                                  "*",
                                  3.0,
                                  "@mB"
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "xstar",
                                [
                                  "/",
                                  [
                                    "-",
                                    "@bInt",
                                    "@aInt"
                                  ],
                                  "@denom"
                                ]
                              ]
                            ],
                            [
                              "let",
                              [
                                [
                                  "ystar",
                                  [
                                    "+",
                                    -2.0,
                                    [
                                      "*",
                                      "@mA",
                                      [
                                        "+",
                                        "@xstar",
                                        3.0
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "let",
                                [
                                  [
                                    "lineA",
                                    {
                                      "color": "#2563eb",
                                      "label": "A",
                                      "samples": [
                                        {
                                          "x": -9.0,
                                          "y": [
                                            "+",
                                            -2.0,
                                            [
                                              "*",
                                              "@mA",
                                              -6.0
                                            ]
                                          ]
                                        },
                                        {
                                          "x": 9.0,
                                          "y": [
                                            "+",
                                            -2.0,
                                            [
                                              "*",
                                              "@mA",
                                              12.0
                                            ]
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                ],
                                [
                                  "let",
                                  [
                                    [
                                      "lineB",
                                      {
                                        "color": "#16a34a",
                                        "label": "B",
                                        "samples": [
                                          {
                                            "x": -9.0,
                                            "y": [
                                              "+",
                                              2.0,
                                              [
                                                "*",
                                                "@mB",
                                                -12.0
                                              ]
                                            ]
                                          },
                                          {
                                            "x": 9.0,
                                            "y": [
                                              "+",
                                              2.0,
                                              [
                                                "*",
                                                "@mB",
                                                6.0
                                              ]
                                            ]
                                          }
                                        ]
                                      }
                                    ]
                                  ],
                                  [
                                    "let",
                                    [
                                      [
                                        "solutionPoint",
                                        {
                                          "color": "#dc2626",
                                          "label": "solution",
                                          "radius": 6.0,
                                          "x": "@xstar",
                                          "y": "@ystar"
                                        }
                                      ]
                                    ],
                                    [
                                      "do",
                                      [
                                        "set",
                                        "@entity.phase",
                                        "@nphase"
                                      ],
                                      [
                                        "set",
                                        "@entity.curves",
                                        [
                                          "@lineA",
                                          "@lineB"
                                        ]
                                      ],
                                      [
                                        "set",
                                        "@entity.points",
                                        [
                                          "@solutionPoint"
                                        ]
                                      ],
                                      [
                                        "render-ui",
                                        "main",
                                        {
                                          "curves": "@entity.curves",
                                          "height": "@config.height",
                                          "points": "@entity.points",
                                          "type": "math-canvas",
                                          "width": "@config.width"
                                        }
                                      ],
                                      [
                                        "emit",
                                        "SYSTEM_UPDATED",
                                        {
                                          "curves": "@entity.curves",
                                          "points": "@entity.points"
                                        }
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "linearTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}