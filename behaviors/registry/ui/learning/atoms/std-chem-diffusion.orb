          },
          "emits": [
            {
              "description": "The current atom scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "ATOMS_UPDATED",
              "eventId": "evt_01KXG051K32R6A4AHZATX1EQHQ",
              "payloadSchema": [
                {
                  "name": "atoms",
                  "type": "[ChemAtom]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "atoms",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "id": "trt_01KXG051K16K582S4TTZCBBW2F",
          "linkedEntity": "ChemDiffusionState",
          "linkedEntityId": "ent_01KXG051K1V9K9DMPQF717AAVW",
          "name": "ChemDiffusionSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current atom scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "ATOMS_UPDATED",
                "name": "Atoms Updated",
                "payloadSchema": [
                  {
                    "name": "atoms",
                    "type": "[ChemAtom]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.atoms",
                    "@config.atoms"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "atoms": "@entity.atoms",
                      "backgroundColor": "@config.backgroundColor",
                      "height": "@config.height",
                      "type": "chemistry-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "ATOMS_UPDATED",
                    {
                      "atoms": "@entity.atoms"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.atoms",
                  [
                    "array/map",
                    "@entity.atoms",
                    [
                      "fn",
                      "a",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@a",
                              "radius"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nx",
                              [
                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@a",
                                    "x"
                                  ],
                                  [
                                    "-",
                                    [
                                      "*",
                                      [
                                        "math/random"
                                      ],
                                      6.0
                                    ],
                                    3.0
                                  ]
                                ],
                                "@r",
                                [
                                  "-",
                                  "@config.width",
                                  "@r"
                                ]
                              ]
                            ],
                            [
                              "ny",
                              [
                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@a",
                                    "y"
                                  ],
                                  [
                                    "-",
                                    [
                                      "*",
                                      [
                                        "math/random"
                                      ],
                                      6.0
                                    ],
                                    3.0
                                  ]
                                ],
                                "@r",
                                [
                                  "-",
                                  "@config.height",
                                  "@r"
                                ]
                              ]
                            ]
                          ],
                          [
                            "object/merge",
                            "@a",
                            {
                              "x": "@nx",
                              "y": "@ny"
                            }
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "atoms": "@entity.atoms",
                    "backgroundColor": "@config.backgroundColor",
                    "height": "@config.height",
                    "type": "chemistry-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "ATOMS_UPDATED",
                  {
                    "atoms": "@entity.atoms"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "diffusionTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}