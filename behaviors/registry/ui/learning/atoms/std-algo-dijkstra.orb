          "id": "trt_01KXG050QM9JE8PJSJRA8X9868",
          "linkedEntity": "DijkstraScene",
          "linkedEntityId": "ent_01KXG050QM6MXBK94PY920BBFW",
          "name": "DijkstraSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG050QME7YH35T4QXQD3KQG",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The graph each step — a composed listener can subscribe; a harmless no-op standalone.",
                "id": "evt_01KXG050QPWE0HRSYV3FN9TR0G",
                "key": "NODES_UPDATED",
                "name": "Nodes Updated",
                "payloadSchema": [
                  {
                    "name": "nodes",
                    "type": "[GraphNode]"
                  },
                  {
                    "name": "edges",
                    "type": "[GraphEdge]"
                  }
                ],
                "synonyms": "tick, frame, step, relax, settle, shortest, path",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.edges",
                    "@config.edges"
                  ],
                  [
                    "set",
                    "@entity.wedges",
                    "@config.wedges"
                  ],
                  [
                    "set",
                    "@entity.dists",
                    "@config.dists"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "set",
                    "@entity.visited",
                    []
                  ],
                  [
                    "set",
                    "@entity.cur",
                    ""
                  ],
                  [
                    "set",
                    "@entity.minD",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.distU",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.done",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "edges": "@entity.edges",
                      "height": "@config.height",
                      "nodes": "@entity.nodes",
                      "type": "biology-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "NODES_UPDATED",
                    {
                      "edges": "@entity.edges",
                      "nodes": "@entity.nodes"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG050QME7YH35T4QXQD3KQG",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.minD",
                  [
                    "array/min",
                    [
                      "array/map",
                      [
                        "array/filter",
                        "@entity.dists",
                        [
                          "fn",
                          "dd",
                          [
                            "not",
                            [
                              "array/includes",
                              "@entity.visited",
                              [
                                "object/get",
                                "@dd",
                                "id"
                              ]
                            ]
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "dd",
                        [
                          "object/get",
                          "@dd",
                          "d"
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.cur",
                  [
                    "object/get",
                    [
                      "array/first",
                      [
                        "array/filter",
                        "@entity.dists",
                        [
                          "fn",
                          "dd",
                          [
                            "and",
                            [
                              "not",
                              [
                                "array/includes",
                                "@entity.visited",
                                [
                                  "object/get",
                                  "@dd",
                                  "id"
                                ]
                              ]
                            ],
                            [
                              "==",
                              [
                                "object/get",
                                "@dd",
                                "d"
                              ],
                              "@entity.minD"
                            ]
                          ]
                        ]
                      ]
                    ],
                    "id"
                  ]
                ],
                [
                  "set",
                  "@entity.distU",
                  "@entity.minD"
                ],
                [
                  "set",
                  "@entity.visited",
                  [
                    "array/append",
                    "@entity.visited",
                    "@entity.cur"
                  ]
                ],
                [
                  "set",
                  "@entity.dists",
                  [
                    "array/map",
                    "@entity.dists",
                    [
                      "fn",
                      "row",
                      [
                        "let",
                        [
                          [
                            "nid",
                            [
                              "object/get",
                              "@row",
                              "id"
                            ]
                          ],
                          [
                            "dcur",
                            [
                              "object/get",
                              "@row",
                              "d"
                            ]
                          ]
                        ],
                        [
                          "object/merge",
                          "@row",
                          {
                            "d": [
                              "let",
                              [
                                [
                                  "matches",
                                  [
                                    "array/filter",
                                    "@entity.wedges",
                                    [
                                      "fn",
                                      "w",
                                      [
                                        "or",
                                        [
                                          "and",
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@w",
                                              "from"
                                            ],
                                            "@entity.cur"
                                          ],
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@w",
                                              "to"
                                            ],
                                            "@nid"
                                          ]
                                        ],
                                        [
                                          "and",
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@w",
                                              "from"
                                            ],
                                            "@nid"
                                          ],
                                          [
                                            "==",
                                            [
                                              "object/get",
                                              "@w",
                                              "to"
                                            ],
                                            "@entity.cur"
                                          ]
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "if",
                                [
                                  "==",
                                  [
                                    "array/len",
                                    "@matches"
                                  ],
                                  0.0
                                ],
                                "@dcur",
                                [
                                  "let",
                                  [
                                    [
                                      "ww",
                                      [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@matches"
                                        ],
                                        "w"
                                      ]
                                    ]
                                  ],
                                  [
                                    "if",
                                    [
                                      "<",
                                      [
                                        "+",
                                        "@entity.distU",
                                        "@ww"
                                      ],
                                      "@dcur"
                                    ],
                                    [
                                      "+",
                                      "@entity.distU",
                                      "@ww"
                                    ],
                                    "@dcur"
                                  ]
                                ]
                              ]
                            ]
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.nodes",
                  [
                    "array/map",
                    "@entity.nodes",
                    [
                      "fn",
                      "nd",
                      [
                        "let",
                        [
                          [
                            "nid",
                            [
                              "object/get",
                              "@nd",
                              "id"
                            ]
                          ]
                        ],
                        [
                          "object/merge",
                          "@nd",
                          {
                            "color": [
                              "if",
                              [
                                "==",
                                "@nid",
                                "@entity.cur"
                              ],
                              "#3b82f6",
                              [
                                "if",
                                [
                                  "array/includes",
                                  "@entity.visited",
                                  "@nid"
                                ],
                                "#22c55e",
                                [
                                  "let",
                                  [
                                    [
                                      "drec",
                                      [
                                        "array/first",
                                        [
                                          "array/filter",
                                          "@entity.dists",
                                          [
                                            "fn",
                                            "dd",
                                            [
                                              "==",
                                              [
                                                "object/get",
                                                "@dd",
                                                "id"
                                              ],
                                              "@nid"
                                            ]
                                          ]
                                        ]
                                      ]
                                    ]
                                  ],
                                  [
                                    "if",
                                    [
                                      "<",
                                      [
                                        "object/get",
                                        "@drec",
                                        "d"
                                      ],
                                      9999.0
                                    ],
                                    "#f59e0b",
                                    "#64748b"
                                  ]
                                ]
                              ]
                            ]
                          }
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    "==",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@entity.dists",
                        [
                          "fn",
                          "dd",
                          [
                            "and",
                            [
                              "not",
                              [
                                "array/includes",
                                "@entity.visited",
                                [
                                  "object/get",
                                  "@dd",
                                  "id"
                                ]
                              ]
                            ],
                            [
                              "<",
                              [
                                "object/get",
                                "@dd",
                                "d"
                              ],
                              9999.0
                            ]
                          ]
                        ]
                      ]
                    ],
                    0.0
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "edges": "@entity.edges",
                    "height": "@config.height",
                    "nodes": "@entity.nodes",
                    "type": "biology-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "NODES_UPDATED",
                  {
                    "edges": "@entity.edges",
                    "nodes": "@entity.nodes"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 500.0,
              "name": "dijkstraTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}