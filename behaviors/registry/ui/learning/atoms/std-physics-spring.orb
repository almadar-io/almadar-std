        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "anchorX": {
              "default": 300.0,
              "description": "Horizontal position each body oscillates around.",
              "label": "Anchor X",
              "tier": "domain",
              "type": "number"
            },
            "backgroundColor": {
              "default": "#f8fafc",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "bodies": {
              "default": [
                {
                  "color": "#2563eb",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-a",
                  "label": "A",
                  "radius": 14.0,
                  "vx": 0.0,
                  "vy": 0.0,
                  "x": 120.0,
                  "y": 200.0
                },
                {
                  "color": "#16a34a",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-b",
                  "label": "B",
                  "radius": 14.0,
                  "vx": 0.0,
                  "vy": 0.0,
                  "x": 300.0,
                  "y": 200.0
                },
                {
                  "color": "#dc2626",
                  "fx": 0.0,
                  "fy": 0.0,
                  "id": "ball-c",
                  "label": "C",
                  "radius": 14.0,
                  "vx": 0.0,
                  "vy": 0.0,
                  "x": 480.0,
                  "y": 200.0
                }
              ],
              "description": "Initial bodies; each oscillates around anchorX (300) by Hooke's law.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
