              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[SpringBody]"
            },
            "damping": {
              "default": 0.99,
              "description": "Fraction of velocity retained each tick (energy loss).",
              "label": "Damping",
              "tier": "domain",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick integrates; toggle to start/pause the sim.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Draw each body's velocity vector as an arrow.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "springK": {
              "default": 0.02,
              "description": "Restoring-force strength pulling each body toward the anchor (Hooke's law k).",
              "label": "Spring Constant",
              "tier": "domain",
              "type": "number"
            },
            "velocityScale": {
              "default": 10.0,
              "description": "Length multiplier for the velocity arrows.",
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels; bounds body position.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "BODIES_UPDATED",
              "eventId": "evt_01KXG052KV72X3J34444NFH9DB",
              "payloadSchema": [
                {
                  "name": "bodies",
                  "type": "[SpringBody]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bodies",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "SpringState": "ent_01KXG052KS9ERAQ5CFK0ZJ86XX"
          },
          "id": "trt_01KXG052KSAEBGV656J4G2TMSH",
          "linkedEntity": "SpringState",
          "linkedEntityId": "ent_01KXG052KS9ERAQ5CFK0ZJ86XX",
          "name": "SpringSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG052KSDNVA0E84GMD9F2DC",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "id": "evt_01KXG052KV72X3J34444NFH9DB",
                "key": "BODIES_UPDATED",
                "name": "Bodies Updated",
                "payloadSchema": [
                  {
                    "name": "bodies",
                    "type": "[SpringBody]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bodies": "@entity.bodies",
                      "height": "@config.height",
                      "showForces": false,
                      "showVelocity": "@config.showVelocity",
                      "type": "physics-canvas",
                      "velocityScale": "@config.velocityScale",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BODIES_UPDATED",
                    {
                      "bodies": "@entity.bodies"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG052KSDNVA0E84GMD9F2DC",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "a",
                            [
                              "*",
                              [
                                "*",
                                -1.0,
                                "@config.springK"
                              ],
                              [
                                "-",
                                [
                                  "object/get",
                                  "@b",
                                  "x"
                                ],
                                "@config.anchorX"
                              ]
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nvx",
                              [
                                "*",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@b",
                                    "vx"
                                  ],
                                  "@a"
                                ],
                                "@config.damping"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nx",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@b",
                                    "x"
                                  ],
                                  "@nvx"
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": "@nvx",
                                "x": [
                                  "math/clamp",
                                  "@nx",
                                  [
                                    "object/get",
                                    "@b",
                                    "radius"
                                  ],
                                  [
                                    "-",
                                    "@config.width",
                                    [
                                      "object/get",
                                      "@b",
                                      "radius"
                                    ]
                                  ]
                                ]
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bodies": "@entity.bodies",
                    "height": "@config.height",
                    "showForces": false,
                    "showVelocity": "@config.showVelocity",
                    "type": "physics-canvas",
                    "velocityScale": "@config.velocityScale",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BODIES_UPDATED",
                  {
                    "bodies": "@entity.bodies"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "springTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}