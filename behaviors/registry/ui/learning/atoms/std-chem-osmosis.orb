              ],
              "description": "Six large purple solute (S) atoms confined right of the membrane plus twelve small blue water (W) atoms that cross freely; water biases rightward each tick, so it accumulates on the solute side.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "element": {
                    "name": "element",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Atoms",
              "tier": "domain",
              "type": "[ChemAtom]"
            },
            "backgroundColor": {
              "default": "#f8fafc",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "height": {
              "default": 400.0,
              "description": "Simulation height in pixels; bounds the random walk.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick random-walks every atom; toggle to start/pause osmosis.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "shapes": {
              "default": [
                {
                  "color": "#64748b",
                  "id": "membrane",
                  "lineWidth": 4.0,
                  "type": "line",
                  "x1": 300.0,
                  "x2": 300.0,
                  "y1": 20.0,
                  "y2": 380.0
                }
              ],
              "description": "The vertical semipermeable membrane down the canvas middle (x=width/2); solute cannot cross it, water can.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "lineWidth": {
                    "name": "lineWidth",
                    "required": false,
                    "type": "number"
                  },
                  "type": {
                    "name": "type",
                    "required": true,
                    "type": "string",
                    "values": [
                      "line",
                      "arrow",
                      "circle",
                      "rect",
                      "polygon",
                      "path",
                      "text",
                      "axis",
                      "grid"
                    ]
                  },
                  "x1": {
                    "name": "x1",
                    "required": false,
                    "type": "number"
                  },
                  "x2": {
                    "name": "x2",
                    "required": false,
                    "type": "number"
                  },
                  "y1": {
                    "name": "y1",
                    "required": false,
                    "type": "number"
                  },
                  "y2": {
                    "name": "y2",
                    "required": false,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Shapes",
              "tier": "domain",
              "type": "[ChemShape]"
            },
            "width": {
              "default": 600.0,
              "description": "Simulation width in pixels; the membrane sits at width/2.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current atom scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
              "event": "ATOMS_UPDATED",
              "payloadSchema": [
                {
                  "name": "atoms",
                  "type": "[ChemAtom]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "atoms",
              "running"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "ChemOsmosisState",
          "name": "ChemOsmosisSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current atom scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone.",
                "key": "ATOMS_UPDATED",
                "name": "Atoms Updated",
                "payloadSchema": [
                  {
                    "name": "atoms",
                    "type": "[ChemAtom]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.atoms",
                    "@config.atoms"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "atoms": "@entity.atoms",
                      "backgroundColor": "@config.backgroundColor",
                      "height": "@config.height",
                      "shapes": "@config.shapes",
                      "type": "chemistry-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "ATOMS_UPDATED",
                    {
                      "atoms": "@entity.atoms"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.atoms",
                  [
                    "array/map",
                    "@entity.atoms",
                    [
                      "fn",
                      "a",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@a",
                              "radius"
                            ]
                          ],
                          [
                            "mx",
                            [
                              "/",
                              "@config.width",
                              2.0
                            ]
                          ],
                          [
                            "isWater",
                            [
                              "=",
                              [
                                "object/get",
                                "@a",
                                "element"
                              ],
                              "W"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "bias",
                              [
                                "if",
                                "@isWater",
                                0.4,
                                0.0
                              ]
                            ],
                            [
                              "loX",
                              [
                                "if",
                                "@isWater",
                                "@r",
                                [
                                  "+",
                                  "@mx",
                                  "@r"
                                ]
                              ]
                            ],
                            [
                              "ny",
                              [
                                "math/clamp",
                                [
                                  "+",
                                  [
                                    "object/get",
                                    "@a",
                                    "y"
                                  ],
                                  [
                                    "-",
                                    [
                                      "*",
                                      [
                                        "math/random"
                                      ],
                                      6.0
                                    ],
                                    3.0
                                  ]
                                ],
                                "@r",
                                [
                                  "-",
                                  "@config.height",
                                  "@r"
                                ]
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "nx",
                                [
                                  "math/clamp",
                                  [
                                    "+",
                                    [
                                      "+",
                                      [
                                        "object/get",
                                        "@a",
                                        "x"
                                      ],
                                      [
                                        "-",
                                        [
                                          "*",
                                          [
                                            "math/random"
                                          ],
                                          6.0
                                        ],
                                        3.0
                                      ]
                                    ],
                                    "@bias"
                                  ],
                                  "@loX",
                                  [
                                    "-",
                                    "@config.width",
                                    "@r"
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@a",
                              {
                                "x": "@nx",
                                "y": "@ny"
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "atoms": "@entity.atoms",
                    "backgroundColor": "@config.backgroundColor",
                    "height": "@config.height",
                    "shapes": "@config.shapes",
                    "type": "chemistry-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "ATOMS_UPDATED",
                  {
                    "atoms": "@entity.atoms"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "osmosisTick"
            }
          ]
        }
      ]
    }
  ],
  "version": "1.0.0"
}
