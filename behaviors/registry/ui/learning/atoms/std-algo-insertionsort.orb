        "owner": "workspace",
        "renames": []
      },
      "pag_01KXG0510AEQXWQ47VSDZS7JXP": {
        "bakedName": "InsertionSortEnginePage",
        "curName": "InsertionSortEnginePage",
        "id": "pag_01KXG0510AEQXWQ47VSDZS7JXP",
        "kind": "page",
        "owner": "workspace",
        "renames": []
      },
      "trt_01KXG0510969PHP42WABHH2KP5": {
        "bakedName": "InsertionSortSim",
        "curName": "InsertionSortSim",
        "id": "trt_01KXG0510969PHP42WABHH2KP5",
        "kind": "trait",
        "owner": "workspace",
        "renames": []
      }
    },
    "schemaVersion": 1
  },
  "name": "std-algo-insertionsort",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "bars",
            "type": "array"
          },
          {
            "default": 1.0,
            "name": "i",
            "type": "number"
          },
          {
            "default": 1.0,
            "name": "j",
            "type": "number"
          },
          {
            "default": false,
            "name": "shift",
            "type": "boolean"
          },
          {
            "default": false,
            "name": "done",
            "type": "boolean"
          },
          {
            "default": true,
            "name": "running",
            "type": "boolean"
          }
        ],
        "id": "ent_01KXG051090ZA64MBDM79S2G75",
        "name": "InsertionScene",
        "persistence": "runtime"
      },
      "id": "orb_01KXG05109S1HRXNJWF79SV57R",
      "name": "InsertionSortEngineOrbital",
      "pages": [
        {
          "id": "pag_01KXG0510AEQXWQ47VSDZS7JXP",
          "name": "InsertionSortEnginePage",
          "path": "/algo-insertionsort",
          "traits": [
            {
              "ref": "InsertionSortSim",
              "refId": "trt_01KXG0510969PHP42WABHH2KP5"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "backgroundColor": {
              "default": "#f8fafc",
              "description": "Canvas background color.",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "bars": {
              "default": [
                {
                  "color": "#3b82f6",
                  "label": "5",
                  "value": 5.0
                },
                {
                  "color": "#3b82f6",
                  "label": "2",
                  "value": 2.0
                },
                {
                  "color": "#3b82f6",
                  "label": "8",
                  "value": 8.0
                },
                {
                  "color": "#3b82f6",
                  "label": "1",
                  "value": 1.0
                },
                {
                  "color": "#3b82f6",
                  "label": "9",
                  "value": 9.0
                },
                {
                  "color": "#3b82f6",
                  "label": "3",
                  "value": 3.0
                },
                {
                  "color": "#3b82f6",
                  "label": "7",
                  "value": 7.0
                },
                {
                  "color": "#3b82f6",
                  "label": "4",
                  "value": 4.0
                }
              ],
              "description": "Initial unsorted array; each bar's height is proportional to its value.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "value": {
                    "name": "value",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bars",
              "tier": "domain",
              "type": "[AlgoBar]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "running": {
              "default": true,
              "description": "When true the tick performs one shift/settle step; toggle to start/pause the sort.",
              "label": "Running",
              "tier": "domain",
              "type": "boolean"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "emits": [
            {
              "description": "The current bar array each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone.",
              "event": "BARS_UPDATED",
              "eventId": "evt_01KXG0510AFKEJ8HR8X47P54QK",
              "payloadSchema": [
                {
                  "name": "bars",
                  "type": "[AlgoBar]"
                }
              ],
              "scope": "external",
              "synonyms": "tick, frame, step, redraw, compare, shift, insert",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "bars",
              "done",
              "i",
              "j",
              "running",
              "shift"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "entityRefIds": {
            "InsertionScene": "ent_01KXG051090ZA64MBDM79S2G75"
          },
          "id": "trt_01KXG0510969PHP42WABHH2KP5",
          "linkedEntity": "InsertionScene",
          "linkedEntityId": "ent_01KXG051090ZA64MBDM79S2G75",
          "name": "InsertionSortSim",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "id": "evt_01KXG0510956X911HE1ZTPKEZ1",
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The current bar array each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone.",
                "id": "evt_01KXG0510AFKEJ8HR8X47P54QK",
                "key": "BARS_UPDATED",
                "name": "Bars Updated",
                "payloadSchema": [
                  {
                    "name": "bars",
                    "type": "[AlgoBar]"
                  }
                ],
                "synonyms": "tick, frame, step, redraw, compare, shift, insert",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.bars",
                    "@config.bars"
                  ],
                  [
                    "set",
                    "@entity.running",
                    "@config.running"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "backgroundColor": "@config.backgroundColor",
                      "bars": "@entity.bars",
                      "height": "@config.height",
                      "type": "algorithm-canvas",
                      "width": "@config.width"
                    }
                  ],
                  [
                    "emit",
                    "BARS_UPDATED",
                    {
                      "bars": "@entity.bars"
                    }
                  ]
                ],
                "event": "INIT",
                "eventId": "evt_01KXG0510956X911HE1ZTPKEZ1",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.shift",
                  [
                    "and",
                    [
                      ">=",
                      "@entity.j",
                      1.0
                    ],
                    [
                      ">",
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@entity.bars",
                          [
                            "-",
                            "@entity.j",
                            1.0
                          ]
                        ],
                        "value"
                      ],
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@entity.bars",
                          "@entity.j"
                        ],
                        "value"
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.bars",
                  [
                    "let",
                    [
                      [
                        "a",
                        [
                          "array/nth",
                          "@entity.bars",
                          [
                            "-",
                            "@entity.j",
                            1.0
                          ]
                        ]
                      ],
                      [
                        "b",
                        [
                          "array/nth",
                          "@entity.bars",
                          "@entity.j"
                        ]
                      ]
                    ],
                    [
                      "array/map",
                      "@entity.bars",
                      [
                        "object/merge",
                        "@item",
                        {
                          "color": [
                            "if",
                            [
                              "==",
                              "@index",
                              "@entity.j"
                            ],
                            "#f59e0b",
                            [
                              "if",
                              [
                                "or",
                                [
                                  "<",
                                  "@index",
                                  "@entity.i"
                                ],
                                [
                                  ">=",
                                  "@entity.i",
                                  [
                                    "array/len",
                                    "@entity.bars"
                                  ]
                                ]
                              ],
                              "#22c55e",
                              "#3b82f6"
                            ]
                          ],
                          "value": [
                            "if",
                            [
                              "and",
                              "@entity.shift",
                              [
                                "==",
                                "@index",
                                [
                                  "-",
                                  "@entity.j",
                                  1.0
                                ]
                              ]
                            ],
                            [
                              "object/get",
                              "@b",
                              "value"
                            ],
                            [
                              "if",
                              [
                                "and",
                                "@entity.shift",
                                [
                                  "==",
                                  "@index",
                                  "@entity.j"
                                ]
                              ],
                              [
                                "object/get",
                                "@a",
                                "value"
                              ],
                              [
                                "object/get",
                                "@item",
                                "value"
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.i",
                  [
                    "if",
                    "@entity.shift",
                    "@entity.i",
                    [
                      "+",
                      "@entity.i",
                      1.0
                    ]
                  ]
                ],
                [
                  "set",
                  "@entity.j",
                  [
                    "if",
                    "@entity.shift",
                    [
                      "-",
                      "@entity.j",
                      1.0
                    ],
                    "@entity.i"
                  ]
                ],
                [
                  "set",
                  "@entity.done",
                  [
                    ">=",
                    "@entity.i",
                    [
                      "array/len",
                      "@entity.bars"
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "backgroundColor": "@config.backgroundColor",
                    "bars": "@entity.bars",
                    "height": "@config.height",
                    "type": "algorithm-canvas",
                    "width": "@config.width"
                  }
                ],
                [
                  "emit",
                  "BARS_UPDATED",
                  {
                    "bars": "@entity.bars"
                  }
                ]
              ],
              "guard": [
                "and",
                "@entity.running",
                [
                  "not",
                  "@entity.done"
                ]
              ],
              "interval": 300.0,
              "name": "insertionTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}