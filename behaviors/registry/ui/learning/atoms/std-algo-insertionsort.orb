{
  "description": "CS-education visualizer (algorithm-canvas): Insertion-sort engine — one shift/settle step per tick over a bar array on algorithm-canvas; composed by a learning orbital via `uses`.",
  "ledger": {
    "entries": {
      "ent_01KXG051090ZA64MBDM79S2G75": {
        "bakedName": "InsertionScene",
        "curName": "InsertionScene",
        "id": "ent_01KXG051090ZA64MBDM79S2G75",
