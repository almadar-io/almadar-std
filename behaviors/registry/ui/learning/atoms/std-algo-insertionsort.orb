        "renames": []
      },
      "evt_01KXG0510956X911HE1ZTPKEZ1": {
        "bakedName": "INIT",
        "curName": "INIT",
        "id": "evt_01KXG0510956X911HE1ZTPKEZ1",
        "kind": "event",
        "owner": "workspace",
        "parent": "trt_01KXG0510969PHP42WABHH2KP5",
