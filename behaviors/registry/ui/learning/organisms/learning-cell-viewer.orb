{
  "description": "Cell viewer organism — a biology-canvas bound to entity data.",
  "name": "learning-cell-viewer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "backgroundColor",
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "kind": {
                  "name": "kind",
                  "required": false,
                  "type": "string",
                  "values": [
                    "cell",
                    "organelle",
                    "molecule",
                    "organism"
                  ]
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "radius": {
                  "name": "radius",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "nodes",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "from": {
                  "name": "from",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "to": {
                  "name": "to",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "edges",
            "type": "array"
          }
        ],
        "name": "CellViewerItem",
        "persistence": "runtime"
      },
      "name": "CellViewerOrbital",
      "pages": [
        {
          "name": "CellViewerPage",
          "path": "/learning/cell-viewer",
          "traits": [
            {
              "ref": "CellViewerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Enable continuous redraw loop.",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "backgroundColor": {
              "default": "#f0fdf4",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "edges": {
              "default": [],
              "description": "Connections between nodes.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Edges",
              "tier": "domain",
              "type": "[CellViewerEdge]"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction on the canvas.",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "nodes": {
              "default": [
                {
                  "color": "#16a34a",
                  "id": "cell",
                  "kind": "cell",
                  "label": "Cell membrane",
                  "radius": 120.0,
                  "x": 300.0,
                  "y": 200.0
                },
                {
                  "color": "#2563eb",
                  "id": "nucleus",
                  "kind": "organelle",
                  "label": "Nucleus",
                  "radius": 40.0,
                  "x": 300.0,
                  "y": 200.0
                },
                {
                  "color": "#dc2626",
                  "id": "mitochondria",
                  "kind": "organelle",
                  "label": "Mitochondrion",
                  "radius": 20.0,
                  "x": 230.0,
                  "y": 150.0
                },
                {
                  "color": "#ca8a04",
                  "id": "ribosome",
                  "kind": "organelle",
                  "label": "Ribosome",
                  "radius": 10.0,
                  "x": 360.0,
                  "y": 260.0
                }
              ],
              "description": "Cell / organelle nodes to render.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "kind": {
                    "name": "kind",
                    "required": false,
                    "type": "string",
                    "values": [
                      "cell",
                      "organelle",
                      "molecule",
                      "organism"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Nodes",
              "tier": "domain",
              "type": "[CellViewerNode]"
            },
            "title": {
              "default": "Cell Viewer",
              "description": "Title shown above the cell.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "backgroundColor",
              "edges",
              "nodes",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CellViewerItem",
          "name": "CellViewerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.backgroundColor",
                    "@config.backgroundColor"
                  ],
                  [
                    "set",
                    "@entity.nodes",
                    "@config.nodes"
                  ],
                  [
                    "set",
                    "@entity.edges",
                    "@config.edges"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "backgroundColor": "@entity.backgroundColor",
                          "edges": "@entity.edges",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "nodes": "@entity.nodes",
                          "type": "biology-canvas",
                          "width": "@config.width"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}