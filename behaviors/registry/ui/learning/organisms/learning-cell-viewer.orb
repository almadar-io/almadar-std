{
  "description": "Cell viewer organism — a biology-canvas showing a simple cell with organelles and labels.",
  "name": "learning-cell-viewer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CellViewerItem",
        "persistence": "runtime"
      },
      "name": "CellViewerOrbital",
      "pages": [
        {
          "name": "CellViewerPage",
          "path": "/learning/cell-viewer",
          "traits": [
            {
              "ref": "CellViewerRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "height": {
              "default": 400.0,
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "title": {
              "default": "Cell Viewer",
              "description": "Title shown above the cell.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CellViewerItem",
          "name": "CellViewerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@config.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "backgroundColor": "#f0fdf4",
                          "height": "@config.height",
                          "nodes": [
                            {
                              "color": "#16a34a",
                              "id": "cell",
                              "kind": "cell",
                              "label": "Cell membrane",
                              "radius": 120.0,
                              "x": 300.0,
                              "y": 200.0
                            },
                            {
                              "color": "#2563eb",
                              "id": "nucleus",
                              "kind": "organelle",
                              "label": "Nucleus",
                              "radius": 40.0,
                              "x": 300.0,
                              "y": 200.0
                            },
                            {
                              "color": "#dc2626",
                              "id": "mitochondria",
                              "kind": "organelle",
                              "label": "Mitochondrion",
                              "radius": 20.0,
                              "x": 230.0,
                              "y": 150.0
                            },
                            {
                              "color": "#ca8a04",
                              "id": "ribosome",
                              "kind": "organelle",
                              "label": "Ribosome",
                              "radius": 10.0,
                              "x": 360.0,
                              "y": 260.0
                            }
                          ],
                          "type": "biology-canvas",
                          "width": "@config.width"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}