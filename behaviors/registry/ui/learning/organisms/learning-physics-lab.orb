                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    true
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@entity.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "animate": "@config.animate",
                              "backgroundColor": "@config.backgroundColor",
                              "bodies": "@entity.bodies",
                              "constraints": "@entity.constraints",
                              "forceScale": "@config.forceScale",
                              "height": "@config.height",
                              "interactive": "@config.interactive",
                              "shapes": "@entity.shapes",
                              "showForces": "@config.showForces",
                              "showVelocity": "@config.showVelocity",
                              "type": "physics-canvas",
                              "velocityScale": "@config.velocityScale",
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@entity.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "animate": "@config.animate",
                              "backgroundColor": "@config.backgroundColor",
                              "bodies": "@entity.bodies",
                              "constraints": "@entity.constraints",
                              "forceScale": "@config.forceScale",
                              "height": "@config.height",
                              "interactive": "@config.interactive",
                              "shapes": "@entity.shapes",
                              "showForces": "@config.showForces",
                              "showVelocity": "@config.showVelocity",
                              "type": "physics-canvas",
                              "velocityScale": "@config.velocityScale",
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "PAUSE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.running",
                    false
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "content": "@entity.title",
                              "type": "typography",
                              "variant": "h4"
                            },
                            {
                              "children": [
                                {
                                  "action": "START",
                                  "label": "Start",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "PAUSE",
                                  "label": "Pause",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "animate": "@config.animate",
                              "backgroundColor": "@config.backgroundColor",
                              "bodies": "@entity.bodies",
                              "constraints": "@entity.constraints",
                              "forceScale": "@config.forceScale",
                              "height": "@config.height",
                              "interactive": "@config.interactive",
                              "shapes": "@entity.shapes",
                              "showForces": "@config.showForces",
                              "showVelocity": "@config.showVelocity",
                              "type": "physics-canvas",
                              "velocityScale": "@config.velocityScale",
                              "width": "@config.width"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "padding": "md",
                      "type": "box"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "idle",
                "to": "idle"
              }
            ]
          },
          "ticks": [
            {
              "effects": [
                [
                  "set",
                  "@entity.bodies",
                  [
                    "array/map",
                    "@entity.bodies",
                    [
                      "fn",
                      "b",
                      [
                        "let",
                        [
                          [
                            "r",
                            [
                              "object/get",
                              "@b",
                              "radius"
                            ]
                          ],
                          [
                            "nvx",
                            [
                              "*",
                              [
                                "object/get",
                                "@b",
                                "vx"
                              ],
                              "@config.damping"
                            ]
                          ],
                          [
                            "nvy",
                            [
                              "*",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "vy"
                                ],
                                "@config.gravity"
                              ],
                              "@config.damping"
                            ]
                          ]
                        ],
                        [
                          "let",
                          [
                            [
                              "nx",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "x"
                                ],
                                "@nvx"
                              ]
                            ],
                            [
                              "ny",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@b",
                                  "y"
                                ],
                                "@nvy"
                              ]
                            ]
                          ],
                          [
                            "let",
                            [
                              [
                                "hitx",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@nx",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@nx",
                                    [
                                      "-",
                                      "@config.width",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ],
                              [
                                "hity",
                                [
                                  "or",
                                  [
                                    "<",
                                    "@ny",
                                    "@r"
                                  ],
                                  [
                                    ">",
                                    "@ny",
                                    [
                                      "-",
                                      "@config.height",
                                      "@r"
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            [
                              "object/merge",
                              "@b",
                              {
                                "vx": [
                                  "if",
                                  "@hitx",
                                  [
                                    "*",
                                    "@nvx",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvx"
                                ],
                                "vy": [
                                  "if",
                                  "@hity",
                                  [
                                    "*",
                                    "@nvy",
                                    [
                                      "*",
                                      -1.0,
                                      "@config.restitution"
                                    ]
                                  ],
                                  "@nvy"
                                ],
                                "x": [
                                  "math/clamp",
                                  "@nx",
                                  "@r",
                                  [
                                    "-",
                                    "@config.width",
                                    "@r"
                                  ]
                                ],
                                "y": [
                                  "math/clamp",
                                  "@ny",
                                  "@r",
                                  [
                                    "-",
                                    "@config.height",
                                    "@r"
                                  ]
                                ]
                              }
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ],
                [
                  "render-ui",
                  "main",
                  {
                    "children": [
                      {
                        "children": [
                          {
                            "content": "@entity.title",
                            "type": "typography",
                            "variant": "h4"
                          },
                          {
                            "children": [
                              {
                                "action": "START",
                                "label": "Start",
                                "type": "button",
                                "variant": "primary"
                              },
                              {
                                "action": "PAUSE",
                                "label": "Pause",
                                "type": "button",
                                "variant": "secondary"
                              },
                              {
                                "action": "RESET",
                                "label": "Reset",
                                "type": "button",
                                "variant": "ghost"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "animate": "@config.animate",
                            "backgroundColor": "@config.backgroundColor",
                            "bodies": "@entity.bodies",
                            "constraints": "@entity.constraints",
                            "forceScale": "@config.forceScale",
                            "height": "@config.height",
                            "interactive": "@config.interactive",
                            "shapes": "@entity.shapes",
                            "showForces": "@config.showForces",
                            "showVelocity": "@config.showVelocity",
                            "type": "physics-canvas",
                            "velocityScale": "@config.velocityScale",
                            "width": "@config.width"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ],
                    "padding": "md",
                    "type": "box"
                  }
                ]
              ],
              "guard": "@entity.running",
              "interval": 32.0,
              "name": "physicsTick"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
}