                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "label": "Reset",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "animate": "@config.animate",
                              "backgroundColor": "@config.backgroundColor",
