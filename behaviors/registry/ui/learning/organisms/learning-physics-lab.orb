          "entityContract": {
            "provides": [
              "bodies",
              "constraints",
              "shapes",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PhysicsLabItem",
          "name": "PhysicsLabRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.constraints",
                    "@config.constraints"
                  ],
                  [
                    "set",
                    "@entity.shapes",
                    "@config.shapes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "backgroundColor": "@config.backgroundColor",
                          "bodies": "@entity.bodies",
                          "constraints": "@entity.constraints",
                          "forceScale": "@config.forceScale",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "shapes": "@entity.shapes",
                          "showForces": "@config.showForces",
                          "showVelocity": "@config.showVelocity",
                          "type": "physics-canvas",
                          "velocityScale": "@config.velocityScale",
                          "width": "@config.width"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
