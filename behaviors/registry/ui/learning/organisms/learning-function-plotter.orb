                          "showAxes": true,
                          "showGrid": true,
                          "type": "math-canvas",
                          "width": "@config.width",
                          "xMax": "@config.xMax",
                          "xMin": "@config.xMin",
                          "yMax": "@config.yMax",
                          "yMin": "@config.yMin"
