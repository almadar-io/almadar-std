{
  "description": "Function plotter organism — plots multiple sampled functions on a math-canvas.",
  "name": "learning-function-plotter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "FunctionPlotterItem",
        "persistence": "runtime"
      },
      "name": "FunctionPlotterOrbital",
      "pages": [
        {
          "name": "FunctionPlotterPage",
          "path": "/learning/function-plotter",
          "traits": [
            {
              "ref": "FunctionPlotterRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "height": {
              "default": 400.0,
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "title": {
              "default": "Function Plotter",
              "description": "Title shown above the plot.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            },
            "xMax": {
              "default": 7.0,
              "label": "X Max",
              "tier": "domain",
              "type": "number"
            },
            "xMin": {
              "default": -7.0,
              "label": "X Min",
              "tier": "domain",
              "type": "number"
            },
            "yMax": {
              "default": 2.0,
              "label": "Y Max",
              "tier": "domain",
              "type": "number"
            },
            "yMin": {
              "default": -2.0,
              "label": "Y Min",
              "tier": "domain",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FunctionPlotterItem",
          "name": "FunctionPlotterRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
