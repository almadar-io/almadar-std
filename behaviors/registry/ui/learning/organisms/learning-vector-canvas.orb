{
  "description": "Vector canvas organism — plots entity-provided vectors on a math-canvas.",
  "name": "learning-vector-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "vx": {
                  "name": "vx",
                  "required": true,
                  "type": "number"
                },
                "vy": {
                  "name": "vy",
                  "required": true,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "vectors",
            "type": "array"
          }
        ],
        "name": "VectorCanvasItem",
        "persistence": "runtime"
      },
      "name": "VectorCanvasOrbital",
      "pages": [
        {
          "name": "VectorCanvasPage",
          "path": "/learning/vector-canvas",
          "traits": [
            {
              "ref": "VectorCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Enable continuous redraw loop.",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "gridStep": {
              "default": 1.0,
              "label": "Grid Step",
              "tier": "presentation",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction on the canvas.",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "showAxes": {
              "default": true,
              "label": "Show Axes",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": true,
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Vector Canvas",
              "description": "Title shown above the canvas.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "vectors": {
              "default": [
                {
                  "color": "#2563eb",
                  "label": "u",
                  "vx": 3.0,
                  "vy": 2.0,
                  "x": 0.0,
                  "y": 0.0
                },
                {
                  "color": "#dc2626",
                  "label": "v",
                  "vx": -2.0,
                  "vy": 3.0,
                  "x": 0.0,
                  "y": 0.0
                },
                {
                  "color": "#16a34a",
                  "label": "w",
                  "vx": 1.0,
                  "vy": 5.0,
                  "x": 0.0,
                  "y": 0.0
                }
              ],
              "description": "Vectors to plot (origin + components).",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "vx": {
                    "name": "vx",
                    "required": true,
                    "type": "number"
                  },
                  "vy": {
                    "name": "vy",
                    "required": true,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Vectors",
              "tier": "domain",
              "type": "[VectorCanvasVector]"
            },
            "width": {
              "default": 600.0,
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            },
            "xMax": {
              "default": 6.0,
              "label": "X Max",
              "tier": "domain",
              "type": "number"
            },
            "xMin": {
              "default": -6.0,
              "label": "X Min",
              "tier": "domain",
              "type": "number"
            },
            "yMax": {
              "default": 6.0,
              "label": "Y Max",
              "tier": "domain",
              "type": "number"
            },
            "yMin": {
              "default": -2.0,
              "label": "Y Min",
              "tier": "domain",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "title",
              "vectors"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "VectorCanvasItem",
          "name": "VectorCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.vectors",
                    "@config.vectors"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "gridStep": "@config.gridStep",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "showAxes": "@config.showAxes",
                          "showGrid": "@config.showGrid",
                          "type": "math-canvas",
                          "vectors": "@entity.vectors",
                          "width": "@config.width",
                          "xMax": "@config.xMax",
                          "xMin": "@config.xMin",
                          "yMax": "@config.yMax",
                          "yMin": "@config.yMin"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}