{
  "description": "Coordinate plane organism — a math-canvas bound to entity curves and points.",
  "name": "learning-coordinate-plane",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "samples": {
                  "items": {
                    "properties": {
                      "color": {
                        "name": "color",
                        "required": false,
                        "type": "string"
                      },
                      "label": {
                        "name": "label",
                        "required": false,
                        "type": "string"
                      },
                      "radius": {
                        "name": "radius",
                        "required": false,
                        "type": "number"
                      },
                      "x": {
                        "name": "x",
                        "required": true,
                        "type": "number"
                      },
                      "y": {
                        "name": "y",
                        "required": true,
                        "type": "number"
                      }
                    },
                    "type": "object"
                  },
                  "name": "samples",
                  "required": false,
                  "type": "array"
                }
              },
              "type": "object"
            },
            "name": "curves",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "radius": {
                  "name": "radius",
                  "required": false,
                  "type": "number"
                },
                "x": {
                  "name": "x",
                  "required": true,
                  "type": "number"
                },
                "y": {
                  "name": "y",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "points",
            "type": "array"
          }
        ],
        "name": "CoordinatePlaneItem",
        "persistence": "runtime"
      },
      "name": "CoordinatePlaneOrbital",
      "pages": [
        {
          "name": "CoordinatePlanePage",
          "path": "/learning/coordinate-plane",
          "traits": [
            {
              "ref": "CoordinatePlaneRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Enable continuous redraw loop.",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "curves": {
              "default": [
                {
                  "color": "#2563eb",
                  "label": "y = x²",
                  "samples": [
                    {
                      "x": -3.0,
                      "y": 9.0
                    },
                    {
                      "x": -2.0,
                      "y": 4.0
                    },
                    {
                      "x": -1.0,
                      "y": 1.0
                    },
                    {
                      "x": 0.0,
                      "y": 0.0
                    },
                    {
                      "x": 1.0,
                      "y": 1.0
                    },
                    {
                      "x": 2.0,
                      "y": 4.0
                    },
                    {
                      "x": 3.0,
                      "y": 9.0
                    }
                  ]
                }
              ],
              "description": "Sampled curves to plot.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "samples": {
                    "items": {
                      "properties": {
                        "color": {
                          "name": "color",
                          "required": false,
                          "type": "string"
                        },
                        "label": {
                          "name": "label",
                          "required": false,
                          "type": "string"
                        },
                        "radius": {
                          "name": "radius",
                          "required": false,
                          "type": "number"
                        },
                        "x": {
                          "name": "x",
                          "required": true,
                          "type": "number"
                        },
                        "y": {
                          "name": "y",
                          "required": true,
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "name": "samples",
                    "required": false,
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "label": "Curves",
              "tier": "domain",
              "type": "[CoordinatePlaneCurve]"
            },
            "gridStep": {
              "default": 1.0,
              "label": "Grid Step",
              "tier": "presentation",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "description": "Canvas height in pixels.",
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction on the canvas.",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "points": {
              "default": [
                {
                  "color": "#dc2626",
                  "label": "A",
                  "radius": 4.0,
                  "x": -2.0,
                  "y": 4.0
                },
                {
                  "color": "#16a34a",
                  "label": "B",
                  "radius": 4.0,
                  "x": 1.0,
                  "y": 1.0
                }
              ],
              "description": "Scatter points to highlight.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Points",
              "tier": "domain",
              "type": "[CoordinatePlanePoint]"
            },
            "showAxes": {
              "default": true,
              "label": "Show Axes",
              "tier": "presentation",
              "type": "boolean"
            },
            "showGrid": {
              "default": true,
              "label": "Show Grid",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Coordinate Plane",
              "description": "Title shown above the plane.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "description": "Canvas width in pixels.",
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            },
            "xMax": {
              "default": 5.0,
              "description": "Maximum x value.",
              "label": "X Max",
              "tier": "domain",
              "type": "number"
            },
            "xMin": {
              "default": -5.0,
              "description": "Minimum x value.",
              "label": "X Min",
              "tier": "domain",
              "type": "number"
            },
            "yMax": {
              "default": 10.0,
              "description": "Maximum y value.",
              "label": "Y Max",
              "tier": "domain",
              "type": "number"
            },
            "yMin": {
              "default": -2.0,
              "description": "Minimum y value.",
              "label": "Y Min",
              "tier": "domain",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "curves",
              "points",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "CoordinatePlaneItem",
          "name": "CoordinatePlaneRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.curves",
                    "@config.curves"
                  ],
                  [
                    "set",
                    "@entity.points",
                    "@config.points"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "curves": "@entity.curves",
                          "gridStep": "@config.gridStep",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "points": "@entity.points",
                          "showAxes": "@config.showAxes",
                          "showGrid": "@config.showGrid",
                          "type": "math-canvas",
                          "width": "@config.width",
                          "xMax": "@config.xMax",
                          "xMin": "@config.xMin",
                          "yMax": "@config.yMax",
                          "yMin": "@config.yMin"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}