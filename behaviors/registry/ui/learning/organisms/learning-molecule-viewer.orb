                  "to": "H2",
                  "type": "single"
                },
                {
                  "from": "C",
                  "to": "H3",
                  "type": "single"
                }
              ],
              "description": "Bonds between atoms.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  },
                  "type": {
                    "name": "type",
                    "required": false,
                    "type": "string",
                    "values": [
                      "single",
                      "double",
                      "triple"
                    ]
                  }
                },
                "type": "object"
              },
              "label": "Bonds",
              "tier": "domain",
              "type": "[MoleculeViewerBond]"
            },
            "height": {
              "default": 400.0,
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction on the canvas.",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Molecule Viewer",
              "description": "Title shown above the molecule.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "width": {
              "default": 600.0,
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "arrows",
              "atoms",
              "backgroundColor",
              "bonds",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "MoleculeViewerItem",
          "name": "MoleculeViewerRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.backgroundColor",
                    "@config.backgroundColor"
                  ],
                  [
                    "set",
                    "@entity.atoms",
                    "@config.atoms"
                  ],
                  [
                    "set",
                    "@entity.bonds",
                    "@config.bonds"
                  ],
                  [
                    "set",
                    "@entity.arrows",
                    "@config.arrows"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "arrows": "@entity.arrows",
                          "atoms": "@entity.atoms",
                          "backgroundColor": "@entity.backgroundColor",
                          "bonds": "@entity.bonds",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "type": "chemistry-canvas",
                          "width": "@config.width"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}