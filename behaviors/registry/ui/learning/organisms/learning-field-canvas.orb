                }
              },
              "type": "object"
            },
            "name": "bodies",
            "type": "array"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
                  "type": "string"
                },
                "from": {
                  "name": "from",
                  "required": true,
                  "type": "string"
                },
                "to": {
                  "name": "to",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "constraints",
            "type": "array"
          }
        ],
        "name": "FieldCanvasItem",
        "persistence": "runtime"
      },
      "name": "FieldCanvasOrbital",
      "pages": [
        {
          "name": "FieldCanvasPage",
          "path": "/learning/field-canvas",
          "traits": [
            {
              "ref": "FieldCanvasRender"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "animate": {
              "default": false,
              "description": "Enable continuous redraw loop.",
              "label": "Animate",
              "tier": "presentation",
              "type": "boolean"
            },
            "backgroundColor": {
              "default": "#f8fafc",
              "label": "Background Color",
              "tier": "presentation",
              "type": "string"
            },
            "bodies": {
              "default": [
                {
                  "color": "#2563eb",
                  "id": "b1",
                  "label": "A",
                  "radius": 14.0,
                  "vx": 2.0,
                  "vy": -1.0,
                  "x": 120.0,
                  "y": 200.0
                },
                {
                  "color": "#dc2626",
                  "id": "b2",
                  "label": "B",
                  "radius": 18.0,
                  "vx": -1.0,
                  "vy": 1.5,
                  "x": 300.0,
                  "y": 150.0
                },
                {
                  "color": "#16a34a",
                  "fx": -0.5,
                  "fy": 0.0,
                  "id": "b3",
                  "label": "C",
                  "radius": 12.0,
                  "vx": 0.0,
                  "vy": 0.0,
                  "x": 480.0,
                  "y": 220.0
                }
              ],
              "description": "Physics bodies to render.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "fx": {
                    "name": "fx",
                    "required": false,
                    "type": "number"
                  },
                  "fy": {
                    "name": "fy",
                    "required": false,
                    "type": "number"
                  },
                  "id": {
                    "name": "id",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "radius": {
                    "name": "radius",
                    "required": false,
                    "type": "number"
                  },
                  "vx": {
                    "name": "vx",
                    "required": false,
                    "type": "number"
                  },
                  "vy": {
                    "name": "vy",
                    "required": false,
                    "type": "number"
                  },
                  "x": {
                    "name": "x",
                    "required": true,
                    "type": "number"
                  },
                  "y": {
                    "name": "y",
                    "required": true,
                    "type": "number"
                  }
                },
                "type": "object"
              },
              "label": "Bodies",
              "tier": "domain",
              "type": "[FieldCanvasBody]"
            },
            "constraints": {
              "default": [],
              "description": "Constraints linking bodies.",
              "items": {
                "properties": {
                  "color": {
                    "name": "color",
                    "required": false,
                    "type": "string"
                  },
                  "from": {
                    "name": "from",
                    "required": true,
                    "type": "string"
                  },
                  "to": {
                    "name": "to",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Constraints",
              "tier": "domain",
              "type": "[FieldCanvasConstraint]"
            },
            "forceScale": {
              "default": 30.0,
              "label": "Force Scale",
              "tier": "presentation",
              "type": "number"
            },
            "height": {
              "default": 400.0,
              "label": "Height",
              "tier": "presentation",
              "type": "number"
            },
            "interactive": {
              "default": false,
              "description": "Enable pointer interaction on the canvas.",
              "label": "Interactive",
              "tier": "presentation",
              "type": "boolean"
            },
            "showForces": {
              "default": true,
              "description": "Render force arrows for each body.",
              "label": "Show Forces",
              "tier": "presentation",
              "type": "boolean"
            },
            "showVelocity": {
              "default": true,
              "description": "Render velocity arrows for each body.",
              "label": "Show Velocity",
              "tier": "presentation",
              "type": "boolean"
            },
            "title": {
              "default": "Field Canvas",
              "description": "Title shown above the field.",
              "label": "Title",
              "tier": "domain",
              "type": "string"
            },
            "velocityScale": {
              "default": 25.0,
              "label": "Velocity Scale",
              "tier": "presentation",
              "type": "number"
            },
            "width": {
              "default": 600.0,
              "label": "Width",
              "tier": "presentation",
              "type": "number"
            }
          },
          "entityContract": {
            "provides": [
              "backgroundColor",
              "bodies",
              "constraints",
              "title"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "FieldCanvasItem",
          "name": "FieldCanvasRender",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.title",
                    "@config.title"
                  ],
                  [
                    "set",
                    "@entity.backgroundColor",
                    "@config.backgroundColor"
                  ],
                  [
                    "set",
                    "@entity.bodies",
                    "@config.bodies"
                  ],
                  [
                    "set",
                    "@entity.constraints",
                    "@config.constraints"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@entity.title",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "animate": "@config.animate",
                          "backgroundColor": "@entity.backgroundColor",
                          "bodies": "@entity.bodies",
                          "constraints": "@entity.constraints",
                          "forceScale": "@config.forceScale",
                          "height": "@config.height",
                          "interactive": "@config.interactive",
                          "showForces": "@config.showForces",
                          "showVelocity": "@config.showVelocity",
                          "type": "physics-canvas",
                          "velocityScale": "@config.velocityScale",
                          "width": "@config.width"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "padding": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}