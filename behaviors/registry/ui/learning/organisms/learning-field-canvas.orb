{
  "description": "Field canvas organism — a physics-canvas bound to entity bodies, constraints, and forces.",
  "name": "learning-field-canvas",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "backgroundColor",
            "type": "string"
          },
          {
            "items": {
              "properties": {
                "color": {
                  "name": "color",
                  "required": false,
