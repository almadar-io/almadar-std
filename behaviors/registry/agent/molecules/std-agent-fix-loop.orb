              "event": "FIX_APPLIED",
              "eventId": "evt_01KXG04EPASHS1GFAH3TMGRENA",
              "source": {
                "kind": "trait",
                "trait": "FixLoopExecution",
                "traitId": "trt_01KXG04EPAF7T30GPWENR8NB5T"
              },
              "triggers": "FIX_APPLIED",
              "triggersId": "evt_01KXG04EPATGF65TS9QM1XFDTY"
            }
          ],
          "name": "FixLoopListener",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FIX_APPLIED",
                "name": "Fix Applied"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "waiting"
              },
              {
                "name": "resolved"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "INIT",
                "from": "waiting",
                "to": "waiting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "fixed"
                  ]
                ],
                "event": "FIX_APPLIED",
                "from": "waiting",
                "to": "resolved"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "fixed"
                  ]
                ],
                "event": "INIT",
                "from": "resolved",
                "to": "resolved"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "RESET",
                "from": "resolved",
                "to": "waiting"
              }
            ]
          }
        }
      ]
    }
  ],
  "schemaVersion": 1,
  "version": "1.0.0"
