{
  "name": "std-agent-fix-loop",
  "version": "1.0.0",
  "description": "std-agent-fix-loop as a Function",
  "orbitals": [
    {
      "name": "AgentFixLoopOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        },
        {
          "from": "std/behaviors/std-agent-tool-call",
          "as": "AgentToolCall"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "AgentFixLoop",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "target",
            "type": "string",
            "default": ""
          },
          {
            "name": "validationErrors",
            "type": "string",
            "default": ""
          },
          {
            "name": "fixAttempts",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxAttempts",
            "type": "number",
            "default": 5.0
          },
          {
            "name": "currentFix",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "steps",
            "type": "string",
            "default": "Validate,Analyze,Fix,Re-validate"
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          },
          {
            "name": "args",
            "type": "string",
            "default": ""
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentFixLoopCycle",
          "category": "interaction",
          "linkedEntity": "AgentFixLoop",
          "emits": [
            {
              "event": "FIX_SUCCEEDED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "target",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FIX_FAILED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "target",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "FIX_SUCCEEDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentFixLoopCycle"
              }
            },
            {
              "event": "FIX_FAILED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentFixLoopCycle"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "validating"
              },
              {
                "name": "fixing"
              },
              {
                "name": "applying"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FIX",
                "name": "Fix"
              },
              {
                "key": "VALIDATION_PASSED",
                "name": "Validation Passed"
              },
              {
                "key": "VALIDATION_ERRORS",
                "name": "Validation Errors",
                "payloadSchema": [
                  {
                    "name": "errors",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "count",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXCEEDED_ATTEMPTS",
                "name": "Exceeded Attempts",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FIX_GENERATED",
                "name": "Fix Generated",
                "payloadSchema": [
                  {
                    "name": "fix",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FIX_APPLIED",
                "name": "Fix Applied"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "FIX_SUCCEEDED",
                "name": "Fix Succeeded"
              },
              {
                "key": "FIX_FAILED",
                "name": "Fix Failed"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "wrench"
                            },
                            {
                              "content": "Validation-Fix Loop",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Enter the target to validate and auto-fix",
                                  "type": "typography"
                                },
                                {
                                  "type": "form-section",
                                  "fields": [
                                    "target"
                                  ],
                                  "entity": "@entity",
                                  "submitEvent": "FIX",
                                  "mode": "edit"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "validating",
                "event": "FIX",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "set",
                    "@entity.fixAttempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    ""
                  ],
                  [
                    "set",
                    "@entity.errorCount",
                    0.0
                  ],
                  [
                    "agent/invoke",
                    "validate-schema",
                    {
                      "target": "@entity.target"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "shield-check"
                        },
                        {
                          "variant": "h3",
                          "content": "Validating...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "children": [
                            {
                              "label": "@entity.target",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxAttempts"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "justify": "center"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "succeeded",
                "event": "VALIDATION_PASSED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "FIX_SUCCEEDED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Validation Passed",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "action": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "label": "New Target"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "wrench",
                              "value": "@entity.fixAttempts",
                              "type": "stat-display",
                              "label": "Fix Attempts"
                            },
                            {
                              "type": "stat-display",
                              "value": "Passed",
                              "icon": "check",
                              "label": "Status"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Target"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.target"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "fixing",
                "event": "VALIDATION_ERRORS",
                "effects": [
                  [
                    "set",
                    "@entity.validationErrors",
                    "@payload.errors"
                  ],
                  [
                    "set",
                    "@entity.errorCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.fixAttempts",
                    [
                      "+",
                      "@entity.fixAttempts",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "fixing"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Target: ",
                      "@entity.target",
                      "\n\nValidation errors:\n",
                      "@payload.errors",
                      "\n\nGenerate a fix that resolves these errors. Return only the fix content."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "cpu"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Generating fix..."
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "label": "@entity.fixAttempts",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Validation Errors"
                                },
                                {
                                  "type": "alert",
                                  "variant": "error",
                                  "message": "@entity.validationErrors"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "type": "spinner"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "failed",
                "event": "EXCEEDED_ATTEMPTS",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Fix Loop Failed"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "wrench",
                              "type": "stat-display",
                              "value": "@entity.fixAttempts",
                              "label": "Attempts Used"
                            },
                            {
                              "label": "Remaining Errors",
                              "value": "@entity.errorCount",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Validation Errors",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.validationErrors"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "fixing",
                "to": "applying",
                "event": "FIX_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.currentFix",
                    "@payload.fix"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "applying"
                  ],
                  [
                    "agent/invoke",
                    "apply-fix",
                    {
                      "fix": "@payload.fix",
                      "target": "@entity.target"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "tool",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Applying fix...",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Proposed Fix",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.currentFix",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "fixing",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "content": "Fix Loop Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "variant": "error",
                          "message": "@entity.error",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "wrench",
                              "label": "Attempts Used",
                              "type": "stat-display",
                              "value": "@entity.fixAttempts"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.errorCount",
                              "label": "Remaining Errors",
                              "icon": "alert-triangle"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last Validation Errors"
                                },
                                {
                                  "content": "@entity.validationErrors",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "applying",
                "to": "validating",
                "event": "FIX_APPLIED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "agent/invoke",
                    "validate-schema",
                    {
                      "target": "@entity.target"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "shield-check"
                        },
                        {
                          "content": "Validating...",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.target"
                            },
                            {
                              "label": "@entity.maxAttempts",
                              "type": "badge"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "center"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "applying",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "emit",
                    "FIX_FAILED"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "content": "Fix Loop Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.fixAttempts",
                              "icon": "wrench",
                              "label": "Attempts Used",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.errorCount",
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Remaining Errors"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Last Validation Errors"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.validationErrors"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.target",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentFix",
                    ""
                  ],
                  [
                    "set",
                    "@entity.fixAttempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.errorCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "content": "Validation-Fix Loop",
                              "variant": "h2",
                              "type": "typography"
