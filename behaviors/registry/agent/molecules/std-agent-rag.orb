{
  "name": "std-agent-rag",
  "version": "1.0.0",
  "description": "std-agent-rag as a Function",
  "orbitals": [
    {
      "name": "AgentRagOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-agent-search",
          "as": "AgentSearch"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "AgentRag",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string",
            "description": "A human-readable identifier for the agent.",
            "synonyms": "title, label, identifier"
          },
          {
            "name": "description",
            "type": "string",
            "description": "A brief explanation of the component's function.",
            "synonyms": "explanation, details, summary, notes"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Indicates the current operational state of the component.",
            "synonyms": "state, condition, operational_status"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": "",
            "description": "The text used to initiate a search or request.",
            "synonyms": "search term, request, input, question"
          },
          {
            "name": "context",
            "type": "string",
            "default": "",
            "description": "The surrounding information used for processing.",
            "synonyms": "background, details, surrounding text"
          },
          {
            "name": "response",
            "type": "string",
            "default": "",
            "description": "The text output generated by the agent.",
            "synonyms": "output, answer, text, result"
          },
          {
            "name": "memoryHits",
            "type": "number",
            "default": 0.0,
            "description": "The number of memory hits retrieved.",
            "synonyms": "count, hits, number"
          },
          {
            "name": "searchHits",
            "type": "number",
            "default": 0.0,
            "description": "The number of search results retrieved.",
            "synonyms": "count, total, size, number"
          },
          {
            "name": "error",
            "type": "string",
            "default": "",
            "description": "Details about any errors encountered during processing.",
            "synonyms": "failure, problem, issue, exception"
          },
          {
            "name": "content",
            "type": "string",
            "default": "",
            "description": "The textual data associated with an item.",
            "synonyms": "text, data, body, value"
          },
          {
            "name": "category",
            "type": "string",
            "default": "",
            "description": "Classification or type of the agent rag.",
            "synonyms": "type, classification, kind"
          },
          {
            "name": "scope",
            "type": "string",
            "default": "",
            "description": "Defines the boundaries or area of focus.",
            "synonyms": "domain, area, range, limits"
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0,
            "description": "A numerical value representing confidence or relevance.",
            "synonyms": "score, confidence, relevance, rating"
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false,
            "description": "Indicates whether the item is marked as important.",
            "synonyms": "flagged, marked, important"
          },
          {
            "name": "language",
            "type": "string",
            "default": "",
            "description": "The language used for processing and generation.",
            "synonyms": "locale, languageCode, languageTag"
          },
          {
            "name": "resultCount",
            "type": "number",
            "default": 0.0,
            "description": "The number of results returned.",
            "synonyms": "count, size, total, quantity"
          },
          {
            "name": "results",
            "type": "string",
            "default": "[]",
            "description": "The output or outcome of a process or operation.",
            "synonyms": "output, outcome, result, data"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": "",
            "description": "The text used as input for generating a response.",
            "synonyms": "instruction, query, input"
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic",
            "description": "Identifies the source or service providing data.",
            "synonyms": "source, origin, vendor"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514",
            "description": "Specifies the language model used for processing.",
            "synonyms": "engine, classifier, algorithm"
          },
          {
            "name": "activeTab",
            "type": "string",
            "default": "",
            "description": "The currently selected tab within the interface.",
            "synonyms": "selection, current tab, tab"
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "string",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "A list of items retrieved or processed.",
            "synonyms": "entries, records, data"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentRagRag",
          "category": "interaction",
          "linkedEntity": "AgentRag",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "retrieving"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "RETRIEVAL_DONE",
                "name": "Retrieval Done",
                "payloadSchema": [
                  {
                    "name": "context",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "memoryHits",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "searchHits",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GENERATION_DONE",
                "name": "Generation Done",
                "payloadSchema": [
                  {
                    "name": "response",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "RAG Pipeline"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Enter a query to retrieve context and generate a response",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "mode": "edit",
                                  "submitEvent": "GENERATE",
                                  "fields": [
                                    "query"
                                  ],
                                  "type": "form-section",
                                  "entity": "@entity"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "retrieving",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "retrieving"
                  ],
                  [
                    "agent/recall",
                    "@entity.query",
                    5.0
                  ],
                  [
                    "agent/search-code",
                    "@entity.query"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "content": "Retrieving context...",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "badge",
                              "label": "Recalling memories"
                            },
                            {
                              "label": "Searching code",
                              "type": "badge"
                            }
                          ],
                          "justify": "center",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "generating",
                "event": "RETRIEVAL_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.context",
                    "@payload.context"
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    "@payload.memoryHits"
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    "@payload.searchHits"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Context:\n",
                      "@entity.context",
                      "\n\nQuery: ",
                      "@entity.query",
                      "\n\nProvide a comprehensive answer based on the retrieved context."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "cpu"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Generating response..."
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "justify": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "label": "@entity.memoryHits",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.searchHits"
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "retrieving",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "RAG Pipeline Error"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@entity.error"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "label": "Try Again",
                          "action": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "GENERATION_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.response"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "RAG query: ",
                      "@entity.query"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle"
                                },
                                {
                                  "content": "RAG Complete",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "label": "New Query",
                              "icon": "rotate-ccw",
                              "action": "RESET",
                              "variant": "ghost",
                              "type": "button"
                            }
                          ],
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "brain",
                              "label": "Memory Hits",
                              "value": "@entity.memoryHits",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.searchHits",
                              "label": "Code Hits",
                              "icon": "code",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Query",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.query",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "typography",
                                  "content": "Response",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.response",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Retrieved Context",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.context"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "RAG Pipeline Error",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "label": "Try Again",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.context",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.searchHits",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "content": "RAG Pipeline",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Enter a query to retrieve context and generate a response",
                                  "variant": "body"
                                },
                                {
                                  "type": "form-section",
                                  "mode": "edit",
                                  "fields": [
                                    "query"
                                  ],
                                  "submitEvent": "GENERATE",
                                  "entity": "@entity"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Tabs.traits.TabsItemTabs",
          "name": "RagTabs",
          "linkedEntity": "AgentRag"
        },
        {
          "ref": "AgentMemory.traits.AgentMemoryBrowse",
          "name": "RagMemoryLifecycle",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentSearch.traits.AgentSearchBrowse",
          "name": "RagSearchLifecycle",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentCompletion.traits.AgentCompletionModal",
          "name": "RagCompletionFlow",
          "linkedEntity": "AgentRag",
          "emitsScope": "internal"
        }
      ],
      "pages": [
        {
          "name": "AgentRagPage",
          "path": "/agentrags",
          "traits": [
            {
              "ref": "AgentRagRag"
            },
            {
              "ref": "RagTabs"
            },
            {
              "ref": "RagMemoryLifecycle"
            },
            {
              "ref": "RagSearchLifecycle"
            },
            {
              "ref": "RagCompletionFlow"
            }
          ]
        }
      ]
    }
  ]
}
