{
  "name": "std-agent-learner",
  "version": "1.0.0",
  "description": "std-agent-learner as a Function",
  "orbitals": [
    {
      "name": "AgentLearnerOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-memory",
          "as": "AgentMemory"
        },
        {
          "from": "std/behaviors/std-agent-provider",
          "as": "AgentProvider"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "AgentLearner",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "outcome",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "impact",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isSuccess",
            "type": "boolean",
            "default": false
          },
          {
            "name": "provider",
            "type": "string",
            "default": ""
          },
          {
            "name": "consecutiveFailures",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSuccesses",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalFailures",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "currentProvider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "currentModel",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "fallbackProvider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "requestCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentLearnerLearner",
          "category": "interaction",
          "linkedEntity": "AgentLearner",
          "emits": [
            {
              "event": "TASK_SUCCEEDED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "outcome",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TASK_SUCCEEDED",
              "triggers": "TASK_SUCCEEDED",
              "source": {
                "kind": "trait",
                "trait": "AgentLearnerLearner"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "recording"
              },
              {
                "name": "analyzing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TASK_SUCCEEDED",
                "name": "Task Succeeded",
                "payloadSchema": [
                  {
                    "name": "outcome",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TASK_FAILED",
                "name": "Task Failed",
                "payloadSchema": [
                  {
                    "name": "outcome",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RECORDED",
                "name": "Recorded",
                "payloadSchema": [
                  {
                    "name": "memoryId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ANALYSIS_DONE",
                "name": "Analysis Done",
                "payloadSchema": [
                  {
                    "name": "impact",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "graduation-cap"
                            },
                            {
                              "variant": "h2",
                              "content": "Outcome Learner",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.totalSuccesses",
                              "icon": "check-circle",
                              "label": "Successes",
                              "type": "stat-display"
                            },
                            {
                              "icon": "x-circle",
                              "label": "Failures",
                              "value": "@entity.totalFailures",
                              "type": "stat-display"
                            },
                            {
                              "label": "Current Provider",
                              "value": "@entity.provider",
                              "type": "stat-display",
                              "icon": "cpu"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Listening for task outcomes...",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "type": "typography",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Outcome",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "content": "Impact Analysis",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.impact",
                                  "variant": "body"
                                }
                              ],
                              "gap": "sm"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "recording",
                "event": "TASK_SUCCEEDED",
                "effects": [
                  [
                    "set",
                    "@entity.outcome",
                    "@payload.outcome"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.isSuccess",
                    true
                  ],
                  [
                    "set",
                    "@entity.consecutiveFailures",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSuccesses",
                    [
                      "+",
                      "@entity.totalSuccesses",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recording"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Success: ",
                      "@payload.outcome"
                    ],
                    "@payload.category"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "save",
                          "type": "icon"
                        },
                        {
                          "content": "Recording outcome...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "label": "@entity.outcome",
                          "type": "badge"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "recording",
                "event": "TASK_FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.outcome",
                    "@payload.outcome"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.isSuccess",
                    false
                  ],
                  [
                    "set",
                    "@entity.consecutiveFailures",
                    [
                      "+",
                      "@entity.consecutiveFailures",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.totalFailures",
                    [
                      "+",
                      "@entity.totalFailures",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recording"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Failure: ",
                      "@payload.outcome"
                    ],
                    "@payload.category"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "save"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Recording outcome..."
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "badge",
                          "label": "@entity.outcome"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "graduation-cap"
                            },
                            {
                              "content": "Outcome Learner",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.totalSuccesses",
                              "type": "stat-display",
                              "label": "Successes",
                              "icon": "check-circle"
                            },
                            {
                              "icon": "x-circle",
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.totalFailures"
                            },
                            {
                              "value": "@entity.provider",
                              "type": "stat-display",
                              "label": "Current Provider",
                              "icon": "cpu"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Listening for task outcomes...",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically."
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last Outcome"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Impact Analysis"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.impact"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "recording",
                "to": "analyzing",
                "event": "RECORDED",
                "effects": [
                  [
                    "set",
                    "@entity.memoryId",
                    "@payload.memoryId"
                  ],
                  [
                    "if",
                    "@entity.isSuccess",
                    [
                      "agent/reinforce",
                      "@payload.memoryId"
                    ],
                    [
                      "agent/decay"
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      "@entity.consecutiveFailures",
                      3.0
                    ],
                    [
                      "agent/switch-provider",
                      "anthropic"
                    ],
                    [
                      "log",
                      "No provider switch needed"
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    "analyzing"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Outcome: ",
                      "@entity.outcome",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Result: ",
                      [
                        "if",
                        "@entity.isSuccess",
                        "success",
                        "failure"
                      ],
                      "\n",
                      "Consecutive failures: ",
                      [
                        "str/concat",
                        "@entity.consecutiveFailures"
                      ],
                      "\n\n",
                      "Analyze the impact of this outcome. What should be learned? Keep it to 1-2 sentences."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "cpu"
                        },
                        {
                          "variant": "h3",
                          "content": "Analyzing impact...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "@entity.category",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.outcome"
                            }
                          ],
                          "justify": "center",
                          "gap": "md",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "recording",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "graduation-cap",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Outcome Learner"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Successes",
                              "value": "@entity.totalSuccesses",
                              "icon": "check-circle",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "x-circle",
                              "label": "Failures",
                              "value": "@entity.totalFailures"
                            },
                            {
                              "value": "@entity.provider",
                              "icon": "cpu",
                              "label": "Current Provider",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "Listening for task outcomes..."
                                },
                                {
                                  "type": "typography",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Outcome",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Impact Analysis"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.impact",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "analyzing",
                "to": "idle",
                "event": "ANALYSIS_DONE",
                "effects": [
                  [
                    "set",
                    "@entity.impact",
                    "@payload.impact"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.provider",
                    [
                      "agent/provider"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "graduation-cap"
                            },
                            {
                              "type": "typography",
                              "content": "Outcome Learner",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "@entity.totalSuccesses"
                            },
                            {
                              "icon": "x-circle",
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.totalFailures"
                            },
                            {
                              "icon": "cpu",
                              "value": "@entity.provider",
                              "label": "Current Provider",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Listening for task outcomes...",
                                  "variant": "body"
                                },
                                {
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.",
                                  "variant": "caption",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Last Outcome"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.outcome",
                                  "variant": "body"
                                },
                                {
                                  "content": "Impact Analysis",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.impact",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "analyzing",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "graduation-cap"
                            },
                            {
                              "content": "Outcome Learner",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.totalSuccesses",
                              "icon": "check-circle",
                              "label": "Successes"
                            },
                            {
                              "value": "@entity.totalFailures",
                              "label": "Failures",
                              "icon": "x-circle",
                              "type": "stat-display"
                            },
                            {
                              "icon": "cpu",
                              "type": "stat-display",
                              "label": "Current Provider",
                              "value": "@entity.provider"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Listening for task outcomes...",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "This module records TASK_SUCCEEDED and TASK_FAILED events automatically."
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Last Outcome",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.outcome"
                                },
                                {
                                  "content": "Impact Analysis",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.impact"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "LearnerRecordsBrowse",
          "linkedEntity": "AgentLearner"
        },
        {
          "ref": "AgentMemory.traits.AgentMemoryBrowse",
          "name": "LearnerMemoryLifecycle",
          "linkedEntity": "AgentLearner",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentCompletion.traits.AgentCompletionModal",
          "name": "LearnerCompletionFlow",
          "linkedEntity": "AgentLearner",
          "emitsScope": "internal"
        },
        {
          "ref": "AgentProvider.traits.AgentProviderModal",
          "name": "LearnerProviderManager",
          "linkedEntity": "AgentLearner",
          "emitsScope": "internal"
        }
      ],
      "pages": [
        {
          "name": "AgentLearnerPage",
          "path": "/agentlearners",
          "traits": [
            {
              "ref": "AgentLearnerLearner"
            },
            {
              "ref": "LearnerRecordsBrowse"
            },
            {
              "ref": "LearnerMemoryLifecycle"
            },
            {
              "ref": "LearnerCompletionFlow"
            },
            {
              "ref": "LearnerProviderManager"
            }
          ]
        }
      ]
    }
  ]
}
