{
  "description": "std-agent-tool-loop as a Function",
  "name": "std-agent-tool-loop",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the loop.",
            "name": "name",
            "synonyms": "label, identifier, title",
            "type": "string"
          },
          {
            "description": "A textual explanation of the field's content.",
            "name": "description",
            "synonyms": "explanation, details, notes, summary",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Indicates the current operational state of the loop.",
            "name": "status",
            "synonyms": "state, condition, operational_status",
            "type": "string",
            "values": [
              "idle",
              "in_progress",
              "planning",
              "completed",
              "failed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "The identifier or name of the assigned task.",
            "name": "task",
            "synonyms": "taskName, identifier, job",
            "type": "string"
          },
          {
            "default": "",
            "description": "A textual representation of the operational plan.",
            "name": "plan",
            "synonyms": "strategy, outline, sequence, steps",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of times a process repeats.",
            "name": "iterations",
            "synonyms": "count, repeats, loops",
            "type": "number"
          },
          {
            "default": 10.0,
            "description": "The maximum number of iterations allowed.",
            "name": "maxIterations",
            "synonyms": "limit, count, maximum",
            "type": "number"
          },
          {
            "default": "",
            "description": "The output or outcome of a process or operation.",
            "name": "result",
            "synonyms": "output, outcome, value, data",
            "type": "string"
          },
          {
            "default": "",
            "description": "The name of the tool currently being executed.",
            "name": "currentTool",
            "synonyms": "tool, toolName, activeTool",
            "type": "string"
          },
          {
            "default": "",
            "description": "The outcome of the last tool execution.",
            "name": "lastToolResult",
            "synonyms": "output, result, value",
            "type": "string"
          },
          {
            "default": "",
            "description": "Details about any errors encountered during processing.",
            "name": "error",
            "synonyms": "failure, problem, issue, fault",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The index of the current step in a sequence.",
            "name": "currentStep",
            "synonyms": "step, index, position",
            "type": "number"
          },
          {
            "default": 4.0,
            "description": "The total number of steps in the process.",
            "name": "totalSteps",
            "synonyms": "count, quantity, number, size",
            "type": "number"
          },
          {
            "default": "Plan,Execute,Check,Complete",
            "description": "A sequence of actions or operations to be performed.",
            "name": "steps",
            "synonyms": "sequence, order, process, stages",
            "type": "string"
          },
          {
            "default": "",
            "description": "The name of the tool being used.",
            "name": "toolName",
            "synonyms": "tool, identifier, reference",
            "type": "string"
          },
          {
            "default": "",
            "description": "Arguments passed to the function.",
            "name": "args",
            "synonyms": "parameters, inputs, arguments",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text input provided to the tool.",
            "name": "prompt",
            "synonyms": "query, input, request",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text-based output generated by a tool.",
            "name": "response",
            "synonyms": "output, answer, content, text",
            "type": "string"
          },
          {
            "default": "anthropic",
            "description": "Specifies the source or origin of the data.",
            "name": "provider",
            "synonyms": "source, origin, vendor",
            "type": "string"
          },
          {
            "default": "claude-sonnet-4-20250514",
            "description": "The identifier of the language model used.",
            "name": "model",
            "synonyms": "model_id, language_model, llm",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of tokens used.",
            "name": "tokenCount",
            "synonyms": "count, quantity, total",
            "type": "number"
          },
          {
            "default": 200000.0,
            "description": "The maximum number of tokens allowed for processing.",
            "name": "maxTokens",
            "synonyms": "limit, token limit, max length",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "Represents the number of times the component has been utilized.",
            "name": "usage",
            "synonyms": "count, uses, invocations, frequency",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The current value of a numerical measurement or counter.",
            "name": "current",
            "synonyms": "value, count, level, index",
            "type": "number"
          },
          {
            "default": 200000.0,
            "description": "The maximum value allowed or supported.",
            "name": "max",
            "synonyms": "limit, maximum, upper bound",
            "type": "number"
          },
          {
            "default": 0.85,
            "description": "A numerical value representing a limit or boundary.",
            "name": "threshold",
            "synonyms": "limit, boundary, cutoff, level",
            "type": "number"
          },
          {
            "default": "",
            "description": "Timestamp of the last compaction event.",
            "name": "lastCompactedAt",
            "synonyms": "compacted, last compacted, compaction time",
            "type": "string"
          },
          {
            "default": "",
            "description": "The operation or command to be executed.",
            "name": "action",
            "synonyms": "command, operation, task, verb",
            "type": "string"
          },
          {
            "default": "",
            "description": "A detailed explanation or note about a specific event.",
            "name": "detail",
            "synonyms": "note, comment, explanation, remark",
            "type": "string"
          },
          {
            "default": "",
            "description": "The date and time when an event occurred.",
            "name": "timestamp",
            "synonyms": "date, time, when",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The time taken to complete a process, measured in numerical units.",
            "name": "duration",
            "synonyms": "time, length, elapsed, period",
            "type": "number"
          }
        ],
        "name": "AgentToolLoop",
        "persistence": "runtime"
      },
      "name": "AgentToolLoopOrbital",
      "pages": [
        {
          "name": "AgentToolLoopPage",
          "path": "/agenttoolloops",
          "traits": [
            {
              "ref": "AgentToolLoopLoop"
            },
            {
              "ref": "ToolLoopStepProgress"
            },
            {
              "ref": "ToolLoopCompletionFlow"
            },
            {
              "ref": "ToolLoopToolCallFlow"
            },
            {
              "ref": "ToolLoopContextMonitor"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "linkedEntity": "AgentToolLoop",
          "name": "AgentToolLoopLoop",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXECUTE",
                "name": "Execute"
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "toolArgs",
                    "required": true,
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TOOL_RESULT",
                "name": "Tool Result",
                "payloadSchema": [
                  {
                    "name": "output",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHECK_PASSED",
                "name": "Check Passed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHECK_NEEDS_MORE",
                "name": "Check Needs More",
                "payloadSchema": [
                  {
                    "name": "toolName",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "toolArgs",
                    "required": true,
                    "type": "object"
                  }
                ]
              },
              {
                "key": "MAX_ITERATIONS",
                "name": "Max Iterations",
                "payloadSchema": [
                  {
                    "name": "error",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "planning"
              },
              {
                "name": "executing"
              },
              {
                "name": "checking"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.maxIterations",
                    10.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "content": "Tool Execution Loop",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Describe the task to execute with tools",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "entity": "@entity",
                                  "fields": [
                                    "task"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "EXECUTE",
                                  "type": "form-section"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n\nAvailable tools: ",
                      [
                        "str/join",
                        [
                          "agent/tools"
                        ],
                        ", "
                      ],
                      "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "brain",
                          "type": "icon"
                        },
                        {
                          "content": "Planning execution...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.task",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "EXECUTE",
                "from": "idle",
                "to": "planning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.plan"
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "tool",
                                  "type": "icon"
                                },
                                {
                                  "content": "Executing Tool",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "label": "@entity.maxIterations",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Current Tool",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.currentTool",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "type": "spinner"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.plan",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PLAN_GENERATED",
                "from": "planning",
                "to": "executing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Loop Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "icon": "shield",
                              "label": "Max Allowed",
                              "type": "stat-display",
                              "value": "@entity.maxIterations"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAILED",
                "from": "planning",
                "to": "failed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lastToolResult",
                    "@payload.output"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\nPlan: ",
                      "@entity.plan",
                      "\nTool output: ",
                      "@payload.output",
                      "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "eye",
                          "type": "icon"
                        },
                        {
                          "content": "Checking result...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "label": "@entity.iterations",
                          "type": "badge"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "TOOL_RESULT",
                "from": "executing",
                "to": "checking"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Loop Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "icon": "shield",
                              "label": "Max Allowed",
                              "type": "stat-display",
                              "value": "@entity.maxIterations"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAILED",
                "from": "executing",
                "to": "failed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Loop Complete",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "action": "RESET",
                              "icon": "rotate-ccw",
                              "label": "New Task",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "icon": "check",
                              "label": "Status",
                              "type": "stat-display",
                              "value": "@entity.status"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Task",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.task",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "content": "Result",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.result",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CHECK_PASSED",
                "from": "checking",
                "to": "completed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      [
                        "agent/context-usage"
                      ],
                      0.8
                    ],
                    [
                      "agent/compact",
                      "hybrid"
                    ],
                    [
                      "log",
                      "Context below compact threshold"
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "tool",
                                  "type": "icon"
                                },
                                {
                                  "content": "Executing Tool",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "label": "@entity.maxIterations",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Current Tool",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.currentTool",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "type": "spinner"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.plan",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CHECK_NEEDS_MORE",
                "from": "checking",
                "to": "executing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Loop Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "icon": "shield",
                              "label": "Max Allowed",
                              "type": "stat-display",
                              "value": "@entity.maxIterations"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "MAX_ITERATIONS",
                "from": "checking",
                "to": "failed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.result",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    ""
                  ],
                  [
                    "set",
                    "@entity.lastToolResult",
                    ""
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "content": "Tool Execution Loop",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Describe the task to execute with tools",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "entity": "@entity",
                                  "fields": [
                                    "task"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "EXECUTE",
                                  "type": "form-section"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "completed",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.result",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    ""
                  ],
                  [
                    "set",
                    "@entity.lastToolResult",
                    ""
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "content": "Tool Execution Loop",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Describe the task to execute with tools",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "entity": "@entity",
                                  "fields": [
                                    "task"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "EXECUTE",
                                  "type": "form-section"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "failed",
                "to": "idle"
              }
            ]
          }
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentToolLoop",
          "name": "ToolLoopStepProgress",
          "ref": "AgentStepProgress.traits.AgentStepProgressProgress"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentToolLoop",
          "name": "ToolLoopCompletionFlow",
          "ref": "AgentCompletion.traits.AgentCompletionModal"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentToolLoop",
          "name": "ToolLoopToolCallFlow",
          "ref": "AgentToolCall.traits.AgentToolCallModal"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentToolLoop",
          "name": "ToolLoopContextMonitor",
          "ref": "AgentContextWindow.traits.AgentContextWindowGauge"
        }
      ],
      "uses": [
        {
          "as": "AgentCompletion",
          "from": "std/behaviors/std-agent-completion"
        },
        {
          "as": "AgentContextWindow",
          "from": "std/behaviors/std-agent-context-window"
        },
        {
          "as": "AgentStepProgress",
          "from": "std/behaviors/std-agent-step-progress"
        },
        {
          "as": "AgentToolCall",
          "from": "std/behaviors/std-agent-tool-call"
        }
      ]
    }
  ],
  "version": "1.0.0"
}