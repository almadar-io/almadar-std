{
  "name": "std-agent-tool-loop",
  "version": "1.0.0",
  "description": "std-agent-tool-loop as a Function",
  "orbitals": [
    {
      "name": "AgentToolLoopOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-completion",
          "as": "AgentCompletion"
        },
        {
          "from": "std/behaviors/std-agent-context-window",
          "as": "AgentContextWindow"
        },
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        },
        {
          "from": "std/behaviors/std-agent-tool-call",
          "as": "AgentToolCall"
        }
      ],
      "entity": {
        "name": "AgentToolLoop",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "task",
            "type": "string",
            "default": ""
          },
          {
            "name": "plan",
            "type": "string",
            "default": ""
          },
          {
            "name": "iterations",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxIterations",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentTool",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastToolResult",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "steps",
            "type": "string",
            "default": "Plan,Execute,Check,Complete"
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          },
          {
            "name": "args",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "usage",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "current",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "max",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.85
          },
          {
            "name": "lastCompactedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AgentToolLoopLoop",
          "category": "interaction",
          "linkedEntity": "AgentToolLoop",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "planning"
              },
              {
                "name": "executing"
              },
              {
                "name": "checking"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXECUTE",
                "name": "Execute"
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolArgs",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOOL_RESULT",
                "name": "Tool Result",
                "payloadSchema": [
                  {
                    "name": "output",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CHECK_PASSED",
                "name": "Check Passed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CHECK_NEEDS_MORE",
                "name": "Check Needs More",
                "payloadSchema": [
                  {
                    "name": "toolName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "toolArgs",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "MAX_ITERATIONS",
                "name": "Max Iterations",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.maxIterations",
                    10.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "repeat"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Tool Execution Loop"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "body",
                                  "content": "Describe the task to execute with tools",
                                  "type": "typography"
                                },
                                {
                                  "mode": "edit",
                                  "type": "form-section",
                                  "fields": [
                                    "task"
                                  ],
                                  "entity": "@entity",
                                  "submitEvent": "EXECUTE"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "planning",
                "event": "EXECUTE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n\nAvailable tools: ",
                      [
                        "str/join",
                        [
                          "agent/tools"
                        ],
                        ", "
                      ],
                      "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "brain"
                        },
                        {
                          "type": "typography",
                          "content": "Planning execution...",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.task",
                          "variant": "caption"
                        }
                      ],
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "executing",
                "event": "PLAN_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.plan"
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "tool"
                                },
                                {
                                  "content": "Executing Tool",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "badge",
                              "label": "@entity.maxIterations"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Current Tool",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.currentTool",
                                  "variant": "h4",
                                  "type": "typography"
                                },
                                {
                                  "type": "spinner"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.plan"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Loop Failed"
                        },
                        {
                          "message": "@entity.error",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "value": "@entity.iterations"
                            },
                            {
                              "label": "Max Allowed",
                              "type": "stat-display",
                              "value": "@entity.maxIterations",
                              "icon": "shield"
                            }
                          ]
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "checking",
                "event": "TOOL_RESULT",
                "effects": [
                  [
                    "set",
                    "@entity.lastToolResult",
                    "@payload.output"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\nPlan: ",
                      "@entity.plan",
                      "\nTool output: ",
                      "@payload.output",
                      "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "eye",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Checking result...",
                          "type": "typography"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "label": "@entity.iterations",
                          "type": "badge"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "failed",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "variant": "h2",
                          "content": "Loop Failed",
                          "type": "typography"
                        },
                        {
                          "variant": "error",
                          "message": "@entity.error",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Iterations Used",
                              "value": "@entity.iterations",
                              "icon": "repeat"
                            },
                            {
                              "label": "Max Allowed",
                              "icon": "shield",
                              "value": "@entity.maxIterations",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "completed",
                "event": "CHECK_PASSED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "justify": "between",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Loop Complete"
                                }
                              ]
                            },
                            {
                              "action": "RESET",
                              "type": "button",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "label": "New Task"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Iterations",
                              "icon": "repeat",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "icon": "check",
                              "value": "@entity.status",
                              "type": "stat-display",
                              "label": "Status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Task",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.task",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Result"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.result",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "executing",
                "event": "CHECK_NEEDS_MORE",
                "effects": [
                  [
                    "set",
                    "@entity.currentTool",
                    "@payload.toolName"
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    [
                      "+",
                      "@entity.iterations",
                      1.0
                    ]
                  ],
                  [
                    "if",
                    [
                      ">=",
                      [
                        "agent/context-usage"
                      ],
                      0.8
                    ],
                    [
                      "agent/compact",
                      "hybrid"
                    ],
                    [
                      "log",
                      "Context below compact threshold"
                    ]
                  ],
                  [
                    "agent/invoke",
                    "@payload.toolName",
                    "@payload.toolArgs"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "tool"
                                },
                                {
                                  "type": "typography",
                                  "content": "Executing Tool",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "label": "@entity.maxIterations",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Current Tool",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.currentTool",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "type": "spinner"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.plan"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "checking",
                "to": "failed",
                "event": "MAX_ITERATIONS",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "content": "Loop Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "repeat",
                              "label": "Iterations Used",
                              "type": "stat-display",
                              "value": "@entity.iterations"
                            },
                            {
                              "value": "@entity.maxIterations",
                              "type": "stat-display",
                              "icon": "shield",
                              "label": "Max Allowed"
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "action": "RESET",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.result",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTool",
                    ""
                  ],
                  [
                    "set",
                    "@entity.lastToolResult",
                    ""
                  ],
                  [
                    "set",
                    "@entity.iterations",
                    0.0
