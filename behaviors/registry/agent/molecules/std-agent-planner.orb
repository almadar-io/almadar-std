{
  "description": "std-agent-planner as a Function",
  "name": "std-agent-planner",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the agent planner.",
            "name": "name",
            "synonyms": "title, label, identifier",
            "type": "string"
          },
          {
            "description": "A textual explanation of the component's functionality.",
            "name": "description",
            "synonyms": "explanation, details, notes, summary",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Indicates the current operational state of the component.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "idle",
              "classifying",
              "recalling",
              "planning",
              "ready",
              "error"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "The objective or goal to be achieved.",
            "name": "task",
            "synonyms": "objective, goal, purpose, aim",
            "type": "string"
          },
          {
            "default": "",
            "description": "Classification or grouping of the agent planner.",
            "name": "category",
            "synonyms": "type, group, classification",
            "type": "string"
          },
          {
            "default": "",
            "description": "Ordered sequence of actions to achieve a goal.",
            "name": "steps",
            "synonyms": "sequence, process, instructions, procedure",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "Represents the certainty level of a prediction or result.",
            "name": "confidence",
            "synonyms": "probability, certainty, likelihood, score",
            "type": "number"
          },
          {
            "default": "",
            "description": "References to memories deemed important for the task.",
            "name": "relevantMemories",
            "synonyms": "memory references, related memories, memory IDs",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of memories associated with this planner.",
            "name": "memoryCount",
            "synonyms": "count, size, quantity",
            "type": "number"
          },
          {
            "default": "",
            "description": "Details about any errors encountered during processing.",
            "name": "error",
            "synonyms": "failure, problem, issue, fault",
            "type": "string"
          },
          {
            "default": "",
            "description": "Data provided as an initial value or parameter.",
            "name": "input",
            "synonyms": "parameter, argument, value, initialData",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text used as input for generating a response.",
            "name": "prompt",
            "synonyms": "query, instruction, request, text",
            "type": "string"
          },
          {
            "default": "",
            "description": "The output generated by the agent.",
            "name": "response",
            "synonyms": "result, output, answer",
            "type": "string"
          },
          {
            "default": "anthropic",
            "description": "Identifies the source or origin of the data.",
            "name": "provider",
            "synonyms": "source, origin, supplier",
            "type": "string"
          },
          {
            "default": "claude-sonnet-4-20250514",
            "description": "The identifier of the language model used.",
            "name": "model",
            "synonyms": "model_id, language_model, llm",
            "type": "string"
          },
          {
            "default": "",
            "description": "The textual data associated with the planner's output.",
            "name": "content",
            "synonyms": "text, data, body, payload",
            "type": "string"
          },
          {
            "default": "",
            "description": "The area or domain this planner applies to.",
            "name": "scope",
            "synonyms": "domain, area, range, boundaries",
            "type": "string"
          },
          {
            "default": 1.0,
            "description": "A numerical value representing the intensity or magnitude.",
            "name": "strength",
            "synonyms": "magnitude, intensity, power, value",
            "type": "number"
          },
          {
            "default": false,
            "description": "Indicates whether the item is marked as important.",
            "name": "pinned",
            "synonyms": "flagged, marked, favorited",
            "type": "boolean"
          },
          {
            "default": "",
            "description": "The specific action to be performed.",
            "name": "action",
            "synonyms": "command, operation, task",
            "type": "string"
          },
          {
            "default": "",
            "description": "A more in-depth explanation or elaboration.",
            "name": "detail",
            "synonyms": "notes, specifics, particulars, elaboration",
            "type": "string"
          },
          {
            "default": "",
            "description": "The date and time when the event occurred.",
            "name": "timestamp",
            "synonyms": "date, time, when",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The length of time an operation took, typically in seconds.",
            "name": "duration",
            "synonyms": "time, length, elapsed",
            "type": "number"
          },
          {
            "default": "circle",
            "description": "A visual representation, often a symbol or image.",
            "name": "icon",
            "synonyms": "image, symbol, graphic, visual",
            "type": "string"
          }
        ],
        "name": "AgentPlanner",
        "persistence": "runtime"
      },
      "name": "AgentPlannerOrbital",
      "pages": [
        {
          "name": "AgentPlannerPage",
          "path": "/agentplanners",
          "traits": [
            {
              "ref": "AgentPlannerPlanner"
            },
            {
              "ref": "PlannerTaskInput"
            },
            {
              "ref": "PlannerClassifierFlow"
            },
            {
              "ref": "PlannerCompletionFlow"
            },
            {
              "ref": "PlannerMemoryLifecycle"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "PLAN_READY",
              "payloadSchema": [
                {
                  "name": "plan",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ],
              "scope": "external"
            }
          ],
          "linkedEntity": "AgentPlanner",
          "listens": [
            {
              "event": "PLAN_READY",
              "source": {
                "kind": "trait",
                "trait": "AgentPlannerPlanner"
              },
              "triggers": "INIT"
            },
            {
              "event": "PLAN",
              "source": {
                "kind": "trait",
                "trait": "PlannerTaskInput"
              },
              "triggers": "PLAN"
            }
          ],
          "name": "AgentPlannerPlanner",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN",
                "name": "Plan"
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified",
                "payloadSchema": [
                  {
                    "name": "category",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEMORIES_LOADED",
                "name": "Memories Loaded",
                "payloadSchema": [
                  {
                    "name": "memories",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "count",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payloadSchema": [
                  {
                    "name": "steps",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "confidence",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PLAN_READY",
                "name": "Plan Ready",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "classifying"
              },
              {
                "name": "recalling"
              },
              {
                "name": "planning"
              },
              {
                "name": "ready"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "content": "Task Planner",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Describe the task to plan",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "entity": "@entity",
                                  "fields": [
                                    "task"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "PLAN",
                                  "type": "form-section"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "classifying"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify this task into exactly one category.\n",
                      "Categories: ",
                      "code, schema, design, debug, deploy",
                      "\n",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Return only the category name."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "tag",
                          "type": "icon"
                        },
                        {
                          "content": "Classifying task...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "@entity.task",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PLAN",
                "from": "idle",
                "to": "classifying"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recalling"
                  ],
                  [
                    "agent/recall",
                    [
                      "str/concat",
                      "@entity.category",
                      " ",
                      "@entity.task"
                    ],
                    5.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "brain",
                          "type": "icon"
                        },
                        {
                          "content": "Recalling relevant experience...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "label": "@entity.category",
                          "type": "badge"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CLASSIFIED",
                "from": "classifying",
                "to": "recalling"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Planning Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Try Again",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAILED",
                "from": "classifying",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.relevantMemories",
                    "@payload.memories"
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Relevant experience:\n",
                      "@entity.relevantMemories",
                      "\n\n",
                      "Generate a numbered step-by-step execution plan. ",
                      "Include a confidence score (0-100) for how likely this plan will succeed."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "cpu",
                          "type": "icon"
                        },
                        {
                          "content": "Generating plan...",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "spinner"
                        },
                        {
                          "children": [
                            {
                              "label": "@entity.category",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.memoryCount",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "MEMORIES_LOADED",
                "from": "recalling",
                "to": "planning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Planning Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Try Again",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAILED",
                "from": "recalling",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.steps",
                    "@payload.steps"
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    "@payload.confidence"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "ready"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Plan for ",
                      "@entity.category",
                      " task: ",
                      "@entity.task"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "emit",
                    "PLAN_READY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Plan Ready",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "action": "RESET",
                              "icon": "rotate-ccw",
                              "label": "New Plan",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "tag",
                              "label": "Category",
                              "type": "stat-display",
                              "value": "@entity.category"
                            },
                            {
                              "icon": "target",
                              "label": "Confidence",
                              "type": "stat-display",
                              "value": "@entity.confidence"
                            },
                            {
                              "icon": "brain",
                              "label": "Memories Used",
                              "type": "stat-display",
                              "value": "@entity.memoryCount"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Task",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.task",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "content": "Execution Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.steps",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Relevant Memories",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.relevantMemories",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PLAN_GENERATED",
                "from": "planning",
                "to": "ready"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Planning Failed",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "message": "@entity.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Try Again",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAILED",
                "from": "planning",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.task",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.steps",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.relevantMemories",
                    ""
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "content": "Task Planner",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Describe the task to plan",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "entity": "@entity",
                                  "fields": [
                                    "task"
                                  ],
                                  "mode": "edit",
                                  "submitEvent": "PLAN",
                                  "type": "form-section"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "ready",
                "to": "idle"
              }
            ]
          }
        },
        {
          "config": {
            "fields": [
              "task"
            ],
            "icon": "plus-circle",
            "mode": "create",
            "title": "New Task"
          },
          "events": {
            "OPEN": "NEW_TASK",
            "SAVE": "PLAN"
          },
          "linkedEntity": "AgentPlanner",
          "name": "PlannerTaskInput",
          "ref": "Modal.traits.ModalRecordModal"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentPlanner",
          "name": "PlannerClassifierFlow",
          "ref": "AgentClassifier.traits.AgentClassifierModal"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentPlanner",
          "name": "PlannerCompletionFlow",
          "ref": "AgentCompletion.traits.AgentCompletionModal"
        },
        {
          "emitsScope": "internal",
          "linkedEntity": "AgentPlanner",
          "name": "PlannerMemoryLifecycle",
          "ref": "AgentMemory.traits.AgentMemoryBrowse"
        }
