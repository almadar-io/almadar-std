          "name": "AssistantContextAgent",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Tokens"
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payloadSchema": [
                  {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  }
                ]
              },
