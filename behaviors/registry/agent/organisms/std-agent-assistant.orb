                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
                          "label": "Memory"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "normal",
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "normal",
                "guard": [
                  "<",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  0.85
                ],
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Token usage approaching limit",
                      "notificationType": "warning"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "normal",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "to": "approaching_limit"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Token usage at limit",
                      "notificationType": "error"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "approaching_limit",
                "guard": [
                  ">=",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  1.0
                ],
                "to": "at_limit"
              },
              {
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ],
                "event": "COMPACT",
                "from": "approaching_limit",
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "approaching_limit",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "to": "approaching_limit"
              },
              {
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
