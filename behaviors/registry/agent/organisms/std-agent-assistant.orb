                    "agent/forget",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "FORGOT"
                  ]
                ],
                "event": "FORGET",
                "from": "active",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "agent/reinforce",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "REINFORCED"
                  ]
                ],
                "event": "REINFORCE",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED"
                  ]
                ],
                "event": "DECAY",
                "from": "active",
                "to": "active"
              }
            ]
          }
        }
