                ],
                "event": "SWITCHED",
                "from": "active",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.fallbackProvider"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@entity.fallbackProvider"
                  ]
                ],
                "event": "SWITCH_AUTO",
                "from": "active",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "set",
                    "@entity.requestCount",
                    [
                      "+",
                      "@entity.requestCount",
                      1.0
                    ]
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Provider switched",
                      "notificationType": "info"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "switching",
                "to": "active"
              }
            ]
          }
        }
      ]
    },
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "A sequence of text representing the conversation history.",
            "name": "messages",
            "synonyms": "history, transcript, dialogue",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text of the most recent message in the conversation.",
            "name": "currentMessage",
            "synonyms": "text, latest message, recent content",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text generated as an output.",
            "name": "response",
            "synonyms": "reply, answer, output, result",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of memory entries stored.",
            "name": "memoryCount",
            "synonyms": "count, size, quantity",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "Represents the amount of context utilized.",
            "name": "contextUsage",
            "synonyms": "usage, consumption, utilization",
            "type": "number"
          },
          {
            "default": "default",
            "description": "Specifies the external service or system providing the functionality.",
            "name": "provider",
            "synonyms": "source, origin, backend, service",
            "type": "string"
          },
          {
            "default": "",
            "description": "Unique identifier for a user's session.",
            "name": "sessionId",
            "synonyms": "session, sessionID",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Indicates the current operational state of the component.",
            "name": "status",
            "synonyms": "state, condition, mode",
            "type": "string"
          },
          {
            "default": "",
            "description": "Details about any errors encountered during processing.",
            "name": "error",
            "synonyms": "problem, fault, issue, exception",
            "type": "string"
          }
        ],
        "name": "AssistantNav",
        "persistence": "runtime"
      },
      "name": "AssistantNavOrbital",
      "pages": [
        {
          "name": "AssistantNav",
          "path": "/assistant/nav",
          "traits": [
            {
              "ref": "AssistantTabs"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SELECT_TAB",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ]
            },
            {
              "description": "Fired when AssistantNav finishes loading",
              "event": "AssistantNavLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AssistantNav]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AssistantNav fails to load",
              "event": "AssistantNavLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AssistantNav",
          "name": "AssistantTabs",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AssistantNavLoaded",
                "name": "AssistantNav loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AssistantNav]"
                  }
                ]
              },
              {
                "key": "AssistantNavLoadFailed",
                "name": "AssistantNav load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAB",
                "name": "Select Tab",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AssistantNav",
                    {
                      "emit": {
                        "failure": "AssistantNavLoadFailed",
                        "success": "AssistantNavLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Assistant",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "defaultActiveTab": "chat",
                              "tabChangeEvent": "SELECT_TAB",
                              "tabs": [
                                {
                                  "label": "Chat",
                                  "value": "chat"
                                },
                                {
                                  "label": "Memory",
                                  "value": "memory"
                                },
                                {
                                  "label": "Settings",
                                  "value": "settings"
                                }
                              ],
                              "type": "tabs"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "className": "transition-shadow hover:shadow-md cursor-pointer",
                              "entity": "@payload.data",
                              "fields": [],
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "children": [
                                    {
                                      "content": "@item.messages",
                                      "type": "typography",
                                      "variant": "h4"
                                    },
                                    {
                                      "color": "muted",
                                      "content": "@item.currentMessage",
                                      "type": "typography",
                                      "variant": "caption"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "sm",
                                  "type": "stack"
                                }
                              ],
                              "type": "data-grid"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
                          "label": "Memory"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "AssistantNavLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AssistantNavLoadFailed",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AssistantNav",
                    {
                      "emit": {
                        "failure": "AssistantNavLoadFailed",
                        "success": "AssistantNavLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "SELECT_TAB",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    },
