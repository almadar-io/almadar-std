{
  "description": "Agent chat assistant: conversation, persistent memory, provider config (ChatGPT-style).",
  "name": "std-agent-assistant",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "A sequence of text representing a conversation.",
            "name": "messages",
            "synonyms": "conversation, transcript, dialogue, chat",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text of the most recent message in the conversation.",
            "name": "currentMessage",
            "synonyms": "text, body, content",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text generated as an output.",
            "name": "response",
            "synonyms": "reply, answer, output, result",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of memory entries.",
            "name": "memoryCount",
            "synonyms": "count, size, quantity",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "Represents the amount of context utilized.",
            "name": "contextUsage",
            "synonyms": "usage, consumption, utilization",
            "type": "number"
          },
          {
            "default": "default",
            "description": "Specifies the external service or system used.",
            "name": "provider",
            "synonyms": "service, source, backend",
            "type": "string"
          },
          {
            "default": "",
            "description": "Unique identifier for a user's session.",
            "name": "sessionId",
            "synonyms": "session, sessionID",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Indicates the current operational state of the component.",
            "name": "status",
            "synonyms": "state, condition, mode",
            "type": "string"
          },
          {
            "default": "",
            "description": "Details about any errors encountered during operation.",
            "name": "error",
            "synonyms": "issue, problem, fault, exception",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of interactions in the conversation.",
            "name": "turnCount",
            "synonyms": "interaction count, round number, sequence number",
            "type": "number"
          },
          {
            "default": "",
            "description": "The text of the most recent message.",
            "name": "lastMessage",
            "synonyms": "last, recent, previous",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of tokens used.",
            "name": "tokenCount",
            "synonyms": "count, quantity, total",
            "type": "number"
          },
          {
            "default": "user",
            "description": "Specifies the function or identity within the interaction.",
            "name": "role",
            "synonyms": "function, identity, persona, type",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text of the message or content being processed.",
            "name": "content",
            "synonyms": "text, body, data",
            "type": "string"
          },
          {
            "default": "",
            "description": "Date and time when the event occurred.",
            "name": "timestamp",
            "synonyms": "date, time, when",
            "type": "string"
          },
          {
            "default": "",
            "description": "Name of the tool utilized by the assistant.",
            "name": "toolName",
            "synonyms": "tool, function, action",
            "type": "string"
          }
        ],
        "name": "Assistant",
        "persistence": "runtime"
      },
      "name": "AssistantOrbital",
      "pages": [
        {
          "name": "ChatPage",
          "path": "/chat",
          "traits": [
            {
              "ref": "AssistantConversation"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SEND_MESSAGE",
              "payloadSchema": [
                {
                  "name": "content",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "MEMORIZE_RESPONSE",
              "payloadSchema": [
                {
                  "name": "content",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "MEMORIZE_RESPONSE",
              "payloadSchema": [
                {
                  "name": "content",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "description": "Fired when Assistant finishes loading",
              "event": "AssistantLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Assistant]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when Assistant fails to load",
              "event": "AssistantLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "AssistantDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "AssistantDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "MemorySaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "MemorySaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "ProviderConfigUpdated",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "ProviderConfigUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "Assistant",
          "listens": [
            {
              "event": "PROVIDER_CHANGED",
              "source": {
                "kind": "orbital",
                "orbital": "ProviderConfigOrbital",
                "trait": "ProviderManager"
              },
              "triggers": "INIT"
            }
          ],
          "name": "AssistantConversation",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AssistantLoaded",
                "name": "Assistant loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Assistant]"
                  }
                ]
              },
              {
                "key": "AssistantLoadFailed",
                "name": "Assistant load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL_COMPOSE",
                "name": "Cancel Compose"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEMORIZE_RESPONSE",
                "name": "Memorize Response",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantDeleted",
                "name": "Assistant deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantDeleteFailed",
                "name": "Assistant delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MemorySaved",
                "name": "Memory saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MemorySaveFailed",
                "name": "Memory save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProviderConfigUpdated",
                "name": "Provider config updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProviderConfigUpdateFailed",
                "name": "Provider config update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading assistant…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "message-circle",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Assistant Thread",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack"
                                },
                                {
                                  "action": "COMPOSE",
                                  "icon": "plus",
                                  "label": "New Message",
                                  "type": "button",
                                  "variant": "primary"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "@payload.data",
                              "fields": [],
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "children": [
                                    {
                                      "align": "center",
                                      "children": [
                                        {
                                          "label": "@item.role",
                                          "type": "badge"
                                        },
                                        {
                                          "label": "@item.status",
                                          "type": "badge",
                                          "variant": "secondary"
                                        },
                                        {
                                          "color": "muted",
                                          "content": "@item.timestamp",
                                          "type": "typography",
                                          "variant": "caption"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "gap": "sm",
                                      "type": "stack"
                                    },
                                    {
                                      "content": "@item.content",
                                      "type": "typography",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "xs",
                                  "type": "stack"
                                }
                              ],
                              "type": "data-list"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
                          "label": "Memory"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "AssistantLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load assistant",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AssistantLoadFailed",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "message-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Assistant Thread",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CANCEL_COMPOSE",
                          "fields": [
                            "content"
                          ],
                          "mode": "create",
                          "submitEvent": "SEND",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "COMPOSE",
                "from": "idle",
                "to": "composing"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantDeleteFailed",
                        "success": "AssistantDeleted"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "CLEAR",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "Assistant",
                    {
                      "content": "@payload.content",
                      "role": "user",
                      "status": "sent",
                      "timestamp": "@now"
                    },
                    {
                      "emit": {
                        "success": "SEND_MESSAGE"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "SEND",
                "from": "composing",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "CANCEL_COMPOSE",
                "from": "composing",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantDeleteFailed",
                        "success": "AssistantDeleted"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "CLEAR",
                "from": "composing",
                "to": "idle"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "TOKEN_UPDATE",
              "payloadSchema": [
                {
                  "name": "tokenCount",
                  "type": "number"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when Assistant finishes loading",
              "event": "AssistantLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Assistant]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when Assistant fails to load",
              "event": "AssistantLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "Assistant",
          "name": "AssistantAgent",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payloadSchema": [
                  {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update",
                "payloadSchema": [
                  {
                    "name": "tokenCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AssistantLoaded",
                "name": "Assistant loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Assistant]"
                  }
                ]
              },
              {
                "key": "AssistantLoadFailed",
                "name": "Assistant load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "description": "Conversation is ready",
                          "icon": "message-circle",
                          "title": "Conversation",
                          "type": "empty-state"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
                          "label": "Memory"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "idle",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "active",
                "to": "active"
              },
              {
                "event": "PAUSE",
                "from": "active",
                "to": "paused"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    ""
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ],
                "event": "CLEAR",
                "from": "active",
                "to": "idle"
              },
              {
                "event": "RESUME",
                "from": "paused",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    ""
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ],
                "event": "CLEAR",
                "from": "paused",
                "to": "idle"
              }
            ]
          }
        }
      ]
    },
    {
      "entity": {
        "collection": "memorys",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
