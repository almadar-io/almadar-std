                "key": "AssistantContextLoaded",
                "name": "AssistantContext loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AssistantContext]"
                  }
                ]
              },
              {
                "key": "AssistantContextLoadFailed",
                "name": "AssistantContext load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "normal"
              },
              {
                "name": "approaching_limit"
              },
              {
                "name": "at_limit"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.maxTokens",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ],
                  [
                    "fetch",
                    "AssistantContext",
                    {
                      "emit": {
                        "failure": "AssistantContextLoadFailed",
                        "success": "AssistantContextLoaded"
                      }
                    }
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "description": "Context Window is ready",
                          "icon": "layers",
                          "title": "Context Window",
                          "type": "empty-state"
                        }
                      ],
