                      "orbitalName": "@entity.orbitalName"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "building",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.attempts",
                    [
                      "+",
                      "@entity.attempts",
                      1.0
                    ]
                  ],
                  [
                    "behavior/instantiate",
                    "@entity.orbitalName",
                    "@entity.method"
                  ]
                ],
                "event": "BUILD_STEP",
                "from": "building",
                "to": "validating"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "validate/validate",
                    "@entity.orbitalName"
                  ],
                  [
                    "when",
                    [
                      "<",
                      "@entity.attempts",
                      "@entity.maxAttempts"
                    ],
                    [
                      "emit",
                      "PROCESS_RETRY",
                      {
                        "attempt": "@entity.attempts",
                        "orbitalName": "@entity.orbitalName"
                      }
                    ]
                  ],
                  [
                    "when",
                    [
                      ">=",
                      "@entity.attempts",
                      "@entity.maxAttempts"
                    ],
                    [
                      "emit",
                      "PROCESS_DONE",
                      {
                        "orbitalName": "@entity.orbitalName"
                      }
                    ]
                  ]
                ],
                "event": "INIT",
                "from": "validating",
                "to": "validating"
              },
              {
                "event": "PROCESS_RETRY",
                "from": "validating",
                "to": "repairing"
              },
              {
                "event": "PROCESS_DONE",
                "from": "validating",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "repairing"
                  ],
                  [
                    "llm/generate",
                    "@entity.orbitalName",
                    {
                      "emit": {
                        "failure": "FIX_FAILED",
                        "success": "FIX_GENERATED"
                      }
                    }
                  ]
                ],
                "event": "INIT",
                "from": "repairing",
                "to": "fixing"
              },
              {
                "event": "REBUILD",
                "from": "repairing",
                "to": "building"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.fixPrompt",
                    "@payload.result"
                  ],
                  [
                    "emit",
                    "REBUILD",
                    {
                      "orbitalName": "@entity.orbitalName"
                    }
                  ]
                ],
                "event": "FIX_GENERATED",
                "from": "fixing",
                "to": "repairing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.fixPrompt",
                    ""
                  ]
                ],
                "event": "FIX_FAILED",
                "from": "fixing",
                "to": "repairing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "complete"
                  ],
                  [
                    "emit",
                    "ORBITAL_COMPLETE",
                    {
                      "orbitalName": "@entity.orbitalName"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "done",
                "to": "done"
              }
            ]
          }
        },
        {
          "category": "lifecycle",
          "linkedEntity": "OrbitalProcess",
          "listens": [
            {
              "event": "DISPATCHED",
              "source": {
                "kind": "orbital",
                "orbital": "CoordinatorOrbital",
                "trait": "CoordinatorPipeline"
              },
              "triggers": "DISPATCHED"
            }
          ],
          "name": "ProcessDispatcher",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DISPATCHED",
                "name": "Dispatched"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "dispatched"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.orbitalName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.method",
                    "pending"
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.orbitalName",
                    "@entity.orbitalName"
                  ]
                ],
                "event": "DISPATCHED",
                "from": "idle",
                "to": "dispatched"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.orbitalName",
                    "@entity.orbitalName"
                  ]
                ],
                "event": "INIT",
                "from": "dispatched",
                "to": "dispatched"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}