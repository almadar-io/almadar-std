          ],
          "id": "trt_01KXG04ET6EEYB14812TVBQRXY",
          "linkedEntity": "Coordinator",
          "linkedEntityId": "ent_01KXG04ET6Y5GGKTRFESK90Z4E",
          "name": "CoordinatorPipeline",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start",
                "payloadSchema": [
                  {
                    "name": "prompt",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "totalOrbitals",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PLANNED",
                "name": "Planned",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAN_FAILED",
                "name": "Plan Failed"
              },
              {
                "key": "ALL_DONE",
                "name": "All Done"
              },
              {
                "key": "COMPOSED",
                "name": "Composed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE_FAILED",
                "name": "Compose Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "DISPATCHED",
                "name": "Dispatched",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "totalOrbitals",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RABIT_DONE",
                "name": "Rabit Done",
                "payloadSchema": [
                  {
                    "name": "schema",
                    "required": true,
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "planning"
              },
              {
                "name": "monitoring"
              },
              {
                "name": "assembling"
              },
              {
                "name": "done"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.totalOrbitals",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.failedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.composedSchema",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    []
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.prompt",
                    "@payload.prompt"
                  ],
                  [
                    "set",
                    "@entity.totalOrbitals",
                    "@payload.totalOrbitals"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "planning"
                  ],
                  [
                    "llm/generate",
                    "@entity.prompt",
                    {
                      "emit": {
                        "failure": "PLAN_FAILED",
                        "success": "PLANNED"
                      }
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "planning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.result"
                  ],
                  [
                    "session/write-spec",
                    "coordinator-plan",
                    "@entity.plan"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "dispatching"
                  ],
                  [
                    "emit",
                    "DISPATCHED",
                    {
                      "plan": "@entity.plan",
                      "totalOrbitals": "@entity.totalOrbitals"
                    }
                  ]
                ],
                "event": "PLANNED",
                "from": "planning",
                "to": "monitoring"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ]
                ],
                "event": "PLAN_FAILED",
                "from": "planning",
                "to": "monitoring"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "monitoring"
                  ]
                ],
