{
  "description": "Rabit organism — coordinator decomposes a prompt into orbital specs, dispatches subagent builds, monitors completion, assembles and validates the composed schema.",
  "name": "std-agent-rabit",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "name": "prompt",
            "type": "string"
          },
          {
            "default": "idle",
            "name": "phase",
            "type": "string",
            "values": [
              "idle",
              "planning",
              "dispatching",
              "monitoring",
              "assembling",
              "validating",
              "done",
              "failed"
            ]
          },
          {
            "default": "",
            "name": "plan",
            "type": "string"
          },
          {
            "default": 0.0,
            "name": "totalOrbitals",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "completedCount",
            "type": "number"
          },
          {
            "default": 0.0,
            "name": "failedCount",
            "type": "number"
          },
          {
            "default": "",
            "name": "composedSchema",
            "type": "string"
          },
          {
            "default": [],
            "items": {
              "properties": {
                "code": {
                  "name": "code",
                  "required": true,
                  "type": "string"
                },
                "message": {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                "orbitalName": {
                  "name": "orbitalName",
                  "required": false,
                  "type": "string"
                },
                "severity": {
                  "name": "severity",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "validationErrors",
            "type": "array"
          }
        ],
        "name": "Coordinator",
        "persistence": "runtime"
      },
      "name": "CoordinatorOrbital",
      "pages": [
        {
          "name": "RabitPage",
          "path": "/rabit",
          "traits": [
            {
              "ref": "CoordinatorPipeline"
            },
            {
              "ref": "CoordinatorMonitor"
            },
            {
              "ref": "CoordinatorListener"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "emits": [
            {
              "event": "PLANNED",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPOSED",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ]
            },
            {
              "event": "DISPATCHED",
              "payloadSchema": [
                {
                  "name": "plan",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "totalOrbitals",
                  "required": true,
                  "type": "number"
                }
              ]
            },
            {
              "event": "RABIT_DONE",
              "payloadSchema": [
                {
                  "name": "schema",
                  "required": true,
                  "type": "string"
                }
              ]
            }
          ],
          "linkedEntity": "Coordinator",
          "name": "CoordinatorPipeline",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start",
                "payloadSchema": [
                  {
                    "name": "prompt",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "totalOrbitals",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PLANNED",
                "name": "Planned",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAN_FAILED",
                "name": "Plan Failed"
              },
              {
                "key": "ALL_DONE",
                "name": "All Done"
              },
              {
                "key": "COMPOSED",
                "name": "Composed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE_FAILED",
                "name": "Compose Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "DISPATCHED",
                "name": "Dispatched",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "totalOrbitals",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RABIT_DONE",
                "name": "Rabit Done",
                "payloadSchema": [
                  {
                    "name": "schema",
                    "required": true,
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "planning"
              },
              {
                "name": "monitoring"
              },
              {
                "name": "assembling"
              },
              {
                "name": "done"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.totalOrbitals",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.failedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.composedSchema",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    []
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.prompt",
                    "@payload.prompt"
                  ],
                  [
                    "set",
                    "@entity.totalOrbitals",
                    "@payload.totalOrbitals"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "planning"
                  ],
                  [
                    "llm/generate",
                    "@entity.prompt",
                    {
                      "emit": {
                        "failure": "PLAN_FAILED",
                        "success": "PLANNED"
                      }
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "planning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.result"
                  ],
                  [
                    "session/write-spec",
                    "coordinator-plan",
                    "@entity.plan"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "dispatching"
                  ],
                  [
                    "emit",
                    "DISPATCHED",
                    {
                      "plan": "@entity.plan",
                      "totalOrbitals": "@entity.totalOrbitals"
                    }
                  ]
                ],
                "event": "PLANNED",
                "from": "planning",
                "to": "monitoring"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ]
                ],
                "event": "PLAN_FAILED",
                "from": "planning",
                "to": "monitoring"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "monitoring"
                  ]
                ],
                "event": "INIT",
                "from": "monitoring",
                "to": "monitoring"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "assembling"
                  ],
                  [
                    "compose/compose-all",
                    {
                      "emit": {
                        "failure": "COMPOSE_FAILED",
                        "success": "COMPOSED"
                      }
                    }
                  ]
                ],
                "event": "ALL_DONE",
                "from": "monitoring",
                "to": "assembling"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.composedSchema",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "validating"
                  ],
                  [
                    "validate/validate",
                    "composed"
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "done"
                  ],
                  [
                    "emit",
                    "RABIT_DONE",
                    {
                      "schema": "@entity.composedSchema"
                    }
                  ]
                ],
                "event": "COMPOSED",
                "from": "assembling",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.composedSchema",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "done"
                  ],
                  [
                    "emit",
                    "RABIT_DONE",
                    {
                      "schema": "@entity.composedSchema"
                    }
                  ]
                ],
                "event": "COMPOSE_FAILED",
                "from": "assembling",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "done"
                  ]
                ],
                "event": "INIT",
                "from": "done",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.totalOrbitals",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.failedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.composedSchema",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationErrors",
                    []
                  ]
                ],
                "event": "RESET",
                "from": "done",
                "to": "idle"
              }
            ]
          }
        },
        {
          "category": "lifecycle",
          "emits": [
            {
              "event": "ALL_DONE"
            }
          ],
          "linkedEntity": "Coordinator",
          "name": "CoordinatorMonitor",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ORBITAL_COMPLETE",
                "name": "Orbital Complete"
              },
              {
                "key": "ORBITAL_FAILED",
                "name": "Orbital Failed"
              },
              {
                "key": "ALL_DONE",
                "name": "All Done"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "waiting"
              },
              {
                "name": "counting"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.totalOrbitals",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completedCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.failedCount",
                    0.0
                  ]
                ],
                "event": "INIT",
                "from": "waiting",
                "to": "waiting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.completedCount",
                    [
                      "+",
                      "@entity.completedCount",
                      1.0
                    ]
                  ],
                  [
                    "when",
                    [
                      "==",
                      [
                        "+",
                        "@entity.completedCount",
                        "@entity.failedCount"
                      ],
                      "@entity.totalOrbitals"
                    ],
                    [
                      "emit",
                      "ALL_DONE",
                      {}
                    ]
                  ]
                ],
                "event": "ORBITAL_COMPLETE",
                "from": "waiting",
                "to": "counting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.failedCount",
                    [
                      "+",
                      "@entity.failedCount",
                      1.0
                    ]
                  ],
                  [
                    "when",
                    [
                      "==",
                      [
                        "+",
                        "@entity.completedCount",
                        "@entity.failedCount"
                      ],
                      "@entity.totalOrbitals"
                    ],
                    [
                      "emit",
                      "ALL_DONE",
                      {}
                    ]
                  ]
                ],
                "event": "ORBITAL_FAILED",
                "from": "waiting",
                "to": "counting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.completedCount",
                    "@entity.completedCount"
                  ]
                ],
                "event": "INIT",
                "from": "counting",
                "to": "counting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.completedCount",
                    [
                      "+",
                      "@entity.completedCount",
                      1.0
                    ]
                  ],
                  [
                    "when",
                    [
                      "==",
                      [
                        "+",
                        "@entity.completedCount",
                        "@entity.failedCount"
                      ],
                      "@entity.totalOrbitals"
                    ],
                    [
                      "emit",
                      "ALL_DONE",
                      {}
                    ]
                  ]
                ],
                "event": "ORBITAL_COMPLETE",
                "from": "counting",
                "to": "counting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.failedCount",
                    [
                      "+",
                      "@entity.failedCount",
                      1.0
                    ]
                  ],
                  [
                    "when",
                    [
                      "==",
                      [
                        "+",
                        "@entity.completedCount",
                        "@entity.failedCount"
                      ],
                      "@entity.totalOrbitals"
                    ],
                    [
                      "emit",
                      "ALL_DONE",
                      {}
                    ]
                  ]
                ],
                "event": "ORBITAL_FAILED",
                "from": "counting",
                "to": "counting"
              }
            ]
          }
        },
        {
          "category": "lifecycle",
          "linkedEntity": "Coordinator",
          "listens": [
            {
              "event": "RABIT_DONE",
              "source": {
                "kind": "trait",
                "trait": "CoordinatorPipeline"
              },
              "triggers": "RABIT_DONE"
            }
          ],
          "name": "CoordinatorListener",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RABIT_DONE",
                "name": "Rabit Done"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "waiting"
              },
              {
                "name": "done"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "idle"
                  ]
                ],
                "event": "INIT",
                "from": "waiting",
                "to": "waiting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "done"
                  ]
                ],
                "event": "RABIT_DONE",
                "from": "waiting",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.phase",
                    "done"
                  ]
                ],
                "event": "INIT",
                "from": "done",
                "to": "done"
              }
            ]
          }
        }
      ]
    },
    {
      "entity": {
        "fields": [
