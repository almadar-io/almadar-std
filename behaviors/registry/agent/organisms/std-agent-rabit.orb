                }
              ]
            },
            {
              "event": "FIX_GENERATED",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ]
            }
          ],
          "linkedEntity": "OrbitalProcess",
          "name": "ProcessPipeline",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BUILD",
                "name": "Build",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "method",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "spec",
                    "required": true,
                    "type": "OrbitalSpec"
                  }
                ]
              },
              {
                "key": "BUILD_STEP",
                "name": "Build Step",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PROCESS_RETRY",
                "name": "Process Retry",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "attempt",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PROCESS_DONE",
                "name": "Process Done",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REBUILD",
                "name": "Rebuild",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FIX_GENERATED",
                "name": "Fix Generated",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FIX_FAILED",
                "name": "Fix Failed"
              },
              {
                "key": "ORBITAL_COMPLETE",
                "name": "Orbital Complete",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "pending"
              },
              {
                "name": "building"
              },
              {
                "name": "validating"
              },
              {
                "name": "repairing"
              },
              {
                "name": "fixing"
              },
              {
                "name": "done"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.orbitalName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.method",
                    "pending"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "pending"
                  ],
                  [
                    "set",
                    "@entity.attempts",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.maxAttempts",
                    3.0
                  ],
                  [
                    "set",
                    "@entity.fixPrompt",
                    ""
                  ]
                ],
                "event": "INIT",
                "from": "pending",
                "to": "pending"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.orbitalName",
                    "@payload.orbitalName"
                  ],
                  [
                    "set",
                    "@entity.method",
                    "@payload.method"
                  ],
                  [
                    "set",
                    "@entity.spec",
