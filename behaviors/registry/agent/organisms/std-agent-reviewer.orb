{
  "name": "std-agent-reviewer",
  "version": "1.0.0",
  "description": "Agent reviewer: code/doc review with RAG analysis and issue tracking.",
  "orbitals": [
    {
      "name": "ReviewOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "Review",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "target",
            "type": "string",
            "default": "",
            "description": "The item being reviewed.",
            "synonyms": "subject, item, targetObject"
          },
          {
            "name": "category",
            "type": "string",
            "default": "",
            "description": "Classification or type of the review.",
            "synonyms": "type, classification, kind"
          },
          {
            "name": "issues",
            "type": "string",
            "default": "[]",
            "description": "A textual description of identified problems or concerns.",
            "synonyms": "problems, concerns, defects, findings"
          },
          {
            "name": "suggestions",
            "type": "string",
            "default": "[]",
            "description": "Proposed improvements or recommendations for the reviewed item.",
            "synonyms": "recommendations, feedback, notes, advice"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0,
            "description": "A numerical value representing a rating or assessment.",
            "synonyms": "rating, value, measurement, grade"
          },
          {
            "name": "reviewStatus",
            "type": "string",
            "default": "idle",
            "description": "The current state of the review process.",
            "synonyms": "status, state, condition"
          },
          {
            "name": "error",
            "type": "string",
            "default": "",
            "description": "A textual description of an encountered error.",
            "synonyms": "problem, fault, issue, mistake"
          },
          {
            "name": "activeTab",
            "type": "string",
            "default": "",
            "description": "The currently selected tab within the interface.",
            "synonyms": "selection, current tab, tab"
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "name": "value",
                  "type": "string",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": false
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "A list of items or elements being reviewed.",
            "synonyms": "elements, entries, details, components"
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewGenerator",
          "category": "interaction",
          "linkedEntity": "Review",
          "emits": [
            {
              "event": "ReviewLoaded",
              "description": "Fired when Review finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Review]"
                }
              ]
            },
            {
              "event": "ReviewLoadFailed",
              "description": "Fired when Review fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewRagSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewRagSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AnalysisSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AnalysisSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewCompletionSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewCompletionSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CLASSIFIED",
              "triggers": "SUBMIT_REVIEW",
              "source": {
                "kind": "orbital",
                "orbital": "AnalysisOrbital",
                "trait": "InputClassifier"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "analyzing"
              },
              {
                "name": "reviewing"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT_REVIEW",
                "name": "Submit Review",
                "payloadSchema": [
                  {
                    "name": "target",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PATTERNS_FOUND",
                "name": "Patterns Found"
              },
              {
                "key": "REVIEW_GENERATED",
                "name": "Review Generated"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ReviewLoaded",
                "name": "Review loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Review]"
                  }
                ]
              },
              {
                "key": "ReviewLoadFailed",
                "name": "Review load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewRagSaved",
                "name": "Review rag saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewRagSaveFailed",
                "name": "Review rag save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AnalysisSaved",
                "name": "Analysis saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AnalysisSaveFailed",
                "name": "Analysis save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewCompletionSaved",
                "name": "Review completion saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewCompletionSaveFailed",
                "name": "Review completion save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "fetch",
                    "Review",
                    {
                      "emit": {
                        "failure": "ReviewLoadFailed",
                        "success": "ReviewLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "file-search",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Code Review"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review."
                                    },
                                    {
                                      "entity": "@entity",
                                      "type": "form-section",
                                      "fields": [
                                        "target"
                                      ],
                                      "submitEvent": "SUBMIT_REVIEW",
                                      "mode": "edit"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "label": "Review",
                          "href": "/review"
                        },
                        {
                          "label": "Analysis",
                          "icon": "tag",
                          "href": "/analysis"
                        },
                        {
                          "href": "/issues",
                          "label": "Issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "appName": "Code Reviewer"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "analyzing",
                "event": "SUBMIT_REVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.target",
                    "@payload.target"
                  ],
                  [
                    "set",
                    "@entity.reviewStatus",
                    "analyzing"
                  ],
                  [
                    "agent/recall",
                    "@payload.target"
                  ],
                  [
                    "agent/search-code",
                    "@payload.target"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "Code Reviewer",
                      "children": [
                        {
                          "direction": "vertical",
                          "align": "center",
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Analyzing input..."
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "content": "Classifying and searching for patterns",
                              "variant": "caption",
                              "type": "typography"
                            }
                          ],
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/review",
                          "label": "Review",
                          "icon": "file-search"
                        },
                        {
                          "icon": "tag",
                          "label": "Analysis",
                          "href": "/analysis"
                        },
                        {
                          "icon": "alert-triangle",
                          "href": "/issues",
                          "label": "Issues"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "analyzing",
                "to": "reviewing",
                "event": "PATTERNS_FOUND",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "reviewing"
                  ],
                  [
                    "agent/generate",
                    "@entity.target"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "icon",
                              "name": "cpu"
                            },
                            {
                              "content": "Generating review...",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "type": "typography",
                              "content": "Category: @entity.category",
                              "variant": "caption"
                            }
                          ],
                          "align": "center",
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "label": "Review",
                          "icon": "file-search",
                          "href": "/review"
                        },
                        {
                          "icon": "tag",
                          "label": "Analysis",
                          "href": "/analysis"
                        },
                        {
                          "href": "/issues",
                          "icon": "alert-triangle",
                          "label": "Issues"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "completed",
                "event": "REVIEW_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "completed"
                  ],
                  [
                    "agent/memorize",
                    "@entity.target",
                    "review-pattern"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-circle"
                                    },
                                    {
                                      "content": "Review Complete",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "sm",
                                  "align": "center",
                                  "direction": "horizontal",
                                  "type": "stack"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.score"
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal",
                              "justify": "between",
                              "gap": "sm"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "stack",
                                      "gap": "sm",
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "label": "@entity.category",
                                          "type": "badge"
                                        },
                                        {
                                          "label": "@entity.reviewStatus",
                                          "type": "badge"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Issues",
                                      "variant": "h4"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "@entity.issues",
                                      "variant": "body"
                                    },
                                    {
                                      "type": "divider"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Suggestions",
                                      "variant": "h4"
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@entity.suggestions",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "md"
                                }
                              ]
                            },
                            {
                              "action": "RESET",
                              "label": "New Review",
                              "type": "button",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "label": "Review",
                          "href": "/review",
                          "icon": "file-search"
                        },
                        {
                          "label": "Analysis",
                          "href": "/analysis",
                          "icon": "tag"
                        },
                        {
                          "href": "/issues",
                          "label": "Issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.target",
                    ""
                  ],
                  [
                    "set",
                    "@entity.issues",
                    "[]"
                  ],
                  [
                    "set",
                    "@entity.suggestions",
                    "[]"
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "file-search",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Code Review",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review.",
                                      "variant": "body"
                                    },
                                    {
                                      "mode": "edit",
                                      "entity": "@entity",
                                      "type": "form-section",
                                      "submitEvent": "SUBMIT_REVIEW",
                                      "fields": [
                                        "target"
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/review",
                          "label": "Review",
                          "icon": "file-search"
                        },
                        {
                          "icon": "tag",
                          "label": "Analysis",
                          "href": "/analysis"
                        },
                        {
                          "label": "Issues",
                          "icon": "alert-triangle",
                          "href": "/issues"
                        }
                      ],
                      "appName": "Code Reviewer"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReviewPage",
          "path": "/review",
          "traits": [
            {
              "ref": "ReviewGenerator"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewRagOrbital",
      "entity": {
        "name": "ReviewRag",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "query",
            "type": "string",
            "description": "The text used to initiate the review process.",
            "synonyms": "search term, request, question, input"
          },
          {
            "name": "context",
            "type": "string",
            "description": "Background information or surrounding details.",
            "synonyms": "details, background, information, surrounding"
          },
          {
            "name": "response",
            "type": "string",
            "description": "The text-based output generated by the agent.",
            "synonyms": "output, text, answer, result"
          },
          {
            "name": "memoryHits",
            "type": "number",
            "description": "The number of memory-related search results.",
            "synonyms": "count, hits, number, quantity"
          },
          {
            "name": "searchHits",
            "type": "number",
            "description": "The number of results found during a search.",
            "synonyms": "count, hits, result count"
          },
          {
            "name": "status",
            "type": "string",
            "description": "The current state or condition of the review process.",
            "synonyms": "state, condition, progress"
          },
          {
            "name": "error",
            "type": "string",
            "default": "",
            "description": "A textual description of an error encountered.",
            "synonyms": "problem, fault, issue, mistake"
          },
          {
            "name": "content",
            "type": "string",
            "description": "The main text or data of the review.",
            "synonyms": "text, body, data, details"
          },
          {
            "name": "category",
            "type": "string",
            "default": "",
            "description": "Classification or type of the review.",
            "synonyms": "type, kind, classification"
          },
          {
            "name": "scope",
            "type": "string",
            "description": "The area or boundaries of the review's focus.",
            "synonyms": "area, range, boundaries, focus"
          },
          {
            "name": "strength",
            "type": "number",
            "description": "A numerical value representing the level of confidence or intensity.",
            "synonyms": "intensity, magnitude, value, level"
          },
          {
            "name": "pinned",
            "type": "boolean",
            "description": "Indicates whether the review is marked as important.",
            "synonyms": "flagged, highlighted, starred"
          },
          {
            "name": "language",
            "type": "string",
            "description": "The language used for the content being reviewed.",
            "synonyms": "locale, languageCode, languageTag"
          },
          {
            "name": "resultCount",
            "type": "number",
            "description": "The total number of results retrieved.",
            "synonyms": "count, total, size, quantity"
          },
          {
            "name": "results",
            "type": "string",
            "description": "The outcome or findings of the review process.",
            "synonyms": "outcome, findings, output, report"
          },
          {
            "name": "prompt",
            "type": "string",
            "description": "The text used as input for the review process.",
            "synonyms": "query, input, question, request"
          },
          {
            "name": "provider",
            "type": "string",
            "description": "Identifies the source or origin of the data.",
            "synonyms": "source, origin, vendor"
          },
          {
            "name": "model",
            "type": "string",
            "description": "The identifier of the language model used.",
            "synonyms": "modelName, llm, aiModel"
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewRagRag",
          "category": "interaction",
          "linkedEntity": "ReviewRag",
          "listens": [
            {
              "event": "GENERATE",
              "triggers": "GENERATE",
              "source": {
                "kind": "trait",
                "trait": "RagCompletionFlow"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "retrieving"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "RETRIEVAL_DONE",
                "name": "Retrieval Done",
                "payloadSchema": [
                  {
                    "name": "context",
                    "type": "string"
                  },
                  {
                    "name": "memoryHits",
                    "type": "number"
                  },
                  {
                    "name": "searchHits",
