        {
          "name": "RagTabs",
          "category": "interaction",
          "linkedEntity": "ReviewRag",
          "emits": [
            {
              "event": "SELECT_TAB",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewRagLoaded",
              "description": "Fired when ReviewRag finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ReviewRag]"
                }
              ]
            },
            {
              "event": "ReviewRagLoadFailed",
              "description": "Fired when ReviewRag fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReviewRagLoaded",
                "name": "ReviewRag loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ReviewRag]"
                  }
                ]
              },
              {
                "key": "ReviewRagLoadFailed",
                "name": "ReviewRag load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAB",
                "name": "Select Tab",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewRag",
                    {
                      "emit": {
                        "failure": "ReviewRagLoadFailed",
                        "success": "ReviewRagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading RAG pipeline…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReviewRagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "brain"
                                },
                                {
                                  "content": "RAG Pipeline",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "defaultActiveTab": "query",
                              "tabChangeEvent": "SELECT_TAB",
                              "tabs": [
                                {
                                  "value": "query",
                                  "label": "Query"
                                },
                                {
                                  "label": "Sources",
                                  "value": "sources"
                                },
                                {
                                  "value": "response",
                                  "label": "Response"
                                }
                              ],
                              "type": "tabs"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "@payload.data",
                              "type": "data-grid",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "h4",
                                      "content": "@item.query",
                                      "type": "typography"
                                    },
                                    {
                                      "variant": "caption",
                                      "color": "muted",
                                      "content": "@item.query",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "vertical"
                                }
                              ],
                              "fields": [],
                              "className": "transition-shadow hover:shadow-md cursor-pointer"
                            }
                          ],
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack"
                        }
                      ],
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "label": "Review",
                          "href": "/review",
                          "icon": "file-search"
                        },
                        {
                          "label": "Analysis",
                          "href": "/analysis",
                          "icon": "tag"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReviewRagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load RAG pipeline",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "action": "INIT",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_TAB",
                "effects": [
                  [
                    "fetch",
                    "ReviewRag",
                    {
                      "emit": {
                        "success": "ReviewRagLoaded",
                        "failure": "ReviewRagLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "RagMemoryLifecycle",
          "category": "interaction",
          "linkedEntity": "ReviewRag",
          "emits": [
            {
              "event": "ReviewRagLoaded",
              "description": "Fired when ReviewRag finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ReviewRag]"
                }
              ]
            },
            {
              "event": "ReviewRagLoadFailed",
              "description": "Fired when ReviewRag fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
