              "event": "GENERATED",
              "triggers": "GENERATED",
              "source": {
                "kind": "trait",
                "trait": "ReviewCompletionFlow"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              },
              {
                "name": "error"
              }
            ],
