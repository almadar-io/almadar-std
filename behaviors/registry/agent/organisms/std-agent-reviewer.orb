                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "DO_GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.data.prompt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Review complete",
                      "notificationType": "success"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "error",
                "event": "RESET",
                "guard": [
                  "=",
                  "@entity.status",
                  "generating"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Generation was cancelled"
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ]
                ]
              },
              {
                "from": "error",
                "to": "generating",
                "event": "RETRY",
                "guard": [
                  "=",
                  "@entity.status",
                  "error"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Completion",
          "path": "/completion",
          "traits": [
            {
              "ref": "ReviewCompletionFlow"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewNavOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "ReviewNav",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "target",
            "type": "string",
            "default": "",
            "description": "The item being reviewed.",
            "synonyms": "subject, item, focus"
          },
          {
            "name": "category",
            "type": "string",
            "default": "",
            "description": "Classification or type of the review.",
            "synonyms": "type, classification, kind"
          },
          {
            "name": "issues",
            "type": "string",
            "default": "[]",
            "description": "A textual representation of identified problems or concerns.",
            "synonyms": "problems, concerns, defects, findings"
          },
          {
            "name": "suggestions",
            "type": "string",
            "default": "[]",
            "description": "Recommendations or proposed improvements.",
            "synonyms": "recommendations, proposals, hints, advice"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0,
            "description": "A numerical value representing a rating or assessment.",
            "synonyms": "rating, value, grade, assessment"
          },
          {
            "name": "reviewStatus",
            "type": "string",
            "default": "idle",
            "description": "The current state of the review process.",
            "synonyms": "status, state, condition"
          },
          {
            "name": "error",
            "type": "string",
            "default": "",
            "description": "A textual description of an encountered error.",
            "synonyms": "problem, fault, issue, mistake"
          }
        ]
      },
      "traits": [
        {
          "ref": "Tabs.traits.TabsItemTabs",
          "name": "ReviewerTabs",
          "linkedEntity": "Review"
        }
      ],
      "pages": [
        {
          "name": "ReviewerNav",
          "path": "/reviewer/nav",
          "traits": [
            {
              "ref": "ReviewerTabs"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewIssueOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "ReviewIssue",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "description": "A textual explanation or summary of the review.",
            "synonyms": "summary, details, notes, explanation"
          },
          {
            "name": "severity",
            "type": "string",
            "description": "Indicates the seriousness or impact of a finding.",
            "synonyms": "priority, impact, level"
          },
          {
            "name": "line",
            "type": "number",
            "description": "The position of the element within a larger structure.",
            "synonyms": "position, index, number, sequence"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "IssuesBrowse",
          "linkedEntity": "ReviewIssue"
        }
      ],
      "pages": [
        {
          "name": "Issues",
          "path": "/issues",
          "traits": [
            {
              "ref": "IssuesBrowse"
            }
          ]
        }
      ]
    }
  ]
}
