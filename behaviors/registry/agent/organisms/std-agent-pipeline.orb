      "pages": [
        {
          "name": "Execution",
          "path": "/execution",
          "traits": [
            {
              "ref": "PipelineExecutor"
            }
          ]
        }
      ]
    },
    {
      "name": "PipelineSessionOrbital",
      "entity": {
        "name": "PipelineSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sessionId",
            "type": "string"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "label",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PipelineSessionManager",
          "category": "interaction",
          "linkedEntity": "PipelineSession",
          "emits": [
            {
              "event": "PipelineSessionLoaded",
              "description": "Fired when PipelineSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PipelineSession]"
                }
              ]
            },
            {
              "event": "PipelineSessionLoadFailed",
              "description": "Fired when PipelineSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "FORKED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineSessionAgent"
              }
            },
            {
              "event": "LABELED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineSessionLabel"
              }
            },
            {
              "event": "ENDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineSessionAgent"
              }
            },
            {
              "event": "STEP_COMPLETE",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PipelineSessionLoaded",
                "name": "PipelineSession loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PipelineSession]"
                  }
                ]
              },
              {
                "key": "PipelineSessionLoadFailed",
                "name": "PipelineSession load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "failure": "PipelineSessionLoadFailed",
                        "success": "PipelineSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PipelineSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "justify": "between",
                              "align": "center",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "terminal"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "PipelineSession Manager",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm"
                                },
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "label": "Fork",
                                      "variant": "secondary",
                                      "icon": "git-branch",
                                      "action": "FORK",
                                      "type": "button"
                                    },
                                    {
