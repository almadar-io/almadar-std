{
  "name": "std-agent-pipeline",
  "version": "1.0.0",
  "description": "std-agent-pipeline as a Function",
  "orbitals": [
    {
      "name": "PipelinePlanOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        },
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "PipelinePlan",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "task",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "steps",
            "type": "string",
            "default": ""
          },
          {
            "name": "confidence",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "relevantMemories",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "input",
            "type": "string",
            "default": ""
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string",
            "default": ""
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "PipelinePlanner",
          "category": "interaction",
          "linkedEntity": "PipelinePlan",
          "emits": [
            {
              "event": "PLAN_READY",
              "scope": "external",
              "payload": [
                {
                  "name": "plan",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PIPELINE_PLANNED",
              "scope": "internal"
            },
            {
              "event": "PIPELINE_PLANNED",
              "scope": "external",
              "payload": [
                {
                  "name": "steps",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SessionTreeLoaded",
              "description": "Emitted event SessionTreeLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SessionTreeLoadFailed",
              "description": "Emitted event SessionTreeLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelinePlanSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelinePlanSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineExecSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineExecSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineSessionUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineSessionUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PLAN_READY",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelinePlanner"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "classifying"
              },
              {
                "name": "recalling"
              },
              {
                "name": "planning"
              },
              {
                "name": "ready"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN",
                "name": "Plan"
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified",
                "payload": [
                  {
                    "name": "category",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MEMORIES_LOADED",
                "name": "Memories Loaded",
                "payload": [
                  {
                    "name": "memories",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "count",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "PLAN_GENERATED",
                "name": "Plan Generated",
                "payload": [
                  {
                    "name": "steps",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "confidence",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "plan",
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "type": "string"
                  },
                  {
                    "name": "toolArgs",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PLAN_READY",
                "name": "Plan Ready"
              },
              {
                "key": "PIPELINE_PLANNED",
                "name": "Pipeline Planned"
              },
              {
                "key": "SessionTreeLoaded",
                "name": "Session tree loaded",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SessionTreeLoadFailed",
                "name": "Session tree load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelinePlanSaved",
                "name": "PipelinePlan saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelinePlanSaveFailed",
                "name": "PipelinePlan save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineExecSaved",
                "name": "Pipeline exec saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineExecSaveFailed",
                "name": "Pipeline exec save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineSessionUpdated",
                "name": "Pipeline session updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineSessionUpdateFailed",
                "name": "Pipeline session update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaved",
                "name": "Execution log saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaveFailed",
                "name": "Execution log save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Pipeline",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "map"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Task Planner",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": "Describe the task to plan"
                                    },
                                    {
                                      "fields": [
                                        "task"
                                      ],
                                      "entity": "@entity",
                                      "submitEvent": "PLAN",
                                      "type": "form-section",
                                      "mode": "edit"
                                    }
                                  ],
                                  "gap": "md",
                                  "type": "stack",
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "icon": "git-branch",
                          "href": "/pipeline"
                        },
                        {
                          "href": "/execution",
                          "icon": "play",
                          "label": "Execution"
                        },
                        {
                          "label": "Logs",
                          "href": "/logs",
                          "icon": "terminal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "PLAN",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "classifying"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify this task into exactly one category.\n",
                      "Categories: ",
                      "data, transform, validate, deploy, test",
                      "\n",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Return only the category name."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "icon": "git-branch",
                          "href": "/pipeline",
                          "label": "Pipeline"
                        },
                        {
                          "href": "/execution",
                          "icon": "play",
                          "label": "Execution"
                        },
                        {
                          "label": "Logs",
                          "href": "/logs",
                          "icon": "terminal"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "icon",
                              "name": "tag"
                            },
                            {
                              "variant": "h3",
                              "content": "Classifying task...",
                              "type": "typography"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "@entity.task"
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "appName": "Agent Pipeline",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "recalling",
                "event": "CLASSIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.category"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "recalling"
                  ],
                  [
                    "agent/recall",
                    [
                      "str/concat",
                      "@entity.category",
                      " ",
                      "@entity.task"
                    ],
                    5.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "content": "Recalling relevant experience...",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "label": "@entity.category",
                              "type": "badge"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "navItems": [
                        {
                          "icon": "git-branch",
                          "href": "/pipeline",
                          "label": "Pipeline"
                        },
                        {
                          "href": "/execution",
                          "icon": "play",
                          "label": "Execution"
                        },
                        {
                          "icon": "terminal",
                          "label": "Logs",
                          "href": "/logs"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Agent Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Pipeline",
                      "children": [
                        {
                          "align": "center",
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "type": "typography",
                              "content": "Planning Failed",
                              "variant": "h2"
                            },
                            {
                              "message": "@entity.error",
                              "type": "alert",
                              "variant": "error"
                            },
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "action": "RESET",
                              "label": "Try Again",
                              "variant": "primary"
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "href": "/pipeline",
                          "icon": "git-branch"
                        },
                        {
                          "href": "/execution",
                          "icon": "play",
                          "label": "Execution"
                        },
                        {
                          "icon": "terminal",
                          "label": "Logs",
                          "href": "/logs"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "planning",
                "event": "MEMORIES_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.relevantMemories",
                    "@payload.memories"
                  ],
                  [
                    "set",
                    "@entity.memoryCount",
                    "@payload.count"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "planning"
                  ],
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Task: ",
                      "@entity.task",
                      "\n",
                      "Category: ",
                      "@entity.category",
                      "\n",
                      "Relevant experience:\n",
                      "@entity.relevantMemories",
                      "\n\n",
                      "Generate a numbered step-by-step execution plan. ",
                      "Include a confidence score (0-100) for how likely this plan will succeed."
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "cpu"
                            },
                            {
                              "variant": "h3",
                              "content": "Generating plan...",
                              "type": "typography"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "justify": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "@entity.category"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.memoryCount"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "href": "/pipeline",
                          "icon": "git-branch"
                        },
                        {
                          "href": "/execution",
                          "icon": "play",
                          "label": "Execution"
                        },
                        {
                          "href": "/logs",
                          "icon": "terminal",
                          "label": "Logs"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Agent Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "recalling",
                "to": "idle",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "href": "/pipeline",
                          "icon": "git-branch"
                        },
                        {
                          "icon": "play",
                          "label": "Execution",
                          "href": "/execution"
                        },
                        {
                          "icon": "terminal",
                          "href": "/logs",
                          "label": "Logs"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Planning Failed"
                            },
                            {
                              "variant": "error",
                              "message": "@entity.error",
                              "type": "alert"
                            },
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "action": "RESET",
                              "label": "Try Again",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "align": "center",
                          "type": "stack"
                        }
                      ],
                      "appName": "Agent Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "planning",
                "to": "ready",
                "event": "PLAN_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.steps",
                    "@payload.steps"
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    "@payload.confidence"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "ready"
                  ],
                  [
                    "agent/memorize",
                    [
                      "str/concat",
                      "Plan for ",
                      "@entity.category",
                      " task: ",
                      "@entity.task"
                    ],
                    "pattern-affinity"
                  ],
                  [
                    "emit",
                    "PLAN_READY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-circle"
                                    },
                                    {
                                      "content": "Plan Ready",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "type": "button",
                                  "label": "New Plan",
                                  "variant": "ghost",
                                  "action": "RESET",
                                  "icon": "rotate-ccw"
                                }
                              ],
                              "type": "stack",
                              "align": "center",
                              "justify": "between",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "simple-grid",
                              "cols": 3.0,
                              "children": [
                                {
                                  "type": "stat-display",
                                  "icon": "tag",
                                  "label": "Category",
                                  "value": "@entity.category"
                                },
                                {
                                  "icon": "target",
                                  "type": "stat-display",
                                  "label": "Confidence",
                                  "value": "@entity.confidence"
                                },
                                {
                                  "label": "Memories Used",
                                  "value": "@entity.memoryCount",
                                  "type": "stat-display",
                                  "icon": "brain"
