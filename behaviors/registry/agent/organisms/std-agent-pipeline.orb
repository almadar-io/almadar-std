                                  "event": "FORGET",
                                  "label": "Forget",
                                  "variant": "danger"
                                }
                              ],
                              "entity": "@payload.data",
                              "type": "data-grid"
                            }
                          ],
                          "gap": "lg"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ExecutionLogLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load executionlog",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ExecutionLogCreate",
          "category": "interaction",
          "linkedEntity": "ExecutionLog",
          "emits": [
            {
              "event": "MEMORIZED"
            },
            {
              "event": "ExecutionLogLoadFailed",
              "description": "Fired when ExecutionLog fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogLoaded",
              "description": "Fired when ExecutionLog finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ExecutionLog]"
                }
              ]
            },
            {
              "event": "ExecutionLogSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MEMORIZE",
                "name": "Memorize"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEMORIZED",
                "name": "Memorized"
              },
              {
                "key": "ExecutionLogLoadFailed",
                "name": "ExecutionLog load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogLoaded",
                "name": "ExecutionLog loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ExecutionLog]"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaveFailed",
                "name": "ExecutionLog save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaved",
                "name": "ExecutionLog saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ExecutionLog"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "MEMORIZE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Memorize",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "fields": [
                            "content",
                            "category",
                            "scope"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ExecutionLog",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "ExecutionLogSaveFailed",
                        "success": "ExecutionLogSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "MEMORIZED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ExecutionLogAgent",
          "category": "interaction",
          "linkedEntity": "ExecutionLog",
          "emits": [
            {
              "event": "FORGOT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REINFORCED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DECAYED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PINNED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogLoadFailed",
              "description": "Fired when ExecutionLog fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogLoaded",
              "description": "Fired when ExecutionLog finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ExecutionLog]"
                }
              ]
            },
            {
              "event": "ExecutionLogSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ExecutionLogSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PIPELINE_FINISHED",
              "triggers": "MEMORIZE",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_MEMORIZE",
                "name": "Do Memorize",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DECAY",
                "name": "Decay"
              },
              {
                "key": "MEMORIZED",
                "name": "Memorized"
              },
              {
                "key": "RECALL",
                "name": "Recall",
                "payload": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORGOT",
                "name": "Forgot"
              },
              {
                "key": "REINFORCED",
                "name": "Reinforced"
              },
              {
                "key": "DECAYED",
                "name": "Decayed"
              },
              {
                "key": "PINNED",
                "name": "Pinned"
              },
              {
                "key": "ExecutionLogLoadFailed",
                "name": "ExecutionLog load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogLoaded",
                "name": "ExecutionLog loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ExecutionLog]"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaveFailed",
                "name": "ExecutionLog save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ExecutionLogSaved",
                "name": "ExecutionLog saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ExecutionLog",
                    {
                      "emit": {
                        "failure": "ExecutionLogLoadFailed",
                        "success": "ExecutionLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "Agent Pipeline",
                      "children": [
                        {
                          "description": "Memory is ready",
                          "type": "empty-state",
                          "title": "Memory",
                          "icon": "brain"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "href": "/pipeline",
                          "icon": "git-branch"
                        },
                        {
                          "icon": "play",
                          "href": "/execution",
                          "label": "Execution"
                        },
                        {
                          "href": "/logs",
                          "label": "Logs",
                          "icon": "terminal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "DO_MEMORIZE",
                "effects": [
                  [
                    "agent/memorize",
                    "@payload.data.content",
                    "@payload.data.category"
                  ],
                  [
                    "persist",
                    "create",
                    "ExecutionLog",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ExecutionLogSaved",
                        "failure": "ExecutionLogSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "MEMORIZED",
                "effects": [
                  [
                    "fetch",
                    "ExecutionLog",
                    {
                      "emit": {
                        "failure": "ExecutionLogLoadFailed",
                        "success": "ExecutionLogLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "RECALL",
                "effects": [
                  [
                    "agent/recall",
                    "@payload.query"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "PIN",
                "guard": [
                  "not",
                  [
                    "agent/is-pinned",
                    "@payload.id"
                  ]
                ],
                "effects": [
                  [
                    "agent/pin",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.pinned",
                    true
                  ],
                  [
                    "emit",
                    "PINNED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "idle",
                "event": "FORGET",
                "effects": [
                  [
                    "agent/forget",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "FORGOT"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "REINFORCE",
                "effects": [
                  [
                    "agent/reinforce",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "REINFORCED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Logs",
          "path": "/logs",
          "traits": [
            {
              "ref": "ExecutionLogBrowse"
            },
            {
              "ref": "ExecutionLogCreate"
            },
            {
              "ref": "ExecutionLogAgent"
            }
          ]
        }
      ]
    },
    {
      "name": "PipelineProgressOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-agent-step-progress",
          "as": "AgentStepProgress"
        }
      ],
      "entity": {
        "name": "PipelineProgress",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "steps",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number"
          },
          {
            "name": "totalSteps",
            "type": "number"
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "ref": "AgentStepProgress.traits.AgentStepProgressProgress",
          "name": "PipelineStepProgress",
          "linkedEntity": "PipelineProgress"
        }
      ],
      "pages": [
        {
          "name": "PipelineProgress",
          "path": "/pipeline/progress",
          "traits": [
            {
              "ref": "PipelineStepProgress"
            }
          ]
        }
      ]
    },
    {
      "name": "SessionTreeOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "SessionTree",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "branchId",
            "type": "string"
          },
          {
            "name": "label",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "ref": "Drawer.traits.DrawerContentDrawer",
          "name": "SessionTreeDrawer",
          "linkedEntity": "SessionTree"
        }
      ],
      "pages": [
        {
          "name": "PipelineTree",
          "path": "/pipeline/tree",
          "traits": [
            {
              "ref": "SessionTreeDrawer"
            }
          ]
        }
      ]
    }
  ]
}