              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PipelineSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load pipelinesession"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button",
