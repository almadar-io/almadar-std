                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PipelineSessionLabel",
          "category": "interaction",
          "linkedEntity": "PipelineSession",
          "emits": [
            {
              "event": "LABELED"
            },
            {
              "event": "PipelineSessionLoadFailed",
              "description": "Fired when PipelineSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineSessionLoaded",
              "description": "Fired when PipelineSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PipelineSession]"
                }
              ]
            },
            {
              "event": "PipelineSessionUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineSessionUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LABEL",
                "name": "Label"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LABELED",
                "name": "Labeled"
              },
              {
                "key": "PipelineSessionLoadFailed",
                "name": "PipelineSession load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineSessionLoaded",
                "name": "PipelineSession loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PipelineSession]"
                  }
                ]
              },
              {
                "key": "PipelineSessionUpdateFailed",
                "name": "PipelineSession update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PipelineSessionUpdated",
                "name": "PipelineSession updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "PipelineSession"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "LABEL",
                "effects": [
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "failure": "PipelineSessionLoadFailed",
                        "success": "PipelineSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "tag",
                              "type": "icon"
                            },
                            {
                              "content": "Label Session",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "content": "Session:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.sessionId",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "fields": [
                            "label"
                          ],
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "cancelEvent": "CLOSE",
                          "mode": "edit",
                          "entity": "@entity"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "PipelineSession",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PipelineSessionUpdated",
                        "failure": "PipelineSessionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "LABELED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PipelineSessionAgent",
          "category": "interaction",
          "linkedEntity": "PipelineSession",
          "emits": [
            {
              "event": "ENDED",
              "scope": "external",
              "payload": [
                {
                  "name": "sessionId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FORKED",
              "scope": "external",
              "payload": [
                {
                  "name": "sessionId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PipelineSessionLoaded",
              "description": "Fired when PipelineSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PipelineSession]"
                }
              ]
            },
            {
              "event": "PipelineSessionLoadFailed",
              "description": "Fired when PipelineSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ENDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineSessionAgent"
              }
            },
            {
              "event": "FORKED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineSessionAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "active",
                "isInitial": true
              },
              {
                "name": "forked"
              },
              {
                "name": "ended"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FORK",
                "name": "Fork"
              },
              {
                "key": "DO_LABEL",
                "name": "Do Label",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LABELED",
                "name": "Labeled"
              },
              {
                "key": "END",
                "name": "End"
              },
              {
                "key": "ENDED",
                "name": "Ended"
              },
              {
                "key": "FORKED",
                "name": "Forked"
              },
              {
                "key": "PipelineSessionLoaded",
                "name": "PipelineSession loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PipelineSession]"
                  }
                ]
              },
              {
                "key": "PipelineSessionLoadFailed",
                "name": "PipelineSession load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "active",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "success": "PipelineSessionLoaded",
                        "failure": "PipelineSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@now"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "description": "Session is ready",
                          "type": "empty-state",
                          "icon": "git-branch",
                          "title": "Session"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Pipeline",
                          "href": "/pipeline",
                          "icon": "git-branch"
                        },
                        {
                          "label": "Execution",
                          "icon": "play",
                          "href": "/execution"
                        },
                        {
                          "label": "Logs",
                          "href": "/logs",
                          "icon": "terminal"
                        }
                      ],
                      "appName": "Agent Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "set",
                    "@entity.parentId",
                    "@entity.sessionId"
                  ],
                  [
                    "agent/fork"
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "persist",
                    "create",
                    "PipelineSession",
                    {
                      "parentId": "@entity.parentId",
                      "sessionId": "@entity.sessionId",
                      "status": "forked",
                      "createdAt": "@now"
                    }
                  ],
                  [
                    "emit",
                    "FORKED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DO_LABEL",
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.data.label"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "LABELED",
                "effects": [
                  [
                    "agent/label",
                    "@entity.label"
                  ],
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "failure": "PipelineSessionLoadFailed",
                        "success": "PipelineSessionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "ended"
                  ],
                  [
                    "emit",
                    "ENDED"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "set",
                    "@entity.parentId",
                    "@entity.sessionId"
                  ],
                  [
                    "agent/fork"
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "persist",
                    "create",
                    "PipelineSession",
                    {
                      "parentId": "@entity.parentId",
                      "sessionId": "@entity.sessionId",
                      "createdAt": "@now",
                      "status": "forked"
                    }
                  ],
                  [
                    "emit",
                    "FORKED"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "DO_LABEL",
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.data.label"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "LABELED",
                "effects": [
                  [
                    "agent/label",
                    "@entity.label"
                  ],
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "success": "PipelineSessionLoaded",
                        "failure": "PipelineSessionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "ended"
                  ],
                  [
                    "emit",
                    "ENDED"
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PipelineSession",
                    {
                      "emit": {
                        "failure": "PipelineSessionLoadFailed",
                        "success": "PipelineSessionLoaded"
                      }
                    }
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "active"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Pipeline",
                      "navItems": [
                        {
                          "icon": "git-branch",
                          "href": "/pipeline",
                          "label": "Pipeline"
                        },
                        {
                          "label": "Execution",
                          "href": "/execution",
                          "icon": "play"
                        },
                        {
                          "icon": "terminal",
                          "href": "/logs",
                          "label": "Logs"
                        }
                      ],
                      "children": [
                        {
                          "title": "Session",
                          "icon": "git-branch",
                          "type": "empty-state",
                          "description": "Session is ready"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Session",
          "path": "/session",
          "traits": [
