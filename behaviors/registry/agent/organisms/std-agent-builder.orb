              "event": "RESET"
            },
            {
              "event": "BuildLoopLoaded",
              "description": "Fired when BuildLoop finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BuildLoop]"
                }
              ]
            },
            {
              "event": "BuildLoopLoadFailed",
              "description": "Fired when BuildLoop fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
