                  "name": "schema",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESET"
            }
          ],
          "listens": [
            {
              "event": "PLAN_READY",
              "triggers": "EXECUTE",
              "source": {
                "kind": "orbital",
