        {
          "name": "PlannerMemoryLifecycle",
          "category": "interaction",
          "linkedEntity": "BuildPlan",
          "emits": [
            {
              "event": "BuildPlanLoaded",
              "description": "Fired when BuildPlan finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BuildPlan]"
                }
              ]
            },
            {
              "event": "BuildPlanLoadFailed",
              "description": "Fired when BuildPlan fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BuildPlanLoaded",
                "name": "BuildPlan loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BuildPlan]"
                  }
                ]
              },
              {
                "key": "BuildPlanLoadFailed",
                "name": "BuildPlan load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BuildPlan"
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BuildPlan"
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BuildPlan"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BuildPlan",
                    {
                      "emit": {
                        "failure": "BuildPlanLoadFailed",
                        "success": "BuildPlanLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading…",
