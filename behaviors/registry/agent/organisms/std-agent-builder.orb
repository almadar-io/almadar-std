                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "BuildPlanLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "align": "center",
                              "justify": "between",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "brain"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "BuildPlan Manager",
                                      "variant": "h2"
                                    }
