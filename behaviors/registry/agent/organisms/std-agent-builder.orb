{
  "description": "Agent builder organism — plan, build, validate, fix a single orbital end-to-end.",
  "name": "std-agent-builder",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "default": "",
            "name": "request",
            "type": "string"
          },
          {
            "default": "",
            "name": "plan",
            "type": "string"
          },
          {
            "default": "",
            "name": "orbitalName",
            "type": "string"
          },
          {
            "default": {},
            "name": "spec",
            "properties": {
              "deltaPrompt": {
                "name": "deltaPrompt",
                "required": true,
                "type": "string"
              },
              "method": {
                "name": "method",
                "required": true,
                "type": "string"
              },
              "orbitalName": {
                "name": "orbitalName",
                "required": true,
                "type": "string"
              },
              "organism": {
                "name": "organism",
                "required": true,
                "type": "string"
              }
            },
            "type": "object"
          },
          {
            "default": "",
            "name": "validationResult",
            "type": "string"
          },
          {
            "default": "",
            "name": "fixPrompt",
            "type": "string"
          },
          {
            "default": "idle",
            "name": "status",
            "type": "string",
            "values": [
              "idle",
              "done"
            ]
          }
        ],
        "name": "BuilderProcess",
        "persistence": "runtime"
      },
      "name": "AgentBuilderOrbital",
      "pages": [
        {
          "name": "AgentBuilderPage",
          "path": "/agent-builder",
          "traits": [
            {
              "ref": "BuilderPipeline"
            },
            {
              "ref": "BuilderListener"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "lifecycle",
          "emits": [
            {
              "event": "BUILD_COMPLETE",
              "payloadSchema": [
                {
                  "name": "orbitalName",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "plan",
                  "required": true,
                  "type": "string"
                }
              ]
            },
            {
              "event": "PLANNED",
              "payloadSchema": [
                {
                  "name": "result",
                  "required": true,
                  "type": "string"
                }
              ]
            }
          ],
          "linkedEntity": "BuilderProcess",
          "name": "BuilderPipeline",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start",
                "payloadSchema": [
                  {
                    "name": "request",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLANNED",
                "name": "Planned",
                "payloadSchema": [
                  {
                    "name": "result",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAN_FAILED",
                "name": "Plan Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "BUILD_COMPLETE",
                "name": "Build Complete",
                "payloadSchema": [
                  {
                    "name": "orbitalName",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "plan",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "planning"
              },
              {
                "name": "done"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.request",
                    ""
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.orbitalName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationResult",
                    ""
                  ],
                  [
                    "set",
                    "@entity.fixPrompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.request",
                    "@payload.request"
                  ],
                  [
                    "set",
                    "@entity.orbitalName",
                    "@payload.orbitalName"
                  ],
                  [
                    "llm/generate",
                    "@entity.request",
                    {
                      "emit": {
                        "failure": "PLAN_FAILED",
                        "success": "PLANNED"
                      }
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "planning"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    "@payload.result"
                  ],
                  [
                    "behavior/instantiate",
                    "@entity.orbitalName",
                    "@entity.plan"
                  ],
                  [
                    "validate/validate",
                    "@entity.orbitalName"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "done"
                  ],
                  [
                    "emit",
                    "BUILD_COMPLETE",
                    {
                      "orbitalName": "@entity.orbitalName",
                      "plan": "@entity.plan"
                    }
                  ]
                ],
                "event": "PLANNED",
                "from": "planning",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "behavior/instantiate",
                    "@entity.orbitalName",
                    "@entity.plan"
                  ],
                  [
                    "validate/validate",
                    "@entity.orbitalName"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "done"
                  ],
                  [
                    "emit",
                    "BUILD_COMPLETE",
                    {
                      "orbitalName": "@entity.orbitalName",
                      "plan": "@entity.plan"
                    }
                  ]
                ],
                "event": "PLAN_FAILED",
                "from": "planning",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "done"
                  ]
                ],
                "event": "INIT",
                "from": "done",
                "to": "done"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.request",
                    ""
                  ],
                  [
                    "set",
                    "@entity.plan",
                    ""
                  ],
                  [
                    "set",
                    "@entity.orbitalName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.validationResult",
                    ""
                  ],
                  [
                    "set",
                    "@entity.fixPrompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "RESET",
                "from": "done",
                "to": "idle"
              }
            ]
          }
        },
        {
          "category": "lifecycle",
          "linkedEntity": "BuilderProcess",
          "listens": [
            {
              "event": "BUILD_COMPLETE",
              "source": {
                "kind": "trait",
                "trait": "BuilderPipeline"
              },
              "triggers": "BUILD_COMPLETE"
            }
          ],
          "name": "BuilderListener",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BUILD_COMPLETE",
                "name": "Build Complete"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "waiting"
              },
              {
                "name": "resolved"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "INIT",
                "from": "waiting",
                "to": "waiting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "done"
                  ]
                ],
                "event": "BUILD_COMPLETE",
                "from": "waiting",
                "to": "resolved"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "done"
                  ]
                ],
                "event": "INIT",
                "from": "resolved",
                "to": "resolved"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ]
                ],
                "event": "RESET",
                "from": "resolved",
                "to": "waiting"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}