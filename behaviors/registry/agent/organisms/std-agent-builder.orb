          {
            "name": "tokenCount",
            "type": "number"
          },
          {
            "name": "maxTokens",
            "type": "number"
          },
          {
            "name": "usage",
            "type": "number"
          },
          {
            "name": "current",
            "type": "number"
          },
          {
            "name": "max",
            "type": "number"
          },
          {
            "name": "threshold",
            "type": "number"
          },
          {
            "name": "lastCompactedAt",
