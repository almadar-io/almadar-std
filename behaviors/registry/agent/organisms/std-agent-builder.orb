                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "BuildFixLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/plan",
                          "icon": "clipboard-list",
                          "label": "Plan"
                        },
                        {
                          "icon": "hammer",
                          "label": "Build",
                          "href": "/build"
                        },
                        {
                          "icon": "wrench",
                          "label": "Fix",
                          "href": "/fix"
                        }
                      ],
                      "appName": "Schema Builder",
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "alert-triangle"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "Validation Errors"
                                    }
