                  [
                    "persist",
                    "create",
                    "Concept",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ConceptSaved",
                        "failure": "ConceptSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "MEMORIZED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ConceptAgent",
          "category": "interaction",
          "linkedEntity": "Concept",
