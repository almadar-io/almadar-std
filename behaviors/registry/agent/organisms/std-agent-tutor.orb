                  }
                ]
              },
              {
                "key": "TutorChatLoaded",
                "name": "TutorChat loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TutorChat]"
                  }
                ]
              },
              {
                "key": "TutorChatLoadFailed",
                "name": "TutorChat load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "failure": "TutorChatLoadFailed",
                        "success": "TutorChatLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "description": "Conversation is ready",
                          "icon": "message-circle",
                          "title": "Conversation",
                          "type": "empty-state"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "href": "/quiz",
                          "icon": "help-circle",
                          "label": "Quiz"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "idle",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "active",
                "to": "active"
              },
              {
                "event": "PAUSE",
                "from": "active",
                "to": "paused"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ],
                "event": "CLEAR",
                "from": "active",
                "to": "idle"
              },
              {
                "event": "RESUME",
                "from": "paused",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ],
                "event": "CLEAR",
                "from": "paused",
                "to": "idle"
              }
            ]
          }
        }
      ]
    },
