                "event": "CLASSIFIED",
                "from": "idle",
                "to": "classifying"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.data.input"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ],
                "event": "DO_CLASSIFY",
                "from": "classifying",
                "to": "classified"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.input",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ]
                ],
                "event": "RESET",
                "from": "classified",
                "to": "idle"
              }
            ]
          }
        }
      ]
    },
