{
  "description": "Agent tutor: personalized tutoring with quizzes, concepts, and student assessments.",
  "name": "std-agent-tutor",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "The subject or area of study being addressed.",
            "name": "topic",
            "synonyms": "subject, area, theme, focus",
            "type": "string"
          },
          {
            "default": "unknown",
            "description": "Represents the student's proficiency level.",
            "name": "studentLevel",
            "synonyms": "level, skill, proficiency",
            "type": "string"
          },
          {
            "default": "",
            "description": "Detailed clarification or reasoning for a concept or answer.",
            "name": "explanation",
            "synonyms": "reasoning, justification, details, elaboration",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The total number of questions presented during the session.",
            "name": "questionsAsked",
            "synonyms": "count, number, total",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The number of questions answered correctly.",
            "name": "correctAnswers",
            "synonyms": "count, total, score",
            "type": "number"
          },
          {
            "default": "idle",
            "description": "The current state of the tutoring session.",
            "name": "sessionStatus",
            "synonyms": "status, state, condition",
            "type": "string"
          },
          {
            "default": "",
            "description": "A textual description of any encountered problem.",
            "name": "error",
            "synonyms": "issue, problem, fault, failure",
            "type": "string"
          },
          {
            "default": "",
            "description": "The currently selected tab or view within the session.",
            "name": "activeTab",
            "synonyms": "tab, view, selection",
            "type": "string"
          },
          {
            "default": [],
            "description": "A list of items associated with the session.",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "items",
            "synonyms": "elements, entries, list",
            "type": "array"
          }
        ],
        "name": "TutorSession",
        "persistence": "runtime"
      },
      "name": "TutorSessionOrbital",
      "pages": [
        {
          "name": "TeachPage",
          "path": "/teach",
          "traits": [
            {
              "ref": "TeachingSession"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "ASSESSMENT_DONE",
              "payloadSchema": [
                {
                  "name": "level",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "ASSESSMENT_DONE",
              "payloadSchema": [
                {
                  "name": "level",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "description": "Fired when TutorSession finishes loading",
              "event": "TutorSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TutorSession]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when TutorSession fails to load",
              "event": "TutorSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "TutorChatDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "TutorChatDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "ConceptSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "ConceptSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "StudentAssessmentSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "StudentAssessmentSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "TutorSession",
          "name": "TeachingSession",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START_SESSION",
                "name": "Start Session",
                "payloadSchema": [
                  {
                    "name": "topic",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ASSESSMENT_COMPLETE",
                "name": "Assessment Complete"
              },
              {
                "key": "EXPLAIN_MORE",
                "name": "Explain More"
              },
              {
                "key": "START_QUIZ",
                "name": "Start Quiz"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ASSESSMENT_DONE",
                "name": "Assessment Done",
                "payloadSchema": [
                  {
                    "name": "level",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TutorSessionLoaded",
                "name": "TutorSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TutorSession]"
                  }
                ]
              },
              {
                "key": "TutorSessionLoadFailed",
                "name": "TutorSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TutorChatDeleted",
                "name": "Tutor chat deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TutorChatDeleteFailed",
                "name": "Tutor chat delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConceptSaved",
                "name": "Concept saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConceptSaveFailed",
                "name": "Concept save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StudentAssessmentSaved",
                "name": "Student assessment saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StudentAssessmentSaveFailed",
                "name": "Student assessment save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "assessing"
              },
              {
                "name": "teaching"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.studentLevel",
                    "unknown"
                  ],
                  [
                    "fetch",
                    "TutorSession",
                    {
                      "emit": {
                        "failure": "TutorSessionLoadFailed",
                        "success": "TutorSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "graduation-cap",
                                  "type": "icon"
                                },
                                {
                                  "content": "Tutor",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "content": "What topic would you like to learn about? The tutor will assess your level and guide you through it.",
                                      "type": "typography",
                                      "variant": "body"
                                    },
                                    {
                                      "entity": "@entity",
                                      "fields": [
                                        "topic"
                                      ],
                                      "mode": "edit",
                                      "submitEvent": "START_SESSION",
                                      "type": "form-section"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "md",
                                  "type": "stack"
                                }
                              ],
                              "type": "card"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "href": "/quiz",
                          "icon": "help-circle",
                          "label": "Quiz"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.topic",
                    "@payload.topic"
                  ],
                  [
                    "set",
                    "@entity.sessionStatus",
                    "assessing"
                  ],
                  [
                    "agent/recall",
                    "@payload.topic"
                  ],
                  [
                    "agent/generate",
                    "@payload.topic"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "content": "Assessing your level...",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "content": "Recalling prior learning and classifying skill level",
                              "type": "typography",
                              "variant": "caption"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "href": "/quiz",
                          "icon": "help-circle",
                          "label": "Quiz"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "START_SESSION",
                "from": "idle",
                "to": "assessing"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.sessionStatus",
                    "teaching"
                  ],
                  [
                    "agent/memorize",
                    "@entity.topic",
                    "student-level"
                  ],
                  [
                    "emit",
                    "ASSESSMENT_DONE"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "book-open",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Lesson: @entity.topic",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack"
                                },
                                {
                                  "label": "@entity.studentLevel",
                                  "type": "badge"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "content": "@entity.explanation",
                                      "type": "typography",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "md",
                                  "type": "stack"
                                }
                              ],
                              "type": "card"
                            },
                            {
                              "children": [
                                {
                                  "action": "START_QUIZ",
                                  "icon": "help-circle",
                                  "label": "Quiz Me",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "EXPLAIN_MORE",
                                  "icon": "book-open",
                                  "label": "Explain More",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "RESET",
                                  "icon": "rotate-ccw",
                                  "label": "New Topic",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "label": "@entity.questionsAsked",
                                  "type": "badge"
                                },
                                {
                                  "label": "@entity.correctAnswers",
                                  "type": "badge"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "xs",
                              "type": "stack"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "href": "/quiz",
                          "icon": "help-circle",
                          "label": "Quiz"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "ASSESSMENT_COMPLETE",
                "from": "assessing",
                "to": "teaching"
              },
              {
                "effects": [
                  [
                    "agent/generate",
                    "@entity.topic"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "children": [
