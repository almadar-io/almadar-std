                                          "variant": "outline",
                                          "type": "badge",
                                          "label": "@item.status"
                                        },
                                        {
                                          "variant": "caption",
                                          "type": "typography",
                                          "color": "muted",
                                          "content": "@item.timestamp"
                                        }
                                      ],
                                      "align": "center",
                                      "gap": "sm"
                                    },
                                    {
                                      "content": "@item.content",
                                      "type": "typography",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TutorChatLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load tutorchat"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "label": "Retry",
                          "variant": "primary",
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "type": "typography",
                              "content": "TutorChat Thread",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CANCEL_COMPOSE",
                          "type": "form-section",
                          "fields": [
                            "content"
                          ],
                          "submitEvent": "SEND",
                          "mode": "create"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "TutorChat",
                    {
                      "emit": {
                        "success": "TutorChatDeleted",
                        "failure": "TutorChatDeleteFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "success": "TutorChatLoaded",
                        "failure": "TutorChatLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "TutorChat",
                    {
                      "content": "@payload.content",
                      "role": "user",
                      "timestamp": "@now",
                      "status": "sent"
                    }
                  ],
                  [
                    "emit",
                    "SEND_MESSAGE"
                  ],
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "failure": "TutorChatLoadFailed",
                        "success": "TutorChatLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "CANCEL_COMPOSE",
                "effects": [
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "success": "TutorChatLoaded",
                        "failure": "TutorChatLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "TutorChat",
                    {
                      "emit": {
                        "failure": "TutorChatDeleteFailed",
                        "success": "TutorChatDeleted"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "failure": "TutorChatLoadFailed",
                        "success": "TutorChatLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TutorChatAgent",
          "category": "interaction",
          "linkedEntity": "TutorChat",
          "emits": [
            {
              "event": "TOKEN_UPDATE",
              "scope": "internal",
              "payload": [
                {
                  "name": "tokenCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TutorChatLoaded",
              "description": "Fired when TutorChat finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[TutorChat]"
                }
              ]
            },
            {
              "event": "TutorChatLoadFailed",
              "description": "Fired when TutorChat fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payload": [
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update"
              },
              {
                "key": "TutorChatLoaded",
                "name": "TutorChat loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[TutorChat]"
                  }
                ]
              },
              {
                "key": "TutorChatLoadFailed",
                "name": "TutorChat load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TutorChat",
                    {
                      "emit": {
                        "success": "TutorChatLoaded",
                        "failure": "TutorChatLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "href": "/quiz",
                          "label": "Quiz",
                          "icon": "help-circle"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ],
                      "appName": "AI Tutor",
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "icon": "message-circle",
                          "title": "Conversation",
                          "description": "Conversation is ready",
                          "type": "empty-state"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "paused",
                "event": "PAUSE"
              },
              {
                "from": "active",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "active",
                "event": "RESUME"
              },
              {
                "from": "paused",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Chat",
          "path": "/chat",
          "traits": [
            {
              "ref": "TutorConversation"
            }
          ]
        }
      ]
    },
