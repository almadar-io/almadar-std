{
  "name": "std-agent-tutor",
  "version": "1.0.0",
  "description": "std-agent-tutor as a Function",
  "orbitals": [
    {
      "name": "TutorSessionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "TutorSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "topic",
            "type": "string",
            "default": ""
          },
          {
            "name": "studentLevel",
            "type": "string",
            "default": "unknown"
          },
          {
            "name": "explanation",
            "type": "string",
            "default": ""
          },
          {
            "name": "questionsAsked",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "correctAnswers",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "sessionStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TeachingSession",
          "category": "interaction",
          "linkedEntity": "TutorSession",
          "emits": [
            {
              "event": "ASSESSMENT_DONE",
              "scope": "internal",
              "payload": [
                {
                  "name": "level",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ASSESSMENT_DONE",
              "scope": "external",
              "payload": [
                {
                  "name": "level",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TutorSessionLoaded",
              "description": "Fired when TutorSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[TutorSession]"
                }
              ]
            },
            {
              "event": "TutorSessionLoadFailed",
              "description": "Fired when TutorSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TutorChatDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TutorChatDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConceptSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConceptSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StudentAssessmentSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StudentAssessmentSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "assessing"
              },
              {
                "name": "teaching"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START_SESSION",
                "name": "Start Session",
                "payload": [
                  {
                    "name": "topic",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ASSESSMENT_COMPLETE",
                "name": "Assessment Complete"
              },
              {
                "key": "EXPLAIN_MORE",
                "name": "Explain More"
              },
              {
                "key": "START_QUIZ",
                "name": "Start Quiz"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ASSESSMENT_DONE",
                "name": "Assessment Done"
              },
              {
                "key": "TutorSessionLoaded",
                "name": "TutorSession loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[TutorSession]"
                  }
                ]
              },
              {
                "key": "TutorSessionLoadFailed",
                "name": "TutorSession load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TutorChatDeleted",
                "name": "Tutor chat deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TutorChatDeleteFailed",
                "name": "Tutor chat delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConceptSaved",
                "name": "Concept saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConceptSaveFailed",
                "name": "Concept save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StudentAssessmentSaved",
                "name": "Student assessment saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StudentAssessmentSaveFailed",
                "name": "Student assessment save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TutorSession",
                    {
                      "emit": {
                        "success": "TutorSessionLoaded",
                        "failure": "TutorSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "graduation-cap"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Tutor"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "content": "What topic would you like to learn about? The tutor will assess your level and guide you through it.",
                                      "variant": "body",
                                      "type": "typography"
                                    },
                                    {
                                      "submitEvent": "START_SESSION",
                                      "fields": [
                                        "topic"
                                      ],
                                      "entity": "@entity",
                                      "mode": "edit",
                                      "type": "form-section"
                                    }
                                  ]
                                }
                              ],
                              "type": "card"
                            }
                          ]
                        }
                      ],
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "label": "Quiz",
                          "icon": "help-circle",
                          "href": "/quiz"
                        },
                        {
                          "label": "Concepts",
                          "icon": "brain",
                          "href": "/concepts"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "assessing",
                "event": "START_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.topic",
                    "@payload.topic"
                  ],
                  [
                    "set",
                    "@entity.sessionStatus",
                    "assessing"
                  ],
                  [
                    "agent/recall",
                    "@payload.topic"
                  ],
                  [
                    "agent/generate",
                    "@payload.topic"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "align": "center",
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "content": "Assessing your level...",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Recalling prior learning and classifying skill level"
                            }
                          ]
                        }
                      ],
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "icon": "help-circle",
                          "label": "Quiz",
                          "href": "/quiz"
                        },
                        {
                          "label": "Concepts",
                          "href": "/concepts",
                          "icon": "brain"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "assessing",
                "to": "teaching",
                "event": "ASSESSMENT_COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.sessionStatus",
                    "teaching"
                  ],
                  [
                    "agent/memorize",
                    "@entity.topic",
                    "student-level"
                  ],
                  [
                    "emit",
                    "ASSESSMENT_DONE"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/teach",
                          "label": "Teach",
                          "icon": "book-open"
                        },
                        {
                          "label": "Quiz",
                          "href": "/quiz",
                          "icon": "help-circle"
                        },
                        {
                          "href": "/concepts",
                          "label": "Concepts",
                          "icon": "brain"
                        }
                      ],
                      "appName": "AI Tutor",
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "book-open"
                                    },
                                    {
                                      "content": "Lesson: @entity.topic",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "sm",
                                  "align": "center",
                                  "direction": "horizontal",
                                  "type": "stack"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.studentLevel"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "md",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "content": "@entity.explanation",
                                      "variant": "body",
                                      "type": "typography"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "icon": "help-circle",
                                  "action": "START_QUIZ",
                                  "variant": "primary",
                                  "type": "button",
                                  "label": "Quiz Me"
                                },
                                {
                                  "label": "Explain More",
                                  "type": "button",
                                  "action": "EXPLAIN_MORE",
                                  "icon": "book-open",
                                  "variant": "secondary"
                                },
                                {
                                  "variant": "ghost",
                                  "type": "button",
                                  "label": "New Topic",
                                  "action": "RESET",
                                  "icon": "rotate-ccw"
                                }
                              ]
                            },
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "label": "@entity.questionsAsked",
                                  "type": "badge"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.correctAnswers"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "teaching",
                "to": "teaching",
                "event": "EXPLAIN_MORE",
                "effects": [
                  [
                    "agent/generate",
                    "@entity.topic"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "href": "/teach",
                          "label": "Teach",
                          "icon": "book-open"
                        },
                        {
                          "label": "Quiz",
                          "href": "/quiz",
                          "icon": "help-circle"
                        },
                        {
                          "label": "Concepts",
                          "icon": "brain",
                          "href": "/concepts"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "justify": "between",
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "book-open"
                                    },
                                    {
                                      "content": "Lesson: @entity.topic",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.studentLevel"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "gap": "md",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": "@entity.explanation"
                                    }
                                  ],
                                  "type": "stack"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "button",
                                  "label": "Quiz Me",
                                  "icon": "help-circle",
                                  "action": "START_QUIZ",
                                  "variant": "primary"
                                },
                                {
                                  "type": "button",
                                  "label": "Explain More",
                                  "action": "EXPLAIN_MORE",
                                  "icon": "book-open",
                                  "variant": "secondary"
                                },
                                {
                                  "icon": "rotate-ccw",
                                  "action": "RESET",
                                  "variant": "ghost",
                                  "type": "button",
                                  "label": "New Topic"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "gap": "xs",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "@entity.questionsAsked",
                                  "type": "badge"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.correctAnswers"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "teaching",
                "to": "teaching",
                "event": "START_QUIZ",
                "effects": [
                  [
                    "emit",
                    "ASSESSMENT_DONE"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/teach",
                          "icon": "book-open",
                          "label": "Teach"
                        },
                        {
                          "label": "Quiz",
                          "href": "/quiz",
                          "icon": "help-circle"
                        },
                        {
                          "label": "Concepts",
                          "icon": "brain",
                          "href": "/concepts"
                        }
                      ],
                      "children": [
                        {
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "name": "book-open",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h2",
                                      "content": "Lesson: @entity.topic"
                                    }
                                  ]
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.studentLevel"
                                }
                              ],
                              "type": "stack",
                              "align": "center",
                              "justify": "between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "direction": "vertical",
                                  "gap": "md",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "@entity.explanation",
                                      "variant": "body"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "type": "button",
                                  "action": "START_QUIZ",
                                  "variant": "primary",
                                  "icon": "help-circle",
                                  "label": "Quiz Me"
                                },
                                {
                                  "icon": "book-open",
                                  "type": "button",
                                  "action": "EXPLAIN_MORE",
                                  "variant": "secondary",
                                  "label": "Explain More"
                                },
                                {
                                  "label": "New Topic",
                                  "type": "button",
                                  "variant": "ghost",
                                  "action": "RESET",
                                  "icon": "rotate-ccw"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "gap": "xs",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "@entity.questionsAsked"
                                },
                                {
                                  "label": "@entity.correctAnswers",
                                  "type": "badge"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "AI Tutor"
                    }
                  ]
                ]
              },
              {
                "from": "teaching",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sessionStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.topic",
                    ""
                  ],
                  [
                    "set",
                    "@entity.explanation",
                    ""
                  ],
                  [
                    "set",
                    "@entity.questionsAsked",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.correctAnswers",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "graduation-cap"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Tutor"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "What topic would you like to learn about? The tutor will assess your level and guide you through it.",
                                      "variant": "body"
                                    },
                                    {
                                      "mode": "edit",
                                      "type": "form-section",
                                      "submitEvent": "START_SESSION",
                                      "fields": [
                                        "topic"
                                      ],
                                      "entity": "@entity"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "md",
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "label": "Teach",
                          "href": "/teach",
                          "icon": "book-open"
                        },
                        {
                          "label": "Quiz",
                          "icon": "help-circle",
                          "href": "/quiz"
                        },
                        {
                          "href": "/concepts",
                          "icon": "brain",
                          "label": "Concepts"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TeachPage",
          "path": "/teach",
          "traits": [
            {
              "ref": "TeachingSession"
            }
          ]
        }
      ]
    },
    {
      "name": "QuizQuestionOrbital",
      "entity": {
        "name": "QuizQuestion",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "question",
            "type": "string"
          },
          {
            "name": "options",
            "type": "string"
          },
          {
            "name": "correctAnswer",
            "type": "string"
          },
          {
            "name": "studentAnswer",
            "type": "string"
          },
          {
            "name": "isCorrect",
            "type": "boolean"
          },
          {
            "name": "feedback",
            "type": "string"
          },
          {
            "name": "quizStatus",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "QuizEngine",
          "category": "interaction",
          "linkedEntity": "QuizQuestion",
          "emits": [
            {
              "event": "QUIZ_GRADED",
              "scope": "internal",
              "payload": [
                {
                  "name": "correct",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "QUIZ_GRADED",
              "scope": "external",
              "payload": [
                {
                  "name": "correct",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "QuizQuestionLoaded",
              "description": "Fired when QuizQuestion finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[QuizQuestion]"
                }
              ]
            },
            {
              "event": "QuizQuestionLoadFailed",
              "description": "Fired when QuizQuestion fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ASSESSMENT_DONE",
              "triggers": "GENERATE_QUESTION",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "quizzing"
              },
              {
                "name": "reviewing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE_QUESTION",
                "name": "Generate Question"
              },
              {
                "key": "QUESTION_READY",
                "name": "Question Ready"
              },
              {
                "key": "SUBMIT_ANSWER",
                "name": "Submit Answer",
                "payload": [
                  {
                    "name": "studentAnswer",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "NEXT_QUESTION",
                "name": "Next Question"
              },
              {
                "key": "BACK_TO_LESSON",
                "name": "Back To Lesson"
              },
              {
                "key": "QUIZ_GRADED",
                "name": "Quiz Graded"
              },
              {
                "key": "QuizQuestionLoaded",
                "name": "QuizQuestion loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[QuizQuestion]"
                  }
                ]
              },
              {
                "key": "QuizQuestionLoadFailed",
                "name": "QuizQuestion load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuizQuestion",
                    {
                      "emit": {
                        "failure": "QuizQuestionLoadFailed",
                        "success": "QuizQuestionLoaded"
                      }
                    }
