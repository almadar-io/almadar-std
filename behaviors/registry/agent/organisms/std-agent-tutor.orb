                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "hidden",
                "to": "hidden",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StudentAssessment",
                    {
                      "emit": {
                        "failure": "StudentAssessmentLoadFailed",
                        "success": "StudentAssessmentLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "hidden",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "book-open",
                          "label": "Teach",
                          "href": "/teach"
                        },
                        {
                          "icon": "help-circle",
                          "label": "Quiz",
                          "href": "/quiz"
                        },
                        {
                          "label": "Concepts",
                          "icon": "brain",
                          "href": "/concepts"
                        }
                      ],
                      "children": [
                        {
                          "children": [
                            {
                              "justify": "between",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "tag"
                                    },
                                    {
                                      "variant": "h2",
                                      "content": "StudentAssessment Result",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "md",
                                  "type": "stack",
                                  "align": "center"
                                },
                                {
                                  "label": "Dismiss",
                                  "action": "HIDE",
                                  "type": "button",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ],
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "variant": "@entity.notificationType",
                              "message": "@entity.message",
                              "type": "alert"
                            },
                            {
                              "type": "toast-slot"
                            },
                            {
                              "message": "@entity.message",
                              "type": "alert",
                              "variant": "warning"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "appName": "AI Tutor"
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "justify": "between",
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "align": "center",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "tag"
                                    },
                                    {
                                      "content": "StudentAssessment Result",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ]
                                },
                                {
                                  "type": "button",
                                  "variant": "ghost",
                                  "icon": "x",
                                  "action": "HIDE",
                                  "label": "Dismiss"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "alert",
                              "variant": "@entity.notificationType",
                              "message": "@entity.message"
                            },
                            {
                              "type": "toast-slot"
                            },
                            {
                              "variant": "warning",
                              "message": "@entity.message",
                              "type": "alert"
                            }
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ],
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "label": "Teach",
                          "icon": "book-open",
                          "href": "/teach"
                        },
                        {
                          "icon": "help-circle",
                          "label": "Quiz",
                          "href": "/quiz"
                        },
                        {
                          "label": "Concepts",
                          "href": "/concepts",
                          "icon": "brain"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "hidden",
                "event": "HIDE",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "StudentAssessmentAgent",
          "category": "interaction",
          "linkedEntity": "StudentAssessment",
          "emits": [
            {
              "event": "SHOW",
              "scope": "internal",
              "payload": [
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "confidence",
                  "type": "number"
                }
              ]
            },
            {
              "event": "StudentAssessmentLoaded",
              "description": "Fired when StudentAssessment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[StudentAssessment]"
                }
              ]
            },
            {
              "event": "StudentAssessmentLoadFailed",
              "description": "Fired when StudentAssessment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CLASSIFIED",
              "triggers": "CLASSIFIED",
              "source": {
                "kind": "trait",
                "trait": "LevelClassifier"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "classifying"
              },
              {
                "name": "classified"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CLASSIFY",
                "name": "Do Classify",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "StudentAssessmentLoaded",
                "name": "StudentAssessment loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[StudentAssessment]"
                  }
                ]
              },
              {
                "key": "StudentAssessmentLoadFailed",
                "name": "StudentAssessment load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StudentAssessment",
                    {
                      "emit": {
                        "failure": "StudentAssessmentLoadFailed",
                        "success": "StudentAssessmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "AI Tutor",
                      "navItems": [
                        {
                          "label": "Teach",
                          "href": "/teach",
                          "icon": "book-open"
                        },
                        {
                          "icon": "help-circle",
                          "label": "Quiz",
                          "href": "/quiz"
                        },
                        {
                          "icon": "brain",
                          "label": "Concepts",
                          "href": "/concepts"
                        }
                      ],
                      "children": [
                        {
                          "icon": "tag",
                          "type": "empty-state",
                          "title": "Classifier",
                          "description": "Classifier is ready"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "DO_CLASSIFY",
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "beginner, intermediate, advanced, expert",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "CLASSIFIED",
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "beginner, intermediate, advanced, expert",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "classified",
                "event": "DO_CLASSIFY",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.data.input"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "classified",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.input",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Assessment",
          "path": "/assessment",
          "traits": [
            {
              "ref": "LevelClassifier"
            }
          ]
        }
      ]
    },
    {
      "name": "TutorNavOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "TutorNav",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "topic",
            "type": "string",
            "default": ""
          },
          {
            "name": "studentLevel",
            "type": "string",
            "default": "unknown"
          },
          {
            "name": "explanation",
            "type": "string",
            "default": ""
          },
          {
            "name": "questionsAsked",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "correctAnswers",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "sessionStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Tabs.traits.TabContentTabs",
          "name": "TutorTabs",
          "linkedEntity": "TutorSession"
        }
      ],
      "pages": [
        {
          "name": "TutorNav",
          "path": "/tutor/nav",
          "traits": [
            {
              "ref": "TutorTabs"
            }
          ]
        }
      ]
    },
    {
      "name": "ConceptViewOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "ConceptView",
        "collection": "conceptviews",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "strength",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ConceptsBrowse",
          "linkedEntity": "Concept"
        }
      ],
      "pages": [
        {
          "name": "TutorConcepts",
          "path": "/tutor/concepts",
          "traits": [
            {
              "ref": "ConceptsBrowse"
            }
          ]
        }
      ]
    }
  ]
}
