              {
                "key": "SHOW",
                "name": "Show",
                "payloadSchema": [
                  {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentClassifierLoaded",
                "name": "AgentClassifier loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "input",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "confidence",
                    "type": "number"
                  },
                  {
                    "name": "model",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentClassifierLoadFailed",
                "name": "AgentClassifier load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "classifying"
              },
              {
                "name": "classified"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentClassifier",
                    {
                      "emit": {
                        "failure": "AgentClassifierLoadFailed",
                        "success": "AgentClassifierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Classifier is ready",
                      "icon": "tag",
                      "title": "Classifier",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "positive, negative, neutral",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ],
                "event": "DO_CLASSIFY",
                "from": "idle",
                "to": "classifying"
              },
              {
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "positive, negative, neutral",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ],
                "event": "CLASSIFIED",
                "from": "idle",
                "to": "classifying"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.data.input"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Classification complete",
                      "notificationType": "success"
                    }
                  ]
                ],
                "event": "DO_CLASSIFY",
                "from": "classifying",
                "to": "classified"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.input",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0.0
                  ]
                ],
                "event": "RESET",
                "from": "classified",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}