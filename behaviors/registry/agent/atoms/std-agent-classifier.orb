{
  "description": "std-agent-classifier as a Function",
  "name": "std-agent-classifier",
  "orbitals": [
    {
      "entity": {
        "collection": "agentclassifiers",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the agent classifier.",
            "name": "name",
            "synonyms": "identifier, label, designation",
            "type": "string"
          },
          {
            "description": "A textual explanation of the agent's classification.",
            "name": "description",
            "synonyms": "explanation, details, notes, summary",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the classifier.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "Data provided to the component for processing.",
            "name": "input",
            "synonyms": "data, value, content, source",
            "type": "string"
          },
          {
            "default": "",
            "description": "Represents the classification type or group.",
            "name": "category",
            "synonyms": "type, class, group",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "Represents the certainty level of a classification result.",
            "name": "confidence",
            "synonyms": "score, probability, certainty",
            "type": "number"
          },
          {
            "default": "claude-sonnet-4-20250514",
            "description": "The identifier or path to the machine learning model.",
            "name": "model",
            "synonyms": "path, identifier, reference, location",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text content of the message being processed.",
            "name": "message",
            "synonyms": "text, content, body, payload",
            "type": "string"
          },
          {
            "default": "info",
            "description": "Indicates the type of notification generated.",
            "name": "notificationType",
            "synonyms": "type, level, severity",
            "type": "string",
            "values": [
              "info",
              "success",
              "warning",
              "error"
            ]
          }
        ],
        "name": "AgentClassifier",
        "persistence": "persistent"
      },
