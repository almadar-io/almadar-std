{
  "description": "std-agent-context-window as a Function",
  "name": "std-agent-context-window",
  "orbitals": [
    {
      "entity": {
        "collection": "agentcontextwindows",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the context window.",
            "name": "name",
            "synonyms": "label, identifier, title",
            "type": "string"
          },
          {
            "description": "A textual explanation of the context window's purpose.",
            "name": "description",
            "synonyms": "explanation, details, notes, information",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the component.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of tokens currently in use.",
            "name": "tokenCount",
            "synonyms": "count, quantity, size",
            "type": "number"
          },
          {
            "default": 200000.0,
            "description": "The maximum number of tokens allowed.",
            "name": "maxTokens",
            "synonyms": "limit, maximum, cap",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "Represents the current usage of the context window.",
            "name": "usage",
            "synonyms": "count, current, utilization",
            "type": "number"
          },
          {
            "default": "",
            "description": "Timestamp of the last compaction event.",
            "name": "lastCompactedAt",
            "synonyms": "lastModified, updated, compactionTime",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The current value of a numerical measurement.",
            "name": "current",
            "synonyms": "value, amount, level, reading",
            "type": "number"
          },
          {
            "default": 200000.0,
            "description": "The maximum allowable value for this context.",
            "name": "max",
            "synonyms": "limit, maximum, upper bound",
            "type": "number"
          },
          {
            "default": 0.85,
            "description": "The point at which an action is triggered.",
            "name": "threshold",
            "synonyms": "limit, boundary, trigger",
            "type": "number"
          },
          {
            "default": "",
            "description": "The text content of the message.",
            "name": "message",
            "synonyms": "content, text, body",
            "type": "string"
          },
          {
            "default": "info",
            "description": "Indicates the type of notification generated.",
            "name": "notificationType",
            "synonyms": "type, alert, level",
            "type": "string",
            "values": [
              "info",
              "success",
              "warning",
              "error"
            ]
          }
        ],
        "name": "AgentContextWindow",
        "persistence": "persistent"
      },
      "name": "AgentContextWindowOrbital",
      "pages": [
        {
          "name": "AgentContextWindowPage",
          "path": "/agentcontextwindows",
          "traits": [
            {
              "ref": "AgentContextWindowGauge"
            },
            {
              "ref": "AgentContextWindowNotification"
            },
            {
              "ref": "AgentContextWindowAgent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "COMPACT"
            },
            {
              "description": "Fired when AgentContextWindow finishes loading",
              "event": "AgentContextWindowLoaded",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "maxTokens",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentContextWindow fails to load",
              "event": "AgentContextWindowLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "entityContract": {
            "provides": [
              "current",
              "lastCompactedAt",
              "max"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AgentContextWindow",
          "name": "AgentContextWindowGauge",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "current",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "AgentContextWindowLoaded",
                "name": "AgentContextWindow loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoadFailed",
                "name": "AgentContextWindow load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "normal"
              },
              {
                "name": "warning"
              },
              {
                "name": "critical"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.max",
                    200000.0
                  ],
                  [
                    "fetch",
                    "AgentContextWindow",
                    {
                      "emit": {
                        "failure": "AgentContextWindowLoadFailed",
                        "success": "AgentContextWindowLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "gauge",
                              "type": "icon"
                            },
                            {
                              "content": "Token Usage",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "label": "Normal",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "max": "@entity.max",
                          "type": "progress-bar",
                          "value": "@entity.current"
                        },
                        {
                          "children": [
                            {
                              "label": "Tokens Used",
                              "type": "stat-display",
                              "value": "@entity.current"
                            },
                            {
                              "label": "Max Tokens",
                              "type": "stat-display",
                              "value": "@entity.max"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "normal",
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.current",
                    "@payload.current"
