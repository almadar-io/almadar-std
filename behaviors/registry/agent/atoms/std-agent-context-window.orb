                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentContextWindow fails to load",
              "event": "AgentContextWindowLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentContextWindow",
          "listens": [
            {
              "event": "COMPACT",
              "source": {
                "kind": "trait",
                "trait": "AgentContextWindowGauge"
              },
              "triggers": "COMPACT"
            }
          ],
          "name": "AgentContextWindowAgent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Tokens"
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payloadSchema": [
                  {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoaded",
                "name": "AgentContextWindow loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoadFailed",
                "name": "AgentContextWindow load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "normal"
              },
              {
                "name": "approaching_limit"
              },
              {
                "name": "at_limit"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.maxTokens",
                    200000.0
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ],
                  [
                    "fetch",
                    "AgentContextWindow",
                    {
                      "emit": {
                        "failure": "AgentContextWindowLoadFailed",
                        "success": "AgentContextWindowLoaded"
                      }
                    }
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Context Window is ready",
                      "icon": "layers",
                      "title": "Context Window",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "normal",
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "normal",
                "guard": [
                  "<",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  0.85
                ],
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Token usage approaching limit",
                      "notificationType": "warning"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "normal",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "to": "approaching_limit"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Token usage at limit. Compact required.",
                      "notificationType": "error"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "approaching_limit",
                "guard": [
                  ">=",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  1.0
                ],
                "to": "at_limit"
              },
              {
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ]
                ],
                "event": "COMPACT",
                "from": "approaching_limit",
                "to": "normal"
              },
              {
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ]
                ],
                "event": "UPDATE_TOKENS",
                "from": "approaching_limit",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "to": "approaching_limit"
              },
              {
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE",
                    {
                      "current": "@entity.tokenCount",
                      "max": "@entity.maxTokens"
                    }
                  ]
                ],
                "event": "COMPACT",
                "from": "at_limit",
                "to": "normal"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
