                "event": "SHOW",
                "from": "visible",
                "to": "visible"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ],
                "event": "HIDE",
                "from": "visible",
                "to": "hidden"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SHOW",
              "payloadSchema": [
                {
