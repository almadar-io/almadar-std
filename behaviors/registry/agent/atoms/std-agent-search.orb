{
  "description": "std-agent-search as a Function",
  "name": "std-agent-search",
  "orbitals": [
    {
      "entity": {
        "collection": "agentsearchs",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The identifier or title for the agent.",
            "name": "name",
            "synonyms": "title, label, identifier",
            "type": "string"
          },
          {
            "description": "A textual explanation of the search.",
            "name": "description",
            "synonyms": "summary, details, explanation",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the search.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "The search term or criteria used for the request.",
            "name": "query",
            "synonyms": "term, searchString, criteria, keyword",
            "type": "string"
          },
          {
            "default": [],
            "description": "The data returned as a result of the search.",
            "items": {
              "type": "string"
            },
            "name": "results",
            "synonyms": "output, data, response",
            "type": "array"
          },
          {
            "default": "",
            "description": "The language used for the search query.",
            "name": "language",
            "synonyms": "locale, languageCode, languageTag",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The total number of results found.",
            "name": "resultCount",
            "synonyms": "count, total, size",
            "type": "number"
          }
        ],
        "name": "AgentSearch",
        "persistence": "persistent"
      },
      "name": "AgentSearchOrbital",
      "pages": [
        {
          "name": "AgentSearchPage",
          "path": "/agentsearchs",
          "traits": [
            {
              "ref": "AgentSearchBrowse"
            },
            {
              "ref": "AgentSearchAgent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SEARCH"
            },
            {
              "event": "CLEAR"
            },
            {
              "description": "Fired when AgentSearch finishes loading; payload.data holds the list",
              "event": "AgentSearchLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSearch]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentSearch fails to load",
              "event": "AgentSearchLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AgentSearch",
          "listens": [
            {
              "event": "SEARCHED",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchAgent"
              },
              "triggers": "INIT"
            }
          ],
          "name": "AgentSearchBrowse",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSearch]"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "AgentSearch"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading searches…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "search",
                                  "type": "icon"
                                },
                                {
                                  "content": "AgentSearch",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "action": "SEARCH",
                                  "icon": "search",
                                  "label": "Search",
                                  "type": "button",
                                  "variant": "primary"
                                },
                                {
                                  "action": "CLEAR",
                                  "icon": "x",
                                  "label": "Clear",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "icon": "search",
                              "label": "Query",
                              "name": "query",
                              "variant": "h4"
                            },
                            {
                              "colorMap": {
                                "active": "success",
                                "archived": "neutral",
                                "cancelled": "error",
                                "completed": "success",
                                "disabled": "neutral",
                                "done": "success",
                                "draft": "warning",
                                "error": "error",
                                "failed": "error",
                                "inactive": "neutral",
                                "pending": "warning",
                                "scheduled": "warning"
                              },
                              "label": "Language",
                              "name": "language",
                              "variant": "badge"
                            },
                            {
                              "label": "Result Count",
                              "name": "resultCount",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "ghost"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "className": "max-w-5xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentSearchLoaded",
                "from": "loading",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load searches",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentSearchLoadFailed",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "browsing",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SEARCHED",
              "payloadSchema": [
                {
                  "name": "query",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "resultCount",
                  "type": "number"
                }
              ],
              "scope": "external"
            },
            {
              "description": "Fired when AgentSearch finishes loading; payload.data holds the list",
              "event": "AgentSearchLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSearch]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentSearch fails to load",
              "event": "AgentSearchLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentSearch",
          "listens": [
            {
              "event": "SEARCH",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchBrowse"
              },
              "triggers": "SEARCH"
            },
            {
              "event": "CLEAR",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchBrowse"
              },
              "triggers": "CLEAR"
            }
          ],
          "name": "AgentSearchAgent",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "language",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEARCHED",
                "name": "Searched",
                "payloadSchema": [
                  {
                    "name": "query",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "resultCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSearch]"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Code Search is ready",
                      "icon": "search",
                      "title": "Code Search",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ],
                "event": "SEARCH",
                "from": "idle",
                "to": "searching"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "emit",
                    "SEARCHED",
                    {
                      "query": "@payload.query",
                      "resultCount": 0.0
                    }
                  ]
                ],
                "event": "SEARCH",
                "from": "searching",
                "to": "results"
              },
              {
                "effects": [
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ],
                "event": "SEARCH",
                "from": "results",
                "to": "searching"
              },
              {
                "event": "CLEAR",
                "from": "results",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}