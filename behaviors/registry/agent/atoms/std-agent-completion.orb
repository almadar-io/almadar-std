{
  "description": "std-agent-completion as a Function",
  "name": "std-agent-completion",
  "orbitals": [
    {
      "entity": {
        "collection": "agentcompletions",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A user-facing identifier for the completion.",
            "name": "name",
            "synonyms": "label, identifier, title",
            "type": "string"
          },
          {
            "description": "A textual explanation of the completion's purpose.",
            "name": "description",
            "synonyms": "explanation, details, notes",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Current operational state of the process.",
            "name": "status",
            "synonyms": "state, condition, progress",
            "type": "string",
            "values": [
              "idle",
              "generating",
              "completed",
              "error"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text used as input to generate a completion.",
            "name": "prompt",
            "synonyms": "query, input, request",
            "type": "string"
          },
          {
            "default": "",
            "description": "The output or result generated by the agent.",
            "name": "response",
            "synonyms": "result, output, answer, value",
            "type": "string"
          },
          {
            "default": "anthropic",
            "description": "Identifies the source of the completion data.",
            "name": "provider",
            "synonyms": "source, origin, provider",
            "type": "string"
          },
          {
            "default": "claude-sonnet-4-20250514",
            "description": "The underlying model used for generating completions.",
            "name": "model",
            "synonyms": "algorithm, engine, technique",
            "type": "string"
          },
          {
            "default": "",
            "description": "Details about any errors encountered during processing.",
            "name": "error",
            "synonyms": "failure, problem, issue, fault",
            "type": "string"
          },
          {
            "default": "",
            "description": "The text content of the completion message.",
            "name": "message",
            "synonyms": "content, text, body",
            "type": "string"
          },
          {
            "default": "info",
            "description": "Indicates the type of notification generated.",
            "name": "notificationType",
            "synonyms": "type, level, category",
            "type": "string",
            "values": [
              "info",
              "success",
              "warning",
              "error"
            ]
          }
        ],
        "name": "AgentCompletion",
        "persistence": "persistent"
      },
