                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionLoadFailed",
                "name": "AgentCompletion load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentCompletion",
                    {
                      "emit": {
                        "success": "AgentCompletionLoaded",
                        "failure": "AgentCompletionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "empty-state",
                      "icon": "sparkles",
                      "title": "Completion",
                      "description": "Completion is ready"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "DO_GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "DO_GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.data.prompt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "notificationType": "success",
                      "message": "Completion ready"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "error",
                "event": "RESET",
                "guard": [
                  "=",
                  "@entity.status",
                  "generating"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Generation was cancelled"
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ]
                ]
              },
              {
                "from": "error",
                "to": "generating",
                "event": "RETRY",
                "guard": [
                  "=",
                  "@entity.status",
                  "error"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentCompletionPage",
          "path": "/agentcompletions",
          "traits": [
            {
              "ref": "AgentCompletionModal"
            },
            {
              "ref": "AgentCompletionNotification"
            },
            {
              "ref": "AgentCompletionAgent"
            }
          ]
        }
      ]
    }
  ]
}
