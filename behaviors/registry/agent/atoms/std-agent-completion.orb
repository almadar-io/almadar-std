{
  "name": "std-agent-completion",
  "version": "1.0.0",
  "description": "std-agent-completion as a Function",
  "orbitals": [
    {
      "name": "AgentCompletionOrbital",
      "entity": {
        "name": "AgentCompletion",
        "collection": "agentcompletions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "provider",
            "type": "string",
            "default": "anthropic"
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "notificationType",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "success",
              "warning",
              "error"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "AgentCompletionModal",
          "category": "interaction",
          "linkedEntity": "AgentCompletion",
          "emits": [
            {
              "event": "GENERATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentCompletionLoaded",
              "description": "Fired when AgentCompletion finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "prompt",
                  "type": "string"
                },
                {
                  "name": "response",
                  "type": "string"
                },
                {
                  "name": "provider",
                  "type": "string"
                },
                {
                  "name": "model",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentCompletionLoadFailed",
              "description": "Fired when AgentCompletion fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentCompletionSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentCompletionSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "GENERATED",
                "name": "Generated"
              },
              {
                "key": "AgentCompletionLoaded",
                "name": "AgentCompletion loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "prompt",
                    "type": "string"
                  },
                  {
                    "name": "response",
                    "type": "string"
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "model",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionLoadFailed",
                "name": "AgentCompletion load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionSaved",
                "name": "AgentCompletion saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionSaveFailed",
                "name": "AgentCompletion save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentCompletion",
                    {
                      "emit": {
                        "failure": "AgentCompletionLoadFailed",
                        "success": "AgentCompletionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "sparkles"
                                },
                                {
                                  "type": "typography",
                                  "content": "AgentCompletion",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "label": "Open",
                              "type": "button",
                              "variant": "primary",
                              "icon": "sparkles",
                              "action": "GENERATE"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "title": "Nothing open",
                          "type": "empty-state",
                          "icon": "sparkles",
                          "description": "Click Open to view details in a modal overlay."
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "GENERATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "sparkles"
                            },
                            {
                              "content": "AgentCompletion",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@entity.provider"
                            },
                            {
                              "label": "@entity.model",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "type": "form-section",
                          "fields": [
                            "prompt"
                          ],
                          "mode": "create",
                          "submitEvent": "SAVE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ],
                  [
                    "fetch",
                    "AgentCompletion",
                    {
                      "emit": {
                        "failure": "AgentCompletionLoadFailed",
                        "success": "AgentCompletionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "sparkles",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "AgentCompletion"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "variant": "primary",
                              "action": "GENERATE",
                              "label": "Open",
                              "type": "button",
                              "icon": "sparkles"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "icon": "sparkles",
                          "description": "Click Open to view details in a modal overlay.",
                          "title": "Nothing open",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentCompletion",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "AgentCompletionSaved",
                        "failure": "AgentCompletionSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "GENERATED"
                  ],
                  [
                    "fetch",
                    "AgentCompletion",
                    {
                      "emit": {
                        "failure": "AgentCompletionLoadFailed",
                        "success": "AgentCompletionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "sparkles"
                                },
                                {
                                  "variant": "h2",
                                  "content": "AgentCompletion",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "icon": "sparkles",
                              "variant": "primary",
                              "label": "Open",
                              "action": "GENERATE"
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "icon": "sparkles",
                          "type": "empty-state",
                          "description": "Click Open to view details in a modal overlay.",
                          "title": "Nothing open"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AgentCompletionNotification",
