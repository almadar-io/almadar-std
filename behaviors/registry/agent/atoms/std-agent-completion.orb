                "key": "DO_GENERATE",
                "name": "Do Generate",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ]
              },
              {
                "key": "GENERATED",
                "name": "Generated"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payloadSchema": [
                  {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionLoaded",
                "name": "AgentCompletion loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "prompt",
                    "type": "string"
                  },
                  {
                    "name": "response",
                    "type": "string"
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "model",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentCompletionLoadFailed",
                "name": "AgentCompletion load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentCompletion",
                    {
                      "emit": {
                        "failure": "AgentCompletionLoadFailed",
                        "success": "AgentCompletionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Completion is ready",
                      "icon": "sparkles",
                      "title": "Completion",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ],
                "event": "DO_GENERATE",
                "from": "idle",
                "to": "generating"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ],
                "event": "GENERATED",
                "from": "idle",
                "to": "generating"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.data.prompt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Completion ready",
                      "notificationType": "success"
                    }
                  ]
                ],
                "event": "DO_GENERATE",
                "from": "generating",
                "to": "completed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Generation was cancelled"
                  ]
                ],
                "event": "RESET",
                "from": "generating",
                "guard": [
                  "=",
                  "@entity.status",
                  "generating"
                ],
                "to": "error"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ]
                ],
                "event": "RESET",
                "from": "completed",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ],
                "event": "RETRY",
                "from": "error",
                "guard": [
                  "=",
                  "@entity.status",
                  "error"
                ],
                "to": "generating"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ]
                ],
                "event": "RESET",
                "from": "error",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.1"
}