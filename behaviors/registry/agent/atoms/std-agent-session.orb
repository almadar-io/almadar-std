                              "icon": "git-branch",
                              "label": "Fork",
                              "variant": "secondary"
                            },
                            {
                              "event": "LABEL",
                              "icon": "tag",
                              "label": "Label",
                              "variant": "secondary"
                            },
                            {
                              "event": "END",
                              "icon": "square",
                              "label": "End",
                              "variant": "ghost"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "className": "max-w-5xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentSessionLoaded",
                "from": "loading",
                "to": "browsing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
