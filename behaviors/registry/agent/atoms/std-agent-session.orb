                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "entity": "@payload.row",
                          "fields": [
                            "label"
                          ],
                          "mode": "edit",
                          "submitEvent": "SAVE",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "LABEL",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "LABELED",
                    {
                      "id": "@payload.data.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ],
                "event": "SAVE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "ENDED",
              "payloadSchema": [
                {
                  "name": "sessionId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "event": "FORKED",
              "payloadSchema": [
                {
                  "name": "sessionId",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "description": "Fired when AgentSession finishes loading; payload.data holds the sessions",
              "event": "AgentSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSession]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentSession fails to load",
              "event": "AgentSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a new session is persisted",
              "event": "AgentSessionSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when persisting a session fails",
              "event": "AgentSessionSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a session is updated",
              "event": "AgentSessionUpdated",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when updating a session fails",
              "event": "AgentSessionUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentSession",
          "listens": [
            {
              "event": "FORK",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionBrowse"
              },
              "triggers": "FORK"
            },
            {
              "event": "END",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionBrowse"
              },
              "triggers": "END"
            }
          ],
          "name": "AgentSessionAgent",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FORK",
                "name": "Fork",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "DO_LABEL",
                "name": "Do Label",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "END",
                "name": "End",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "ENDED",
                "name": "Ended",
                "payloadSchema": [
                  {
                    "name": "sessionId",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORKED",
                "name": "Forked",
                "payloadSchema": [
                  {
                    "name": "sessionId",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSession]"
                  }
                ]
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaved",
                "name": "AgentSession saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaveFailed",
                "name": "AgentSession save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "active"
              },
              {
                "name": "forked"
              },
              {
                "name": "ended"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Session is ready",
                      "icon": "git-branch",
                      "title": "Session",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "createdAt": "@now",
                      "parentId": "@payload.row.id",
                      "status": "forked"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "FORK",
                "from": "active",
                "to": "forked"
              },
              {
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ]
                ],
                "event": "DO_LABEL",
                "from": "active",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "END",
                "from": "active",
                "to": "ended"
              },
              {
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "createdAt": "@now",
                      "parentId": "@payload.row.id",
                      "status": "forked"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "FORK",
                "from": "forked",
                "to": "forked"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "END",
                "from": "forked",
                "to": "ended"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Session is ready",
                      "icon": "git-branch",
                      "title": "Session",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "ended",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "createdAt": "@now",
                      "parentId": "@payload.row.id",
                      "status": "forked"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "FORK",
                "from": "ended",
                "to": "forked"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ],
                "event": "END",
                "from": "ended",
                "to": "ended"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}