{
  "description": "std-agent-session as a Function",
  "name": "std-agent-session",
  "orbitals": [
    {
      "entity": {
        "collection": "agentsessions",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A user-defined identifier for the session.",
            "name": "name",
            "synonyms": "identifier, sessionName, title",
            "type": "string"
          },
          {
            "description": "A textual explanation of the session's purpose or content.",
            "name": "description",
            "synonyms": "summary, details, notes, explanation",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the session.",
            "name": "status",
            "synonyms": "state, condition, mode",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending",
              "forked",
              "ended"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "Unique identifier for a session.",
            "name": "sessionId",
            "synonyms": "session ID, session identifier",
            "type": "string"
          },
          {
            "default": "",
            "description": "Reference to the parent entity's identifier.",
            "name": "parentId",
            "synonyms": "parent, reference, source",
            "type": "string"
          },
          {
            "default": "",
            "description": "A user-friendly identifier for the session.",
            "name": "label",
            "synonyms": "title, identifier, display name",
            "type": "string"
          }
        ],
        "name": "AgentSession",
        "persistence": "persistent"
      },
      "name": "AgentSessionOrbital",
      "pages": [
        {
          "name": "AgentSessionPage",
          "path": "/agentsessions",
          "traits": [
            {
              "ref": "AgentSessionBrowse"
            },
            {
              "ref": "AgentSessionLabel"
            },
            {
              "ref": "AgentSessionAgent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "FORK",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "row",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "createdAt",
                      "type": "string"
                    },
                    {
                      "name": "sessionId",
                      "type": "string"
                    },
                    {
                      "name": "parentId",
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "event": "LABEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "row",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "createdAt",
                      "type": "string"
                    },
                    {
                      "name": "sessionId",
                      "type": "string"
                    },
                    {
                      "name": "parentId",
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "event": "END",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "row",
                  "properties": [
                    {
                      "name": "id",
                      "required": true,
                      "type": "string"
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "status",
                      "type": "string"
                    },
                    {
                      "name": "createdAt",
                      "type": "string"
                    },
                    {
                      "name": "sessionId",
                      "type": "string"
                    },
                    {
                      "name": "parentId",
                      "type": "string"
                    },
                    {
                      "name": "label",
                      "type": "string"
                    }
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "description": "Fired when AgentSession finishes loading; payload.data holds the sessions",
              "event": "AgentSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSession]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentSession fails to load",
              "event": "AgentSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a session is updated",
              "event": "AgentSessionUpdated",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when updating a session fails",
              "event": "AgentSessionUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a new session is persisted",
              "event": "AgentSessionSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when persisting a session fails",
              "event": "AgentSessionSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentSession",
          "listens": [
            {
              "event": "FORKED",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              },
              "triggers": "INIT"
            },
            {
              "event": "LABELED",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionLabel"
              },
              "triggers": "INIT"
            },
            {
              "event": "ENDED",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              },
              "triggers": "INIT"
            }
          ],
          "name": "AgentSessionBrowse",
          "scope": "collection",
          "stateMachine": {
