{
  "name": "std-agent-session",
  "version": "1.0.0",
  "description": "std-agent-session as a Function",
  "orbitals": [
    {
      "name": "AgentSessionOrbital",
      "entity": {
        "name": "AgentSession",
        "collection": "agentsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "description": "A user-defined identifier for the session.",
            "synonyms": "identifier, sessionName, title"
          },
          {
            "name": "description",
            "type": "string",
            "description": "A textual explanation of the session's purpose or content.",
            "synonyms": "summary, details, notes, explanation"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "forked",
              "ended"
            ],
            "description": "Current operational state of the session.",
            "synonyms": "state, condition, mode"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "sessionId",
            "type": "string",
            "default": "",
            "description": "Unique identifier for a session.",
            "synonyms": "session ID, session identifier"
          },
          {
            "name": "parentId",
            "type": "string",
            "default": "",
            "description": "Reference to the parent entity's identifier.",
            "synonyms": "parent, reference, source"
          },
          {
            "name": "label",
            "type": "string",
            "default": "",
            "description": "A user-friendly identifier for the session.",
            "synonyms": "title, identifier, display name"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentSessionBrowse",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "FORK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.sessionId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LABEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.sessionId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "END",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.sessionId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading; payload.data holds the sessions",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSession]"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdated",
              "description": "Fired when a session is updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdateFailed",
              "description": "Fired when updating a session fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaved",
              "description": "Fired when a new session is persisted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaveFailed",
              "description": "Fired when persisting a session fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "FORKED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            },
            {
              "event": "LABELED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionLabel"
              }
            },
            {
              "event": "ENDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSession]"
                  }
                ]
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORK",
                "name": "Fork"
              },
              {
                "key": "LABEL",
                "name": "Label"
              },
              {
                "key": "END",
                "name": "End"
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaved",
                "name": "AgentSession saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaveFailed",
                "name": "AgentSession save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading sessions…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AgentSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "terminal",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "AgentSession Manager",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "secondary",
                              "event": "FORK",
                              "icon": "git-branch",
                              "label": "Fork"
                            },
                            {
                              "icon": "tag",
                              "variant": "secondary",
                              "label": "Label",
                              "event": "LABEL"
                            },
                            {
                              "icon": "square",
                              "event": "END",
                              "label": "End",
                              "variant": "ghost"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Session ID",
                              "variant": "h4",
                              "name": "sessionId",
                              "icon": "terminal"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "label": "Label",
                              "variant": "caption",
                              "name": "label"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load sessions",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "label": "Retry"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "AgentSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "terminal"
                            },
                            {
                              "type": "typography",
                              "content": "AgentSession Manager",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "secondary",
                              "label": "Fork",
                              "event": "FORK",
                              "icon": "git-branch"
                            },
                            {
                              "event": "LABEL",
                              "variant": "secondary",
                              "icon": "tag",
                              "label": "Label"
                            },
                            {
                              "event": "END",
                              "variant": "ghost",
                              "icon": "square",
                              "label": "End"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Session ID",
                              "name": "sessionId",
                              "variant": "h4",
                              "icon": "terminal"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            },
                            {
                              "name": "label",
                              "variant": "caption",
                              "label": "Label"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "AgentSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to load sessions",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentSessionLabel",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "LABELED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading; payload.data holds the sessions",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSession]"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdated",
              "description": "Fired when a session is updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdateFailed",
              "description": "Fired when updating a session fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LABEL",
              "triggers": "LABEL",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LABEL",
                "name": "Label",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "LABELED",
                "name": "Labeled"
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSession]"
                  }
                ]
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "LABEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "tag"
                            },
                            {
                              "content": "Label Session",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "mode": "edit",
                          "entity": "@payload.row",
                          "type": "form-section",
                          "fields": [
                            "label"
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "LABELED",
                    {
                      "id": "@payload.data.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AgentSessionAgent",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "ENDED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "sessionId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FORKED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "sessionId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading; payload.data holds the sessions",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSession]"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaved",
              "description": "Fired when a new session is persisted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaveFailed",
              "description": "Fired when persisting a session fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdated",
              "description": "Fired when a session is updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdateFailed",
              "description": "Fired when updating a session fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "FORK",
              "triggers": "FORK",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionBrowse"
              }
            },
            {
              "event": "END",
              "triggers": "END",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "active",
                "isInitial": true
              },
              {
                "name": "forked"
              },
              {
                "name": "ended"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FORK",
                "name": "Fork",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "DO_LABEL",
                "name": "Do Label",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "END",
                "name": "End",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentSession"
                  }
                ]
              },
              {
                "key": "ENDED",
                "name": "Ended"
              },
              {
                "key": "FORKED",
                "name": "Forked"
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSession]"
                  }
                ]
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaved",
                "name": "AgentSession saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaveFailed",
                "name": "AgentSession save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "active",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "empty-state",
                      "title": "Session",
                      "icon": "git-branch",
                      "description": "Session is ready"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "createdAt": "@now",
                      "status": "forked",
                      "parentId": "@payload.row.id"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DO_LABEL",
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "parentId": "@payload.row.id",
                      "createdAt": "@now",
                      "status": "forked"
                    },
                    {
                      "emit": {
                        "success": "AgentSessionSaved",
                        "failure": "AgentSessionSaveFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "success": "AgentSessionUpdated",
                        "failure": "AgentSessionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Session",
                      "description": "Session is ready",
                      "icon": "git-branch",
                      "type": "empty-state"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "status": "forked",
                      "parentId": "@payload.row.id",
                      "createdAt": "@now"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "status": "ended",
                      "id": "@payload.row.id"
                    },
                    {
                      "emit": {
                        "success": "AgentSessionUpdated",
                        "failure": "AgentSessionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentSessionPage",
          "path": "/agentsessions",
          "traits": [
            {
              "ref": "AgentSessionBrowse"
            },
            {
              "ref": "AgentSessionLabel"
            },
            {
              "ref": "AgentSessionAgent"
            }
          ]
        }
      ]
    }
  ]
}
