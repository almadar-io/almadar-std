{
  "description": "std-agent-conversation as a Function",
  "name": "std-agent-conversation",
  "orbitals": [
    {
      "entity": {
        "collection": "agentconversations",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the conversation.",
            "name": "name",
            "synonyms": "title, label, identifier",
            "type": "string"
          },
          {
            "description": "A textual summary or explanation of the conversation.",
            "name": "description",
            "synonyms": "summary, explanation, details, overview",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the conversation.",
            "name": "status",
            "synonyms": "state, condition, mode",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending",
              "sent"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": [],
            "description": "An array of messages exchanged during the conversation.",
            "items": {
              "type": "string"
            },
            "name": "messages",
            "synonyms": "conversation history, chat log, message list",
            "type": "array"
          },
          {
            "default": 0.0,
            "description": "The number of turns in the conversation.",
            "name": "turnCount",
            "synonyms": "count, number, iterations",
            "type": "number"
          },
          {
            "default": "",
            "description": "The text of the most recent message.",
            "name": "lastMessage",
            "synonyms": "latest message, recent message, last text",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of tokens used in the conversation.",
            "name": "tokenCount",
            "synonyms": "count, length, size",
            "type": "number"
          },
          {
            "default": "user",
            "description": "Identifies the participant in the conversation.",
            "name": "role",
            "synonyms": "participant, speaker, actor, persona",
            "type": "string",
            "values": [
              "user",
              "assistant",
              "system",
              "tool"
            ]
          },
          {
            "default": "",
            "description": "The textual body of a message or response.",
            "name": "content",
            "synonyms": "text, body, payload, value",
            "type": "string"
          },
          {
            "default": "",
            "description": "The date and time when an event occurred.",
            "name": "timestamp",
            "synonyms": "date, time, when",
            "type": "string"
          },
          {
            "default": "",
            "description": "The name of the tool utilized in this conversation.",
            "name": "toolName",
            "synonyms": "tool, utility, application",
            "type": "string"
          }
        ],
        "name": "AgentConversation",
        "persistence": "persistent"
      },
      "name": "AgentConversationOrbital",
      "pages": [
        {
          "name": "AgentConversationPage",
          "path": "/agentconversations",
          "traits": [
            {
              "ref": "AgentConversationThread"
            },
            {
              "ref": "AgentConversationAgent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Fired when conversation finishes loading; payload.data holds the turns",
              "event": "AgentConversationLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentConversation]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when conversation fails to load",
              "event": "AgentConversationLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a new turn is persisted",
              "event": "AgentConversationSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when persisting a turn fails",
              "event": "AgentConversationSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when the conversation is cleared",
              "event": "AgentConversationDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when clearing the conversation fails",
              "event": "AgentConversationDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentConversation",
          "name": "AgentConversationThread",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentConversation]"
                  }
                ]
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL_COMPOSE",
                "name": "Cancel Compose"
              },
              {
                "key": "AgentConversationSaved",
                "name": "AgentConversation saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationSaveFailed",
                "name": "AgentConversation save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationDeleted",
                "name": "AgentConversation deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationDeleteFailed",
                "name": "AgentConversation delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "idle"
              },
              {
                "name": "composing"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading conversation…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Conversation Thread",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "action": "COMPOSE",
                              "icon": "plus",
                              "label": "New Message",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "label": "@item.status",
                                      "type": "badge",
                                      "variant": "secondary"
                                    },
                                    {
                                      "color": "muted",
                                      "content": "@item.timestamp",
                                      "type": "typography",
                                      "variant": "caption"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack"
                                },
                                {
                                  "content": "@item.content",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs",
                              "type": "stack"
                            }
                          ],
                          "type": "data-list"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentConversationLoaded",
                "from": "loading",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentConversationLoadFailed",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "message-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Conversation Thread",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CANCEL_COMPOSE",
                          "fields": [
                            "content"
                          ],
                          "mode": "create",
                          "submitEvent": "SEND",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "COMPOSE",
                "from": "idle",
                "to": "composing"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationDeleteFailed",
                        "success": "AgentConversationDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "CLEAR",
                "from": "idle",
                "to": "deleting"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentConversation",
                    {
                      "content": "@payload.content",
                      "role": "user",
                      "status": "sent",
                      "timestamp": "@now"
                    },
                    {
                      "emit": {
                        "failure": "AgentConversationSaveFailed",
                        "success": "AgentConversationSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "SEND",
                "from": "composing",
                "to": "persisting"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "CANCEL_COMPOSE",
                "from": "composing",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "AgentConversationSaved",
                "from": "persisting",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to send",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentConversationSaveFailed",
                "from": "persisting",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "AgentConversationDeleted",
                "from": "deleting",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to clear",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentConversationDeleteFailed",
                "from": "deleting",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "TOKEN_UPDATE",
              "payloadSchema": [
                {
                  "name": "tokenCount",
                  "required": true,
                  "type": "number"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when conversation finishes loading; payload.data holds the turns",
              "event": "AgentConversationLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentConversation]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when conversation fails to load",
              "event": "AgentConversationLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentConversation",
          "name": "AgentConversationAgent",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payloadSchema": [
                  {
                    "name": "content",
                    "required": true,
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update",
                "payloadSchema": [
                  {
                    "name": "tokenCount",
                    "required": true,
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentConversation]"
                  }
                ]
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Conversation is ready",
                      "icon": "message-circle",
                      "title": "Conversation",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE",
                    {
                      "tokenCount": 0.0
                    }
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "idle",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE",
                    {
                      "tokenCount": 0.0
                    }
                  ]
                ],
                "event": "SEND_MESSAGE",
                "from": "active",
                "to": "active"
              },
              {
                "event": "PAUSE",
                "from": "active",
                "to": "paused"
              },
              {
                "event": "CLEAR",
                "from": "active",
                "to": "idle"
              },
              {
                "event": "RESUME",
                "from": "paused",
                "to": "active"
              },
              {
                "event": "CLEAR",
                "from": "paused",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}