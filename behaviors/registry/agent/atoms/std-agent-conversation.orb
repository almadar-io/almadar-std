{
  "name": "std-agent-conversation",
  "version": "1.0.0",
  "description": "std-agent-conversation as a Function",
  "orbitals": [
    {
      "name": "AgentConversationOrbital",
      "entity": {
        "name": "AgentConversation",
        "collection": "agentconversations",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "sent"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "messages",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "turnCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "role",
            "type": "string",
            "default": "user",
            "values": [
              "user",
              "assistant",
              "system",
              "tool"
            ]
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentConversationThread",
          "category": "interaction",
          "linkedEntity": "AgentConversation",
          "emits": [
            {
              "event": "AgentConversationLoaded",
              "description": "Fired when conversation finishes loading; payload.data holds the turns",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentConversation]"
                }
              ]
            },
            {
              "event": "AgentConversationLoadFailed",
              "description": "Fired when conversation fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationSaved",
              "description": "Fired when a new turn is persisted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationSaveFailed",
              "description": "Fired when persisting a turn fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationDeleted",
              "description": "Fired when the conversation is cleared",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationDeleteFailed",
              "description": "Fired when clearing the conversation fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "composing"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentConversation]"
                  }
                ]
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_COMPOSE",
                "name": "Cancel Compose"
              },
              {
                "key": "AgentConversationSaved",
                "name": "AgentConversation saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationSaveFailed",
                "name": "AgentConversation save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationDeleted",
                "name": "AgentConversation deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentConversationDeleteFailed",
                "name": "AgentConversation delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading conversation…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "AgentConversationLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Conversation Thread"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "variant": "primary",
                              "action": "COMPOSE",
                              "icon": "plus",
                              "label": "New Message",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "gap": "sm",
                                  "align": "center",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "label": "@item.status",
                                      "variant": "secondary",
                                      "type": "badge"
                                    },
                                    {
                                      "variant": "caption",
                                      "color": "muted",
                                      "type": "typography",
                                      "content": "@item.timestamp"
                                    }
                                  ],
                                  "direction": "horizontal"
                                },
                                {
                                  "content": "@item.content",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentConversationLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to load",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "Conversation Thread",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "content"
                          ],
                          "cancelEvent": "CANCEL_COMPOSE",
                          "mode": "create",
                          "type": "form-section",
                          "submitEvent": "SEND"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "deleting",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationDeleteFailed",
                        "success": "AgentConversationDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "persisting",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentConversation",
                    {
                      "role": "user",
                      "content": "@payload.content",
                      "status": "sent",
                      "timestamp": "@now"
                    },
                    {
                      "emit": {
                        "failure": "AgentConversationSaveFailed",
                        "success": "AgentConversationSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "loading",
                "event": "CANCEL_COMPOSE",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "loading",
                "event": "AgentConversationSaved",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AgentConversationSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to send",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "loading",
                "event": "AgentConversationDeleted",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "error",
                "event": "AgentConversationDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to clear",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentConversationAgent",
          "category": "interaction",
          "linkedEntity": "AgentConversation",
          "emits": [
            {
              "event": "TOKEN_UPDATE",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "tokenCount",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "AgentConversationLoaded",
              "description": "Fired when conversation finishes loading; payload.data holds the turns",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentConversation]"
                }
              ]
            },
            {
              "event": "AgentConversationLoadFailed",
              "description": "Fired when conversation fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update",
                "payloadSchema": [
                  {
                    "name": "tokenCount",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentConversation]"
                  }
                ]
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "message-circle",
                      "type": "empty-state",
                      "description": "Conversation is ready",
                      "title": "Conversation"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE",
                    {
                      "tokenCount": 0.0
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE",
                    {
                      "tokenCount": 0.0
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "paused",
                "event": "PAUSE"
              },
              {
                "from": "active",
                "to": "idle",
                "event": "CLEAR"
              },
              {
                "from": "paused",
                "to": "active",
                "event": "RESUME"
              },
              {
                "from": "paused",
                "to": "idle",
                "event": "CLEAR"
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentConversationPage",
          "path": "/agentconversations",
          "traits": [
            {
              "ref": "AgentConversationThread"
            },
            {
              "ref": "AgentConversationAgent"
            }
          ]
        }
      ]
    }
  ]
}