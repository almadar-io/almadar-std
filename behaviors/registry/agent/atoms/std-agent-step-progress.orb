                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "action": "START",
                          "icon": "play",
                          "label": "Start",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESET",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    [
