                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "message": "Pipeline failed at the current step.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "label": "Failed At Step",
                              "type": "stat-display",
                              "value": "@entity.currentStep"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "FAIL",
                "from": "in_progress",
                "to": "failed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
