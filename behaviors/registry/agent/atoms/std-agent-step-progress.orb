                          "type": "wizard-progress"
                        },
                        {
                          "message": "All steps completed successfully.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "type": "button",
                          "variant": "ghost"
