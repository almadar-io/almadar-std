{
  "description": "std-agent-step-progress as a Function",
  "name": "std-agent-step-progress",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A descriptive label for the progress step.",
            "name": "name",
            "synonyms": "label, title, identifier",
            "type": "string"
          },
          {
            "description": "A textual explanation of the step's purpose or details.",
            "name": "description",
            "synonyms": "details, explanation, notes, summary",
            "type": "string"
          },
          {
            "default": "idle",
            "description": "Indicates the current operational state of the process.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "idle",
              "in_progress",
              "completed",
              "failed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The numerical value representing the current step.",
            "name": "currentStep",
            "synonyms": "step, progress, count",
            "type": "number"
          },
          {
            "default": 4.0,
            "description": "The total number of steps in the process.",
            "name": "totalSteps",
            "synonyms": "count, size, length, quantity",
            "type": "number"
          }
        ],
        "name": "AgentStepProgress",
        "persistence": "runtime"
      },
      "name": "AgentStepProgressOrbital",
      "pages": [
        {
          "name": "AgentStepProgressPage",
          "path": "/agentstepprogresss",
          "traits": [
            {
              "ref": "AgentStepProgressProgress"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Fired when AgentStepProgress finishes loading",
              "event": "AgentStepProgressLoaded",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentStepProgress fails to load",
              "event": "AgentStepProgressLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "entityContract": {
            "provides": [
              "currentStep",
              "status",
              "totalSteps"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AgentStepProgress",
          "name": "AgentStepProgressProgress",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ADVANCE",
                "name": "Advance"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAIL",
                "name": "Fail"
              },
              {
                "key": "AgentStepProgressLoaded",
                "name": "AgentStepProgress loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentStepProgressLoadFailed",
                "name": "AgentStepProgress load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "in_progress"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.totalSteps",
                    4.0
                  ],
                  [
                    "fetch",
                    "AgentStepProgress",
                    {
                      "emit": {
                        "failure": "AgentStepProgressLoadFailed",
                        "success": "AgentStepProgressLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "list-ordered",
                              "type": "icon"
                            },
                            {
                              "content": "AgentStepProgress",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "label": "Idle",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "action": "START",
                          "icon": "play",
                          "label": "Start",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "in_progress"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "content": "AgentStepProgress",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "label": "In Progress",
                              "type": "badge",
                              "variant": "warning"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "label": "Current Step",
                              "type": "stat-display",
                              "value": "@entity.currentStep"
                            },
                            {
                              "label": "Total Steps",
                              "type": "stat-display",
                              "value": "@entity.totalSteps"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "action": "ADVANCE",
                              "icon": "chevron-right",
                              "label": "Advance",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "action": "RESET",
                              "icon": "rotate-ccw",
                              "label": "Reset",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "START",
                "from": "idle",
                "to": "in_progress"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
