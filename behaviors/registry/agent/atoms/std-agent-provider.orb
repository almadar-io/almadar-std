                          "type": "alert",
                          "variant": "warning"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "SHOW",
                "from": "visible",
                "to": "visible"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ],
                "event": "HIDE",
                "from": "visible",
                "to": "hidden"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SHOW",
              "payloadSchema": [
                {
                  "name": "message",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentProvider finishes loading",
              "event": "AgentProviderLoaded",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentProvider",
                  "type": "string"
                },
                {
                  "name": "currentModel",
                  "type": "string"
                },
                {
                  "name": "fallbackProvider",
                  "type": "string"
                },
                {
                  "name": "requestCount",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentProvider fails to load",
              "event": "AgentProviderLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "linkedEntity": "AgentProvider",
          "listens": [
            {
              "event": "SWITCHED",
              "source": {
                "kind": "trait",
                "trait": "AgentProviderModal"
              },
              "triggers": "SWITCHED"
            }
          ],
          "name": "AgentProviderAgent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_SWITCH",
                "name": "Do Switch",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ]
              },
              {
                "key": "SWITCHED",
                "name": "Switched"
              },
              {
                "key": "SWITCH_AUTO",
                "name": "Switch Auto"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payloadSchema": [
                  {
                    "name": "message",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderLoaded",
                "name": "AgentProvider loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentProvider",
                    "type": "string"
                  },
                  {
                    "name": "currentModel",
                    "type": "string"
                  },
                  {
                    "name": "fallbackProvider",
                    "type": "string"
                  },
                  {
                    "name": "requestCount",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderLoadFailed",
                "name": "AgentProvider load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "active"
              },
              {
                "name": "switching"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.fallbackProvider",
                    "openai"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Provider is ready",
                      "icon": "repeat",
                      "title": "Provider",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "active"
              },
              {
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ],
                "event": "DO_SWITCH",
                "from": "idle",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ],
                "event": "DO_SWITCH",
                "from": "active",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.currentProvider",
                    "@entity.currentModel"
                  ]
                ],
                "event": "SWITCHED",
                "from": "active",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.fallbackProvider"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@entity.fallbackProvider"
                  ]
                ],
                "event": "SWITCH_AUTO",
                "from": "active",
                "to": "switching"
              },
              {
                "effects": [
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "set",
                    "@entity.requestCount",
                    [
                      "+",
                      "@entity.requestCount",
                      1.0
                    ]
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "message": "Provider switched",
                      "notificationType": "info"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "switching",
                "to": "active"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}