{
  "description": "std-agent-provider as a Function",
  "name": "std-agent-provider",
  "orbitals": [
    {
      "entity": {
        "collection": "agentproviders",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the agent provider.",
            "name": "name",
            "synonyms": "label, identifier, designation",
            "type": "string"
          },
          {
            "description": "A textual explanation of the agent provider's function.",
            "name": "description",
            "synonyms": "explanation, details, notes",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the operational state of the agent provider.",
            "name": "status",
            "synonyms": "state, condition, operationalStatus",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "anthropic",
            "description": "The currently active provider implementation.",
            "name": "currentProvider",
            "synonyms": "implementation, active, provider",
            "type": "string"
          },
          {
            "default": "claude-sonnet-4-20250514",
            "description": "The currently active model identifier.",
            "name": "currentModel",
            "synonyms": "model, identifier, selection",
            "type": "string"
          },
          {
            "default": "openai",
            "description": "An alternative provider to use when the primary fails.",
            "name": "fallbackProvider",
            "synonyms": "alternate, backup, secondary",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of times a request has been made.",
            "name": "requestCount",
            "synonyms": "count, requests, usage",
            "type": "number"
          },
          {
            "default": "",
            "description": "A textual message associated with the agent provider.",
            "name": "message",
            "synonyms": "text, content, details, note",
            "type": "string"
          },
          {
            "default": "info",
            "description": "Specifies the type of notification.",
            "name": "notificationType",
            "synonyms": "type, category, level",
            "type": "string",
            "values": [
              "info",
              "success",
              "warning",
              "error"
            ]
          }
        ],
        "name": "AgentProvider",
        "persistence": "persistent"
      },
      "name": "AgentProviderOrbital",
      "pages": [
        {
          "name": "AgentProviderPage",
          "path": "/agentproviders",
          "traits": [
            {
              "ref": "AgentProviderModal"
            },
            {
              "ref": "AgentProviderNotification"
            },
            {
              "ref": "AgentProviderAgent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "event": "SWITCHED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external"
            },
            {
              "description": "Fired when AgentProvider finishes loading",
              "event": "AgentProviderLoaded",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentProvider",
                  "type": "string"
                },
                {
                  "name": "currentModel",
                  "type": "string"
                },
                {
                  "name": "fallbackProvider",
                  "type": "string"
                },
                {
                  "name": "requestCount",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when AgentProvider fails to load",
              "event": "AgentProviderLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired on modal open with the pre-fill row",
              "event": "AgentProviderRowLoaded",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "AgentProvider"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "AgentProviderUpdated",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "event": "AgentProviderUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "entityContract": {
            "provides": [
              "currentModel",
              "currentProvider"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AgentProvider",
          "name": "AgentProviderModal",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SWITCH",
                "name": "Switch"
              },
              {
                "key": "AgentProviderRowLoaded",
                "name": "AgentProvider row loaded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "AgentProvider"
                  }
                ]
              },
              {
                "key": "AgentProviderLoadFailed",
                "name": "AgentProvider load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ]
              },
              {
                "key": "SWITCHED",
                "name": "Switched",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderLoaded",
                "name": "AgentProvider loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentProvider",
                    "type": "string"
                  },
                  {
                    "name": "currentModel",
                    "type": "string"
                  },
                  {
                    "name": "fallbackProvider",
                    "type": "string"
                  },
                  {
                    "name": "requestCount",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderUpdated",
                "name": "AgentProvider updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderUpdateFailed",
                "name": "AgentProvider update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "loading"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "set",
                    "@entity.currentModel",
                    "claude-sonnet-4-20250514"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "anthropic"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "action": "SWITCH",
                              "icon": "repeat",
                              "label": "Open",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderRowLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "SWITCH",
                "from": "closed",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "content": "Switch Provider",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "content": "Current:",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "label": "@entity.currentProvider",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.currentModel",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "entity": "@payload.row",
                          "fields": [
                            "currentProvider",
                            "currentModel"
                          ],
                          "mode": "edit",
                          "submitEvent": "SAVE",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentProviderRowLoaded",
                "from": "loading",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Failed to load provider",
                    "error"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "action": "SWITCH",
                              "icon": "repeat",
                              "label": "Open",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentProviderLoadFailed",
                "from": "loading",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "action": "SWITCH",
                              "icon": "repeat",
                              "label": "Open",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentProvider",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentProviderUpdateFailed",
                        "success": "AgentProviderUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SWITCHED"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "action": "SWITCH",
                              "icon": "repeat",
                              "label": "Open",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "SAVE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        },
