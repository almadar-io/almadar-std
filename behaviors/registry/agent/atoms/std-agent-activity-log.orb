{
  "description": "std-agent-activity-log as a Function",
  "name": "std-agent-activity-log",
  "orbitals": [
    {
      "entity": {
        "collection": "agentactivitylogs",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A short identifier or label for the activity.",
            "name": "name",
            "synonyms": "label, identifier, title",
            "type": "string"
          },
          {
            "description": "A textual explanation of the activity.",
            "name": "description",
            "synonyms": "explanation, note, summary, remarks",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Current operational state of the activity.",
            "name": "status",
            "synonyms": "state, condition, operational_status",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "description": "The event or operation that occurred.",
            "name": "action",
            "synonyms": "event, operation, type, task",
            "type": "string"
          },
          {
            "default": "",
            "description": "Provides additional information about the activity.",
            "name": "detail",
            "synonyms": "notes, specifics, particulars, details",
            "type": "string"
          },
          {
            "default": "",
            "description": "The date and time when the event occurred.",
            "name": "timestamp",
            "synonyms": "date, time, when",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The length of time an activity took to complete.",
            "name": "duration",
            "synonyms": "time, length, elapsed",
            "type": "number"
          },
          {
            "default": "circle",
            "description": "A visual representation, often a symbol or image.",
            "name": "icon",
            "synonyms": "image, symbol, graphic, representation",
            "type": "string"
          }
        ],
        "name": "AgentActivityLog",
        "persistence": "persistent"
      },
      "name": "AgentActivityLogOrbital",
      "pages": [
        {
          "name": "AgentActivityLogPage",
          "path": "/agentactivitylogs",
          "traits": [
            {
              "ref": "AgentActivityLogLog"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Fired when the AgentActivityLog collection finishes loading; payload.data holds the list",
              "event": "AgentActivityLogLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentActivityLog]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when the AgentActivityLog collection fails to load",
              "event": "AgentActivityLogLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a LOG_ENTRY persist succeeds",
              "event": "AgentActivityLogSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when a LOG_ENTRY persist fails",
              "event": "AgentActivityLogSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when CLEAR deletes activity log rows",
              "event": "AgentActivityLogDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Fired when CLEAR fails to delete",
              "event": "AgentActivityLogDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AgentActivityLog",
          "name": "AgentActivityLogLog",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentActivityLogLoaded",
                "name": "AgentActivityLog loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentActivityLog]"
                  }
                ]
              },
              {
                "key": "AgentActivityLogLoadFailed",
                "name": "AgentActivityLog load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry",
                "payloadSchema": [
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "AgentActivityLogSaved",
                "name": "AgentActivityLog saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogSaveFailed",
                "name": "AgentActivityLog save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleted",
                "name": "AgentActivityLog deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleteFailed",
                "name": "AgentActivityLog delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "logging"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading activity log…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon"
                                },
                                {
                                  "content": "Activity Log",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "action": "CLEAR",
                              "icon": "trash",
                              "label": "Clear",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [],
                          "type": "timeline"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentActivityLogLoaded",
                "from": "loading",
                "to": "logging"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load activity log",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentActivityLogLoadFailed",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentActivityLog",
                    {
                      "action": "@payload.action",
                      "detail": "@payload.detail",
                      "status": "@payload.status",
                      "timestamp": "@now"
                    },
                    {
                      "emit": {
                        "failure": "AgentActivityLogSaveFailed",
                        "success": "AgentActivityLogSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Recording entry…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "LOG_ENTRY",
                "from": "logging",
                "to": "persisting"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogDeleteFailed",
                        "success": "AgentActivityLogDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Clearing activity log…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CLEAR",
                "from": "logging",
                "to": "deleting"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "AgentActivityLogSaved",
                "from": "persisting",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to record entry",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentActivityLogSaveFailed",
                "from": "persisting",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "AgentActivityLogDeleted",
                "from": "deleting",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to clear activity log",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AgentActivityLogDeleteFailed",
                "from": "deleting",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}