{
  "name": "std-agent-activity-log",
  "version": "1.0.0",
  "description": "std-agent-activity-log as a Function",
  "orbitals": [
    {
      "name": "AgentActivityLogOrbital",
      "entity": {
        "name": "AgentActivityLog",
        "collection": "agentactivitylogs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentActivityLogLog",
          "category": "interaction",
          "linkedEntity": "AgentActivityLog",
          "emits": [
            {
              "event": "AgentActivityLogLoaded",
              "description": "Fired when the AgentActivityLog collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentActivityLog]"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoadFailed",
              "description": "Fired when the AgentActivityLog collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaved",
              "description": "Fired when a LOG_ENTRY persist succeeds",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaveFailed",
              "description": "Fired when a LOG_ENTRY persist fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleted",
              "description": "Fired when CLEAR deletes activity log rows",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleteFailed",
              "description": "Fired when CLEAR fails to delete",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "logging"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentActivityLogLoaded",
                "name": "AgentActivityLog loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentActivityLog]"
                  }
                ]
              },
              {
                "key": "AgentActivityLogLoadFailed",
                "name": "AgentActivityLog load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry",
                "payloadSchema": [
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "AgentActivityLogSaved",
                "name": "AgentActivityLog saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogSaveFailed",
                "name": "AgentActivityLog save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleted",
                "name": "AgentActivityLog deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleteFailed",
                "name": "AgentActivityLog delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading activity log…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "logging",
                "event": "AgentActivityLogLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Activity Log",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "icon": "trash",
                              "label": "Clear",
                              "action": "CLEAR",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "type": "timeline",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentActivityLogLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load activity log"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "action": "INIT"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "persisting",
                "event": "LOG_ENTRY",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentActivityLog",
                    {
                      "action": "@payload.action",
                      "detail": "@payload.detail",
                      "timestamp": "@now",
                      "status": "@payload.status"
                    },
                    {
                      "emit": {
                        "failure": "AgentActivityLogSaveFailed",
                        "success": "AgentActivityLogSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Recording entry…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "deleting",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogDeleted",
                        "failure": "AgentActivityLogDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Clearing activity log…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "loading",
                "event": "AgentActivityLogSaved",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AgentActivityLogSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to record entry",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "loading",
                "event": "AgentActivityLogDeleted",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "error",
                "event": "AgentActivityLogDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to clear activity log",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "action": "INIT"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentActivityLogPage",
          "path": "/agentactivitylogs",
          "traits": [
            {
              "ref": "AgentActivityLogLog"
            }
          ]
        }
      ]
    }
  ]
}