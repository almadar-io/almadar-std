{
  "name": "std-agent-token-gauge",
  "version": "1.0.0",
  "description": "std-agent-token-gauge as a Function",
  "orbitals": [
    {
      "name": "AgentTokenGaugeOrbital",
      "entity": {
        "name": "AgentTokenGauge",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "current",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "max",
            "type": "number",
            "default": 180000.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.85
          },
          {
            "name": "lastCompactedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentTokenGaugeGauge",
          "category": "interaction",
          "linkedEntity": "AgentTokenGauge",
          "emits": [
            {
              "event": "AgentTokenGaugeLoaded",
              "description": "Fired when AgentTokenGauge finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentTokenGaugeLoadFailed",
              "description": "Fired when AgentTokenGauge fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
              },
              {
                "name": "warning"
              },
              {
                "name": "critical"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "current",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "AgentTokenGaugeLoaded",
                "name": "AgentTokenGauge loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentTokenGaugeLoadFailed",
                "name": "AgentTokenGauge load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.max",
                    180000.0
                  ],
                  [
                    "fetch",
                    "AgentTokenGauge",
                    {
                      "emit": {
                        "success": "AgentTokenGaugeLoaded",
                        "failure": "AgentTokenGaugeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "gauge",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Token Usage"
                            },
                            {
                              "label": "Normal",
                              "variant": "default",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.current",
                          "max": "@entity.max"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "value": "@entity.current",
                              "type": "stat-display",
                              "label": "Tokens Used"
                            },
                            {
                              "value": "@entity.max",
                              "label": "Max Tokens",
                              "type": "stat-display"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "label": "Reset",
                          "icon": "rotate-ccw",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "normal",
                "event": "UPDATE",
                "guard": [
                  "<",
                  [
                    "/",
                    "@payload.current",
                    "@entity.max"
                  ],
                  0.85
                ],
                "effects": [
