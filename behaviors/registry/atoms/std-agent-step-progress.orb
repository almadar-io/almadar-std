{
  "name": "std-agent-step-progress",
  "version": "1.0.0",
  "description": "std-agent-step-progress as a Function",
  "orbitals": [
    {
      "name": "AgentStepProgressOrbital",
      "entity": {
        "name": "AgentStepProgress",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4.0
          }
        ]
      },
      "traits": [
        {
          "name": "AgentStepProgressProgress",
          "category": "interaction",
          "linkedEntity": "AgentStepProgress",
          "emits": [
            {
              "event": "AgentStepProgressLoaded",
              "description": "Fired when AgentStepProgress finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentStepProgressLoadFailed",
              "description": "Fired when AgentStepProgress fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "in_progress"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ADVANCE",
                "name": "Advance"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAIL",
                "name": "Fail"
              },
              {
                "key": "AgentStepProgressLoaded",
                "name": "AgentStepProgress loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentStepProgressLoadFailed",
                "name": "AgentStepProgress load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentStepProgress",
                    {
                      "emit": {
                        "failure": "AgentStepProgressLoadFailed",
                        "success": "AgentStepProgressLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "list-ordered",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "AgentStepProgress"
                            },
                            {
                              "type": "badge",
                              "label": "Idle",
                              "variant": "default"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "title": "Validate",
                              "id": "2"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ]
                        },
                        {
                          "action": "START",
                          "variant": "primary",
                          "icon": "play",
                          "label": "Start",
                          "type": "button"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "in_progress",
                "event": "START",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "in_progress"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "AgentStepProgress",
                              "variant": "h2"
                            },
                            {
                              "label": "In Progress",
                              "variant": "warning",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "title": "Validate",
                              "id": "2"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep"
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "value": "@entity.currentStep",
                              "label": "Current Step",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.totalSteps",
                              "label": "Total Steps",
                              "type": "stat-display"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "action": "ADVANCE",
                              "icon": "chevron-right",
                              "type": "button",
                              "variant": "primary",
                              "label": "Advance"
                            },
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "action": "RESET",
                              "variant": "ghost",
                              "label": "Reset"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-ordered"
                            },
                            {
                              "type": "typography",
                              "content": "AgentStepProgress",
                              "variant": "h2"
                            },
                            {
                              "label": "Idle",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "title": "Process",
                              "id": "1"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "title": "Complete",
                              "id": "3"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "icon": "play",
                          "variant": "primary",
                          "action": "START",
                          "type": "button",
                          "label": "Start"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "in_progress",
                "to": "in_progress",
                "event": "ADVANCE",
                "guard": [
                  "<",
                  "@entity.currentStep",
                  "@entity.totalSteps"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    [
                      "+",
                      "@entity.currentStep",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "content": "AgentStepProgress",
                              "variant": "h2",
                              "type": "typography"
                            },
                            {
                              "label": "In Progress",
                              "type": "badge",
                              "variant": "warning"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Initialize"
                            },
                            {
                              "title": "Process",
                              "id": "1"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "title": "Complete",
                              "id": "3"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Current Step",
                              "value": "@entity.currentStep"
                            },
                            {
                              "label": "Total Steps",
                              "type": "stat-display",
                              "value": "@entity.totalSteps"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "action": "ADVANCE",
                              "type": "button",
                              "variant": "primary",
                              "icon": "chevron-right",
                              "label": "Advance"
                            },
                            {
                              "label": "Reset",
                              "type": "button",
                              "action": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "in_progress",
                "to": "completed",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    "@entity.totalSteps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "AgentStepProgress"
                            },
                            {
                              "label": "Completed",
                              "type": "badge",
                              "variant": "success"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "steps": [
                            {
                              "title": "Initialize",
                              "id": "0"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "title": "Validate",
                              "id": "2"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress",
                          "currentStep": "@entity.totalSteps"
                        },
                        {
                          "message": "All steps completed successfully.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "action": "RESET"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "in_progress",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "x-circle"
                            },
                            {
                              "variant": "h2",
                              "content": "AgentStepProgress",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "variant": "danger",
                              "label": "Failed"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "title": "Initialize",
                              "id": "0"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "alert",
                          "message": "Pipeline failed at the current step.",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "label": "Failed At Step",
                              "value": "@entity.currentStep",
                              "type": "stat-display"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "variant": "ghost",
                          "type": "button",
                          "action": "RESET"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "in_progress",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-ordered"
                            },
                            {
                              "content": "AgentStepProgress",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "Idle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "currentStep": "@entity.currentStep",
                          "type": "wizard-progress",
                          "steps": [
                            {
                              "title": "Initialize",
                              "id": "0"
                            },
                            {
                              "id": "1",
                              "title": "Process"
                            },
                            {
                              "id": "2",
                              "title": "Validate"
                            },
                            {
                              "id": "3",
                              "title": "Complete"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Start",
                          "action": "START",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-ordered"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "AgentStepProgress"
                            },
                            {
                              "variant": "default",
                              "label": "Idle",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "title": "Initialize",
                              "id": "0"
                            },
                            {
                              "title": "Process",
                              "id": "1"
                            },
                            {
                              "title": "Validate",
                              "id": "2"
                            },
                            {
                              "title": "Complete",
                              "id": "3"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "icon": "play",
                          "action": "START",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "failed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
