{
  "name": "std-theme",
  "version": "1.0.0",
  "description": "std-theme as a Function",
  "orbitals": [
    {
      "name": "ThemePreferenceOrbital",
      "entity": {
        "name": "ThemePreference",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "mode",
            "type": "string",
            "default": "light"
          },
          {
            "name": "colorScheme",
            "type": "string",
            "default": "default"
          }
        ]
      },
      "traits": [
        {
          "name": "ThemePreferenceTheme",
          "category": "interaction",
          "linkedEntity": "ThemePreference",
          "emits": [
            {
              "event": "ThemePreferenceLoaded",
              "description": "Fired when ThemePreference finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "mode",
                  "type": "string"
                },
                {
                  "name": "colorScheme",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ThemePreferenceLoadFailed",
              "description": "Fired when ThemePreference fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TOGGLE",
                "name": "Toggle"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "payload": [
                  {
                    "name": "theme",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ThemePreferenceLoaded",
                "name": "ThemePreference loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "mode",
                    "type": "string"
                  },
                  {
                    "name": "colorScheme",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ThemePreferenceLoadFailed",
                "name": "ThemePreference load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ThemePreference",
                    {
                      "emit": {
                        "success": "ThemePreferenceLoaded",
                        "failure": "ThemePreferenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "palette"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Theme Settings"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "Quick Toggle"
                                },
                                {
                                  "content": "Switch between light and dark mode",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "theme-toggle"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Theme Palette",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "type": "typography",
                                  "content": "Choose from available color schemes",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "cols": 3.0,
                                  "type": "simple-grid",
                                  "children": [
                                    {
                                      "variant": "secondary",
                                      "type": "button",
                                      "action": "SELECT",
                                      "label": "Almadar"
                                    },
                                    {
                                      "label": "Ocean",
                                      "type": "button",
                                      "variant": "secondary",
                                      "action": "SELECT"
                                    },
                                    {
                                      "label": "Forest",
                                      "type": "button",
                                      "variant": "secondary",
                                      "action": "SELECT"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "content": "Current mode:",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "mode"
                              ],
                              "type": "badge"
                            },
                            {
                              "content": "Scheme:",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "colorScheme"
                              ],
                              "type": "badge"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TOGGLE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "palette"
                            },
                            {
                              "type": "typography",
                              "content": "Theme Settings",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "h4",
                                  "content": "Quick Toggle",
                                  "type": "typography"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Switch between light and dark mode"
                                },
                                {
                                  "type": "theme-toggle"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "Theme Palette"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Choose from available color schemes"
                                },
                                {
                                  "cols": 3.0,
                                  "type": "simple-grid",
                                  "children": [
                                    {
                                      "label": "Almadar",
                                      "type": "button",
                                      "action": "SELECT",
                                      "variant": "secondary"
                                    },
                                    {
                                      "label": "Ocean",
                                      "action": "SELECT",
                                      "type": "button",
                                      "variant": "secondary"
                                    },
                                    {
                                      "variant": "secondary",
                                      "type": "button",
                                      "label": "Forest",
                                      "action": "SELECT"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "content": "Current mode:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "mode"
                              ]
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Scheme:"
                            },
                            {
                              "type": "badge",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "colorScheme"
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT",
                "effects": [
                  [
                    "set",
                    "@entity.colorScheme",
                    "@payload.theme"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "palette"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Theme Settings"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Quick Toggle",
                                  "variant": "h4",
                                  "type": "typography"
                                },
                                {
                                  "content": "Switch between light and dark mode",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "theme-toggle"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "Theme Palette"
                                },
                                {
                                  "content": "Choose from available color schemes",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "simple-grid",
                                  "cols": 3.0,
                                  "children": [
                                    {
                                      "label": "Almadar",
                                      "action": "SELECT",
                                      "type": "button",
                                      "variant": "secondary"
                                    },
                                    {
                                      "action": "SELECT",
                                      "type": "button",
                                      "variant": "secondary",
                                      "label": "Ocean"
                                    },
                                    {
                                      "type": "button",
                                      "action": "SELECT",
                                      "label": "Forest",
                                      "variant": "secondary"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "content": "Current mode:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "mode"
                              ]
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Scheme:"
                            },
                            {
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "colorScheme"
                              ],
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ThemePreferenceThemePage",
          "path": "/themepreferences/theme",
          "traits": [
            {
              "ref": "ThemePreferenceTheme"
            }
          ]
        }
      ]
    }
  ]
}