{
  "name": "std-tabs",
  "version": "1.0.0",
  "description": "std-tabs as a Function",
  "orbitals": [
    {
      "name": "TabContentOrbital",
      "entity": {
        "name": "TabContent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TabContentTabs",
          "category": "interaction",
          "linkedEntity": "TabContent",
          "emits": [
            {
              "event": "TabContentLoaded",
              "description": "Fired when TabContent finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TabContentLoadFailed",
              "description": "Fired when TabContent fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_TAB",
                "name": "Select Tab",
                "payload": [
                  {
                    "name": "tab",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TabContentLoaded",
                "name": "TabContent loaded"
              },
              {
                "key": "TabContentLoadFailed",
                "name": "TabContent load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TabContent",
                    {
                      "emit": {
                        "success": "TabContentLoaded",
                        "failure": "TabContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "layout-grid",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "TabContents"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "onTabChange": "SELECT_TAB",
                          "tabs": [
                            {
                              "value": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "value": "description"
                            },
                            {
                              "label": "Status",
                              "value": "status"
                            },
                            {
                              "value": "createdAt",
                              "label": "CreatedAt"
                            }
                          ],
                          "type": "tabs",
                          "defaultActiveTab": "name"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "TabContent",
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyTitle": "No tabcontents yet",
                          "emptyDescription": "Add tabcontents to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "content": "@item.name",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "content": "@item.name",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_TAB",
                "effects": [
                  [
                    "fetch",
                    "TabContent",
                    {
                      "emit": {
                        "success": "TabContentLoaded",
                        "failure": "TabContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layout-grid",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "TabContents",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "tabs": [
                            {
                              "value": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "value": "description"
                            },
                            {
                              "label": "Status",
                              "value": "status"
                            },
                            {
                              "label": "CreatedAt",
                              "value": "createdAt"
                            }
                          ],
                          "type": "tabs",
                          "activeTab": "@payload.tab",
                          "onTabChange": "SELECT_TAB",
                          "defaultActiveTab": "name"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "emptyTitle": "No tabcontents yet",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@item.name"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "@item.name"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "entity": "TabContent",
                          "emptyDescription": "Add tabcontents to see them here.",
                          "emptyIcon": "inbox"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TabContentTabsPage",
          "path": "/tabcontents",
          "traits": [
            {
              "ref": "TabContentTabs"
            }
          ]
        }
      ]
    }
  ]
}