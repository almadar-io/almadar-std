{
  "name": "std-gallery",
  "version": "1.0.0",
  "description": "std-gallery as a Function",
  "orbitals": [
    {
      "name": "GalleryItemOrbital",
      "entity": {
        "name": "GalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string",
            "default": "https://picsum.photos/seed/gallery/800/600"
          }
        ]
      },
      "traits": [
        {
          "name": "GalleryItemGallery",
          "category": "interaction",
          "linkedEntity": "GalleryItem",
          "emits": [
            {
              "event": "GalleryItemLoaded",
              "description": "Fired when GalleryItem finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "imageUrl",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GalleryItemLoadFailed",
              "description": "Fired when GalleryItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "viewing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "GalleryItemLoaded",
                "name": "GalleryItem loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "imageUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GalleryItemLoadFailed",
                "name": "GalleryItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "image",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "GalleryItems Gallery"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Click any image to view full size",
                              "color": "muted"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "imageField": "imageUrl",
                          "gap": "md",
                          "itemActions": [
                            {
                              "label": "View",
                              "icon": "maximize",
                              "event": "VIEW"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "h4",
                              "label": "Title",
                              "name": "name"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "type": "data-grid",
                          "cols": 3.0,
                          "entity": "@entity"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "closeAction": "CLOSE",
                      "isOpen": true,
                      "type": "lightbox",
                      "images": [
                        {
                          "alt": "Mountain landscape",
                          "caption": "Mountain landscape",
                          "src": "https://picsum.photos/seed/gallery1/800/600"
                        },
                        {
                          "caption": "Ocean sunset",
                          "alt": "Ocean sunset",
                          "src": "https://picsum.photos/seed/gallery2/800/600"
                        },
                        {
                          "src": "https://picsum.photos/seed/gallery3/800/600",
                          "alt": "Forest trail",
                          "caption": "Forest trail"
                        }
                      ],
                      "currentIndex": 0.0,
                      "showCounter": true
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "image",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "GalleryItems Gallery"
                                }
                              ]
                            },
                            {
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography",
                              "content": "Click any image to view full size"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "cols": 3.0,
                          "entity": "@entity",
                          "imageField": "imageUrl",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "icon": "maximize"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "h4",
                              "label": "Title",
                              "name": "name"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "GalleryItemGalleryPage",
          "path": "/galleryitems/gallery",
          "traits": [
            {
              "ref": "GalleryItemGallery"
            }
          ]
        }
      ]
    }
  ]
}