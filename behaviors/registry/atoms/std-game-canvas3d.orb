{
  "name": "std-game-canvas3d",
  "version": "1.0.0",
  "description": "std-game-canvas3d as a Function",
  "orbitals": [
    {
      "name": "Canvas3dSceneOrbital",
      "entity": {
        "name": "Canvas3dScene",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "tiles",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "features",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "traits": [
        {
          "name": "Canvas3dSceneGameCanvas3d",
          "category": "interaction",
          "linkedEntity": "Canvas3dScene",
          "emits": [
            {
              "event": "Canvas3dSceneLoaded",
              "description": "Fired when Canvas3dScene finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tiles",
                  "type": "[string]"
                },
                {
                  "name": "units",
                  "type": "[string]"
                },
                {
                  "name": "features",
                  "type": "[string]"
                }
              ]
            },
            {
              "event": "Canvas3dSceneLoadFailed",
              "description": "Fired when Canvas3dScene fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payload": [
                  {
                    "name": "tileId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payload": [
                  {
                    "name": "unitId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CAMERA_CHANGE",
                "name": "Camera Change"
              },
              {
                "key": "Canvas3dSceneLoaded",
                "name": "Canvas3dScene loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tiles",
                    "type": "[string]"
                  },
                  {
                    "name": "units",
                    "type": "[string]"
                  },
                  {
                    "name": "features",
                    "type": "[string]"
                  }
                ]
              },
              {
                "key": "Canvas3dSceneLoadFailed",
                "name": "Canvas3dScene load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Canvas3dScene",
                    {
                      "emit": {
                        "success": "Canvas3dSceneLoaded",
                        "failure": "Canvas3dSceneLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "tiles": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "tiles"
                      ],
                      "backgroundColor": "#1a1a2e",
                      "unitClickEvent": "UNIT_CLICK",
                      "units": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "units"
                      ],
                      "showGrid": true,
                      "features": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "features"
                      ],
                      "tileClickEvent": "TILE_CLICK",
                      "cameraMode": "perspective",
                      "orientation": "standard",
                      "type": "game-canvas-3d",
                      "shadows": true
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "TILE_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "unitClickEvent": "UNIT_CLICK",
                      "backgroundColor": "#1a1a2e",
                      "shadows": true,
                      "units": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "units"
                      ],
                      "showGrid": true,
                      "tiles": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "tiles"
                      ],
                      "type": "game-canvas-3d",
                      "cameraMode": "perspective",
                      "orientation": "standard",
                      "features": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "features"
                      ],
                      "tileClickEvent": "TILE_CLICK"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "UNIT_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "orientation": "standard",
                      "showGrid": true,
                      "shadows": true,
                      "type": "game-canvas-3d",
                      "cameraMode": "perspective",
                      "units": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "units"
                      ],
                      "tileClickEvent": "TILE_CLICK",
                      "tiles": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "tiles"
                      ],
                      "unitClickEvent": "UNIT_CLICK",
                      "features": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "features"
                      ],
                      "backgroundColor": "#1a1a2e"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CAMERA_CHANGE"
              },
              {
                "from": "active",
                "to": "active",
                "event": "TILE_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "features": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "features"
                      ],
                      "orientation": "standard",
                      "units": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "units"
                      ],
                      "unitClickEvent": "UNIT_CLICK",
                      "tileClickEvent": "TILE_CLICK",
                      "showGrid": true,
                      "tiles": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "tiles"
                      ],
                      "shadows": true,
                      "backgroundColor": "#1a1a2e",
                      "cameraMode": "perspective",
                      "type": "game-canvas-3d"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "UNIT_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-canvas-3d",
                      "units": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "units"
                      ],
                      "cameraMode": "perspective",
                      "features": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "features"
                      ],
                      "orientation": "standard",
                      "backgroundColor": "#1a1a2e",
                      "tileClickEvent": "TILE_CLICK",
                      "tiles": [
                        "object/get",
                        [
                          "array/first",
                          "@Canvas3dScene"
                        ],
                        "tiles"
                      ],
                      "showGrid": true,
                      "shadows": true,
                      "unitClickEvent": "UNIT_CLICK"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "CAMERA_CHANGE"
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Canvas3dSceneCanvas3dPage",
          "path": "/canvas3dscenes",
          "traits": [
            {
              "ref": "Canvas3dSceneGameCanvas3d"
            }
          ]
        }
      ]
    }
  ]
}