{
  "name": "std-browse",
  "version": "1.0.0",
  "description": "std-browse as a Function",
  "orbitals": [
    {
      "name": "BrowseItemOrbital",
      "entity": {
        "name": "BrowseItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "BrowseItemBrowse",
          "category": "interaction",
          "linkedEntity": "BrowseItem",
          "emits": [
            {
              "event": "BrowseItemLoaded",
              "description": "Fired when the BrowseItem collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BrowseItemLoadFailed",
              "description": "Fired when the BrowseItem collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BrowseItemLoaded",
                "name": "BrowseItem loaded"
              },
              {
                "key": "BrowseItemLoadFailed",
                "name": "BrowseItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BrowseItem",
                    {
                      "emit": {
                        "success": "BrowseItemLoaded",
                        "failure": "BrowseItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading BrowseItems…"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "className": "max-w-5xl mx-auto w-full py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BrowseItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "list",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "BrowseItems"
                                }
                              ]
                            }
                          ],
                          "justify": "space-between",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "BrowseItem",
                          "emptyIcon": "inbox",
                          "emptyDescription": "Create your first browseitem to get started.",
                          "type": "data-grid",
                          "emptyTitle": "No browseitems yet",
                          "columns": [
                            {
                              "icon": "list",
                              "label": "Name",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "colorMap": {
                                "cancelled": "destructive",
                                "failed": "destructive",
                                "scheduled": "warning",
                                "inactive": "neutral",
                                "archived": "neutral",
                                "active": "success",
                                "pending": "warning",
                                "disabled": "neutral",
                                "draft": "warning",
                                "error": "destructive",
                                "completed": "success",
                                "done": "success"
                              },
                              "name": "description",
                              "variant": "badge",
                              "label": "Description"
                            },
                            {
                              "name": "status",
                              "variant": "caption",
                              "label": "Status"
                            }
                          ]
                        },
                        {
                          "type": "floating-action-button",
                          "icon": "plus",
                          "label": "Create",
                          "tooltip": "Create",
                          "event": "INIT"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BrowseItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-5xl mx-auto w-full py-12",
                      "children": [
                        {
                          "size": "xl",
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to load BrowseItems",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.message",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "event": "INIT"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BrowseItem",
                    {
                      "emit": {
                        "failure": "BrowseItemLoadFailed",
                        "success": "BrowseItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Refreshing…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full py-12",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BrowseItem",
                    {
                      "emit": {
                        "success": "BrowseItemLoaded",
                        "failure": "BrowseItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full py-12",
                      "children": [
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Retrying…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BrowseItemPage",
          "path": "/browseitems",
          "traits": [
            {
              "ref": "BrowseItemBrowse"
            }
          ]
        }
      ]
    }
  ]
}