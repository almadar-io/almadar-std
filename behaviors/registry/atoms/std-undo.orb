{
  "name": "std-undo",
  "version": "1.0.0",
  "description": "std-undo as a Function",
  "orbitals": [
    {
      "name": "UndoActionOrbital",
      "entity": {
        "name": "UndoAction",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "undoStack",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "redoStack",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "current",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "UndoActionUndo",
          "category": "interaction",
          "linkedEntity": "UndoAction",
          "emits": [
            {
              "event": "UndoActionLoaded",
              "description": "Fired when UndoAction finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "undoStack",
                  "type": "[string]"
                },
                {
                  "name": "redoStack",
                  "type": "[string]"
                },
                {
                  "name": "current",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UndoActionLoadFailed",
              "description": "Fired when UndoAction fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PUSH",
                "name": "Push",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNDO",
                "name": "Undo"
              },
              {
                "key": "REDO",
                "name": "Redo"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "UndoActionLoaded",
                "name": "UndoAction loaded"
              },
              {
                "key": "UndoActionLoadFailed",
                "name": "UndoAction load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "UndoAction",
                    {
                      "emit": {
                        "failure": "UndoActionLoadFailed",
                        "success": "UndoActionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "space-between",
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "history",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "History",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Undo the last action",
                                  "children": [
                                    {
                                      "label": "Undo",
                                      "event": "UNDO",
                                      "type": "button",
                                      "variant": "ghost",
                                      "icon": "undo"
                                    }
                                  ],
                                  "type": "tooltip"
                                },
                                {
                                  "type": "tooltip",
                                  "children": [
                                    {
                                      "icon": "redo",
                                      "label": "Redo",
                                      "type": "button",
                                      "variant": "ghost",
                                      "event": "REDO"
                                    }
                                  ],
                                  "content": "Redo the last undone action"
                                },
                                {
                                  "orientation": "vertical",
                                  "type": "divider"
                                },
                                {
                                  "children": [
                                    {
                                      "label": "Clear",
                                      "type": "button",
                                      "event": "CLEAR",
                                      "icon": "trash-2",
                                      "variant": "ghost"
                                    }
                                  ],
                                  "type": "tooltip",
                                  "content": "Clear all history"
                                }
                              ],
                              "gap": "sm"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography",
                              "content": "Last action:"
                            },
                            {
                              "type": "badge",
                              "label": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "current"
                              ]
                            }
                          ],
                          "gap": "md"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PUSH",
                "effects": [
                  [
                    "set",
                    "@entity.undoStack",
                    [
