{
  "name": "std-agent-context-window",
  "version": "1.0.0",
  "description": "std-agent-context-window as a Function",
  "orbitals": [
    {
      "name": "AgentContextWindowOrbital",
      "entity": {
        "name": "AgentContextWindow",
        "collection": "agentcontextwindows",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "usage",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastCompactedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "current",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "max",
            "type": "number",
            "default": 200000.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.85
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "notificationType",
            "type": "string",
            "default": "info"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentContextWindowGauge",
          "category": "interaction",
          "linkedEntity": "AgentContextWindow",
          "emits": [
            {
              "event": "AgentContextWindowLoaded",
              "description": "Fired when AgentContextWindow finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "maxTokens",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentContextWindowLoadFailed",
              "description": "Fired when AgentContextWindow fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
              },
              {
                "name": "warning"
              },
              {
                "name": "critical"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payload": [
                  {
                    "name": "current",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "AgentContextWindowLoaded",
                "name": "AgentContextWindow loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoadFailed",
                "name": "AgentContextWindow load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentContextWindow",
                    {
                      "emit": {
                        "success": "AgentContextWindowLoaded",
                        "failure": "AgentContextWindowLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "gauge",
                              "type": "icon"
                            },
                            {
                              "content": "Token Usage",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "variant": "default",
                              "label": "Normal"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "progress-bar",
                          "value": "@entity.current",
                          "max": "@entity.max"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "label": "Tokens Used",
                              "type": "stat-display",
                              "value": "@entity.current"
                            },
                            {
                              "value": "@entity.max",
                              "type": "stat-display",
                              "label": "Max Tokens"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "action": "RESET"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "normal",
                "event": "UPDATE",
                "guard": [
                  "<",
                  [
                    "/",
                    "@payload.current",
                    "@entity.max"
                  ],
                  0.85
                ],
                "effects": [
                  [
                    "set",
                    "@entity.current",
                    "@payload.current"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "gauge"
                            },
                            {
                              "content": "Token Usage",
                              "variant": "h2",
                              "type": "typography"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "Normal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "max": "@entity.max",
                          "value": "@entity.current",
                          "type": "progress-bar"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Tokens Used",
                              "value": "@entity.current",
                              "type": "stat-display"
                            },
                            {
                              "label": "Max Tokens",
                              "type": "stat-display",
                              "value": "@entity.max"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "variant": "ghost",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Reset"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "warning",
                "event": "UPDATE",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@payload.current",
                      "@entity.max"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@payload.current",
                      "@entity.max"
                    ],
                    0.95
                  ]
                ],
                "effects": [
