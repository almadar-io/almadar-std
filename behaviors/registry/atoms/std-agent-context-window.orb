            },
            {
              "event": "AgentContextWindowLoaded",
              "description": "Fired when AgentContextWindow finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "maxTokens",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentContextWindowLoadFailed",
              "description": "Fired when AgentContextWindow fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
              },
              {
                "name": "approaching_limit"
              },
              {
                "name": "at_limit"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Tokens"
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "UPDATE",
                "name": "Update"
              },
              {
                "key": "AgentContextWindowLoaded",
                "name": "AgentContextWindow loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoadFailed",
                "name": "AgentContextWindow load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentContextWindow",
                    {
                      "emit": {
                        "success": "AgentContextWindowLoaded",
                        "failure": "AgentContextWindowLoadFailed"
                      }
                    }
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Context Window",
                      "description": "Context Window is ready",
                      "type": "empty-state",
                      "icon": "layers"
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "normal",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "<",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  0.85
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "at_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  ">=",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  1.0
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "at_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentContextWindowPage",
          "path": "/agentcontextwindows",
          "traits": [
            {
              "ref": "AgentContextWindowGauge"
            },
            {
              "ref": "AgentContextWindowNotification"
            },
            {
              "ref": "AgentContextWindowAgent"
            }
          ]
        }
      ]
    }
  ]
}