                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "children": [
                            {
                              "label": "Compact",
                              "type": "button",
                              "variant": "primary",
                              "action": "COMPACT",
                              "icon": "minimize-2"
