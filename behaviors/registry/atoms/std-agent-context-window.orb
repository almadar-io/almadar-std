        {
          "name": "AgentContextWindowNotification",
          "category": "interaction",
          "linkedEntity": "AgentContextWindow",
          "emits": [
            {
              "event": "AgentContextWindowLoaded",
              "description": "Fired when AgentContextWindow finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "maxTokens",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentContextWindowLoadFailed",
              "description": "Fired when AgentContextWindow fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "hidden",
                "isInitial": true
              },
              {
                "name": "visible"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payload": [
                  {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "HIDE",
                "name": "Hide"
              },
              {
                "key": "AgentContextWindowLoaded",
                "name": "AgentContextWindow loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentContextWindowLoadFailed",
                "name": "AgentContextWindow load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "hidden",
                "to": "hidden",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentContextWindow",
                    {
                      "emit": {
                        "success": "AgentContextWindowLoaded",
                        "failure": "AgentContextWindowLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "hidden",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "layers",
                                  "type": "icon"
                                },
                                {
                                  "content": "Context Window Alert",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "variant": "ghost",
                              "action": "HIDE",
                              "icon": "x",
                              "type": "button",
                              "label": "Dismiss"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ],
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert"
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "category": "compliance",
                          "severity": "warning",
                          "type": "violation-alert"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "layers",
                                  "type": "icon"
                                },
                                {
                                  "content": "Context Window Alert",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "icon": "x",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Dismiss",
                              "action": "HIDE"
                            }
                          ],
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert",
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ]
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "severity": "warning",
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "category": "compliance",
                          "type": "violation-alert"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "hidden",
                "event": "HIDE",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
