                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ]
                        },
                        {
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "points"
                          ],
                          "showValue": true,
                          "type": "trend-indicator"
                        },
                        {
                          "type": "spacer"
                        },
                        {
                          "justify": "center",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
