                        {
                          "duration": 300.0,
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ],
                          "type": "animated-counter",
                          "label": ""
                        },
                        {
                          "type": "trend-indicator",
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
