{
  "name": "std-score",
  "version": "1.0.0",
  "description": "std-score as a Function",
  "orbitals": [
    {
      "name": "ScoreEntryOrbital",
      "entity": {
        "name": "ScoreEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "combo",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "points",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "multiplier",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "ScoreEntryScore",
          "category": "interaction",
          "linkedEntity": "ScoreEntry",
          "emits": [
            {
              "event": "ScoreEntryLoaded",
              "description": "Fired when ScoreEntry finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "total",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "points",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ScoreEntryLoadFailed",
              "description": "Fired when ScoreEntry fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD",
                "name": "Add",
                "payload": [
                  {
                    "name": "points",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "SUBTRACT",
                "name": "Subtract",
                "payload": [
                  {
                    "name": "points",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ScoreEntryLoaded",
                "name": "ScoreEntry loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "total",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "points",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ScoreEntryLoadFailed",
                "name": "ScoreEntry load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ScoreEntry",
                    {
                      "emit": {
                        "success": "ScoreEntryLoaded",
                        "failure": "ScoreEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "highScore": 0.0,
                          "type": "score-board",
                          "level": 1.0,
                          "multiplier": 1.0,
                          "combo": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "combo"
                          ],
                          "score": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ]
                        },
                        {
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ],
                          "duration": 300.0,
                          "type": "animated-counter",
                          "label": ""
                        },
                        {
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "points"
                          ],
                          "type": "trend-indicator",
                          "showValue": true
                        },
                        {
                          "type": "spacer"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "action": "ADD",
                              "icon": "plus",
                              "type": "button",
                              "label": "Add",
                              "variant": "primary"
                            },
                            {
                              "label": "Subtract",
                              "variant": "secondary",
                              "type": "button",
                              "action": "SUBTRACT",
                              "icon": "minus"
                            },
                            {
                              "label": "Combo",
                              "action": "COMBO",
                              "type": "button",
                              "variant": "secondary",
                              "icon": "zap"
                            },
                            {
                              "action": "RESET",
                              "type": "button",
                              "icon": "rotate-ccw",
                              "label": "Reset",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD",
                "effects": [
                  [
                    "set",
                    "@entity.points",
                    "@payload.points"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "score-board",
                          "score": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ],
                          "level": 1.0,
                          "multiplier": 1.0,
                          "combo": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "combo"
                          ],
                          "highScore": 0.0
                        },
                        {
                          "label": "",
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "total"
                          ],
                          "type": "animated-counter",
                          "duration": 300.0
                        },
                        {
                          "showValue": true,
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "points"
                          ],
                          "type": "trend-indicator"
                        },
                        {
                          "type": "spacer"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "ADD",
                              "label": "Add",
                              "icon": "plus",
                              "type": "button"
                            },
                            {
                              "label": "Subtract",
