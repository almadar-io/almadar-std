                          "highlightColor": "yellow"
                        },
                        {
                          "children": [
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "name"
                              ]
                            }
                          ],
                          "reference": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "reference"
                          ],
