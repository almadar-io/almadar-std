{
  "name": "std-text-effects",
  "version": "1.0.0",
  "description": "std-text-effects as a Function",
  "orbitals": [
    {
      "name": "TextContentOrbital",
      "entity": {
        "name": "TextContent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "highlightType",
            "type": "string",
            "default": "none"
          },
          {
            "name": "reference",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TextContentTextEffects",
          "category": "interaction",
          "linkedEntity": "TextContent",
          "emits": [
            {
              "event": "TextContentLoaded",
              "description": "Fired when TextContent finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "highlightType",
                  "type": "string"
                },
                {
                  "name": "reference",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TextContentLoadFailed",
              "description": "Fired when TextContent fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "animating"
              },
              {
                "name": "highlighted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ANIMATE",
                "name": "Animate"
              },
              {
                "key": "HIGHLIGHT",
                "name": "Highlight"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "TextContentLoaded",
                "name": "TextContent loaded"
              },
              {
                "key": "TextContentLoadFailed",
                "name": "TextContent load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TextContent",
                    {
                      "emit": {
                        "success": "TextContentLoaded",
                        "failure": "TextContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "name": "type",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Text Effects",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "name"
                          ],
                          "type": "markdown-content"
                        },
                        {
                          "type": "code-block",
                          "code": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "reference"
                          ],
                          "language": "text"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "name"
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Animate",
                              "variant": "primary",
                              "type": "button",
                              "event": "ANIMATE",
                              "icon": "play"
                            },
                            {
                              "type": "button",
                              "event": "HIGHLIGHT",
                              "label": "Highlight",
                              "variant": "secondary",
                              "icon": "highlighter"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "animating",
                "event": "ANIMATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "name": "type",
                              "type": "icon"
                            },
                            {
                              "content": "Text Effects",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "text": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "name"
                          ],
                          "speed": 50.0,
                          "type": "typewriter-text",
                          "cursor": true
                        },
                        {
                          "type": "law-reference-tooltip",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "color": "muted",
                              "content": "Hover for reference details"
                            }
                          ],
                          "reference": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "reference"
                          ]
                        },
                        {
                          "label": "Highlight",
                          "event": "HIGHLIGHT",
                          "variant": "secondary",
                          "type": "button",
                          "icon": "highlighter"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "highlighted",
                "event": "HIGHLIGHT",
