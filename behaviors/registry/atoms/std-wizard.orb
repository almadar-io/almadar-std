{
  "name": "std-wizard",
  "version": "1.0.0",
  "description": "std-wizard as a Function",
  "orbitals": [
    {
      "name": "WizardEntryOrbital",
      "entity": {
        "name": "WizardEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WizardEntryWizard",
          "category": "interaction",
          "linkedEntity": "WizardEntry",
          "emits": [
            {
              "event": "WizardEntryLoaded",
              "description": "Fired when WizardEntry finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardEntryLoadFailed",
              "description": "Fired when WizardEntry fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "step1",
                "isInitial": true
              },
              {
                "name": "step2"
              },
              {
                "name": "step3"
              },
              {
                "name": "review"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NEXT",
                "name": "Next",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PREV",
                "name": "Prev"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "WizardEntryLoaded",
                "name": "WizardEntry loaded"
              },
              {
                "key": "WizardEntryLoadFailed",
                "name": "WizardEntry load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "step1",
                "to": "step1",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardEntry",
                    {
                      "emit": {
                        "failure": "WizardEntryLoadFailed",
                        "success": "WizardEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "clipboard"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Setup Wizard",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "currentIndex": 0.0,
                              "type": "progress-dots",
                              "count": 3.0
                            },
                            {
                              "currentStep": 0.0,
                              "steps": [
                                "Personal Info",
                                "Settings",
                                "Review"
                              ],
                              "type": "wizard-progress"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "typography",
                              "content": "Personal Info",
                              "variant": "h3"
                            },
                            {
                              "cancelEvent": "INIT",
                              "submitEvent": "NEXT",
                              "mode": "create",
                              "type": "form-section",
                              "fields": [
                                "name",
                                "description"
                              ],
                              "entity": "WizardEntry"
                            },
                            {
                              "justify": "end",
                              "gap": "sm",
                              "children": [
                                {
                                  "label": "Next",
                                  "icon": "arrow-right",
                                  "type": "button",
                                  "event": "NEXT",
                                  "variant": "primary"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "type": "container",
                      "padding": "lg",
                      "maxWidth": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "step1",
                "to": "step2",
                "event": "NEXT",
                "effects": [
