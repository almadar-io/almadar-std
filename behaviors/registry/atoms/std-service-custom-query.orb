{
  "name": "std-service-custom-query",
  "version": "1.0.0",
  "description": "std-service-custom-query as a Function",
  "orbitals": [
    {
      "name": "ServiceCustomQueryOrbital",
      "entity": {
        "name": "ServiceCustomQuery",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "endpoint",
            "type": "string"
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "requestBody",
            "type": "string"
          },
          {
            "name": "responseData",
            "type": "string"
          },
          {
            "name": "statusCode",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "callStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCustomQueryCustomQuery",
          "category": "interaction",
          "linkedEntity": "ServiceCustomQuery",
          "emits": [
            {
              "event": "ServiceCustomQueryLoaded",
              "description": "Fired when ServiceCustomQuery finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "endpoint",
                  "type": "string"
                },
                {
                  "name": "method",
                  "type": "string"
                },
                {
                  "name": "requestBody",
                  "type": "string"
                },
                {
                  "name": "responseData",
                  "type": "string"
                },
                {
                  "name": "statusCode",
                  "type": "number"
                },
                {
                  "name": "callStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomQueryLoadFailed",
              "description": "Fired when ServiceCustomQuery fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomQueryCustomQueryApiCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomQueryCustomQueryApiFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CALL_API",
                "name": "Call Api"
              },
              {
                "key": "API_RESPONSE",
                "name": "Api Response",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "statusCode",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceCustomQueryLoaded",
                "name": "ServiceCustomQuery loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "endpoint",
                    "type": "string"
                  },
                  {
                    "name": "method",
                    "type": "string"
                  },
                  {
                    "name": "requestBody",
                    "type": "string"
                  },
                  {
                    "name": "responseData",
                    "type": "string"
                  },
                  {
                    "name": "statusCode",
                    "type": "number"
                  },
                  {
                    "name": "callStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomQueryLoadFailed",
                "name": "ServiceCustomQuery load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomQueryCustomQueryApiCompleted",
                "name": "ServiceCustomQuery custom query api completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomQueryCustomQueryApiFailed",
                "name": "ServiceCustomQuery custom query api failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceCustomQuery",
                    {
                      "emit": {
                        "success": "ServiceCustomQueryLoaded",
                        "failure": "ServiceCustomQueryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "content": "Query Auth API Tester",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input"
                        },
                        {
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "JSON request body"
                        },
                        {
                          "type": "button",
                          "action": "CALL_API",
                          "variant": "primary",
                          "label": "Send Request",
                          "icon": "send"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_API",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Sending request to servicecustomquery endpoint...",
                      "type": "loading-state",
                      "title": "Calling API..."
                    }
                  ],
                  [
                    "call-service",
                    "custom-query-api",
                    "execute",
                    {
                      "endpoint": "@entity.endpoint",
                      "body": "@entity.requestBody",
                      "method": "@entity.method"
                    },
                    {
                      "emit": {
                        "failure": "ServiceCustomQueryCustomQueryApiFailed",
                        "success": "ServiceCustomQueryCustomQueryApiCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "API_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.responseData",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.statusCode",
                    "@payload.statusCode"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Response",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "type": "badge",
                          "label": "@entity.statusCode",
                          "variant": "info"
                        },
                        {
                          "content": "@entity.responseData",
                          "language": "json",
                          "type": "code"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "label": "New Request"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Request Failed",
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Query Auth API Tester"
                        },
                        {
                          "type": "input",
                          "placeholder": "/users"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ]
                        },
                        {
                          "placeholder": "JSON request body",
                          "type": "textarea"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "send",
                          "label": "Send Request",
                          "action": "CALL_API"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "content": "Query Auth API Tester",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input"
                        },
                        {
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "placeholder": "JSON request body",
                          "type": "textarea"
                        },
                        {
                          "icon": "send",
                          "action": "CALL_API",
                          "label": "Send Request",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "search"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Query Auth API Tester"
                        },
                        {
                          "type": "input",
                          "placeholder": "/users"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ]
                        },
                        {
                          "placeholder": "JSON request body",
                          "type": "textarea"
                        },
                        {
                          "action": "CALL_API",
                          "variant": "primary",
                          "type": "button",
                          "label": "Send Request",
                          "icon": "send"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCustomQueryPage",
          "path": "/servicecustomquerys",
          "traits": [
            {
              "ref": "ServiceCustomQueryCustomQuery"
            }
          ]
        }
      ]
    }
  ]
}