{
  "name": "std-agent-memory",
  "version": "1.0.0",
  "description": "std-agent-memory as a Function",
  "orbitals": [
    {
      "name": "AgentMemoryOrbital",
      "entity": {
        "name": "AgentMemory",
        "collection": "agentmemorys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": "general"
          },
          {
            "name": "strength",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pinned",
            "type": "boolean",
            "default": false
          },
          {
            "name": "scope",
            "type": "string",
            "default": "session",
            "values": [
              "session",
              "persistent",
              "shared"
            ]
          },
          {
            "name": "lastAccessedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentMemoryBrowse",
          "category": "interaction",
          "linkedEntity": "AgentMemory",
          "emits": [
            {
              "event": "AgentMemoryLoaded",
              "description": "Fired when the AgentMemory collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[AgentMemory]"
                }
              ]
            },
            {
              "event": "AgentMemoryLoadFailed",
              "description": "Fired when the AgentMemory collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaved",
              "description": "Fired when a new memory is persisted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaveFailed",
              "description": "Fired when persisting a memory fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "MEMORIZED",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            },
            {
              "event": "MEMORY_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            },
            {
              "event": "PINNED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentMemoryAgent"
              }
            },
            {
              "event": "FORGOT",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentMemoryAgent"
              }
            },
            {
              "event": "REINFORCED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentMemoryAgent"
              }
            },
            {
              "event": "DECAYED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentMemoryAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentMemoryLoaded",
                "name": "AgentMemory loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[AgentMemory]"
                  }
                ]
              },
              {
                "key": "AgentMemoryLoadFailed",
                "name": "AgentMemory load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaved",
                "name": "AgentMemory saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaveFailed",
                "name": "AgentMemory save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentMemory"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "success": "AgentMemoryLoaded",
                        "failure": "AgentMemoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading memories…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AgentMemoryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "brain"
                                },
                                {
                                  "type": "typography",
                                  "content": "AgentMemory Manager",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "primary",
                                  "type": "button",
                                  "icon": "plus",
                                  "label": "Memorize",
                                  "action": "MEMORIZE"
                                },
                                {
                                  "icon": "search",
                                  "action": "RECALL",
                                  "variant": "secondary",
                                  "label": "Recall",
                                  "type": "button"
                                },
                                {
                                  "type": "button",
                                  "icon": "clock",
                                  "variant": "ghost",
                                  "action": "DECAY",
                                  "label": "Decay All"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "content",
                              "variant": "h4",
                              "label": "Content",
                              "icon": "brain"
                            },
                            {
                              "variant": "badge",
                              "name": "category",
                              "label": "Category"
                            },
                            {
                              "variant": "caption",
                              "label": "Strength",
                              "name": "strength"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "label": "Pin",
                              "event": "PIN"
                            },
                            {
                              "event": "REINFORCE",
                              "variant": "ghost",
                              "label": "Reinforce"
                            },
                            {
                              "variant": "danger",
                              "label": "Forget",
                              "event": "FORGET"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentMemoryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load memories",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "success": "AgentMemoryLoaded",
                        "failure": "AgentMemoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "failure": "AgentMemoryLoadFailed",
                        "success": "AgentMemoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentMemoryCreate",
          "category": "interaction",
          "linkedEntity": "AgentMemory",
          "emits": [
            {
              "event": "MEMORY_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AgentMemoryLoaded",
              "description": "Fired when the AgentMemory collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[AgentMemory]"
                }
              ]
            },
            {
              "event": "AgentMemoryLoadFailed",
              "description": "Fired when the AgentMemory collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaved",
              "description": "Fired when a new memory is persisted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaveFailed",
              "description": "Fired when persisting a memory fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MEMORIZE",
                "name": "Memorize"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "MEMORY_CREATED",
                "name": "Memory Created"
              },
              {
                "key": "AgentMemoryLoaded",
                "name": "AgentMemory loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[AgentMemory]"
                  }
                ]
              },
              {
                "key": "AgentMemoryLoadFailed",
                "name": "AgentMemory load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaved",
                "name": "AgentMemory saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaveFailed",
                "name": "AgentMemory save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "failure": "AgentMemoryLoadFailed",
                        "success": "AgentMemoryLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "MEMORIZE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Memorize",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "type": "form-section",
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE",
                          "fields": [
                            "content",
                            "category",
                            "scope"
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentMemory",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentMemorySaveFailed",
                        "success": "AgentMemorySaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "MEMORY_CREATED",
                    {
                      "id": "@payload.data.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AgentMemoryAgent",
          "category": "interaction",
          "linkedEntity": "AgentMemory",
          "emits": [
            {
              "event": "FORGOT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REINFORCED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DECAYED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PINNED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MEMORIZED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AgentMemoryLoaded",
              "description": "Fired when the AgentMemory collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[AgentMemory]"
                }
              ]
            },
            {
              "event": "AgentMemoryLoadFailed",
              "description": "Fired when the AgentMemory collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaved",
              "description": "Fired when a new memory is persisted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentMemorySaveFailed",
              "description": "Fired when persisting a memory fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_MEMORIZE",
                "name": "Do Memorize",
                "payload": [
                  {
                    "name": "data",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "DECAY",
                "name": "Decay"
              },
              {
                "key": "MEMORIZED",
                "name": "Memorized",
                "payload": [
                  {
                    "name": "data",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "RECALL",
                "name": "Recall",
                "payload": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FORGOT",
                "name": "Forgot"
              },
              {
                "key": "REINFORCED",
                "name": "Reinforced"
              },
              {
                "key": "DECAYED",
                "name": "Decayed"
              },
              {
                "key": "PINNED",
                "name": "Pinned"
              },
              {
                "key": "AgentMemoryLoaded",
                "name": "AgentMemory loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[AgentMemory]"
                  }
                ]
              },
              {
                "key": "AgentMemoryLoadFailed",
                "name": "AgentMemory load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaved",
                "name": "AgentMemory saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaveFailed",
                "name": "AgentMemory save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "success": "AgentMemoryLoaded",
                        "failure": "AgentMemoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Memory",
                      "icon": "brain",
                      "type": "empty-state",
                      "description": "Memory is ready"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "DO_MEMORIZE",
                "effects": [
                  [
                    "agent/memorize",
                    "@payload.data.content",
                    "@payload.data.category"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentMemory",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentMemorySaveFailed",
                        "success": "AgentMemorySaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "MEMORIZED",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED",
                    {
                      "id": ""
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "MEMORIZED",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "success": "AgentMemoryLoaded",
                        "failure": "AgentMemoryLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "RECALL",
                "effects": [
                  [
                    "agent/recall",
                    "@payload.query"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "PIN",
                "guard": [
                  "not",
                  [
                    "agent/is-pinned",
                    "@payload.id"
                  ]
                ],
                "effects": [
                  [
                    "agent/pin",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "PINNED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "idle",
                "event": "FORGET",
                "effects": [
                  [
                    "agent/forget",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "FORGOT",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "REINFORCE",
                "effects": [
                  [
                    "agent/reinforce",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "REINFORCED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED",
                    {
                      "id": ""
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentMemoryPage",
          "path": "/agentmemorys",
          "traits": [
            {
              "ref": "AgentMemoryBrowse"
            },
            {
              "ref": "AgentMemoryCreate"
            },
            {
              "ref": "AgentMemoryAgent"
            }
          ]
        }
      ]
    }
  ]
}
