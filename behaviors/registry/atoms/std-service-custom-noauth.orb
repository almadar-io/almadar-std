{
  "name": "std-service-custom-noauth",
  "version": "1.0.0",
  "description": "std-service-custom-noauth as a Function",
  "orbitals": [
    {
      "name": "ServiceCustomNoauthOrbital",
      "entity": {
        "name": "ServiceCustomNoauth",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "endpoint",
            "type": "string"
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "requestBody",
            "type": "string"
          },
          {
            "name": "responseData",
            "type": "string"
          },
          {
            "name": "statusCode",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "callStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCustomNoauthCustomNoauth",
          "category": "interaction",
          "linkedEntity": "ServiceCustomNoauth",
          "emits": [
            {
              "event": "ServiceCustomNoauthLoaded",
              "description": "Fired when ServiceCustomNoauth finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "endpoint",
                  "type": "string"
                },
                {
                  "name": "method",
                  "type": "string"
                },
                {
                  "name": "requestBody",
                  "type": "string"
                },
                {
                  "name": "responseData",
                  "type": "string"
                },
                {
                  "name": "statusCode",
                  "type": "number"
                },
                {
                  "name": "callStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomNoauthLoadFailed",
              "description": "Fired when ServiceCustomNoauth fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CALL_API",
                "name": "Call Api"
              },
              {
                "key": "API_RESPONSE",
                "name": "Api Response",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "statusCode",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceCustomNoauthLoaded",
                "name": "ServiceCustomNoauth loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "endpoint",
                    "type": "string"
                  },
                  {
                    "name": "method",
                    "type": "string"
                  },
                  {
                    "name": "requestBody",
                    "type": "string"
                  },
                  {
                    "name": "responseData",
                    "type": "string"
                  },
                  {
                    "name": "statusCode",
                    "type": "number"
                  },
                  {
                    "name": "callStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomNoauthLoadFailed",
                "name": "ServiceCustomNoauth load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceCustomNoauth",
                    {
                      "emit": {
                        "success": "ServiceCustomNoauthLoaded",
                        "failure": "ServiceCustomNoauthLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "globe",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Public API Tester"
                        },
                        {
                          "field": "endpoint",
                          "type": "input",
                          "bind": "@entity.endpoint",
                          "placeholder": "/users"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "value": "PUT",
                              "label": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ],
                          "field": "method",
                          "bind": "@entity.method"
                        },
                        {
                          "type": "textarea",
                          "field": "requestBody",
                          "placeholder": "JSON request body",
                          "bind": "@entity.requestBody"
                        },
                        {
                          "type": "button",
                          "label": "Send Request",
                          "event": "CALL_API",
                          "variant": "primary",
                          "icon": "send"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_API",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Calling API...",
                      "message": "Sending request to servicecustomnoauth endpoint..."
                    }
                  ],
                  [
                    "call-service",
                    "custom-noauth-api",
                    "execute",
                    {
                      "body": "@entity.requestBody",
                      "endpoint": "@entity.endpoint",
                      "method": "@entity.method"
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "API_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.responseData",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.statusCode",
                    "@payload.statusCode"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "content": "Response",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "variant": "info",
                          "type": "badge",
                          "content": "@entity.statusCode"
                        },
                        {
                          "content": "@entity.responseData",
                          "language": "json",
                          "type": "code"
                        },
                        {
                          "variant": "ghost",
                          "label": "New Request",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "event": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Request Failed",
                      "message": "@entity.error",
                      "type": "error-state",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "globe"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Public API Tester"
                        },
                        {
                          "field": "endpoint",
                          "type": "input",
                          "placeholder": "/users",
                          "bind": "@entity.endpoint"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "value": "PUT",
                              "label": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ],
                          "bind": "@entity.method",
                          "field": "method"
                        },
                        {
                          "bind": "@entity.requestBody",
                          "field": "requestBody",
                          "type": "textarea",
                          "placeholder": "JSON request body"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "label": "Send Request",
                          "event": "CALL_API",
                          "icon": "send"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "globe",
                          "size": "lg",
                          "type": "icon"
                        },
                        {
                          "content": "Public API Tester",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "field": "endpoint",
                          "placeholder": "/users",
                          "bind": "@entity.endpoint",
                          "type": "input"
                        },
                        {
                          "type": "select",
                          "field": "method",
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "value": "PUT",
                              "label": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ],
                          "bind": "@entity.method"
                        },
                        {
                          "placeholder": "JSON request body",
                          "field": "requestBody",
                          "bind": "@entity.requestBody",
                          "type": "textarea"
                        },
                        {
                          "event": "CALL_API",
                          "label": "Send Request",
                          "type": "button",
                          "icon": "send",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "globe"
                        },
                        {
                          "type": "typography",
                          "content": "Public API Tester",
                          "variant": "h2"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input",
                          "field": "endpoint",
                          "bind": "@entity.endpoint"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ],
                          "field": "method",
                          "bind": "@entity.method"
                        },
                        {
                          "field": "requestBody",
                          "type": "textarea",
                          "placeholder": "JSON request body",
                          "bind": "@entity.requestBody"
                        },
                        {
                          "label": "Send Request",
                          "type": "button",
                          "variant": "primary",
                          "event": "CALL_API",
                          "icon": "send"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCustomNoauthPage",
          "path": "/servicecustomnoauths",
          "traits": [
            {
              "ref": "ServiceCustomNoauthCustomNoauth"
            }
          ]
        }
      ]
    }
  ]
}