{
  "name": "std-confirmation",
  "version": "1.0.0",
  "description": "std-confirmation as a Function",
  "orbitals": [
    {
      "name": "ConfirmActionOrbital",
      "entity": {
        "name": "ConfirmAction",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ConfirmActionConfirmation",
          "category": "interaction",
          "linkedEntity": "ConfirmAction",
          "emits": [
            {
              "event": "CONFIRM",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoaded",
              "description": "Fired when ConfirmAction finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoadFailed",
              "description": "Fired when ConfirmAction fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "confirming"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ConfirmActionLoaded",
                "name": "ConfirmAction loaded"
              },
              {
                "key": "ConfirmActionLoadFailed",
                "name": "ConfirmAction load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REQUEST",
                "name": "Request",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "failure": "ConfirmActionLoadFailed",
                        "success": "ConfirmActionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "ConfirmActionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "shield-check"
                            },
                            {
                              "content": "ConfirmActions",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "emptyTitle": "No confirmactions yet",
                          "itemActions": [
                            {
                              "label": "Confirm Action",
                              "event": "REQUEST",
                              "variant": "danger"
                            }
                          ],
                          "entity": "ConfirmAction",
                          "type": "data-grid",
                          "emptyDescription": "Items will appear here.",
                          "emptyIcon": "inbox",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "@item.name",
                                  "variant": "h4",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ConfirmActionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "size": "xl",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.message",
                          "type": "typography"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "event": "INIT"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "success": "ConfirmActionLoaded",
                        "failure": "ConfirmActionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "alert-triangle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Confirm Action"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Are you sure?",
                          "variant": "danger"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "icon": "check",
                              "variant": "danger",
                              "event": "CONFIRM",
                              "label": "Confirm",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "success": "ConfirmActionLoaded",
                        "failure": "ConfirmActionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "failure": "ConfirmActionLoadFailed",
                        "success": "ConfirmActionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "failure": "ConfirmActionLoadFailed",
                        "success": "ConfirmActionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "failure": "ConfirmActionLoadFailed",
                        "success": "ConfirmActionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ConfirmActionConfirmPage",
          "path": "/confirmactions/confirm",
          "traits": [
            {
              "ref": "ConfirmActionConfirmation"
            }
          ]
        }
      ]
    }
  ]
}