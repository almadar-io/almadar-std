{
  "name": "std-confirmation",
  "version": "1.0.0",
  "description": "std-confirmation as a Function",
  "orbitals": [
    {
      "name": "ConfirmActionOrbital",
      "entity": {
        "name": "ConfirmAction",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ConfirmActionConfirmation",
          "category": "interaction",
          "linkedEntity": "ConfirmAction",
          "emits": [
            {
              "event": "ConfirmActionLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ConfirmAction]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REQUEST",
                "name": "Request",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CONFIRM",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ConfirmActionLoadFailed",
                "name": "ConfirmAction load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConfirmActionLoaded",
                "name": "ConfirmAction loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ConfirmAction]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConfirmAction",
                    {
                      "emit": {
                        "success": "ConfirmActionLoaded",
                        "failure": "ConfirmActionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "@config.icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "@config.alertMessage"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.name",
                          "variant": "h4"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.pendingId",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "justify": "end",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CANCEL",
                              "type": "button",
                              "label": "Cancel"
                            },
                            {
                              "label": "@config.confirmLabel",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "icon": "check",
                              "action": "CONFIRM",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ConfirmActionConfirmPage",
          "path": "/confirmactions/confirm",
          "traits": [
            {
              "ref": "ConfirmActionConfirmation"
            }
          ]
        }
      ]
    }
  ]
}