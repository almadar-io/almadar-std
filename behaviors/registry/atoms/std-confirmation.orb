{
  "name": "std-confirmation",
  "version": "1.0.0",
  "description": "std-confirmation as a Function",
  "orbitals": [
    {
      "name": "ConfirmActionOrbital",
      "entity": {
        "name": "ConfirmAction",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ConfirmActionConfirmation",
          "category": "interaction",
          "linkedEntity": "ConfirmAction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REQUEST",
                "name": "Request",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConfirmAction"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "@config.icon",
                              "type": "icon",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "@config.alertMessage",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "label": "Cancel",
                              "type": "button",
                              "action": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "action": "CONFIRM",
                              "type": "button",
                              "label": "@config.confirmLabel",
                              "icon": "check",
                              "actionPayload": {
                                "id": "@entity.pendingId"
                              },
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "end",
                          "type": "stack"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ConfirmActionConfirmPage",
          "path": "/confirmactions/confirm",
          "traits": [
            {
              "ref": "ConfirmActionConfirmation"
            }
          ]
        }
      ]
    }
  ]
}
