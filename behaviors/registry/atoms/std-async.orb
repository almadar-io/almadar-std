{
  "name": "std-async",
  "version": "1.0.0",
  "description": "std-async as a Function",
  "orbitals": [
    {
      "name": "AsyncTaskOrbital",
      "entity": {
        "name": "AsyncTask",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AsyncTaskAsync",
          "category": "interaction",
          "linkedEntity": "AsyncTask",
          "emits": [
            {
              "event": "AsyncTaskLoaded",
              "description": "Fired when AsyncTask collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[AsyncTask]"
                }
              ]
            },
            {
              "event": "AsyncTaskLoadFailed",
              "description": "Fired when AsyncTask load fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AsyncTaskSaved",
              "description": "Fired when persist create succeeds",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AsyncTaskSaveFailed",
              "description": "Fired when persist create fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "persisting"
              },
              {
                "name": "success"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LOADED",
                "name": "Loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "AsyncTaskSaved",
                "name": "AsyncTask saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AsyncTaskSaveFailed",
                "name": "AsyncTask save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "AsyncTaskLoaded",
                "name": "AsyncTask loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[AsyncTask]"
                  }
                ]
              },
              {
                "key": "AsyncTaskLoadFailed",
                "name": "AsyncTask load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AsyncTask",
                    {
                      "emit": {
                        "success": "AsyncTaskLoaded",
                        "failure": "AsyncTaskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader"
                            },
                            {
                              "variant": "h2",
                              "content": "AsyncTask",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "content": "Ready to start asynctask operation.",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "label": "Start",
                          "variant": "primary",
                          "icon": "play",
                          "type": "button",
                          "action": "START"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "loading-state",
                          "title": "Loading...",
                          "message": "Processing asynctask..."
                        },
                        {
                          "type": "skeleton",
                          "variant": "text"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "persisting",
                "event": "LOADED",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AsyncTask",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AsyncTaskSaveFailed",
                        "success": "AsyncTaskSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "loading-state",
                          "title": "Saving...",
                          "message": "Persisting asynctask..."
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "onRetry": "RETRY",
                          "message": "An error occurred. Please try again.",
                          "title": "Operation Failed",
                          "type": "error-state"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "variant": "primary",
                              "label": "Retry",
                              "action": "RETRY",
                              "type": "button",
                              "icon": "refresh-cw"
                            },
                            {
                              "variant": "ghost",
                              "type": "button",
                              "icon": "rotate-ccw",
                              "action": "RESET",
                              "label": "Reset"
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "success",
                "event": "AsyncTaskSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Operation completed successfully.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "label": "Reset",
                              "variant": "ghost",
                              "action": "RESET"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AsyncTaskSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "error-state",
                          "message": "Could not persist asynctask.",
                          "onRetry": "RETRY",
                          "title": "Save Failed"
                        },
                        {
                          "icon": "refresh-cw",
                          "variant": "primary",
                          "type": "button",
                          "label": "Retry",
                          "action": "RETRY"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "success",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "content": "AsyncTask",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Ready to start asynctask operation.",
                          "variant": "body"
                        },
                        {
                          "action": "START",
                          "label": "Start",
                          "type": "button",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "AsyncTask"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Ready to start asynctask operation.",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "label": "Start",
                          "icon": "play",
                          "action": "START",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "message": "Processing asynctask...",
                          "title": "Loading...",
                          "type": "loading-state"
                        },
                        {
                          "variant": "text",
                          "type": "skeleton"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AsyncTaskPage",
          "path": "/asynctasks",
          "traits": [
            {
              "ref": "AsyncTaskAsync"
            }
          ]
        }
      ]
    }
  ]
}