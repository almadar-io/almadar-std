{
  "name": "std-agent-search",
  "version": "1.0.0",
  "description": "std-agent-search as a Function",
  "orbitals": [
    {
      "name": "AgentSearchOrbital",
      "entity": {
        "name": "AgentSearch",
        "collection": "agentsearchs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "results",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "type": "string",
            "default": ""
          },
          {
            "name": "resultCount",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AgentSearchBrowse",
          "category": "interaction",
          "linkedEntity": "AgentSearch",
          "emits": [
            {
              "event": "AgentSearchLoaded",
              "description": "Fired when AgentSearch finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "query",
                  "type": "string"
                },
                {
                  "name": "results",
                  "type": "[string]"
                },
                {
                  "name": "language",
                  "type": "string"
                },
                {
                  "name": "resultCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentSearchLoadFailed",
              "description": "Fired when AgentSearch fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEARCHED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "query",
                    "type": "string"
                  },
                  {
                    "name": "results",
                    "type": "[string]"
                  },
                  {
                    "name": "language",
                    "type": "string"
                  },
                  {
                    "name": "resultCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "AgentSearch"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "search",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "AgentSearch",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "icon": "search",
                                  "type": "button",
                                  "action": "SEARCH",
                                  "variant": "primary",
                                  "label": "Search"
                                },
                                {
                                  "label": "Clear",
                                  "variant": "ghost",
                                  "icon": "x",
                                  "action": "CLEAR",
                                  "type": "button"
                                }
                              ]
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "AgentSearch",
                          "fields": [
                            {
                              "icon": "search",
                              "variant": "h4",
                              "label": "Query",
                              "name": "query"
                            },
                            {
                              "colorMap": {
                                "pending": "warning",
                                "draft": "warning",
                                "inactive": "neutral",
                                "archived": "neutral",
                                "done": "success",
                                "disabled": "neutral",
                                "cancelled": "destructive",
                                "failed": "destructive",
                                "active": "success",
                                "completed": "success",
                                "error": "destructive",
                                "scheduled": "warning"
                              },
                              "name": "language",
                              "label": "Language",
                              "variant": "badge"
                            },
                            {
                              "name": "resultCount",
                              "label": "Result Count",
                              "variant": "caption"
                            }
                          ],
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "label": "View",
                              "event": "VIEW"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentSearchAgent",
          "category": "interaction",
          "linkedEntity": "AgentSearch",
          "emits": [
            {
              "event": "SEARCHED",
              "scope": "external",
              "payload": [
                {
                  "name": "query",
                  "type": "string"
                },
                {
                  "name": "resultCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentSearchLoaded",
              "description": "Fired when AgentSearch finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "query",
                  "type": "string"
                },
                {
                  "name": "results",
                  "type": "[string]"
                },
                {
                  "name": "language",
                  "type": "string"
                },
                {
                  "name": "resultCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentSearchLoadFailed",
              "description": "Fired when AgentSearch fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEARCHED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payload": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "language",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEARCHED",
                "name": "Searched"
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "query",
                    "type": "string"
                  },
                  {
                    "name": "results",
                    "type": "[string]"
                  },
                  {
                    "name": "language",
                    "type": "string"
                  },
                  {
                    "name": "resultCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Code Search",
                      "description": "Code Search is ready",
                      "icon": "search",
                      "type": "empty-state"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    "@payload.query"
                  ],
                  [
                    "set",
                    "@entity.language",
                    "@payload.language"
                  ],
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "success": "AgentSearchLoaded",
                        "failure": "AgentSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "SEARCHED"
                  ]
                ]
              },
              {
                "from": "results",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    "@payload.query"
                  ],
                  [
                    "set",
                    "@entity.language",
                    "@payload.language"
                  ],
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    ""
                  ],
                  [
                    "set",
                    "@entity.results",
                    []
                  ],
                  [
                    "set",
                    "@entity.language",
                    ""
                  ],
                  [
                    "set",
                    "@entity.resultCount",
                    0.0
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentSearchPage",
          "path": "/agentsearchs",
          "traits": [
            {
              "ref": "AgentSearchBrowse"
            },
            {
              "ref": "AgentSearchAgent"
            }
          ]
        }
      ]
    }
  ]
}