{
  "name": "std-rating",
  "version": "1.0.0",
  "description": "std-rating as a Function",
  "orbitals": [
    {
      "name": "ReviewOrbital",
      "entity": {
        "name": "Review",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "rating",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewRating",
          "category": "interaction",
          "linkedEntity": "Review",
          "emits": [
            {
              "event": "ReviewLoaded",
              "description": "Fired when Review finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "rating",
                  "type": "number"
                },
                {
                  "name": "comment",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewLoadFailed",
              "description": "Fired when Review fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "rated"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RATE",
                "name": "Rate",
                "payload": [
                  {
                    "name": "rating",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ReviewLoaded",
                "name": "Review loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "rating",
                    "type": "number"
                  },
                  {
                    "name": "comment",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewLoadFailed",
                "name": "Review load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Review",
                    {
                      "emit": {
                        "success": "ReviewLoaded",
                        "failure": "ReviewLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "star"
                            },
                            {
                              "content": "Rating",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "How would you rate this?",
                          "variant": "body"
                        },
                        {
                          "action": "RATE",
                          "value": "@entity.rating",
                          "type": "star-rating",
                          "max": 5.0
                        },
                        {
                          "action": "RATE",
                          "label": "Submit Rating",
                          "variant": "primary",
                          "type": "button",
                          "icon": "star"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "rated",
                "event": "RATE",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "content": "Thank You!",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "star-rating",
                          "max": 5.0,
                          "value": "@entity.rating",
                          "readOnly": true
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Your rating has been recorded."
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Rate Again",
                          "variant": "ghost",
                          "action": "RESET"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "rated",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "star",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Rating",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "How would you rate this?",
                          "type": "typography"
                        },
                        {
                          "max": 5.0,
                          "type": "star-rating",
                          "value": "@entity.rating",
                          "action": "RATE"
                        },
                        {
                          "icon": "star",
                          "type": "button",
                          "label": "Submit Rating",
                          "variant": "primary",
                          "action": "RATE"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ReviewRatingPage",
          "path": "/reviews/rating",
          "traits": [
            {
              "ref": "ReviewRating"
            }
          ]
        }
      ]
    }
  ]
}