{
  "name": "std-drawer",
  "version": "1.0.0",
  "description": "std-drawer as a Function",
  "orbitals": [
    {
      "name": "DrawerContentOrbital",
      "entity": {
        "name": "DrawerContent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DrawerContentDrawer",
          "category": "interaction",
          "linkedEntity": "DrawerContent",
          "emits": [
            {
              "event": "DrawerContentLoaded",
              "description": "Fired when DrawerContent finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DrawerContentLoadFailed",
              "description": "Fired when DrawerContent fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN",
                "name": "Open"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "DrawerContentLoaded",
                "name": "DrawerContent loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DrawerContentLoadFailed",
                "name": "DrawerContent load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "failure": "DrawerContentLoadFailed",
                        "success": "DrawerContentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "panel-right",
                                  "type": "icon"
                                },
                                {
                                  "content": "Details",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "action": "OPEN",
                              "type": "button",
                              "label": "Open",
                              "icon": "panel-right",
                              "variant": "primary"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "@item.name",
                                  "variant": "h4"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "entity": "DrawerContent"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
                "effects": [
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "success": "DrawerContentLoaded",
                        "failure": "DrawerContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "drawer",
                    {
                      "gap": "none",
                      "children": [
                        {
                          "title": "Details",
                          "type": "drawer",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "caption",
                                      "type": "typography",
                                      "content": "Name"
                                    },
                                    {
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "name"
                                      ],
                                      "type": "typography",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "justify": "between"
                                },
                                {
                                  "justify": "between",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Description"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "description"
                                      ]
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "type": "stack"
                                },
                                {
                                  "gap": "md",
                                  "justify": "between",
                                  "children": [
                                    {
                                      "variant": "caption",
                                      "type": "typography",
                                      "content": "Status"
                                    },
                                    {
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "status"
                                      ],
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal"
                                },
                                {
                                  "justify": "between",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "content": "CreatedAt",
                                      "variant": "caption",
                                      "type": "typography"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "createdAt"
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "action": "CLOSE",
                                      "type": "button",
                                      "label": "Close",
                                      "variant": "ghost"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "justify": "end"
                                }
                              ]
                            }
                          ],
                          "isOpen": true
                        },
                        {
                          "title": "Details",
                          "position": "right",
                          "isOpen": true,
                          "onClose": "CLOSE",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "justify": "between",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Name"
                                    },
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "name"
                                      ]
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "gap": "md",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Description"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "description"
                                      ]
                                    }
                                  ],
                                  "justify": "between",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "justify": "between",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "Status"
                                    },
                                    {
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "status"
                                      ],
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "md"
                                },
                                {
                                  "justify": "between",
                                  "gap": "md",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "CreatedAt"
                                    },
                                    {
                                      "variant": "body",
                                      "content": [
                                        "object/get",
                                        [
                                          "array/first",
                                          "@entity"
                                        ],
                                        "createdAt"
                                      ],
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md"
                            }
                          ],
                          "type": "side-panel"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "failure": "DrawerContentLoadFailed",
                        "success": "DrawerContentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "panel-right"
                                },
                                {
                                  "content": "Details",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "action": "OPEN",
                              "type": "button",
                              "variant": "primary",
                              "label": "Open",
                              "icon": "panel-right"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "type": "data-grid",
                          "entity": "DrawerContent",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "@item.name",
                                  "variant": "h4"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DrawerContentDrawerPage",
          "path": "/drawercontents/drawer",
          "traits": [
            {
              "ref": "DrawerContentDrawer"
            }
          ]
        }
      ]
    }
  ]
}