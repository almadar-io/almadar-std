{
  "name": "std-selection",
  "version": "1.0.0",
  "description": "std-selection as a Function",
  "orbitals": [
    {
      "name": "SelectableItemOrbital",
      "entity": {
        "name": "SelectableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SelectableItemSelection",
          "category": "interaction",
          "linkedEntity": "SelectableItem",
          "emits": [
            {
              "event": "SelectableItemLoaded",
              "description": "Fired when SelectableItem finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SelectableItemLoadFailed",
              "description": "Fired when SelectableItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "selecting"
              },
              {
                "name": "selected"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT",
                "name": "Select",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DESELECT",
                "name": "Deselect"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "CONFIRM_SELECTION",
                "name": "Confirm Selection",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SelectableItemLoaded",
                "name": "SelectableItem loaded"
              },
              {
                "key": "SelectableItemLoadFailed",
                "name": "SelectableItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "success": "SelectableItemLoaded",
                        "failure": "SelectableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "check-square",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "content": "SelectableItems",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Choose a selectableitem to continue."
                        },
                        {
                          "itemActions": [
                            {
                              "icon": "check",
                              "event": "SELECT",
                              "label": "Select"
                            }
                          ],
                          "emptyTitle": "No selectableitems yet",
                          "type": "data-grid",
                          "emptyDescription": "Add selectableitems to see them here.",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "label": "@item.name",
                                  "type": "checkbox"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm"
                            }
                          ],
                          "entity": "SelectableItem",
                          "emptyIcon": "inbox"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "selecting",
                "event": "SELECT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "justify": "space-between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "check-square",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "content": "SelectableItems",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "gap": "sm",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "Selecting"
                                },
                                {
                                  "event": "CLEAR",
                                  "type": "button",
                                  "label": "Clear",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "info",
                          "message": [
                            "concat",
                            "Selected: ",
                            "@payload.id"
                          ]
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Select",
                              "event": "SELECT",
                              "icon": "check"
                            }
                          ],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "checked": [
                                    "==",
                                    "@item.id",
                                    "@payload.id"
                                  ],
                                  "type": "checkbox",
                                  "label": "@item.name"
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ],
                          "emptyTitle": "No selectableitems yet",
                          "entity": "SelectableItem",
                          "emptyIcon": "inbox",
                          "emptyDescription": "Add selectableitems to see them here.",
                          "type": "data-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "secondary",
                              "action": "SELECT",
                              "label": "Select All",
                              "type": "button",
                              "icon": "check-square"
                            },
                            {
                              "type": "button",
                              "action": "DESELECT",
                              "icon": "square",
                              "label": "Deselect All",
                              "variant": "secondary"
                            },
                            {
                              "variant": "primary",
                              "icon": "check",
                              "action": "CONFIRM_SELECTION",
                              "type": "button",
                              "label": "Confirm"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "selecting",
                "event": "SELECT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "check-square"
                                },
                                {
                                  "type": "typography",
                                  "content": "SelectableItems",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "Selecting",
                                  "type": "badge"
                                },
                                {
                                  "label": "Clear",
                                  "type": "button",
                                  "event": "CLEAR",
                                  "variant": "ghost",
                                  "icon": "x"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "info",
                          "message": [
                            "concat",
                            "Selected: ",
                            "@payload.id"
                          ],
                          "type": "alert"
                        },
                        {
                          "emptyIcon": "inbox",
                          "entity": "SelectableItem",
                          "type": "data-grid",
                          "emptyTitle": "No selectableitems yet",
                          "itemActions": [
                            {
                              "event": "SELECT",
                              "label": "Select",
                              "icon": "check"
                            }
                          ],
                          "emptyDescription": "Add selectableitems to see them here.",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "checkbox",
                                  "label": "@item.name",
                                  "checked": [
                                    "==",
                                    "@item.id",
                                    "@payload.id"
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "check-square",
                              "action": "SELECT",
                              "variant": "secondary",
                              "type": "button",
                              "label": "Select All"
                            },
                            {
                              "icon": "square",
                              "action": "DESELECT",
                              "label": "Deselect All",
                              "variant": "secondary",
                              "type": "button"
                            },
                            {
                              "action": "CONFIRM_SELECTION",
                              "type": "button",
                              "variant": "primary",
                              "icon": "check",
                              "label": "Confirm"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "idle",
                "event": "DESELECT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "check-square",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "content": "SelectableItems",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "content": "Choose a selectableitem to continue.",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "emptyTitle": "No selectableitems yet",
                          "itemActions": [
                            {
                              "event": "SELECT",
                              "label": "Select",
                              "icon": "check"
                            }
                          ],
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "type": "data-grid",
                          "entity": "SelectableItem",
                          "emptyIcon": "inbox",
                          "emptyDescription": "Add selectableitems to see them here.",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "@item.name",
                                  "type": "checkbox"
                                }
                              ],
                              "align": "center"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "check-square",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "SelectableItems"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Choose a selectableitem to continue.",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "emptyDescription": "Add selectableitems to see them here.",
                          "entity": "SelectableItem",
                          "emptyTitle": "No selectableitems yet",
                          "itemActions": [
                            {
                              "icon": "check",
                              "event": "SELECT",
                              "label": "Select"
                            }
                          ],
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "checkbox",
                                  "label": "@item.name"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "selected",
                "event": "CONFIRM_SELECTION",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "check-circle",
                                  "size": "lg"
                                },
                                {
                                  "content": "Selection Confirmed",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "label": "Confirmed",
                              "type": "badge"
                            }
                          ],
                          "justify": "space-between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Selection confirmed successfully.",
                          "variant": "success"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "content": "Selected ID:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@payload.id"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "event": "CLEAR",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Clear Selection",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "selected",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "check-square"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "SelectableItems"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Choose a selectableitem to continue.",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "emptyTitle": "No selectableitems yet",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "checkbox",
                                  "label": "@item.name"
                                }
                              ]
                            }
                          ],
                          "type": "data-grid",
                          "emptyIcon": "inbox",
                          "itemActions": [
                            {
                              "label": "Select",
                              "event": "SELECT",
                              "icon": "check"
                            }
                          ],
                          "entity": "SelectableItem",
                          "emptyDescription": "Add selectableitems to see them here."
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SelectableItemSelectionPage",
          "path": "/selectableitems/selection",
          "traits": [
            {
              "ref": "SelectableItemSelection"
            }
          ]
        }
      ]
    }
  ]
}