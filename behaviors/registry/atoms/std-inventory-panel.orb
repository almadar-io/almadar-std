{
  "name": "std-inventory-panel",
  "version": "1.0.0",
  "description": "std-inventory-panel as a Function",
  "orbitals": [
    {
      "name": "InventorySlotOrbital",
      "entity": {
        "name": "InventorySlot",
        "persistence": "singleton",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "items",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "traits": [
        {
          "name": "InventorySlotInventoryPanel",
          "category": "interaction",
          "linkedEntity": "InventorySlot",
          "emits": [
            {
              "event": "InventorySlotLoaded",
              "description": "Fired when InventorySlot finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "items",
                  "type": "[string]"
                }
              ]
            },
            {
              "event": "InventorySlotLoadFailed",
              "description": "Fired when InventorySlot fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InventorySlotDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InventorySlotDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "payload": [
                  {
                    "name": "slotId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "USE_ITEM",
                "name": "Use Item",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DROP_ITEM",
                "name": "Drop Item",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "InventorySlotLoaded",
                "name": "InventorySlot loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "items",
                    "type": "[string]"
                  }
                ]
              },
              {
                "key": "InventorySlotLoadFailed",
                "name": "InventorySlot load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "InventorySlotDeleted",
                "name": "InventorySlot deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "InventorySlotDeleteFailed",
                "name": "InventorySlot delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventorySlot",
                    {
                      "emit": {
                        "success": "InventorySlotLoaded",
                        "failure": "InventorySlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "slots": 16.0,
                      "columns": 4.0,
                      "showTooltips": true,
                      "type": "inventory-panel",
                      "items": "@entity.items",
                      "selectSlotEvent": "SELECT_SLOT",
                      "useItemEvent": "USE_ITEM",
                      "dropItemEvent": "DROP_ITEM"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_SLOT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "slots": 16.0,
                      "type": "inventory-panel",
                      "columns": 4.0,
                      "selectSlotEvent": "SELECT_SLOT",
                      "dropItemEvent": "DROP_ITEM",
                      "useItemEvent": "USE_ITEM",
                      "showTooltips": true,
                      "items": "@entity.items"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "USE_ITEM",
                "effects": [
                  [
                    "fetch",
                    "InventorySlot",
                    {
                      "emit": {
                        "failure": "InventorySlotLoadFailed",
                        "success": "InventorySlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "selectSlotEvent": "SELECT_SLOT",
                      "dropItemEvent": "DROP_ITEM",
                      "type": "inventory-panel",
                      "useItemEvent": "USE_ITEM",
                      "items": "@entity.items",
                      "columns": 4.0,
                      "showTooltips": true,
                      "slots": 16.0
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DROP_ITEM",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "InventorySlot",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "InventorySlotDeleted",
                        "failure": "InventorySlotDeleteFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "InventorySlot",
                    {
                      "emit": {
                        "failure": "InventorySlotLoadFailed",
                        "success": "InventorySlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "items": "@entity.items",
                      "columns": 4.0,
                      "useItemEvent": "USE_ITEM",
                      "type": "inventory-panel",
                      "dropItemEvent": "DROP_ITEM",
                      "selectSlotEvent": "SELECT_SLOT",
                      "slots": 16.0,
                      "showTooltips": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InventorySlotInventoryPage",
          "path": "/inventoryslots",
          "traits": [
            {
              "ref": "InventorySlotInventoryPanel"
            }
          ]
        }
      ]
    }
  ]
}