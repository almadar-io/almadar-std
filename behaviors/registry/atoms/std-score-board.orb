{
  "name": "std-score-board",
  "version": "1.0.0",
  "description": "std-score-board as a Function",
  "orbitals": [
    {
      "name": "ScoreBoardEntryOrbital",
      "entity": {
        "name": "ScoreBoardEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "highScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "combo",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "multiplier",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "ScoreBoardEntryScoreBoard",
          "category": "interaction",
          "linkedEntity": "ScoreBoardEntry",
          "emits": [
            {
              "event": "ScoreBoardEntryLoaded",
              "description": "Fired when ScoreBoardEntry finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "highScore",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ScoreBoardEntryLoadFailed",
              "description": "Fired when ScoreBoardEntry fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_SCORE",
                "name": "Add Score",
                "payload": [
                  {
                    "name": "points",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ScoreBoardEntryLoaded",
                "name": "ScoreBoardEntry loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ScoreBoardEntryLoadFailed",
                "name": "ScoreBoardEntry load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ScoreBoardEntry",
                    {
                      "emit": {
                        "failure": "ScoreBoardEntryLoadFailed",
                        "success": "ScoreBoardEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "level": "@entity.level",
                      "score": "@entity.score",
                      "multiplier": "@entity.multiplier",
                      "type": "score-board",
                      "highScore": "@entity.highScore",
                      "combo": "@entity.combo"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "score-board",
                      "highScore": "@entity.highScore",
                      "multiplier": "@entity.multiplier",
                      "score": "@entity.score",
                      "combo": "@entity.combo",
                      "level": "@entity.level"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "highScore": "@entity.highScore",
                      "multiplier": "@entity.multiplier",
                      "type": "score-board",
                      "combo": "@entity.combo",
                      "score": "@entity.score",
                      "level": "@entity.level"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "combo": "@entity.combo",
                      "highScore": "@entity.highScore",
                      "level": "@entity.level",
                      "score": "@entity.score",
                      "type": "score-board",
                      "multiplier": "@entity.multiplier"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ScoreBoardEntryScorePage",
          "path": "/scoreboardentrys",
          "traits": [
            {
              "ref": "ScoreBoardEntryScoreBoard"
            }
          ]
        }
      ]
    }
  ]
}