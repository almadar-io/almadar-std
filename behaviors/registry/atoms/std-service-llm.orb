{
  "name": "std-service-llm",
  "version": "1.0.0",
  "description": "std-service-llm as a Function",
  "orbitals": [
    {
      "name": "ServiceLlmOrbital",
      "entity": {
        "name": "ServiceLlm",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "inputText",
            "type": "string",
            "default": ""
          },
          {
            "name": "action",
            "type": "string",
            "default": "generate"
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "llmStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceLlmLlm",
          "category": "interaction",
          "linkedEntity": "ServiceLlm",
          "emits": [
            {
              "event": "ServiceLlmLoaded",
              "description": "Fired when ServiceLlm finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "inputText",
                  "type": "string"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "llmStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLoadFailed",
              "description": "Fired when ServiceLlm fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "processing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "CLASSIFY",
                "name": "Classify"
              },
              {
                "key": "SUMMARIZE",
                "name": "Summarize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceLlmLoaded",
                "name": "ServiceLlm loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "inputText",
                    "type": "string"
                  },
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "llmStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceLlmLoadFailed",
                "name": "ServiceLlm load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceLlm",
                    {
                      "emit": {
                        "failure": "ServiceLlmLoadFailed",
                        "success": "ServiceLlmLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "ServiceLlm LLM",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "label": "Input Text",
                          "bind": "@entity.inputText",
                          "placeholder": "Enter text for LLM processing...",
                          "type": "textarea"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Generate",
                              "event": "GENERATE",
                              "icon": "sparkles",
                              "variant": "primary"
                            },
                            {
                              "icon": "tag",
                              "label": "Classify",
                              "type": "button",
                              "variant": "secondary",
                              "event": "CLASSIFY"
                            },
                            {
                              "label": "Summarize",
                              "event": "SUMMARIZE",
                              "variant": "secondary",
                              "icon": "align-left",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "generate"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Processing...",
                      "message": "Running servicellm LLM task..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "generate",
                    {
                      "userPrompt": "@entity.inputText"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "CLASSIFY",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "classify"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Processing...",
                      "message": "Running servicellm LLM task...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "classify",
                    {
                      "text": "@entity.inputText",
                      "categories": [
                        "positive",
                        "negative",
                        "neutral"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "SUMMARIZE",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "summarize"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Processing...",
                      "type": "loading-state",
                      "message": "Running servicellm LLM task..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "summarize",
                    {
                      "text": "@entity.inputText"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "size": "lg"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "LLM task complete"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.result"
                        },
                        {
                          "icon": "rotate-ccw",
                          "event": "RESET",
                          "variant": "ghost",
                          "type": "button",
                          "label": "Start Over"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "title": "LLM Failed",
                          "type": "error-state",
                          "message": "@entity.error",
                          "onRetry": "RETRY"
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "label": "Retry",
                              "event": "RETRY",
                              "type": "button",
                              "icon": "refresh-cw"
                            },
                            {
                              "icon": "rotate-ccw",
                              "event": "RESET",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Reset"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "size": "lg",
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "content": "ServiceLlm LLM",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Enter text for LLM processing...",
                          "type": "textarea",
                          "bind": "@entity.inputText",
                          "label": "Input Text"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Generate",
                              "event": "GENERATE",
                              "icon": "sparkles",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "icon": "tag",
                              "label": "Classify",
                              "event": "CLASSIFY",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "type": "button",
                              "label": "Summarize",
                              "event": "SUMMARIZE",
                              "icon": "align-left",
                              "variant": "secondary"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "stretch",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceLlm LLM"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Enter text for LLM processing...",
                          "label": "Input Text",
                          "bind": "@entity.inputText"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Generate",
                              "event": "GENERATE",
                              "icon": "sparkles",
                              "variant": "primary",
                              "type": "button"
                            },
                            {
                              "label": "Classify",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "tag",
                              "event": "CLASSIFY"
                            },
                            {
                              "type": "button",
                              "label": "Summarize",
                              "event": "SUMMARIZE",
                              "icon": "align-left",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "stretch",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "brain"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceLlm LLM"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "label": "Input Text",
                          "bind": "@entity.inputText",
                          "placeholder": "Enter text for LLM processing..."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Generate",
                              "event": "GENERATE",
                              "icon": "sparkles",
                              "variant": "primary"
                            },
                            {
                              "event": "CLASSIFY",
                              "label": "Classify",
                              "icon": "tag",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "label": "Summarize",
                              "type": "button",
                              "variant": "secondary",
                              "icon": "align-left",
                              "event": "SUMMARIZE"
                            }
                          ],
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceLlmPage",
          "path": "/servicellms",
          "traits": [
            {
              "ref": "ServiceLlmLlm"
            }
          ]
        }
      ]
    }
  ]
}