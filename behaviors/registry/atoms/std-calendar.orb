                            {
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "clock",
                                  "type": "icon"
                                },
                                {
                                  "content": "Day View",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "variant": "ghost",
                              "icon": "arrow-left",
                              "label": "Back to Month",
                              "type": "button",
                              "action": "BACK"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h4",
                          "type": "typography",
                          "content": "Events for Selected Day"
                        },
                        {
                          "type": "data-grid",
                          "entity": "CalendarEvent",
                          "itemActions": [
                            {
                              "label": "Select",
                              "icon": "check",
                              "event": "SELECT_SLOT"
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "icon": "clock",
                              "label": "Event"
                            },
                            {
                              "label": "Time",
                              "variant": "badge",
                              "name": "time"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
