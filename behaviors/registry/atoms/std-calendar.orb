{
  "name": "std-calendar",
  "version": "1.0.0",
  "description": "std-calendar as a Function",
  "orbitals": [
    {
      "name": "CalendarEventOrbital",
      "entity": {
        "name": "CalendarEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "string",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0
          }
        ]
      },
      "traits": [
        {
          "name": "CalendarEventCalendar",
          "category": "interaction",
          "linkedEntity": "CalendarEvent",
          "emits": [
            {
              "event": "CalendarEventLoaded",
              "description": "Fired when CalendarEvent finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "date",
                  "type": "string"
                },
                {
                  "name": "time",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CalendarEventLoadFailed",
              "description": "Fired when CalendarEvent fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "month-view",
                "isInitial": true
              },
              {
                "name": "day-view"
              },
              {
                "name": "slot-selected"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_DAY",
                "name": "Select Day",
                "payload": [
                  {
                    "name": "date",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "payload": [
                  {
                    "name": "time",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "BACK",
                "name": "Back"
              },
              {
                "key": "CalendarEventLoaded",
                "name": "CalendarEvent loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "date",
                    "type": "string"
                  },
                  {
                    "name": "time",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "CalendarEventLoadFailed",
                "name": "CalendarEvent load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "month-view",
                "to": "month-view",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "failure": "CalendarEventLoadFailed",
                        "success": "CalendarEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "calendar",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "CalendarEvents Calendar",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "type": "date-range-selector",
                              "startDate": "2026-01-01",
                              "endDate": "2026-12-31",
                              "onSelect": "SELECT_DAY"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "calendar-grid",
                          "month": 3.0,
                          "year": 2026.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "content": "Upcoming Events",
                          "variant": "h4"
                        },
                        {
                          "fields": [
                            {
                              "name": "name",
                              "icon": "calendar",
                              "variant": "h4",
                              "label": "Event"
                            },
                            {
                              "label": "Time",
                              "name": "time",
                              "variant": "badge"
                            },
                            {
                              "label": "Date",
                              "name": "date",
                              "format": "date",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "type": "data-list",
                          "itemActions": [
                            {
                              "label": "View",
                              "icon": "eye",
                              "event": "SELECT_DAY"
                            }
                          ],
                          "entity": "CalendarEvent"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "month-view",
                "to": "day-view",
                "event": "SELECT_DAY",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "md",
