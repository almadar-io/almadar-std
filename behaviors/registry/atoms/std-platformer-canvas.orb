{
  "name": "std-platformer-canvas",
  "version": "1.0.0",
  "description": "std-platformer-canvas as a Function",
  "orbitals": [
    {
      "name": "PlatformerWorldOrbital",
      "entity": {
        "name": "PlatformerWorld",
        "persistence": "singleton",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "platforms",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "player",
            "type": "object"
          }
        ]
      },
      "traits": [
        {
          "name": "PlatformerWorldPlatformerCanvas",
          "category": "interaction",
          "linkedEntity": "PlatformerWorld",
          "emits": [
            {
              "event": "PlatformerWorldLoaded",
              "description": "Fired when PlatformerWorld finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "platforms",
                  "type": "[string]"
                },
                {
                  "name": "player",
                  "type": "object"
                }
              ]
            },
            {
              "event": "PlatformerWorldLoadFailed",
              "description": "Fired when PlatformerWorld fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PlatformerWorldLoaded",
                "name": "PlatformerWorld loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "platforms",
                    "type": "[string]"
                  },
                  {
                    "name": "player",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "PlatformerWorldLoadFailed",
                "name": "PlatformerWorld load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatformerWorld",
                    {
                      "emit": {
                        "success": "PlatformerWorldLoaded",
                        "failure": "PlatformerWorldLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "worldWidth": 2400.0,
                      "canvasHeight": 400.0,
                      "player": "@entity.player",
                      "bgColor": "#1a1a2e",
                      "leftEvent": "LEFT",
                      "rightEvent": "RIGHT",
                      "canvasWidth": 800.0,
                      "followCamera": true,
                      "jumpEvent": "JUMP",
                      "platforms": "@entity.platforms",
                      "type": "platformer-canvas",
                      "stopEvent": "STOP",
                      "worldHeight": 400.0
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "running",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "worldWidth": 2400.0,
                      "player": "@entity.player",
                      "type": "platformer-canvas",
                      "canvasWidth": 800.0,
                      "canvasHeight": 400.0,
                      "stopEvent": "STOP",
                      "rightEvent": "RIGHT",
                      "leftEvent": "LEFT",
                      "worldHeight": 400.0,
                      "bgColor": "#1a1a2e",
                      "platforms": "@entity.platforms",
                      "followCamera": true,
                      "jumpEvent": "JUMP"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "LEFT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "RIGHT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "JUMP"
              },
              {
                "from": "running",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "canvasHeight": 400.0,
                      "leftEvent": "LEFT",
                      "rightEvent": "RIGHT",
                      "jumpEvent": "JUMP",
                      "stopEvent": "STOP",
                      "worldWidth": 2400.0,
                      "player": "@entity.player",
                      "bgColor": "#1a1a2e",
                      "type": "platformer-canvas",
                      "worldHeight": 400.0,
                      "platforms": "@entity.platforms",
                      "canvasWidth": 800.0,
                      "followCamera": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PlatformerWorldPlatformerPage",
          "path": "/platformerworlds",
          "traits": [
            {
              "ref": "PlatformerWorldPlatformerCanvas"
            }
          ]
        }
      ]
    }
  ]
}
