{
  "name": "std-isometric-canvas",
  "version": "1.0.0",
  "description": "std-isometric-canvas as a Function",
  "orbitals": [
    {
      "name": "IsometricWorldOrbital",
      "entity": {
        "name": "IsometricWorld",
        "persistence": "singleton",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "tiles",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "features",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "traits": [
        {
          "name": "IsometricWorldIsometricCanvas",
          "category": "interaction",
          "linkedEntity": "IsometricWorld",
          "emits": [
            {
              "event": "IsometricWorldLoaded",
              "description": "Fired when IsometricWorld finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "tiles",
                  "type": "[string]"
                },
                {
                  "name": "units",
                  "type": "[string]"
                },
                {
                  "name": "features",
                  "type": "[string]"
                }
              ]
            },
            {
              "event": "IsometricWorldLoadFailed",
              "description": "Fired when IsometricWorld fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TILE_CLICK",
                "name": "Tile Click",
                "payload": [
                  {
                    "name": "tileId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UNIT_CLICK",
                "name": "Unit Click",
                "payload": [
                  {
                    "name": "unitId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TILE_HOVER",
                "name": "Tile Hover"
              },
              {
                "key": "TILE_LEAVE",
                "name": "Tile Leave"
              },
              {
                "key": "DESELECT",
                "name": "Deselect"
              },
              {
                "key": "IsometricWorldLoaded",
                "name": "IsometricWorld loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "tiles",
                    "type": "[string]"
                  },
                  {
                    "name": "units",
                    "type": "[string]"
                  },
                  {
                    "name": "features",
                    "type": "[string]"
                  }
                ]
              },
              {
                "key": "IsometricWorldLoadFailed",
                "name": "IsometricWorld load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "IsometricWorld",
                    {
                      "emit": {
                        "success": "IsometricWorldLoaded",
                        "failure": "IsometricWorldLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "tileLeaveEvent": "TILE_LEAVE",
                      "debug": false,
                      "unitClickEvent": "UNIT_CLICK",
                      "showMinimap": false,
                      "enableCamera": true,
                      "tileClickEvent": "TILE_CLICK",
                      "tiles": "@entity.tiles",
                      "unitScale": 2.0,
                      "tileHoverEvent": "TILE_HOVER",
                      "boardWidth": 8.0,
                      "type": "isometric-canvas",
                      "scale": 1.0,
                      "boardHeight": 8.0
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "TILE_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "tiles": "@entity.tiles",
                      "boardWidth": 8.0,
                      "tileClickEvent": "TILE_CLICK",
                      "unitClickEvent": "UNIT_CLICK",
                      "tileHoverEvent": "TILE_HOVER",
                      "tileLeaveEvent": "TILE_LEAVE",
                      "type": "isometric-canvas",
                      "boardHeight": 8.0,
                      "showMinimap": false,
                      "enableCamera": true,
                      "unitScale": 2.0,
                      "scale": 1.0,
                      "debug": false
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "UNIT_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "scale": 1.0,
                      "boardWidth": 8.0,
                      "unitClickEvent": "UNIT_CLICK",
                      "tileClickEvent": "TILE_CLICK",
                      "showMinimap": false,
                      "tiles": "@entity.tiles",
                      "type": "isometric-canvas",
                      "tileLeaveEvent": "TILE_LEAVE",
                      "boardHeight": 8.0,
                      "unitScale": 2.0,
                      "debug": false,
                      "enableCamera": true,
                      "tileHoverEvent": "TILE_HOVER"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TILE_HOVER"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TILE_LEAVE"
              },
              {
                "from": "active",
                "to": "active",
                "event": "TILE_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "tileHoverEvent": "TILE_HOVER",
                      "scale": 1.0,
                      "enableCamera": true,
                      "boardWidth": 8.0,
                      "showMinimap": false,
                      "tileClickEvent": "TILE_CLICK",
                      "debug": false,
                      "unitScale": 2.0,
                      "tileLeaveEvent": "TILE_LEAVE",
                      "boardHeight": 8.0,
                      "tiles": "@entity.tiles",
                      "unitClickEvent": "UNIT_CLICK",
                      "type": "isometric-canvas"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "UNIT_CLICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "tileHoverEvent": "TILE_HOVER",
                      "showMinimap": false,
                      "boardHeight": 8.0,
                      "boardWidth": 8.0,
                      "type": "isometric-canvas",
                      "enableCamera": true,
                      "tileClickEvent": "TILE_CLICK",
                      "debug": false,
                      "tileLeaveEvent": "TILE_LEAVE",
                      "unitScale": 2.0,
                      "scale": 1.0,
                      "unitClickEvent": "UNIT_CLICK",
                      "tiles": "@entity.tiles"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "TILE_HOVER"
              },
              {
                "from": "active",
                "to": "active",
                "event": "TILE_LEAVE"
              },
              {
                "from": "active",
                "to": "idle",
                "event": "DESELECT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "enableCamera": true,
                      "tileLeaveEvent": "TILE_LEAVE",
                      "unitClickEvent": "UNIT_CLICK",
                      "tileClickEvent": "TILE_CLICK",
                      "type": "isometric-canvas",
                      "scale": 1.0,
                      "boardWidth": 8.0,
                      "tileHoverEvent": "TILE_HOVER",
                      "debug": false,
                      "unitScale": 2.0,
                      "tiles": "@entity.tiles",
                      "boardHeight": 8.0,
                      "showMinimap": false
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "IsometricWorldCanvasPage",
          "path": "/isometricworlds",
          "traits": [
            {
              "ref": "IsometricWorldIsometricCanvas"
            }
          ]
        }
      ]
    }
  ]
}