{
  "name": "std-agent-activity-log",
  "version": "1.0.0",
  "description": "std-agent-activity-log as a Function",
  "orbitals": [
    {
      "name": "AgentActivityLogOrbital",
      "entity": {
        "name": "AgentActivityLog",
        "collection": "agentactivitylogs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentActivityLogLog",
          "category": "interaction",
          "linkedEntity": "AgentActivityLog",
          "emits": [
            {
              "event": "LOG_ENTRY",
              "scope": "external",
              "payload": [
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoaded",
              "description": "Fired when AgentActivityLog finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "number"
                },
                {
                  "name": "icon",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoadFailed",
              "description": "Fired when AgentActivityLog fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.LOG_ENTRY",
              "triggers": "LOG_ENTRY"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "logging",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry",
                "payload": [
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "AgentActivityLogLoaded",
                "name": "AgentActivityLog loaded"
              },
              {
                "key": "AgentActivityLogLoadFailed",
                "name": "AgentActivityLog load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "logging",
                "to": "logging",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "activity",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Activity Log"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "label": "Clear",
                              "event": "CLEAR",
                              "variant": "ghost",
                              "icon": "trash",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "timeline",
                          "emptyIcon": "activity",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.status"
                                    },
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "@item.action"
                                    }
                                  ]
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "@item.detail"
                                },
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted",
                                      "content": "@item.timestamp"
                                    },
                                    {
                                      "label": "@item.duration",
                                      "type": "badge",
                                      "variant": "outline"
                                    }
                                  ]
                                }
                              ],
                              "type": "stack",
                              "gap": "xs"
                            }
                          ],
                          "entity": "AgentActivityLog",
                          "emptyTitle": "No activity yet",
                          "emptyDescription": "Agent actions will appear here as they occur."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "logging",
                "event": "LOG_ENTRY",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentActivityLog",
                    {
                      "action": "@payload.action",
                      "status": "@payload.status",
                      "detail": "@payload.detail",
                      "timestamp": "@now"
                    }
                  ],
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "justify": "space-between",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "content": "Activity Log",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "event": "CLEAR",
                              "variant": "ghost",
                              "icon": "trash",
                              "label": "Clear",
                              "type": "button"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "emptyTitle": "No activity yet",
                          "entity": "AgentActivityLog",
                          "emptyDescription": "Agent actions will appear here as they occur.",
                          "emptyIcon": "activity",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.status"
                                    },
                                    {
                                      "variant": "h4",
                                      "content": "@item.action",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "variant": "body",
                                  "color": "muted",
                                  "content": "@item.detail",
                                  "type": "typography"
                                },
                                {
                                  "align": "center",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "content": "@item.timestamp",
                                      "variant": "caption",
                                      "type": "typography",
                                      "color": "muted"
                                    },
                                    {
                                      "label": "@item.duration",
                                      "type": "badge",
                                      "variant": "outline"
                                    }
                                  ]
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ],
                          "type": "timeline"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "logging",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentActivityLog"
                  ],
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "content": "Activity Log",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "event": "CLEAR",
                              "type": "button",
                              "label": "Clear",
                              "variant": "ghost",
                              "icon": "trash"
                            }
                          ],
                          "type": "stack",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "emptyIcon": "activity",
                          "emptyDescription": "Agent actions will appear here as they occur.",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "gap": "xs",
                              "children": [
                                {
                                  "align": "center",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "label": "@item.status",
                                      "type": "badge"
                                    },
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "@item.action"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "body",
                                  "content": "@item.detail"
                                },
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "variant": "caption",
                                      "type": "typography",
                                      "content": "@item.timestamp",
                                      "color": "muted"
                                    },
                                    {
                                      "label": "@item.duration",
                                      "type": "badge",
                                      "variant": "outline"
                                    }
                                  ],
                                  "align": "center"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "type": "timeline",
                          "emptyTitle": "No activity yet",
                          "entity": "AgentActivityLog"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentActivityLogPage",
          "path": "/agentactivitylogs",
          "traits": [
            {
              "ref": "AgentActivityLogLog"
            }
          ]
        }
      ]
    }
  ]
}