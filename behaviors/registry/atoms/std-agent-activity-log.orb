{
  "name": "std-agent-activity-log",
  "version": "1.0.0",
  "description": "std-agent-activity-log as a Function",
  "orbitals": [
    {
      "name": "AgentActivityLogOrbital",
      "entity": {
        "name": "AgentActivityLog",
        "collection": "agentactivitylogs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentActivityLogLog",
          "category": "interaction",
          "linkedEntity": "AgentActivityLog",
          "emits": [
            {
              "event": "LOG_ENTRY",
              "scope": "external",
              "payload": [
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoaded",
              "description": "Fired when AgentActivityLog finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "number"
                },
                {
                  "name": "icon",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoadFailed",
              "description": "Fired when AgentActivityLog fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LOG_ENTRY",
              "triggers": "LOG_ENTRY",
              "source": {
                "kind": "trait",
                "trait": "AgentActivityLogLog"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "logging",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry",
                "payload": [
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "AgentActivityLogLoaded",
                "name": "AgentActivityLog loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "timestamp",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "number"
                  },
                  {
                    "name": "icon",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogLoadFailed",
                "name": "AgentActivityLog load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogSaved",
                "name": "AgentActivityLog saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogSaveFailed",
                "name": "AgentActivityLog save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleted",
                "name": "AgentActivityLog deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleteFailed",
                "name": "AgentActivityLog delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "logging",
                "to": "logging",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Activity Log"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "label": "Clear",
                              "icon": "trash",
                              "type": "button",
                              "action": "CLEAR",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "timeline",
                          "entity": "AgentActivityLog",
                          "fields": []
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "logging",
                "event": "LOG_ENTRY",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentActivityLog",
                    {
                      "status": "@payload.status",
                      "timestamp": "@now",
                      "detail": "@payload.detail",
                      "action": "@payload.action"
                    },
                    {
                      "emit": {
                        "failure": "AgentActivityLogSaveFailed",
                        "success": "AgentActivityLogSaved"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon"
                                },
                                {
                                  "content": "Activity Log",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "action": "CLEAR",
                              "variant": "ghost",
                              "type": "button",
                              "icon": "trash",
                              "label": "Clear"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "entity": "AgentActivityLog",
                          "type": "timeline"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "logging",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogDeleteFailed",
                        "success": "AgentActivityLogDeleted"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Activity Log",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "icon": "trash",
                              "label": "Clear",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLEAR"
                            }
                          ],
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "entity": "AgentActivityLog",
                          "type": "timeline"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentActivityLogPage",
          "path": "/agentactivitylogs",
          "traits": [
            {
              "ref": "AgentActivityLogLog"
            }
          ]
        }
      ]
    }
  ]
}