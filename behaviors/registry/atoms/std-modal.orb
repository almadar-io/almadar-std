{
  "name": "std-modal",
  "version": "1.0.0",
  "description": "std-modal as a Function",
  "orbitals": [
    {
      "name": "ModalRecordOrbital",
      "entity": {
        "name": "ModalRecord",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ModalRecordModal",
          "category": "interaction",
          "linkedEntity": "ModalRecord",
          "emits": [
            {
              "event": "SAVE",
              "scope": "external"
            },
            {
              "event": "ModalRecordLoaded",
              "description": "Fired when ModalRecord finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModalRecordLoadFailed",
              "description": "Fired when ModalRecord fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "closed"
              },
              {
                "name": "open"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ModalRecordLoaded",
                "name": "ModalRecord loaded"
              },
              {
                "key": "ModalRecordLoadFailed",
                "name": "ModalRecord load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModalRecord",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "size": "lg",
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "closed",
                "event": "ModalRecordLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "layout-panel-top"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Details",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "event": "OPEN",
                              "variant": "primary",
                              "icon": "layout-panel-top",
                              "label": "Open"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "icon": "layout-panel-top",
                          "title": "Nothing open",
                          "description": "Click Open to view details in a modal overlay.",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ModalRecordLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "size": "xl",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.message"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "event": "INIT",
                          "label": "Retry",
                          "variant": "primary"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModalRecord",
                    {
                      "emit": {
                        "success": "ModalRecordLoaded",
                        "failure": "ModalRecordLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "isOpen": true,
                      "type": "modal",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Name"
                                },
                                {
                                  "variant": "body",
                                  "content": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "name"
                                  ],
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Description",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "description"
                                  ],
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Status",
                                  "variant": "caption"
                                },
                                {
                                  "content": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "status"
                                  ],
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "ghost",
                                  "type": "button",
                                  "label": "Close",
                                  "event": "CLOSE"
                                }
                              ],
                              "justify": "end",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "title": "Details"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "loading",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "ModalRecord",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModalRecord",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "lg",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ModalRecordModalPage",
          "path": "/modalrecords/modal",
          "traits": [
            {
              "ref": "ModalRecordModal"
            }
          ]
        }
      ]
    }
  ]
}