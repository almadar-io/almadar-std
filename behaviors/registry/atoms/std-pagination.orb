{
  "name": "std-pagination",
  "version": "1.0.0",
  "description": "std-pagination as a Function",
  "orbitals": [
    {
      "name": "PagedItemOrbital",
      "entity": {
        "name": "PagedItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PagedItemPagination",
          "category": "interaction",
          "linkedEntity": "PagedItem",
          "emits": [
            {
              "event": "PagedItemLoaded",
              "description": "Fired when PagedItem finishes loading; payload.data holds the page",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PagedItem]"
                }
              ]
            },
            {
              "event": "PagedItemLoadFailed",
              "description": "Fired when PagedItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PagedItemLoaded",
                "name": "PagedItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PagedItem]"
                  }
                ]
              },
              {
                "key": "PagedItemLoadFailed",
                "name": "PagedItem load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAGE",
                "name": "Page",
                "payload": [
                  {
                    "name": "page",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "pageSize",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded",
                        "failure": "PagedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "PagedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "list",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "PagedItems"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name",
                              "variant": "h4"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ]
                        },
                        {
                          "totalPages": 10.0,
                          "onPageChange": "PAGE",
                          "currentPage": 1.0,
                          "showPageSize": false,
                          "type": "pagination"
                        },
                        {
                          "loadMoreEvent": "PAGE",
                          "type": "infinite-scroll-sentinel"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PagedItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography"
                        },
                        {
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "action": "INIT",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "PAGE",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded",
                        "failure": "PagedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "failure": "PagedItemLoadFailed",
                        "success": "PagedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPagination"
            }
          ]
        }
      ]
    }
  ]
}