{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter as a Function",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FilterTargetLoaded",
              "description": "Fired when FilterTarget collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FilterTargetLoadFailed",
              "description": "Fired when FilterTarget collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "filtered"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FilterTargetLoaded",
                "name": "FilterTarget loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FilterTargetLoadFailed",
                "name": "FilterTarget load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "payload": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "FilterTargetLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter"
                                },
                                {
                                  "type": "typography",
                                  "content": "FilterTargets",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "badge",
                              "label": "All"
                            }
                          ],
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "filters": [
                            {
                              "field": "status",
                              "filterType": "select",
                              "options": [
                                "active",
                                "inactive",
                                "pending"
                              ],
                              "label": "Status"
                            }
                          ],
                          "type": "filter-group",
                          "entity": "FilterTarget"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "FilterTarget",
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@item.name"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "@item.status",
                                  "color": "muted"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "fields": []
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FilterTargetLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.message",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "failure": "FilterTargetLoadFailed",
                        "success": "FilterTargetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "filtered",
                "event": "FILTER",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "filter": [
                        "=",
                        [
                          "object/get",
                          "@entity",
                          "@payload.field"
                        ],
                        "@payload.value"
                      ],
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "filter"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "FilterTargets"
                                }
                              ]
                            },
                            {
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "primary",
                                  "type": "badge",
                                  "label": "Filtered"
                                },
                                {
                                  "label": "Clear All",
                                  "variant": "ghost",
                                  "type": "button",
                                  "icon": "x",
                                  "action": "CLEAR_FILTERS"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "filter",
                              "type": "icon"
                            },
                            {
                              "content": "Filtered by",
                              "color": "muted",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "variant": "secondary",
                              "type": "badge",
                              "label": "@payload.field"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "="
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@payload.value"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "filter-group",
                          "entity": "FilterTarget",
                          "filters": [
                            {
                              "label": "Status",
                              "field": "status",
                              "options": [
                                "active",
                                "inactive",
                                "pending"
                              ],
                              "filterType": "select"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "FilterTarget",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@item.name"
                                },
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "@item.status",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ],
                          "fields": []
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "filtered",
                "to": "filtered",
                "event": "FILTER",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "filter": [
                        "=",
                        [
                          "object/get",
                          "@entity",
                          "@payload.field"
                        ],
                        "@payload.value"
                      ],
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "filtered",
                "to": "loading",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "failure": "FilterTargetLoadFailed",
                        "success": "FilterTargetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}