            "default": 0.0
          },
          {
            "name": "limiterStatus",
            "type": "string",
            "default": "open"
          }
        ]
      },
      "traits": [
        {
          "name": "RateBucketRateLimiter",
          "category": "interaction",
          "linkedEntity": "RateBucket",
          "stateMachine": {
            "states": [
              {
                "name": "open",
                "isInitial": true
              },
              {
                "name": "throttled"
              }
            ],
