              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REQUEST",
                "name": "Request"
              },
              {
                "key": "THROTTLE",
                "name": "Throttle"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
