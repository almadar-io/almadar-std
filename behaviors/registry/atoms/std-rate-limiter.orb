{
  "name": "std-rate-limiter",
  "version": "1.0.0",
  "description": "std-rate-limiter as a Function",
  "orbitals": [
    {
      "name": "RateBucketOrbital",
      "entity": {
        "name": "RateBucket",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "count",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "window",
