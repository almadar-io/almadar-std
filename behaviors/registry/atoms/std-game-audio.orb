{
  "name": "std-game-audio",
  "version": "1.0.0",
  "description": "std-game-audio as a Function",
  "orbitals": [
    {
      "name": "AudioTrackOrbital",
      "entity": {
        "name": "AudioTrack",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AudioTrackGameAudio",
          "category": "interaction",
          "linkedEntity": "AudioTrack",
          "emits": [
            {
              "event": "AudioTrackLoaded",
              "description": "Fired when AudioTrack finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AudioTrackLoadFailed",
              "description": "Fired when AudioTrack fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TOGGLE_MUTE",
                "name": "Toggle Mute"
              },
              {
                "key": "AudioTrackLoaded",
                "name": "AudioTrack loaded"
              },
              {
                "key": "AudioTrackLoadFailed",
                "name": "AudioTrack load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AudioTrack",
                    {
                      "emit": {
                        "success": "AudioTrackLoaded",
                        "failure": "AudioTrackLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "baseUrl": "https://almadar-kflow-assets.web.app/shared/audio",
                      "manifest": {
                        "drop": "https://almadar-kflow-assets.web.app/shared/audio/sfx/drop_001.ogg",
                        "click": "https://almadar-kflow-assets.web.app/shared/audio/sfx/close_001.ogg",
                        "confirm": "https://almadar-kflow-assets.web.app/shared/audio/sfx/confirmation_001.ogg"
                      },
                      "type": "game-audio-provider",
                      "initialMuted": false,
                      "children": [
                        {
                          "direction": "vertical",
                          "className": "max-w-md mx-auto",
                          "gap": "lg",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "volume-2"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Audio Controls",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "direction": "vertical",
                                  "type": "stack",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "Audio Active"
                                    },
                                    {
                                      "content": "Toggle mute to control game audio playback.",
                                      "variant": "body",
                                      "color": "muted",
                                      "type": "typography"
                                    },
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "event": "TOGGLE_MUTE",
                                          "variant": "primary",
                                          "label": "Toggle Mute",
                                          "icon": "volume-2",
                                          "type": "button"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "gap": "sm"
                                    }
                                  ]
                                }
                              ],
                              "type": "card"
                            },
                            {
                              "children": [
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "h4",
                                      "content": "Sound Effects"
                                    },
                                    {
                                      "gap": "sm",
                                      "type": "stack",
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "type": "button",
                                          "variant": "outline",
                                          "label": "Play Click",
                                          "icon": "play"
                                        },
                                        {
                                          "type": "button",
                                          "label": "Play Confirm",
                                          "icon": "play",
                                          "variant": "outline"
                                        },
                                        {
                                          "type": "button",
                                          "label": "Play Drop",
                                          "icon": "play",
                                          "variant": "outline"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ],
                              "type": "card"
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TOGGLE_MUTE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-audio-provider",
                      "baseUrl": "https://almadar-kflow-assets.web.app/shared/audio",
                      "initialMuted": false,
                      "children": [
                        {
                          "className": "max-w-md mx-auto",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "volume-2",
                                  "size": "lg"
                                },
                                {
                                  "content": "Audio Controls",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "Audio Active"
                                    },
                                    {
                                      "content": "Toggle mute to control game audio playback.",
                                      "type": "typography",
                                      "color": "muted",
                                      "variant": "body"
                                    },
                                    {
                                      "type": "stack",
                                      "direction": "horizontal",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "type": "button",
                                          "event": "TOGGLE_MUTE",
                                          "label": "Toggle Mute",
                                          "icon": "volume-2",
                                          "variant": "primary"
                                        }
                                      ]
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "md"
                                }
                              ]
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "Sound Effects",
                                      "variant": "h4"
                                    },
                                    {
                                      "children": [
                                        {
                                          "type": "button",
                                          "label": "Play Click",
                                          "icon": "play",
                                          "variant": "outline"
                                        },
                                        {
                                          "type": "button",
                                          "label": "Play Confirm",
                                          "icon": "play",
                                          "variant": "outline"
                                        },
                                        {
                                          "type": "button",
                                          "icon": "play",
                                          "label": "Play Drop",
                                          "variant": "outline"
                                        }
                                      ],
                                      "type": "stack",
                                      "gap": "sm",
                                      "direction": "horizontal"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "gap": "lg",
                          "type": "stack",
                          "direction": "vertical"
                        }
                      ],
                      "manifest": {
                        "confirm": "https://almadar-kflow-assets.web.app/shared/audio/sfx/confirmation_001.ogg",
                        "drop": "https://almadar-kflow-assets.web.app/shared/audio/sfx/drop_001.ogg",
                        "click": "https://almadar-kflow-assets.web.app/shared/audio/sfx/close_001.ogg"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AudioTrackAudioPage",
          "path": "/audiotracks",
          "traits": [
            {
              "ref": "AudioTrackGameAudio"
            }
          ]
        }
      ]
    }
  ]
}