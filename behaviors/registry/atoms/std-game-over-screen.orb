{
  "name": "std-game-over-screen",
  "version": "1.0.0",
  "description": "std-game-over-screen as a Function",
  "orbitals": [
    {
      "name": "GameOverStateOrbital",
      "entity": {
        "name": "GameOverState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "currentScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "highScore",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "GameOverStateGameOver",
          "category": "interaction",
          "linkedEntity": "GameOverState",
          "emits": [
            {
              "event": "GameOverStateLoaded",
              "description": "Fired when GameOverState finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentScore",
                  "type": "number"
                },
                {
                  "name": "highScore",
                  "type": "number"
                }
              ]
            },
            {
              "event": "GameOverStateLoadFailed",
              "description": "Fired when GameOverState fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "QUIT",
                "name": "Quit"
              },
              {
                "key": "GameOverStateLoaded",
                "name": "GameOverState loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentScore",
                    "type": "number"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "GameOverStateLoadFailed",
                "name": "GameOverState load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameOverState",
                    {
                      "emit": {
                        "failure": "GameOverStateLoadFailed",
                        "success": "GameOverStateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-over-screen",
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "action": "RETRY"
                        },
                        {
                          "action": "QUIT",
                          "label": "Main Menu"
                        }
                      ],
                      "title": "Game Over",
                      "highScore": "@entity.highScore",
                      "message": "Better luck next time!",
                      "currentScore": "@entity.currentScore"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "NAVIGATE"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESTART"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-over-screen",
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "action": "RETRY"
                        },
                        {
                          "label": "Main Menu",
                          "action": "QUIT"
                        }
                      ],
                      "title": "Game Over",
                      "currentScore": "@entity.currentScore",
                      "message": "Better luck next time!",
                      "highScore": "@entity.highScore"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QUIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "action": "RETRY",
                          "label": "Play Again"
                        },
                        {
                          "action": "QUIT",
                          "label": "Main Menu"
                        }
                      ],
                      "message": "Better luck next time!",
                      "title": "Game Over",
                      "currentScore": "@entity.currentScore",
                      "highScore": "@entity.highScore",
                      "type": "game-over-screen"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameOverStateGameOverPage",
          "path": "/gameoverstates",
          "traits": [
            {
              "ref": "GameOverStateGameOver"
            }
          ]
        }
      ]
    }
  ]
}