{
  "name": "std-flip-card",
  "version": "1.0.0",
  "description": "std-flip-card as a Function",
  "orbitals": [
    {
      "name": "FlashcardOrbital",
      "entity": {
        "name": "Flashcard",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "question",
            "type": "string",
            "default": ""
          },
          {
            "name": "answer",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "FlashcardFlipCard",
          "category": "interaction",
          "linkedEntity": "Flashcard",
          "emits": [
            {
              "event": "FlashcardLoaded",
              "description": "Fired when Flashcard finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "question",
                  "type": "string"
                },
                {
                  "name": "answer",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FlashcardLoadFailed",
              "description": "Fired when Flashcard fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "front",
                "isInitial": true
              },
              {
                "name": "back"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FLIP",
                "name": "Flip"
              },
              {
                "key": "FLIP_BACK",
                "name": "Flip Back"
              },
              {
                "key": "NEXT",
                "name": "Next"
              },
              {
                "key": "FlashcardLoaded",
                "name": "Flashcard loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "question",
                    "type": "string"
                  },
                  {
                    "name": "answer",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FlashcardLoadFailed",
                "name": "Flashcard load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "front",
                "to": "front",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Flashcard",
                    {
                      "emit": {
                        "success": "FlashcardLoaded",
                        "failure": "FlashcardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "rotate-3d",
                              "type": "icon"
                            },
                            {
                              "content": "Flashcards Flashcards",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "flipped": false,
                          "front": {
                            "direction": "vertical",
                            "type": "stack",
                            "children": [
                              {
                                "type": "icon",
                                "name": "help-circle"
                              },
                              {
                                "variant": "h3",
                                "content": "@entity.name",
                                "type": "typography"
                              },
                              {
                                "type": "typography",
                                "content": "Tap to reveal answer",
                                "variant": "caption",
                                "color": "muted"
                              }
                            ],
                            "gap": "md",
                            "align": "center"
                          },
                          "back": {
                            "align": "center",
                            "children": [
                              {
                                "type": "icon",
                                "name": "lightbulb"
                              },
                              {
                                "variant": "h3",
                                "content": "@entity.description",
                                "type": "typography"
                              },
                              {
                                "type": "badge",
                                "label": "Answer"
                              }
                            ],
                            "gap": "md",
                            "direction": "vertical",
                            "type": "stack"
                          },
                          "type": "flip-card"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "icon": "rotate-3d",
                          "label": "Flip",
                          "action": "FLIP"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "front",
                "to": "back",
                "event": "FLIP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "rotate-3d"
                            },
                            {
                              "type": "typography",
                              "content": "Flashcards Flashcards",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "flipped": true,
                          "back": {
                            "type": "stack",
                            "children": [
                              {
                                "name": "lightbulb",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "@entity.description"
                              },
                              {
                                "label": "Answer",
                                "type": "badge"
                              }
                            ],
                            "gap": "md",
                            "align": "center",
                            "direction": "vertical"
                          },
                          "front": {
                            "type": "stack",
                            "gap": "md",
                            "align": "center",
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "icon",
                                "name": "help-circle"
                              },
                              {
                                "content": "@entity.name",
                                "variant": "h3",
                                "type": "typography"
                              },
                              {
                                "color": "muted",
                                "content": "Tap to reveal answer",
                                "variant": "caption",
                                "type": "typography"
                              }
                            ]
                          },
                          "type": "flip-card"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Flip Back",
                              "action": "FLIP_BACK",
                              "variant": "ghost",
                              "type": "button",
                              "icon": "rotate-3d"
                            },
                            {
                              "type": "button",
                              "action": "NEXT",
                              "variant": "primary",
                              "icon": "arrow-right",
                              "label": "Next"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "back",
                "to": "front",
                "event": "FLIP_BACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "rotate-3d"
                            },
                            {
                              "type": "typography",
                              "content": "Flashcards Flashcards",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "flip-card",
                          "flipped": false,
                          "front": {
                            "align": "center",
                            "children": [
                              {
                                "type": "icon",
                                "name": "help-circle"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "@entity.name"
                              },
                              {
                                "type": "typography",
                                "content": "Tap to reveal answer",
                                "variant": "caption",
                                "color": "muted"
                              }
                            ],
                            "direction": "vertical",
                            "type": "stack",
                            "gap": "md"
                          },
                          "back": {
                            "type": "stack",
                            "direction": "vertical",
                            "align": "center",
                            "gap": "md",
                            "children": [
                              {
                                "type": "icon",
                                "name": "lightbulb"
                              },
                              {
                                "type": "typography",
                                "content": "@entity.description",
                                "variant": "h3"
                              },
                              {
                                "type": "badge",
                                "label": "Answer"
                              }
                            ]
                          }
                        },
                        {
                          "type": "button",
                          "icon": "rotate-3d",
                          "action": "FLIP",
                          "label": "Flip",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "back",
                "to": "front",
                "event": "NEXT",
                "effects": [
                  [
                    "fetch",
                    "Flashcard",
                    {
                      "emit": {
                        "success": "FlashcardLoaded",
                        "failure": "FlashcardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "rotate-3d"
                            },
                            {
                              "content": "Flashcards Flashcards",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "flipped": false,
                          "type": "flip-card",
                          "front": {
                            "type": "stack",
                            "align": "center",
                            "children": [
                              {
                                "name": "help-circle",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "@entity.name"
                              },
                              {
                                "content": "Tap to reveal answer",
                                "type": "typography",
                                "color": "muted",
                                "variant": "caption"
                              }
                            ],
                            "direction": "vertical",
                            "gap": "md"
                          },
                          "back": {
                            "align": "center",
                            "gap": "md",
                            "type": "stack",
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "icon",
                                "name": "lightbulb"
                              },
                              {
                                "variant": "h3",
                                "content": "@entity.description",
                                "type": "typography"
                              },
                              {
                                "type": "badge",
                                "label": "Answer"
                              }
                            ]
                          }
                        },
                        {
                          "label": "Flip",
                          "type": "button",
                          "action": "FLIP",
                          "variant": "primary",
                          "icon": "rotate-3d"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FlashcardFlipCardPage",
          "path": "/flashcards/flashcards",
          "traits": [
            {
              "ref": "FlashcardFlipCard"
            }
          ]
        }
      ]
    }
  ]
}