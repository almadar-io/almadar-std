{
  "name": "std-autoregressive",
  "version": "1.0.0",
  "description": "std-autoregressive as a Function",
  "orbitals": [
    {
      "name": "AutoregressiveOrbital",
      "entity": {
        "name": "Autoregressive",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "default": ""
          },
          {
            "name": "generatedTokens",
            "type": "string",
            "default": ""
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastToken",
            "type": "number",
            "default": -1.0
          },
          {
            "name": "genStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AutoregressiveAutoregressive",
          "category": "interaction",
          "linkedEntity": "Autoregressive",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "generating"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "TOKEN_READY",
                "name": "Token Ready",
                "payload": [
                  {
                    "name": "decoded",
                    "type": "string"
                  },
                  {
                    "name": "token",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.genStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.generatedTokens",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "size": "lg",
                              "name": "message-square",
                              "type": "icon"
                            },
                            {
                              "content": "Autoregressive Generator",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "badge",
                          "label": "@entity.genStatus"
                        },
                        {
                          "content": "Vocab: undefined | Max length: undefined",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.generatedTokens"
                        },
                        {
                          "icon": "play",
                          "event": "GENERATE",
                          "type": "button",
                          "label": "Generate",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.genStatus",
                    "generating"
                  ],
                  [
                    "set",
                    "@entity.generatedTokens",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ],
                  [
                    "forward",
                    "primary",
                    {
                      "output-contract": {
                        "shape": [
                          null
                        ],
                        "type": "tensor",
                        "activation": "softmax",
                        "dtype": "float32"
                      },
                      "on-complete": "TOKEN_READY",
                      "input": "@entity.generatedTokens"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Generating",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "value": "@entity.tokenCount",
                          "type": "progress-bar"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.generatedTokens",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "content": "Tokens: @entity.tokenCount",
                          "type": "typography"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "generating",
                "event": "TOKEN_READY",
                "guard": [
                  "not",
                  [
                    "or",
                    [
                      "eq",
                      "@payload.token",
                      null
                    ],
                    [
                      "gte",
                      "@entity.tokenCount",
                      null
                    ]
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.lastToken",
                    "@payload.token"
                  ],
                  [
                    "set",
                    "@entity.generatedTokens",
                    [
                      "concat",
                      "@entity.generatedTokens",
                      "@payload.decoded"
                    ]
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    [
                      "+",
                      "@entity.tokenCount",
                      1.0
                    ]
                  ],
                  [
                    "forward",
                    "primary",
                    {
                      "input": "@entity.generatedTokens",
                      "output-contract": {
                        "shape": [
                          null
                        ],
                        "activation": "softmax",
                        "type": "tensor",
                        "dtype": "float32"
                      },
                      "on-complete": "TOKEN_READY"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Generating"
                        },
                        {
                          "value": "@entity.tokenCount",
                          "type": "progress-bar"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.generatedTokens",
                          "type": "typography"
                        },
                        {
                          "content": "Tokens: @entity.tokenCount",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "type": "spinner",
                          "size": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "idle",
                "event": "TOKEN_READY",
                "guard": [
                  "or",
                  [
                    "eq",
                    "@payload.token",
                    null
                  ],
                  [
                    "gte",
                    "@entity.tokenCount",
                    null
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.genStatus",
                    "complete"
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    [
                      "+",
                      "@entity.tokenCount",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Generation Complete"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.generatedTokens"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Total tokens: @entity.tokenCount"
                        },
                        {
                          "variant": "outline",
                          "type": "button",
                          "event": "GENERATE",
                          "icon": "refresh-cw",
                          "label": "Generate Again"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AutoregressiveGeneratePage",
          "path": "/autoregressives/generate",
          "traits": [
            {
              "ref": "AutoregressiveAutoregressive"
            }
          ]
        }
      ]
    }
  ]
}