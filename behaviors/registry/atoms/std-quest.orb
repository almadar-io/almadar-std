                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "label": "Active",
                              "type": "badge"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "progress-bar",
                          "value": 50.0,
