{
  "name": "std-quest",
  "version": "1.0.0",
  "description": "std-quest as a Function",
  "orbitals": [
    {
      "name": "QuestLogOrbital",
      "entity": {
        "name": "QuestLog",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "QuestLogTracking",
          "category": "interaction",
          "linkedEntity": "QuestLog",
          "emits": [
            {
              "event": "QuestLogLoaded",
              "description": "Fired when QuestLog finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestLogLoadFailed",
              "description": "Fired when QuestLog fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "available",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "progressing"
              },
              {
                "name": "complete"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ACCEPT",
                "name": "Accept"
              },
              {
                "key": "PROGRESS",
                "name": "Progress",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAIL",
                "name": "Fail"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "QuestLogLoaded",
                "name": "QuestLog loaded"
              },
              {
                "key": "QuestLogLoadFailed",
                "name": "QuestLog load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "available",
                "to": "available",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "failure": "QuestLogLoadFailed",
                        "success": "QuestLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "flag",
                                  "size": "lg"
                                },
                                {
                                  "content": "QuestLogs Board",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "justify": "space-between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "QuestLog",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "gap": "sm",
                                      "align": "center",
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "flag",
                                          "size": "sm"
                                        },
                                        {
                                          "type": "typography",
                                          "variant": "h4",
                                          "content": "@item.name"
                                        }
                                      ],
                                      "type": "stack",
                                      "direction": "horizontal"
                                    },
                                    {
                                      "type": "badge",
                                      "label": "@item.description"
                                    }
                                  ],
                                  "justify": "space-between"
                                },
                                {
                                  "content": "@item.status",
                                  "type": "typography",
                                  "variant": "caption"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "type": "data-list",
                          "emptyTitle": "No questlogs available",
                          "groupBy": "status",
                          "emptyDescription": "Check back later for new questlogs.",
                          "itemActions": [
                            {
                              "event": "ACCEPT",
                              "label": "Accept"
                            }
                          ],
                          "emptyIcon": "inbox"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "available",
                "to": "active",
                "event": "ACCEPT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "flag",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "QuestLogs Board"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "label": "Active",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "space-between",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "showPercentage": true,
                          "value": 50.0,
                          "type": "progress-bar"
                        },
                        {
                          "emptyIcon": "inbox",
                          "emptyDescription": "Accept a quest to begin.",
                          "itemActions": [
                            {
                              "label": "Progress",
                              "event": "PROGRESS"
                            },
                            {
                              "label": "Complete",
                              "event": "COMPLETE"
                            },
                            {
                              "label": "Fail",
                              "event": "FAIL",
                              "variant": "danger"
                            }
                          ],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "gap": "sm",
                                      "type": "stack",
                                      "align": "center",
                                      "children": [
                                        {
                                          "type": "icon",
                                          "size": "sm",
                                          "name": "flag"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "@item.name",
                                          "variant": "h4"
                                        }
                                      ],
                                      "direction": "horizontal"
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ],
                                  "justify": "space-between",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "@item.status"
                                }
                              ]
                            }
                          ],
                          "type": "data-grid",
                          "entity": "QuestLog",
                          "emptyTitle": "No active quests"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "failure": "QuestLogLoadFailed",
                        "success": "QuestLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "space-between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "flag"
                                },
                                {
                                  "type": "typography",
                                  "content": "QuestLogs Board",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "badge",
                              "label": "Active"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "value": 50.0,
                          "showPercentage": true,
                          "type": "progress-bar"
                        },
                        {
                          "emptyTitle": "No active quests",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "justify": "space-between",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "flag",
                                          "size": "sm"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "@item.name",
                                          "variant": "h4"
                                        }
                                      ],
                                      "gap": "sm",
                                      "direction": "horizontal",
                                      "align": "center",
                                      "type": "stack"
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ]
                                },
                                {
                                  "variant": "caption",
                                  "content": "@item.status",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "data-grid",
                          "entity": "QuestLog",
                          "emptyDescription": "Accept a quest to begin.",
                          "itemActions": [
                            {
                              "event": "PROGRESS",
                              "label": "Progress"
                            },
                            {
                              "label": "Complete",
                              "event": "COMPLETE"
                            },
                            {
                              "variant": "danger",
                              "label": "Fail",
                              "event": "FAIL"
                            }
                          ],
                          "emptyIcon": "inbox"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "progressing",
                "event": "PROGRESS",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "trending-up",
                              "size": "md"
                            },
                            {
                              "content": "Update Progress",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "QuestLog",
                          "cancelEvent": "CANCEL",
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "fields": [
                            "name",
                            "description",
                            "status",
                            "createdAt"
                          ],
                          "mode": "edit"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Quest Complete"
                        },
                        {
                          "variant": "success",
                          "message": "Congratulations! The quest has been completed.",
                          "type": "alert"
                        },
                        {
                          "variant": "primary",
                          "icon": "arrow-left",
                          "type": "button",
                          "label": "View Quests",
                          "event": "RESET"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Quest Failed"
                        },
                        {
                          "variant": "danger",
                          "type": "alert",
                          "message": "The quest was not completed. You can try again."
                        },
                        {
                          "event": "RESET",
                          "type": "button",
                          "label": "View Quests",
                          "variant": "primary",
                          "icon": "arrow-left"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "progressing",
                "to": "active",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
