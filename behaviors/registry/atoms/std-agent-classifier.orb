                "key": "AgentClassifierLoadFailed",
                "name": "AgentClassifier load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "hidden",
                "to": "hidden",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentClassifier",
                    {
                      "emit": {
                        "success": "AgentClassifierLoaded",
                        "failure": "AgentClassifierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "hidden",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "tag"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "AgentClassifier Result"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "action": "HIDE",
                              "label": "Dismiss",
                              "icon": "x",
                              "variant": "ghost",
                              "type": "button"
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "justify": "between",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ],
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert"
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "variant": "warning",
                          "type": "alert"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "tag",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "AgentClassifier Result",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "label": "Dismiss",
                              "action": "HIDE",
                              "type": "button",
                              "variant": "ghost",
                              "icon": "x"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert",
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ]
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "variant": "warning",
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "hidden",
                "event": "HIDE",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
