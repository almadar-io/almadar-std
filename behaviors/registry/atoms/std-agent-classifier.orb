{
  "name": "std-agent-classifier",
  "version": "1.0.0",
  "description": "std-agent-classifier as a Function",
  "orbitals": [
    {
      "name": "AgentClassifierOrbital",
      "entity": {
        "name": "AgentClassifier",
        "collection": "agentclassifiers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "input",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "confidence",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "model",
            "type": "string",
            "default": "claude-sonnet-4-20250514"
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "notificationType",
            "type": "string",
            "default": "info"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentClassifierModal",
          "category": "interaction",
          "linkedEntity": "AgentClassifier",
          "emits": [
            {
              "event": "CLASSIFIED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentClassifierLoaded",
              "description": "Fired when AgentClassifier finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "input",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "confidence",
                  "type": "number"
                },
                {
                  "name": "model",
                  "type": "string"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentClassifierLoadFailed",
              "description": "Fired when AgentClassifier fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentClassifierSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentClassifierSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CLASSIFY",
                "name": "Classify"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLASSIFIED",
                "name": "Classified"
              },
              {
                "key": "AgentClassifierLoaded",
                "name": "AgentClassifier loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "input",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "confidence",
                    "type": "number"
                  },
                  {
                    "name": "model",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentClassifierLoadFailed",
                "name": "AgentClassifier load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentClassifierSaved",
                "name": "AgentClassifier saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentClassifierSaveFailed",
                "name": "AgentClassifier save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "AgentClassifier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "tag",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "AgentClassifier",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "variant": "primary",
                              "action": "CLASSIFY",
                              "icon": "tag",
                              "label": "Open",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
