                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "name": "tag",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "AgentClassifier"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "content": "Categories:",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "variant": "secondary",
                              "label": "positive",
                              "type": "badge"
                            },
                            {
                              "label": "negative",
                              "type": "badge",
                              "variant": "secondary"
                            },
                            {
                              "label": "neutral",
                              "variant": "secondary",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "mode": "create",
                          "type": "form-section",
                          "cancelEvent": "CLOSE",
                          "entity": "AgentClassifier",
                          "fields": [
                            "input"
                          ],
                          "submitEvent": "SAVE"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ],
                  [
                    "ref",
                    "AgentClassifier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "name": "tag",
                                  "type": "icon"
                                },
                                {
                                  "content": "AgentClassifier",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "icon": "tag",
                              "variant": "primary",
                              "action": "CLASSIFY",
                              "type": "button",
                              "label": "Open"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "title": "Nothing open",
                          "description": "Click Open to view details in a modal overlay.",
                          "type": "empty-state",
                          "icon": "tag"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentClassifier",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "AgentClassifierSaved",
