                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "CLASSIFIED"
                  ],
                  [
                    "ref",
                    "AgentClassifier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "tag"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "AgentClassifier"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "icon": "tag",
                              "variant": "primary",
                              "type": "button",
                              "label": "Open",
                              "action": "CLASSIFY"
