{
  "name": "std-game-hud",
  "version": "1.0.0",
  "description": "std-game-hud as a Function",
  "orbitals": [
    {
      "name": "HudStateOrbital",
      "entity": {
        "name": "HudState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "HudStateHud",
          "category": "interaction",
          "linkedEntity": "HudState",
          "emits": [
            {
              "event": "HudStateLoaded",
              "description": "Fired when HudState finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HudStateLoadFailed",
              "description": "Fired when HudState fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "HudStateLoaded",
                "name": "HudState loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "HudStateLoadFailed",
                "name": "HudState load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HudState",
                    {
                      "emit": {
                        "failure": "HudStateLoadFailed",
                        "success": "HudStateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "md",
                      "transparent": false,
                      "type": "game-hud",
                      "position": "top-left",
                      "stats": [
                        {
                          "label": "Name",
                          "value": "@entity.name"
                        },
                        {
                          "label": "Description",
                          "value": "@entity.description"
                        },
                        {
                          "label": "Status",
                          "value": "@entity.status"
                        },
                        {
                          "label": "CreatedAt",
                          "value": "@entity.createdAt"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HudState",
                    {
                      "emit": {
                        "failure": "HudStateLoadFailed",
                        "success": "HudStateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "transparent": false,
                      "stats": [
                        {
                          "value": "@entity.name",
                          "label": "Name"
                        },
                        {
                          "label": "Description",
                          "value": "@entity.description"
                        },
                        {
                          "label": "Status",
                          "value": "@entity.status"
                        },
                        {
                          "value": "@entity.createdAt",
                          "label": "CreatedAt"
                        }
                      ],
                      "type": "game-hud",
                      "position": "top-left",
                      "size": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "HudStateHudPage",
          "path": "/hudstates",
          "traits": [
            {
              "ref": "HudStateHud"
            }
          ]
        }
      ]
    }
  ]
}