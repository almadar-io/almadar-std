{
  "name": "std-upload",
  "version": "1.0.0",
  "description": "std-upload as a Function",
  "orbitals": [
    {
      "name": "UploadFileOrbital",
      "entity": {
        "name": "UploadFile",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "fileName",
            "type": "string",
            "default": ""
          },
          {
            "name": "fileSize",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "uploadStatus",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "UploadFileUpload",
          "category": "interaction",
          "linkedEntity": "UploadFile",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "uploading"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payload": [
                  {
                    "name": "fileName",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAILED",
                "name": "Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "type": "typography",
                              "content": "Upload",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "action": "UPLOAD",
                          "maxSize": 10485760.0,
                          "accept": "*/*",
                          "type": "upload-drop-zone"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "set",
                    "@entity.fileName",
                    "@payload.fileName"
                  ],
                  [
                    "set",
                    "@entity.uploadStatus",
                    "uploading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Uploading..."
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ],
                          "type": "typography"
                        },
                        {
                          "value": 50.0,
                          "showPercentage": true,
                          "type": "progress-bar"
                        },
                        {
                          "type": "spinner"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Upload Complete",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "File uploaded successfully.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Upload Another",
                          "icon": "upload",
                          "variant": "primary",
                          "action": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "title": "Upload Failed",
                          "type": "error-state",
                          "onRetry": "UPLOAD",
                          "message": "Something went wrong. Please try again."
                        },
                        {
                          "children": [
                            {
                              "label": "Retry",
                              "action": "RETRY",
                              "type": "button",
                              "variant": "primary",
                              "icon": "rotate-ccw"
                            },
                            {
                              "type": "button",
                              "label": "Cancel",
                              "action": "RESET",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "content": "Upload",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "upload-drop-zone",
                          "accept": "*/*",
                          "action": "UPLOAD",
                          "maxSize": 10485760.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "uploading",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "uploading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "type": "typography",
                              "content": "Uploading...",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ]
                        },
                        {
                          "value": 50.0,
                          "showPercentage": true,
                          "type": "progress-bar"
                        },
                        {
                          "type": "spinner"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "content": "Upload",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "maxSize": 10485760.0,
                          "accept": "*/*",
                          "type": "upload-drop-zone",
                          "action": "UPLOAD"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "UploadFileUploadPage",
          "path": "/uploadfiles/upload",
          "traits": [
            {
              "ref": "UploadFileUpload"
            }
          ]
        }
      ]
    }
  ]
}