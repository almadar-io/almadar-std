{
  "name": "std-notification",
  "version": "1.0.0",
  "description": "std-notification as a Function",
  "orbitals": [
    {
      "name": "NotificationOrbital",
      "entity": {
        "name": "Notification",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "notificationType",
            "type": "string",
            "default": "info"
          }
        ]
      },
      "traits": [
        {
          "name": "NotificationNotification",
          "category": "interaction",
          "linkedEntity": "Notification",
          "emits": [
            {
              "event": "NotificationLoaded",
              "description": "Fired when Notification finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NotificationLoadFailed",
              "description": "Fired when Notification fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "hidden",
                "isInitial": true
              },
              {
                "name": "visible"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payload": [
                  {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "HIDE",
                "name": "Hide"
              },
              {
                "key": "NotificationLoaded",
                "name": "Notification loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "NotificationLoadFailed",
                "name": "Notification load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "hidden",
                "to": "hidden",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Notification",
                    {
                      "emit": {
                        "failure": "NotificationLoadFailed",
                        "success": "NotificationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "variant": "h2",
                              "content": "Notifications",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "icon": "bell-off",
                          "description": "New notifications will appear here.",
                          "title": "No notifications",
                          "type": "empty-state"
                        },
                        {
                          "label": "Test Notification",
                          "type": "button",
                          "variant": "secondary",
                          "icon": "bell",
                          "actionPayload": {
                            "notificationType": "info",
                            "message": "This is a test notification"
                          },
                          "action": "SHOW"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "hidden",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "bell",
                                  "type": "icon"
                                },
                                {
                                  "content": "Notifications",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "variant": "ghost",
                              "action": "HIDE",
                              "icon": "x",
                              "type": "button",
                              "label": "Dismiss"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ],
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert"
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert",
                          "variant": "warning"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "bell",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Notifications",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "align": "center"
                            },
                            {
                              "label": "Dismiss",
                              "variant": "ghost",
                              "icon": "x",
                              "type": "button",
                              "action": "HIDE"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert",
                          "variant": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "notificationType"
                          ]
                        },
                        {
                          "type": "toast-slot"
                        },
                        {
                          "message": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "message"
                          ],
                          "type": "alert",
                          "variant": "warning"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "hidden",
                "event": "HIDE",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "type": "typography",
                              "content": "Notifications",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "icon": "bell-off",
                          "description": "New notifications will appear here.",
                          "title": "No notifications"
                        },
                        {
                          "type": "button",
                          "icon": "bell",
                          "action": "SHOW",
                          "actionPayload": {
                            "message": "This is a test notification",
                            "notificationType": "info"
                          },
                          "label": "Test Notification",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "NotificationNotificationPage",
          "path": "/notifications/notifications",
          "traits": [
            {
              "ref": "NotificationNotification"
            }
          ]
        }
      ]
    }
  ]
}