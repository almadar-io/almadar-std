{
  "name": "std-agent-session",
  "version": "1.0.0",
  "description": "std-agent-session as a Function",
  "orbitals": [
    {
      "name": "AgentSessionOrbital",
      "entity": {
        "name": "AgentSession",
        "collection": "agentsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "sessionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "parentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "label",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentSessionBrowse",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "sessionId",
                  "type": "string"
                },
                {
                  "name": "parentId",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "FORKED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            },
            {
              "event": "LABELED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionLabel"
              }
            },
            {
              "event": "ENDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "sessionId",
                    "type": "string"
                  },
                  {
                    "name": "parentId",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaved",
                "name": "AgentSession saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaveFailed",
                "name": "AgentSession save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "AgentSession"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "terminal"
                                },
                                {
                                  "content": "AgentSession Manager",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "button",
                                  "action": "FORK",
                                  "label": "Fork",
                                  "variant": "secondary",
                                  "icon": "git-branch"
                                },
                                {
                                  "label": "Label",
                                  "icon": "tag",
                                  "action": "LABEL",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "type": "button",
                                  "label": "End",
                                  "variant": "ghost",
                                  "action": "END",
                                  "icon": "square"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "sessionId",
                              "label": "Session ID",
                              "icon": "terminal",
                              "variant": "h4"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "colorMap": {
                                "active": "success",
                                "inactive": "neutral",
                                "failed": "destructive",
                                "scheduled": "warning",
                                "archived": "neutral",
                                "cancelled": "destructive",
                                "completed": "success",
                                "draft": "warning",
                                "done": "success",
                                "disabled": "neutral",
                                "error": "destructive",
                                "pending": "warning"
                              },
                              "label": "Status"
                            },
                            {
                              "variant": "caption",
                              "label": "Label",
                              "name": "label"
                            }
                          ],
                          "entity": "@entity",
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentSessionLabel",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "LABELED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "sessionId",
                  "type": "string"
                },
                {
                  "name": "parentId",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LABEL",
                "name": "Label"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "LABELED",
                "name": "Labeled"
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "sessionId",
                    "type": "string"
                  },
                  {
                    "name": "parentId",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdateFailed",
                "name": "AgentSession update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionUpdated",
                "name": "AgentSession updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "AgentSession"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "LABEL",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "tag"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Label Session"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Session:"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.sessionId"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "fields": [
                            "label"
                          ],
                          "entity": "AgentSession",
                          "mode": "edit",
                          "cancelEvent": "CLOSE",
                          "type": "form-section",
                          "submitEvent": "SAVE"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "LABELED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentSessionAgent",
          "category": "interaction",
          "linkedEntity": "AgentSession",
          "emits": [
            {
              "event": "ENDED",
              "scope": "external",
              "payload": [
                {
                  "name": "sessionId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FORKED",
              "scope": "external",
              "payload": [
                {
                  "name": "sessionId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoadFailed",
              "description": "Fired when AgentSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionLoaded",
              "description": "Fired when AgentSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "sessionId",
                  "type": "string"
                },
                {
                  "name": "parentId",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentSessionSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ENDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            },
            {
              "event": "FORKED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSessionAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "active",
                "isInitial": true
              },
              {
                "name": "forked"
              },
              {
                "name": "ended"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FORK",
                "name": "Fork"
              },
              {
                "key": "DO_LABEL",
                "name": "Do Label",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "LABELED",
                "name": "Labeled",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "END",
                "name": "End"
              },
              {
                "key": "ENDED",
                "name": "Ended"
              },
              {
                "key": "FORKED",
                "name": "Forked"
              },
              {
                "key": "AgentSessionLoadFailed",
                "name": "AgentSession load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionLoaded",
                "name": "AgentSession loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "sessionId",
                    "type": "string"
                  },
                  {
                    "name": "parentId",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaveFailed",
                "name": "AgentSession save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentSessionSaved",
                "name": "AgentSession saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "active",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "success": "AgentSessionLoaded",
                        "failure": "AgentSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@now"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "git-branch",
                      "title": "Session",
                      "type": "empty-state",
                      "description": "Session is ready"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "set",
                    "@entity.parentId",
                    "@entity.sessionId"
                  ],
                  [
                    "agent/fork"
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "status": "forked",
                      "createdAt": "@now",
                      "sessionId": "@entity.sessionId",
                      "parentId": "@entity.parentId"
                    },
                    {
                      "emit": {
                        "success": "AgentSessionSaved",
                        "failure": "AgentSessionSaveFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DO_LABEL",
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.data.label"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "LABELED",
                "effects": [
                  [
                    "agent/label",
                    "@entity.label"
                  ],
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "ended"
                  ],
                  [
                    "emit",
                    "ENDED"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "set",
                    "@entity.parentId",
                    "@entity.sessionId"
                  ],
                  [
                    "agent/fork"
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "parentId": "@entity.parentId",
                      "status": "forked",
                      "createdAt": "@now",
                      "sessionId": "@entity.sessionId"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionSaveFailed",
                        "success": "AgentSessionSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "DO_LABEL",
                "effects": [
                  [
                    "agent/label",
                    "@payload.data.label"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.data.label"
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "forked",
                "event": "LABELED",
                "effects": [
                  [
                    "agent/label",
                    "@entity.label"
                  ],
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "forked",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "ended"
                  ],
                  [
                    "emit",
                    "ENDED"
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSession",
                    {
                      "emit": {
                        "failure": "AgentSessionLoadFailed",
                        "success": "AgentSessionLoaded"
                      }
                    }
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "active"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Session",
                      "description": "Session is ready",
                      "type": "empty-state",
                      "icon": "git-branch"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentSessionPage",
          "path": "/agentsessions",
          "traits": [
            {
              "ref": "AgentSessionBrowse"
            },
            {
              "ref": "AgentSessionLabel"
            },
            {
              "ref": "AgentSessionAgent"
            }
          ]
        }
      ]
    }
  ]
}