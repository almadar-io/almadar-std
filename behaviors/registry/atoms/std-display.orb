{
  "name": "std-display",
  "version": "1.0.0",
  "description": "std-display as a Function",
  "orbitals": [
    {
      "name": "DisplayItemOrbital",
      "entity": {
        "name": "DisplayItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DisplayItemDisplay",
          "category": "interaction",
          "linkedEntity": "DisplayItem",
          "emits": [
            {
              "event": "DisplayItemLoaded",
              "description": "Fired when DisplayItem finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DisplayItemLoadFailed",
              "description": "Fired when DisplayItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "DisplayItemLoaded",
                "name": "DisplayItem loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DisplayItemLoadFailed",
                "name": "DisplayItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DisplayItem",
                    {
                      "emit": {
                        "success": "DisplayItemLoaded",
                        "failure": "DisplayItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "scaled-diagram",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "breadcrumb",
                              "items": [
                                {
                                  "href": "/",
                                  "label": "Home"
                                },
                                {
                                  "label": "DisplayItems"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "bar-chart-2",
