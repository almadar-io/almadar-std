{
  "name": "std-service-email",
  "version": "1.0.0",
  "description": "std-service-email as a Function",
  "orbitals": [
    {
      "name": "ServiceEmailOrbital",
      "entity": {
        "name": "ServiceEmail",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "from",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "messageId",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceEmailEmail",
          "category": "interaction",
          "linkedEntity": "ServiceEmail",
          "emits": [
            {
              "event": "ServiceEmailLoaded",
              "description": "Fired when ServiceEmail finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "subject",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "from",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "messageId",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceEmailLoadFailed",
              "description": "Fired when ServiceEmail fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "SENT",
                "name": "Sent",
                "payload": [
                  {
                    "name": "messageId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceEmailLoaded",
                "name": "ServiceEmail loaded"
              },
              {
                "key": "ServiceEmailLoadFailed",
                "name": "ServiceEmail load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceEmail",
                    {
                      "emit": {
                        "success": "ServiceEmailLoaded",
                        "failure": "ServiceEmailLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceEmail Email"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "label": "To",
                          "placeholder": "recipient@example.com",
                          "bind": "@entity.to",
                          "type": "input"
                        },
                        {
                          "bind": "@entity.subject",
                          "placeholder": "Email subject",
                          "label": "Subject",
                          "type": "input"
                        },
                        {
                          "placeholder": "Write your message...",
                          "bind": "@entity.body",
                          "type": "textarea",
                          "label": "Body"
                        },
                        {
                          "label": "Send",
                          "event": "SEND",
                          "icon": "send",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Delivering serviceemail email...",
                      "title": "Sending email..."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "to": "@entity.to",
                      "subject": "@entity.subject",
                      "body": "@entity.body"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "size": "lg"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Email sent successfully"
                        },
                        {
                          "event": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Send Another",
                          "variant": "ghost",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "error-state",
                          "title": "Send Failed",
                          "message": "Could not deliver the email.",
                          "onRetry": "RETRY"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "label": "Retry",
                              "event": "RETRY",
                              "type": "button",
                              "icon": "refresh-cw"
                            },
                            {
                              "label": "Reset",
                              "type": "button",
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "event": "RESET"
                            }
                          ],
                          "justify": "center",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "ServiceEmail Email",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "recipient@example.com",
                          "bind": "@entity.to",
                          "type": "input",
                          "label": "To"
                        },
                        {
                          "placeholder": "Email subject",
                          "bind": "@entity.subject",
                          "type": "input",
                          "label": "Subject"
                        },
                        {
                          "label": "Body",
                          "bind": "@entity.body",
                          "placeholder": "Write your message...",
                          "type": "textarea"
                        },
                        {
                          "variant": "primary",
                          "event": "SEND",
                          "icon": "send",
                          "label": "Send",
                          "type": "button"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "mail"
                            },
                            {
                              "variant": "h2",
                              "content": "ServiceEmail Email",
                              "type": "typography"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "bind": "@entity.to",
                          "type": "input",
                          "placeholder": "recipient@example.com",
                          "label": "To"
                        },
                        {
                          "type": "input",
                          "bind": "@entity.subject",
                          "label": "Subject",
                          "placeholder": "Email subject"
                        },
                        {
                          "placeholder": "Write your message...",
                          "label": "Body",
                          "bind": "@entity.body",
                          "type": "textarea"
                        },
                        {
                          "icon": "send",
                          "event": "SEND",
                          "label": "Send",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail",
                              "size": "lg"
                            },
                            {
                              "content": "ServiceEmail Email",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "recipient@example.com",
                          "bind": "@entity.to",
                          "label": "To"
                        },
                        {
                          "bind": "@entity.subject",
                          "type": "input",
                          "placeholder": "Email subject",
                          "label": "Subject"
                        },
                        {
                          "placeholder": "Write your message...",
                          "label": "Body",
                          "type": "textarea",
                          "bind": "@entity.body"
                        },
                        {
                          "icon": "send",
                          "type": "button",
                          "label": "Send",
                          "variant": "primary",
                          "event": "SEND"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceEmailPage",
          "path": "/serviceemails",
          "traits": [
            {
              "ref": "ServiceEmailEmail"
            }
          ]
        }
      ]
    }
  ]
}