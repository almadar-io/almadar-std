{
  "name": "std-collision",
  "version": "1.0.0",
  "description": "std-collision as a Function",
  "orbitals": [
    {
      "name": "CollidableBodyOrbital",
      "entity": {
        "name": "CollidableBody",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "x",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "collisionStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "targetId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CollidableBodyCollision",
          "category": "interaction",
          "linkedEntity": "CollidableBody",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "detecting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHECK",
                "name": "Check"
              },
              {
                "key": "COLLISION_DETECTED",
                "name": "Collision Detected",
                "payload": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "justify": "space-between",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "crosshair"
                                },
                                {
                                  "type": "typography",
                                  "content": "CollidableBody Collision",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "label": "Idle",
                              "type": "status-dot",
                              "status": "inactive"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "X",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ]
                            },
                            {
                              "type": "stat-display",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ],
                              "label": "Y"
                            }
                          ],
                          "columns": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "justify": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Check",
                              "event": "CHECK",
                              "variant": "primary",
                              "icon": "scan"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "detecting",
                "event": "CHECK",
                "effects": [
                  [
                    "set",
                    "@entity.collisionStatus",
                    "detecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "size": "lg",
                                  "name": "crosshair",
                                  "type": "icon"
                                },
                                {
                                  "content": "CollidableBody Collision",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "label": "Detecting",
                              "type": "status-dot",
                              "status": "warning",
                              "pulse": true
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Collision detection in progress...",
                          "variant": "warning"
                        },
                        {
                          "columns": 2.0,
                          "children": [
                            {
                              "label": "X",
                              "type": "stat-display",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ]
                            },
                            {
                              "label": "Y",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ],
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "targetId"
                          ],
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "justify": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "icon": "x",
                              "type": "button",
                              "event": "CLEAR",
                              "label": "Clear"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "detecting",
                "event": "COLLISION_DETECTED",
                "effects": [
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.targetId"
                  ],
                  [
                    "set",
                    "@entity.collisionStatus",
                    "detected"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "crosshair"
                                },
                                {
                                  "content": "CollidableBody Collision",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "pulse": true,
                              "type": "status-dot",
                              "status": "warning",
                              "label": "Detecting"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Collision detection in progress...",
                          "variant": "warning",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "label": "X",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ],
                              "type": "stat-display"
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ],
                              "label": "Y",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "columns": 2.0
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "targetId"
                          ],
                          "variant": "caption"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Clear",
                              "event": "CLEAR",
                              "icon": "x",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.collisionStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "justify": "space-between",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "crosshair"
                                },
                                {
                                  "content": "CollidableBody Collision",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "status": "inactive",
                              "label": "Idle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "columns": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "X",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ]
                            },
                            {
                              "type": "stat-display",
                              "label": "Y",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ]
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Check",
                              "event": "CHECK",
                              "variant": "primary",
                              "icon": "scan",
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "detecting",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "crosshair",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "CollidableBody Collision"
                                }
                              ]
                            },
                            {
                              "status": "warning",
                              "label": "Detecting",
                              "type": "status-dot",
                              "pulse": true
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "md",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "warning",
                          "message": "Collision detection in progress...",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "label": "X",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ],
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Y",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ]
                            }
                          ],
                          "columns": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "targetId"
                          ]
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "x",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Clear",
                              "event": "CLEAR"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CollidableBodyCollisionPage",
          "path": "/collidablebodys/collision",
          "traits": [
            {
              "ref": "CollidableBodyCollision"
            }
          ]
        }
      ]
    }
  ]
}