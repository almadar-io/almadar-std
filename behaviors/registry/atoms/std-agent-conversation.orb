                          "entity": "AgentConversation",
                          "type": "data-list",
                          "emptyIcon": "message-circle",
                          "emptyTitle": "No messages yet",
                          "emptyDescription": "Start a conversation by sending a message."
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.role",
                    "user"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentConversation",
                    {
                      "timestamp": "@now",
                      "status": "sent",
                      "role": "user",
                      "content": "@payload.content"
                    }
                  ],
                  [
                    "emit",
                    "SEND_MESSAGE"
                  ],
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
