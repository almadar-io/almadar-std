                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@item.content"
                                }
                              ],
                              "gap": "xs"
                            }
                          ],
                          "entity": "AgentConversation",
                          "emptyTitle": "No messages yet",
                          "emptyDescription": "Start a conversation by sending a message.",
                          "emptyIcon": "message-circle",
                          "type": "data-list"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "justify": "space-between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "AgentConversation Thread",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "disabled": true,
                              "variant": "primary",
                              "type": "button",
                              "label": "New Message",
                              "event": "COMPOSE",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "AgentConversation",
                          "type": "data-list",
                          "emptyTitle": "No messages yet",
                          "emptyDescription": "Start a conversation by sending a message.",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "gap": "sm",
                                  "align": "center",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.role"
                                    },
                                    {
                                      "type": "badge",
                                      "variant": "outline",
                                      "label": "@item.status"
                                    },
                                    {
                                      "color": "muted",
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "@item.timestamp"
                                    }
                                  ]
                                },
                                {
                                  "content": "@item.content",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "xs"
                            }
                          ],
                          "emptyIcon": "message-circle"
                        },
                        {
                          "type": "form-section",
                          "title": "Compose Message",
                          "children": [
                            {
                              "bind": "@entity.content",
                              "type": "textarea",
                              "placeholder": "Type your message...",
                              "label": "Message"
