          "scope": "collection"
        },
        {
          "name": "AgentConversationAgent",
          "category": "interaction",
          "linkedEntity": "AgentConversation",
          "emits": [
            {
              "event": "TOKEN_UPDATE",
              "scope": "internal",
              "payload": [
                {
                  "name": "tokenCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentConversationLoaded",
              "description": "Fired when AgentConversation finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "messages",
                  "type": "[string]"
                },
                {
                  "name": "turnCount",
                  "type": "number"
                },
                {
                  "name": "lastMessage",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "role",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationLoadFailed",
              "description": "Fired when AgentConversation fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update"
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded"
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "success": "AgentConversationLoaded",
                        "failure": "AgentConversationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "message-circle",
                      "title": "Conversation",
                      "description": "Conversation is ready",
                      "type": "empty-state"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "paused",
                "event": "PAUSE"
              },
              {
                "from": "active",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
