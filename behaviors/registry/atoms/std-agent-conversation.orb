{
  "name": "std-agent-conversation",
  "version": "1.0.0",
  "description": "std-agent-conversation as a Function",
  "orbitals": [
    {
      "name": "AgentConversationOrbital",
      "entity": {
        "name": "AgentConversation",
        "collection": "agentconversations",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "messages",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "turnCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "role",
            "type": "string",
            "default": "user"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentConversationThread",
          "category": "interaction",
          "linkedEntity": "AgentConversation",
          "emits": [
            {
              "event": "SEND_MESSAGE",
              "scope": "internal",
              "payload": [
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationLoaded",
              "description": "Fired when AgentConversation finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "messages",
                  "type": "[string]"
                },
                {
                  "name": "turnCount",
                  "type": "number"
                },
                {
                  "name": "lastMessage",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "role",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentConversationLoadFailed",
              "description": "Fired when AgentConversation fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "composing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message"
              },
              {
                "key": "AgentConversationLoaded",
                "name": "AgentConversation loaded"
              },
              {
                "key": "AgentConversationLoadFailed",
                "name": "AgentConversation load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentConversation",
                    {
                      "emit": {
                        "failure": "AgentConversationLoadFailed",
                        "success": "AgentConversationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "size": "lg",
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "AgentConversation Thread",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "type": "button",
                              "label": "New Message",
                              "icon": "plus",
                              "event": "COMPOSE",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "space-between",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "label": "@item.status",
                                      "variant": "outline",
                                      "type": "badge"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted",
                                      "content": "@item.timestamp"
                                    }
