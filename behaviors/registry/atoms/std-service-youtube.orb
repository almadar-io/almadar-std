{
  "name": "std-service-youtube",
  "version": "1.0.0",
  "description": "std-service-youtube as a Function",
  "orbitals": [
    {
      "name": "ServiceYoutubeOrbital",
      "entity": {
        "name": "ServiceYoutube",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "selectedVideoId",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "searchStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceYoutubeYoutube",
          "category": "interaction",
          "linkedEntity": "ServiceYoutube",
          "emits": [
            {
              "event": "ServiceYoutubeLoaded",
              "description": "Fired when ServiceYoutube finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "query",
                  "type": "string"
                },
                {
                  "name": "selectedVideoId",
                  "type": "string"
                },
                {
                  "name": "videoTitle",
                  "type": "string"
                },
                {
                  "name": "videoDescription",
                  "type": "string"
                },
                {
                  "name": "searchStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeLoadFailed",
              "description": "Fired when ServiceYoutube fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              },
              {
                "name": "viewingDetail"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "SEARCH_COMPLETE",
                "name": "Search Complete",
                "payload": [
                  {
                    "name": "results",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_VIDEO",
                "name": "Select Video",
                "payload": [
                  {
                    "name": "videoId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "VIDEO_LOADED",
                "name": "Video Loaded",
                "payload": [
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "BACK",
                "name": "Back"
              },
              {
                "key": "ServiceYoutubeLoaded",
                "name": "ServiceYoutube loaded"
              },
              {
                "key": "ServiceYoutubeLoadFailed",
                "name": "ServiceYoutube load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceYoutube",
                    {
                      "emit": {
                        "success": "ServiceYoutubeLoaded",
                        "failure": "ServiceYoutubeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "video",
                              "size": "lg"
                            },
                            {
                              "content": "YouTube Search",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Search YouTube videos...",
                          "type": "input",
                          "label": "Search",
                          "bind": "@entity.query"
                        },
                        {
                          "type": "button",
                          "icon": "search",
                          "label": "Search",
                          "variant": "primary",
                          "event": "SEARCH"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Searching YouTube for videos...",
                      "title": "Searching..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "maxResults": 10.0,
                      "type": "video",
                      "query": "@entity.query"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SEARCH_COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "video"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Search Results"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Select a video to view details.",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "event": "RESET",
                              "label": "New Search",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "type": "button"
                            },
                            {
                              "icon": "search",
                              "variant": "outline",
                              "event": "SEARCH",
                              "type": "button",
                              "label": "Search Again"
                            }
                          ],
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.searchStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "onRetry": "SEARCH",
                          "message": "@entity.error",
                          "type": "error-state",
                          "title": "Search Failed"
                        },
                        {
                          "children": [
                            {
                              "icon": "refresh-cw",
                              "type": "button",
                              "label": "Retry",
                              "variant": "primary",
                              "event": "SEARCH"
                            },
                            {
                              "label": "Reset",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "event": "RESET",
                              "type": "button"
                            }
                          ],
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Searching YouTube for videos...",
                      "type": "loading-state",
                      "title": "Searching..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "type": "video",
                      "maxResults": 10.0,
                      "query": "@entity.query"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "viewingDetail",
                "event": "SELECT_VIDEO",
                "effects": [
                  [
                    "set",
                    "@entity.selectedVideoId",
                    "@payload.videoId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading video...",
                      "message": "Fetching video details..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "getVideo",
                    {
                      "videoId": "@payload.videoId"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "video",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "content": "YouTube Search",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "label": "Search",
                          "bind": "@entity.query",
                          "type": "input",
                          "placeholder": "Search YouTube videos..."
                        },
                        {
                          "variant": "primary",
                          "label": "Search",
                          "event": "SEARCH",
                          "type": "button",
                          "icon": "search"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "viewingDetail",
                "to": "viewingDetail",
                "event": "VIDEO_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.videoTitle",
                    "@payload.title"
                  ],
                  [
                    "set",
                    "@entity.videoDescription",
                    "@payload.description"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "stretch",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "video",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.videoTitle",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.videoDescription",
                          "variant": "body"
                        },
                        {
                          "event": "BACK",
                          "icon": "arrow-left",
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back to Results"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewingDetail",
                "to": "results",
                "event": "BACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "video"
                            },
                            {
                              "type": "typography",
                              "content": "Search Results",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "Select a video to view details."
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "icon": "rotate-ccw",
                              "event": "RESET",
                              "label": "New Search",
                              "variant": "ghost"
                            },
                            {
                              "icon": "search",
                              "variant": "outline",
                              "label": "Search Again",
                              "event": "SEARCH",
                              "type": "button"
                            }
                          ],
                          "justify": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "align": "stretch",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "video"
                            },
                            {
                              "content": "YouTube Search",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "label": "Search",
                          "type": "input",
                          "bind": "@entity.query",
                          "placeholder": "Search YouTube videos..."
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "label": "Search",
                          "event": "SEARCH",
                          "icon": "search"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceYoutubePage",
          "path": "/serviceyoutubes",
          "traits": [
            {
              "ref": "ServiceYoutubeYoutube"
            }
          ]
        }
      ]
    }
  ]
}