{
  "name": "std-movement",
  "version": "1.0.0",
  "description": "std-movement as a Function",
  "orbitals": [
    {
      "name": "MovableEntityOrbital",
      "entity": {
        "name": "MovableEntity",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "x",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "MovableEntityMovement",
          "category": "interaction",
          "linkedEntity": "MovableEntity",
          "emits": [
            {
              "event": "MovableEntityLoaded",
              "description": "Fired when MovableEntity finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "x",
                  "type": "number"
                },
                {
                  "name": "y",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MovableEntityLoadFailed",
              "description": "Fired when MovableEntity fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "moving"
              },
              {
                "name": "colliding"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MOVE",
                "name": "Move",
                "payload": [
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "COLLISION",
                "name": "Collision",
                "payload": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESOLVE",
                "name": "Resolve"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "MovableEntityLoaded",
                "name": "MovableEntity loaded"
              },
              {
                "key": "MovableEntityLoadFailed",
                "name": "MovableEntity load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MovableEntity",
                    {
                      "emit": {
                        "failure": "MovableEntityLoadFailed",
                        "success": "MovableEntityLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "move",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "content": "MovableEntitys Movement",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "status": "inactive",
                              "label": "Idle",
                              "type": "status-dot"
                            }
                          ],
                          "gap": "md",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "columns": 2.0,
                          "children": [
                            {
                              "label": "X",
                              "type": "stat-display",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "x"
                              ]
                            },
                            {
                              "label": "Y",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "y"
                              ],
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "content": "Name",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "name"
                              ],
                              "variant": "body"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Description"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "description"
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Status",
                              "variant": "caption"
                            },
                            {
                              "content": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "status"
                              ],
                              "type": "typography",
                              "variant": "body"
                            }
