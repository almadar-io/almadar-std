                            {
                              "variant": "caption",
                              "content": "CreatedAt",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "content": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "createdAt"
                              ],
                              "variant": "body"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "icon": "navigation",
                              "event": "MOVE",
                              "label": "Move"
                            }
                          ],
                          "justify": "end",
                          "type": "stack",
                          "gap": "sm"
                        }
