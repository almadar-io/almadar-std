{
  "name": "std-agent-tool-call",
  "version": "1.0.0",
  "description": "std-agent-tool-call as a Function",
  "orbitals": [
    {
      "name": "AgentToolCallOrbital",
      "entity": {
        "name": "AgentToolCall",
        "collection": "agenttoolcalls",
