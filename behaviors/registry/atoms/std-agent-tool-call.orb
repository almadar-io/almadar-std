                          "icon": "wrench"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "INVOKE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "content": "Invoke Tool",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "toolName",
                            "args"
                          ],
                          "entity": "AgentToolCall",
                          "mode": "create",
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ],
                  [
                    "ref",
                    "AgentToolCall"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "wrench"
                                },
                                {
                                  "content": "Invoke Tool",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "variant": "primary",
                              "action": "INVOKE",
                              "type": "button",
                              "label": "Open",
                              "icon": "wrench"
                            }
                          ],
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "icon": "wrench",
                          "description": "Click Open to view details in a modal overlay.",
                          "title": "Nothing open"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentToolCall",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentToolCallSaveFailed",
                        "success": "AgentToolCallSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "INVOKED"
                  ],
                  [
                    "ref",
                    "AgentToolCall"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "wrench",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Invoke Tool",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "action": "INVOKE",
                              "variant": "primary",
                              "type": "button",
                              "label": "Open",
                              "icon": "wrench"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "description": "Click Open to view details in a modal overlay.",
                          "icon": "wrench",
                          "title": "Nothing open"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AgentToolCallAgent",
          "category": "interaction",
          "linkedEntity": "AgentToolCall",
          "emits": [
            {
              "event": "TOOL_STARTED",
              "scope": "internal",
              "payload": [
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TOOL_COMPLETED",
              "scope": "internal",
              "payload": [
                {
                  "name": "toolName",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LOG_ENTRY",
              "scope": "internal",
              "payload": [
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentToolCallLoaded",
              "description": "Fired when AgentToolCall finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                },
                {
                  "name": "args",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "number"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "detail",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentToolCallLoadFailed",
              "description": "Fired when AgentToolCall fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "INVOKED",
              "triggers": "INVOKED",
              "source": {
                "kind": "trait",
                "trait": "AgentToolCallModal"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "completed"
              },
              {
                "name": "failed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_INVOKE",
                "name": "Do Invoke",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "INVOKED",
                "name": "Invoked"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "TOOL_STARTED",
                "name": "Tool Started"
              },
              {
                "key": "TOOL_COMPLETED",
                "name": "Tool Completed"
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry"
              },
              {
                "key": "AgentToolCallLoaded",
                "name": "AgentToolCall loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "type": "string"
                  },
                  {
                    "name": "args",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "number"
                  },
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "timestamp",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentToolCallLoadFailed",
                "name": "AgentToolCall load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentToolCall",
                    {
                      "emit": {
                        "success": "AgentToolCallLoaded",
                        "failure": "AgentToolCallLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Tool Call is ready",
                      "title": "Tool Call",
                      "type": "empty-state",
                      "icon": "wrench"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DO_INVOKE",
                "effects": [
                  [
                    "set",
                    "@entity.toolName",
                    "@payload.data.toolName"
                  ],
                  [
                    "set",
                    "@entity.args",
                    "@payload.data.args"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "executing"
                  ],
                  [
                    "emit",
                    "TOOL_STARTED"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY"
                  ],
                  [
                    "agent/invoke",
                    "@payload.data.toolName",
                    "@payload.data.args"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "INVOKED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "executing"
                  ],
                  [
                    "emit",
                    "TOOL_STARTED"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY"
                  ],
                  [
                    "agent/invoke",
                    "@entity.toolName",
                    "@entity.args"
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "completed",
                "event": "DO_INVOKE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "set",
                    "@entity.result",
                    "@payload.data.result"
                  ],
                  [
                    "emit",
                    "TOOL_COMPLETED"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY"
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "failed",
                "event": "CANCEL",
                "guard": [
                  "=",
                  "@entity.status",
                  "executing"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Cancelled"
                  ],
                  [
                    "emit",
                    "TOOL_COMPLETED"
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "emit",
                    "TOOL_COMPLETED"
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "executing",
                "event": "DO_INVOKE",
                "effects": [
                  [
                    "set",
                    "@entity.toolName",
                    "@payload.data.toolName"
                  ],
                  [
                    "set",
                    "@entity.args",
                    "@payload.data.args"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "executing"
                  ],
                  [
                    "emit",
                    "TOOL_STARTED"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY"
                  ],
                  [
                    "agent/invoke",
                    "@payload.data.toolName",
                    "@payload.data.args"
                  ]
                ]
              },
              {
                "from": "failed",
                "to": "executing",
                "event": "DO_INVOKE",
                "effects": [
                  [
                    "set",
                    "@entity.toolName",
                    "@payload.data.toolName"
                  ],
                  [
                    "set",
                    "@entity.args",
                    "@payload.data.args"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "executing"
                  ],
                  [
                    "emit",
                    "TOOL_STARTED"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY"
                  ],
                  [
                    "agent/invoke",
                    "@payload.data.toolName",
                    "@payload.data.args"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentToolCallPage",
          "path": "/agenttoolcalls",
          "traits": [
            {
              "ref": "AgentToolCallModal"
            },
            {
              "ref": "AgentToolCallAgent"
            }
          ]
        }
      ]
    }
  ]
}