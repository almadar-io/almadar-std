{
  "name": "std-agent-chat-thread",
  "version": "1.0.0",
  "description": "std-agent-chat-thread as a Function",
  "orbitals": [
    {
      "name": "AgentChatThreadOrbital",
      "entity": {
        "name": "AgentChatThread",
        "collection": "agentchatthreads",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "sent"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "role",
            "type": "string",
            "default": "user",
            "values": [
              "user",
              "assistant",
              "system",
              "tool"
            ]
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentChatThreadThread",
          "category": "interaction",
          "linkedEntity": "AgentChatThread",
          "emits": [
            {
              "event": "AgentChatThreadLoaded",
              "description": "Fired when the chat thread finishes loading; payload.data holds the messages",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[AgentChatThread]"
                }
              ]
            },
            {
              "event": "AgentChatThreadLoadFailed",
              "description": "Fired when the chat thread fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaved",
              "description": "Fired when a new message is persisted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaveFailed",
              "description": "Fired when a message persist fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleted",
              "description": "Fired when the chat thread is cleared",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleteFailed",
              "description": "Fired when clearing the chat thread fails",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "composing"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentChatThreadLoaded",
                "name": "AgentChatThread loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[AgentChatThread]"
                  }
                ]
              },
              {
                "key": "AgentChatThreadLoadFailed",
                "name": "AgentChatThread load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_COMPOSE",
                "name": "Cancel Compose"
              },
              {
                "key": "AgentChatThreadSaved",
                "name": "AgentChatThread saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadSaveFailed",
                "name": "AgentChatThread save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleted",
                "name": "AgentChatThread deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleteFailed",
                "name": "AgentChatThread delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "failure": "AgentChatThreadLoadFailed",
                        "success": "AgentChatThreadLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading conversation…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "AgentChatThreadLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Chat Thread",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "action": "COMPOSE",
                              "label": "New Message",
                              "variant": "primary",
                              "type": "button",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "variant": "secondary",
                                      "type": "badge",
                                      "label": "@item.status"
                                    },
                                    {
                                      "content": "@item.timestamp",
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted"
                                    }
                                  ]
                                },
                                {
                                  "content": "@item.content",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "gap": "xs"
                            }
                          ],
                          "type": "data-list",
                          "fields": []
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentChatThreadLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load conversation",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Chat Thread"
                                }
                              ]
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "content"
                          ],
                          "cancelEvent": "CANCEL_COMPOSE",
                          "type": "form-section",
                          "submitEvent": "SEND",
                          "mode": "create"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "deleting",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadDeleted",
                        "failure": "AgentChatThreadDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Clearing conversation…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "persisting",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentChatThread",
                    {
                      "role": "user",
                      "timestamp": "@now",
                      "status": "sent",
                      "content": "@payload.content"
                    },
                    {
                      "emit": {
                        "failure": "AgentChatThreadSaveFailed",
                        "success": "AgentChatThreadSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Sending…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "loading",
                "event": "CANCEL_COMPOSE",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "loading",
                "event": "AgentChatThreadSaved",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AgentChatThreadSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to send message",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "loading",
                "event": "AgentChatThreadDeleted",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "error",
                "event": "AgentChatThreadDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to clear conversation"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "type": "button",
                          "label": "Retry"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentChatThreadPage",
          "path": "/agentchatthreads",
          "traits": [
            {
              "ref": "AgentChatThreadThread"
            }
          ]
        }
      ]
    }
  ]
}