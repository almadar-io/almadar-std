                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
