                              "gap": "xs"
                            }
                          ],
                          "entity": "AgentChatThread"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.role",
                    "user"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentChatThread",
                    {
                      "content": "@payload.content",
                      "timestamp": "@now",
                      "status": "sent",
                      "role": "user"
                    },
                    {
                      "emit": {
                        "failure": "AgentChatThreadSaveFailed",
                        "success": "AgentChatThreadSaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "SEND_MESSAGE"
                  ],
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "failure": "AgentChatThreadLoadFailed",
                        "success": "AgentChatThreadLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
