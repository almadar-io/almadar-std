                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "variant": "primary",
                              "icon": "plus",
                              "action": "COMPOSE",
                              "type": "button",
                              "label": "New Message"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "AgentChatThread",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "align": "center",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "label": "@item.status",
                                      "type": "badge",
                                      "variant": "outline"
                                    },
                                    {
                                      "variant": "caption",
