{
  "name": "std-agent-chat-thread",
  "version": "1.0.0",
  "description": "std-agent-chat-thread as a Function",
  "orbitals": [
    {
      "name": "AgentChatThreadOrbital",
      "entity": {
        "name": "AgentChatThread",
        "collection": "agentchatthreads",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "role",
            "type": "string",
            "default": "user"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentChatThreadThread",
          "category": "interaction",
          "linkedEntity": "AgentChatThread",
          "emits": [
            {
              "event": "SEND_MESSAGE",
              "scope": "internal",
              "payload": [
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadLoaded",
              "description": "Fired when AgentChatThread finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "role",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadLoadFailed",
              "description": "Fired when AgentChatThread fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "composing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message"
              },
              {
                "key": "AgentChatThreadLoaded",
                "name": "AgentChatThread loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "role",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "timestamp",
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadLoadFailed",
                "name": "AgentChatThread load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleted",
                "name": "AgentChatThread deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleteFailed",
                "name": "AgentChatThread delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadSaved",
                "name": "AgentChatThread saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadSaveFailed",
                "name": "AgentChatThread save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "content": "AgentChatThread Thread",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "action": "COMPOSE",
                              "variant": "primary",
                              "label": "New Message",
                              "icon": "plus"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "type": "data-list",
                          "entity": "AgentChatThread",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "label": "@item.role",
                                      "type": "badge"
                                    },
                                    {
                                      "label": "@item.status",
                                      "type": "badge",
                                      "variant": "outline"
                                    },
                                    {
                                      "content": "@item.timestamp",
                                      "type": "typography",
                                      "color": "muted",
                                      "variant": "caption"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "content": "@item.content",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "sm",
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "content": "AgentChatThread Thread",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "icon": "plus",
                              "type": "button",
                              "action": "COMPOSE",
                              "label": "New Message",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.role"
                                    },
                                    {
                                      "type": "badge",
                                      "label": "@item.status",
                                      "variant": "outline"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted",
