{
  "name": "std-service-github",
  "version": "1.0.0",
  "description": "std-service-github as a Function",
  "orbitals": [
    {
      "name": "ServiceGithubOrbital",
      "entity": {
        "name": "ServiceGithub",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "head",
            "type": "string",
            "default": ""
          },
          {
            "name": "base",
            "type": "string",
            "default": "main"
          },
          {
            "name": "prUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "prNumber",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "ghStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceGithubGithub",
          "category": "interaction",
          "linkedEntity": "ServiceGithub",
          "emits": [
            {
              "event": "ServiceGithubLoaded",
              "description": "Fired when ServiceGithub finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "head",
                  "type": "string"
                },
                {
                  "name": "base",
                  "type": "string"
                },
                {
                  "name": "prUrl",
                  "type": "string"
                },
                {
                  "name": "prNumber",
                  "type": "number"
                },
                {
                  "name": "ghStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubLoadFailed",
              "description": "Fired when ServiceGithub fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creatingPR"
              },
              {
                "name": "prCreated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PR",
                "name": "Create Pr"
              },
              {
                "key": "PR_CREATED",
                "name": "Pr Created",
                "payload": [
                  {
                    "name": "url",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "number",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceGithubLoaded",
                "name": "ServiceGithub loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "head",
                    "type": "string"
                  },
                  {
                    "name": "base",
                    "type": "string"
                  },
                  {
                    "name": "prUrl",
                    "type": "string"
                  },
                  {
                    "name": "prNumber",
                    "type": "number"
                  },
                  {
                    "name": "ghStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubLoadFailed",
                "name": "ServiceGithub load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubGithubCompleted",
                "name": "ServiceGithub github completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceGithubGithubFailed",
                "name": "ServiceGithub github failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceGithub",
                    {
                      "emit": {
                        "success": "ServiceGithubLoaded",
                        "failure": "ServiceGithubLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "type": "typography",
                              "content": "Create Pull Request",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "placeholder": "Describe your changes...",
                              "type": "textarea"
                            },
                            {
                              "placeholder": "feature-branch",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "main"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "md"
                        },
                        {
                          "icon": "git-pull-request",
                          "type": "button",
                          "variant": "primary",
                          "label": "Create PR",
                          "action": "CREATE_PR"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "creatingPR",
                "event": "CREATE_PR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Creating pull request...",
                      "type": "loading-state",
                      "message": "Submitting your PR to GitHub."
                    }
                  ],
                  [
                    "call-service",
                    "github",
                    "createPR",
                    {
                      "title": "@entity.title",
                      "body": "@entity.body",
                      "head": "@entity.head",
                      "base": "@entity.base"
                    },
                    {
                      "emit": {
                        "success": "ServiceGithubGithubCompleted",
                        "failure": "ServiceGithubGithubFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "prCreated",
                "event": "PR_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.prUrl",
                    "@payload.url"
                  ],
                  [
                    "set",
                    "@entity.prNumber",
                    "@payload.number"
                  ],
                  [
                    "set",
                    "@entity.ghStatus",
                    "created"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "message": "Pull request created!",
                          "variant": "success"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.prUrl",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "action": "RESET",
                          "label": "Create Another",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "PR Creation Failed",
                      "message": "@entity.error",
                      "onRetry": "RETRY",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "prCreated",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "content": "Create Pull Request",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Describe your changes..."
                            },
                            {
                              "placeholder": "feature-branch",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "main"
                            }
                          ]
                        },
                        {
                          "icon": "git-pull-request",
                          "action": "CREATE_PR",
                          "variant": "primary",
                          "label": "Create PR",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Create Pull Request"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "placeholder": "Describe your changes...",
                              "type": "textarea"
                            },
                            {
                              "type": "input",
                              "placeholder": "feature-branch"
                            },
                            {
                              "placeholder": "main",
                              "type": "input"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "action": "CREATE_PR",
                          "type": "button",
                          "label": "Create PR",
                          "icon": "git-pull-request",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "git-pull-request",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Create Pull Request"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "placeholder": "Describe your changes...",
                              "type": "textarea"
                            },
                            {
                              "placeholder": "feature-branch",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "main"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Create PR",
                          "icon": "git-pull-request",
                          "action": "CREATE_PR",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceGithubPage",
          "path": "/servicegithubs",
          "traits": [
            {
              "ref": "ServiceGithubGithub"
            }
          ]
        }
      ]
    }
  ]
}