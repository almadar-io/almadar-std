{
  "name": "std-sort",
  "version": "1.0.0",
  "description": "std-sort as a Function",
  "orbitals": [
    {
      "name": "SortableItemOrbital",
      "entity": {
        "name": "SortableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SortableItemSort",
          "category": "interaction",
          "linkedEntity": "SortableItem",
          "emits": [
            {
              "event": "SortableItemLoaded",
              "description": "Fired when SortableItem finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SortableItemLoadFailed",
              "description": "Fired when SortableItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sorted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SORT",
                "name": "Sort",
                "payload": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "direction",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SortableItemLoaded",
                "name": "SortableItem loaded"
              },
              {
                "key": "SortableItemLoadFailed",
                "name": "SortableItem load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "emit": {
                        "failure": "SortableItemLoadFailed",
                        "success": "SortableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "arrow-up-down",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "SortableItems"
                                }
                              ]
                            }
                          ],
                          "justify": "space-between",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "content": "Sort by",
                              "color": "muted",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "field": "name",
                                "direction": "asc"
                              },
                              "variant": "secondary",
                              "icon": "arrow-up-down",
                              "event": "SORT",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "variant": "secondary",
                              "actionPayload": {
                                "field": "description",
                                "direction": "asc"
                              },
                              "icon": "arrow-up-down",
                              "type": "button",
                              "event": "SORT"
                            },
                            {
                              "actionPayload": {
                                "field": "status",
                                "direction": "asc"
                              },
                              "type": "button",
                              "icon": "arrow-up-down",
                              "event": "SORT",
                              "variant": "secondary",
                              "label": "Status"
                            },
                            {
                              "variant": "secondary",
                              "event": "SORT",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "createdAt"
                              },
                              "label": "CreatedAt",
                              "icon": "arrow-up-down",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "emptyIcon": "inbox",
                          "entity": "SortableItem",
                          "emptyDescription": "Add sortableitems to see them here.",
                          "type": "data-grid",
                          "emptyTitle": "No sortableitems yet",
                          "columns": [
                            {
                              "variant": "h4",
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sorted",
                "event": "SORT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "sort": [
                        "concat",
                        "@payload.field",
                        ":",
                        "@payload.direction"
                      ],
                      "emit": {
                        "success": "SortableItemLoaded",
                        "failure": "SortableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "justify": "space-between",
                          "children": [
                            {
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "arrow-up-down"
                                },
                                {
                                  "type": "typography",
                                  "content": "SortableItems",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "button",
                              "icon": "x",
                              "label": "Clear sort",
                              "event": "INIT",
                              "variant": "ghost"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "color": "muted",
                              "type": "typography",
                              "content": "Sort by",
                              "variant": "caption"
                            },
                            {
                              "variant": "primary",
                              "type": "button",
                              "label": "Name",
                              "actionPayload": {
                                "field": "name",
                                "direction": "desc"
                              },
                              "event": "SORT",
                              "icon": "chevron-up"
                            },
                            {
                              "actionPayload": {
                                "direction": "asc",
                                "field": "description"
                              },
                              "event": "SORT",
                              "type": "button",
                              "label": "Description",
                              "variant": "secondary",
                              "icon": "arrow-up-down"
                            },
                            {
                              "event": "SORT",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "status"
                              },
                              "type": "button",
                              "icon": "arrow-up-down",
                              "label": "Status",
                              "variant": "secondary"
                            },
                            {
                              "event": "SORT",
                              "icon": "arrow-up-down",
                              "label": "CreatedAt",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "createdAt"
                              },
                              "variant": "secondary",
                              "type": "button"
                            }
                          ]
                        },
                        {
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyDescription": "Add sortableitems to see them here.",
                          "entity": "SortableItem",
                          "columns": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "emptyTitle": "No sortableitems yet"
                        },
                        {
                          "type": "sortable-list",
                          "onReorder": "SORT",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "grip-vertical",
                                  "type": "icon",
                                  "size": "sm"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@item.name"
                                }
                              ],
                              "type": "stack",
                              "align": "center",
                              "gap": "md"
                            }
                          ],
                          "entity": "SortableItem"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sorted",
                "to": "sorted",
                "event": "SORT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "sort": [
                        "concat",
                        "@payload.field",
                        ":",
                        "@payload.direction"
                      ],
                      "emit": {
                        "failure": "SortableItemLoadFailed",
                        "success": "SortableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "space-between",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "sm",
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "arrow-up-down"
                                },
                                {
                                  "content": "SortableItems",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "variant": "ghost",
                              "icon": "x",
                              "type": "button",
                              "label": "Clear sort",
                              "event": "INIT"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "color": "muted",
                              "type": "typography",
                              "variant": "caption",
                              "content": "Sort by"
                            },
                            {
                              "variant": "primary",
                              "actionPayload": {
                                "field": "name",
                                "direction": "desc"
                              },
                              "icon": "chevron-up",
                              "event": "SORT",
                              "type": "button",
                              "label": "Name"
                            },
                            {
                              "type": "button",
                              "label": "Description",
                              "variant": "secondary",
                              "icon": "arrow-up-down",
                              "actionPayload": {
                                "field": "description",
                                "direction": "asc"
                              },
                              "event": "SORT"
                            },
                            {
                              "label": "Status",
                              "icon": "arrow-up-down",
                              "actionPayload": {
                                "field": "status",
                                "direction": "asc"
                              },
                              "variant": "secondary",
                              "event": "SORT",
                              "type": "button"
                            },
                            {
                              "icon": "arrow-up-down",
                              "event": "SORT",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "createdAt"
                              },
                              "type": "button",
                              "label": "CreatedAt",
                              "variant": "secondary"
                            }
                          ]
                        },
                        {
                          "emptyTitle": "No sortableitems yet",
                          "columns": [
                            {
                              "variant": "h4",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "emptyDescription": "Add sortableitems to see them here.",
                          "type": "data-grid",
                          "emptyIcon": "inbox",
                          "entity": "SortableItem"
                        },
                        {
                          "entity": "SortableItem",
                          "onReorder": "SORT",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "grip-vertical",
                                  "size": "sm",
                                  "type": "icon"
                                },
                                {
                                  "content": "@item.name",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "align": "center"
                            }
                          ],
                          "type": "sortable-list"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "sorted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "emit": {
                        "success": "SortableItemLoaded",
                        "failure": "SortableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "space-between",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "arrow-up-down",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "variant": "h2",
                                  "content": "SortableItems",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Sort by",
                              "type": "typography",
                              "color": "muted"
                            },
                            {
                              "actionPayload": {
                                "field": "name",
                                "direction": "asc"
                              },
                              "type": "button",
                              "icon": "arrow-up-down",
                              "label": "Name",
                              "event": "SORT",
                              "variant": "secondary"
                            },
                            {
                              "label": "Description",
                              "actionPayload": {
                                "field": "description",
                                "direction": "asc"
                              },
                              "variant": "secondary",
                              "icon": "arrow-up-down",
                              "type": "button",
                              "event": "SORT"
                            },
                            {
                              "type": "button",
                              "event": "SORT",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "status"
                              },
                              "label": "Status",
                              "variant": "secondary",
                              "icon": "arrow-up-down"
                            },
                            {
                              "event": "SORT",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "arrow-up-down",
                              "label": "CreatedAt",
                              "actionPayload": {
                                "direction": "asc",
                                "field": "createdAt"
                              }
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "entity": "SortableItem",
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyTitle": "No sortableitems yet",
                          "emptyDescription": "Add sortableitems to see them here.",
                          "columns": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SortableItemSortPage",
          "path": "/sortableitems",
          "traits": [
            {
              "ref": "SortableItemSort"
            }
          ]
        }
      ]
    }
  ]
}