{
  "name": "std-sort",
  "version": "1.0.0",
  "description": "std-sort as a Function",
  "orbitals": [
    {
      "name": "SortableItemOrbital",
      "entity": {
        "name": "SortableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SortableItemSort",
          "category": "interaction",
          "linkedEntity": "SortableItem",
          "emits": [
            {
              "event": "SortableItemLoaded",
              "description": "Fired when SortableItem finishes loading; payload.data holds the sorted list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[SortableItem]"
                }
              ]
            },
            {
              "event": "SortableItemLoadFailed",
              "description": "Fired when SortableItem fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SortableItemLoaded",
                "name": "SortableItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[SortableItem]"
                  }
                ]
              },
              {
                "key": "SortableItemLoadFailed",
                "name": "SortableItem load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SORT",
                "name": "Sort",
                "payload": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "direction",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "emit": {
                        "success": "SortableItemLoaded",
                        "failure": "SortableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "SortableItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "arrow-up-down"
                                },
                                {
                                  "type": "typography",
                                  "content": "SortableItems",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center"
                            }
                          ],
                          "align": "center",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Sort by",
                              "color": "muted"
                            },
                            {
                              "variant": "secondary",
                              "action": "SORT",
                              "icon": "arrow-up-down",
                              "type": "button",
                              "label": "Name",
                              "actionPayload": {
                                "field": "name",
                                "direction": "asc"
                              }
                            },
                            {
                              "icon": "arrow-up-down",
                              "variant": "secondary",
                              "type": "button",
                              "label": "Description",
                              "action": "SORT",
                              "actionPayload": {
                                "field": "description",
                                "direction": "asc"
                              }
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "field": "status",
                                "direction": "asc"
                              },
                              "action": "SORT",
                              "variant": "secondary",
                              "icon": "arrow-up-down",
                              "label": "Status"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SortableItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "SORT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "emit": {
                        "success": "SortableItemLoaded",
                        "failure": "SortableItemLoadFailed"
                      },
                      "sort": [
                        "concat",
                        "@payload.field",
                        ":",
                        "@payload.direction"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SortableItem",
                    {
                      "emit": {
                        "failure": "SortableItemLoadFailed",
                        "success": "SortableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SortableItemSortPage",
          "path": "/sortableitems",
          "traits": [
            {
              "ref": "SortableItemSort"
            }
          ]
        }
      ]
    }
  ]
}