{
  "name": "std-validate-on-save",
  "version": "1.0.0",
  "description": "std-validate-on-save as a Function",
  "orbitals": [
    {
      "name": "ValidateOnSave",
      "entity": {
        "name": "ValidateOnSave",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string"
          },
          {
            "name": "valid",
            "type": "boolean",
            "default": false
          },
          {
            "name": "errors",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "warnings",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "OrbFileWatcher",
          "category": "interaction",
          "linkedEntity": "ValidateOnSave",
          "emits": [
            {
              "event": "AGENT_INTERRUPT",
              "scope": "external",
              "payload": [
                {
                  "name": "type",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "path",
                  "type": "string"
                },
                {
                  "name": "errors",
                  "type": "[string]"
                },
                {
                  "name": "blocking",
                  "type": "boolean"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.OS_FILE_MODIFIED",
              "triggers": "undefined"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "validating"
              },
              {
                "name": "valid"
              },
              {
                "name": "invalid"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OS_FILE_MODIFIED",
                "name": "Os File Modified",
                "payload": [
                  {
                    "name": "path",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VALIDATION_PASSED",
                "name": "Validation Passed",
                "payload": [
                  {
                    "name": "warnings",
                    "type": "array"
                  }
                ]
              },
              {
                "key": "VALIDATION_FAILED",
                "name": "Validation Failed",
                "payload": [
                  {
                    "name": "errors",
                    "type": "array"
                  },
                  {
                    "name": "warnings",
                    "type": "array"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "AGENT_INTERRUPT",
                "name": "Agent Interrupt"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "os/watch-files",
                    "**/*.orb"
                  ],
                  [
                    "os/debounce",
                    500.0,
                    "OS_FILE_MODIFIED"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "subtitle": "Watching **/*.orb for changes",
                      "title": "Orb File Validator"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "title": "Waiting for file changes",
                      "type": "empty-state",
                      "description": "Watching **/*.orb. Save an .orb file to trigger validation."
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "validating",
                "event": "OS_FILE_MODIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.path",
                    "@payload.path"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Orb File Validator",
                      "subtitle": "Validating...",
                      "type": "page-header"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "type": "loading-state",
                      "title": "Running orbital validate..."
                    }
                  ],
                  [
                    "call-service",
                    "orbital-cli",
                    "validate",
                    {
                      "onSuccess": "VALIDATION_PASSED",
                      "path": "@payload.path",
                      "onError": "VALIDATION_FAILED"
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "valid",
                "event": "VALIDATION_PASSED",
                "effects": [
                  [
                    "set",
                    "@entity.valid",
                    true
                  ],
                  [
                    "set",
                    "@entity.errors",
                    []
                  ],
                  [
                    "set",
                    "@entity.warnings",
                    "@payload.warnings"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "valid"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Orb File Validator",
                      "subtitle": "Validation passed",
                      "actions": [
                        {
                          "variant": "primary",
                          "label": "Validate Now",
                          "event": "REFRESH"
                        }
                      ],
                      "type": "page-header"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "path"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.path",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "valid",
                          "variant": "caption"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.valid",
                          "variant": "body"
                        },
                        {
                          "content": "status",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "content": "@entity.status",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "timestamp"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.timestamp"
                        }
                      ]
                    }
                  ],
                  [
                    "notify",
                    "success",
                    "Schema is valid"
                  ],
                  [
                    "emit",
                    "AGENT_INTERRUPT",
                    {
                      "type": "validation",
                      "status": "passed",
                      "path": "@entity.path",
                      "blocking": false
                    }
                  ]
                ]
              },
              {
                "from": "validating",
                "to": "invalid",
                "event": "VALIDATION_FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.valid",
                    false
                  ],
                  [
                    "set",
                    "@entity.errors",
                    "@payload.errors"
                  ],
                  [
                    "set",
                    "@entity.warnings",
                    "@payload.warnings"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "invalid"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Orb File Validator",
                      "actions": [
                        {
                          "variant": "primary",
                          "event": "REFRESH",
                          "label": "Validate Now"
                        }
                      ],
                      "type": "page-header",
                      "subtitle": "Validation failed"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "children": [
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "path"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.path"
                        },
                        {
                          "content": "status",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "content": "@entity.status",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "errors"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.errors",
                          "type": "typography"
                        },
                        {
                          "content": "warnings",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "content": "@entity.warnings",
                          "type": "typography",
                          "variant": "body"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ],
                  [
                    "notify",
                    "error",
                    "Schema has errors"
                  ],
                  [
                    "emit",
                    "AGENT_INTERRUPT",
                    {
                      "status": "failed",
                      "type": "validation",
                      "errors": "@payload.errors",
                      "path": "@entity.path",
                      "blocking": true
                    }
                  ]
                ]
              },
              {
                "from": "valid",
                "to": "validating",
                "event": "OS_FILE_MODIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.path",
                    "@payload.path"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Re-validating...",
                      "type": "page-header",
                      "title": "Orb File Validator"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "title": "Running orbital validate...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "orbital-cli",
                    "validate",
                    {
                      "onSuccess": "VALIDATION_PASSED",
                      "onError": "VALIDATION_FAILED",
                      "path": "@payload.path"
                    }
                  ]
                ]
              },
              {
                "from": "valid",
                "to": "validating",
                "event": "REFRESH",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "title": "Orb File Validator",
                      "subtitle": "Re-validating..."
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "type": "loading-state",
                      "title": "Running orbital validate..."
                    }
                  ],
                  [
                    "call-service",
                    "orbital-cli",
                    "validate",
                    {
                      "path": "@entity.path",
                      "onSuccess": "VALIDATION_PASSED",
                      "onError": "VALIDATION_FAILED"
                    }
                  ]
                ]
              },
              {
                "from": "invalid",
                "to": "validating",
                "event": "OS_FILE_MODIFIED",
                "effects": [
                  [
                    "set",
                    "@entity.path",
                    "@payload.path"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Orb File Validator",
                      "type": "page-header",
                      "subtitle": "Re-validating..."
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "title": "Running orbital validate...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "orbital-cli",
                    "validate",
                    {
                      "onSuccess": "VALIDATION_PASSED",
                      "path": "@payload.path",
                      "onError": "VALIDATION_FAILED"
                    }
                  ]
                ]
              },
              {
                "from": "invalid",
                "to": "validating",
                "event": "REFRESH",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "validating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Re-validating...",
                      "title": "Orb File Validator",
                      "type": "page-header"
                    }
                  ],
                  [
                    "render-ui",
                    "center",
                    {
                      "type": "loading-state",
                      "title": "Running orbital validate..."
                    }
                  ],
                  [
                    "call-service",
                    "orbital-cli",
                    "validate",
                    {
                      "onError": "VALIDATION_FAILED",
                      "path": "@entity.path",
                      "onSuccess": "VALIDATION_PASSED"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ValidatorPage",
          "path": "/validator",
          "traits": [
            {
              "ref": "OrbFileWatcher"
            }
          ]
        }
      ]
    }
  ]
}