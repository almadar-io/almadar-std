{
  "name": "std-strategy-game",
  "version": "1.0.0",
  "description": "std-strategy-game as a Function",
  "orbitals": [
    {
      "name": "ArmyBattleOrbital",
      "entity": {
        "name": "ArmyBattle",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "turn",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "armySize",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "morale",
            "type": "number",
            "default": 100.0
          }
        ]
      },
      "traits": [
        {
          "name": "ArmyBattleBattleFlow",
          "category": "interaction",
          "linkedEntity": "ArmyBattle",
          "emits": [
            {
              "event": "ArmyBattleLoaded",
              "description": "Fired when ArmyBattle finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "turn",
                  "type": "number"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "armySize",
                  "type": "number"
                },
                {
                  "name": "morale",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ArmyBattleLoadFailed",
              "description": "Fired when ArmyBattle fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "END_TURN",
                "name": "End Turn"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "ArmyBattleLoaded",
                "name": "ArmyBattle loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "turn",
                    "type": "number"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "armySize",
                    "type": "number"
                  },
                  {
                    "name": "morale",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ArmyBattleLoadFailed",
                "name": "ArmyBattle load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArmyBattle",
                    {
                      "emit": {
                        "success": "ArmyBattleLoaded",
                        "failure": "ArmyBattleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "subtitle": "Turn-Based Strategy",
                          "menuItems": [
                            {
                              "label": "Start Battle",
                              "variant": "primary",
                              "event": "START"
                            }
                          ],
                          "title": "Army Battle",
                          "type": "game-menu"
                        }
                      ],
                      "appName": "Strategy Game",
                      "showTopBar": true,
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Strategy Game",
                      "type": "game-shell",
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "Turn",
                              "value": "@entity.turn"
                            },
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            }
                          ],
                          "type": "game-hud"
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "END_TURN",
                "effects": [
                  [
                    "set",
                    "@entity.turn",
                    [
                      "+",
                      "@entity.turn",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Strategy Game",
                      "children": [
                        {
                          "stats": [
                            {
                              "value": "@entity.turn",
                              "label": "Turn"
                            },
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            }
                          ],
                          "type": "game-hud"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "menuItems": [
                        {
                          "label": "Resume",
                          "event": "RESUME",
                          "variant": "primary"
                        },
                        {
                          "label": "Quit",
                          "event": "RESTART",
                          "variant": "ghost"
                        }
                      ],
                      "title": "Paused",
                      "type": "game-menu"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Strategy Game",
                      "children": [
                        {
                          "type": "game-over-screen",
                          "stats": [
                            {
                              "label": "Turns",
                              "value": "@entity.turn"
                            },
                            {
                              "value": "@entity.score",
                              "label": "Score"
                            }
                          ],
                          "menuItems": [
                            {
                              "event": "RESTART",
                              "label": "Play Again",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "event": "RESTART",
                              "label": "Main Menu"
                            }
                          ],
                          "title": "Battle Over"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Strategy Game",
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Turn",
                              "value": "@entity.turn"
                            },
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Strategy Game",
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Turn",
                              "value": "@entity.turn"
                            },
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "subtitle": "Turn-Based Strategy",
                          "menuItems": [
                            {
                              "label": "Start Battle",
                              "event": "START",
                              "variant": "primary"
                            }
                          ],
                          "type": "game-menu",
                          "title": "Army Battle"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Strategy Game"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "title": "Army Battle",
                          "menuItems": [
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start Battle"
                            }
                          ],
                          "subtitle": "Turn-Based Strategy",
                          "type": "game-menu"
                        }
                      ],
                      "appName": "Strategy Game"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ArmyBattleCombatLog",
          "category": "interaction",
          "linkedEntity": "ArmyBattle",
          "emits": [
            {
              "event": "ArmyBattleLoaded",
              "description": "Fired when ArmyBattle finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "turn",
                  "type": "number"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "armySize",
                  "type": "number"
                },
                {
                  "name": "morale",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ArmyBattleLoadFailed",
              "description": "Fired when ArmyBattle fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOG_EVENT",
                "name": "Log Event",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "ArmyBattleLoaded",
                "name": "ArmyBattle loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "turn",
                    "type": "number"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "armySize",
                    "type": "number"
                  },
                  {
                    "name": "morale",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ArmyBattleLoadFailed",
                "name": "ArmyBattle load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArmyBattle",
                    {
                      "emit": {
                        "failure": "ArmyBattleLoadFailed",
                        "success": "ArmyBattleLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "LOG_EVENT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "showTimestamps": true,
                          "autoScroll": true,
                          "events": "@ArmyBattle",
                          "type": "combat-log",
                          "title": "Combat Log",
                          "maxVisible": 10.0
                        }
                      ],
                      "appName": "Strategy Game",
                      "showTopBar": true,
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Strategy Game",
                      "children": [
                        {
                          "showTimestamps": true,
                          "type": "combat-log",
                          "autoScroll": true,
                          "title": "Combat Log",
                          "maxVisible": 10.0,
                          "events": "@ArmyBattle"
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BattlePage",
          "path": "/battle",
          "traits": [
            {
              "ref": "ArmyBattleBattleFlow"
            },
            {
              "ref": "ArmyBattleCombatLog"
            }
          ]
        }
      ]
    },
    {
      "name": "TerritoryOrbital",
      "entity": {
        "name": "Territory",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "owner",
            "type": "string"
          },
          {
            "name": "defense",
            "type": "number"
          },
          {
            "name": "explored",
            "type": "boolean"
          }
        ]
      },
      "traits": [
        {
          "name": "TerritoryNavigation",
          "category": "interaction",
          "linkedEntity": "Territory",
          "emits": [
            {
              "event": "TerritoryLoaded",
              "description": "Fired when Territory finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "owner",
                  "type": "string"
                },
                {
                  "name": "defense",
                  "type": "number"
                },
                {
                  "name": "explored",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "TerritoryLoadFailed",
              "description": "Fired when Territory fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "exploring",
                "isInitial": true
              },
              {
                "name": "transitioning"
              },
              {
                "name": "entered"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TRAVEL",
                "name": "Travel"
              },
              {
                "key": "ARRIVE",
                "name": "Arrive"
              },
              {
                "key": "BACK",
                "name": "Back"
              },
              {
                "key": "TerritoryLoaded",
                "name": "Territory loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "owner",
                    "type": "string"
                  },
                  {
                    "name": "defense",
                    "type": "number"
                  },
                  {
                    "name": "explored",
                    "type": "boolean"
                  }
                ]
              },
              {
                "key": "TerritoryLoadFailed",
                "name": "Territory load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "exploring",
                "to": "exploring",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Territory",
                    {
                      "emit": {
                        "success": "TerritoryLoaded",
                        "failure": "TerritoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "map"
                                    },
                                    {
                                      "variant": "h2",
                                      "content": "Territory Map",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md"
                                },
                                {
                                  "label": "Exploring",
                                  "status": "online",
                                  "pulse": false,
                                  "type": "status-dot"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "markers": [],
                              "height": "200px",
                              "zoom": 10.0,
                              "type": "map-view"
                            },
                            {
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "direction": "vertical",
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "direction": "horizontal",
                                          "gap": "sm",
                                          "align": "center",
                                          "children": [
                                            {
                                              "type": "icon",
                                              "name": "map-pin"
                                            },
                                            {
                                              "type": "typography",
                                              "variant": "h4",
                                              "content": "@item.name"
                                            }
                                          ],
                                          "type": "stack"
                                        },
                                        {
                                          "label": "@item.owner",
                                          "type": "badge"
                                        }
                                      ],
                                      "align": "center",
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "justify": "between"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "content": "@item.defense"
                                    }
                                  ]
                                }
                              ],
                              "itemActions": [
                                {
                                  "label": "Travel",
                                  "event": "TRAVEL"
                                }
                              ],
                              "entity": "Territory",
                              "fields": [],
                              "type": "data-grid"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "appName": "Strategy Game"
                    }
                  ]
                ]
              },
              {
                "from": "exploring",
                "to": "transitioning",
                "event": "TRAVEL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
