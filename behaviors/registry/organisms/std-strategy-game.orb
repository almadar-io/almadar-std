                              ],
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "content": "Traveling to the destination territorys map.",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "transitioning",
                "to": "entered",
                "event": "ARRIVE",
                "effects": [
                  [
                    "fetch",
                    "Territory",
                    {
                      "emit": {
                        "failure": "TerritoryLoadFailed",
                        "success": "TerritoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Strategy Game",
                      "children": [
                        {
                          "gap": "lg",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "justify": "between",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "md",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "name": "map",
                                      "type": "icon"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "Territorys Map"
                                    }
                                  ]
                                },
                                {
                                  "label": "Entered",
                                  "status": "online",
                                  "type": "status-dot"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "align": "center",
                                          "gap": "sm",
                                          "type": "stack",
                                          "children": [
                                            {
                                              "name": "map-pin",
                                              "type": "icon"
                                            },
                                            {
                                              "variant": "h4",
                                              "content": "@item.name",
                                              "type": "typography"
                                            }
                                          ],
                                          "direction": "horizontal"
                                        },
                                        {
                                          "type": "badge",
                                          "label": "@item.owner"
                                        }
                                      ],
                                      "justify": "between",
                                      "align": "center"
