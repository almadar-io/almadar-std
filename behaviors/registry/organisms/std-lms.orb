        {
          "name": "CourseDelete",
          "category": "interaction",
          "linkedEntity": "Course",
          "emits": [
            {
              "event": "COURSE_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoaded",
              "description": "Fired when Course finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "instructor",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "string"
                },
                {
                  "name": "level",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoadFailed",
              "description": "Fired when Course fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "COURSE_DELETED",
                "name": "Course Deleted"
              },
              {
                "key": "CourseLoaded",
                "name": "Course loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "instructor",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "string"
                  },
                  {
                    "name": "level",
                    "type": "string"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CourseLoadFailed",
                "name": "Course load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Course"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Course",
                    {
                      "emit": {
                        "failure": "CourseLoadFailed",
                        "success": "CourseLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "type": "typography",
                              "content": "Delete Course",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "action": "CANCEL",
                              "label": "Cancel"
                            },
                            {
                              "type": "button",
                              "action": "CONFIRM_DELETE",
                              "label": "Delete",
                              "icon": "check",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Course",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Course"
                  ],
                  [
                    "emit",
                    "COURSE_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Course"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Course"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
