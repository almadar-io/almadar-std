{
  "name": "std-lms",
  "version": "1.0.0",
  "description": "std-lms as a Function",
  "orbitals": [
    {
      "name": "CourseOrbital",
      "entity": {
        "name": "Course",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "instructor",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "string",
            "default": ""
          },
          {
            "name": "level",
            "type": "string",
            "default": "Beginner",
            "values": [
              "Beginner",
              "Intermediate",
              "Advanced"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CourseBrowse",
          "category": "interaction",
          "linkedEntity": "Course",
          "emits": [
            {
              "event": "ENROLL",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoaded",
              "description": "Fired when Course finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "instructor",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "string"
                },
                {
                  "name": "level",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoadFailed",
              "description": "Fired when Course fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COURSE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CourseCreate"
              }
            },
            {
              "event": "COURSE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CourseEdit"
              }
            },
            {
              "event": "COURSE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CourseDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ENROLL",
                "name": "Enroll"
              },
              {
                "key": "CourseLoaded",
                "name": "Course loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "instructor",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "string"
                  },
                  {
                    "name": "level",
                    "type": "string"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CourseLoadFailed",
                "name": "Course load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Course"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "book-open",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Courses",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm"
                                },
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "icon": "plus",
                                      "variant": "primary",
                                      "label": "Add Course",
                                      "type": "button",
                                      "action": "CREATE"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "justify": "between",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "itemActions": [
                                {
                                  "label": "View",
                                  "event": "VIEW",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Edit",
                                  "event": "EDIT",
                                  "variant": "ghost"
                                },
                                {
                                  "event": "DELETE",
                                  "label": "Delete",
                                  "variant": "danger"
                                }
                              ],
                              "columns": [
                                {
                                  "variant": "h3",
                                  "icon": "book-open",
                                  "name": "title"
                                },
                                {
                                  "name": "level",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "body",
                                  "name": "instructor"
                                },
                                {
                                  "name": "duration",
                                  "variant": "body"
                                },
                                {
                                  "name": "description",
                                  "variant": "caption"
                                }
                              ],
                              "cols": 2.0,
                              "gap": "md",
                              "fields": [],
                              "entity": "Course",
                              "type": "data-grid"
                            }
                          ],
                          "className": "max-w-5xl mx-auto w-full",
                          "type": "stack",
                          "direction": "vertical"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Courses",
                          "href": "/courses",
                          "icon": "book-open"
                        },
                        {
                          "label": "Enroll",
                          "icon": "layout-list",
                          "href": "/enroll"
                        },
                        {
                          "label": "Progress",
                          "icon": "layout-list",
                          "href": "/progress"
                        }
                      ],
                      "appName": "LMS",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CourseCreate",
          "category": "interaction",
          "linkedEntity": "Course",
          "emits": [
            {
              "event": "COURSE_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoaded",
              "description": "Fired when Course finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "instructor",
                  "type": "string"
                },
                {
                  "name": "duration",
                  "type": "string"
                },
                {
                  "name": "level",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoadFailed",
              "description": "Fired when Course fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "COURSE_CREATED",
                "name": "Course Created"
              },
              {
                "key": "CourseLoaded",
                "name": "Course loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "instructor",
                    "type": "string"
                  },
                  {
                    "name": "duration",
                    "type": "string"
                  },
                  {
                    "name": "level",
                    "type": "string"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CourseLoadFailed",
                "name": "Course load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Course"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Course",
                    {
                      "emit": {
                        "success": "CourseLoaded",
                        "failure": "CourseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "New Course"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "title",
                            "description",
                            "instructor",
                            "duration",
                            "level"
                          ],
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "entity": "Course",
                          "mode": "create"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Course",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "COURSE_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CourseEdit",
          "category": "interaction",
          "linkedEntity": "Course",
          "emits": [
            {
              "event": "COURSE_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CourseLoaded",
              "description": "Fired when Course finishes loading",
