              "ref": "TransactionBrowse"
            },
            {
              "ref": "TransactionCreate"
            },
            {
              "ref": "TransactionEdit"
            },
            {
              "ref": "TransactionView"
            },
            {
              "ref": "TransactionDelete"
            }
          ]
        }
      ]
