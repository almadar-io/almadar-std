{
  "name": "std-finance-tracker",
  "version": "1.0.0",
  "description": "std-finance-tracker as a Function",
  "orbitals": [
    {
      "name": "TransactionOrbital",
      "entity": {
        "name": "Transaction",
        "collection": "transactions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "required": true
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "date",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TransactionBrowse",
          "category": "interaction",
          "linkedEntity": "Transaction",
          "emits": [
            {
              "event": "TransactionLoaded",
              "description": "Fired when Transaction finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "date",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TransactionLoadFailed",
              "description": "Fired when Transaction fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TRANSACTION_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TransactionCreate"
              }
            },
            {
              "event": "TRANSACTION_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TransactionEdit"
              }
            },
            {
              "event": "TRANSACTION_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TransactionDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TransactionLoaded",
                "name": "Transaction loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "date",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TransactionLoadFailed",
                "name": "Transaction load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Transaction"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Finance Tracker",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Transactions",
                          "href": "/transactions",
                          "icon": "dollar-sign"
                        },
                        {
                          "label": "Summary",
                          "icon": "layout-list",
                          "href": "/summary"
                        },
                        {
                          "label": "Reports",
                          "icon": "bar-chart",
                          "href": "/reports"
                        }
                      ],
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "credit-card"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Transactions",
                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "action": "CREATE",
                                      "type": "button",
                                      "label": "Create Transaction",
                                      "variant": "primary",
                                      "icon": "plus"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "justify": "between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "data-list",
                              "entity": "Transaction",
                              "itemActions": [
                                {
                                  "event": "VIEW",
                                  "label": "View",
                                  "variant": "ghost"
                                },
                                {
                                  "event": "EDIT",
                                  "variant": "ghost",
                                  "label": "Edit"
                                },
                                {
                                  "label": "Delete",
                                  "event": "DELETE",
                                  "variant": "danger"
                                }
                              ],
                              "columns": [
                                {
                                  "icon": "credit-card",
                                  "name": "description",
                                  "variant": "h3"
                                },
                                {
                                  "name": "category",
                                  "variant": "badge"
                                },
                                {
                                  "name": "amount",
                                  "variant": "h4",
                                  "format": "currency"
                                },
                                {
                                  "format": "date",
                                  "name": "date",
                                  "variant": "caption"
                                }
                              ],
                              "gap": "sm",
                              "variant": "card",
                              "fields": []
                            }
                          ],
                          "className": "max-w-5xl mx-auto w-full",
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TransactionCreate",
          "category": "interaction",
          "linkedEntity": "Transaction",
          "emits": [
            {
              "event": "TRANSACTION_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TransactionLoaded",
              "description": "Fired when Transaction finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "date",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TransactionLoadFailed",
              "description": "Fired when Transaction fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TRANSACTION_CREATED",
                "name": "Transaction Created"
              },
              {
                "key": "TransactionLoaded",
                "name": "Transaction loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "date",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TransactionLoadFailed",
                "name": "Transaction load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Transaction"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Transaction",
                    {
                      "emit": {
                        "failure": "TransactionLoadFailed",
                        "success": "TransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Create Transaction",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Transaction",
                          "submitEvent": "SAVE",
                          "mode": "create",
                          "fields": [
                            "description",
                            "amount",
                            "category",
                            "date"
                          ],
                          "cancelEvent": "CLOSE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Transaction",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TRANSACTION_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TransactionEdit",
          "category": "interaction",
          "linkedEntity": "Transaction",
          "emits": [
            {
              "event": "TRANSACTION_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TransactionLoaded",
              "description": "Fired when Transaction finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "date",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TransactionLoadFailed",
              "description": "Fired when Transaction fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TRANSACTION_UPDATED",
                "name": "Transaction Updated"
              },
              {
                "key": "TransactionLoaded",
                "name": "Transaction loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "date",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TransactionLoadFailed",
                "name": "Transaction load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Transaction"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Transaction",
                    {
                      "emit": {
                        "success": "TransactionLoaded",
                        "failure": "TransactionLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "content": "Edit Transaction",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "description",
                            "amount",
                            "category",
                            "date"
                          ],
                          "mode": "edit",
                          "entityId": "@entity.id",
                          "type": "form-section",
                          "entity": "Transaction"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Transaction",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TRANSACTION_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
