{
  "name": "std-cms",
  "version": "1.0.0",
  "description": "std-cms as a Function",
  "orbitals": [
    {
      "name": "ArticleOrbital",
      "entity": {
        "name": "Article",
        "collection": "articles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "author",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "review",
              "published",
              "archived"
            ]
          },
          {
            "name": "publishedAt",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ArticleBrowse",
          "category": "interaction",
          "linkedEntity": "Article",
          "emits": [
            {
              "event": "PUBLISH",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CATEGORIZE",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoaded",
              "description": "Fired when Article finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "publishedAt",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoadFailed",
              "description": "Fired when Article fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ARTICLE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleCreate"
              }
            },
            {
              "event": "ARTICLE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleEdit"
              }
            },
            {
              "event": "ARTICLE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PUBLISH",
                "name": "Publish"
              },
              {
                "key": "CATEGORIZE",
                "name": "Categorize"
              },
              {
                "key": "ArticleLoaded",
                "name": "Article loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "slug",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "author",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "publishedAt",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ArticleLoadFailed",
                "name": "Article load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Article"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "CmsApp",
                      "children": [
                        {
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "size": "lg",
                                      "type": "icon",
                                      "name": "file-text"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "Articles"
                                    }
                                  ]
                                },
                                {
                                  "children": [
                                    {
                                      "icon": "plus",
                                      "type": "button",
                                      "variant": "primary",
                                      "event": "CREATE",
                                      "label": "Create Article"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack"
                                }
                              ],
                              "gap": "md",
                              "justify": "space-between",
                              "align": "center",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "emptyDescription": "Write your first article.",
                              "emptyTitle": "No articles yet",
                              "type": "data-list",
                              "emptyIcon": "inbox",
                              "gap": "sm",
                              "itemActions": [
                                {
                                  "event": "VIEW",
                                  "variant": "ghost",
                                  "label": "View",
                                  "size": "sm"
                                },
                                {
                                  "label": "Edit",
                                  "size": "sm",
                                  "variant": "ghost",
                                  "event": "EDIT"
                                },
                                {
                                  "variant": "danger",
                                  "event": "DELETE",
                                  "size": "sm",
                                  "label": "Delete"
                                }
                              ],
                              "entity": "Article",
                              "columns": [
                                {
                                  "variant": "h3",
                                  "icon": "file-text",
                                  "name": "title"
                                },
                                {
                                  "variant": "badge",
                                  "name": "status"
                                },
                                {
                                  "variant": "body",
                                  "name": "author"
                                },
                                {
                                  "name": "slug",
                                  "variant": "caption"
                                },
                                {
                                  "label": "Published",
                                  "format": "date",
                                  "name": "publishedAt",
                                  "variant": "caption"
                                }
                              ],
                              "variant": "card"
                            }
                          ],
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ],
                      "navItems": [
                        {
                          "icon": "file-text",
                          "label": "Articles",
                          "href": "/articles"
                        },
                        {
                          "label": "Media",
                          "icon": "image",
                          "href": "/media"
                        },
                        {
                          "label": "Categories",
                          "icon": "folder",
                          "href": "/categories"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ArticleCreate",
          "category": "interaction",
          "linkedEntity": "Article",
          "emits": [
            {
              "event": "ARTICLE_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoaded",
              "description": "Fired when Article finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "publishedAt",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoadFailed",
              "description": "Fired when Article fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARTICLE_CREATED",
                "name": "Article Created"
              },
              {
                "key": "ArticleLoaded",
                "name": "Article loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "slug",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "author",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "publishedAt",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ArticleLoadFailed",
                "name": "Article load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Article"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Article",
                    {
                      "emit": {
                        "failure": "ArticleLoadFailed",
                        "success": "ArticleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "plus-circle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Create Article",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "title",
                            "slug",
                            "content",
                            "author",
                            "status",
                            "publishedAt"
                          ],
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "mode": "create",
                          "cancelEvent": "CLOSE",
                          "entity": "Article"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Article",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ARTICLE_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ArticleEdit",
          "category": "interaction",
          "linkedEntity": "Article",
          "emits": [
            {
              "event": "ARTICLE_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoaded",
              "description": "Fired when Article finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "publishedAt",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoadFailed",
              "description": "Fired when Article fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARTICLE_UPDATED",
                "name": "Article Updated"
              },
              {
                "key": "ArticleLoaded",
                "name": "Article loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "slug",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "author",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "publishedAt",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ArticleLoadFailed",
                "name": "Article load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Article"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Article",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "success": "ArticleLoaded",
                        "failure": "ArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "edit",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Edit Article",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "entityId": "@entity.id",
                          "fields": [
                            "title",
                            "slug",
                            "content",
                            "author",
                            "status",
                            "publishedAt"
                          ],
                          "type": "form-section",
                          "mode": "edit",
                          "entity": "Article",
                          "submitEvent": "SAVE"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Article",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ARTICLE_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
