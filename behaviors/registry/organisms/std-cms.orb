              },
              {
                "key": "CategoryLoaded",
                "name": "Category loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "slug",
                    "type": "string",
                    "required": true
