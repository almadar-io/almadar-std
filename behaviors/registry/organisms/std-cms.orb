                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "type": "form-section",
                          "entity": "Category",
                          "fields": [
                            "name",
                            "slug",
                            "description",
                            "parentCategory",
                            "articleCount"
                          ],
                          "entityId": "@entity.id",
                          "mode": "edit"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Category",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "CATEGORY_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
