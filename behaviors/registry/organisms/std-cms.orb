                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "File Name",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.fileName"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "content": "File Type",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "content": "@entity.fileType",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "content": "File Size",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.fileSize"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Url",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.url",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Alt Text",
                              "variant": "caption"
                            },
                            {
                              "content": "@entity.altText",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Uploaded At"
                            },
                            {
                              "content": "@entity.uploadedAt",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Close",
                              "event": "CLOSE",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
