        {
          "name": "ArticleDelete",
          "category": "interaction",
          "linkedEntity": "Article",
          "emits": [
            {
              "event": "ARTICLE_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoaded",
              "description": "Fired when Article finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "publishedAt",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoadFailed",
              "description": "Fired when Article fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ARTICLE_DELETED",
                "name": "Article Deleted"
              },
              {
                "key": "ArticleLoaded",
                "name": "Article loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "slug",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "author",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "publishedAt",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ArticleLoadFailed",
                "name": "Article load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Article"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Article",
                    {
                      "emit": {
                        "failure": "ArticleLoadFailed",
                        "success": "ArticleLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Delete Article"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "danger",
                          "message": "This action cannot be undone.",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "event": "CANCEL",
                              "type": "button",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "end"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Article",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Article"
                  ],
                  [
                    "emit",
                    "ARTICLE_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Article"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Article"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
