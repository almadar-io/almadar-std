{
  "name": "std-platformer-app",
  "version": "1.0.0",
  "description": "std-platformer-app as a Function",
  "orbitals": [
    {
      "name": "PlatLevelOrbital",
      "entity": {
        "name": "PlatLevel",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lives",
            "type": "number",
            "default": 3.0
          },
          {
            "name": "time",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "player",
            "type": "string",
            "default": ""
          },
          {
            "name": "platforms",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PlatLevelPlatformerFlow",
          "category": "interaction",
          "linkedEntity": "PlatLevel",
          "emits": [
            {
              "event": "PlatLevelLoaded",
              "description": "Fired when PlatLevel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PlatLevel]"
                }
              ]
            },
            {
              "event": "PlatLevelLoadFailed",
              "description": "Fired when PlatLevel fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CollectibleDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "PlatLevelLoaded",
                "name": "PlatLevel loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PlatLevel]"
                  }
                ]
              },
              {
                "key": "PlatLevelLoadFailed",
                "name": "PlatLevel load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleSaved",
                "name": "Collectible saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleSaveFailed",
                "name": "Collectible save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleUpdated",
                "name": "Collectible updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleUpdateFailed",
                "name": "Collectible update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleDeleted",
                "name": "Collectible deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CollectibleDeleteFailed",
                "name": "Collectible delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatLevel",
                    {
                      "emit": {
                        "failure": "PlatLevelLoadFailed",
                        "success": "PlatLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Platformer App",
                      "showTopBar": true,
                      "children": [
                        {
                          "type": "game-menu",
                          "title": "Platformer",
                          "subtitle": "Side-Scrolling Adventure",
                          "menuItems": [
                            {
                              "variant": "primary",
                              "label": "Start Game",
                              "event": "START"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Platformer App",
                      "children": [
                        {
                          "canvasWidth": 800.0,
                          "stopEvent": "STOP",
                          "worldWidth": 2400.0,
                          "followCamera": true,
                          "worldHeight": 400.0,
                          "rightEvent": "RIGHT",
                          "type": "platformer-canvas",
                          "leftEvent": "LEFT",
                          "bgColor": "#1a1a2e",
                          "canvasHeight": 400.0,
                          "jumpEvent": "JUMP"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "LEFT"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "RIGHT"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "JUMP"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "STOP"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "menuItems": [
                        {
                          "variant": "primary",
                          "label": "Resume",
                          "event": "RESUME"
                        },
                        {
                          "variant": "ghost",
                          "label": "Quit",
                          "event": "RESTART"
                        }
                      ],
                      "type": "game-menu",
                      "title": "Paused"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Platformer App",
                      "children": [
                        {
                          "type": "game-over-screen",
                          "menuItems": [
                            {
                              "event": "RESTART",
                              "label": "Play Again",
                              "variant": "primary"
                            },
                            {
                              "label": "Main Menu",
                              "event": "RESTART",
                              "variant": "secondary"
                            }
                          ],
                          "stats": [
                            {
                              "label": "Score",
                              "value": "@entity.score"
                            },
                            {
                              "value": "@entity.lives",
                              "label": "Lives"
                            }
                          ],
                          "title": "Game Over"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Platformer App",
                      "type": "game-shell",
                      "children": [
                        {
                          "canvasHeight": 400.0,
                          "stopEvent": "STOP",
                          "type": "platformer-canvas",
                          "rightEvent": "RIGHT",
                          "followCamera": true,
                          "bgColor": "#1a1a2e",
                          "jumpEvent": "JUMP",
                          "worldWidth": 2400.0,
                          "worldHeight": 400.0,
                          "leftEvent": "LEFT",
                          "canvasWidth": 800.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Platformer App",
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "platformer-canvas",
                          "stopEvent": "STOP",
                          "worldWidth": 2400.0,
                          "worldHeight": 400.0,
                          "rightEvent": "RIGHT",
                          "leftEvent": "LEFT",
                          "bgColor": "#1a1a2e",
                          "canvasHeight": 400.0,
                          "jumpEvent": "JUMP",
                          "canvasWidth": 800.0,
                          "followCamera": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Platformer App",
                      "showTopBar": true,
                      "children": [
                        {
                          "type": "game-menu",
                          "title": "Platformer",
                          "subtitle": "Side-Scrolling Adventure",
                          "menuItems": [
                            {
                              "variant": "primary",
                              "event": "START",
                              "label": "Start Game"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "menuItems": [
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start Game"
                            }
                          ],
                          "type": "game-menu",
                          "title": "Platformer",
                          "subtitle": "Side-Scrolling Adventure"
                        }
                      ],
                      "appName": "Platformer App",
                      "type": "game-shell"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PlatLevelPlatformerCanvas",
          "category": "interaction",
          "linkedEntity": "PlatLevel",
          "emits": [
            {
              "event": "PlatLevelLoaded",
              "description": "Fired when PlatLevel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PlatLevel]"
                }
              ]
            },
            {
              "event": "PlatLevelLoadFailed",
              "description": "Fired when PlatLevel fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LEFT",
                "name": "Left"
              },
              {
                "key": "RIGHT",
                "name": "Right"
              },
              {
                "key": "JUMP",
                "name": "Jump"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "PlatLevelLoaded",
                "name": "PlatLevel loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PlatLevel]"
                  }
                ]
              },
              {
                "key": "PlatLevelLoadFailed",
                "name": "PlatLevel load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatLevel",
                    {
                      "emit": {
                        "success": "PlatLevelLoaded",
                        "failure": "PlatLevelLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "running",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "leftEvent": "LEFT",
                          "platforms": "@entity.platforms",
                          "rightEvent": "RIGHT",
                          "worldWidth": 2400.0,
                          "jumpEvent": "JUMP",
                          "stopEvent": "STOP",
                          "type": "platformer-canvas",
                          "player": "@entity.player",
                          "canvasWidth": 800.0,
                          "canvasHeight": 400.0,
                          "worldHeight": 400.0,
                          "bgColor": "#1a1a2e",
                          "followCamera": true
                        }
                      ],
                      "appName": "Platformer App"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "LEFT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "RIGHT"
              },
              {
                "from": "running",
                "to": "running",
                "event": "JUMP"
              },
              {
                "from": "running",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "platformer-canvas",
                          "canvasHeight": 400.0,
                          "rightEvent": "RIGHT",
                          "jumpEvent": "JUMP",
                          "player": "@entity.player",
                          "followCamera": true,
                          "bgColor": "#1a1a2e",
                          "worldHeight": 400.0,
                          "leftEvent": "LEFT",
                          "worldWidth": 2400.0,
                          "stopEvent": "STOP",
                          "canvasWidth": 800.0,
                          "platforms": "@entity.platforms"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Platformer App",
                      "showTopBar": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "GamePage",
          "path": "/game",
          "traits": [
            {
              "ref": "PlatLevelPlatformerFlow"
            },
            {
              "ref": "PlatLevelPlatformerCanvas"
            }
          ]
        }
      ]
    },
    {
      "name": "PlatScoreOrbital",
      "entity": {
        "name": "PlatScore",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "playerName",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "required": true,
            "default": 0.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "completedAt",
            "type": "string"
          },
          {
            "name": "highScore",
            "type": "number"
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "PlatScoreScoreBoard",
          "category": "interaction",
          "linkedEntity": "PlatScore",
          "emits": [
            {
              "event": "PlatScoreLoaded",
              "description": "Fired when PlatScore finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[PlatScore]"
                }
              ]
            },
            {
              "event": "PlatScoreLoadFailed",
              "description": "Fired when PlatScore fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_SCORE",
                "name": "Add Score",
                "payload": [
                  {
                    "name": "points",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "PlatScoreLoaded",
                "name": "PlatScore loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[PlatScore]"
                  }
                ]
              },
              {
                "key": "PlatScoreLoadFailed",
                "name": "PlatScore load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PlatScore",
                    {
                      "emit": {
                        "success": "PlatScoreLoaded",
                        "failure": "PlatScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "multiplier": "@entity.multiplier",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "score": "@entity.score",
                          "combo": "@entity.combo",
                          "type": "score-board"
                        }
                      ],
                      "appName": "Platformer App",
                      "showTopBar": true,
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Platformer App",
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "score": "@entity.score",
                          "combo": "@entity.combo",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "multiplier": "@entity.multiplier",
                          "type": "score-board"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level",
                          "type": "score-board",
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "score": "@entity.score"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Platformer App",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Platformer App",
                      "children": [
                        {
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "level": "@entity.level",
                          "type": "score-board",
