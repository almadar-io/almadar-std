                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_ADDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CollectibleAdd"
              }
            },
            {
              "event": "ITEM_USED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CollectibleUse"
              }
            },
            {
              "event": "CONFIRM_DROP",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CollectibleDrop"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CollectibleLoaded",
                "name": "Collectible loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Collectible]"
                  }
                ]
              },
              {
                "key": "CollectibleLoadFailed",
                "name": "Collectible load failed",
