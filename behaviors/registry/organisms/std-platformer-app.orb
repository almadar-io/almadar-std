            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Collectible",
                    {
                      "emit": {
                        "failure": "CollectibleLoadFailed",
                        "success": "CollectibleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CollectibleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Platformer App",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "name": "package",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h2",
                                      "content": "Collectibles"
                                    }
                                  ],
                                  "align": "center",
                                  "type": "stack"
                                },
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "action": "ADD_ITEM",
                                      "label": "Add Collectible",
                                      "variant": "primary",
                                      "icon": "plus",
                                      "type": "button"
                                    }
                                  ]
                                }
                              ],
                              "type": "stack",
                              "justify": "between",
                              "align": "center",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "itemActions": [
                                {
                                  "event": "USE_ITEM",
                                  "label": "Use",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Drop",
                                  "event": "DROP",
                                  "variant": "danger"
                                }
                              ],
                              "columns": [
                                {
                                  "variant": "h4",
                                  "name": "name",
                                  "label": "Name",
                                  "icon": "package"
                                },
                                {
                                  "colorMap": {
                                    "error": "destructive",
                                    "draft": "warning",
                                    "archived": "neutral",
                                    "completed": "success",
                                    "done": "success",
                                    "pending": "warning",
                                    "disabled": "neutral",
                                    "active": "success",
                                    "inactive": "neutral",
                                    "cancelled": "destructive",
                                    "scheduled": "warning",
                                    "failed": "destructive"
                                  },
                                  "name": "type",
                                  "label": "Type",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "caption",
                                  "name": "quantity",
                                  "label": "Quantity"
