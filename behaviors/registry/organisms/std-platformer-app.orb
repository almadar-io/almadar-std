                              "type": "button",
                              "icon": "check",
                              "variant": "danger",
                              "label": "Drop",
                              "action": "CONFIRM_DROP"
                            }
                          ],
                          "justify": "end",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DROP",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Collectible",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "CollectibleDeleteFailed",
                        "success": "CollectibleDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Collectible"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Collectible"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Collectible"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Collectibles",
