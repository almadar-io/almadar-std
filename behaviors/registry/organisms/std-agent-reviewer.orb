          "category": "interaction",
          "linkedEntity": "ReviewCompletion",
          "emits": [
            {
              "event": "ReviewCompletionLoaded",
              "description": "Fired when ReviewCompletion finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ReviewCompletion]"
                }
              ]
            },
            {
              "event": "ReviewCompletionLoadFailed",
              "description": "Fired when ReviewCompletion fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "hidden",
                "isInitial": true
              },
              {
                "name": "visible"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SHOW",
                "name": "Show",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "HIDE",
                "name": "Hide"
              },
              {
                "key": "ReviewCompletionLoaded",
                "name": "ReviewCompletion loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ReviewCompletion]"
                  }
                ]
              },
              {
                "key": "ReviewCompletionLoadFailed",
                "name": "ReviewCompletion load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "hidden",
                "to": "hidden",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewCompletion",
                    {
                      "emit": {
                        "success": "ReviewCompletionLoaded",
                        "failure": "ReviewCompletionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "hidden",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Review",
                          "icon": "file-search",
                          "href": "/review"
                        },
                        {
                          "icon": "tag",
                          "href": "/analysis",
                          "label": "Analysis"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "appName": "Code Reviewer",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "align": "center",
                              "justify": "between",
                              "children": [
                                {
                                  "gap": "md",
                                  "align": "center",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "sparkles"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h2",
                                      "content": "ReviewCompletion Status"
                                    }
                                  ]
                                },
                                {
                                  "type": "button",
                                  "label": "Dismiss",
                                  "variant": "ghost",
                                  "icon": "x",
                                  "action": "HIDE"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "message": "@entity.message",
                              "type": "alert",
                              "variant": "@entity.notificationType"
                            },
                            {
                              "type": "toast-slot"
                            },
                            {
                              "variant": "warning",
                              "type": "alert",
                              "message": "@entity.message"
                            }
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "visible",
                "event": "SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    "@payload.message"
                  ],
                  [
                    "set",
                    "@entity.notificationType",
                    "@payload.notificationType"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "href": "/review",
                          "icon": "file-search",
                          "label": "Review"
                        },
                        {
                          "icon": "tag",
                          "href": "/analysis",
                          "label": "Analysis"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "justify": "between",
                              "children": [
                                {
                                  "align": "center",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "name": "sparkles",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "ReviewCompletion Status",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "md"
                                },
                                {
                                  "icon": "x",
                                  "action": "HIDE",
                                  "label": "Dismiss",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ],
                              "gap": "md",
                              "align": "center",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "message": "@entity.message",
                              "type": "alert",
                              "variant": "@entity.notificationType"
                            },
                            {
                              "type": "toast-slot"
                            },
                            {
                              "variant": "warning",
                              "message": "@entity.message",
                              "type": "alert"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "visible",
                "to": "hidden",
                "event": "HIDE",
                "effects": [
                  [
                    "set",
                    "@entity.message",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ReviewCompletionAgent",
          "category": "interaction",
          "linkedEntity": "ReviewCompletion",
          "emits": [
            {
              "event": "SHOW",
              "scope": "internal",
              "payload": [
                {
                  "name": "response",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewCompletionLoaded",
              "description": "Fired when ReviewCompletion finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ReviewCompletion]"
                }
              ]
            },
            {
              "event": "ReviewCompletionLoadFailed",
              "description": "Fired when ReviewCompletion fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "GENERATED",
              "triggers": "GENERATED",
              "source": {
                "kind": "trait",
                "trait": "ReviewCompletionFlow"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_GENERATE",
                "name": "Do Generate",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GENERATED",
                "name": "Generated"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "ReviewCompletionLoaded",
                "name": "ReviewCompletion loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ReviewCompletion]"
                  }
                ]
              },
              {
                "key": "ReviewCompletionLoadFailed",
                "name": "ReviewCompletion load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewCompletion",
                    {
                      "emit": {
                        "failure": "ReviewCompletionLoadFailed",
                        "success": "ReviewCompletionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Code Reviewer",
                      "children": [
                        {
                          "description": "Completion is ready",
                          "type": "empty-state",
                          "icon": "sparkles",
                          "title": "Completion"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "href": "/review",
                          "label": "Review"
                        },
                        {
                          "icon": "tag",
                          "label": "Analysis",
                          "href": "/analysis"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "DO_GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "completed",
                "event": "DO_GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.response",
                    "@payload.data.prompt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "error",
                "event": "RESET",
                "guard": [
                  "=",
                  "@entity.status",
                  "generating"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Generation was cancelled"
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.response",
                    ""
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ]
                ]
              },
              {
                "from": "error",
                "to": "generating",
                "event": "RETRY",
                "guard": [
                  "=",
                  "@entity.status",
                  "error"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "agent/generate",
                    "@entity.prompt"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Completion",
          "path": "/completion",
          "traits": [
            {
              "ref": "ReviewCompletionFlow"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewNavOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "ReviewNav",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "target",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "issues",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "suggestions",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reviewStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Tabs.traits.TabContentTabs",
          "name": "ReviewerTabs",
          "linkedEntity": "Review"
        }
      ],
      "pages": [
        {
          "name": "ReviewerNav",
          "path": "/reviewer/nav",
          "traits": [
            {
              "ref": "ReviewerTabs"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewIssueOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "ReviewIssue",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "severity",
            "type": "string"
          },
          {
            "name": "line",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "IssuesBrowse",
          "linkedEntity": "ReviewIssue"
        }
      ],
      "pages": [
        {
          "name": "Issues",
          "path": "/issues",
          "traits": [
            {
              "ref": "IssuesBrowse"
            }
          ]
        }
      ]
    }
  ]
}