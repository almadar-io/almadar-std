          "scope": "collection"
        },
        {
          "name": "RagTabs",
          "category": "interaction",
          "linkedEntity": "ReviewRag",
          "emits": [
            {
              "event": "ReviewRagLoaded",
              "description": "Fired when ReviewRag finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ReviewRag]"
                }
              ]
            },
            {
              "event": "ReviewRagLoadFailed",
              "description": "Fired when ReviewRag fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReviewRagLoaded",
                "name": "ReviewRag loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ReviewRag]"
                  }
                ]
              },
              {
                "key": "ReviewRagLoadFailed",
                "name": "ReviewRag load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAB",
                "name": "Select Tab",
                "payload": [
                  {
                    "name": "tab",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewRag",
                    {
                      "emit": {
                        "failure": "ReviewRagLoadFailed",
                        "success": "ReviewRagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading RAG pipeline…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReviewRagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "href": "/review",
                          "icon": "file-search",
                          "label": "Review"
                        },
                        {
                          "href": "/analysis",
                          "icon": "tag",
                          "label": "Analysis"
                        },
                        {
                          "icon": "alert-triangle",
                          "label": "Issues",
                          "href": "/issues"
                        }
                      ],
                      "children": [
                        {
                          "gap": "lg",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "brain",
                                  "type": "icon"
                                },
                                {
                                  "content": "RAG Pipeline",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "defaultActiveTab": "query",
                              "onTabChange": "SELECT_TAB",
                              "type": "tabs",
                              "tabs": [
                                {
                                  "value": "query",
                                  "label": "Query"
                                },
                                {
                                  "value": "sources",
                                  "label": "Sources"
                                },
                                {
                                  "value": "response",
                                  "label": "Response"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "@payload.data",
                              "type": "data-grid",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "@item.query",
                                      "variant": "h4"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted",
                                      "content": "@item.query"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "vertical"
                                }
                              ],
                              "className": "transition-shadow hover:shadow-md cursor-pointer",
                              "fields": []
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ReviewRagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "Failed to load RAG pipeline",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "body"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_TAB",
                "effects": [
                  [
                    "fetch",
                    "ReviewRag",
                    {
                      "emit": {
                        "failure": "ReviewRagLoadFailed",
                        "success": "ReviewRagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
