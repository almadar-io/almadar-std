{
  "name": "std-agent-reviewer",
  "version": "1.0.0",
  "description": "std-agent-reviewer as a Function",
  "orbitals": [
    {
      "name": "ReviewOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "Review",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "target",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "issues",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "suggestions",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reviewStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewGenerator",
          "category": "interaction",
          "linkedEntity": "Review",
          "emits": [
            {
              "event": "ReviewLoaded",
              "description": "Fired when Review finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Review]"
                }
              ]
            },
            {
              "event": "ReviewLoadFailed",
              "description": "Fired when Review fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewRagSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewRagSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AnalysisSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AnalysisSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewCompletionSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewCompletionSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CLASSIFIED",
              "triggers": "SUBMIT_REVIEW",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "analyzing"
              },
              {
                "name": "reviewing"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT_REVIEW",
                "name": "Submit Review",
                "payload": [
                  {
                    "name": "target",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PATTERNS_FOUND",
                "name": "Patterns Found"
              },
              {
                "key": "REVIEW_GENERATED",
                "name": "Review Generated"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ReviewLoaded",
                "name": "Review loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Review]"
                  }
                ]
              },
              {
                "key": "ReviewLoadFailed",
                "name": "Review load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewRagSaved",
                "name": "Review rag saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewRagSaveFailed",
                "name": "Review rag save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AnalysisSaved",
                "name": "Analysis saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AnalysisSaveFailed",
                "name": "Analysis save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewCompletionSaved",
                "name": "Review completion saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewCompletionSaveFailed",
                "name": "Review completion save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Review",
                    {
                      "emit": {
                        "failure": "ReviewLoadFailed",
                        "success": "ReviewLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "file-search",
                                  "type": "icon"
                                },
                                {
                                  "content": "Code Review",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm",
                              "align": "center",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "gap": "md",
                                  "children": [
                                    {
                                      "content": "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review.",
                                      "type": "typography",
                                      "variant": "body"
                                    },
                                    {
                                      "submitEvent": "SUBMIT_REVIEW",
                                      "fields": [
                                        "target"
                                      ],
                                      "type": "form-section",
                                      "entity": "Review",
                                      "mode": "edit"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "appName": "Code Reviewer",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "label": "Review",
                          "href": "/review"
                        },
                        {
                          "label": "Analysis",
                          "href": "/analysis",
                          "icon": "tag"
                        },
                        {
                          "icon": "alert-triangle",
                          "label": "Issues",
                          "href": "/issues"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "analyzing",
                "event": "SUBMIT_REVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.target",
                    "@payload.target"
                  ],
                  [
                    "set",
                    "@entity.reviewStatus",
                    "analyzing"
                  ],
                  [
                    "agent/recall",
                    "@payload.target"
                  ],
                  [
                    "agent/search-code",
                    "@payload.target"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Code Reviewer",
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Analyzing input...",
                              "variant": "h3"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Classifying and searching for patterns"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "align": "center"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Review",
                          "href": "/review",
                          "icon": "file-search"
                        },
                        {
                          "href": "/analysis",
                          "icon": "tag",
                          "label": "Analysis"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "analyzing",
                "to": "reviewing",
                "event": "PATTERNS_FOUND",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "reviewing"
                  ],
                  [
                    "agent/generate",
                    "@entity.target"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Code Reviewer",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "label": "Review",
                          "href": "/review"
                        },
                        {
                          "label": "Analysis",
                          "href": "/analysis",
                          "icon": "tag"
                        },
                        {
                          "href": "/issues",
                          "icon": "alert-triangle",
                          "label": "Issues"
                        }
                      ],
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "cpu"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Generating review..."
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "content": "Category: @entity.category",
                              "type": "typography",
                              "variant": "caption"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "completed",
                "event": "REVIEW_GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "completed"
                  ],
                  [
                    "agent/memorize",
                    "@entity.target",
                    "review-pattern"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/review",
                          "icon": "file-search",
                          "label": "Review"
                        },
                        {
                          "href": "/analysis",
                          "label": "Analysis",
                          "icon": "tag"
                        },
                        {
                          "icon": "alert-triangle",
                          "href": "/issues",
                          "label": "Issues"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "justify": "between",
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-circle"
                                    },
                                    {
                                      "content": "Review Complete",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "type": "stack"
                                },
                                {
                                  "type": "badge",
                                  "label": "@entity.score"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "label": "@entity.category",
                                          "type": "badge"
                                        },
                                        {
                                          "type": "badge",
                                          "label": "@entity.reviewStatus"
                                        }
                                      ],
                                      "type": "stack",
                                      "gap": "sm"
                                    },
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "Issues"
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@entity.issues",
                                      "type": "typography"
                                    },
                                    {
                                      "type": "divider"
                                    },
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "Suggestions"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "@entity.suggestions",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "md",
                                  "type": "stack"
                                }
                              ]
                            },
                            {
                              "label": "New Review",
                              "icon": "rotate-ccw",
                              "type": "button",
                              "variant": "ghost",
                              "action": "RESET"
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Code Reviewer"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.reviewStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.target",
                    ""
                  ],
                  [
                    "set",
                    "@entity.issues",
                    "[]"
                  ],
                  [
                    "set",
                    "@entity.suggestions",
                    "[]"
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-search"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Code Review"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "direction": "vertical",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "variant": "body",
                                      "content": "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review.",
                                      "type": "typography"
                                    },
                                    {
                                      "submitEvent": "SUBMIT_REVIEW",
                                      "fields": [
                                        "target"
                                      ],
                                      "entity": "Review",
                                      "type": "form-section",
                                      "mode": "edit"
                                    }
                                  ],
                                  "type": "stack"
                                }
                              ],
                              "type": "card"
                            }
                          ],
                          "type": "stack",
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "href": "/review",
                          "label": "Review"
                        },
                        {
                          "icon": "tag",
                          "href": "/analysis",
                          "label": "Analysis"
                        },
                        {
                          "label": "Issues",
                          "href": "/issues",
                          "icon": "alert-triangle"
                        }
                      ],
                      "appName": "Code Reviewer"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReviewPage",
          "path": "/review",
          "traits": [
            {
              "ref": "ReviewGenerator"
            }
          ]
        }
      ]
    },
    {
      "name": "ReviewRagOrbital",
      "entity": {
        "name": "ReviewRag",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "query",
            "type": "string"
          },
          {
            "name": "context",
            "type": "string"
          },
          {
            "name": "response",
            "type": "string"
          },
          {
            "name": "memoryHits",
            "type": "number"
          },
          {
            "name": "searchHits",
            "type": "number"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "scope",
            "type": "string"
          },
          {
            "name": "strength",
            "type": "number"
          },
          {
            "name": "pinned",
            "type": "boolean"
          },
          {
            "name": "language",
            "type": "string"
          },
          {
            "name": "resultCount",
            "type": "number"
          },
          {
            "name": "results",
            "type": "string"
          },
          {
            "name": "prompt",
            "type": "string"
          },
          {
            "name": "provider",
            "type": "string"
          },
          {
            "name": "model",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewRagRag",
          "category": "interaction",
          "linkedEntity": "ReviewRag",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "retrieving"
              },
              {
                "name": "generating"
              },
              {
                "name": "completed"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "RETRIEVAL_DONE",
                "name": "Retrieval Done",
                "payload": [
                  {
                    "name": "context",
                    "type": "string"
                  },
                  {
                    "name": "memoryHits",
                    "type": "string"
                  },
                  {
                    "name": "searchHits",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GENERATION_DONE",
                "name": "Generation Done",
                "payload": [
                  {
                    "name": "response",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "file-search",
                          "label": "Review",
                          "href": "/review"
                        },
                        {
                          "icon": "tag",
                          "label": "Analysis",
                          "href": "/analysis"
                        },
                        {
                          "icon": "alert-triangle",
                          "label": "Issues",
                          "href": "/issues"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "brain",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "RAG Pipeline"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": "Enter a query to retrieve context and generate a response"
                                    },
                                    {
                                      "type": "form-section",
                                      "submitEvent": "GENERATE",
                                      "entity": "ReviewRag",
                                      "fields": [
                                        "query"
                                      ],
                                      "mode": "edit"
                                    }
                                  ],
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "appName": "Code Reviewer"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "retrieving",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "retrieving"
                  ],
                  [
                    "agent/recall",
                    "@entity.query",
                    5.0
                  ],
                  [
                    "agent/search-code",
                    "@entity.query"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "type": "typography",
                              "content": "Retrieving context...",
                              "variant": "h3"
                            },
                            {
                              "type": "spinner"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "label": "Recalling memories",
                                  "type": "badge"
                                },
                                {
                                  "type": "badge",
                                  "label": "Searching code"
                                }
                              ],
                              "direction": "horizontal",
