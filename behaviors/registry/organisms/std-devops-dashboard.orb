                    "persist",
                    "delete",
                    "LogEntry",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "LogEntry"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY_DELETED"
                  ]
                ]
              },
