{
  "name": "std-devops-dashboard",
  "version": "1.0.0",
  "description": "std-devops-dashboard as a Function",
  "orbitals": [
    {
      "name": "ServiceNodeOrbital",
      "entity": {
        "name": "ServiceNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "values": [
              "healthy",
              "degraded",
              "down"
            ]
          },
          {
            "name": "url",
            "type": "string"
          },
          {
            "name": "lastChecked",
            "type": "datetime"
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 5.0
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceNodeCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "ServiceNodeLoaded",
              "description": "Fired when ServiceNode finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "url",
                  "type": "string"
                },
                {
                  "name": "lastChecked",
                  "type": "datetime"
                },
                {
                  "name": "failureCount",
                  "type": "number"
                },
                {
                  "name": "successCount",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ServiceNodeLoadFailed",
              "description": "Fired when ServiceNode fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceNodeLoaded",
                "name": "ServiceNode loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "url",
                    "type": "string"
                  },
                  {
                    "name": "lastChecked",
                    "type": "datetime"
                  },
                  {
                    "name": "failureCount",
                    "type": "number"
                  },
                  {
                    "name": "successCount",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ServiceNodeLoadFailed",
                "name": "ServiceNode load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceNode",
                    {
                      "emit": {
                        "success": "ServiceNodeLoaded",
                        "failure": "ServiceNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "DevOps Dashboard",
                      "navItems": [
                        {
                          "label": "Services",
                          "href": "/services",
                          "icon": "server"
                        },
                        {
                          "href": "/alerts",
                          "label": "Alerts",
                          "icon": "bell"
                        },
                        {
                          "icon": "terminal",
                          "href": "/logs",
                          "label": "Logs"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Metrics",
                          "href": "/metrics"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between",
                              "type": "stack",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "server",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "ServiceNode",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "md"
                                },
                                {
                                  "pulse": false,
                                  "label": "Circuit Closed",
                                  "status": "online",
                                  "type": "status-dot"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "alert",
                              "variant": "success",
                              "message": "Service is healthy. All requests are being processed."
                            },
                            {
                              "type": "simple-grid",
                              "cols": 2.0,
                              "children": [
                                {
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ],
                                  "type": "stat-display",
                                  "label": "Failures"
                                },
                                {
                                  "label": "Successes",
                                  "type": "stat-display",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "meter",
                              "min": 0.0,
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ],
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Services",
                          "href": "/services",
                          "icon": "server"
                        },
                        {
                          "href": "/alerts",
                          "label": "Alerts",
                          "icon": "bell"
                        },
                        {
                          "label": "Logs",
                          "href": "/logs",
                          "icon": "terminal"
                        },
                        {
                          "label": "Metrics",
                          "href": "/metrics",
                          "icon": "layout-list"
                        }
                      ],
                      "appName": "DevOps Dashboard",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "align": "center",
                                  "gap": "md",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "name": "alert-triangle",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h2",
                                      "content": "ServiceNode"
                                    }
                                  ]
                                },
                                {
                                  "status": "critical",
                                  "pulse": true,
                                  "type": "status-dot",
                                  "label": "Circuit Open"
                                }
                              ],
                              "align": "center",
                              "gap": "md",
                              "justify": "between",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                              "variant": "error",
                              "type": "alert"
                            },
                            {
                              "cols": 2.0,
                              "type": "simple-grid",
                              "children": [
                                {
                                  "label": "Failures",
                                  "type": "stat-display",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ]
                                },
                                {
                                  "label": "Successes",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ],
                                  "type": "stat-display"
                                }
                              ]
                            },
                            {
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ],
                              "min": 0.0,
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ],
                              "type": "meter"
                            },
                            {
                              "variant": "ghost",
                              "action": "RESET",
                              "label": "Reset",
                              "icon": "rotate-ccw",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/services",
                          "icon": "server",
                          "label": "Services"
                        },
                        {
                          "href": "/alerts",
                          "icon": "bell",
                          "label": "Alerts"
                        },
                        {
                          "href": "/logs",
                          "label": "Logs",
                          "icon": "terminal"
                        },
                        {
                          "label": "Metrics",
                          "href": "/metrics",
                          "icon": "layout-list"
                        }
                      ],
                      "appName": "DevOps Dashboard",
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "server"
                                    },
                                    {
                                      "content": "ServiceNode",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "align": "center"
                                },
                                {
                                  "status": "online",
                                  "pulse": false,
                                  "label": "Circuit Closed",
                                  "type": "status-dot"
                                }
                              ],
                              "gap": "md",
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "variant": "success",
                              "type": "alert",
                              "message": "Service is healthy. All requests are being processed."
                            },
                            {
                              "type": "simple-grid",
                              "children": [
                                {
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ],
                                  "label": "Failures",
                                  "type": "stat-display"
                                },
                                {
                                  "label": "Successes",
                                  "type": "stat-display",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ]
                                }
                              ],
                              "cols": 2.0
                            },
                            {
                              "min": 0.0,
                              "type": "meter",
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ],
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "icon": "server",
                          "href": "/services",
                          "label": "Services"
                        },
                        {
                          "label": "Alerts",
                          "href": "/alerts",
                          "icon": "bell"
                        },
                        {
                          "label": "Logs",
                          "href": "/logs",
                          "icon": "terminal"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Metrics",
                          "href": "/metrics"
                        }
                      ],
                      "appName": "DevOps Dashboard",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "justify": "between",
                              "align": "center",
                              "gap": "md",
                              "children": [
                                {
                                  "gap": "md",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "name": "activity",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "ServiceNode",
                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "type": "status-dot",
                                  "status": "warning",
                                  "label": "Circuit Half-Open",
                                  "pulse": true
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "alert",
                              "message": "Testing recovery. Limited requests are being allowed through.",
                              "variant": "warning"
                            },
                            {
                              "type": "simple-grid",
                              "cols": 2.0,
                              "children": [
                                {
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ],
                                  "type": "stat-display",
                                  "label": "Failures"
                                },
                                {
                                  "type": "stat-display",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ],
                                  "label": "Successes"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "justify": "between",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "name": "server",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "ServiceNode",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "align": "center"
                                },
                                {
                                  "label": "Circuit Closed",
                                  "status": "online",
                                  "type": "status-dot",
                                  "pulse": false
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "message": "Service is healthy. All requests are being processed.",
                              "type": "alert",
                              "variant": "success"
                            },
                            {
                              "children": [
                                {
                                  "type": "stat-display",
                                  "label": "Failures",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ]
                                },
                                {
                                  "type": "stat-display",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ],
                                  "label": "Successes"
                                }
                              ],
                              "type": "simple-grid",
                              "cols": 2.0
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ],
                              "min": 0.0,
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ],
                              "type": "meter"
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/services",
                          "label": "Services",
                          "icon": "server"
                        },
                        {
                          "label": "Alerts",
                          "icon": "bell",
                          "href": "/alerts"
                        },
                        {
                          "label": "Logs",
                          "icon": "terminal",
                          "href": "/logs"
                        },
                        {
                          "icon": "layout-list",
                          "href": "/metrics",
                          "label": "Metrics"
                        }
                      ],
                      "appName": "DevOps Dashboard"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "DevOps Dashboard",
                      "navItems": [
                        {
                          "label": "Services",
                          "href": "/services",
                          "icon": "server"
                        },
                        {
                          "icon": "bell",
                          "label": "Alerts",
                          "href": "/alerts"
                        },
                        {
                          "icon": "terminal",
                          "label": "Logs",
                          "href": "/logs"
                        },
                        {
                          "href": "/metrics",
                          "icon": "layout-list",
                          "label": "Metrics"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "server"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "ServiceNode",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "md"
                                },
                                {
                                  "pulse": false,
                                  "label": "Circuit Closed",
                                  "type": "status-dot",
                                  "status": "online"
                                }
                              ],
                              "gap": "md",
                              "justify": "between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "alert",
                              "variant": "success",
                              "message": "Service is healthy. All requests are being processed."
                            },
                            {
                              "cols": 2.0,
                              "type": "simple-grid",
                              "children": [
                                {
                                  "type": "stat-display",
                                  "label": "Failures",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ]
                                },
                                {
                                  "type": "stat-display",
                                  "label": "Successes",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ]
                                }
                              ]
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ],
                              "min": 0.0,
                              "type": "meter",
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ]
                            }
                          ],
                          "gap": "lg"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "DevOps Dashboard",
                      "navItems": [
                        {
                          "label": "Services",
                          "href": "/services",
                          "icon": "server"
                        },
                        {
                          "icon": "bell",
                          "label": "Alerts",
                          "href": "/alerts"
                        },
                        {
                          "icon": "terminal",
                          "label": "Logs",
                          "href": "/logs"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Metrics",
                          "href": "/metrics"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between",
                              "type": "stack",
                              "children": [
                                {
                                  "align": "center",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "name": "alert-triangle",
                                      "type": "icon"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "ServiceNode"
                                    }
                                  ]
                                },
                                {
                                  "pulse": true,
                                  "label": "Circuit Open",
                                  "type": "status-dot",
                                  "status": "critical"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                              "type": "alert",
                              "variant": "error"
                            },
                            {
                              "type": "simple-grid",
                              "cols": 2.0,
                              "children": [
                                {
                                  "type": "stat-display",
                                  "label": "Failures",
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "failureCount"
                                  ]
                                },
                                {
                                  "value": [
                                    "object/get",
                                    [
                                      "array/first",
                                      "@entity"
                                    ],
                                    "successCount"
                                  ],
                                  "type": "stat-display",
                                  "label": "Successes"
                                }
                              ]
                            },
                            {
                              "type": "meter",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "failureCount"
                              ],
                              "min": 0.0,
                              "max": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "threshold"
                              ]
                            },
                            {
                              "icon": "rotate-ccw",
                              "action": "RESET",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Reset"
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
