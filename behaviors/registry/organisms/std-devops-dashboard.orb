                                                    [
                                                      "array/first",
                                                      "@entity"
                                                    ],
                                                    "unit"
                                                  ]
                                                }
                                              ]
                                            }
                                          ]
                                        },
                                        {
                                          "type": "card",
                                          "children": [
                                            {
                                              "type": "stack",
                                              "direction": "vertical",
                                              "gap": "sm",
                                              "children": [
