                              "name": "alert-triangle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Delete LogEntry",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "danger",
                          "message": "This action cannot be undone."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
