              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "LOG_ENTRY_DELETED",
                "name": "Log Entry Deleted"
              },
              {
                "key": "LogEntryLoaded",
                "name": "LogEntry loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "level",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "timestamp",
                    "type": "datetime"
                  },
                  {
                    "name": "service",
                    "type": "string"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LogEntryLoadFailed",
                "name": "LogEntry load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "LogEntry"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LogEntry",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "LogEntryLoadFailed",
                        "success": "LogEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "Delete LogEntry",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "message": "This action cannot be undone.",
                          "type": "alert"
                        },
                        {
                          "justify": "end",
                          "children": [
                            {
                              "label": "Cancel",
                              "type": "button",
                              "variant": "ghost",
                              "action": "CANCEL"
                            },
                            {
                              "action": "CONFIRM_DELETE",
                              "label": "Delete",
                              "icon": "check",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "LogEntry",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "LogEntry"
                  ],
                  [
                    "emit",
                    "LOG_ENTRY_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "LogEntry"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "LogEntry"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
