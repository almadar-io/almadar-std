                            },
                            {
                              "variant": "body",
                              "content": "@entity.dateOfBirth",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "content": "Phone",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.phone",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "children": [
                            {
                              "content": "Insurance ID",
