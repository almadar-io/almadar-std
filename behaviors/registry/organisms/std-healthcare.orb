                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Prescription",
                    {
                      "emit": {
                        "failure": "PrescriptionLoadFailed",
                        "success": "PrescriptionLoaded"
                      }
                    }
