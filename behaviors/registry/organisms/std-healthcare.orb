{
  "name": "std-healthcare",
  "version": "1.0.0",
  "description": "std-healthcare as a Function",
  "orbitals": [
    {
      "name": "PatientOrbital",
      "entity": {
        "name": "Patient",
        "collection": "patients",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "firstName",
            "type": "string",
            "required": true
          },
          {
            "name": "lastName",
            "type": "string",
            "required": true
          },
          {
            "name": "dateOfBirth",
            "type": "datetime",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "insuranceId",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "discharged"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PatientBrowse",
          "category": "interaction",
          "linkedEntity": "Patient",
          "emits": [
            {
              "event": "PatientLoaded",
              "description": "Fired when Patient finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "firstName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "lastName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "dateOfBirth",
                  "type": "datetime",
                  "required": true
                },
                {
                  "name": "phone",
                  "type": "string"
                },
                {
                  "name": "insuranceId",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientLoadFailed",
              "description": "Fired when Patient fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.PATIENT_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "*.PATIENT_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "*.PATIENT_DELETED",
              "triggers": "INIT"
            },
            {
              "event": "*.INTAKE_COMPLETE",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PatientLoaded",
                "name": "Patient loaded"
              },
              {
                "key": "PatientLoadFailed",
                "name": "Patient load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Patient"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "users",
                                      "size": "lg"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Patients",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal"
                                },
                                {
                                  "children": [
                                    {
                                      "event": "CREATE",
                                      "type": "button",
                                      "variant": "primary",
                                      "label": "Create Patient",
                                      "icon": "plus"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack"
                                }
                              ],
                              "justify": "space-between",
                              "align": "center",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "type": "stat-display",
                                  "label": "Total Patients",
                                  "icon": "users",
                                  "value": [
                                    "array/len",
                                    "@entity"
                                  ]
                                }
                              ],
                              "type": "simple-grid",
                              "columns": 1.0
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "data-list",
                              "emptyTitle": "No patients registered",
                              "variant": "card",
                              "emptyDescription": "Register a patient to get started.",
                              "entity": "Patient",
                              "emptyIcon": "inbox",
                              "gap": "sm",
                              "columns": [
                                {
                                  "name": "firstName",
                                  "variant": "h3",
                                  "icon": "user"
                                },
                                {
                                  "variant": "h3",
                                  "name": "lastName"
                                },
                                {
                                  "variant": "badge",
                                  "name": "status"
                                },
                                {
                                  "format": "date",
                                  "name": "dateOfBirth",
                                  "label": "Date of Birth",
                                  "variant": "body"
                                },
                                {
                                  "name": "phone",
                                  "variant": "caption"
                                },
                                {
                                  "label": "Insurance ID",
                                  "name": "insuranceId",
                                  "variant": "caption"
                                }
                              ],
                              "itemActions": [
                                {
                                  "label": "View",
                                  "size": "sm",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                },
                                {
                                  "event": "EDIT",
                                  "label": "Edit",
                                  "size": "sm",
                                  "variant": "ghost"
                                },
                                {
                                  "variant": "danger",
                                  "label": "Delete",
                                  "event": "DELETE",
                                  "size": "sm"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "navItems": [
                        {
                          "href": "/patients",
                          "icon": "heart",
                          "label": "Patients"
                        },
                        {
                          "icon": "calendar",
                          "label": "Appointments",
                          "href": "/appointments"
                        },
                        {
                          "label": "Intake",
                          "href": "/intake",
                          "icon": "layout-list"
                        },
                        {
                          "label": "Prescriptions",
                          "href": "/prescriptions",
                          "icon": "pill"
                        },
                        {
                          "label": "Dashboard",
                          "href": "/dashboard",
                          "icon": "layout-dashboard"
                        }
                      ],
                      "appName": "HealthcareApp",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PatientCreate",
          "category": "interaction",
          "linkedEntity": "Patient",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PATIENT_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientLoaded",
              "description": "Fired when Patient finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "firstName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "lastName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "dateOfBirth",
                  "type": "datetime",
                  "required": true
                },
                {
                  "name": "phone",
                  "type": "string"
                },
                {
                  "name": "insuranceId",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientLoadFailed",
              "description": "Fired when Patient fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PATIENT_CREATED",
                "name": "Patient Created"
              },
              {
                "key": "PatientLoaded",
                "name": "Patient loaded"
              },
              {
                "key": "PatientLoadFailed",
                "name": "Patient load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Patient"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "failure": "PatientLoadFailed",
                        "success": "PatientLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "plus-circle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Create Patient"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Patient",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "firstName",
                            "lastName",
                            "dateOfBirth",
                            "phone",
                            "insuranceId",
                            "status"
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Patient",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "PATIENT_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PatientEdit",
          "category": "interaction",
          "linkedEntity": "Patient",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PATIENT_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientLoaded",
              "description": "Fired when Patient finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "firstName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "lastName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "dateOfBirth",
                  "type": "datetime",
                  "required": true
                },
                {
                  "name": "phone",
                  "type": "string"
                },
                {
                  "name": "insuranceId",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientLoadFailed",
              "description": "Fired when Patient fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PATIENT_UPDATED",
                "name": "Patient Updated"
              },
              {
                "key": "PatientLoaded",
                "name": "Patient loaded"
              },
              {
                "key": "PatientLoadFailed",
                "name": "Patient load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Patient"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "failure": "PatientLoadFailed",
                        "success": "PatientLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Edit Patient",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "mode": "edit",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "firstName",
                            "lastName",
                            "dateOfBirth",
                            "phone",
                            "insuranceId",
                            "status"
                          ],
                          "entityId": "@entity.id",
                          "entity": "Patient"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Patient",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "PATIENT_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PatientView",
