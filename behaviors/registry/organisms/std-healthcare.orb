              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PrescriptionLoaded",
                "name": "Prescription loaded"
              },
              {
                "key": "PrescriptionLoadFailed",
                "name": "Prescription load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
