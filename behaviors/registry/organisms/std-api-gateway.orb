                              "gap": "lg",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "items": [
                                    {
                                      "label": "Home",
                                      "href": "/"
                                    },
                                    {
                                      "label": "Analytics"
                                    }
                                  ],
                                  "type": "breadcrumb"
                                },
                                {
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "bar-chart-2"
                                        },
                                        {
                                          "variant": "h2",
                                          "content": "Analytics",
                                          "type": "typography"
                                        }
                                      ],
                                      "gap": "md",
                                      "direction": "horizontal",
                                      "type": "stack"
                                    },
                                    {
                                      "type": "button",
                                      "action": "REFRESH",
                                      "label": "Refresh",
                                      "icon": "refresh-cw",
                                      "variant": "secondary"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "md",
                                  "justify": "between",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "stat-display",
                                          "value": "@entity.totalRequests",
                                          "label": "TotalRequests"
                                        },
                                        {
                                          "label": "ErrorRate",
                                          "value": "@entity.errorRate",
                                          "type": "stat-display"
                                        },
                                        {
                                          "value": "@entity.avgLatency",
                                          "type": "stat-display",
                                          "label": "AvgLatency"
                                        },
                                        {
                                          "children": [
                                            {
                                              "children": [
                                                {
                                                  "content": "Uptime",
                                                  "variant": "caption",
                                                  "type": "typography"
                                                },
                                                {
                                                  "type": "typography",
                                                  "content": "@entity.uptime",
                                                  "variant": "h3"
                                                }
                                              ],
                                              "direction": "vertical",
                                              "type": "stack",
                                              "gap": "sm"
                                            }
