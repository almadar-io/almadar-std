    {
      "name": "AnalyticsOrbital",
      "entity": {
        "name": "Analytics",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "totalRequests",
            "type": "number",
            "required": true
          },
          {
            "name": "errorRate",
            "type": "number",
            "required": true
          },
          {
            "name": "avgLatency",
            "type": "number"
          },
          {
            "name": "uptime",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AnalyticsDisplay",
          "category": "interaction",
          "linkedEntity": "Analytics",
          "emits": [
            {
              "event": "AnalyticsLoaded",
              "description": "Fired when Analytics finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Analytics]"
                }
              ]
            },
            {
              "event": "AnalyticsLoadFailed",
              "description": "Fired when Analytics fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "AnalyticsLoaded",
                "name": "Analytics loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Analytics]"
                  }
                ]
              },
              {
                "key": "AnalyticsLoadFailed",
                "name": "Analytics load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Analytics",
                    {
                      "emit": {
                        "success": "AnalyticsLoaded",
                        "failure": "AnalyticsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "scaled-diagram",
                          "children": [
