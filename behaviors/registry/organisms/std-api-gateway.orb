{
  "name": "std-api-gateway",
  "version": "1.0.0",
  "description": "std-api-gateway as a Function",
  "orbitals": [
    {
      "name": "RouteOrbital",
      "entity": {
        "name": "Route",
        "collection": "routes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string",
            "required": true
          },
          {
            "name": "method",
            "type": "string",
            "values": [
              "GET",
              "POST",
              "PUT",
              "DELETE",
              "PATCH"
            ]
          },
          {
            "name": "backend",
            "type": "string",
            "required": true
          },
          {
            "name": "rateLimit",
            "type": "number"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RouteBrowse",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "RouteLoaded",
              "description": "Fired when Route finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "description": "Fired when Route fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ROUTE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "RouteCreate"
              }
            },
            {
              "event": "ROUTE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "RouteEdit"
              }
            },
            {
              "event": "ROUTE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "RouteDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteSaved",
                "name": "Route saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteSaveFailed",
                "name": "Route save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteUpdated",
                "name": "Route updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteUpdateFailed",
                "name": "Route update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteDeleted",
                "name": "Route deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteDeleteFailed",
                "name": "Route delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading routes…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RouteLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/routes",
                          "label": "Routes",
                          "icon": "git-branch"
                        },
                        {
                          "icon": "server",
                          "href": "/backends",
                          "label": "Backends"
                        },
                        {
                          "href": "/analytics",
                          "label": "Analytics",
                          "icon": "bar-chart-2"
                        }
                      ],
                      "children": [
                        {
                          "gap": "lg",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "direction": "horizontal",
                              "justify": "between",
                              "align": "center",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "git-branch"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Routes",
                                      "variant": "h2"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "children": [
                                    {
                                      "variant": "primary",
                                      "label": "Create Route",
                                      "type": "button",
                                      "action": "CREATE",
                                      "icon": "plus"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "columns": [
                                {
                                  "variant": "badge",
                                  "name": "method"
                                },
                                {
                                  "variant": "h3",
                                  "icon": "git-branch",
                                  "name": "path"
                                },
                                {
                                  "name": "backend",
                                  "variant": "body"
                                },
                                {
                                  "format": "number",
                                  "label": "Rate Limit",
                                  "name": "rateLimit",
                                  "variant": "caption"
                                }
                              ],
                              "entity": "@payload.data",
                              "itemActions": [
                                {
                                  "label": "View",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                },
                                {
                                  "event": "EDIT",
                                  "variant": "ghost",
                                  "label": "Edit"
                                },
                                {
                                  "event": "DELETE",
                                  "variant": "danger",
                                  "label": "Delete"
                                }
                              ],
                              "type": "data-list",
                              "fields": [],
                              "variant": "card",
                              "gap": "sm"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "appName": "API Gateway",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RouteLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load routes"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "label": "Retry"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "RouteCreate",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "ROUTE_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "description": "Fired when Route fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "description": "Fired when Route finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ROUTE_CREATED",
                "name": "Route Created"
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteSaveFailed",
                "name": "Route save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteSaved",
                "name": "Route saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Route"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Create Route",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "path",
                            "method",
                            "backend",
                            "rateLimit"
                          ],
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Route",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "RouteSaveFailed",
                        "success": "RouteSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ROUTE_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "RouteEdit",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "ROUTE_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "description": "Fired when Route fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "description": "Fired when Route finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ROUTE_UPDATED",
                "name": "Route Updated"
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteUpdateFailed",
                "name": "Route update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteUpdated",
                "name": "Route updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Route"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "type": "typography",
                              "content": "Edit Route",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Route",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "mode": "edit",
                          "fields": [
                            "path",
                            "method",
                            "backend",
                            "rateLimit"
                          ],
                          "entityId": "@entity.id"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Route",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "RouteUpdated",
                        "failure": "RouteUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ROUTE_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "RouteView",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "RouteLoaded",
              "description": "Fired when Route finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "description": "Fired when Route fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Route"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.path"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Path",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.path",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Method"
                            },
                            {
                              "content": "@entity.method",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "content": "Backend",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.backend"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Rate Limit",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.rateLimit"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "EDIT",
                              "variant": "primary",
                              "icon": "edit",
                              "label": "Edit",
                              "type": "button"
                            },
                            {
                              "label": "Close",
                              "type": "button",
                              "action": "CLOSE",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "RouteDelete",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "ROUTE_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "description": "Fired when Route fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "description": "Fired when Route finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ROUTE_DELETED",
                "name": "Route Deleted"
              },
              {
                "key": "RouteDeleteFailed",
                "name": "Route delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteDeleted",
                "name": "Route deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Route"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Delete Route"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "action": "CONFIRM_DELETE",
                              "type": "button",
                              "label": "Delete",
                              "icon": "check",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Route",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "RouteDeleted",
                        "failure": "RouteDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Route"
                  ],
                  [
                    "emit",
                    "ROUTE_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Route"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Route"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RoutesPage",
          "path": "/routes",
          "traits": [
            {
              "ref": "RouteBrowse"
            },
            {
              "ref": "RouteCreate"
            },
            {
              "ref": "RouteEdit"
            },
            {
              "ref": "RouteView"
            },
            {
              "ref": "RouteDelete"
            }
          ]
        }
      ]
    },
