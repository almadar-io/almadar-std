{
  "name": "std-trading-dashboard",
  "version": "1.0.0",
  "description": "std-trading-dashboard as a Function",
  "orbitals": [
    {
      "name": "PortfolioOrbital",
      "entity": {
        "name": "Portfolio",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "totalValue",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "dailyChange",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "positions",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "cashBalance",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "PortfolioDisplay",
          "category": "interaction",
          "linkedEntity": "Portfolio",
          "emits": [
            {
              "event": "PortfolioLoaded",
              "description": "Fired when Portfolio finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "totalValue",
                  "type": "number"
                },
                {
                  "name": "dailyChange",
                  "type": "number"
                },
                {
                  "name": "positions",
                  "type": "number"
                },
                {
                  "name": "cashBalance",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PortfolioLoadFailed",
              "description": "Fired when Portfolio fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TradeOrderDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MarketFeedSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MarketFeedSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "PortfolioLoaded",
                "name": "Portfolio loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "totalValue",
                    "type": "number"
                  },
                  {
                    "name": "dailyChange",
                    "type": "number"
                  },
                  {
                    "name": "positions",
                    "type": "number"
                  },
                  {
                    "name": "cashBalance",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "PortfolioLoadFailed",
                "name": "Portfolio load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderSaved",
                "name": "Trade order saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderSaveFailed",
                "name": "Trade order save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderUpdated",
                "name": "Trade order updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderUpdateFailed",
                "name": "Trade order update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderDeleted",
                "name": "Trade order deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TradeOrderDeleteFailed",
                "name": "Trade order delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MarketFeedSaved",
                "name": "Market feed saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MarketFeedSaveFailed",
                "name": "Market feed save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "failure": "PortfolioLoadFailed",
                        "success": "PortfolioLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Trading Dashboard",
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "scaled-diagram",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "lg",
                              "children": [
                                {
                                  "type": "breadcrumb",
                                  "items": [
                                    {
                                      "href": "/",
                                      "label": "Home"
                                    },
                                    {
                                      "label": "Portfolio"
                                    }
                                  ]
                                },
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "md",
                                  "justify": "between",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "gap": "md",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "name": "trending-up",
                                          "type": "icon"
                                        },
                                        {
                                          "variant": "h2",
                                          "content": "Portfolio",
                                          "type": "typography"
                                        }
                                      ]
                                    },
                                    {
                                      "label": "Refresh",
                                      "type": "button",
                                      "action": "REFRESH",
                                      "icon": "refresh-cw",
                                      "variant": "secondary"
                                    }
                                  ]
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "box",
                                  "padding": "md",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "stat-display",
                                          "label": "TotalValue",
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "totalValue"
                                          ]
                                        },
                                        {
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "dailyChange"
                                          ],
                                          "type": "stat-display",
                                          "label": "DailyChange"
                                        },
                                        {
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "positions"
                                          ],
                                          "label": "Positions",
                                          "type": "stat-display"
                                        },
                                        {
                                          "type": "stat-display",
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "cashBalance"
                                          ],
                                          "label": "CashBalance"
                                        }
                                      ],
                                      "cols": 3.0,
                                      "type": "simple-grid"
                                    }
                                  ]
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "gap": "md",
                                  "cols": 2.0,
                                  "type": "grid",
                                  "children": [
                                    {
                                      "type": "card",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "content": "Chart View"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "card",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "content": "Graph View",
                                          "variant": "caption"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "line-chart",
                                  "data": [
                                    {
                                      "value": 12.0,
                                      "date": "Jan"
                                    },
                                    {
                                      "date": "Feb",
                                      "value": 19.0
                                    },
                                    {
                                      "value": 15.0,
                                      "date": "Mar"
                                    },
                                    {
                                      "value": 25.0,
                                      "date": "Apr"
                                    },
                                    {
                                      "date": "May",
                                      "value": 22.0
                                    },
                                    {
                                      "value": 30.0,
                                      "date": "Jun"
                                    }
                                  ]
                                },
                                {
                                  "items": [
                                    {
                                      "label": "Current",
                                      "color": "primary"
                                    },
                                    {
                                      "label": "Previous",
                                      "color": "muted"
                                    }
                                  ],
                                  "type": "chart-legend"
                                },
                                {
                                  "type": "graph-view",
                                  "edges": [
                                    {
                                      "from": "a",
                                      "to": "b"
                                    },
                                    {
                                      "from": "b",
                                      "to": "c"
                                    }
                                  ],
                                  "height": 200.0,
                                  "nodes": [
                                    {
                                      "id": "a",
                                      "x": 50.0,
                                      "y": 100.0,
                                      "label": "Start"
                                    },
                                    {
                                      "x": 200.0,
                                      "y": 50.0,
                                      "id": "b",
                                      "label": "Process"
                                    },
                                    {
                                      "label": "End",
                                      "y": 100.0,
                                      "id": "c",
                                      "x": 350.0
                                    }
                                  ],
                                  "width": 400.0
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "navItems": [
                        {
                          "icon": "layout-list",
                          "label": "Portfolio",
                          "href": "/portfolio"
                        },
                        {
                          "href": "/orders",
                          "icon": "clipboard-list",
                          "label": "Orders"
                        },
                        {
                          "href": "/market",
                          "icon": "layout-list",
                          "label": "Market"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "displaying",
                "event": "LOADED",
                "effects": [
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
