                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "TRADE_ORDER_DELETED",
                "name": "Trade Order Deleted"
              },
              {
                "key": "TradeOrderLoaded",
                "name": "TradeOrder loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "symbol",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "side",
                    "type": "string",
                    "required": true
                  },
