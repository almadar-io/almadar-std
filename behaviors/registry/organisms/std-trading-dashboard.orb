                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "TradeOrder"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TradeOrder",
                    {
                      "emit": {
                        "success": "TradeOrderLoaded",
                        "failure": "TradeOrderLoadFailed"
                      },
                      "id": "@payload.id"
