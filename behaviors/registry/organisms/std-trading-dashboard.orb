                              "variant": "ghost",
                              "action": "CANCEL",
                              "type": "button",
                              "label": "Cancel"
                            },
                            {
                              "type": "button",
                              "action": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check",
                              "label": "Delete"
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "TradeOrder",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "TradeOrderDeleteFailed",
                        "success": "TradeOrderDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "TradeOrder"
                  ],
                  [
                    "emit",
                    "TRADE_ORDER_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
