                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantLoadFailed",
              "description": "Fired when Assistant fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "paused"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "TOKEN_UPDATE",
                "name": "Token Update"
              },
              {
                "key": "AssistantLoaded",
                "name": "Assistant loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "messages",
                    "type": "string"
                  },
                  {
                    "name": "currentMessage",
                    "type": "string"
                  },
                  {
                    "name": "response",
                    "type": "string"
                  },
                  {
                    "name": "memoryCount",
                    "type": "number"
                  },
                  {
                    "name": "contextUsage",
                    "type": "number"
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "sessionId",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "turnCount",
                    "type": "number"
                  },
                  {
                    "name": "lastMessage",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "role",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "timestamp",
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantLoadFailed",
                "name": "Assistant load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "icon": "message-circle",
                          "type": "empty-state",
                          "title": "Conversation",
                          "description": "Conversation is ready"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Chat",
                          "icon": "message-circle",
                          "href": "/chat"
                        },
                        {
                          "label": "Memory",
                          "href": "/memory",
                          "icon": "brain"
                        },
                        {
                          "icon": "settings",
                          "label": "Settings",
                          "href": "/settings"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SEND_MESSAGE",
                "effects": [
                  [
                    "set",
                    "@entity.lastMessage",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    [
                      "+",
                      "@entity.turnCount",
                      1.0
                    ]
                  ],
                  [
                    "agent/generate",
                    "@payload.content"
                  ],
                  [
                    "emit",
                    "TOKEN_UPDATE"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "paused",
                "event": "PAUSE"
              },
              {
                "from": "active",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "active",
                "event": "RESUME"
              },
              {
                "from": "paused",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.messages",
                    []
                  ],
                  [
                    "set",
                    "@entity.turnCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastMessage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.tokenCount",
                    0.0
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
