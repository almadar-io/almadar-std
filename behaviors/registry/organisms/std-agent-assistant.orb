          "name": "MemoryAgent",
          "category": "interaction",
          "linkedEntity": "Memory",
          "emits": [
            {
              "event": "FORGOT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REINFORCED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DECAYED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PINNED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MemoryLoaded",
              "description": "Fired when Memory finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "strength",
                  "type": "number"
                },
                {
                  "name": "pinned",
                  "type": "boolean"
                },
                {
                  "name": "scope",
                  "type": "string"
                },
                {
                  "name": "lastAccessedAt",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MemoryLoadFailed",
              "description": "Fired when Memory fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "MEMORIZE_RESPONSE",
              "triggers": "MEMORIZE",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_MEMORIZE",
                "name": "Do Memorize",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DECAY",
                "name": "Decay"
              },
              {
                "key": "MEMORIZED",
                "name": "Memorized"
              },
              {
                "key": "RECALL",
                "name": "Recall",
                "payload": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FORGOT",
                "name": "Forgot"
              },
              {
                "key": "REINFORCED",
                "name": "Reinforced"
              },
              {
                "key": "DECAYED",
                "name": "Decayed"
              },
              {
                "key": "PINNED",
                "name": "Pinned"
              },
              {
                "key": "MemoryLoaded",
                "name": "Memory loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "strength",
                    "type": "number"
                  },
                  {
                    "name": "pinned",
                    "type": "boolean"
                  },
                  {
                    "name": "scope",
                    "type": "string"
                  },
                  {
                    "name": "lastAccessedAt",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MemoryLoadFailed",
                "name": "Memory load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Memory",
                    {
                      "emit": {
                        "success": "MemoryLoaded",
                        "failure": "MemoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "empty-state",
                          "icon": "brain",
                          "title": "Memory",
                          "description": "Memory is ready"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Agent Assistant",
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "label": "Memory",
                          "icon": "brain",
                          "href": "/memory"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "DO_MEMORIZE",
                "effects": [
                  [
                    "agent/memorize",
                    "@payload.data.content",
                    "@payload.data.category"
                  ],
                  [
                    "persist",
                    "create",
                    "Memory",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "MemorySaved",
                        "failure": "MemorySaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "MEMORIZED",
                "effects": [
                  [
                    "fetch",
                    "Memory",
                    {
                      "emit": {
                        "success": "MemoryLoaded",
                        "failure": "MemoryLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "RECALL",
                "effects": [
                  [
                    "agent/recall",
                    "@payload.query"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "PIN",
                "guard": [
                  "not",
                  [
                    "agent/is-pinned",
                    "@payload.id"
                  ]
                ],
                "effects": [
                  [
                    "agent/pin",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.pinned",
                    true
                  ],
                  [
                    "emit",
                    "PINNED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "idle",
                "event": "FORGET",
                "effects": [
                  [
                    "agent/forget",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "FORGOT"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "REINFORCE",
                "effects": [
                  [
                    "agent/reinforce",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "REINFORCED"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Memory",
          "path": "/memory",
          "traits": [
            {
              "ref": "MemoryBrowse"
            },
            {
              "ref": "MemoryCreate"
            },
            {
              "ref": "MemoryAgent"
            }
          ]
        }
      ]
    },
