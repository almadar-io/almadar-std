{
  "name": "std-agent-assistant",
  "version": "1.0.0",
  "description": "std-agent-assistant as a Function",
  "orbitals": [
    {
      "name": "AssistantOrbital",
      "entity": {
        "name": "Assistant",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "messages",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "currentMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "memoryCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "contextUsage",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "provider",
            "type": "string",
            "default": "default"
          },
          {
            "name": "sessionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "turnCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "tokenCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "role",
            "type": "string",
            "default": "user"
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AssistantConversation",
          "category": "interaction",
          "linkedEntity": "Assistant",
          "emits": [
            {
              "event": "SEND_MESSAGE",
              "scope": "internal",
              "payload": [
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MEMORIZE_RESPONSE",
              "scope": "internal",
              "payload": [
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MEMORIZE_RESPONSE",
              "scope": "external",
              "payload": [
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantLoaded",
              "description": "Fired when Assistant finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "messages",
                  "type": "string"
                },
                {
                  "name": "currentMessage",
                  "type": "string"
                },
                {
                  "name": "response",
                  "type": "string"
                },
                {
                  "name": "memoryCount",
                  "type": "number"
                },
                {
                  "name": "contextUsage",
                  "type": "number"
                },
                {
                  "name": "provider",
                  "type": "string"
                },
                {
                  "name": "sessionId",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "turnCount",
                  "type": "number"
                },
                {
                  "name": "lastMessage",
                  "type": "string"
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "role",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                },
                {
                  "name": "toolName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantLoadFailed",
              "description": "Fired when Assistant fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MemorySaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MemorySaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProviderConfigUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProviderConfigUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PROVIDER_CHANGED",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "composing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SEND_MESSAGE",
                "name": "Send Message"
              },
              {
                "key": "MEMORIZE_RESPONSE",
                "name": "Memorize Response"
              },
              {
                "key": "AssistantLoaded",
                "name": "Assistant loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "messages",
                    "type": "string"
                  },
                  {
                    "name": "currentMessage",
                    "type": "string"
                  },
                  {
                    "name": "response",
                    "type": "string"
                  },
                  {
                    "name": "memoryCount",
                    "type": "number"
                  },
                  {
                    "name": "contextUsage",
                    "type": "number"
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "sessionId",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "turnCount",
                    "type": "number"
                  },
                  {
                    "name": "lastMessage",
                    "type": "string"
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "role",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "timestamp",
                    "type": "string"
                  },
                  {
                    "name": "toolName",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantLoadFailed",
                "name": "Assistant load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantDeleted",
                "name": "Assistant deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantDeleteFailed",
                "name": "Assistant delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MemorySaved",
                "name": "Memory saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MemorySaveFailed",
                "name": "Memory save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProviderConfigUpdated",
                "name": "Provider config updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProviderConfigUpdateFailed",
                "name": "Provider config update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Chat",
                          "href": "/chat",
                          "icon": "message-circle"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
                          "label": "Memory"
                        },
                        {
                          "icon": "settings",
                          "label": "Settings",
                          "href": "/settings"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "message-circle",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Assistant Thread",
                                      "variant": "h2"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "label": "New Message",
                                  "action": "COMPOSE",
                                  "type": "button",
                                  "icon": "plus",
                                  "variant": "primary"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "direction": "horizontal",
                                      "align": "center",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "type": "badge",
                                          "label": "@item.role"
                                        },
                                        {
                                          "variant": "outline",
                                          "type": "badge",
                                          "label": "@item.status"
                                        },
                                        {
                                          "content": "@item.timestamp",
                                          "variant": "caption",
                                          "color": "muted",
                                          "type": "typography"
                                        }
                                      ]
                                    },
                                    {
                                      "content": "@item.content",
                                      "type": "typography",
                                      "variant": "body"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "gap": "xs"
                                }
                              ],
                              "entity": "Assistant",
                              "fields": [],
                              "type": "data-list"
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "appName": "Agent Assistant"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Chat",
                          "href": "/chat",
                          "icon": "message-circle"
                        },
                        {
                          "icon": "brain",
                          "label": "Memory",
                          "href": "/memory"
                        },
                        {
                          "label": "Settings",
                          "icon": "settings",
                          "href": "/settings"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "message-circle",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Assistant Thread",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "label": "New Message",
                                  "action": "COMPOSE",
                                  "type": "button",
                                  "variant": "primary",
                                  "icon": "plus"
                                }
                              ],
                              "direction": "horizontal",
                              "justify": "between",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "fields": [],
                              "type": "data-list",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "gap": "xs",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "align": "center",
                                      "type": "stack",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "type": "badge",
                                          "label": "@item.role"
                                        },
                                        {
                                          "type": "badge",
                                          "label": "@item.status",
                                          "variant": "outline"
                                        },
                                        {
                                          "variant": "caption",
                                          "content": "@item.timestamp",
                                          "type": "typography",
                                          "color": "muted"
                                        }
                                      ]
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@item.content",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "vertical"
                                }
                              ],
                              "entity": "Assistant"
                            },
                            {
                              "children": [
                                {
                                  "placeholder": "Type your message...",
                                  "type": "textarea"
                                },
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "label": "Send",
                                      "variant": "primary",
                                      "action": "SEND",
                                      "type": "button",
                                      "icon": "send"
                                    }
                                  ]
                                }
                              ],
                              "title": "Compose Message",
                              "fields": [],
                              "type": "form-section"
                            }
                          ]
                        }
                      ],
                      "appName": "Agent Assistant"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Assistant",
                    {
                      "emit": {
                        "success": "AssistantDeleted",
                        "failure": "AssistantDeleteFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "success": "AssistantLoaded",
                        "failure": "AssistantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Agent Assistant",
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "label": "Memory",
                          "href": "/memory",
                          "icon": "brain"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "message-circle",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Assistant Thread",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack"
                                },
                                {
                                  "variant": "primary",
                                  "action": "COMPOSE",
                                  "icon": "plus",
                                  "type": "button",
                                  "label": "New Message"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "Assistant",
                              "type": "data-list",
                              "fields": [],
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "gap": "xs",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "type": "badge",
                                          "label": "@item.role"
                                        },
                                        {
                                          "label": "@item.status",
                                          "type": "badge",
                                          "variant": "outline"
                                        },
                                        {
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "@item.timestamp",
                                          "variant": "caption"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "gap": "sm",
                                      "align": "center"
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@item.content",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "vertical"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.role",
                    "user"
                  ],
                  [
                    "set",
                    "@entity.timestamp",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "persist",
                    "create",
                    "Assistant",
                    {
                      "status": "sent",
                      "timestamp": "@now",
                      "role": "user",
                      "content": "@payload.content"
                    }
                  ],
                  [
                    "emit",
                    "SEND_MESSAGE"
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Chat",
                          "href": "/chat",
                          "icon": "message-circle"
                        },
                        {
                          "label": "Memory",
                          "href": "/memory",
                          "icon": "brain"
                        },
                        {
                          "icon": "settings",
                          "label": "Settings",
                          "href": "/settings"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "Agent Assistant",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "message-circle"
                                    },
                                    {
                                      "content": "Assistant Thread",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "button",
                                  "action": "COMPOSE",
                                  "label": "New Message",
                                  "variant": "primary",
                                  "icon": "plus"
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "justify": "between",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "Assistant",
                              "fields": [],
                              "type": "data-list",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "gap": "xs",
                                  "direction": "vertical",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "type": "badge",
                                          "label": "@item.role"
                                        },
                                        {
                                          "variant": "outline",
                                          "type": "badge",
                                          "label": "@item.status"
                                        },
                                        {
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "@item.timestamp",
                                          "variant": "caption"
                                        }
                                      ],
                                      "align": "center",
                                      "type": "stack",
                                      "gap": "sm"
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@item.content",
                                      "type": "typography"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "lg"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Assistant",
                    {
                      "emit": {
                        "success": "AssistantDeleted",
                        "failure": "AssistantDeleteFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Assistant",
                    {
                      "emit": {
                        "failure": "AssistantLoadFailed",
                        "success": "AssistantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Chat",
                          "href": "/chat",
                          "icon": "message-circle"
                        },
                        {
                          "href": "/memory",
                          "icon": "brain",
