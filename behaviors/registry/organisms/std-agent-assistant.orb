              ]
            },
            {
              "event": "ProviderConfigLoadFailed",
              "description": "Fired when ProviderConfig fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SWITCHED",
              "triggers": "SWITCHED",
              "source": {
                "kind": "trait",
                "trait": "ProviderManager"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "switching"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_SWITCH",
                "name": "Do Switch",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SWITCHED",
                "name": "Switched"
              },
              {
                "key": "SWITCH_AUTO",
                "name": "Switch Auto"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "ProviderConfigLoaded",
                "name": "ProviderConfig loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "currentProvider",
                    "type": "string"
                  },
                  {
                    "name": "currentModel",
                    "type": "string"
                  },
                  {
                    "name": "fallbackProvider",
                    "type": "string"
                  },
                  {
                    "name": "requestCount",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProviderConfigLoadFailed",
                "name": "ProviderConfig load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ProviderConfig",
                    {
                      "emit": {
                        "failure": "ProviderConfigLoadFailed",
                        "success": "ProviderConfigLoaded"
                      }
                    }
                  ],
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "type": "empty-state",
                          "title": "Provider",
                          "icon": "repeat",
                          "description": "Provider is ready"
                        }
                      ],
                      "appName": "Agent Assistant",
                      "navItems": [
                        {
                          "href": "/chat",
                          "icon": "message-circle",
                          "label": "Chat"
                        },
                        {
                          "href": "/memory",
                          "label": "Memory",
                          "icon": "brain"
                        },
                        {
                          "icon": "settings",
                          "href": "/settings",
                          "label": "Settings"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "switching",
                "event": "DO_SWITCH",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "DO_SWITCH",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "SWITCHED",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.currentProvider",
                    "@entity.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "SWITCH_AUTO",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.fallbackProvider"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@entity.fallbackProvider"
                  ]
                ]
              },
              {
                "from": "switching",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "set",
                    "@entity.requestCount",
                    [
                      "+",
                      "@entity.requestCount",
                      1.0
                    ]
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Settings",
          "path": "/settings",
          "traits": [
            {
              "ref": "ProviderManager"
            }
          ]
        }
      ]
    },
