        {
          "name": "AssistantContextAgent",
          "category": "interaction",
          "linkedEntity": "AssistantContext",
          "emits": [
            {
              "event": "SHOW",
              "scope": "internal",
              "payload": [
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                }
              ]
            },
            {
              "event": "UPDATE",
              "scope": "internal",
              "payload": [
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AssistantContextLoaded",
              "description": "Fired when AssistantContext finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "tokenCount",
                  "type": "number"
                },
                {
                  "name": "maxTokens",
                  "type": "number"
                },
                {
                  "name": "usage",
                  "type": "number"
                },
                {
                  "name": "lastCompactedAt",
                  "type": "string"
                },
                {
                  "name": "current",
                  "type": "number"
                },
                {
                  "name": "max",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssistantContextLoadFailed",
              "description": "Fired when AssistantContext fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "normal",
                "isInitial": true
              },
              {
                "name": "approaching_limit"
              },
              {
                "name": "at_limit"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPDATE_TOKENS",
                "name": "Update Tokens"
              },
              {
                "key": "COMPACT",
                "name": "Compact"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "UPDATE",
                "name": "Update"
              },
              {
                "key": "AssistantContextLoaded",
                "name": "AssistantContext loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "tokenCount",
                    "type": "number"
                  },
                  {
                    "name": "maxTokens",
                    "type": "number"
                  },
                  {
                    "name": "usage",
                    "type": "number"
                  },
                  {
                    "name": "lastCompactedAt",
                    "type": "string"
                  },
                  {
                    "name": "current",
                    "type": "number"
                  },
                  {
                    "name": "max",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssistantContextLoadFailed",
                "name": "AssistantContext load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "normal",
                "to": "normal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AssistantContext",
                    {
                      "emit": {
                        "success": "AssistantContextLoaded",
                        "failure": "AssistantContextLoadFailed"
                      }
                    }
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/chat",
                          "label": "Chat",
                          "icon": "message-circle"
                        },
                        {
                          "href": "/memory",
                          "label": "Memory",
                          "icon": "brain"
                        },
                        {
                          "href": "/settings",
                          "icon": "settings",
                          "label": "Settings"
                        }
                      ],
                      "children": [
                        {
                          "title": "Context Window",
                          "description": "Context Window is ready",
                          "icon": "layers",
                          "type": "empty-state"
                        }
                      ],
                      "appName": "Agent Assistant"
                    }
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "normal",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "<",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  0.85
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "normal",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "at_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  ">=",
                  [
                    "/",
                    "@entity.tokenCount",
                    "@entity.maxTokens"
                  ],
                  1.0
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    100.0
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ],
                  [
                    "emit",
                    "SHOW"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "approaching_limit",
                "to": "approaching_limit",
                "event": "UPDATE_TOKENS",
                "guard": [
                  "and",
                  [
                    ">=",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    0.85
                  ],
                  [
                    "<",
                    [
                      "/",
                      "@entity.tokenCount",
                      "@entity.maxTokens"
                    ],
                    1.0
                  ]
                ],
                "effects": [
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              },
              {
                "from": "at_limit",
                "to": "normal",
                "event": "COMPACT",
                "effects": [
                  [
                    "agent/compact"
                  ],
                  [
                    "agent/token-count"
                  ],
                  [
                    "agent/context-usage"
                  ],
                  [
                    "set",
                    "@entity.lastCompactedAt",
                    "@now"
                  ],
                  [
                    "set",
                    "@entity.usage",
                    [
                      "*",
                      [
                        "/",
                        "@entity.tokenCount",
                        "@entity.maxTokens"
                      ],
                      100.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.current",
                    "@entity.tokenCount"
                  ],
                  [
                    "emit",
                    "UPDATE"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Context",
          "path": "/context",
          "traits": [
            {
              "ref": "AssistantContextMonitor"
            }
          ]
        }
      ]
