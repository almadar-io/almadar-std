                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "space-between",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "sparkles",
                                      "size": "lg"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "BuildLoop",
                                      "variant": "h2"
                                    }
                                  ]
                                },
                                {
                                  "type": "button",
                                  "label": "Open",
                                  "event": "GENERATE",
                                  "variant": "primary",
                                  "icon": "sparkles"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "empty-state",
                              "icon": "sparkles",
                              "title": "Nothing open",
                              "description": "Click Open to view details in a modal overlay."
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
