            {
              "event": "FIX_FAILED",
              "triggers": "INIT",
              "scope": "external"
            },
            {
              "event": "TOOL_LOOP_DONE",
              "triggers": "FIX",
              "scope": "external"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
