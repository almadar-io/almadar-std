            "required": true
          },
          {
            "name": "target",
            "type": "string",
            "default": ""
          },
          {
            "name": "validationErrors",
            "type": "string",
            "default": ""
          },
          {
            "name": "fixAttempts",
            "type": "number",
            "default": 0
          },
          {
            "name": "maxAttempts",
            "type": "number",
            "default": 5
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "currentFix",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStep",
            "type": "number",
            "default": 0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 4
          },
          {
            "name": "steps",
            "type": "string",
            "default": "Validate,Analyze,Fix,Re-validate"
