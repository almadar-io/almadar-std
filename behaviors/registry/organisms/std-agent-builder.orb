        {
          "name": "ToolLoopCompletionFlow",
          "linkedEntity": "BuildLoop",
          "category": "interaction",
          "emits": [
            {
              "event": "GENERATED",
              "scope": "internal"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Open"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "BuildLoop"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "Schema Builder",
