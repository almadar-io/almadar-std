{
  "name": "std-iot-dashboard",
  "version": "1.0.0",
  "description": "std-iot-dashboard as a Function",
  "orbitals": [
    {
      "name": "SensorReadingOrbital",
      "entity": {
        "name": "SensorReading",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sensorId",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "number",
            "required": true
          },
          {
            "name": "unit",
            "type": "string"
          },
          {
            "name": "timestamp",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SensorReadingDisplay",
          "category": "interaction",
          "linkedEntity": "SensorReading",
          "emits": [
            {
              "event": "SensorReadingLoaded",
              "description": "Fired when SensorReading finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "sensorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "value",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "unit",
                  "type": "string"
                },
                {
                  "name": "timestamp",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SensorReadingLoadFailed",
              "description": "Fired when SensorReading fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "SensorReadingLoaded",
                "name": "SensorReading loaded"
              },
              {
                "key": "SensorReadingLoadFailed",
                "name": "SensorReading load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SensorReading",
                    {
                      "emit": {
                        "success": "SensorReadingLoaded",
                        "failure": "SensorReadingLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "IoT Dashboard",
                      "children": [
                        {
                          "type": "scaled-diagram",
                          "children": [
                            {
                              "gap": "lg",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "items": [
                                    {
                                      "label": "Home",
                                      "href": "/"
                                    },
                                    {
                                      "label": "Sensor Readings"
                                    }
                                  ],
                                  "type": "breadcrumb"
                                },
                                {
                                  "children": [
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "name": "thermometer",
                                          "type": "icon",
                                          "size": "lg"
                                        },
                                        {
                                          "content": "Sensor Readings",
                                          "type": "typography",
                                          "variant": "h2"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "gap": "md"
                                    },
                                    {
                                      "type": "button",
                                      "label": "Refresh",
                                      "variant": "secondary",
                                      "icon": "refresh-cw",
                                      "event": "REFRESH"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "md",
                                  "justify": "space-between"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "box",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "card",
                                          "children": [
                                            {
                                              "type": "stack",
                                              "direction": "vertical",
                                              "children": [
                                                {
                                                  "content": "SensorId",
                                                  "variant": "caption",
                                                  "type": "typography"
                                                },
                                                {
                                                  "type": "typography",
                                                  "variant": "h3",
                                                  "content": [
                                                    "object/get",
                                                    [
                                                      "array/first",
                                                      "@entity"
                                                    ],
                                                    "sensorId"
                                                  ]
                                                }
                                              ],
                                              "gap": "sm"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "stat-display",
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "value"
                                          ],
                                          "label": "Value"
                                        },
                                        {
                                          "type": "card",
                                          "children": [
                                            {
                                              "direction": "vertical",
                                              "type": "stack",
                                              "gap": "sm",
                                              "children": [
                                                {
                                                  "variant": "caption",
                                                  "content": "Unit",
                                                  "type": "typography"
                                                },
                                                {
                                                  "type": "typography",
                                                  "variant": "h3",
                                                  "content": [
                                                    "object/get",
                                                    [
                                                      "array/first",
                                                      "@entity"
                                                    ],
                                                    "unit"
                                                  ]
                                                }
                                              ]
                                            }
                                          ]
                                        },
                                        {
                                          "type": "card",
                                          "children": [
                                            {
                                              "children": [
                                                {
                                                  "variant": "caption",
                                                  "content": "Timestamp",
                                                  "type": "typography"
                                                },
                                                {
                                                  "content": [
                                                    "object/get",
                                                    [
                                                      "array/first",
                                                      "@entity"
                                                    ],
                                                    "timestamp"
                                                  ],
                                                  "variant": "h3",
                                                  "type": "typography"
                                                }
                                              ],
                                              "direction": "vertical",
                                              "type": "stack",
                                              "gap": "sm"
                                            }
                                          ]
                                        }
                                      ],
                                      "columns": 3.0,
                                      "type": "simple-grid"
                                    }
                                  ],
                                  "padding": "md"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "grid",
                                  "children": [
                                    {
                                      "type": "card",
                                      "children": [
                                        {
                                          "content": "Chart View",
                                          "type": "typography",
                                          "variant": "caption"
                                        }
                                      ]
                                    },
                                    {
                                      "children": [
                                        {
                                          "variant": "caption",
                                          "type": "typography",
                                          "content": "Graph View"
                                        }
                                      ],
                                      "type": "card"
                                    }
                                  ],
                                  "gap": "md",
                                  "columns": 2.0
                                },
                                {
                                  "type": "line-chart",
                                  "title": "Trend",
                                  "xKey": "date",
                                  "yKey": "value",
                                  "data": [
                                    {
                                      "date": "Jan",
                                      "value": 12.0
                                    },
                                    {
                                      "date": "Feb",
                                      "value": 19.0
                                    },
                                    {
                                      "date": "Mar",
                                      "value": 15.0
                                    },
                                    {
                                      "date": "Apr",
                                      "value": 25.0
                                    },
                                    {
                                      "date": "May",
                                      "value": 22.0
                                    },
                                    {
                                      "value": 30.0,
                                      "date": "Jun"
                                    }
                                  ]
                                },
                                {
                                  "type": "chart-legend",
                                  "items": [
                                    {
                                      "label": "Current",
                                      "color": "primary"
                                    },
                                    {
                                      "label": "Previous",
                                      "color": "muted"
                                    }
                                  ]
                                },
                                {
                                  "height": 200.0,
                                  "edges": [
                                    {
                                      "from": "a",
                                      "to": "b"
                                    },
                                    {
                                      "to": "c",
                                      "from": "b"
                                    }
                                  ],
                                  "type": "graph-view",
                                  "nodes": [
                                    {
                                      "id": "a",
                                      "label": "Start",
                                      "x": 50.0,
                                      "y": 100.0
                                    },
                                    {
                                      "id": "b",
                                      "y": 50.0,
                                      "label": "Process",
                                      "x": 200.0
                                    },
                                    {
                                      "id": "c",
                                      "x": 350.0,
                                      "y": 100.0,
                                      "label": "End"
                                    }
                                  ],
                                  "width": 400.0
                                }
                              ]
                            }
                          ]
