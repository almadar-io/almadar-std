                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Description"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.description",
                              "variant": "body"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Price",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.price"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Category"
                            },
                            {
                              "content": "@entity.category",
                              "variant": "body",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "In Stock"
                            },
                            {
                              "content": "@entity.inStock",
                              "variant": "body",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "event": "EDIT",
                              "variant": "primary",
                              "type": "button",
                              "label": "Edit",
                              "icon": "edit"
                            },
                            {
                              "type": "button",
                              "variant": "ghost",
                              "event": "CLOSE",
                              "label": "Close"
                            }
                          ],
                          "gap": "sm",
                          "justify": "end",
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductDelete",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "CONFIRM_DELETE"
            },
            {
              "event": "PRODUCT_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "inStock",
                  "type": "boolean"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "PRODUCT_DELETED",
                "name": "Product Deleted"
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Product"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Delete Product"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "variant": "danger",
                          "type": "alert"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "type": "button"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "check",
                              "type": "button",
                              "event": "CONFIRM_DELETE"
                            }
                          ],
                          "type": "stack",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Product",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Product"
                  ],
                  [
                    "emit",
                    "PRODUCT_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Product"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Product"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ProductsPage",
          "path": "/products",
          "traits": [
            {
              "ref": "ProductBrowse"
            },
            {
              "ref": "ProductCreate"
            },
            {
              "ref": "ProductEdit"
            },
            {
              "ref": "ProductView"
            },
            {
              "ref": "ProductDelete"
            }
          ]
        }
      ]
    },
    {
      "name": "AuthSessionOrbital",
      "entity": {
        "name": "AuthSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string"
          },
          {
            "name": "authUrl",
            "type": "string"
          },
          {
            "name": "accessToken",
            "type": "string"
          },
          {
            "name": "refreshToken",
            "type": "string"
          },
          {
            "name": "authStatus",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AuthSessionOauth",
          "category": "interaction",
          "linkedEntity": "AuthSession",
          "emits": [
            {
              "event": "AuthSessionLoaded",
              "description": "Fired when AuthSession finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "provider",
                  "type": "string"
                },
                {
                  "name": "authUrl",
                  "type": "string"
                },
                {
                  "name": "accessToken",
                  "type": "string"
                },
                {
                  "name": "refreshToken",
                  "type": "string"
                },
                {
                  "name": "authStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AuthSessionLoadFailed",
              "description": "Fired when AuthSession fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "unauthenticated",
                "isInitial": true
              },
              {
                "name": "authorizing"
              },
              {
                "name": "authenticated"
              },
              {
                "name": "refreshing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              },
              {
                "key": "AUTH_URL_RECEIVED",
                "name": "Auth Url Received",
                "payload": [
                  {
                    "name": "authUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CALLBACK",
                "name": "Callback",
                "payload": [
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TOKEN_RECEIVED",
                "name": "Token Received",
                "payload": [
                  {
                    "name": "accessToken",
                    "type": "string"
                  },
                  {
                    "name": "refreshToken",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "LOGOUT",
                "name": "Logout"
              },
              {
                "key": "TOKEN_REFRESHED",
                "name": "Token Refreshed",
                "payload": [
                  {
                    "name": "accessToken",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "AuthSessionLoaded",
                "name": "AuthSession loaded"
              },
              {
                "key": "AuthSessionLoadFailed",
                "name": "AuthSession load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "unauthenticated",
                "to": "unauthenticated",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AuthSession",
                    {
                      "emit": {
                        "failure": "AuthSessionLoadFailed",
                        "success": "AuthSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "gap": "md",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "lock"
                                },
                                {
                                  "content": "Sign In",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "select",
                              "field": "provider",
                              "label": "Provider",
                              "bind": "@entity.provider",
                              "options": [
                                {
                                  "value": "google",
                                  "label": "Google"
                                },
                                {
                                  "label": "GitHub",
                                  "value": "github"
                                },
                                {
                                  "label": "Microsoft",
                                  "value": "microsoft"
                                }
