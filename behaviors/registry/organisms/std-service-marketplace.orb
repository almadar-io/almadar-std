                              "type": "icon",
                              "size": "lg",
                              "name": "check-circle"
                            },
                            {
                              "type": "alert",
                              "variant": "success",
                              "message": "Authenticated successfully"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "outline",
                                  "icon": "refresh-cw",
                                  "label": "Refresh Token",
                                  "event": "REFRESH",
                                  "type": "button"
                                },
                                {
                                  "icon": "log-out",
                                  "label": "Logout",
                                  "type": "button",
                                  "variant": "ghost",
                                  "event": "LOGOUT"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "justify": "center"
                            }
                          ],
                          "direction": "vertical",
                          "align": "center"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Products",
                          "href": "/products",
                          "icon": "package"
                        },
                        {
                          "label": "Login",
                          "href": "/login",
                          "icon": "layout-list"
                        },
                        {
                          "label": "Checkout",
                          "href": "/checkout",
                          "icon": "credit-card"
                        },
                        {
                          "label": "Orders",
                          "icon": "clipboard-list",
                          "href": "/orders"
                        }
                      ]
                    }
                  ]
                ]
              },
