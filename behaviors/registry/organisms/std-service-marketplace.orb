        {
          "name": "OrderPaymentReceipt",
          "category": "interaction",
          "linkedEntity": "OrderPayment",
          "listens": [
            {
              "event": "*.SEND_RECEIPT",
              "triggers": "SEND_RECEIPT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "waiting",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "receiptError"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_RECEIPT",
                "name": "Send Receipt"
              },
              {
                "key": "SENT",
                "name": "Sent"
              },
              {
                "key": "FAILED",
                "name": "Failed"
              },
              {
                "key": "RETRY_RECEIPT",
                "name": "Retry Receipt"
              }
            ],
            "transitions": [
              {
                "from": "waiting",
                "to": "waiting",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "ServiceMarketplace",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "name": "mail",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Receipt will be sent after payment.",
                              "variant": "body",
                              "color": "muted"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Products",
                          "href": "/products",
                          "icon": "package"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Login",
                          "href": "/login"
                        },
                        {
                          "icon": "credit-card",
                          "label": "Checkout",
                          "href": "/checkout"
                        },
                        {
                          "href": "/orders",
                          "label": "Orders",
                          "icon": "clipboard-list"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "waiting",
                "to": "sending",
                "event": "SEND_RECEIPT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/products",
                          "label": "Products",
                          "icon": "package"
                        },
                        {
                          "href": "/login",
                          "icon": "layout-list",
                          "label": "Login"
                        },
                        {
                          "label": "Checkout",
                          "icon": "credit-card",
                          "href": "/checkout"
                        },
                        {
                          "label": "Orders",
                          "href": "/orders",
                          "icon": "clipboard-list"
                        }
                      ],
                      "children": [
                        {
                          "type": "loading-state",
                          "title": "Sending receipt...",
                          "message": "Delivering your payment receipt."
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "ServiceMarketplace"
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "body": "@entity.body",
                      "to": "@entity.to",
                      "subject": "@entity.subject"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle",
                              "size": "md"
                            },
                            {
                              "message": "Receipt sent successfully",
                              "type": "alert",
                              "variant": "success"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "md",
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "ServiceMarketplace",
                      "navItems": [
                        {
                          "label": "Products",
                          "href": "/products",
                          "icon": "package"
                        },
                        {
                          "href": "/login",
                          "icon": "layout-list",
                          "label": "Login"
                        },
                        {
                          "href": "/checkout",
                          "label": "Checkout",
                          "icon": "credit-card"
                        },
                        {
                          "label": "Orders",
                          "icon": "clipboard-list",
                          "href": "/orders"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "receiptError",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Products",
                          "icon": "package",
                          "href": "/products"
                        },
                        {
                          "label": "Login",
                          "href": "/login",
                          "icon": "layout-list"
                        },
                        {
                          "label": "Checkout",
                          "icon": "credit-card",
                          "href": "/checkout"
                        },
                        {
                          "icon": "clipboard-list",
                          "label": "Orders",
                          "href": "/orders"
                        }
                      ],
                      "appName": "ServiceMarketplace",
                      "children": [
                        {
                          "children": [
                            {
                              "title": "Receipt Failed",
                              "onRetry": "RETRY_RECEIPT",
                              "message": "Could not send receipt email.",
                              "type": "error-state"
                            },
                            {
                              "type": "button",
                              "label": "Retry",
                              "variant": "primary",
                              "icon": "refresh-cw",
                              "event": "RETRY_RECEIPT"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "receiptError",
                "to": "sending",
                "event": "RETRY_RECEIPT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "loading-state",
                          "message": "Delivering your payment receipt.",
                          "title": "Sending receipt..."
                        }
                      ],
                      "appName": "ServiceMarketplace",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "package",
                          "label": "Products",
                          "href": "/products"
                        },
                        {
                          "label": "Login",
                          "href": "/login",
                          "icon": "layout-list"
                        },
                        {
                          "label": "Checkout",
                          "href": "/checkout",
                          "icon": "credit-card"
                        },
                        {
                          "label": "Orders",
                          "icon": "clipboard-list",
                          "href": "/orders"
                        }
                      ]
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "body": "@entity.body",
                      "subject": "@entity.subject",
                      "to": "@entity.to"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Checkout",
          "path": "/checkout",
          "traits": [
            {
              "ref": "OrderPaymentPayment"
            },
            {
              "ref": "OrderPaymentReceipt"
            }
          ]
        }
      ]
    },
    {
      "name": "OrderOrbital",
      "entity": {
