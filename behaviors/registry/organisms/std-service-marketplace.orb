                          "type": "stack"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "refreshing",
                "event": "REFRESH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Products",
