                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Product Name"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.productName"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
