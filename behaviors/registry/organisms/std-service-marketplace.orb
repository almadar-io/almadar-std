                              "size": "lg",
                              "name": "external-link",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Authorization Required"
                            },
                            {
                              "content": "@entity.authUrl",
                              "color": "muted",
                              "variant": "body",
                              "type": "typography"
                            },
                            {
                              "type": "input",
                              "label": "Authorization Code",
                              "field": "code",
                              "placeholder": "Paste authorization code here"
                            },
                            {
                              "label": "Submit",
                              "event": "CALLBACK",
                              "variant": "primary",
                              "type": "button",
                              "icon": "check"
                            }
                          ],
                          "align": "center",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authenticated",
                "event": "CALLBACK",
                "effects": [
                  [
                    "call-service",
                    "oauth",
                    "token",
                    {
                      "code": "@payload.code"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "ServiceMarketplace",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
