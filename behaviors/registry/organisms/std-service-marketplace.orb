                          "href": "/checkout"
                        },
                        {
                          "href": "/orders",
                          "icon": "clipboard-list",
                          "label": "Orders"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "title": "Refreshing token...",
                          "message": "Obtaining a new access token.",
                          "type": "loading-state"
                        }
                      ],
                      "appName": "ServiceMarketplace"
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "refresh",
                    {
                      "refreshToken": "@entity.refreshToken"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "unauthenticated",
                "event": "LOGOUT",
                "effects": [
                  [
                    "set",
                    "@entity.authStatus",
                    "unauthenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "align": "center",
