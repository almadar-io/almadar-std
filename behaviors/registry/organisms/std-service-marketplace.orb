              "event": "*.ORDER_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "*.ORDER_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "*.ORDER_DELETED",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
