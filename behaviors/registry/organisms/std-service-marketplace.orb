{
  "name": "std-service-marketplace",
  "version": "1.0.0",
  "description": "std-service-marketplace as a Function",
  "orbitals": [
    {
      "name": "ProductOrbital",
      "entity": {
        "name": "Product",
        "collection": "products",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "inStock",
            "type": "boolean",
            "default": true
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ProductBrowse",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "CHECKOUT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "inStock",
                  "type": "boolean"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.PRODUCT_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "*.PRODUCT_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "*.PRODUCT_DELETED",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHECKOUT",
                "name": "Checkout"
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Product"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Products",
                          "href": "/products",
                          "icon": "package"
                        },
                        {
                          "href": "/login",
                          "icon": "layout-list",
                          "label": "Login"
                        },
                        {
                          "icon": "credit-card",
                          "label": "Checkout",
                          "href": "/checkout"
                        },
                        {
                          "icon": "clipboard-list",
                          "href": "/orders",
                          "label": "Orders"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "className": "max-w-5xl mx-auto w-full",
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "justify": "space-between",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "name": "shopping-bag",
                                      "size": "lg",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Products",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "icon": "plus",
                                      "variant": "primary",
                                      "type": "button",
                                      "label": "Create Product",
                                      "event": "CREATE"
                                    }
                                  ]
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "columns": [
                                {
                                  "icon": "shopping-bag",
                                  "label": "Name",
                                  "variant": "h4",
                                  "name": "name"
                                },
                                {
                                  "variant": "badge",
                                  "colorMap": {
                                    "failed": "destructive",
                                    "pending": "warning",
                                    "completed": "success",
                                    "scheduled": "warning",
                                    "draft": "warning",
                                    "active": "success",
                                    "done": "success",
                                    "disabled": "neutral",
                                    "error": "destructive",
                                    "cancelled": "destructive",
                                    "archived": "neutral",
                                    "inactive": "neutral"
                                  },
                                  "name": "description",
                                  "label": "Description"
                                },
                                {
                                  "name": "price",
                                  "label": "Price",
                                  "variant": "caption"
                                }
                              ],
                              "emptyIcon": "inbox",
                              "type": "data-grid",
                              "emptyTitle": "No products yet",
                              "emptyDescription": "Add products to build your catalog.",
                              "itemActions": [
                                {
                                  "size": "sm",
                                  "label": "View",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                },
                                {
                                  "variant": "ghost",
                                  "event": "EDIT",
                                  "size": "sm",
                                  "label": "Edit"
                                },
                                {
                                  "label": "Delete",
                                  "event": "DELETE",
                                  "size": "sm",
                                  "variant": "danger"
                                }
                              ],
                              "entity": "Product"
                            }
                          ]
                        }
                      ],
                      "appName": "ServiceMarketplace"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductCreate",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PRODUCT_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "inStock",
                  "type": "boolean"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PRODUCT_CREATED",
                "name": "Product Created"
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Product"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Create Product"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "entity": "Product",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "name",
                            "description",
                            "price",
                            "category",
                            "inStock"
                          ],
                          "mode": "create"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Product",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "PRODUCT_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductEdit",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PRODUCT_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "inStock",
                  "type": "boolean"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PRODUCT_UPDATED",
                "name": "Product Updated"
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Product"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "edit",
                              "type": "icon",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Edit Product"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "fields": [
                            "name",
                            "description",
                            "price",
                            "category",
                            "inStock"
                          ],
                          "entity": "Product",
                          "mode": "edit",
                          "cancelEvent": "CLOSE",
                          "entityId": "@entity.id",
                          "type": "form-section"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Product",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "PRODUCT_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductView",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "inStock",
                  "type": "boolean"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Product"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.name",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Name"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.name"
                            }
                          ]
                        },
                        {
                          "gap": "md",
