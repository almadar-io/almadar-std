                          "icon": "layout-list",
                          "label": "Login",
                          "href": "/login"
                        },
                        {
                          "icon": "credit-card",
                          "href": "/checkout",
                          "label": "Checkout"
                        },
                        {
                          "label": "Orders",
                          "icon": "clipboard-list",
                          "href": "/orders"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack",
                          "children": [
                            {
                              "message": "@entity.error",
                              "title": "Authentication Failed",
                              "type": "error-state",
