                        },
                        {
                          "icon": "layout-list",
                          "label": "Login",
                          "href": "/login"
                        },
                        {
                          "icon": "credit-card",
                          "href": "/checkout",
                          "label": "Checkout"
                        },
                        {
                          "label": "Orders",
                          "href": "/orders",
                          "icon": "clipboard-list"
                        }
                      ]
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "authorize",
                    {
                      "scopes": [
                        "openid",
                        "email"
                      ],
                      "provider": "@entity.provider"
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authorizing",
                "event": "AUTH_URL_RECEIVED",
                "effects": [
