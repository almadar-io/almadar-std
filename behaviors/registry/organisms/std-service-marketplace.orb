        },
        {
          "name": "OrderDelete",
          "category": "interaction",
          "linkedEntity": "Order",
          "emits": [
            {
              "event": "CONFIRM_DELETE"
            },
            {
              "event": "ORDER_DELETED"
            },
            {
              "event": "OrderLoaded",
              "description": "Fired when Order finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "productName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "paymentStatus",
                  "type": "string"
                },
                {
                  "name": "orderDate",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderLoadFailed",
              "description": "Fired when Order fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ORDER_DELETED",
                "name": "Order Deleted"
              },
              {
                "key": "OrderLoaded",
                "name": "Order loaded"
              },
              {
                "key": "OrderLoadFailed",
                "name": "Order load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Order"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Order",
                    {
                      "emit": {
                        "success": "OrderLoaded",
                        "failure": "OrderLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Delete Order"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "danger",
                          "type": "alert",
                          "message": "This action cannot be undone."
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "end",
                          "children": [
                            {
                              "label": "Cancel",
                              "type": "button",
                              "variant": "ghost",
                              "event": "CANCEL"
                            },
                            {
                              "type": "button",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check",
                              "label": "Delete"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Order",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Order"
                  ],
                  [
                    "emit",
                    "ORDER_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Order"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "Order"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Orders",
          "path": "/orders",
          "traits": [
            {
              "ref": "OrderBrowse"
            },
            {
              "ref": "OrderCreate"
            },
            {
              "ref": "OrderEdit"
            },
            {
              "ref": "OrderView"
            },
            {
              "ref": "OrderDelete"
            }
          ]
        }
      ]
    }
  ]
