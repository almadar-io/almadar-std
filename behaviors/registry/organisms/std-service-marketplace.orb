                                  "size": "lg"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Sign In",
                                  "type": "typography"
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "label": "Provider",
                              "type": "select",
                              "bind": "@entity.provider",
                              "field": "provider",
                              "options": [
                                {
                                  "label": "Google",
                                  "value": "google"
                                },
                                {
                                  "value": "github",
                                  "label": "GitHub"
                                },
                                {
                                  "label": "Microsoft",
                                  "value": "microsoft"
                                }
                              ]
                            },
                            {
                              "icon": "log-in",
                              "label": "Login",
                              "event": "LOGIN",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack"
