              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "productName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "paymentStatus",
                  "type": "string"
                },
                {
                  "name": "orderDate",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderLoadFailed",
              "description": "Fired when Order fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
