                            {
                              "type": "button",
                              "icon": "log-in",
                              "label": "Login",
                              "variant": "primary",
                              "event": "LOGIN"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "align": "center",
                          "gap": "lg"
                        }
                      ],
                      "appName": "ServiceMarketplace",
                      "navItems": [
                        {
                          "icon": "package",
                          "label": "Products",
                          "href": "/products"
                        },
                        {
                          "href": "/login",
