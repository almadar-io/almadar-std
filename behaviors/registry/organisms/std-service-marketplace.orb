    {
      "name": "OrderPaymentOrbital",
      "entity": {
        "name": "OrderPayment",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string"
          },
          {
            "name": "paymentIntentId",
            "type": "string"
          },
          {
            "name": "clientSecret",
            "type": "string"
          },
          {
            "name": "paymentStatus",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "OrderPaymentPayment",
          "category": "interaction",
          "linkedEntity": "OrderPayment",
          "emits": [
            {
              "event": "SEND_RECEIPT"
            },
            {
              "event": "OrderPaymentLoaded",
              "description": "Fired when OrderPayment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number"
                },
                {
                  "name": "currency",
                  "type": "string"
                },
                {
                  "name": "paymentIntentId",
                  "type": "string"
                },
                {
                  "name": "clientSecret",
                  "type": "string"
                },
                {
                  "name": "paymentStatus",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "subject",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderPaymentLoadFailed",
              "description": "Fired when OrderPayment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.CHECKOUT",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "confirming"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              },
              {
                "key": "PAYMENT_CREATED",
                "name": "Payment Created",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "clientSecret",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAYMENT_CONFIRMED",
                "name": "Payment Confirmed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "SEND_RECEIPT",
                "name": "Send Receipt"
              },
              {
                "key": "OrderPaymentLoaded",
                "name": "OrderPayment loaded"
              },
              {
                "key": "OrderPaymentLoadFailed",
                "name": "OrderPayment load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OrderPayment",
                    {
                      "emit": {
                        "failure": "OrderPaymentLoadFailed",
                        "success": "OrderPaymentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
