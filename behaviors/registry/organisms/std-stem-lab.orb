                                    },
                                    {
                                      "from": "b",
                                      "to": "c"
                                    }
                                  ],
                                  "height": 200.0
                                }
                              ],
                              "gap": "lg",
                              "direction": "vertical"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "displaying",
                "event": "LOADED",
                "effects": [
                  [
                    "fetch",
                    "LabResult",
                    {
                      "emit": {
                        "failure": "LabResultLoadFailed",
                        "success": "LabResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "scaled-diagram",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "breadcrumb",
                                  "items": [
                                    {
                                      "label": "Home",
                                      "href": "/"
                                    },
                                    {
                                      "label": "Lab Results"
                                    }
                                  ]
                                },
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "gap": "md",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "name": "clipboard",
                                          "type": "icon"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "Lab Results",
                                          "variant": "h2"
                                        }
                                      ]
                                    },
                                    {
                                      "icon": "refresh-cw",
                                      "action": "REFRESH",
                                      "type": "button",
                                      "label": "Refresh",
                                      "variant": "secondary"
                                    }
                                  ],
                                  "justify": "between",
                                  "type": "stack",
                                  "gap": "md"
                                },
                                {
                                  "type": "divider"
