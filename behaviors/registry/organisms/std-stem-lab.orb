          },
          {
            "name": "avgAccuracy",
            "type": "number"
          },
          {
            "name": "totalScore",
            "type": "number"
          },
          {
            "name": "grade",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "LabResultDisplay",
          "category": "interaction",
          "linkedEntity": "LabResult",
          "emits": [
            {
              "event": "LabResultLoaded",
              "description": "Fired when LabResult finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "experimentCount",
                  "type": "number"
                },
                {
                  "name": "avgAccuracy",
                  "type": "number"
                },
                {
                  "name": "totalScore",
                  "type": "number"
                },
                {
                  "name": "grade",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LabResultLoadFailed",
              "description": "Fired when LabResult fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "LabResultLoaded",
                "name": "LabResult loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "experimentCount",
                    "type": "number"
                  },
                  {
                    "name": "avgAccuracy",
                    "type": "number"
                  },
                  {
                    "name": "totalScore",
                    "type": "number"
                  },
                  {
                    "name": "grade",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LabResultLoadFailed",
                "name": "LabResult load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LabResult",
                    {
                      "emit": {
                        "success": "LabResultLoaded",
                        "failure": "LabResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "STEM Lab",
                      "showTopBar": true,
                      "children": [
                        {
                          "type": "scaled-diagram",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "breadcrumb",
                                  "items": [
                                    {
                                      "label": "Home",
                                      "href": "/"
                                    },
                                    {
                                      "label": "Lab Results"
                                    }
                                  ]
                                },
                                {
                                  "justify": "between",
                                  "gap": "md",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "gap": "md",
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "clipboard"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "Lab Results",
                                          "variant": "h2"
                                        }
                                      ]
                                    },
                                    {
                                      "variant": "secondary",
                                      "type": "button",
                                      "icon": "refresh-cw",
                                      "label": "Refresh",
                                      "action": "REFRESH"
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "type": "box",
                                  "padding": "md",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "experimentCount"
                                          ],
                                          "label": "ExperimentCount",
                                          "type": "stat-display"
                                        },
                                        {
                                          "label": "AvgAccuracy",
                                          "type": "stat-display",
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "avgAccuracy"
                                          ]
                                        },
                                        {
                                          "value": [
                                            "object/get",
                                            [
                                              "array/first",
                                              "@entity"
                                            ],
                                            "totalScore"
                                          ],
                                          "type": "stat-display",
                                          "label": "TotalScore"
                                        },
                                        {
                                          "type": "card",
                                          "children": [
                                            {
                                              "children": [
                                                {
                                                  "variant": "caption",
                                                  "type": "typography",
                                                  "content": "Grade"
                                                },
                                                {
                                                  "content": [
                                                    "object/get",
                                                    [
                                                      "array/first",
                                                      "@entity"
                                                    ],
                                                    "grade"
                                                  ],
                                                  "variant": "h3",
                                                  "type": "typography"
                                                }
                                              ],
                                              "type": "stack",
                                              "gap": "sm",
                                              "direction": "vertical"
                                            }
                                          ]
                                        }
                                      ],
                                      "cols": 3.0,
                                      "type": "simple-grid"
                                    }
                                  ]
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "cols": 2.0,
                                  "type": "grid",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "variant": "caption",
                                          "content": "Chart View",
                                          "type": "typography"
                                        }
                                      ],
                                      "type": "card"
                                    },
                                    {
                                      "type": "card",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "content": "Graph View"
                                        }
                                      ]
                                    }
                                  ],
                                  "gap": "md"
                                },
                                {
                                  "data": [
                                    {
                                      "date": "Jan",
                                      "value": 12.0
                                    },
                                    {
                                      "value": 19.0,
                                      "date": "Feb"
                                    },
                                    {
                                      "date": "Mar",
                                      "value": 15.0
                                    },
                                    {
                                      "date": "Apr",
                                      "value": 25.0
                                    },
                                    {
                                      "value": 22.0,
                                      "date": "May"
                                    },
                                    {
                                      "value": 30.0,
                                      "date": "Jun"
                                    }
                                  ],
                                  "type": "line-chart"
                                },
                                {
                                  "items": [
                                    {
                                      "label": "Current",
                                      "color": "primary"
                                    },
                                    {
                                      "label": "Previous",
                                      "color": "muted"
                                    }
                                  ],
                                  "type": "chart-legend"
                                },
                                {
                                  "nodes": [
                                    {
                                      "label": "Start",
                                      "id": "a",
                                      "y": 100.0,
                                      "x": 50.0
                                    },
                                    {
                                      "id": "b",
                                      "y": 50.0,
                                      "x": 200.0,
                                      "label": "Process"
                                    },
                                    {
                                      "label": "End",
                                      "x": 350.0,
                                      "y": 100.0,
                                      "id": "c"
