                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "storyPoints",
                    "type": "number"
                  },
                  {
                    "name": "dueDate",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
