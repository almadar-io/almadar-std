      "traits": [
        {
          "name": "BurndownDisplay",
          "category": "interaction",
          "linkedEntity": "Burndown",
          "emits": [
            {
              "event": "BurndownLoaded",
              "description": "Fired when Burndown finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "totalPoints",
                  "type": "number"
                },
                {
                  "name": "completedPoints",
                  "type": "number"
                },
                {
                  "name": "remainingPoints",
                  "type": "number"
                },
                {
                  "name": "velocity",
                  "type": "number"
                },
                {
                  "name": "daysRemaining",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BurndownLoadFailed",
              "description": "Fired when Burndown fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COMPLETE_SPRINT",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "BurndownLoaded",
                "name": "Burndown loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "totalPoints",
                    "type": "number"
                  },
                  {
                    "name": "completedPoints",
                    "type": "number"
                  },
                  {
                    "name": "remainingPoints",
                    "type": "number"
                  },
                  {
                    "name": "velocity",
                    "type": "number"
                  },
                  {
                    "name": "daysRemaining",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "BurndownLoadFailed",
                "name": "Burndown load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Burndown",
