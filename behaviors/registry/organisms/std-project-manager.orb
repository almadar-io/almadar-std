                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Sprint"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Sprint",
                    {
                      "emit": {
                        "failure": "SprintLoadFailed",
                        "success": "SprintLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "gap": "sm",
