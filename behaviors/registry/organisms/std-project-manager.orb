                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded"
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "eye",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.title"
                            }
                          ],
                          "direction": "horizontal",
