                              "icon": "check",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Sprint",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Sprint"
                  ],
                  [
                    "emit",
                    "SPRINT_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
