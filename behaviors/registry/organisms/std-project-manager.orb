{
  "name": "std-project-manager",
  "version": "1.0.0",
  "description": "std-project-manager as a Function",
  "orbitals": [
    {
      "name": "TaskOrbital",
      "entity": {
        "name": "Task",
        "collection": "tasks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "assignee",
            "type": "string"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "in-progress",
              "review",
              "done"
            ]
          },
          {
            "name": "storyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "dueDate",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TaskBrowse",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TASK_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskCreate"
              }
            },
            {
              "event": "TASK_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskEdit"
              }
            },
            {
              "event": "TASK_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskDelete"
              }
            },
            {
              "event": "ASSIGN_TASK",
              "triggers": "INIT",
              "source": {
                "kind": "any"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "assignee",
                    "type": "string"
                  },
                  {
                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "storyPoints",
                    "type": "number"
                  },
                  {
                    "name": "dueDate",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/tasks",
                          "label": "Tasks",
                          "icon": "check-square"
                        },
                        {
                          "icon": "zap",
                          "href": "/sprints",
                          "label": "Sprints"
                        },
                        {
                          "label": "Burndown",
                          "icon": "layout-list",
                          "href": "/burndown"
                        }
                      ],
                      "appName": "ProjectManagerApp",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-square"
                                    },
                                    {
                                      "content": "Tasks",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "align": "center"
                                },
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "label": "Create Task",
                                      "action": "CREATE",
                                      "icon": "plus",
                                      "type": "button",
                                      "variant": "primary"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal"
                                }
                              ],
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "type": "stat-display",
                                  "icon": "check-square",
                                  "value": [
                                    "array/len",
                                    "@entity"
                                  ],
                                  "label": "Total Tasks"
                                }
                              ],
                              "cols": 1.0,
                              "type": "simple-grid"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "fields": [],
                              "cols": 2.0,
                              "entity": "Task",
                              "itemActions": [
                                {
                                  "variant": "ghost",
                                  "event": "VIEW",
                                  "label": "View"
                                },
                                {
                                  "label": "Edit",
                                  "event": "EDIT",
                                  "variant": "ghost"
                                },
                                {
                                  "variant": "danger",
                                  "event": "DELETE",
                                  "label": "Delete"
                                }
                              ],
                              "type": "data-grid",
                              "gap": "md",
                              "columns": [
                                {
                                  "name": "title",
                                  "icon": "check-square",
                                  "variant": "h3"
                                },
                                {
                                  "variant": "badge",
                                  "name": "priority"
                                },
                                {
                                  "variant": "badge",
                                  "name": "status"
                                },
                                {
                                  "name": "assignee",
                                  "variant": "body"
                                },
                                {
                                  "label": "Points",
                                  "variant": "body",
                                  "format": "number",
                                  "name": "storyPoints"
                                },
                                {
                                  "variant": "caption",
                                  "name": "dueDate",
                                  "label": "Due",
                                  "format": "date"
                                }
                              ]
                            }
                          ],
                          "className": "max-w-5xl mx-auto w-full",
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskCreate",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "TASK_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TASK_CREATED",
                "name": "Task Created"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "assignee",
                    "type": "string"
                  },
                  {
                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "storyPoints",
                    "type": "number"
                  },
                  {
                    "name": "dueDate",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "failure": "TaskLoadFailed",
                        "success": "TaskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Create Task"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "Task",
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "mode": "create",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "title",
                            "description",
                            "assignee",
                            "priority",
                            "status",
                            "storyPoints",
                            "dueDate"
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TASK_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskEdit",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
