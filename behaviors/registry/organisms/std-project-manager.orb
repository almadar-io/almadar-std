{
  "name": "std-project-manager",
  "version": "1.0.0",
  "description": "std-project-manager as a Function",
  "orbitals": [
    {
      "name": "TaskOrbital",
      "entity": {
        "name": "Task",
        "collection": "tasks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "assignee",
            "type": "string"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "in-progress",
              "review",
              "done"
            ]
          },
          {
            "name": "storyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "dueDate",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TaskBrowse",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.TASK_CREATED",
              "triggers": "INIT"
            },
            {
              "event": "*.TASK_UPDATED",
              "triggers": "INIT"
            },
            {
              "event": "*.TASK_DELETED",
              "triggers": "INIT"
            },
            {
              "event": "*.ASSIGN_TASK",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded"
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "label": "Tasks",
                          "href": "/tasks",
                          "icon": "check-square"
                        },
                        {
                          "icon": "zap",
                          "label": "Sprints",
                          "href": "/sprints"
                        },
                        {
                          "href": "/burndown",
                          "icon": "layout-list",
                          "label": "Burndown"
                        }
                      ],
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "className": "max-w-5xl mx-auto w-full",
                          "gap": "lg",
                          "children": [
                            {
                              "direction": "horizontal",
                              "justify": "space-between",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "check-square",
                                      "size": "lg"
                                    },
                                    {
                                      "content": "Tasks",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "align": "center",
                                  "type": "stack"
                                },
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "variant": "primary",
                                      "label": "Create Task",
                                      "type": "button",
                                      "icon": "plus",
                                      "event": "CREATE"
                                    }
                                  ]
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "columns": 1.0,
                              "children": [
                                {
                                  "type": "stat-display",
                                  "icon": "check-square",
                                  "label": "Total Tasks",
                                  "value": [
                                    "array/len",
                                    "@entity"
                                  ]
                                }
                              ],
                              "type": "simple-grid"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "emptyIcon": "inbox",
                              "cols": 2.0,
                              "emptyTitle": "No tasks yet",
                              "entity": "Task",
                              "emptyDescription": "Create tasks to plan your sprint.",
                              "type": "data-grid",
                              "gap": "md",
                              "columns": [
                                {
                                  "name": "title",
                                  "variant": "h3",
                                  "icon": "check-square"
                                },
                                {
                                  "name": "priority",
                                  "variant": "badge"
                                },
                                {
                                  "name": "status",
                                  "variant": "badge"
                                },
                                {
                                  "name": "assignee",
                                  "variant": "body"
                                },
                                {
                                  "format": "number",
                                  "label": "Points",
                                  "variant": "body",
                                  "name": "storyPoints"
                                },
                                {
                                  "format": "date",
                                  "label": "Due",
                                  "name": "dueDate",
                                  "variant": "caption"
                                }
                              ],
                              "itemActions": [
                                {
                                  "size": "sm",
                                  "label": "View",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                },
                                {
                                  "variant": "ghost",
                                  "size": "sm",
                                  "label": "Edit",
                                  "event": "EDIT"
                                },
                                {
                                  "variant": "danger",
                                  "size": "sm",
                                  "event": "DELETE",
                                  "label": "Delete"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "appName": "ProjectManagerApp"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskCreate",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "TASK_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TASK_CREATED",
                "name": "Task Created"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded"
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "failure": "TaskLoadFailed",
                        "success": "TaskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "plus-circle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Create Task",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "entity": "Task",
                          "fields": [
                            "title",
                            "description",
                            "assignee",
                            "priority",
                            "status",
                            "storyPoints",
                            "dueDate"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TASK_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskEdit",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "TASK_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TASK_UPDATED",
                "name": "Task Updated"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded"
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Edit Task",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "title",
                            "description",
                            "assignee",
                            "priority",
                            "status",
                            "storyPoints",
                            "dueDate"
                          ],
                          "entityId": "@entity.id",
                          "mode": "edit",
                          "entity": "Task"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TASK_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskView",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
