                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Title"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.title",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Description"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.description"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "content": "Assignee",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.assignee"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Priority"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.priority"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
