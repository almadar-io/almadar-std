                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
