                        {
                          "children": [
                            {
                              "content": "Due Date",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.dueDate"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Edit",
                              "type": "button",
                              "event": "EDIT",
                              "variant": "primary",
                              "icon": "edit"
                            },
                            {
                              "variant": "ghost",
                              "event": "CLOSE",
                              "type": "button",
                              "label": "Close"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TaskDelete",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "CONFIRM_DELETE"
            },
            {
              "event": "TASK_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoaded",
              "description": "Fired when Task finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "assignee",
                  "type": "string"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "storyPoints",
                  "type": "number"
                },
                {
                  "name": "dueDate",
                  "type": "datetime"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when Task fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "TASK_DELETED",
                "name": "Task Deleted"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded"
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "TaskLoadFailed",
                        "success": "TaskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Delete Task"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "danger",
                          "message": "This action cannot be undone."
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "event": "CANCEL",
                              "label": "Cancel",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "icon": "check",
                              "event": "CONFIRM_DELETE",
                              "label": "Delete",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "justify": "end",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "emit",
                    "TASK_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
