                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Story Points",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.storyPoints",
                              "type": "typography"
                            }
                          ]
