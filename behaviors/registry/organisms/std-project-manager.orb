                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "TASK_DELETED",
                "name": "Task Deleted"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "assignee",
                    "type": "string"
                  },
                  {
                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "storyPoints",
                    "type": "number"
                  },
                  {
                    "name": "dueDate",
                    "type": "datetime"
                  },
                  {
                    "name": "pendingId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Delete Task",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "This action cannot be undone."
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CANCEL",
                              "label": "Cancel"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "icon": "check",
                              "label": "Delete",
                              "action": "CONFIRM_DELETE"
                            }
                          ],
                          "gap": "sm",
                          "justify": "end",
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ],
                  [
                    "emit",
                    "TASK_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Task"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
