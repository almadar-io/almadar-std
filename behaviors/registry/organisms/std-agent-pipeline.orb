                "main",
                {
                  "type": "dashboard-layout",
                  "appName": "Agent Pipeline",
                  "navItems": [
                    {
                      "label": "Pipeline",
                      "href": "/pipeline",
                      "icon": "git-branch"
                    },
                    {
                      "label": "Execution",
                      "href": "/execution",
                      "icon": "play"
                    },
                    {
                      "label": "Logs",
                      "href": "/logs",
                      "icon": "terminal"
                    }
                  ],
                  "children": [
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "x-circle",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "PipelineProgress",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "label": "Failed",
                              "variant": "destructive"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Plan"
                            },
                            {
                              "id": "1",
                              "title": "Execute"
                            },
                            {
                              "id": "2",
                              "title": "Checkpoint"
                            },
                            {
                              "id": "3",
                              "title": "Verify"
                            },
                            {
                              "id": "4",
                              "title": "Done"
                            }
                          ]
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "Pipeline failed at the current step."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failed At Step",
                              "value": "@entity.currentStep"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "event": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                }
              ]
            ],
            "RESET": [
              [
                "set",
                "@entity.status",
                "idle"
              ],
              [
                "set",
                "@entity.currentStep",
                0
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "dashboard-layout",
                  "appName": "Agent Pipeline",
                  "navItems": [
                    {
                      "label": "Pipeline",
                      "href": "/pipeline",
                      "icon": "git-branch"
                    },
                    {
                      "label": "Execution",
                      "href": "/execution",
                      "icon": "play"
                    },
                    {
                      "label": "Logs",
                      "href": "/logs",
                      "icon": "terminal"
                    }
                  ],
                  "children": [
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-ordered",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "PipelineProgress",
                              "variant": "h2"
                            },
                            {
                              "type": "badge",
                              "label": "Idle",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStep",
                          "steps": [
                            {
                              "id": "0",
                              "title": "Plan"
                            },
                            {
                              "id": "1",
                              "title": "Execute"
                            },
                            {
                              "id": "2",
                              "title": "Checkpoint"
                            },
                            {
                              "id": "3",
                              "title": "Verify"
                            },
                            {
                              "id": "4",
                              "title": "Done"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "variant": "primary",
                          "icon": "play"
                        }
                      ]
                    }
                  ]
                }
              ]
            ]
          }
        }
      ],
      "pages": [
