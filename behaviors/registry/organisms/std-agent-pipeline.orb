                                    "active": "success",
                                    "completed": "success",
                                    "done": "success",
                                    "pending": "warning",
                                    "draft": "warning",
                                    "scheduled": "warning",
                                    "inactive": "neutral",
                                    "archived": "neutral",
                                    "disabled": "neutral",
                                    "error": "destructive",
                                    "cancelled": "destructive",
                                    "failed": "destructive"
