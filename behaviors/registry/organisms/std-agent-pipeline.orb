                    "@entity.sessionId"
                  ],
                  [
                    "agent/fork"
                  ],
                  [
                    "agent/session-id"
                  ],
                  [
                    "persist",
                    "create",
                    "PipelineSession",
                    {
                      "sessionId": "@entity.sessionId",
                      "parentId": "@entity.parentId",
                      "status": "forked",
