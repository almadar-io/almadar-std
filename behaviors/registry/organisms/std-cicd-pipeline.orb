    {
      "name": "DeploymentOrbital",
      "entity": {
        "name": "Deployment",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "environment",
            "type": "string",
            "required": true
          },
          {
            "name": "version",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "values": [
              "pending",
              "running",
              "success",
              "failed"
            ]
          },
          {
            "name": "deployedAt",
            "type": "datetime"
          }
        ]
      },
      "traits": [
        {
          "name": "DeploymentAsync",
          "category": "interaction",
          "linkedEntity": "Deployment",
          "emits": [
            {
              "event": "DeploymentLoaded",
              "description": "Fired when Deployment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "environment",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "version",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "deployedAt",
                  "type": "datetime"
                }
              ]
            },
            {
              "event": "DeploymentLoadFailed",
              "description": "Fired when Deployment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "success"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "LOADED",
                "name": "Loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "DeploymentLoaded",
                "name": "Deployment loaded"
              },
              {
                "key": "DeploymentLoadFailed",
                "name": "Deployment load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Deployment",
                    {
                      "emit": {
                        "success": "DeploymentLoaded",
                        "failure": "DeploymentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Builds",
                          "icon": "hammer",
                          "href": "/builds"
                        },
                        {
                          "href": "/stages",
                          "label": "Stages",
                          "icon": "layers"
                        },
                        {
                          "label": "Deploy",
                          "href": "/deploy",
                          "icon": "rocket"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "size": "lg",
                                  "name": "upload-cloud"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Deployment"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "typography",
                              "color": "muted",
                              "variant": "body",
                              "content": "Ready to start deployment operation."
                            },
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start",
                              "icon": "play",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        }
                      ],
                      "appName": "CI/CD Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/builds",
                          "label": "Builds",
                          "icon": "hammer"
                        },
                        {
                          "label": "Stages",
                          "href": "/stages",
                          "icon": "layers"
                        },
                        {
                          "href": "/deploy",
                          "icon": "rocket",
                          "label": "Deploy"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "message": "Processing deployment...",
                              "type": "loading-state",
                              "title": "Deploying..."
                            },
                            {
                              "variant": "text",
                              "type": "skeleton"
                            }
                          ]
                        }
                      ],
                      "appName": "CI/CD Pipeline",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "success",
                "event": "LOADED",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Deployment",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "align": "center",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "name": "check-circle",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "type": "alert",
                              "variant": "success",
                              "message": "Deployment successful."
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "event": "RESET",
                                  "variant": "ghost",
                                  "type": "button",
                                  "label": "Reset",
                                  "icon": "rotate-ccw"
                                }
                              ],
                              "direction": "horizontal",
                              "justify": "center",
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "appName": "CI/CD Pipeline",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/builds",
                          "label": "Builds",
                          "icon": "hammer"
                        },
                        {
                          "href": "/stages",
                          "label": "Stages",
                          "icon": "layers"
                        },
                        {
                          "label": "Deploy",
                          "href": "/deploy",
                          "icon": "rocket"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "CI/CD Pipeline",
                      "navItems": [
                        {
                          "label": "Builds",
                          "icon": "hammer",
                          "href": "/builds"
                        },
                        {
                          "href": "/stages",
                          "icon": "layers",
                          "label": "Stages"
                        },
                        {
                          "icon": "rocket",
                          "href": "/deploy",
                          "label": "Deploy"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "lg",
                          "children": [
                            {
                              "message": "Deployment failed.",
                              "title": "Operation Failed",
                              "type": "error-state",
                              "onRetry": "RETRY"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "event": "RETRY",
                                  "variant": "primary",
                                  "label": "Retry",
                                  "icon": "refresh-cw",
                                  "type": "button"
                                },
                                {
                                  "type": "button",
                                  "label": "Reset",
                                  "event": "RESET",
                                  "variant": "ghost",
                                  "icon": "rotate-ccw"
                                }
                              ],
                              "justify": "center",
                              "gap": "sm"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "success",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "CI/CD Pipeline",
                      "navItems": [
                        {
                          "icon": "hammer",
                          "label": "Builds",
                          "href": "/builds"
                        },
                        {
                          "href": "/stages",
                          "label": "Stages",
                          "icon": "layers"
                        },
                        {
                          "label": "Deploy",
                          "href": "/deploy",
                          "icon": "rocket"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "upload-cloud"
                                },
                                {
                                  "content": "Deployment",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "color": "muted",
                              "type": "typography",
                              "variant": "body",
                              "content": "Ready to start deployment operation."
                            },
                            {
                              "label": "Start",
                              "event": "START",
                              "type": "button",
                              "icon": "play",
                              "variant": "primary"
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "icon": "hammer",
                          "label": "Builds",
                          "href": "/builds"
                        },
                        {
                          "label": "Stages",
                          "icon": "layers",
                          "href": "/stages"
                        },
                        {
                          "icon": "rocket",
                          "href": "/deploy",
                          "label": "Deploy"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical",
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "upload-cloud"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Deployment",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "Ready to start deployment operation.",
                              "color": "muted"
                            },
                            {
                              "type": "button",
                              "label": "Start",
                              "event": "START",
                              "variant": "primary",
                              "icon": "play"
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "CI/CD Pipeline"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "lg",
                          "align": "center",
                          "children": [
                            {
                              "type": "loading-state",
                              "message": "Processing deployment...",
                              "title": "Deploying..."
                            },
                            {
                              "variant": "text",
                              "type": "skeleton"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack"
                        }
                      ],
                      "appName": "CI/CD Pipeline",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "hammer",
                          "label": "Builds",
                          "href": "/builds"
                        },
                        {
                          "icon": "layers",
                          "label": "Stages",
                          "href": "/stages"
                        },
                        {
                          "href": "/deploy",
                          "label": "Deploy",
                          "icon": "rocket"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Deploy",
          "path": "/deploy",
          "traits": [
            {
              "ref": "DeploymentAsync"
            }
          ]
        }
      ]
    }
  ]
}