{
  "name": "std-cicd-pipeline",
  "version": "1.0.0",
  "description": "std-cicd-pipeline as a Function",
  "orbitals": [
    {
      "name": "BuildOrbital",
      "entity": {
        "name": "Build",
        "collection": "builds",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "branch",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "values": [
              "pending",
              "running",
              "success",
              "failed"
            ]
          },
          {
            "name": "commit",
            "type": "string"
          },
          {
            "name": "triggeredBy",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "BuildBrowse",
          "category": "interaction",
          "linkedEntity": "Build",
          "emits": [
            {
              "event": "BuildLoaded",
              "description": "Fired when Build finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "branch",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "commit",
                  "type": "string"
                },
                {
                  "name": "triggeredBy",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoadFailed",
              "description": "Fired when Build fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "BUILD_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BuildCreate"
              }
            },
            {
              "event": "BUILD_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BuildEdit"
              }
            },
            {
              "event": "BUILD_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BuildDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BuildLoaded",
                "name": "Build loaded"
              },
              {
                "key": "BuildLoadFailed",
                "name": "Build load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Build"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/builds",
                          "icon": "hammer",
                          "label": "Builds"
                        },
                        {
                          "label": "Stages",
                          "href": "/stages",
                          "icon": "layers"
                        },
                        {
                          "icon": "rocket",
                          "href": "/deploy",
                          "label": "Deploy"
                        }
                      ],
                      "appName": "CI/CD Pipeline",
                      "children": [
                        {
                          "children": [
                            {
                              "justify": "space-between",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "size": "lg",
                                      "type": "icon",
                                      "name": "package"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Builds",
                                      "variant": "h2"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm",
                                  "align": "center",
                                  "direction": "horizontal"
                                },
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "event": "CREATE",
                                      "label": "Create Build",
                                      "type": "button",
                                      "icon": "plus",
                                      "variant": "primary"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "emptyIcon": "inbox",
                              "variant": "card",
                              "columns": [
                                {
                                  "name": "branch",
                                  "icon": "git-branch",
                                  "variant": "h3"
                                },
                                {
                                  "name": "status",
                                  "variant": "badge"
                                },
                                {
                                  "name": "commit",
                                  "variant": "body"
                                },
                                {
                                  "variant": "caption",
                                  "name": "triggeredBy",
                                  "label": "Triggered By"
                                }
                              ],
                              "emptyTitle": "No builds yet",
                              "emptyDescription": "Trigger a build to get started.",
                              "itemActions": [
                                {
                                  "size": "sm",
                                  "event": "VIEW",
                                  "variant": "ghost",
                                  "label": "View"
                                },
                                {
                                  "event": "EDIT",
                                  "variant": "ghost",
                                  "label": "Edit",
                                  "size": "sm"
                                },
                                {
                                  "size": "sm",
                                  "label": "Delete",
                                  "event": "DELETE",
                                  "variant": "danger"
                                }
                              ],
                              "entity": "Build",
                              "type": "data-list",
                              "gap": "sm"
                            }
                          ],
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "BuildCreate",
          "category": "interaction",
          "linkedEntity": "Build",
          "emits": [
            {
              "event": "BUILD_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoaded",
              "description": "Fired when Build finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "branch",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "commit",
                  "type": "string"
                },
                {
                  "name": "triggeredBy",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoadFailed",
              "description": "Fired when Build fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "BUILD_CREATED",
                "name": "Build Created"
              },
              {
                "key": "BuildLoaded",
                "name": "Build loaded"
              },
              {
                "key": "BuildLoadFailed",
                "name": "Build load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Build"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Build",
                    {
                      "emit": {
                        "success": "BuildLoaded",
                        "failure": "BuildLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Create Build"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "Build",
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE",
                          "fields": [
                            "branch",
                            "status",
                            "commit",
                            "triggeredBy"
                          ],
                          "type": "form-section",
                          "mode": "create"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Build",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "BUILD_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "BuildEdit",
          "category": "interaction",
          "linkedEntity": "Build",
          "emits": [
            {
              "event": "BUILD_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoaded",
              "description": "Fired when Build finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "branch",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "commit",
                  "type": "string"
                },
                {
                  "name": "triggeredBy",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoadFailed",
              "description": "Fired when Build fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "BUILD_UPDATED",
                "name": "Build Updated"
              },
              {
                "key": "BuildLoaded",
                "name": "Build loaded"
              },
              {
                "key": "BuildLoadFailed",
                "name": "Build load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Build"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Build",
                    {
                      "emit": {
                        "failure": "BuildLoadFailed",
                        "success": "BuildLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "content": "Edit Build",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "branch",
                            "status",
                            "commit",
                            "triggeredBy"
                          ],
                          "mode": "edit",
                          "entityId": "@entity.id",
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "entity": "Build"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Build",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "BUILD_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "BuildView",
          "category": "interaction",
          "linkedEntity": "Build",
          "emits": [
            {
              "event": "BuildLoaded",
              "description": "Fired when Build finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "branch",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "commit",
                  "type": "string"
                },
                {
                  "name": "triggeredBy",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoadFailed",
              "description": "Fired when Build fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "BuildLoaded",
                "name": "Build loaded"
              },
              {
                "key": "BuildLoadFailed",
                "name": "Build load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Build"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Build",
                    {
                      "emit": {
                        "success": "BuildLoaded",
                        "failure": "BuildLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "eye",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.branch",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Branch",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.branch",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "gap": "md",
