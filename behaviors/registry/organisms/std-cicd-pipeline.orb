                              "label": "Edit"
                            },
                            {
                              "event": "CLOSE",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Close"
                            }
                          ],
                          "justify": "end",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "BuildDelete",
          "category": "interaction",
          "linkedEntity": "Build",
          "emits": [
            {
              "event": "BUILD_DELETED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoaded",
              "description": "Fired when Build finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "branch",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "commit",
                  "type": "string"
                },
                {
                  "name": "triggeredBy",
                  "type": "string"
                },
                {
                  "name": "pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BuildLoadFailed",
              "description": "Fired when Build fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "BUILD_DELETED",
                "name": "Build Deleted"
              },
              {
                "key": "BuildLoaded",
                "name": "Build loaded"
              },
              {
                "key": "BuildLoadFailed",
                "name": "Build load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Build"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Build",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "BuildLoadFailed",
                        "success": "BuildLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Delete Build"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "danger",
                          "message": "This action cannot be undone."
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "event": "CANCEL",
                              "label": "Cancel"
                            },
                            {
                              "icon": "check",
                              "event": "CONFIRM_DELETE",
                              "label": "Delete",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Build",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Build"
                  ],
                  [
                    "emit",
                    "BUILD_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Build"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Build"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
