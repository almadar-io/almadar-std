{
  "name": "std-social-feed",
  "version": "1.0.0",
  "description": "std-social-feed as a Function",
  "orbitals": [
    {
      "name": "PostOrbital",
      "entity": {
        "name": "Post",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "likes",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "PostBrowse",
          "category": "interaction",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "COMMENT",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PostLoaded",
              "description": "Fired when Post finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                },
                {
                  "name": "likes",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PostLoadFailed",
              "description": "Fired when Post fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.SAVE",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMMENT",
                "name": "Comment"
              },
              {
                "key": "PostLoaded",
                "name": "Post loaded"
              },
              {
                "key": "PostLoadFailed",
                "name": "Post load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Post"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "size": "lg",
                                      "name": "rss",
                                      "type": "icon"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "Feed"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "primary",
                                      "label": "New Post",
                                      "type": "button",
                                      "event": "CREATE",
                                      "icon": "plus"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ],
                              "align": "center",
                              "justify": "space-between",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "emptyIcon": "inbox",
                              "columns": [
                                {
                                  "name": "title",
                                  "variant": "h3",
                                  "icon": "rss"
                                },
                                {
                                  "name": "likes",
                                  "format": "number",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "body",
                                  "name": "author"
                                },
                                {
                                  "name": "content",
                                  "variant": "body"
                                },
                                {
                                  "variant": "caption",
                                  "name": "createdAt",
                                  "format": "date",
                                  "label": "Posted"
                                }
                              ],
                              "itemActions": [
                                {
                                  "label": "View",
                                  "size": "sm",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                }
                              ],
                              "variant": "card",
                              "entity": "Post",
                              "gap": "sm",
                              "emptyTitle": "No posts yet",
                              "type": "data-list",
                              "emptyDescription": "Share your first post."
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Feed",
                          "href": "/feed",
                          "icon": "layout-list"
                        },
                        {
                          "label": "Messages",
                          "href": "/messages",
                          "icon": "message-circle"
                        }
                      ],
                      "appName": "SocialFeed"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PostCreate",
          "category": "interaction",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PostLoaded",
              "description": "Fired when Post finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                },
                {
                  "name": "likes",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PostLoadFailed",
              "description": "Fired when Post fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PostLoaded",
                "name": "Post loaded"
              },
              {
                "key": "PostLoadFailed",
                "name": "Post load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Post"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Post",
                    {
                      "emit": {
                        "success": "PostLoaded",
                        "failure": "PostLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "content": "Create Post",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "entity": "Post",
                          "fields": [
                            "title",
                            "content",
                            "author",
                            "likes"
                          ],
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "type": "form-section"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Post",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "PostView",
          "category": "interaction",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "PostLoaded",
              "description": "Fired when Post finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                },
                {
                  "name": "likes",
                  "type": "number"
                }
              ]
            },
            {
              "event": "PostLoadFailed",
              "description": "Fired when Post fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PostLoaded",
                "name": "Post loaded"
              },
              {
                "key": "PostLoadFailed",
                "name": "Post load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Post"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Post",
                    {
                      "emit": {
                        "success": "PostLoaded",
                        "failure": "PostLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.title",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Title"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.title"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Content"
                            },
                            {
                              "content": "@entity.content",
                              "variant": "body",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "content": "Author",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.author"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Created At"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.createdAt",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "content": "Likes",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.likes",
                              "variant": "body"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "justify": "end",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Close",
                              "event": "CLOSE",
                              "variant": "ghost",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "FeedPage",
          "path": "/feed",
          "traits": [
            {
              "ref": "PostBrowse"
            },
            {
              "ref": "PostCreate"
            },
            {
              "ref": "PostView"
            }
          ]
        }
      ]
    },
    {
      "name": "CommentOrbital",
      "entity": {
        "name": "Comment",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "postId",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "datetime",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CommentBrowse",
          "category": "interaction",
          "linkedEntity": "Comment",
          "emits": [
            {
              "event": "CommentLoaded",
              "description": "Fired when Comment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "postId",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                }
              ]
            },
            {
              "event": "CommentLoadFailed",
              "description": "Fired when Comment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "*.SEND",
              "triggers": "INIT"
            },
            {
              "event": "*.COMMENT",
              "triggers": "INIT"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CommentLoaded",
                "name": "Comment loaded"
              },
              {
                "key": "CommentLoadFailed",
                "name": "Comment load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Comment"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "SocialFeed",
                      "children": [
                        {
                          "gap": "lg",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "message-circle",
                                      "size": "lg"
                                    },
                                    {
                                      "content": "Messages",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center"
                                },
                                {
                                  "children": [
                                    {
                                      "variant": "primary",
                                      "label": "Compose",
                                      "icon": "edit",
                                      "type": "button",
                                      "event": "COMPOSE"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "justify": "space-between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "gap": "sm",
                              "emptyTitle": "No messages yet",
                              "emptyIcon": "inbox",
                              "itemActions": [
                                {
                                  "variant": "ghost",
                                  "event": "VIEW",
                                  "label": "View",
                                  "size": "sm"
                                }
                              ],
                              "variant": "card",
                              "emptyDescription": "Start a new conversation.",
                              "entity": "Comment",
                              "type": "data-list",
                              "columns": [
                                {
                                  "variant": "h4",
                                  "icon": "message-circle",
                                  "name": "author"
                                },
                                {
                                  "name": "body",
                                  "variant": "body"
                                },
                                {
                                  "format": "date",
                                  "variant": "caption",
                                  "name": "createdAt"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full"
                        }
                      ],
                      "navItems": [
                        {
                          "label": "Feed",
                          "href": "/feed",
                          "icon": "layout-list"
                        },
                        {
                          "icon": "message-circle",
                          "href": "/messages",
                          "label": "Messages"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CommentCompose",
          "category": "interaction",
          "linkedEntity": "Comment",
          "emits": [
            {
              "event": "SEND"
            },
            {
              "event": "CommentLoaded",
              "description": "Fired when Comment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "postId",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                }
              ]
            },
            {
              "event": "CommentLoadFailed",
              "description": "Fired when Comment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CommentLoaded",
                "name": "Comment loaded"
              },
              {
                "key": "CommentLoadFailed",
                "name": "Comment load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Comment"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "type": "typography",
                              "content": "New Comment",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "body",
                            "author",
                            "postId"
                          ],
                          "mode": "create",
                          "submitEvent": "SEND",
                          "type": "form-section",
                          "cancelEvent": "CLOSE",
                          "entity": "Comment"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Comment",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CommentView",
          "category": "interaction",
          "linkedEntity": "Comment",
          "emits": [
            {
              "event": "SAVE"
            },
            {
              "event": "CommentLoaded",
              "description": "Fired when Comment finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "author",
                  "type": "string"
                },
                {
                  "name": "postId",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "datetime"
                }
              ]
            },
            {
              "event": "CommentLoadFailed",
              "description": "Fired when Comment fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CommentLoaded",
                "name": "Comment loaded"
              },
              {
                "key": "CommentLoadFailed",
                "name": "Comment load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Comment"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Comment",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "CommentLoadFailed",
                        "success": "CommentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.body"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "content": "Body",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.body",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Author"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.author"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "content": "Post ID",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.postId",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Created At",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.createdAt"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "justify": "end",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "event": "CLOSE",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Close"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Messages",
          "path": "/messages",
          "traits": [
            {
              "ref": "CommentBrowse"
            },
            {
              "ref": "CommentCompose"
            },
            {
              "ref": "CommentView"
            }
          ]
        }
      ]
    }
  ]
}