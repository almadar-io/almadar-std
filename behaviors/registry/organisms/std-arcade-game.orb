{
  "name": "std-arcade-game",
  "version": "1.0.0",
  "description": "std-arcade-game as a Function",
  "orbitals": [
    {
      "name": "ArcadeStateOrbital",
      "entity": {
        "name": "ArcadeState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lives",
            "type": "number",
            "default": 3.0
          },
          {
            "name": "highScore",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "ArcadeStateGameflow",
          "category": "interaction",
          "linkedEntity": "ArcadeState",
          "emits": [
            {
              "event": "ArcadeStateLoaded",
              "description": "Fired when ArcadeState finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "level",
                  "type": "number"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "lives",
                  "type": "number"
                },
                {
                  "name": "highScore",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ArcadeStateLoadFailed",
              "description": "Fired when ArcadeState fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "ArcadeStateLoaded",
                "name": "ArcadeState loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "level",
                    "type": "number"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "lives",
                    "type": "number"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ArcadeStateLoadFailed",
                "name": "ArcadeState load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArcadeState",
                    {
                      "emit": {
                        "success": "ArcadeStateLoaded",
                        "failure": "ArcadeStateLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "game-menu",
                          "menuItems": [
                            {
                              "label": "Start Game",
                              "variant": "primary",
                              "event": "START"
                            }
                          ],
                          "title": "Arcade",
                          "subtitle": "Main Menu"
                        }
                      ],
                      "appName": "Arcade Game",
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Score",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ],
                              "label": "Level"
                            }
                          ]
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "title": "Paused",
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "label": "Resume",
                          "event": "RESUME",
                          "variant": "primary"
                        },
                        {
                          "label": "Quit",
                          "variant": "ghost",
                          "event": "RESTART"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "stats": [
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ],
                              "label": "Score"
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ],
                              "label": "Level"
                            }
                          ],
                          "menuItems": [
                            {
                              "label": "Play Again",
                              "event": "RESTART",
                              "variant": "primary"
                            },
                            {
                              "label": "Main Menu",
                              "event": "RESTART",
                              "variant": "secondary"
                            }
                          ],
                          "type": "game-over-screen",
                          "title": "Game Over"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "stats": [
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ],
                              "label": "Score"
                            },
                            {
                              "label": "Level",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ]
                            }
                          ],
                          "type": "game-hud"
                        }
                      ],
                      "appName": "Arcade Game",
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Score",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "label": "Level",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "menuItems": [
                            {
                              "variant": "primary",
                              "event": "START",
                              "label": "Start Game"
                            }
                          ],
                          "title": "Arcade",
                          "subtitle": "Main Menu",
                          "type": "game-menu"
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "title": "Arcade",
                          "subtitle": "Main Menu",
                          "type": "game-menu",
                          "menuItems": [
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start Game"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GamePage",
          "path": "/game",
          "traits": [
            {
              "ref": "ArcadeStateGameflow"
            }
          ]
        }
      ]
    },
    {
      "name": "ArcadeCanvasOrbital",
      "entity": {
        "name": "ArcadeCanvas",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "width",
            "type": "number"
          },
          {
            "name": "height",
            "type": "number"
          },
          {
            "name": "fps",
            "type": "number"
          },
          {
            "name": "running",
            "type": "boolean"
          }
        ]
      },
      "traits": [
        {
          "name": "ArcadeCanvasGameCanvas2d",
          "category": "interaction",
          "linkedEntity": "ArcadeCanvas",
          "emits": [
            {
              "event": "ArcadeCanvasLoaded",
              "description": "Fired when ArcadeCanvas finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "width",
                  "type": "number"
                },
                {
                  "name": "height",
                  "type": "number"
                },
                {
                  "name": "fps",
                  "type": "number"
                },
                {
                  "name": "running",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "ArcadeCanvasLoadFailed",
              "description": "Fired when ArcadeCanvas fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "rendering"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "ArcadeCanvasLoaded",
                "name": "ArcadeCanvas loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "width",
                    "type": "number"
                  },
                  {
                    "name": "height",
                    "type": "number"
                  },
                  {
                    "name": "fps",
                    "type": "number"
                  },
                  {
                    "name": "running",
                    "type": "boolean"
                  }
                ]
              },
              {
                "key": "ArcadeCanvasLoadFailed",
                "name": "ArcadeCanvas load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArcadeCanvas",
                    {
                      "emit": {
                        "success": "ArcadeCanvasLoaded",
                        "failure": "ArcadeCanvasLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "monitor"
                                },
                                {
                                  "content": "ArcadeCanvas Canvas",
                                  "type": "typography",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "color": "muted",
                              "content": "800x600 @ 60fps",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "game-canvas-2d",
                              "width": 800.0,
                              "fps": 60.0,
                              "height": 600.0
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "label": "Start",
                              "icon": "play",
                              "action": "START"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "rendering",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "showTopBar": true,
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "monitor",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "ArcadeCanvas Canvas",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "width": 800.0,
                              "fps": 60.0,
                              "height": 600.0,
                              "type": "game-canvas-2d"
                            },
                            {
                              "type": "button",
                              "label": "Stop",
                              "action": "STOP",
                              "icon": "square",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "rendering",
                "to": "rendering",
                "event": "TICK"
              },
              {
                "from": "rendering",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "monitor"
                                },
                                {
                                  "content": "ArcadeCanvas Canvas",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center"
                            },
                            {
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography",
                              "content": "800x600 @ 60fps"
                            },
                            {
                              "height": 600.0,
                              "fps": 60.0,
                              "width": 800.0,
                              "type": "game-canvas-2d"
                            },
                            {
                              "label": "Start",
                              "type": "button",
                              "action": "START",
                              "variant": "primary",
                              "icon": "play"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Canvas",
          "path": "/canvas",
          "traits": [
            {
              "ref": "ArcadeCanvasGameCanvas2d"
            }
          ]
        }
      ]
    },
    {
      "name": "ArcadeScoreOrbital",
      "entity": {
        "name": "ArcadeScore",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "playerName",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "required": true,
            "default": 0.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "completedAt",
            "type": "string"
          },
          {
            "name": "highScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "ArcadeScoreScoreBoard",
          "category": "interaction",
          "linkedEntity": "ArcadeScore",
          "emits": [
            {
              "event": "ArcadeScoreLoaded",
              "description": "Fired when ArcadeScore finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "playerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "score",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "level",
                  "type": "number"
                },
                {
                  "name": "completedAt",
                  "type": "string"
                },
                {
                  "name": "highScore",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ArcadeScoreLoadFailed",
              "description": "Fired when ArcadeScore fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_SCORE",
                "name": "Add Score",
                "payload": [
                  {
                    "name": "points",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ArcadeScoreLoaded",
                "name": "ArcadeScore loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "playerName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "score",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "level",
                    "type": "number"
                  },
                  {
                    "name": "completedAt",
                    "type": "string"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ArcadeScoreLoadFailed",
                "name": "ArcadeScore load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArcadeScore",
                    {
                      "emit": {
                        "success": "ArcadeScoreLoaded",
                        "failure": "ArcadeScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "children": [
                        {
                          "score": "@entity.score",
                          "level": "@entity.level",
                          "highScore": "@entity.highScore",
                          "type": "score-board",
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier"
                        }
                      ],
                      "showTopBar": true,
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "type": "game-shell",
                      "showTopBar": true,
                      "children": [
                        {
                          "multiplier": "@entity.multiplier",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "score": "@entity.score",
                          "type": "score-board",
                          "combo": "@entity.combo"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "multiplier": "@entity.multiplier",
                          "combo": "@entity.combo",
                          "type": "score-board",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level"
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "type": "score-board",
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "score": "@entity.score",
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level"
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Scores",
          "path": "/scores",
          "traits": [
            {
              "ref": "ArcadeScoreScoreBoard"
            }
          ]
        }
      ]
    },
    {
      "name": "ArcadeHudOrbital",
      "entity": {
        "name": "ArcadeHud",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lives",
            "type": "number",
            "default": 3.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "timer",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "ArcadeHudHud",
          "category": "interaction",
          "linkedEntity": "ArcadeHud",
          "emits": [
            {
              "event": "ArcadeHudLoaded",
              "description": "Fired when ArcadeHud finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "lives",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                },
                {
                  "name": "timer",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ArcadeHudLoadFailed",
              "description": "Fired when ArcadeHud fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "ArcadeHudLoaded",
                "name": "ArcadeHud loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "lives",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  },
                  {
                    "name": "timer",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ArcadeHudLoadFailed",
                "name": "ArcadeHud load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArcadeHud",
                    {
                      "emit": {
                        "failure": "ArcadeHudLoadFailed",
                        "success": "ArcadeHudLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "position": "top-left",
                          "transparent": false,
                          "type": "game-hud",
                          "stats": [
                            {
                              "value": "@entity.score",
                              "label": "Score"
                            },
                            {
                              "label": "Lives",
                              "value": "@entity.lives"
                            },
                            {
                              "label": "Level",
                              "value": "@entity.level"
                            },
                            {
                              "label": "Timer",
                              "value": "@entity.timer"
                            }
                          ]
                        }
                      ],
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "ArcadeHud",
                    {
                      "emit": {
                        "success": "ArcadeHudLoaded",
                        "failure": "ArcadeHudLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-hud",
                          "transparent": false,
                          "position": "top-left",
                          "stats": [
                            {
                              "value": "@entity.score",
                              "label": "Score"
                            },
                            {
                              "label": "Lives",
                              "value": "@entity.lives"
                            },
                            {
                              "value": "@entity.level",
                              "label": "Level"
                            },
                            {
                              "label": "Timer",
                              "value": "@entity.timer"
                            }
                          ]
                        }
                      ],
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Hud",
          "path": "/hud",
          "traits": [
            {
              "ref": "ArcadeHudHud"
            }
          ]
        }
      ]
    }
  ]
