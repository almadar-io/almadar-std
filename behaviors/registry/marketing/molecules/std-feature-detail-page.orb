{
  "name": "std-feature-detail-page",
  "version": "1.0.0",
  "description": "Feature detail page molecule for marketing sites. Composes hero, alternating split sections, and CTA as a vertical stack of individual marketing patterns. Pick for product deep-dives and capability explainers.",
  "orbitals": [
    {
      "name": "FeatureDetailPageItemOrbital",
      "entity": {
        "name": "FeatureDetailPageItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FeatureDetailPageItemLayout",
          "category": "interaction",
          "linkedEntity": "FeatureDetailPageItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "none",
                      "type": "stack",
                      "children": [
                        {
                          "tag": "@config.heroTag",
                          "primaryAction": {
                            "label": "@config.heroPrimaryActionLabel",
                            "href": "@config.heroPrimaryActionHref"
                          },
                          "type": "hero-section",
                          "title": "@config.heroTitle",
                          "titleAccent": "@config.heroTitleAccent",
                          "secondaryAction": {
                            "label": "@config.heroSecondaryActionLabel",
                            "href": "@config.heroSecondaryActionHref"
                          },
                          "align": "@config.heroAlign",
                          "subtitle": "@config.heroSubtitle",
                          "background": "@config.heroBackground"
                        },
                        {
                          "bullets": "@config.sections[0].bullets",
                          "title": "@config.sections[0].title",
                          "image": "@config.sections[0].image",
                          "description": "@config.sections[0].description",
                          "type": "split-section",
                          "imagePosition": "@config.sections[0].imagePosition"
                        },
                        {
                          "type": "split-section",
                          "image": "@config.sections[1].image",
                          "title": "@config.sections[1].title",
                          "imagePosition": "@config.sections[1].imagePosition",
                          "description": "@config.sections[1].description",
                          "bullets": "@config.sections[1].bullets"
                        },
                        {
                          "image": "@config.sections[2].image",
                          "description": "@config.sections[2].description",
                          "bullets": "@config.sections[2].bullets",
                          "type": "split-section",
                          "imagePosition": "@config.sections[2].imagePosition",
                          "title": "@config.sections[2].title"
                        },
                        {
                          "type": "cta-banner",
                          "primaryAction": "@config.ctaAction",
                          "title": "@config.ctaTitle"
                        },
                        {
                          "copyright": "@config.footerCopyright",
                          "type": "marketing-footer",
                          "columns": "@config.footerColumns"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "heroPrimaryActionHref": {
              "type": "string",
              "default": "/signup"
            },
            "ctaTitle": {
              "type": "string",
              "default": "Ready to experience the future?"
            },
            "heroAlign": {
              "type": "string",
              "default": "center"
            },
            "sections": {
              "type": "[SectionCard]",
              "default": [
                {
                  "description": "Describe what you want. Almadar translates your words into a complete application schema.",
                  "bullets": [
                    "No-code visual editor",
                    "AI-assisted schema generation",
                    "Real-time preview"
                  ],
                  "title": "Design in Natural Language",
                  "image": {
                    "src": "",
                    "alt": "Design interface"
                  },
                  "imagePosition": "right"
                },
                {
                  "title": "Full-Stack Generation",
                  "image": {
                    "alt": "Generated code",
                    "src": ""
                  },
                  "description": "Get a production-ready TypeScript backend and React frontend in seconds.",
                  "bullets": [
                    "Type-safe APIs",
                    "Auto-generated database schema",
                    "Instant deployments"
                  ],
                  "imagePosition": "left"
                },
                {
                  "title": "Enterprise-Grade Security",
                  "bullets": [
                    "SOC-2 ready",
                    "RBAC & SSO",
                    "End-to-end encryption"
                  ],
                  "description": "Built-in auth, audit logs, and compliance from day one.",
                  "image": {
                    "src": "",
                    "alt": "Security dashboard"
                  },
                  "imagePosition": "right"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "image": {
                    "name": "image",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "alt": {
                        "name": "alt",
                        "type": "string",
                        "required": false
                      },
                      "src": {
                        "name": "src",
                        "type": "string",
                        "required": false
                      }
                    }
                  },
                  "imagePosition": {
                    "name": "imagePosition",
                    "type": "string",
                    "required": false
                  },
                  "bullets": {
                    "name": "bullets",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "footerCopyright": {
              "type": "string",
              "default": "© 2026 Almadar. All rights reserved."
            },
            "heroBackground": {
              "type": "string",
              "default": "gradient"
            },
            "footerColumns": {
              "type": "[FooterColumn]",
              "default": [
                {
                  "items": [
                    {
                      "label": "Features",
                      "href": "#"
                    },
                    {
                      "label": "Pricing",
                      "href": "#"
                    },
                    {
                      "label": "Changelog",
                      "href": "#"
                    }
                  ],
                  "title": "Product"
                },
                {
                  "items": [
                    {
                      "label": "About",
                      "href": "#"
                    },
                    {
                      "label": "Careers",
                      "href": "#"
                    },
                    {
                      "href": "#",
                      "label": "Blog"
                    }
                  ],
                  "title": "Company"
                },
                {
                  "title": "Resources",
                  "items": [
                    {
                      "href": "#",
                      "label": "Docs"
                    },
                    {
                      "href": "#",
                      "label": "Community"
                    },
                    {
                      "href": "#",
                      "label": "Support"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  }
                }
              }
            },
            "heroPrimaryActionLabel": {
              "type": "string",
              "default": "Get Started"
            },
            "heroSecondaryActionLabel": {
              "type": "string",
              "default": "Watch Demo"
            },
            "ctaAction": {
              "type": "ActionCard",
              "default": {
                "href": "/signup",
                "label": "Get Started"
              },
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            },
            "heroTag": {
              "type": "string",
              "default": "Feature"
            },
            "heroTitle": {
              "type": "string",
              "default": "Everything you need to ship"
            },
            "heroSubtitle": {
              "type": "string",
              "default": "From design to deployment, Almadar handles the entire stack."
            },
            "heroTitleAccent": {
              "type": "string",
              "default": ""
            },
            "heroSecondaryActionHref": {
              "type": "string",
              "default": "#"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FeatureDetailPage",
          "path": "/features",
          "traits": [
            {
              "ref": "FeatureDetailPageItemLayout"
            }
          ]
        }
      ]
    }
  ]
}