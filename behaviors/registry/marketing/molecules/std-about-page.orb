{
  "name": "std-about-page",
  "version": "1.0.0",
  "description": "About page molecule for marketing sites. Composes hero, articles, team grid, case studies, and CTA sections as a vertical stack of individual marketing patterns. Pick for company overviews, team showcases, and culture pages.",
  "orbitals": [
    {
      "name": "AboutPageItemOrbital",
      "entity": {
        "name": "AboutPageItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AboutPageItemLayout",
          "category": "interaction",
          "linkedEntity": "AboutPageItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "none",
                      "children": [
                        {
                          "title": "@config.heroTitle",
                          "titleAccent": "@config.heroTitleAccent",
                          "subtitle": "@config.heroSubtitle",
                          "align": "@config.heroAlign",
                          "background": "@config.heroBackground",
                          "type": "hero-section",
                          "tag": "@config.heroTag",
                          "primaryAction": {
                            "label": "@config.heroPrimaryActionLabel",
                            "href": "@config.heroPrimaryActionHref"
                          }
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "className": "max-w-prose mx-auto py-12",
                          "children": [
                            {
                              "content": "@config.article1Title",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "content": "@config.article1Content",
                              "variant": "body",
                              "type": "typography"
                            },
                            {
                              "variant": "h2",
                              "content": "@config.article2Title",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "content": "@config.article2Content",
                              "type": "typography"
                            },
                            {
                              "variant": "h2",
                              "content": "@config.article3Title",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "content": "@config.article3Content",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "team-organism",
                          "entity": "@config.team"
                        },
                        {
                          "entity": "@config.caseStudies",
                          "type": "case-study-organism"
                        },
                        {
                          "primaryAction": "@config.ctaAction",
                          "type": "cta-banner",
                          "title": "@config.ctaTitle"
                        },
                        {
                          "columns": "@config.footerColumns",
                          "copyright": "@config.footerCopyright",
                          "type": "marketing-footer"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "article1Content": {
              "type": "string",
              "default": "Almadar started with a simple belief: everyone should be able to build software."
            },
            "article2Content": {
              "type": "string",
              "default": "We exist to democratize software creation through natural language and AI."
            },
            "heroSubtitle": {
              "type": "string",
              "default": "We're building the future of software creation."
            },
            "team": {
              "type": "[TeamMemberCard]",
              "default": [
                {
                  "name": "Jane Doe",
                  "role": "CEO",
                  "nameAr": "",
                  "bio": "Former VP Engineering at BigTech. Obsessed with developer experience.",
                  "id": "1",
                  "avatar": ""
                },
                {
                  "role": "CTO",
                  "bio": "Built distributed systems at scale for a decade.",
                  "id": "2",
                  "avatar": "",
                  "nameAr": "",
                  "name": "John Smith"
                },
                {
                  "role": "Head of Design",
                  "id": "3",
                  "bio": "Believes great design is invisible.",
                  "name": "Alice Chen",
                  "nameAr": "",
                  "avatar": ""
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "nameAr": {
                    "name": "nameAr",
                    "type": "string",
                    "required": false
                  },
                  "bio": {
                    "name": "bio",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "avatar": {
                    "name": "avatar",
                    "type": "string",
                    "required": false
                  },
                  "role": {
                    "name": "role",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "article3Content": {
              "type": "string",
              "default": "Speed, simplicity, and developer joy guide every decision we make."
            },
            "heroTitleAccent": {
              "type": "string",
              "default": ""
            },
            "article1Title": {
              "type": "string",
              "default": "Our Story"
            },
            "footerCopyright": {
              "type": "string",
              "default": "© 2026 Almadar. All rights reserved."
            },
            "ctaAction": {
              "type": "ActionCard",
              "default": {
                "href": "/careers",
                "label": "View Open Roles"
              },
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                }
              }
            },
            "article3Title": {
              "type": "string",
              "default": "Our Values"
            },
            "ctaTitle": {
              "type": "string",
              "default": "Want to work with us?"
            },
            "heroTag": {
              "type": "string",
              "default": ""
            },
            "heroAlign": {
              "type": "string",
              "default": "center"
            },
            "footerColumns": {
              "type": "[FooterColumn]",
              "default": [
                {
                  "title": "Product",
                  "items": [
                    {
                      "href": "#",
                      "label": "Features"
                    },
                    {
                      "href": "#",
                      "label": "Pricing"
                    },
                    {
                      "href": "#",
                      "label": "Changelog"
                    }
                  ]
                },
                {
                  "title": "Company",
                  "items": [
                    {
                      "href": "#",
                      "label": "About"
                    },
                    {
                      "label": "Careers",
                      "href": "#"
                    },
                    {
                      "label": "Blog",
                      "href": "#"
                    }
                  ]
                },
                {
                  "title": "Resources",
                  "items": [
                    {
                      "href": "#",
                      "label": "Docs"
                    },
                    {
                      "href": "#",
                      "label": "Community"
                    },
                    {
                      "label": "Support",
                      "href": "#"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        },
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroTitle": {
              "type": "string",
              "default": "About Almadar"
            },
            "heroPrimaryActionLabel": {
              "type": "string",
              "default": "Join Us"
            },
            "heroBackground": {
              "type": "string",
              "default": "subtle"
            },
            "article2Title": {
              "type": "string",
              "default": "Our Mission"
            },
            "caseStudies": {
              "type": "[CaseStudyCard]",
              "default": [
                {
                  "href": "#",
                  "categoryColor": "",
                  "linkLabel": "Read story",
                  "id": "1",
                  "title": "Acme Corp",
                  "category": "SaaS",
                  "description": "How Acme scaled from 1K to 1M users in 6 months."
                },
                {
                  "category": "Fintech",
                  "href": "#",
                  "categoryColor": "",
                  "linkLabel": "Read story",
                  "description": "Globex reduced infrastructure costs by 70%.",
                  "title": "Globex",
                  "id": "2"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "categoryColor": {
                    "name": "categoryColor",
                    "type": "string",
                    "required": false
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": true
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "category": {
                    "name": "category",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroPrimaryActionHref": {
              "type": "string",
              "default": "/careers"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AboutPage",
          "path": "/about",
          "traits": [
            {
              "ref": "AboutPageItemLayout"
            }
          ]
        }
      ]
    }
  ]
}