{
  "name": "std-pricing-page",
  "version": "1.1.0",
  "description": "Pricing page molecule for marketing sites. Composes hero, pricing grid, FAQ accordion, and CTA sections as a vertical stack of individual marketing patterns. Pick for SaaS pricing pages and plan comparisons.",
  "orbitals": [
    {
      "name": "PricingPageItemOrbital",
      "entity": {
        "name": "PricingPageItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PricingPageItemLayout",
          "category": "interaction",
          "linkedEntity": "PricingPageItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "tag": "@config.heroTag",
                          "secondaryAction": {
                            "href": "@config.heroSecondaryActionHref",
                            "label": "@config.heroSecondaryActionLabel"
                          },
                          "title": "@config.heroTitle",
                          "background": "@config.heroBackground",
                          "subtitle": "@config.heroSubtitle",
                          "align": "@config.heroAlign",
                          "type": "hero-section",
                          "titleAccent": "@config.heroTitleAccent",
                          "primaryAction": {
                            "href": "@config.heroPrimaryActionHref",
                            "label": "@config.heroPrimaryActionLabel"
                          }
                        },
                        {
                          "type": "pricing-grid",
                          "plans": "@config.plans"
                        },
                        {
                          "type": "accordion",
                          "items": "@config.faq"
                        },
                        {
                          "type": "cta-banner",
                          "title": "@config.ctaTitle",
                          "primaryAction": "@config.ctaAction",
                          "subtitle": "@config.ctaSubtitle"
                        },
                        {
                          "copyright": "@config.footerCopyright",
                          "type": "marketing-footer",
                          "columns": "@config.footerColumns"
                        }
                      ],
                      "gap": "none",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "heroPrimaryActionHref": {
              "type": "string",
              "default": "/signup"
            },
            "heroBackground": {
              "type": "string",
              "default": "subtle"
            },
            "faq": {
              "type": "[FaqItem]",
              "default": [
                {
                  "title": "Can I change plans later?",
                  "id": "plan-changes",
                  "content": "Yes, you can upgrade or downgrade at any time."
                },
                {
                  "title": "Is there a free trial?",
                  "content": "Yes, every paid plan includes a 14-day free trial.",
                  "id": "free-trial"
                },
                {
                  "id": "payment-methods",
                  "title": "What payment methods do you accept?",
                  "content": "We accept all major credit cards and wire transfers for Enterprise."
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroTag": {
              "type": "string",
              "default": ""
            },
            "ctaSubtitle": {
              "type": "string",
              "default": "Our team is here to help you find the right plan."
            },
            "heroTitle": {
              "type": "string",
              "default": "Simple, transparent pricing"
            },
            "heroSubtitle": {
              "type": "string",
              "default": "Start free, scale as you grow."
            },
            "heroPrimaryActionLabel": {
              "type": "string",
              "default": "Get Started"
            },
            "heroSecondaryActionHref": {
              "type": "string",
              "default": "/contact"
            },
            "plans": {
              "type": "[PricingPlan]",
              "default": [
                {
                  "highlighted": false,
                  "description": "For individuals and small projects.",
                  "action": {
                    "label": "Get Started",
                    "href": "#"
                  },
                  "name": "Starter",
                  "price": "$0",
                  "badge": "",
                  "features": [
                    "1 project",
                    "Community support",
                    "Basic analytics"
                  ]
                },
                {
                  "name": "Pro",
                  "description": "For growing teams that need more power.",
                  "features": [
                    "Unlimited projects",
                    "Priority support",
                    "Advanced analytics",
                    "Custom domains"
                  ],
                  "price": "$49",
                  "action": {
                    "label": "Start Trial",
                    "href": "#"
                  },
                  "highlighted": true,
                  "badge": "Most Popular"
                },
                {
                  "description": "For organizations with advanced needs.",
                  "features": [
                    "Dedicated infra",
                    "SLA guarantee",
                    "SSO & SAML",
                    "Audit logs",
                    "Custom contracts"
                  ],
                  "price": "Custom",
                  "badge": "",
                  "name": "Enterprise",
                  "action": {
                    "href": "#",
                    "label": "Contact Sales"
                  },
                  "highlighted": false
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "action": {
                    "name": "action",
                    "type": "object",
                    "required": true,
                    "properties": {
                      "href": {
                        "name": "href",
                        "type": "string",
                        "required": true
                      },
                      "label": {
                        "name": "label",
                        "type": "string",
                        "required": true
                      }
                    }
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "price": {
                    "name": "price",
                    "type": "string",
                    "required": true
                  },
                  "features": {
                    "name": "features",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "highlighted": {
                    "name": "highlighted",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            },
            "heroAlign": {
              "type": "string",
              "default": "center"
            },
            "ctaTitle": {
              "type": "string",
              "default": "Still have questions?"
            },
            "footerCopyright": {
              "type": "string",
              "default": "© 2026 Almadar. All rights reserved."
            },
            "ctaAction": {
              "type": "ActionCard",
              "default": {
                "label": "Contact Sales",
                "href": "/contact"
              },
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                }
              }
            },
            "heroSecondaryActionLabel": {
              "type": "string",
              "default": "Contact Sales"
            },
            "footerColumns": {
              "type": "[FooterColumn]",
              "default": [
                {
                  "items": [
                    {
                      "href": "#",
                      "label": "Features"
                    },
                    {
                      "label": "Pricing",
                      "href": "#"
                    },
                    {
                      "href": "#",
                      "label": "Changelog"
                    }
                  ],
                  "title": "Product"
                },
                {
                  "items": [
                    {
                      "href": "#",
                      "label": "About"
                    },
                    {
                      "label": "Careers",
                      "href": "#"
                    },
                    {
                      "label": "Blog",
                      "href": "#"
                    }
                  ],
                  "title": "Company"
                },
                {
                  "title": "Resources",
                  "items": [
                    {
                      "href": "#",
                      "label": "Docs"
                    },
                    {
                      "label": "Community",
                      "href": "#"
                    },
                    {
                      "href": "#",
                      "label": "Support"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  }
                }
              }
            },
            "heroTitleAccent": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PricingPage",
          "path": "/pricing",
          "traits": [
            {
              "ref": "PricingPageItemLayout"
            }
          ]
        }
      ]
    }
  ]
}