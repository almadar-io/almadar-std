{
  "name": "std-landing-page",
  "version": "1.0.0",
  "description": "Landing page molecule for marketing sites. Composes hero, features, stats, steps, showcase, CTA, and footer sections as a vertical stack of individual marketing patterns. Pick for product launches, SaaS homepages, and campaign microsites.",
  "orbitals": [
    {
      "name": "LandingPageItemOrbital",
      "entity": {
        "name": "LandingPageItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "LandingPageItemLayout",
          "category": "interaction",
          "linkedEntity": "LandingPageItem",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "none",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "hero-section",
                          "titleAccent": "@config.heroTitleAccent",
                          "tag": "@config.heroTag",
                          "subtitle": "@config.heroSubtitle",
                          "primaryAction": {
                            "label": "@config.heroPrimaryActionLabel",
                            "href": "@config.heroPrimaryActionHref"
                          },
                          "secondaryAction": {
                            "label": "@config.heroSecondaryActionLabel",
                            "href": "@config.heroSecondaryActionHref"
                          },
                          "align": "@config.heroAlign",
                          "background": "@config.heroBackground",
                          "title": "@config.heroTitle"
                        },
                        {
                          "type": "feature-grid",
                          "items": "@config.features"
                        },
                        {
                          "type": "stats-grid",
                          "stats": "@config.stats"
                        },
                        {
                          "type": "step-flow-organism",
                          "entity": "@config.steps"
                        },
                        {
                          "entity": "@config.showcase",
                          "type": "showcase-organism"
                        },
                        {
                          "secondaryAction": "@config.ctaSecondaryAction",
                          "title": "@config.ctaTitle",
                          "type": "cta-banner",
                          "primaryAction": "@config.ctaPrimaryAction",
                          "subtitle": "@config.ctaSubtitle"
                        },
                        {
                          "copyright": "@config.footerCopyright",
                          "columns": "@config.footerColumns",
                          "type": "marketing-footer"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "heroTitleAccent": {
              "type": "string",
              "default": ""
            },
            "ctaSubtitle": {
              "type": "string",
              "default": "Join thousands of teams shipping faster."
            },
            "ctaSecondaryAction": {
              "type": "ActionCard",
              "default": {
                "label": "",
                "href": ""
              },
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            },
            "footerCopyright": {
              "type": "string",
              "default": "© 2026 Almadar. All rights reserved."
            },
            "features": {
              "type": "[FeatureCard]",
              "default": [
                {
                  "linkLabel": "Learn more",
                  "title": "Lightning Fast",
                  "icon": "zap",
                  "description": "Build and deploy in minutes.",
                  "href": ""
                },
                {
                  "linkLabel": "Learn more",
                  "description": "SOC-2 compliant with end-to-end encryption.",
                  "href": "",
                  "title": "Enterprise Secure",
                  "icon": "shield"
                },
                {
                  "description": "Plug in any service, any data source, any UI pattern.",
                  "icon": "puzzle",
                  "href": "",
                  "linkLabel": "Learn more",
                  "title": "Infinitely Extensible"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroSecondaryActionLabel": {
              "type": "string",
              "default": ""
            },
            "heroTitle": {
              "type": "string",
              "default": "Build faster with Almadar"
            },
            "steps": {
              "type": "[StepCard]",
              "default": [
                {
                  "title": "Design",
                  "id": "1",
                  "number": 1.0,
                  "icon": "pen-tool",
                  "description": "Describe your app in natural language."
                },
                {
                  "number": 2.0,
                  "description": "Almadar generates the full stack automatically.",
                  "id": "2",
                  "icon": "hammer",
                  "title": "Build"
                },
                {
                  "id": "3",
                  "description": "Deploy to production with one click.",
                  "icon": "rocket",
                  "number": 3.0,
                  "title": "Ship"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "number": {
                    "name": "number",
                    "type": "number",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroSubtitle": {
              "type": "string",
              "default": "From idea to production in minutes, not months."
            },
            "ctaTitle": {
              "type": "string",
              "default": "Ready to get started?"
            },
            "heroBackground": {
              "type": "string",
              "default": "gradient"
            },
            "showcase": {
              "type": "[ShowcaseCard]",
              "default": [
                {
                  "href": "",
                  "id": "dashboard",
                  "image": {
                    "src": "",
                    "alt": "Dashboard"
                  },
                  "title": "Dashboard",
                  "description": "Real-time analytics at a glance.",
                  "badge": "New",
                  "accentColor": ""
                },
                {
                  "title": "API",
                  "badge": "",
                  "href": "",
                  "accentColor": "",
                  "id": "api",
                  "description": "GraphQL and REST in one click.",
                  "image": {
                    "src": "",
                    "alt": "API"
                  }
                },
                {
                  "image": {
                    "src": "",
                    "alt": "Mobile"
                  },
                  "href": "",
                  "description": "Native apps without native code.",
                  "badge": "Beta",
                  "accentColor": "",
                  "id": "mobile",
                  "title": "Mobile"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "image": {
                    "name": "image",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "src": {
                        "name": "src",
                        "type": "string",
                        "required": true
                      },
                      "alt": {
                        "name": "alt",
                        "type": "string",
                        "required": false
                      }
                    }
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "accentColor": {
                    "name": "accentColor",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "heroPrimaryActionHref": {
              "type": "string",
              "default": "/signup"
            },
            "footerColumns": {
              "type": "[FooterColumn]",
              "default": [
                {
                  "items": [
                    {
                      "label": "Features",
                      "href": "#"
                    },
                    {
                      "label": "Pricing",
                      "href": "#"
                    },
                    {
                      "label": "Changelog",
                      "href": "#"
                    }
                  ],
                  "title": "Product"
                },
                {
                  "title": "Company",
                  "items": [
                    {
                      "label": "About",
                      "href": "#"
                    },
                    {
                      "label": "Careers",
                      "href": "#"
                    },
                    {
                      "label": "Blog",
                      "href": "#"
                    }
                  ]
                },
                {
                  "title": "Resources",
                  "items": [
                    {
                      "href": "#",
                      "label": "Docs"
                    },
                    {
                      "href": "#",
                      "label": "Community"
                    },
                    {
                      "href": "#",
                      "label": "Support"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        },
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  }
                }
              }
            },
            "stats": {
              "type": "[StatCard]",
              "default": [
                {
                  "value": "10K+",
                  "label": "Developers"
                },
                {
                  "value": "99.9%",
                  "label": "Uptime"
                },
                {
                  "value": "50M+",
                  "label": "Requests served"
                },
                {
                  "label": "Average rating",
                  "value": "4.9"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "ctaPrimaryAction": {
              "type": "ActionCard",
              "default": {
                "label": "Get Started",
                "href": "/signup"
              },
              "properties": {
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                }
              }
            },
            "heroPrimaryActionLabel": {
              "type": "string",
              "default": "Get Started"
            },
            "heroAlign": {
              "type": "string",
              "default": "center"
            },
            "heroTag": {
              "type": "string",
              "default": ""
            },
            "heroSecondaryActionHref": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "LandingPage",
          "path": "/",
          "traits": [
            {
              "ref": "LandingPageItemLayout"
            }
          ]
        }
      ]
    }
  ]
}