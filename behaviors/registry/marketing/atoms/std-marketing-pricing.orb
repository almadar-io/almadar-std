{
  "name": "std-marketing-pricing",
  "version": "1.0.0",
  "description": "Pricing grid atom for marketing pages. Renders tiered pricing cards with plans, features, and CTAs. Pick for SaaS pricing pages and subscription showcases.",
  "orbitals": [
    {
      "name": "PricingItemOrbital",
      "entity": {
        "name": "PricingItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "PricingItemPricing",
          "category": "interaction",
          "linkedEntity": "PricingItem",
          "emits": [
            {
              "event": "PLAN_SELECT",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "plan",
                  "type": "string"
                },
                {
                  "name": "href",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN_SELECT",
                "name": "Plan Select",
                "payloadSchema": [
                  {
                    "name": "plan",
                    "type": "string"
                  },
                  {
                    "name": "href",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pricing-grid",
                      "plans": "@config.plans"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PLAN_SELECT",
                "effects": [
                  [
                    "emit",
                    "PLAN_SELECT",
                    {
                      "href": "@payload.href",
                      "plan": "@payload.plan"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "plans": {
              "type": "[PricingPlan]",
              "default": [
                {
                  "action": {
                    "label": "Get Started",
                    "href": "#"
                  },
                  "highlighted": false,
                  "badge": "",
                  "price": "$0",
                  "features": [
                    "1 project",
                    "Community support",
                    "Basic analytics"
                  ],
                  "description": "For individuals and small projects.",
                  "name": "Starter"
                },
                {
                  "highlighted": true,
                  "features": [
                    "Unlimited projects",
                    "Priority support",
                    "Advanced analytics",
                    "Custom domains"
                  ],
                  "badge": "Most Popular",
                  "name": "Pro",
                  "description": "For growing teams that need more power.",
                  "price": "$49",
                  "action": {
                    "href": "#",
                    "label": "Start Trial"
                  }
                },
                {
                  "highlighted": false,
                  "badge": "",
                  "name": "Enterprise",
                  "price": "Custom",
                  "features": [
                    "Dedicated infra",
                    "SLA guarantee",
                    "SSO & SAML",
                    "Audit logs",
                    "Custom contracts"
                  ],
                  "action": {
                    "label": "Contact Sales",
                    "href": "#"
                  },
                  "description": "For organizations with advanced needs."
                }
              ],
              "label": "Pricing Plans",
              "description": "Array of pricing tiers",
              "tier": "domain",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "features": {
                    "name": "features",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "highlighted": {
                    "name": "highlighted",
                    "type": "boolean",
                    "required": false
                  },
                  "price": {
                    "name": "price",
                    "type": "string",
                    "required": true
                  },
                  "action": {
                    "name": "action",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "href": {
                        "name": "href",
                        "type": "string",
                        "required": true
                      },
                      "label": {
                        "name": "label",
                        "type": "string",
                        "required": true
                      }
                    }
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PricingItemPricingPage",
          "path": "/pricing",
          "traits": [
            {
              "ref": "PricingItemPricing"
            }
          ]
        }
      ]
    }
  ]
}