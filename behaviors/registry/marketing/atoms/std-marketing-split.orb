{
  "name": "std-marketing-split",
  "version": "1.0.0",
  "description": "Split section atom for marketing pages. Renders a two-column layout with text and image alternating sides. Pick for feature deep-dives and alternating content sections.",
  "orbitals": [
    {
      "name": "SplitItemOrbital",
      "entity": {
        "name": "SplitItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "SplitItemSplit",
          "category": "interaction",
          "linkedEntity": "SplitItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "imagePosition": "@config.imagePosition",
                      "description": "@config.description",
                      "image": {
                        "alt": "@config.imageAlt",
                        "src": "@config.imageSrc"
                      },
                      "background": "@config.background",
                      "title": "@config.title",
                      "bullets": "@config.bullets",
                      "type": "split-section"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "imageSrc": {
              "type": "string",
              "default": "",
              "label": "Image Source",
              "tier": "presentation"
            },
            "imagePosition": {
              "type": "string",
              "default": "right",
              "label": "Image Position",
              "description": "left or right",
              "tier": "presentation"
            },
            "background": {
              "type": "string",
              "default": "default",
              "label": "Background",
              "description": "default or alt",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Powerful under the hood",
              "label": "Title",
              "description": "Section headline",
              "tier": "presentation"
            },
            "bullets": {
              "type": "[string]",
              "default": [
                "Instant deployments",
                "Auto-scaling",
                "Global CDN"
              ],
              "label": "Bullets",
              "description": "Feature bullet points",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "imageAlt": {
              "type": "string",
              "default": "",
              "label": "Image Alt Text",
              "tier": "presentation"
            },
            "description": {
              "type": "string",
              "default": "Everything you need to build, deploy, and scale.",
              "label": "Description",
              "description": "Body text",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SplitItemSplitPage",
          "path": "/split",
          "traits": [
            {
              "ref": "SplitItemSplit"
            }
          ]
        }
      ]
    }
  ]
}