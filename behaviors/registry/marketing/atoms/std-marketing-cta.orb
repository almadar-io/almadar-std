{
  "name": "std-marketing-cta",
  "version": "1.0.0",
  "description": "Call-to-action banner atom for marketing pages. Renders a high-conversion CTA section with title, subtitle, and action buttons. Pick for conversion points at the end of pages or between sections.",
  "orbitals": [
    {
      "name": "CTAItemOrbital",
      "entity": {
        "name": "CTAItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "CTAItemCTA",
          "category": "interaction",
          "linkedEntity": "CTAItem",
          "emits": [
            {
              "event": "CTA_PRIMARY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CTA_SECONDARY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CTA_PRIMARY",
                "name": "Cta Primary",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CTA_SECONDARY",
                "name": "Cta Secondary",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "@config.align",
                      "type": "cta-banner",
                      "subtitle": "@config.subtitle",
                      "title": "@config.title",
                      "primaryAction": {
                        "href": "@config.primaryActionHref",
                        "label": "@config.primaryActionLabel"
                      },
                      "secondaryAction": {
                        "href": "@config.secondaryActionHref",
                        "label": "@config.secondaryActionLabel"
                      },
                      "background": "@config.background"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CTA_PRIMARY",
                "effects": [
                  [
                    "emit",
                    "CTA_PRIMARY",
                    {
                      "href": "@config.primaryActionHref"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CTA_SECONDARY",
                "effects": [
                  [
                    "emit",
                    "CTA_SECONDARY",
                    {
                      "href": "@config.secondaryActionHref"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "secondaryActionLabel": {
              "type": "string",
              "default": "Learn More",
              "label": "Secondary Action Label",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Ready to get started?",
              "label": "Title",
              "description": "Banner headline",
              "tier": "presentation"
            },
            "primaryActionLabel": {
              "type": "string",
              "default": "Get Started",
              "label": "Primary Action Label",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "Join thousands of teams shipping faster.",
              "label": "Subtitle",
              "description": "Supporting text below the title",
              "tier": "presentation"
            },
            "primaryActionHref": {
              "type": "string",
              "default": "#",
              "label": "Primary Action Link",
              "tier": "presentation"
            },
            "align": {
              "type": "string",
              "default": "center",
              "label": "Alignment",
              "description": "center or left",
              "tier": "presentation"
            },
            "secondaryActionHref": {
              "type": "string",
              "default": "",
              "label": "Secondary Action Link",
              "tier": "presentation"
            },
            "background": {
              "type": "string",
              "default": "primary",
              "label": "Background",
              "description": "default, alt, dark, gradient, or primary",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CTAItemCTAPage",
          "path": "/cta",
          "traits": [
            {
              "ref": "CTAItemCTA"
            }
          ]
        }
      ]
    }
  ]
}