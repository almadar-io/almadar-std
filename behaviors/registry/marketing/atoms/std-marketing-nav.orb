{
  "name": "std-marketing-nav",
  "version": "1.0.0",
  "description": "Marketing navigation atom for marketing pages. Renders a sticky header with brand logo and nav links. Pick for site-wide navigation on static pages.",
  "orbitals": [
    {
      "name": "NavItemOrbital",
      "entity": {
        "name": "NavItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "NavItemNav",
          "category": "interaction",
          "linkedEntity": "NavItem",
          "emits": [
            {
              "event": "NAV_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NAV_CLICK",
                "name": "Nav Click",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navigationItems": "@config.items",
                      "brandName": "@config.brandName",
                      "actions": [
                        {
                          "label": "@config.primaryActionLabel",
                          "href": "@config.primaryActionHref",
                          "variant": "primary"
                        }
                      ],
                      "type": "header",
                      "logoSrc": "@config.logoSrc"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "NAV_CLICK",
                "effects": [
                  [
                    "emit",
                    "NAV_CLICK",
                    {
                      "href": "@payload.href",
                      "label": "@payload.label"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "primaryActionHref": {
              "type": "string",
              "default": "#",
              "label": "Primary Action Link",
              "tier": "presentation"
            },
            "items": {
              "type": "[NavLink]",
              "default": [
                {
                  "label": "Product",
                  "href": "#product"
                },
                {
                  "label": "Pricing",
                  "href": "#pricing"
                },
                {
                  "label": "About",
                  "href": "#about"
                },
                {
                  "label": "Docs",
                  "href": "#docs"
                }
              ],
              "label": "Navigation Items",
              "description": "Array of nav links",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "brandName": {
              "type": "string",
              "default": "Almadar",
              "label": "Brand Name",
              "tier": "presentation"
            },
            "logoSrc": {
              "type": "string",
              "default": "",
              "label": "Logo Source",
              "tier": "presentation"
            },
            "primaryActionLabel": {
              "type": "string",
              "default": "Get Started",
              "label": "Primary Action Label",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "NavItemNavPage",
          "path": "/nav",
          "traits": [
            {
              "ref": "NavItemNav"
            }
          ]
        }
      ]
    }
  ]
}