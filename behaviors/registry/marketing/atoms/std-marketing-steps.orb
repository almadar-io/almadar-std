{
  "name": "std-marketing-steps",
  "version": "1.0.0",
  "description": "Step flow atom for marketing pages. Renders numbered steps horizontally or vertically. Pick for how-it-works sections and onboarding explainers.",
  "orbitals": [
    {
      "name": "StepItemOrbital",
      "entity": {
        "name": "StepSectionItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "steps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "number": {
                  "name": "number",
                  "type": "number",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "StepSectionItemSteps",
          "category": "interaction",
          "linkedEntity": "StepSectionItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.steps",
                    "@config.steps"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "step-flow-organism",
                      "entity": "@entity.steps"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "steps": {
              "type": "[StepCard]",
              "default": [
                {
                  "number": 1.0,
                  "description": "Describe your app in natural language.",
                  "title": "Design",
                  "icon": "pen-tool",
                  "id": "1"
                },
                {
                  "title": "Build",
                  "number": 2.0,
                  "description": "Almadar generates the full stack automatically.",
                  "id": "2",
                  "icon": "hammer"
                },
                {
                  "id": "3",
                  "icon": "rocket",
                  "description": "Deploy to production with one click.",
                  "title": "Ship",
                  "number": 3.0
                }
              ],
              "label": "Steps",
              "description": "Array of step items",
              "tier": "essential",
              "items": {
                "type": "object",
                "properties": {
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "number": {
                    "name": "number",
                    "type": "number",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "horizontal or vertical",
              "tier": "customization"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StepSectionItemStepsPage",
          "path": "/steps",
          "traits": [
            {
              "ref": "StepSectionItemSteps"
            }
          ]
        }
      ]
    }
  ]
}