{
  "name": "std-marketing-testimonials",
  "version": "1.0.0",
  "description": "Testimonials atom for marketing pages. Renders social proof as logos, quotes, or badges. Pick for trust-building sections and customer validation.",
  "orbitals": [
    {
      "name": "TestimonialItemOrbital",
      "entity": {
        "name": "TestimonialItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "TestimonialItemTestimonials",
          "category": "interaction",
          "linkedEntity": "TestimonialItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "social-proof",
                      "variant": "@config.variant",
                      "items": "@config.items"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[TestimonialCard]",
              "default": [
                {
                  "quote": "Almadar cut our time-to-market by 80%.",
                  "name": "Acme Corp",
                  "logo": ""
                },
                {
                  "logo": "",
                  "quote": "The most intuitive platform we've ever used.",
                  "name": "Globex"
                },
                {
                  "name": "Initech",
                  "quote": "We replaced three tools with one.",
                  "logo": ""
                }
              ],
              "label": "Testimonials",
              "description": "Array of social proof items",
              "tier": "essential",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "quote": {
                    "name": "quote",
                    "type": "string",
                    "required": false
                  },
                  "logo": {
                    "name": "logo",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "variant": {
              "type": "string",
              "default": "quotes",
              "label": "Variant",
              "description": "logos, quotes, or badges",
              "tier": "customization"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TestimonialItemTestimonialsPage",
          "path": "/testimonials",
          "traits": [
            {
              "ref": "TestimonialItemTestimonials"
            }
          ]
        }
      ]
    }
  ]
}