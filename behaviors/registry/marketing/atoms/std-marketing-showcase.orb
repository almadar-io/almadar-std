{
  "name": "std-marketing-showcase",
  "version": "1.0.0",
  "description": "Showcase grid atom for marketing pages. Renders a grid of portfolio or product showcase cards with images, badges, and descriptions. Pick for product galleries and portfolio sections.",
  "orbitals": [
    {
      "name": "ShowcaseItemOrbital",
      "entity": {
        "name": "ShowcaseItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "image": {
                  "name": "image",
                  "type": "object",
                  "required": false,
                  "properties": {
                    "src": {
                      "name": "src",
                      "type": "string",
                      "required": true
                    },
                    "alt": {
                      "name": "alt",
                      "type": "string",
                      "required": false
                    }
                  }
                },
                "badge": {
                  "name": "badge",
                  "type": "string",
                  "required": false
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": false
                },
                "accentColor": {
                  "name": "accentColor",
                  "type": "string",
                  "required": false
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "ShowcaseItemShowcase",
          "category": "interaction",
          "linkedEntity": "ShowcaseItem",
          "emits": [
            {
              "event": "SHOWCASE_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "title",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SHOWCASE_CLICK",
                "name": "Showcase Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity.items",
                      "type": "showcase-organism"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SHOWCASE_CLICK",
                "effects": [
                  [
                    "emit",
                    "SHOWCASE_CLICK",
                    {
                      "id": "@payload.id",
                      "title": "@payload.title"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[ShowcaseCard]",
              "default": [
                {
                  "id": "1",
                  "accentColor": "",
                  "description": "Real-time analytics at a glance.",
                  "title": "Dashboard",
                  "href": "",
                  "badge": "New",
                  "image": {
                    "src": "",
                    "alt": "Dashboard preview"
                  }
                },
                {
                  "href": "",
                  "id": "2",
                  "title": "API",
                  "description": "GraphQL and REST in one click.",
                  "accentColor": "",
                  "image": {
                    "src": "",
                    "alt": "API docs preview"
                  },
                  "badge": ""
                },
                {
                  "accentColor": "",
                  "title": "Mobile",
                  "href": "",
                  "description": "Native apps without native code.",
                  "id": "3",
                  "badge": "Beta",
                  "image": {
                    "alt": "Mobile app preview",
                    "src": ""
                  }
                }
              ],
              "label": "Showcase Items",
              "description": "Array of showcase cards",
              "tier": "essential",
              "items": {
                "type": "object",
                "properties": {
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "image": {
                    "name": "image",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "src": {
                        "name": "src",
                        "type": "string",
                        "required": true
                      },
                      "alt": {
                        "name": "alt",
                        "type": "string",
                        "required": false
                      }
                    }
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "accentColor": {
                    "name": "accentColor",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ShowcaseItemShowcasePage",
          "path": "/showcase",
          "traits": [
            {
              "ref": "ShowcaseItemShowcase"
            }
          ]
        }
      ]
    }
  ]
}