{
  "name": "std-marketing-case-studies",
  "version": "1.0.0",
  "description": "Case studies grid atom for marketing pages. Renders a grid of case study cards with categories, descriptions, and links. Pick for social proof and success story sections.",
  "orbitals": [
    {
      "name": "CaseStudyItemOrbital",
      "entity": {
        "name": "CaseStudyItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                },
                "categoryColor": {
                  "name": "categoryColor",
                  "type": "string",
                  "required": false
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": true
                },
                "category": {
                  "name": "category",
                  "type": "string",
                  "required": true
                },
                "linkLabel": {
                  "name": "linkLabel",
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "CaseStudyItemCaseStudies",
          "category": "interaction",
          "linkedEntity": "CaseStudyItem",
          "emits": [
            {
              "event": "CASE_STUDY_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "title",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CASE_STUDY_CLICK",
                "name": "Case Study Click",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "title",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.items"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity.items",
                      "type": "case-study-organism"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CASE_STUDY_CLICK",
                "effects": [
                  [
                    "emit",
                    "CASE_STUDY_CLICK",
                    {
                      "id": "@payload.id",
                      "title": "@payload.title"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "items": {
              "type": "[CaseStudyCard]",
              "default": [
                {
                  "title": "Acme Corp",
                  "id": "1",
                  "categoryColor": "",
                  "href": "#",
                  "linkLabel": "Read story",
                  "category": "SaaS",
                  "description": "How Acme scaled from 1K to 1M users in 6 months."
                },
                {
                  "id": "2",
                  "description": "Globex reduced infrastructure costs by 70%.",
                  "category": "Fintech",
                  "linkLabel": "Read story",
                  "categoryColor": "",
                  "title": "Globex",
                  "href": "#"
                },
                {
                  "href": "#",
                  "id": "3",
                  "title": "Initech",
                  "categoryColor": "",
                  "category": "Healthtech",
                  "description": "Initech shipped their mobile app 3x faster.",
                  "linkLabel": "Read story"
                }
              ],
              "label": "Case Studies",
              "description": "Array of case study cards",
              "tier": "essential",
              "items": {
                "type": "object",
                "properties": {
                  "category": {
                    "name": "category",
                    "type": "string",
                    "required": true
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "categoryColor": {
                    "name": "categoryColor",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CaseStudyItemCaseStudiesPage",
          "path": "/case-studies",
          "traits": [
            {
              "ref": "CaseStudyItemCaseStudies"
            }
          ]
        }
      ]
    }
  ]
}