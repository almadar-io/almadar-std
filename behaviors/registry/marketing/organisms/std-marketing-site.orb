                    },
                    {
                      "label": "Community",
                      "href": "#"
                    },
                    {
                      "label": "Support",
                      "href": "#"
                    }
                  ],
                  "title": "Resources"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  },
                  "title": {
