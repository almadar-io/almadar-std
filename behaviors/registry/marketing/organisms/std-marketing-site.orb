{
  "name": "std-marketing-site",
  "version": "1.1.0",
  "description": "Full marketing site organism with landing, pricing, about, and feature detail pages. Pick for product websites, SaaS frontends, and campaign microsites that need beautiful static pages.",
  "orbitals": [
    {
      "name": "MarketingSiteOrbital",
      "entity": {
        "name": "MarketingSite",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "MarketingSiteNav",
          "category": "interaction",
          "linkedEntity": "MarketingSite",
          "emits": [
            {
              "event": "NAV_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "href",
                  "type": "string"
                },
                {
                  "name": "label",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NAV_CLICK",
                "name": "Nav Click",
                "payloadSchema": [
                  {
                    "name": "href",
                    "type": "string"
                  },
                  {
                    "name": "label",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "logoSrc": "@config.logoSrc",
                      "brandName": "@config.brandName",
                      "type": "header",
                      "navigationItems": "@config.navItems",
                      "actions": [
                        {
                          "variant": "primary",
                          "href": "@config.primaryActionHref",
                          "label": "@config.primaryActionLabel"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "NAV_CLICK",
                "effects": [
                  [
                    "emit",
                    "NAV_CLICK",
                    {
                      "label": "@payload.label",
                      "href": "@payload.href"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "brandName": {
              "type": "string",
              "default": "Almadar",
              "label": "Brand Name",
              "tier": "essential"
            },
            "primaryActionHref": {
              "type": "string",
              "default": "/signup",
              "label": "Primary Action Link",
              "tier": "customization"
            },
            "logoSrc": {
              "type": "string",
              "default": "",
              "label": "Logo Source",
              "tier": "customization"
            },
            "primaryActionLabel": {
              "type": "string",
              "default": "Get Started",
              "label": "Primary Action Label",
              "tier": "customization"
            },
            "navItems": {
              "type": "[NavLink]",
              "default": [
                {
                  "href": "/",
                  "label": "Product"
                },
                {
                  "href": "/pricing",
                  "label": "Pricing"
                },
                {
                  "label": "About",
                  "href": "/about"
                },
                {
                  "label": "Features",
                  "href": "/features"
                }
              ],
              "label": "Navigation Items",
              "tier": "essential",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "instance"
        },
        {
          "name": "MarketingSiteLanding",
          "category": "interaction",
          "linkedEntity": "MarketingSite",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "none",
                      "children": [
                        {
                          "background": "gradient",
                          "align": "center",
                          "subtitle": "@config.heroSubtitle",
                          "type": "hero-section",
                          "title": "@config.heroTitle",
                          "primaryAction": {
                            "href": "@config.heroPrimaryActionHref",
                            "label": "@config.heroPrimaryActionLabel"
                          }
                        },
                        {
                          "items": "@config.features",
                          "type": "feature-grid"
                        },
                        {
                          "type": "stats-grid",
                          "stats": "@config.stats"
                        },
                        {
                          "type": "step-flow-organism",
                          "entity": "@config.steps"
                        },
                        {
                          "type": "showcase-organism",
                          "entity": "@config.showcase"
                        },
                        {
                          "subtitle": "@config.ctaSubtitle",
                          "primaryAction": "@config.ctaPrimaryAction",
                          "type": "cta-banner",
                          "title": "@config.ctaTitle"
                        },
                        {
                          "columns": "@config.footerColumns",
                          "copyright": "@config.footerCopyright",
                          "type": "marketing-footer"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "ctaSubtitle": {
              "type": "string",
              "default": "Join thousands of teams shipping faster."
            },
            "heroPrimaryActionHref": {
              "type": "string",
              "default": "/signup"
            },
            "ctaPrimaryAction": {
              "type": "ActionCard",
              "default": {
                "label": "Get Started",
                "href": "/signup"
              },
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "href": {
                  "name": "href",
                  "type": "string",
                  "required": true
                }
              }
            },
            "footerColumns": {
              "type": "[FooterColumn]",
              "default": [
                {
                  "title": "Product",
                  "items": [
                    {
                      "label": "Features",
                      "href": "#"
                    },
                    {
                      "label": "Pricing",
                      "href": "#"
                    },
                    {
                      "href": "#",
                      "label": "Changelog"
                    }
                  ]
                },
                {
                  "items": [
                    {
                      "label": "About",
                      "href": "#"
                    },
                    {
                      "href": "#",
                      "label": "Careers"
                    },
                    {
                      "label": "Blog",
                      "href": "#"
                    }
                  ],
                  "title": "Company"
                },
                {
                  "title": "Resources",
                  "items": [
                    {
                      "label": "Docs",
                      "href": "#"
                    },
                    {
                      "label": "Community",
                      "href": "#"
                    },
                    {
                      "label": "Support",
                      "href": "#"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "items": {
                    "name": "items",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "href": {
                          "name": "href",
                          "type": "string",
                          "required": true
                        }
                      }
                    }
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "ctaTitle": {
              "type": "string",
              "default": "Ready to get started?"
            },
            "stats": {
              "type": "[StatCard]",
              "default": [
                {
                  "label": "Developers",
                  "value": "10K+"
                },
                {
                  "value": "99.9%",
                  "label": "Uptime"
                },
                {
                  "value": "50M+",
                  "label": "Requests served"
                },
                {
                  "value": "4.9",
                  "label": "Average rating"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "value": {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "heroPrimaryActionLabel": {
              "type": "string",
              "default": "Get Started"
            },
            "heroTitle": {
              "type": "string",
              "default": "Build faster with Almadar"
            },
            "features": {
              "type": "[FeatureCard]",
              "default": [
                {
                  "description": "Build and deploy in minutes.",
                  "href": "",
                  "title": "Lightning Fast",
                  "linkLabel": "Learn more",
                  "icon": "zap"
                },
                {
                  "title": "Enterprise Secure",
                  "description": "SOC-2 compliant with end-to-end encryption.",
                  "href": "",
                  "linkLabel": "Learn more",
                  "icon": "shield"
                },
                {
                  "description": "Plug in any service, any data source, any UI pattern.",
                  "icon": "puzzle",
                  "href": "",
                  "linkLabel": "Learn more",
                  "title": "Infinitely Extensible"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "linkLabel": {
                    "name": "linkLabel",
                    "type": "string",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "steps": {
              "type": "[StepCard]",
              "default": [
                {
                  "icon": "pen-tool",
                  "title": "Design",
                  "description": "Describe your app in natural language.",
                  "number": 1.0,
                  "id": "1"
                },
                {
                  "description": "Almadar generates the full stack automatically.",
                  "id": "2",
                  "number": 2.0,
                  "title": "Build",
                  "icon": "hammer"
                },
                {
                  "icon": "rocket",
                  "id": "3",
                  "description": "Deploy to production with one click.",
                  "number": 3.0,
                  "title": "Ship"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": true
                  },
                  "number": {
                    "name": "number",
                    "type": "number",
                    "required": false
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "showcase": {
              "type": "[ShowcaseCard]",
              "default": [
                {
                  "badge": "New",
                  "accentColor": "",
                  "title": "Dashboard",
                  "id": "dashboard",
                  "description": "Real-time analytics at a glance.",
                  "image": {
                    "alt": "Dashboard",
                    "src": ""
                  },
                  "href": ""
                },
                {
                  "id": "api",
                  "title": "API",
                  "badge": "",
                  "image": {
                    "alt": "API",
                    "src": ""
                  },
                  "href": "",
                  "accentColor": "",
                  "description": "GraphQL and REST in one click."
                },
                {
                  "accentColor": "",
                  "image": {
                    "src": "",
                    "alt": "Mobile"
                  },
                  "badge": "Beta",
                  "description": "Native apps without native code.",
                  "id": "mobile",
                  "title": "Mobile",
                  "href": ""
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "title": {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "image": {
                    "name": "image",
                    "type": "object",
                    "required": false,
                    "properties": {
                      "alt": {
                        "name": "alt",
                        "type": "string",
                        "required": false
                      },
                      "src": {
                        "name": "src",
                        "type": "string",
                        "required": true
                      }
                    }
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": false
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  },
                  "accentColor": {
                    "name": "accentColor",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "footerCopyright": {
              "type": "string",
              "default": "© 2026 Almadar. All rights reserved."
            },
            "heroSubtitle": {
              "type": "string",
              "default": "From idea to production in minutes, not months."
            }
          },
          "scope": "instance"
        },
        {
          "name": "MarketingSitePricing",
          "category": "interaction",
          "linkedEntity": "MarketingSite",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "hero-section",
                          "align": "center",
                          "background": "subtle",
                          "subtitle": "@config.heroSubtitle",
                          "title": "@config.heroTitle"
                        },
                        {
                          "type": "pricing-grid",
                          "plans": "@config.plans"
                        },
                        {
                          "items": "@config.faq",
                          "type": "accordion"
                        },
                        {
                          "primaryAction": "@config.ctaAction",
                          "type": "cta-banner",
                          "title": "@config.ctaTitle",
                          "subtitle": "@config.ctaSubtitle"
                        },
                        {
                          "columns": "@config.footerColumns",
                          "type": "marketing-footer",
                          "copyright": "@config.footerCopyright"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "none"
                    }
                  ]
                ]
              }
            ]
          },
