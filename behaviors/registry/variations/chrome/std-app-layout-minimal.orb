{
  "name": "std-app-layout-minimal",
  "version": "1.0.0",
  "description": "Minimal chrome. Embeds std-app-layout with minimal layout pattern.",
  "orbitals": [
    {
      "name": "MinimalLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppLayout"
        }
      ],
      "entity": {
        "name": "MinimalLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "AppLayout.traits.AppLayout",
          "name": "MinimalLayout",
          "linkedEntity": "MinimalLayoutState",
          "config": {
            "layoutMode": "minimal",
            "appName": "Minimal Demo",
            "navItems": [
              {
                "label": "Home",
                "icon": "home",
                "href": "/"
              },
              {
                "icon": "users",
                "href": "/contacts",
                "label": "Contacts"
              },
              {
                "href": "/tasks",
                "label": "Tasks",
                "icon": "check-square"
              },
              {
                "icon": "settings",
                "label": "Settings",
                "href": "/settings"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "MinimalLayoutPage",
          "path": "/minimal-layout",
          "traits": [
            {
              "ref": "MinimalLayout"
            }
          ]
        }
      ]
    }
  ]
}