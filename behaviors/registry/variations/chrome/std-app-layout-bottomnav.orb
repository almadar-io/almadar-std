{
  "name": "std-app-layout-bottomnav",
  "version": "1.0.0",
  "description": "Bottom-navigation chrome. Embeds std-app-layout with bottomnav layout pattern.",
  "orbitals": [
    {
      "name": "BottomnavLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppLayout"
        }
      ],
      "entity": {
        "name": "BottomnavLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "AppLayout.traits.AppLayout",
          "name": "BottomnavLayout",
          "linkedEntity": "BottomnavLayoutState",
          "config": {
            "layoutMode": "bottomnav",
            "appName": "Bottomnav Demo",
            "navItems": [
              {
                "href": "/",
                "label": "Home",
                "icon": "home"
              },
              {
                "label": "Contacts",
                "icon": "users",
                "href": "/contacts"
              },
              {
                "label": "Tasks",
                "icon": "check-square",
                "href": "/tasks"
              },
              {
                "href": "/settings",
                "label": "Settings",
                "icon": "settings"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "BottomnavLayoutPage",
          "path": "/bottomnav-layout",
          "traits": [
            {
              "ref": "BottomnavLayout"
            }
          ]
        }
      ]
    }
  ]
}
