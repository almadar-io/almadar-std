{
  "name": "std-app-layout-topnav",
  "version": "1.0.0",
  "description": "Top-navigation chrome. Embeds std-app-layout with topnav layout pattern.",
  "orbitals": [
    {
      "name": "TopnavLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppLayout"
        }
      ],
      "entity": {
        "name": "TopnavLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "AppLayout.traits.AppLayout",
          "name": "TopnavLayout",
          "linkedEntity": "TopnavLayoutState",
          "config": {
            "appName": "Topnav Demo",
            "navItems": [
              {
                "icon": "home",
                "href": "/",
                "label": "Home"
              },
              {
                "label": "Contacts",
                "href": "/contacts",
                "icon": "users"
              },
              {
                "label": "Tasks",
                "href": "/tasks",
                "icon": "check-square"
              },
              {
                "label": "Settings",
                "icon": "settings",
                "href": "/settings"
              }
            ],
            "layoutMode": "topnav"
          }
        }
      ],
      "pages": [
        {
          "name": "TopnavLayoutPage",
          "path": "/topnav-layout",
          "traits": [
            {
              "ref": "TopnavLayout"
            }
          ]
        }
      ]
    }
  ]
}
