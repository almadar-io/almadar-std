{
  "name": "std-stats-sparkline",
  "version": "1.1.0",
  "description": "Sparkline stat view. Composes std-stats with metrics that carry `sparklineData` arrays so each stat-display item renders its mini line chart. std-stats already supports per-metric sparkline rendering — the variation supplies the data; the atom does the rest. Distinguishes from std-stats-bignumber by the presence of sparklineData on every metric.",
  "orbitals": [
    {
      "name": "SparklineStatsItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "SparklineStatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false
                },
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "string",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "SparklineStatsItemStats",
          "linkedEntity": "SparklineStatsItem",
          "config": {
            "title": "Trend Summary",
            "metrics": [
              {
                "label": "Active Sessions",
                "icon": "activity",
                "sparklineData": [
                  4.0,
                  7.0,
                  5.0,
                  9.0,
                  12.0,
                  8.0,
                  11.0,
                  14.0,
                  13.0,
                  17.0
                ],
                "aggregation": "count",
                "format": "number",
                "variant": "primary"
              },
              {
                "label": "Conversions",
                "icon": "trending-up",
                "variant": "success",
                "format": "number",
                "sparklineData": [
                  2.0,
                  5.0,
                  4.0,
                  7.0,
                  6.0,
                  9.0,
                  8.0,
                  11.0,
                  13.0,
                  15.0
                ],
                "aggregation": "count"
              },
              {
                "label": "Avg Duration",
                "field": "value",
                "format": "number",
                "variant": "info",
                "aggregation": "avg",
                "icon": "clock",
                "sparklineData": [
                  12.0,
                  14.0,
                  13.0,
                  16.0,
                  18.0,
                  15.0,
                  19.0,
                  17.0,
                  20.0,
                  22.0
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "SparklineStatsPage",
          "path": "/sparkline-stats",
          "traits": [
            {
              "ref": "SparklineStatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}