{
  "name": "std-graphs-area",
  "version": "1.0.0",
  "description": "Area chart view. Embeds std-graphs with area chart pattern override.",
  "orbitals": [
    {
      "name": "AreaGraphItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graph"
        }
      ],
      "entity": {
        "name": "AreaGraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object"
            }
          }
        ]
      },
      "traits": [
        {
          "ref": "Graph.traits.GraphItemGraph",
          "name": "AreaGraphItemGraph",
          "linkedEntity": "AreaGraphItem",
          "config": {
            "viewPattern": "area-chart"
          }
        }
      ],
      "pages": [
        {
          "name": "AreaGraphPage",
          "path": "/area-graph",
          "traits": [
            {
              "ref": "AreaGraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}
