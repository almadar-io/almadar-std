{
  "name": "std-browse-grid",
  "version": "1.0.0",
  "description": "Card grid view for std-browse. Embeds base browse atom with entity-cards pattern override.",
  "orbitals": [
    {
      "name": "GridBrowseItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "GridBrowseItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "GridBrowseItemBrowse",
          "linkedEntity": "GridBrowseItem",
          "config": {
            "viewPattern": "entity-cards"
          }
        }
      ],
      "pages": [
        {
          "name": "GridBrowsePage",
          "path": "/grid-browse",
          "traits": [
            {
              "ref": "GridBrowseItemBrowse"
            }
          ]
        }
      ]
    }
  ]
}