{
  "name": "std-browse-timeline",
  "version": "1.0.0",
  "description": "Timeline view for std-browse. Embeds base browse atom with timeline pattern override.",
  "orbitals": [
    {
      "name": "TimelineBrowseItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "TimelineBrowseItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "TimelineBrowseItemBrowse",
          "linkedEntity": "TimelineBrowseItem",
          "config": {
            "viewPattern": "timeline"
          }
        }
      ],
      "pages": [
        {
          "name": "TimelineBrowsePage",
          "path": "/timeline-browse",
          "traits": [
            {
              "ref": "TimelineBrowseItemBrowse"
            }
          ]
        }
      ]
    }
  ]
}