{
  "name": "std-stats-bignumber",
  "version": "1.0.0",
  "description": "Big-number stat view. Embeds std-stats with big-number pattern override.",
  "orbitals": [
    {
      "name": "BigNumberStatsItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "BigNumberStatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                },
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "string",
                  "required": false
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "BigNumberStatsItemStats",
          "linkedEntity": "BigNumberStatsItem",
          "config": {
            "viewPattern": "data-grid"
          }
        }
      ],
      "pages": [
        {
          "name": "BigNumberStatsPage",
          "path": "/bignumber-stats",
          "traits": [
            {
              "ref": "BigNumberStatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}