{
  "description": "Bar chart view. Embeds std-graphs with the bar chartType — vertical bars, one per category bucket. Default for distribution-of-categories visualisations.",
  "name": "std-graphs-bar",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "Data points used to render the chart.",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "chartData",
            "synonyms": "data, values, series",
            "type": "array"
          }
        ],
        "name": "BarGraphItem",
        "persistence": "runtime"
      },
      "name": "BarGraphItemOrbital",
      "pages": [
        {
          "name": "BarGraphPage",
          "path": "/bar-graph",
          "traits": [
            {
              "ref": "BarGraphItemGraph"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "chartType": {
              "default": "bar",
              "type": "unknown"
            }
          },
          "linkedEntity": "BarGraphItem",
          "name": "BarGraphItemGraph",
          "ref": "Graph.traits.GraphItemGraph"
        }
      ],
      "uses": [
        {
          "as": "Graph",
          "from": "std/behaviors/std-graphs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}