{
  "name": "std-stats-sparkline-row",
  "version": "1.2.0",
  "description": "Sparkline tile grid — chart-first card tiles where the mini trend line is the visual centerpiece, with label above and value+delta footer. For trend-led overviews: telemetry, weekly active users, traffic shape, observability at a glance.",
  "orbitals": [
    {
      "name": "SparklineRowStatsOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "SparklineRowStats",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false,
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false,
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false,
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": false
                }
              }
            },
            "description": "An array of statistical cards displayed in a row.",
            "synonyms": "tiles, items, elements"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "SparklineRowStatsItemStats",
          "linkedEntity": "SparklineRowStats",
          "config": {
            "metrics": [
              {
                "label": "Weekly Active Users",
                "trend": 9.3,
                "sparklineData": [
                  12000.0,
                  12800.0,
                  13500.0,
                  13200.0,
                  14600.0,
                  15400.0,
                  15100.0,
                  16200.0,
                  16900.0,
                  17400.0,
                  17900.0,
                  18420.0
                ],
                "format": "number",
                "trendFormat": "percent",
                "value": 18420.0,
                "trendPolarity": "higher-is-better",
                "variant": "primary",
                "icon": "users"
              },
              {
                "label": "Requests / min",
                "variant": "info",
                "trendFormat": "percent",
                "icon": "activity",
                "trend": -4.1,
                "value": 2340.0,
                "sparklineData": [
                  2600.0,
                  2520.0,
                  2580.0,
                  2490.0,
                  2410.0,
                  2450.0,
                  2380.0,
                  2360.0,
                  2410.0,
                  2350.0,
                  2330.0,
                  2340.0
                ],
                "trendPolarity": "higher-is-better",
                "format": "number"
              },
              {
                "format": "number",
                "trendPolarity": "lower-is-better",
                "suffix": "ms",
                "trend": -12.0,
                "value": 184.0,
                "variant": "warning",
                "icon": "gauge",
                "sparklineData": [
                  240.0,
                  232.0,
                  228.0,
                  235.0,
                  210.0,
                  205.0,
                  198.0,
                  201.0,
                  190.0,
                  188.0,
                  186.0,
                  184.0
                ],
                "label": "p95 Latency",
                "trendFormat": "percent"
              },
              {
                "sparklineData": [
                  0.9,
                  0.82,
                  0.78,
                  0.7,
                  0.66,
                  0.61,
                  0.55,
                  0.52,
                  0.48,
                  0.45,
                  0.43,
                  0.42
                ],
                "label": "Error Rate",
                "variant": "error",
                "format": "percent",
                "trend": -0.18,
                "icon": "alert-circle",
                "suffix": "%",
                "trendFormat": "absolute",
                "trendPolarity": "lower-is-better",
                "value": 0.42
              }
            ],
            "bodyContent": {
              "fields": [],
              "className": "w-full",
              "entity": "@entity.cards",
              "gap": "md",
              "renderItem": [
                "fn",
                "card",
                {
                  "gap": "sm",
                  "direction": "vertical",
                  "type": "stack",
                  "className": "rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-card-md shadow-elevation-sm hover:shadow-elevation-md transition-shadow min-h-[180px]",
                  "children": [
                    {
                      "children": [
                        {
                          "color": "muted",
                          "type": "icon",
                          "name": "@card.icon",
                          "size": "xs"
                        },
                        {
                          "content": "@card.label",
                          "className": "uppercase tracking-wide truncate",
                          "type": "typography",
                          "weight": "semibold",
                          "color": "muted",
                          "variant": "overline"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "xs",
                      "direction": "horizontal"
                    },
                    {
                      "height": 64.0,
                      "strokeWidth": 2.0,
                      "type": "sparkline",
                      "className": "w-full",
                      "color": "auto",
                      "data": "@card.sparklineData",
                      "fill": true
                    },
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "align": "baseline",
                          "direction": "horizontal",
                          "gap": "xs",
                          "type": "stack",
                          "children": [
                            {
                              "content": "@card.prefix",
                              "type": "typography",
                              "color": "muted",
                              "variant": "caption"
                            },
                            {
                              "content": "@card.value",
                              "variant": "h3",
                              "type": "typography",
                              "weight": "semibold",
                              "className": "tabular-nums"
                            },
                            {
                              "variant": "caption",
                              "content": "@card.suffix",
                              "type": "typography",
                              "color": "muted"
                            }
                          ]
                        },
                        {
                          "size": "sm",
                          "value": "@card.trend",
                          "showValue": true,
                          "type": "trend-indicator"
                        }
                      ],
                      "align": "baseline",
                      "justify": "between",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                }
              ],
              "minCardWidth": 260.0,
              "type": "data-grid"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "SparklineRowStatsPage",
          "path": "/sparkline-row",
          "traits": [
            {
              "ref": "SparklineRowStatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
