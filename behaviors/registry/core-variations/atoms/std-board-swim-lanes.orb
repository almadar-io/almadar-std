{
  "name": "std-board-swim-lanes",
  "version": "1.0.2",
  "description": "Swim-lane board — full-width horizontal lanes per status, cards flow left-to-right within each lane. Lane header on top with icon + label + count; cards render in the lane body. Useful for HR-portal recruiting stages and project-manager team boards. Same BoardItemBoard trait, same state machine, same emits/listens as std-board — only the bodyContent tree differs.",
  "orbitals": [
    {
      "name": "SwimLanesBoardOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-board",
          "as": "Board"
        }
      ],
      "entity": {
        "name": "SwimLaneItem",
        "collection": "swim_lane_items",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true,
            "description": "The text displayed as the lane's header.",
            "synonyms": "label, heading, name"
          },
          {
            "name": "description",
            "type": "string",
            "default": "",
            "description": "A brief explanation or summary of the item.",
            "synonyms": "summary, details, explanation, notes"
          },
          {
            "name": "stage",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "doing",
              "done"
            ],
            "description": "The current status or phase of the item.",
            "synonyms": "status, phase, state, step"
          },
          {
            "name": "notes",
            "type": "string",
            "default": "",
            "description": "Free-form text providing additional information or context.",
            "synonyms": "comments, remarks, details, information"
          },
          {
            "name": "position",
            "type": "number",
            "default": 0.0,
            "description": "The sequential order of this item within its parent.",
            "synonyms": "order, sequence, index, rank"
          },
          {
            "name": "boards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object"
            },
            "description": "A collection of related board items.",
            "synonyms": "items, records, entries"
          },
          {
            "name": "currentId",
            "type": "string",
            "default": "",
            "description": "The unique identifier for this item.",
            "synonyms": "identifier, key, ref"
          },
          {
            "name": "currentTitle",
            "type": "string",
            "default": "",
            "description": "The displayed title for the current item.",
            "synonyms": "label, heading, name"
          },
          {
            "name": "currentDescription",
            "type": "string",
            "default": "",
            "description": "The current textual description associated with the item.",
            "synonyms": "text, details, content, notes"
          },
          {
            "name": "currentStage",
            "type": "string",
            "default": "",
            "description": "The current status or phase of an item.",
            "synonyms": "status, phase, step, stage"
          },
          {
            "name": "currentNotes",
            "type": "string",
            "default": "",
            "description": "The textual notes associated with the current item.",
            "synonyms": "comments, remarks, annotations, details"
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": "",
            "description": "Error message associated with the item.",
            "synonyms": "error, alert, message"
          }
        ]
      },
      "traits": [
        {
          "ref": "Board.traits.BoardItemBoard",
          "name": "SwimLanesBoard",
          "linkedEntity": "SwimLaneItem",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "gap": "md",
              "type": "stack",
              "children": [
                {
                  "direction": "horizontal",
                  "type": "stack",
                  "align": "center",
                  "gap": "sm",
                  "children": [
                    {
                      "name": "layout-rows",
                      "type": "icon"
                    },
                    {
                      "type": "typography",
                      "variant": "h2",
                      "content": "@config.title"
                    }
                  ],
                  "className": "px-card-md"
                },
                {
                  "type": "divider"
                },
                {
                  "renderItem": [
                    "fn",
                    "col",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "align": "center",
                              "gap": "sm",
                              "className": "p-card-md border-b border-[var(--color-border)] bg-[var(--color-surface-subtle)]",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "@col.icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "@col.label",
                                  "variant": "h4",
                                  "className": "flex-1"
                                },
                                {
                                  "type": "badge",
                                  "size": "sm",
                                  "variant": "primary",
                                  "label": "@col.count"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "entity": "@col.items",
                              "dropEvent": "MOVE_CARD",
                              "reorderEvent": "REORDER_CARD",
                              "className": "p-card-md min-h-[140px] flex flex-row flex-nowrap gap-3 overflow-x-auto",
                              "dragGroup": "@col.key",
                              "type": "data-list",
                              "sortable": true,
                              "fields": [],
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "padding": "sm",
                                  "className": "min-w-[220px] max-w-[260px] rounded-md cursor-grab shadow-sm hover:shadow-md transition-shadow",
                                  "type": "card",
                                  "look": "elevated",
                                  "children": [
                                    {
                                      "direction": "vertical",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "weight": "medium",
                                          "content": "@config.cardTitleBinding",
                                          "variant": "body"
                                        },
                                        {
                                          "variant": "caption",
                                          "type": "typography",
                                          "content": "@config.cardDescriptionBinding",
                                          "className": "line-clamp-2",
                                          "color": "muted"
                                        },
                                        {
                                          "type": "stack",
                                          "direction": "horizontal",
                                          "align": "center",
                                          "className": "pt-1",
                                          "gap": "xs",
                                          "children": [
                                            {
                                              "label": "@config.cardStageBinding",
                                              "size": "sm",
                                              "variant": "primary",
                                              "type": "badge"
                                            },
                                            {
                                              "size": "sm",
                                              "className": "ml-auto",
                                              "icon": "arrow-right",
                                              "label": "Open",
                                              "variant": "ghost",
                                              "type": "button",
                                              "action": "OPEN_CARD",
                                              "actionPayload": {
                                                "id": "@config.cardIdBinding",
                                                "row": "@item"
                                              }
                                            }
                                          ]
                                        }
                                      ],
                                      "gap": "xs",
                                      "type": "stack"
                                    }
                                  ]
                                }
                              ],
                              "gap": "sm",
                              "accepts": "*",
                              "positionEvent": "REORDER_POSITION"
                            }
                          ],
                          "gap": "none"
                        }
                      ],
                      "className": "overflow-hidden rounded-lg",
                      "type": "card",
                      "look": "flat-bordered",
                      "padding": "none"
                    }
                  ],
                  "gap": "md",
                  "fields": [],
                  "dndRoot": true,
                  "type": "data-list",
                  "entity": "@entity.boards"
                },
                {
                  "action": "ADD_CARD",
                  "type": "floating-action-button",
                  "label": "Add card",
                  "icon": "plus",
                  "variant": "primary"
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "SwimLanesPage",
          "path": "/swim-lanes",
          "traits": [
            {
              "ref": "SwimLanesBoard"
            }
          ]
        }
      ]
    }
  ]
}
