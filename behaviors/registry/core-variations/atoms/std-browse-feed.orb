{
  "name": "std-browse-feed",
  "version": "1.0.1",
  "description": "Activity feed — chronological card-per-item stream with avatar, title, meta, body, timestamp; hover-lift, gap-md rhythm.",
  "orbitals": [
    {
      "name": "FeedBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "FeedPost",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "published",
            "values": [
              "published",
              "draft",
              "hidden"
            ]
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "FeedBrowse",
          "linkedEntity": "FeedPost",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "type": "stack",
                  "className": "rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                  "children": [
                    {
                      "name": "search",
                      "type": "icon"
                    },
                    {
                      "placeholder": "Filter the feed…",
                      "type": "input",
                      "className": "flex-1",
                      "inputType": "search",
                      "action": "REFETCH_QUERY"
                    }
                  ],
                  "gap": "sm",
                  "direction": "horizontal",
                  "align": "center"
                },
                {
                  "entity": "@payload.data",
                  "fields": [],
                  "type": "data-list",
                  "variant": "card",
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "look": "flat-bordered",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "start",
                          "children": [
                            {
                              "fallback": "@item.name",
                              "size": "md",
                              "className": "rounded-full flex-shrink-0",
                              "type": "avatar"
                            },
                            {
                              "gap": "xs",
                              "className": "flex-1 min-w-0",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "className": "flex-wrap",
                                  "gap": "xs",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "body",
                                      "content": "@item.name",
                                      "weight": "medium",
                                      "type": "typography",
                                      "className": "truncate"
                                    },
                                    {
                                      "variant": "neutral",
                                      "label": "@item.category",
                                      "size": "sm",
                                      "type": "badge"
                                    }
                                  ]
                                },
                                {
                                  "className": "text-[var(--color-foreground)] whitespace-pre-wrap break-words leading-relaxed",
                                  "variant": "body",
                                  "content": "@item.description",
                                  "type": "typography"
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "justify": "between",
                                  "className": "pt-1",
                                  "children": [
                                    {
                                      "variant": "caption",
                                      "type": "typography",
                                      "color": "muted",
                                      "content": "@item.createdAt"
                                    },
                                    {
                                      "variant": "default",
                                      "type": "badge",
                                      "label": "@item.status",
                                      "size": "sm"
                                    }
                                  ],
                                  "gap": "sm",
                                  "align": "center"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "className": "p-card-md"
                        }
                      ],
                      "className": "rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] shadow-sm transition-all duration-normal hover:shadow-main hover:border-[var(--color-border-strong)] hover:-translate-y-px",
                      "type": "card"
                    }
                  ],
                  "gap": "md"
                }
              ],
              "type": "stack",
              "className": "max-w-2xl mx-auto p-card-md",
              "direction": "vertical",
              "gap": "lg"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "FeedPage",
          "path": "/feed",
          "traits": [
            {
              "ref": "FeedBrowse"
            }
          ]
        }
      ]
    }
  ]
}