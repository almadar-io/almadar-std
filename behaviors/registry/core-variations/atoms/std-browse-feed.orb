{
  "description": "Activity feed — chronological card-per-item stream with avatar, title, meta, body, timestamp; hover-lift, gap-md rhythm.",
  "name": "std-browse-feed",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The title or short designation of the item.",
            "name": "name",
            "required": true,
            "synonyms": "title, label, heading",
            "type": "string"
          },
          {
            "description": "A brief summary or explanation of the post's content.",
            "name": "description",
            "synonyms": "summary, text, content, details",
            "type": "string"
          },
          {
            "default": "published",
            "description": "Indicates the current visibility state of the item.",
            "name": "status",
            "synonyms": "visibility, state, condition",
            "type": "string",
            "values": [
              "published",
              "draft",
              "hidden"
            ]
          },
          {
            "description": "The classification or type of the feed item.",
            "name": "category",
            "synonyms": "type, topic, group, section",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ],
        "name": "FeedPost",
        "persistence": "runtime"
      },
      "name": "FeedBrowseOrbital",
      "pages": [
        {
          "name": "FeedPage",
          "path": "/feed",
          "traits": [
            {
              "ref": "FeedBrowse"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      {
                        "name": "search",
                        "type": "icon"
                      },
                      {
                        "action": "REFETCH_QUERY",
                        "className": "flex-1",
                        "inputType": "search",
                        "placeholder": "@config.searchPlaceholder",
                        "type": "input"
                      }
                    ],
                    "className": "rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                    "direction": "horizontal",
                    "gap": "sm",
                    "type": "stack"
                  },
                  {
                    "entity": "@payload.data",
                    "fields": [],
                    "gap": "md",
                    "renderItem": [
                      "fn",
                      "item",
                      {
                        "children": [
                          {
                            "align": "start",
                            "children": [
                              {
                                "className": "rounded-full flex-shrink-0",
                                "fallback": "@config.titleBinding",
                                "size": "md",
                                "type": "avatar"
                              },
                              {
                                "children": [
                                  {
                                    "align": "center",
                                    "children": [
                                      {
                                        "className": "truncate",
                                        "content": "@config.titleBinding",
                                        "type": "typography",
                                        "variant": "body",
                                        "weight": "medium"
                                      },
                                      {
                                        "label": "@config.categoryBinding",
                                        "size": "sm",
                                        "type": "badge",
                                        "variant": "neutral"
                                      }
                                    ],
                                    "className": "flex-wrap",
                                    "direction": "horizontal",
                                    "gap": "xs",
                                    "type": "stack"
                                  },
                                  {
                                    "className": "text-[var(--color-foreground)] whitespace-pre-wrap break-words leading-relaxed",
                                    "content": "@config.descriptionBinding",
                                    "type": "typography",
                                    "variant": "body"
                                  },
                                  {
                                    "align": "center",
                                    "children": [
                                      {
                                        "color": "muted",
                                        "content": "@config.metaBinding",
                                        "type": "typography",
                                        "variant": "caption"
                                      },
                                      {
                                        "label": "@config.badgeBinding",
                                        "size": "sm",
                                        "type": "badge",
                                        "variant": "default"
                                      }
                                    ],
                                    "className": "pt-1",
                                    "direction": "horizontal",
                                    "gap": "sm",
                                    "justify": "between",
                                    "type": "stack"
                                  }
                                ],
                                "className": "flex-1 min-w-0",
                                "direction": "vertical",
                                "gap": "xs",
                                "type": "stack"
                              }
                            ],
                            "className": "p-card-md",
                            "direction": "horizontal",
                            "gap": "md",
                            "type": "stack"
                          }
                        ],
                        "className": "rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] shadow-sm transition-all duration-normal hover:shadow-main hover:border-[var(--color-border-strong)] hover:-translate-y-px",
                        "look": "flat-bordered",
                        "type": "card"
                      }
                    ],
                    "type": "data-list",
                    "variant": "card"
                  }
                ],
                "className": "w-full p-card-md",
                "direction": "vertical",
                "gap": "lg",
                "type": "stack"
              },
              "type": "unknown"
            }
          },
          "linkedEntity": "FeedPost",
          "name": "FeedBrowse",
          "ref": "Browse.traits.BrowseItemBrowse"
        }
      ],
      "uses": [
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        }
      ]
    }
  ],
  "version": "1.0.1"
}