{
  "description": "Scatter plot view. Embeds std-graphs with scatter plot pattern override.",
  "name": "std-graphs-scatter",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "Data points used to generate the scatter plot.",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "chartData",
            "synonyms": "data, values, points",
            "type": "array"
          }
        ],
        "name": "ScatterGraphItem",
        "persistence": "runtime"
      },
      "name": "ScatterGraphItemOrbital",
      "pages": [
        {
          "name": "ScatterGraphPage",
          "path": "/scatter-graph",
          "traits": [
            {
              "ref": "ScatterGraphItemGraph"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "chartType": {
              "default": "scatter",
              "type": "unknown"
            }
          },
          "linkedEntity": "ScatterGraphItem",
          "name": "ScatterGraphItemGraph",
          "ref": "Graph.traits.GraphItemGraph"
        }
      ],
      "uses": [
        {
          "as": "Graph",
          "from": "std/behaviors/std-graphs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}