{
  "description": "Sidebar-rail tabs — vertical nav rail on the left listing tab items as a Stack with the active one highlighted; the matching @trait.X content trait renders to the right. Ideal for app-shell side nav, settings pages with many sections, and profile pages. Same TabsItemTabs trait, state machine, emits/listens as std-tabs — only the bodyContent tree differs.",
  "name": "std-tabs-sidebar-rail",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "Identifies the currently selected tab.",
            "name": "activeTab",
            "synonyms": "selected, current, highlighted",
            "type": "string"
          },
          {
            "default": [],
            "description": "A collection of tab specifications.",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "items",
            "synonyms": "tabs, list, entries, data",
            "type": "array"
          }
        ],
        "name": "SidebarRailTabsItem",
        "persistence": "runtime"
      },
      "name": "SidebarRailTabsOrbital",
      "pages": [
        {
          "name": "SidebarRailTabsPage",
          "path": "/sidebar-tabs",
          "traits": [
            {
              "ref": "SidebarRailTabs"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "align": "stretch",
                "children": [
                  {
                    "align": "stretch",
                    "children": [
                      {
                        "activeTab": "@entity.activeTab",
                        "className": "px-2 gap-1",
                        "items": [
                          {
                            "icon": "home",
                            "id": "tab1",
                            "label": "Tab 1"
                          },
                          {
                            "icon": "settings",
                            "id": "tab2",
                            "label": "Tab 2"
                          },
                          {
                            "icon": "user",
                            "id": "tab3",
                            "label": "Tab 3"
                          }
                        ],
                        "orientation": "vertical",
                        "tabChangeEvent": "TAB_CHANGED",
                        "type": "tabs",
                        "variant": "pills"
                      }
                    ],
                    "className": "w-56 shrink-0 border-r bg-muted/30 py-3",
                    "direction": "vertical",
                    "gap": "none",
                    "type": "stack"
                  },
                  {
                    "children": [],
                    "className": "flex-1 min-w-0 p-card-md",
                    "direction": "vertical",
                    "gap": "md",
                    "type": "stack"
                  }
                ],
                "className": "min-h-[24rem] border rounded-md overflow-hidden",
                "direction": "horizontal",
                "gap": "none",
                "type": "stack"
              },
              "type": "unknown"
            }
          },
          "linkedEntity": "SidebarRailTabsItem",
          "name": "SidebarRailTabs",
          "ref": "Tabs.traits.TabsItemTabs"
        }
      ],
      "uses": [
        {
          "as": "Tabs",
          "from": "std/behaviors/std-tabs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}