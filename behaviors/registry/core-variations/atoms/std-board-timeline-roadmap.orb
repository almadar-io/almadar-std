{
  "description": "Timeline / roadmap board — horizontal time axis with quarters or months as columns; items render as cards inside their target column (item.stage = column.key). Mirrors the Linear / Asana / Productboard roadmap UX. Configure `columns` as ['Q1', 'Q2', 'Q3', 'Q4'] (or months) and the board lays them out left-to-right along a time axis. Same BoardItemBoard trait, same state machine, same emits/listens as std-board — only the bodyContent tree differs.",
  "name": "std-board-timeline-roadmap",
  "orbitals": [
    {
      "entity": {
        "collection": "timeline_roadmap_items",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The item's displayed name or heading.",
            "name": "title",
            "required": true,
            "synonyms": "name, heading, label",
            "type": "string"
          },
          {
            "default": "",
            "description": "A textual explanation or summary of the item.",
            "name": "description",
            "synonyms": "details, summary, explanation, notes",
            "type": "string"
          },
          {
            "default": "Q1",
            "description": "The item's position within the timeline's time divisions.",
            "name": "stage",
            "synonyms": "period, timeframe, phase, quarter, month",
            "type": "string",
            "values": [
              "Q1",
              "Q2",
              "Q3",
              "Q4"
            ]
          },
          {
            "default": "",
            "description": "Free-form text providing additional information.",
            "name": "notes",
            "synonyms": "comments, remarks, details, annotations",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "Numerical order within the timeline.",
            "name": "position",
            "synonyms": "order, sequence, index",
            "type": "number"
          },
          {
            "default": [],
            "intrinsic": true,
            "items": {
              "type": "object"
            },
            "name": "boards",
            "type": "array"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "currentId",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "currentTitle",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "currentDescription",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "currentStage",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "currentNotes",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "errorMessage",
            "type": "string"
          }
        ],
        "name": "TimelineRoadmapItem",
        "persistence": "persistent"
      },
      "name": "TimelineRoadmapBoardOrbital",
      "pages": [
        {
          "name": "TimelineRoadmapPage",
          "path": "/timeline-roadmap",
          "traits": [
            {
              "ref": "TimelineRoadmapBoard"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      {
                        "name": "calendar-range",
                        "type": "icon"
                      },
                      {
                        "content": "@config.title",
                        "type": "typography",
                        "variant": "h2"
                      },
                      {
                        "className": "ml-2",
                        "color": "muted",
                        "content": "Roadmap",
                        "type": "typography",
                        "variant": "caption"
                      }
                    ],
                    "className": "px-card-md",
                    "direction": "horizontal",
                    "gap": "sm",
                    "type": "stack"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "align": "stretch",
                    "children": [
                      {
                        "className": "min-w-full",
                        "cols": "@config.gridCols",
                        "dndRoot": true,
                        "entity": "@entity.boards",
                        "fields": [],
                        "gap": "none",
                        "renderItem": [
                          "fn",
                          "col",
                          {
                            "children": [
                              {
                                "align": "center",
                                "children": [
                                  {
                                    "name": "@col.icon",
                                    "type": "icon"
                                  },
                                  {
                                    "className": "flex-1",
                                    "content": "@col.label",
                                    "type": "typography",
                                    "variant": "h4"
                                  },
                                  {
                                    "label": "@col.count",
                                    "size": "sm",
                                    "type": "badge",
                                    "variant": "primary"
                                  }
                                ],
                                "className": "px-card-md py-2 bg-[var(--color-surface-subtle)] border-b border-[var(--color-border)] sticky top-0",
                                "direction": "horizontal",
                                "gap": "xs",
                                "type": "stack"
                              },
                              {
                                "accepts": "*",
                                "className": "p-card-md min-h-[160px]",
                                "dragGroup": "@col.key",
                                "dropEvent": "MOVE_CARD",
                                "entity": "@col.items",
                                "fields": [],
                                "gap": "sm",
                                "positionEvent": "REORDER_POSITION",
                                "renderItem": [
                                  "fn",
                                  "item",
                                  {
                                    "children": [
                                      {
                                        "children": [
                                          {
                                            "align": "center",
                                            "children": [
                                              {
                                                "name": "flag",
                                                "type": "icon"
                                              },
                                              {
                                                "className": "flex-1",
                                                "content": "@config.cardTitleBinding",
                                                "type": "typography",
                                                "variant": "body",
                                                "weight": "medium"
                                              }
                                            ],
                                            "direction": "horizontal",
                                            "gap": "xs",
                                            "type": "stack"
                                          },
                                          {
                                            "className": "line-clamp-2",
                                            "color": "muted",
                                            "content": "@config.cardDescriptionBinding",
                                            "type": "typography",
                                            "variant": "caption"
                                          },
                                          {
                                            "align": "center",
                                            "children": [
                                              {
                                                "label": "@config.cardStageBinding",
                                                "size": "sm",
                                                "type": "badge",
                                                "variant": "primary"
                                              },
                                              {
                                                "action": "OPEN_CARD",
                                                "actionPayload": {
                                                  "id": "@config.cardIdBinding",
                                                  "row": "@item"
                                                },
                                                "className": "ml-auto",
                                                "icon": "arrow-right",
                                                "label": "Details",
                                                "size": "sm",
                                                "type": "button",
                                                "variant": "ghost"
                                              }
                                            ],
                                            "className": "pt-1",
                                            "direction": "horizontal",
                                            "gap": "xs",
                                            "type": "stack"
                                          }
                                        ],
                                        "direction": "vertical",
                                        "gap": "xs",
                                        "type": "stack"
                                      }
                                    ],
                                    "className": "cursor-grab hover:shadow-md transition-shadow",
                                    "look": "elevated",
                                    "padding": "sm",
                                    "type": "card"
                                  }
                                ],
                                "reorderEvent": "REORDER_CARD",
                                "sortable": true,
                                "type": "data-list"
                              }
                            ],
                            "className": "min-w-[240px] border-r border-[var(--color-border)] last:border-r-0",
                            "direction": "vertical",
                            "gap": "none",
                            "type": "stack"
                          }
                        ],
                        "type": "data-grid"
                      }
                    ],
                    "className": "overflow-x-auto border-y border-[var(--color-border)]",
                    "direction": "horizontal",
                    "gap": "none",
                    "type": "stack"
                  },
                  {
                    "action": "ADD_CARD",
                    "icon": "plus",
                    "label": "Add milestone",
                    "type": "floating-action-button",
                    "variant": "primary"
                  }
                ],
                "direction": "vertical",
                "gap": "md",
                "type": "stack"
              },
              "type": "unknown"
            },
            "columns": {
              "default": [
                {
                  "icon": "calendar",
                  "key": "Q1",
                  "label": "Q1",
                  "variant": "default"
                },
                {
                  "icon": "calendar",
                  "key": "Q2",
                  "label": "Q2",
                  "variant": "primary"
                },
                {
                  "icon": "calendar",
                  "key": "Q3",
                  "label": "Q3",
                  "variant": "info"
                },
                {
                  "icon": "calendar",
                  "key": "Q4",
                  "label": "Q4",
                  "variant": "success"
                }
              ],
              "type": "unknown"
            },
            "gridCols": {
              "default": 4.0,
              "type": "unknown"
            }
          },
          "linkedEntity": "TimelineRoadmapItem",
          "name": "TimelineRoadmapBoard",
          "ref": "Board.traits.BoardItemBoard"
        }
      ],
      "uses": [
        {
          "as": "Board",
          "from": "std/behaviors/std-board"
        }
      ]
    }
  ],
  "version": "1.1.0"
}