{
  "description": "Nested threaded comments — Disqus/Hacker News style: indented reply tree, inline reply composer on every comment card, and a visible replies group per parent. For forum discussions, blog comments, document review threads, project-manager issue comments.",
  "name": "std-thread-comments-linear",
  "orbitals": [
    {
      "entity": {
        "collection": "commentslinearposts",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Identifier of the comment this comment replies to.",
            "name": "parentId",
            "synonyms": "parent, replyTo, source",
            "type": "string"
          },
          {
            "description": "Identifier of the top-level comment in the thread.",
            "name": "threadRootId",
            "required": true,
            "synonyms": "rootId, topLevelId, originId",
            "type": "string"
          },
          {
            "description": "Unique identifier for the comment's author.",
            "name": "authorId",
            "required": true,
            "synonyms": "user identifier, author reference, contributor ID",
            "type": "string"
          },
          {
            "description": "The name of the comment's author.",
            "name": "authorName",
            "required": true,
            "synonyms": "author, user, contributor",
            "type": "string"
          },
          {
            "description": "The text of the comment or post.",
            "name": "content",
            "required": true,
            "synonyms": "text, body, message, postContent",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of votes or ratings associated with the comment.",
            "name": "voteCount",
            "synonyms": "rating, score, likes, upvotes",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The number of replies to this comment.",
            "name": "replyCount",
            "synonyms": "child comments, responses, sub-comments",
            "type": "number"
          },
          {
            "description": "A list of child comments in the thread.",
            "name": "replies",
            "relation": {
              "cardinality": "many",
              "entity": "CommentsLinearPost"
            },
            "synonyms": "replies, children, descendants",
            "type": "relation"
          },
          {
            "default": {},
            "description": "The currently selected comment within the comment thread.",
            "name": "focusedRow",
            "synonyms": "selected, active, highlighted",
            "type": "object"
          }
        ],
        "name": "CommentsLinearPost",
        "persistence": "persistent"
      },
      "name": "CommentsLinearOrbital",
      "pages": [
        {
          "name": "CommentsLinearPage",
          "path": "/comments-thread",
          "traits": [
            {
              "ref": "CommentsLinear"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      {
                        "name": "message-square",
                        "size": "md",
                        "type": "icon"
                      },
                      {
                        "content": "@config.sectionTitle",
                        "type": "typography",
                        "variant": "h3"
                      }
                    ],
                    "direction": "horizontal",
                    "gap": "sm",
                    "type": "stack"
                  },
                  {
                    "children": {
                      "children": [
                        {
                          "content": "Add a comment",
                          "type": "typography",
                          "variant": "label"
                        },
                        {
                          "action": "EDIT_REPLY",
                          "inputType": "textarea",
                          "placeholder": "Share your thoughts…",
                          "rows": 3.0,
                          "type": "input"
                        },
                        {
                          "children": [
                            {
                              "action": "CANCEL_REPLY",
                              "label": "Cancel",
                              "size": "sm",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "action": "SUBMIT_REPLY",
                              "icon": "send",
                              "label": "Comment",
                              "size": "sm",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    },
                    "look": "flat-bordered",
                    "padding": "md",
                    "type": "card"
                  },
                  {
                    "nodes": "@payload.data",
                    "replyEvent": "REPLY",
                    "showActions": true,
                    "type": "reply-tree"
                  }
                ],
                "className": "w-full px-card-md py-section",
                "direction": "vertical",
                "gap": "lg",
                "type": "stack"
              },
              "type": "unknown"
            }
          },
          "linkedEntity": "CommentsLinearPost",
          "name": "CommentsLinear",
          "ref": "Thread.traits.ThreadPostBrowse"
        }
      ],
      "uses": [
        {
          "as": "Thread",
          "from": "std/behaviors/std-thread"
        }
      ]
    }
  ],
  "version": "1.2.0"
}