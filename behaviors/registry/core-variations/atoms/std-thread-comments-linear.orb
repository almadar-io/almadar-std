{
  "name": "std-thread-comments-linear",
  "version": "1.2.0",
  "description": "Nested threaded comments — Disqus/Hacker News style: indented reply tree, inline reply composer on every comment card, and a visible replies group per parent. For forum discussions, blog comments, document review threads, project-manager issue comments.",
  "orbitals": [
    {
      "name": "CommentsLinearOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "CommentsLinearPost",
        "collection": "commentslinearposts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replies",
            "type": "relation",
            "relation": {
              "entity": "CommentsLinearPost",
              "cardinality": "many"
            }
          },
          {
            "name": "focusedRow",
            "type": "object",
            "default": {}
          }
        ]
      },
      "traits": [
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "CommentsLinear",
          "linkedEntity": "CommentsLinearPost",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "children": [
                {
                  "children": [
                    {
                      "name": "message-square",
                      "type": "icon",
                      "size": "md"
                    },
                    {
                      "type": "typography",
                      "content": "Discussion",
                      "variant": "h3"
                    }
                  ],
                  "gap": "sm",
                  "direction": "horizontal",
                  "type": "stack",
                  "align": "center"
                },
                {
                  "look": "flat-bordered",
                  "children": {
                    "direction": "vertical",
                    "gap": "sm",
                    "type": "stack",
                    "children": [
                      {
                        "type": "typography",
                        "variant": "label",
                        "content": "Add a comment"
                      },
                      {
                        "inputType": "textarea",
                        "action": "EDIT_REPLY",
                        "rows": 3.0,
                        "type": "input",
                        "placeholder": "Share your thoughts…"
                      },
                      {
                        "direction": "horizontal",
                        "gap": "sm",
                        "children": [
                          {
                            "size": "sm",
                            "type": "button",
                            "action": "CANCEL_REPLY",
                            "label": "Cancel",
                            "variant": "ghost"
                          },
                          {
                            "icon": "send",
                            "action": "SUBMIT_REPLY",
                            "size": "sm",
                            "type": "button",
                            "label": "Comment",
                            "variant": "primary"
                          }
                        ],
                        "type": "stack",
                        "justify": "end"
                      }
                    ]
                  },
                  "padding": "md",
                  "type": "card"
                },
                {
                  "showActions": true,
                  "nodes": "@payload.data",
                  "replyEvent": "REPLY",
                  "type": "reply-tree"
                }
              ],
              "className": "max-w-3xl mx-auto px-card-md py-section",
              "type": "stack",
              "gap": "lg"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "CommentsLinearPage",
          "path": "/comments-thread",
          "traits": [
            {
              "ref": "CommentsLinear"
            }
          ]
        }
      ]
    }
  ]
}