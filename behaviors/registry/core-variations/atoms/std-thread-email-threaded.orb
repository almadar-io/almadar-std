{
  "name": "std-thread-email-threaded",
  "version": "1.3.5",
  "description": "Email-threaded — Gmail/Outlook/Mail.app split-pane: left message list (sender, subject, preview), right pane shows the focused message with from/to/subject header and quoted-reply nested tree. For helpdesk email threads, support tickets, document discussions that read like email.",
  "orbitals": [
    {
      "name": "EmailThreadedOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "EmailThreadedPost",
        "collection": "emailthreadedposts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string",
            "description": "Identifier of the parent message in the thread.",
            "synonyms": "parent, reference, source"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true,
            "description": "Identifier of the top-level message in the thread.",
            "synonyms": "root id, top id, original id"
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the post's author.",
            "synonyms": "author, user, creator"
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true,
            "description": "The name of the post's author.",
            "synonyms": "author, creator, user"
          },
          {
            "name": "fromAddress",
            "type": "string",
            "required": true,
            "description": "The email sender's address.",
            "synonyms": "sender, originator, email"
          },
          {
            "name": "toAddress",
            "type": "string",
            "required": true,
            "description": "Recipient(s) of the email message.",
            "synonyms": "recipient, cc, to"
          },
          {
            "name": "subject",
            "type": "string",
            "required": true,
            "description": "The title or heading of the message.",
            "synonyms": "title, heading, topic"
          },
          {
            "name": "preview",
            "type": "string",
            "description": "A short excerpt of the post's content.",
            "synonyms": "snippet, excerpt, summary, abstract"
          },
          {
            "name": "content",
            "type": "string",
            "required": true,
            "description": "The main text of the post's message.",
            "synonyms": "body, message, text"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0,
            "description": "The number of votes or ratings associated with this item.",
            "synonyms": "rating, score, likes, upvotes"
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0,
            "description": "The number of replies to this post.",
            "synonyms": "count, number of replies, response count"
          },
          {
            "name": "replies",
            "type": "relation",
            "relation": {
              "entity": "EmailThreadedPost",
              "cardinality": "many"
            },
            "description": "Nested replies to this post, forming a threaded conversation.",
            "synonyms": "replies, children, nested replies, descendants"
          },
          {
            "name": "focusedRow",
            "type": "object",
            "default": {},
            "properties": {
              "authorName": {
                "name": "authorName",
                "type": "string",
                "required": false
              },
              "fromAddress": {
                "name": "fromAddress",
                "type": "string",
                "required": false
              },
              "toAddress": {
                "name": "toAddress",
                "type": "string",
                "required": false
              },
              "replies": {
                "name": "replies",
                "type": "relation",
                "required": false,
                "relation": {
                  "entity": "EmailThreadedPost",
                  "cardinality": "many"
                }
              },
              "id": {
                "name": "id",
                "type": "string",
                "required": false
              },
              "createdAt": {
                "name": "createdAt",
                "type": "string",
                "required": false
              },
              "content": {
                "name": "content",
                "type": "string",
                "required": false
              },
              "subject": {
                "name": "subject",
                "type": "string",
                "required": false
              }
            },
            "description": "The complete, rendered content of the currently selected message.",
            "synonyms": "message, body, full text"
          }
        ]
      },
      "traits": [
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "EmailThreaded",
          "linkedEntity": "EmailThreadedPost",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "gap": "none",
                  "type": "stack",
                  "children": [
                    {
                      "gap": "sm",
                      "direction": "horizontal",
                      "align": "center",
                      "className": "p-card-md border-b border-[var(--color-border)] sticky top-0 bg-[var(--color-surface-subtle)] z-10",
                      "children": [
                        {
                          "size": "sm",
                          "type": "icon",
                          "name": "inbox"
                        },
                        {
                          "variant": "label",
                          "content": "Inbox",
                          "weight": "medium",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    },
                    {
                      "fields": [],
                      "itemClickEvent": "SELECT",
                      "gap": "none",
                      "type": "data-list",
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "className": "min-w-0 px-4 py-3",
                          "children": [
                            {
                              "size": "sm",
                              "name": "@config.emailAuthorBinding",
                              "className": "shrink-0 mt-0.5",
                              "type": "avatar"
                            },
                            {
                              "direction": "vertical",
                              "className": "flex-1 min-w-0",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "variant": "body2",
                                      "type": "typography",
                                      "content": "@config.emailAuthorBinding",
                                      "weight": "semibold",
                                      "className": "flex-1 truncate"
                                    },
                                    {
                                      "type": "icon",
                                      "name": "chevron-right",
                                      "size": "xs",
                                      "className": "shrink-0 text-[var(--color-text-muted)]"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "className": "min-w-0",
                                  "align": "center"
                                },
                                {
                                  "content": "@config.emailSubjectBinding",
                                  "variant": "body2",
                                  "type": "typography",
                                  "className": "truncate"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "@config.emailPreviewBinding",
                                  "className": "truncate"
                                }
                              ],
                              "gap": "xs",
                              "type": "stack"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "start"
                        }
                      ],
                      "entity": "@payload.data",
                      "variant": "default"
                    }
                  ],
                  "className": "w-80 shrink-0 border-r border-[var(--color-border)] bg-[var(--color-surface-subtle)] overflow-y-auto",
                  "direction": "vertical"
                },
                {
                  "direction": "vertical",
                  "className": "flex-1 min-w-0 p-card-lg overflow-y-auto",
                  "type": "stack",
                  "children": [
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "pb-4 border-b border-[var(--color-border)]",
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "start",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "className": "flex-1 min-w-0",
                              "variant": "h3",
                              "content": "@config.detailSubjectBinding"
                            },
                            {
                              "type": "stack",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "secondary",
                                  "size": "sm",
                                  "type": "button",
                                  "action": "REPLY",
                                  "actionPayload": {
                                    "parentId": "@entity.focusedRow.id"
                                  },
                                  "icon": "corner-up-left",
                                  "label": "Reply"
                                },
                                {
                                  "variant": "ghost",
                                  "icon": "corner-up-right",
                                  "type": "button",
                                  "size": "sm",
                                  "label": "Forward",
                                  "action": "REPLY"
                                }
                              ],
                              "className": "shrink-0",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "avatar",
                              "name": "@config.detailAuthorBinding",
                              "className": "shrink-0",
                              "size": "md"
                            },
                            {
                              "direction": "vertical",
                              "gap": "none",
                              "children": [
                                {
                                  "gap": "xs",
                                  "align": "center",
                                  "children": [
                                    {
                                      "variant": "caption",
                                      "type": "typography",
                                      "className": "w-10 shrink-0",
                                      "color": "muted",
                                      "content": "From"
                                    },
                                    {
                                      "className": "truncate",
                                      "content": "@config.detailFromBinding",
                                      "weight": "medium",
                                      "variant": "body2",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack"
                                },
                                {
                                  "gap": "xs",
                                  "children": [
                                    {
                                      "content": "To",
                                      "type": "typography",
                                      "className": "w-10 shrink-0",
                                      "variant": "caption",
                                      "color": "muted"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "@config.detailToBinding",
                                      "variant": "body2",
                                      "className": "truncate"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center"
                                }
                              ],
                              "type": "stack",
                              "className": "flex-1 min-w-0"
                            },
                            {
                              "className": "shrink-0",
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography",
                              "content": "@config.detailDateBinding"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "card",
                      "look": "flat-bordered",
                      "padding": "lg",
                      "children": {
                        "content": "@config.detailContentBinding",
                        "type": "typography",
                        "variant": "body",
                        "className": "leading-relaxed whitespace-pre-wrap"
                      }
                    },
                    {
                      "children": [
                        {
                          "size": "xs",
                          "name": "corner-down-right",
                          "type": "icon"
                        },
                        {
                          "variant": "label",
                          "color": "muted",
                          "type": "typography",
                          "content": "Quoted replies"
                        }
                      ],
                      "gap": "sm",
                      "direction": "horizontal",
                      "type": "stack",
                      "align": "center"
                    },
                    {
                      "variant": "default",
                      "gap": "sm",
                      "type": "data-list",
                      "renderItem": [
                        "fn",
                        "reply",
                        {
                          "look": "flat-bordered",
                          "className": "border-l-4 border-l-[var(--color-primary)] ml-card-md",
                          "type": "card",
                          "children": {
                            "gap": "sm",
                            "direction": "vertical",
                            "children": [
                              {
                                "align": "center",
                                "type": "stack",
                                "direction": "horizontal",
                                "gap": "sm",
                                "children": [
                                  {
                                    "name": "@config.replyAuthorBinding",
                                    "size": "xs",
                                    "type": "avatar"
                                  },
                                  {
                                    "weight": "medium",
                                    "variant": "body2",
                                    "type": "typography",
                                    "content": "@config.replyAuthorBinding"
                                  },
                                  {
                                    "type": "typography",
                                    "content": "@config.replyFromBinding",
                                    "color": "muted",
                                    "variant": "caption"
                                  },
                                  {
                                    "color": "muted",
                                    "type": "typography",
                                    "variant": "caption",
                                    "content": "·"
                                  },
                                  {
                                    "variant": "caption",
                                    "color": "muted",
                                    "content": "@config.replyDateBinding",
                                    "type": "typography"
                                  }
                                ]
                              },
                              {
                                "content": "@config.replyContentBinding",
                                "type": "typography",
                                "variant": "body"
                              }
                            ],
                            "type": "stack"
                          },
                          "padding": "md"
                        }
                      ],
                      "fields": [],
                      "entity": "@entity.focusedRow.replies"
                    }
                  ],
                  "gap": "lg"
                }
              ],
              "type": "stack",
              "direction": "horizontal",
              "align": "stretch",
              "className": "w-full my-section min-h-[32rem] max-h-[80vh] border border-[var(--color-border)] rounded-lg overflow-hidden shadow-sm bg-[var(--color-surface)]",
              "gap": "none"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "EmailThreadedPage",
          "path": "/email-thread",
          "traits": [
            {
              "ref": "EmailThreaded"
            }
          ]
        }
      ]
    }
  ]
}
