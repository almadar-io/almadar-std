{
  "name": "std-thread-email-threaded",
  "version": "1.1.0",
  "description": "Email-threaded — Gmail/Outlook/Mail.app split-pane: left message list (sender, subject, preview), right pane shows the focused message with from/to/subject header and quoted-reply nested tree. For helpdesk email threads, support tickets, document discussions that read like email.",
  "orbitals": [
    {
      "name": "EmailThreadedOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "EmailThreadedPost",
        "collection": "emailthreadedposts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true
          },
          {
            "name": "fromAddress",
            "type": "string",
            "required": true
          },
          {
            "name": "toAddress",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "required": true
          },
          {
            "name": "preview",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replies",
            "type": "relation",
            "relation": {
              "entity": "EmailThreadedPost",
              "cardinality": "many"
            }
          },
          {
            "name": "focusedId",
            "type": "string"
          },
          {
            "name": "focusedSubject",
            "type": "string"
          },
          {
            "name": "focusedAuthorName",
            "type": "string"
          },
          {
            "name": "focusedFromAddress",
            "type": "string"
          },
          {
            "name": "focusedToAddress",
            "type": "string"
          },
          {
            "name": "focusedCreatedAt",
            "type": "string"
          },
          {
            "name": "focusedContent",
            "type": "string"
          },
          {
            "name": "focusedReplies",
            "type": "relation",
            "relation": {
              "entity": "EmailThreadedPost",
              "cardinality": "many"
            }
          }
        ]
      },
      "traits": [
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "EmailThreaded",
          "linkedEntity": "EmailThreadedPost",
          "config": {
            "bodyContent": {
              "direction": "horizontal",
              "className": "max-w-7xl mx-auto h-full border border-[var(--color-border)] rounded-md overflow-hidden",
              "type": "stack",
              "gap": "none",
              "children": [
                {
                  "type": "stack",
                  "gap": "none",
                  "children": [
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "px-card-md py-md border-b border-[var(--color-border)]",
                      "direction": "horizontal",
                      "children": [
                        {
                          "size": "sm",
                          "name": "inbox",
                          "type": "icon"
                        },
                        {
                          "weight": "medium",
                          "type": "typography",
                          "variant": "label",
                          "content": "Inbox"
                        }
                      ],
                      "gap": "sm"
                    },
                    {
                      "type": "data-list",
                      "fields": [],
                      "entity": "@payload.data",
                      "renderItem": [
                        "fn",
                        "item",
                        {
                          "type": "card",
                          "look": "borderless-divider",
                          "padding": "md",
                          "children": {
                            "direction": "horizontal",
                            "type": "stack",
                            "gap": "sm",
                            "children": [
                              {
                                "name": "@item.authorName",
                                "type": "avatar",
                                "size": "sm"
                              },
                              {
                                "direction": "vertical",
                                "gap": "xs",
                                "className": "flex-1 min-w-0",
                                "type": "stack",
                                "children": [
                                  {
                                    "gap": "sm",
                                    "type": "stack",
                                    "direction": "horizontal",
                                    "children": [
                                      {
                                        "variant": "body",
                                        "type": "typography",
                                        "content": "@item.authorName",
                                        "weight": "medium",
                                        "className": "flex-1 truncate"
                                      },
                                      {
                                        "variant": "caption",
                                        "content": "@item.createdAt",
                                        "type": "typography",
                                        "color": "muted"
                                      }
                                    ],
                                    "align": "center"
                                  },
                                  {
                                    "weight": "medium",
                                    "variant": "body2",
                                    "content": "@item.subject",
                                    "type": "typography",
                                    "className": "truncate"
                                  },
                                  {
                                    "type": "typography",
                                    "className": "truncate",
                                    "content": "@item.preview",
                                    "color": "muted",
                                    "variant": "caption"
                                  }
                                ]
                              }
                            ],
                            "align": "start"
                          }
                        }
                      ],
                      "gap": "none",
                      "variant": "default"
                    }
                  ],
                  "direction": "vertical",
                  "className": "w-80 shrink-0 border-r border-[var(--color-border)] bg-[var(--color-muted)]"
                },
                {
                  "direction": "vertical",
                  "gap": "md",
                  "type": "stack",
                  "className": "flex-1 px-card-md py-md overflow-y-auto",
                  "children": [
                    {
                      "direction": "vertical",
                      "className": "pb-md border-b border-[var(--color-border)]",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@entity.focusedSubject"
                        },
                        {
                          "children": [
                            {
                              "type": "avatar",
                              "name": "@entity.focusedAuthorName",
                              "size": "md"
                            },
                            {
                              "className": "flex-1",
                              "gap": "xs",
                              "direction": "vertical",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "color": "muted",
                                      "variant": "label",
                                      "content": "From"
                                    },
                                    {
                                      "content": "@entity.focusedFromAddress",
                                      "type": "typography",
                                      "variant": "body2",
                                      "weight": "medium"
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "children": [
                                    {
                                      "color": "muted",
                                      "content": "To",
                                      "variant": "label",
                                      "type": "typography"
                                    },
                                    {
                                      "variant": "body2",
                                      "content": "@entity.focusedToAddress",
                                      "type": "typography"
                                    }
                                  ],
                                  "align": "center",
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "typography",
                              "variant": "caption",
                              "color": "muted",
                              "content": "@entity.focusedCreatedAt"
                            },
                            {
                              "actionPayload": {
                                "parentId": "@entity.focusedId"
                              },
                              "label": "Reply",
                              "action": "REPLY",
                              "icon": "corner-up-left",
                              "type": "button",
                              "variant": "secondary",
                              "size": "sm"
                            },
                            {
                              "icon": "corner-up-right",
                              "action": "REPLY",
                              "type": "button",
                              "label": "Forward",
                              "size": "sm",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "md"
                        }
                      ],
                      "type": "stack",
                      "gap": "xs"
                    },
                    {
                      "type": "card",
                      "children": {
                        "content": "@entity.focusedContent",
                        "variant": "body",
                        "type": "typography"
                      },
                      "padding": "md",
                      "look": "flat-bordered"
                    },
                    {
                      "type": "stack",
                      "gap": "sm",
                      "align": "center",
                      "children": [
                        {
                          "size": "xs",
                          "type": "icon",
                          "name": "corner-down-right"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "label",
                          "content": "Quoted replies"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "type": "data-list",
                      "variant": "default",
                      "renderItem": [
                        "fn",
                        "reply",
                        {
                          "look": "flat-bordered",
                          "padding": "md",
                          "type": "card",
                          "className": "border-l-4 border-l-[var(--color-primary)] ml-card-md",
                          "children": {
                            "type": "stack",
                            "gap": "sm",
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "stack",
                                "gap": "sm",
                                "align": "center",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "type": "avatar",
                                    "name": "@reply.authorName",
                                    "size": "xs"
                                  },
                                  {
                                    "type": "typography",
                                    "variant": "body2",
                                    "content": "@reply.authorName",
                                    "weight": "medium"
                                  },
                                  {
                                    "content": "@reply.fromAddress",
                                    "type": "typography",
                                    "color": "muted",
                                    "variant": "caption"
                                  },
                                  {
                                    "color": "muted",
                                    "variant": "caption",
                                    "content": "·",
                                    "type": "typography"
                                  },
                                  {
                                    "variant": "caption",
                                    "content": "@reply.createdAt",
                                    "color": "muted",
                                    "type": "typography"
                                  }
                                ]
                              },
                              {
                                "type": "typography",
                                "variant": "body",
                                "content": "@reply.content"
                              }
                            ]
                          }
                        }
                      ],
                      "gap": "sm",
                      "entity": "@entity.focusedReplies",
                      "fields": []
                    }
                  ]
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "EmailThreadedPage",
          "path": "/email-thread",
          "traits": [
            {
              "ref": "EmailThreaded"
            }
          ]
        }
      ]
    }
  ]
}