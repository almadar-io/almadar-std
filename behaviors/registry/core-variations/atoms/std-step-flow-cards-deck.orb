{
  "description": "Full-page card deck step flow — each step is rendered as one large centered card occupying the viewport with the step icon, title, and description prominent; progress-dots at the bottom indicate position in the sequence; primary advance + back controls flank the dots. Same StepFlowReview trait, same state machine, same emits/listens as std-step-flow — only the bodyContent tree differs. Suited for mobile-flavored onboarding, marketing-campaign creation flows, and any single-focus sequential UX.",
  "name": "std-step-flow-cards-deck",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "CardsDeckView",
        "persistence": "runtime"
      },
      "name": "CardsDeckOrbital",
      "pages": [
        {
          "name": "CardsDeckPage",
          "path": "/cards-deck",
          "traits": [
            {
              "ref": "CardsDeckReview"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "align": "center",
              "children": [
                {
                  "children": [
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "@entity.currentStepIcon",
                          "size": "lg",
                          "type": "icon"
                        },
                        {
                          "align": "center",
                          "content": "@entity.currentStepLabel",
                          "type": "typography",
                          "variant": "h1"
                        },
                        {
                          "align": "center",
                          "color": "muted",
                          "content": "@entity.currentStepDescription",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "action": "REJECT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "icon": "x",
                              "label": "Reject",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "action": "ESCALATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "icon": "alert-triangle",
                              "label": "Escalate",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "className": "pt-md",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "className": "p-card-xl text-center",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ],
                  "look": "@config.cardLook",
                  "type": "card"
                },
                {
                  "align": "center",
                  "children": [
                    {
                      "action": "BACK",
                      "actionPayload": {
                        "id": "@entity.id"
                      },
                      "disabled": "@entity.isFirstStep",
                      "icon": "chevron-left",
                      "label": "Back",
                      "type": "button",
                      "variant": "ghost"
                    },
                    {
                      "count": "@entity.totalSteps",
                      "currentIndex": "@entity.currentStepIndex",
                      "size": "md",
                      "type": "progress-dots"
                    },
                    {
                      "action": "ADVANCE",
                      "actionPayload": {
                        "id": "@entity.id"
                      },
                      "icon": "@entity.primaryActionIcon",
                      "label": "@entity.primaryActionLabel",
                      "type": "button",
                      "variant": "primary"
                    }
                  ],
                  "className": "justify-between w-full",
                  "direction": "horizontal",
                  "gap": "lg",
                  "type": "stack"
                }
              ],
              "className": "w-full pt-section",
              "direction": "vertical",
              "gap": "xl",
              "type": "stack"
            }
          },
          "linkedEntity": "CardsDeckView",
          "name": "CardsDeckReview",
          "ref": "StepFlow.traits.StepFlowReview"
        }
      ],
      "uses": [
        {
          "as": "StepFlow",
          "from": "std/behaviors/std-step-flow"
        }
      ]
    }
  ],
  "version": "1.0.0"
}