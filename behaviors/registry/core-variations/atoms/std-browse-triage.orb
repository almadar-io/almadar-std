{
  "name": "std-browse-triage",
  "version": "1.0.1",
  "description": "Work-queue triage — prioritized rows with leading queue-position pill, priority badge, and per-row Accept/Defer/Escalate action buttons.",
  "orbitals": [
    {
      "name": "TriageBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "TriageItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high"
            ]
          },
          {
            "name": "queueIndex",
            "type": "string"
          },
          {
            "name": "assignee",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "TriageBrowse",
          "linkedEntity": "TriageItem",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "type": "stack",
                  "className": "px-1",
                  "gap": "sm",
                  "justify": "between",
                  "direction": "horizontal",
                  "children": [
                    {
                      "variant": "overline",
                      "type": "typography",
                      "content": "Triage queue",
                      "color": "muted"
                    },
                    {
                      "label": "@payload.data.length",
                      "variant": "neutral",
                      "size": "sm",
                      "type": "badge"
                    }
                  ],
                  "align": "center"
                },
                {
                  "type": "divider"
                },
                {
                  "entity": "@payload.data",
                  "gap": "md",
                  "variant": "card",
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "className": "p-card-md",
                          "children": [
                            {
                              "gap": "xs",
                              "type": "stack",
                              "className": "flex-1 min-w-0",
                              "direction": "vertical",
                              "children": [
                                {
                                  "align": "center",
                                  "className": "min-w-0",
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "label": "@config.priorityBinding",
                                      "type": "badge",
                                      "size": "sm",
                                      "variant": "neutral"
                                    },
                                    {
                                      "type": "typography",
                                      "weight": "medium",
                                      "content": "@config.titleBinding",
                                      "className": "truncate",
                                      "variant": "body"
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "className": "truncate",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "@config.descriptionBinding"
                                },
                                {
                                  "children": [
                                    {
                                      "name": "user",
                                      "className": "text-[var(--color-text-muted)]",
                                      "type": "icon",
                                      "size": "sm"
                                    },
                                    {
                                      "content": "@config.assigneeBinding",
                                      "type": "typography",
                                      "variant": "caption",
                                      "color": "muted"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "xs",
                                  "type": "stack",
                                  "className": "pt-0.5",
                                  "align": "center"
                                }
                              ]
                            },
                            {
                              "align": "center",
                              "className": "shrink-0 opacity-60 group-hover:opacity-100 transition-opacity duration-normal",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "Defer",
                                  "size": "sm",
                                  "variant": "ghost",
                                  "type": "button",
                                  "action": "DEFER"
                                },
                                {
                                  "action": "ESCALATE",
                                  "type": "button",
                                  "size": "sm",
                                  "label": "Escalate",
                                  "variant": "warning"
                                },
                                {
                                  "action": "ACCEPT",
                                  "type": "button",
                                  "size": "sm",
                                  "label": "Accept",
                                  "variant": "primary"
                                }
                              ],
                              "type": "stack",
                              "gap": "xs"
                            }
                          ]
                        }
                      ],
                      "look": "flat-bordered",
                      "type": "card",
                      "className": "group rounded-md bg-[var(--color-card)] border border-[var(--color-border)] shadow-sm transition-all duration-normal hover:shadow-hover hover:border-[var(--color-border-strong)] hover:-translate-y-px"
                    }
                  ],
                  "fields": [],
                  "type": "data-list"
                }
              ],
              "gap": "md",
              "className": "w-full",
              "type": "stack",
              "direction": "vertical"
            }
          },
          "events": {
            "EDIT": "DEFER",
            "DELETE": "ESCALATE",
            "VIEW": "ACCEPT"
          }
        }
      ],
      "pages": [
        {
          "name": "TriagePage",
          "path": "/triage",
          "traits": [
            {
              "ref": "TriageBrowse"
            }
          ]
        }
      ]
    }
  ]
}