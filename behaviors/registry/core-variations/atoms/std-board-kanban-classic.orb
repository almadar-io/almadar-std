{
  "name": "std-board-kanban-classic",
  "version": "1.0.0",
  "description": "Trello-style kanban — wide elevated columns side-by-side, sticky column headers with icon + label + count chip, dense cards with title, description, and a status badge. Same BoardItemBoard trait, same state machine, same emits/listens as std-board — only the bodyContent tree differs.",
  "orbitals": [
    {
      "name": "KanbanClassicBoardOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-board",
          "as": "Board"
        }
      ],
      "entity": {
        "name": "KanbanClassicItem",
        "collection": "kanban_classic_items",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "stage",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "doing",
              "done"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "position",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "boards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object"
            }
          },
          {
            "name": "currentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStage",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentNotes",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Board.traits.BoardItemBoard",
          "name": "KanbanClassicBoard",
          "linkedEntity": "KanbanClassicItem",
          "config": {
            "bodyContent": {
              "type": "stack",
              "direction": "vertical",
              "className": "h-full",
              "children": [
                {
                  "children": [
                    {
                      "type": "icon",
                      "name": "kanban-square"
                    },
                    {
                      "type": "typography",
                      "variant": "h2",
                      "content": "@config.title"
                    }
                  ],
                  "className": "px-card-md",
                  "type": "stack",
                  "direction": "horizontal",
                  "gap": "sm",
                  "align": "center"
                },
                {
                  "type": "divider"
                },
                {
                  "renderItem": [
                    "fn",
                    "col",
                    {
                      "padding": "none",
                      "type": "card",
                      "look": "elevated",
                      "className": "min-w-[280px] bg-[var(--color-surface-subtle)] rounded-lg overflow-hidden",
                      "children": [
                        {
                          "gap": "none",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "sm",
                              "className": "px-card-md py-3 border-b border-[var(--color-border)] sticky top-0 bg-[var(--color-surface)]",
                              "children": [
                                {
                                  "name": "@col.icon",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h4",
                                  "content": "@col.label",
                                  "type": "typography",
                                  "className": "flex-1"
                                },
                                {
                                  "variant": "primary",
                                  "label": "@col.count",
                                  "size": "sm",
                                  "type": "badge"
                                }
                              ]
                            },
                            {
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "type": "card",
                                  "children": [
                                    {
                                      "gap": "xs",
                                      "children": [
                                        {
                                          "variant": "body",
                                          "weight": "medium",
                                          "content": "@item.title",
                                          "type": "typography"
                                        },
                                        {
                                          "variant": "caption",
                                          "content": "@item.description",
                                          "color": "muted",
                                          "type": "typography",
                                          "className": "line-clamp-2"
                                        },
                                        {
                                          "align": "center",
                                          "direction": "horizontal",
                                          "type": "stack",
                                          "children": [
                                            {
                                              "variant": "primary",
                                              "type": "badge",
                                              "label": "@item.stage",
                                              "size": "sm"
                                            },
                                            {
                                              "type": "button",
                                              "action": "OPEN_CARD",
                                              "icon": "arrow-right",
                                              "className": "ml-auto",
                                              "size": "sm",
                                              "label": "Open",
                                              "variant": "ghost",
                                              "actionPayload": {
                                                "id": "@item.id",
                                                "row": "@item"
                                              }
                                            }
                                          ],
                                          "gap": "xs",
                                          "className": "pt-1"
                                        }
                                      ],
                                      "type": "stack",
                                      "direction": "vertical"
                                    }
                                  ],
                                  "look": "elevated",
                                  "className": "cursor-grab hover:shadow-lg transition-shadow",
                                  "padding": "sm"
                                }
                              ],
                              "positionEvent": "REORDER_POSITION",
                              "fields": [],
                              "dragGroup": "@col.key",
                              "reorderEvent": "REORDER_CARD",
                              "className": "p-card-md min-h-[120px]",
                              "sortable": true,
                              "type": "data-list",
                              "gap": "sm",
                              "entity": "@col.items",
                              "accepts": "*",
                              "dropEvent": "MOVE_CARD"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ],
                  "gap": "lg",
                  "type": "data-grid",
                  "cols": "@config.gridCols",
                  "entity": "@entity.boards",
                  "fields": [],
                  "dndRoot": true
                },
                {
                  "variant": "primary",
                  "type": "floating-action-button",
                  "label": "Add card",
                  "action": "ADD_CARD",
                  "icon": "plus"
                }
              ],
              "gap": "md"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "KanbanClassicPage",
          "path": "/kanban-classic",
          "traits": [
            {
              "ref": "KanbanClassicBoard"
            }
          ]
        }
      ]
    }
  ]
}