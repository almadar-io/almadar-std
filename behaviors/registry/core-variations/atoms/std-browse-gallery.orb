{
  "name": "std-browse-gallery",
  "version": "1.0.0",
  "description": "Gallery browse — image-first responsive card grid (Pinterest/Dribbble) using data-grid with auto-fit minCardWidth so it stays a grid from 3 cols above 1200px down to 1 col under 600px.",
  "orbitals": [
    {
      "name": "GalleryBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "GalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "draft",
              "archived"
            ]
          },
          {
            "name": "price",
            "type": "string"
          },
          {
            "name": "thumbnailLabel",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "GalleryBrowse",
          "linkedEntity": "GalleryItem",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "direction": "horizontal",
                  "type": "stack",
                  "className": "sticky top-0 z-10 -mx-card-md px-card-md py-3 bg-[var(--color-surface)]/95 backdrop-blur border-b border-[var(--color-border)]",
                  "children": [
                    {
                      "className": "text-muted-foreground",
                      "name": "search",
                      "type": "icon"
                    },
                    {
                      "type": "input",
                      "inputType": "search",
                      "placeholder": "Search the gallery…",
                      "action": "REFETCH_QUERY"
                    }
                  ],
                  "align": "center",
                  "gap": "sm"
                },
                {
                  "entity": "@payload.data",
                  "gap": "lg",
                  "className": "w-full",
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "className": "relative aspect-square w-full bg-muted overflow-hidden",
                          "justify": "center",
                          "gap": "xs",
                          "align": "center",
                          "children": [
                            {
                              "size": "lg",
                              "className": "text-muted-foreground opacity-50 transition-transform duration-normal group-hover:scale-105",
                              "name": "image",
                              "type": "icon"
                            },
                            {
                              "color": "muted",
                              "variant": "caption",
                              "className": "px-2 text-center truncate max-w-full",
                              "type": "typography",
                              "content": "@item.thumbnailLabel"
                            },
                            {
                              "type": "stack",
                              "className": "absolute top-2 right-2",
                              "direction": "horizontal",
                              "gap": "xs",
                              "align": "center",
                              "children": [
                                {
                                  "variant": "primary",
                                  "type": "badge",
                                  "label": "@item.price"
                                }
                              ]
                            },
                            {
                              "className": "absolute top-2 left-2",
                              "children": [
                                {
                                  "label": "@item.status",
                                  "type": "badge",
                                  "variant": "neutral"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "xs",
                              "align": "center"
                            }
                          ]
                        },
                        {
                          "className": "px-card-md pb-card-md",
                          "gap": "xs",
                          "type": "stack",
                          "children": [
                            {
                              "content": "@item.name",
                              "type": "typography",
                              "className": "truncate",
                              "variant": "h4"
                            },
                            {
                              "content": "@item.description",
                              "type": "typography",
                              "className": "line-clamp-2",
                              "variant": "caption",
                              "color": "muted"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "type": "stack",
                      "className": "group rounded-lg overflow-hidden bg-[var(--color-card)] border border-[var(--color-border)] shadow-sm hover:shadow-hover hover:-translate-y-0.5 transition-all duration-normal cursor-pointer",
                      "gap": "sm"
                    }
                  ],
                  "minCardWidth": 280.0,
                  "type": "data-grid",
                  "fields": []
                }
              ],
              "gap": "lg",
              "className": "max-w-7xl mx-auto px-card-md py-section",
              "type": "stack",
              "direction": "vertical"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "GalleryBrowsePage",
          "path": "/gallery-browse",
          "traits": [
            {
              "ref": "GalleryBrowse"
            }
          ]
        }
      ]
    }
  ]
}