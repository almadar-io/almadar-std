{
  "name": "std-display-sidebar-meta",
  "version": "1.0.0",
  "description": "Narrow right-rail meta panel — Linear/Jira/GitHub issue sidebar. Stacked label/value rows in a ~280px column, grouped with dividers.",
  "orbitals": [
    {
      "name": "SidebarMetaDisplayOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-display",
          "as": "Display"
        }
      ],
      "entity": {
        "name": "SidebarRecord",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "in_progress",
              "closed"
            ]
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high"
            ]
          },
          {
            "name": "assignee",
            "type": "string"
          },
          {
            "name": "reporter",
            "type": "string"
          },
          {
            "name": "milestone",
            "type": "string"
          },
          {
            "name": "labels",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "updatedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Display.traits.DisplayItemDisplay",
          "name": "SidebarMetaDisplay",
          "linkedEntity": "SidebarRecord",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "gap": "md",
              "children": [
                {
                  "type": "stack",
                  "direction": "vertical",
                  "children": [
                    {
                      "variant": "caption",
                      "content": "@entity.id",
                      "color": "muted",
                      "className": "font-mono uppercase tracking-wide",
                      "type": "typography"
                    },
                    {
                      "className": "leading-snug break-words",
                      "type": "typography",
                      "weight": "semibold",
                      "content": "@entity.title",
                      "variant": "h4"
                    }
                  ],
                  "gap": "xs"
                },
                {
                  "type": "divider"
                },
                {
                  "justify": "between",
                  "gap": "sm",
                  "align": "center",
                  "children": [
                    {
                      "type": "typography",
                      "content": "Status",
                      "color": "muted",
                      "variant": "overline"
                    },
                    {
                      "type": "badge",
                      "variant": "default",
                      "label": "@entity.status"
                    }
                  ],
                  "direction": "horizontal",
                  "type": "stack"
                },
                {
                  "align": "center",
                  "gap": "sm",
                  "type": "stack",
                  "justify": "between",
                  "direction": "horizontal",
                  "children": [
                    {
                      "content": "Priority",
                      "type": "typography",
                      "color": "muted",
                      "variant": "overline"
                    },
                    {
                      "variant": "neutral",
                      "type": "badge",
                      "label": "@entity.priority"
                    }
                  ]
                },
                {
                  "type": "divider"
                },
                {
                  "type": "stack",
                  "direction": "vertical",
                  "children": [
                    {
                      "content": "Assignee",
                      "variant": "overline",
                      "color": "muted",
                      "type": "typography"
                    },
                    {
                      "gap": "xs",
                      "align": "center",
                      "direction": "horizontal",
                      "className": "hover:bg-[var(--color-muted)] rounded-sm -mx-1 px-1 py-0.5 transition-colors cursor-pointer",
                      "children": [
                        {
                          "type": "avatar",
                          "name": "@entity.assignee",
                          "size": "xs"
                        },
                        {
                          "variant": "body2",
                          "content": "@entity.assignee",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ],
                  "gap": "xs"
                },
                {
                  "gap": "xs",
                  "children": [
                    {
                      "color": "muted",
                      "type": "typography",
                      "content": "Reporter",
                      "variant": "overline"
                    },
                    {
                      "gap": "xs",
                      "type": "stack",
                      "direction": "horizontal",
                      "children": [
                        {
                          "size": "xs",
                          "name": "@entity.reporter",
                          "type": "avatar"
                        },
                        {
                          "type": "typography",
                          "variant": "body2",
                          "content": "@entity.reporter"
                        }
                      ],
                      "align": "center"
                    }
                  ],
                  "type": "stack",
                  "direction": "vertical"
                },
                {
                  "type": "divider"
                },
                {
                  "direction": "horizontal",
                  "justify": "between",
                  "gap": "sm",
                  "type": "stack",
                  "align": "center",
                  "children": [
                    {
                      "variant": "overline",
                      "type": "typography",
                      "color": "muted",
                      "content": "Milestone"
                    },
                    {
                      "variant": "body2",
                      "content": "@entity.milestone",
                      "type": "typography"
                    }
                  ]
                },
                {
                  "direction": "vertical",
                  "type": "stack",
                  "children": [
                    {
                      "content": "Labels",
                      "variant": "overline",
                      "color": "muted",
                      "type": "typography"
                    },
                    {
                      "type": "badge",
                      "variant": "neutral",
                      "label": "@entity.labels"
                    }
                  ],
                  "gap": "xs"
                },
                {
                  "type": "divider"
                },
                {
                  "direction": "horizontal",
                  "type": "stack",
                  "gap": "sm",
                  "justify": "between",
                  "children": [
                    {
                      "color": "muted",
                      "content": "Created",
                      "type": "typography",
                      "variant": "overline"
                    },
                    {
                      "content": "@entity.createdAt",
                      "className": "tabular-nums",
                      "type": "typography",
                      "variant": "caption",
                      "color": "muted"
                    }
                  ],
                  "align": "center"
                },
                {
                  "gap": "sm",
                  "direction": "horizontal",
                  "type": "stack",
                  "align": "center",
                  "justify": "between",
                  "children": [
                    {
                      "type": "typography",
                      "content": "Updated",
                      "color": "muted",
                      "variant": "overline"
                    },
                    {
                      "content": "@entity.updatedAt",
                      "className": "tabular-nums",
                      "variant": "caption",
                      "type": "typography",
                      "color": "muted"
                    }
                  ]
                }
              ],
              "className": "max-w-[280px] w-full p-card-md",
              "type": "stack"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "SidebarMetaDisplayPage",
          "path": "/sidebar-display",
          "traits": [
            {
              "ref": "SidebarMetaDisplay"
            }
          ]
        }
      ]
    }
  ]
}