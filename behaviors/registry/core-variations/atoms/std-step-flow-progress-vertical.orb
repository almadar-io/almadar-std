{
  "name": "std-step-flow-progress-vertical",
  "version": "1.0.0",
  "description": "Header progress bar above a vertical step list — full-width progress affordance up top, every step as a row card below.",
  "orbitals": [
    {
      "name": "ProgressVerticalOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-step-flow",
          "as": "StepFlow"
        }
      ],
      "entity": {
        "name": "ProgressVerticalView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "progressLabel",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "StepFlow.traits.StepFlowReview",
          "name": "ProgressVerticalReview",
          "linkedEntity": "ProgressVerticalView",
          "config": {
            "bodyContent": {
              "gap": "lg",
              "direction": "vertical",
              "className": "w-full pt-section w-full",
              "type": "stack",
              "children": [
                {
                  "gap": "sm",
                  "children": [
                    {
                      "children": [
                        {
                          "content": "@config.title",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "@entity.progressLabel"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack",
                      "gap": "sm",
                      "justify": "between",
                      "align": "center"
                    },
                    {
                      "value": "@entity.currentStepIndex",
                      "steps": "@entity.totalSteps",
                      "max": "@entity.totalSteps",
                      "type": "progress-bar"
                    }
                  ],
                  "type": "stack",
                  "direction": "vertical"
                },
                {
                  "type": "divider"
                },
                {
                  "fields": [],
                  "type": "data-list",
                  "renderItem": [
                    "fn",
                    "step",
                    {
                      "type": "card",
                      "children": [
                        {
                          "className": "p-card-md",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "badge",
                              "label": "@step.indexLabel",
                              "variant": "@step.badgeVariant"
                            },
                            {
                              "type": "icon",
                              "size": "md",
                              "name": "@step.icon"
                            },
                            {
                              "direction": "vertical",
                              "gap": "xs",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "@step.label"
                                },
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "@step.description",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ],
                      "look": "@config.cardLook"
                    }
                  ],
                  "entity": "@entity.wizardSteps",
                  "gap": "md"
                },
                {
                  "children": [
                    {
                      "actionPayload": {
                        "id": "@entity.id"
                      },
                      "variant": "ghost",
                      "action": "BACK",
                      "type": "button",
                      "icon": "chevron-left",
                      "disabled": "@entity.isFirstStep",
                      "label": "Back"
                    },
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "horizontal",
                      "children": [
                        {
                          "label": "Reject",
                          "action": "REJECT",
                          "variant": "ghost",
                          "icon": "x",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "type": "button"
                        },
                        {
                          "label": "Escalate",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "action": "ESCALATE",
                          "variant": "ghost",
                          "type": "button",
                          "icon": "alert-triangle"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "@entity.primaryActionIcon",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "label": "@entity.primaryActionLabel",
                          "action": "ADVANCE"
                        }
                      ],
                      "gap": "sm"
                    }
                  ],
                  "type": "stack",
                  "direction": "horizontal",
                  "align": "center",
                  "className": "justify-between",
                  "gap": "sm"
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "ProgressVerticalPage",
          "path": "/progress-vertical",
          "traits": [
            {
              "ref": "ProgressVerticalReview"
            }
          ]
        }
      ]
    }
  ]
}