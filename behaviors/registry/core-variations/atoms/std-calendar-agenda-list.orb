{
  "description": "Day-grouped agenda — events organized by date with overline day headers (Today, Tomorrow, Mon Jun 5) and a time marker per event. Inherits std-calendar's fetch + SELECT_DAY state machine; only bodyContent differs from std-calendar's month-grid and std-calendar-week-timeline's 7-col timeline. For appointment queues, class-roster schedules, court-deadline lists where users scan a vertical chronological flow grouped by day.",
  "name": "std-calendar-agenda-list",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The event's title or short identifier.",
            "name": "name",
            "required": true,
            "synonyms": "title, label, eventName",
            "type": "string"
          },
          {
            "description": "A brief explanation of the event.",
            "name": "description",
            "synonyms": "summary, details, notes",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the event.",
            "name": "status",
            "synonyms": "state, condition, flag",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "date",
            "type": "datetime"
          },
          {
            "default": "",
            "description": "The time of the event.",
            "name": "time",
            "synonyms": "start time, scheduled time, time slot",
            "type": "string"
          },
          {
            "default": 60.0,
            "description": "The length of time the event lasts, in minutes.",
            "name": "duration",
            "synonyms": "length, time, span",
            "type": "number"
          },
          {
            "default": "",
            "description": "The date to which this event belongs.",
            "name": "dateGroup",
            "synonyms": "day, date",
            "type": "string"
          },
          {
            "default": "month",
            "intrinsic": true,
            "name": "selectedRange",
            "type": "string"
          }
        ],
        "name": "AgendaListEvent",
        "persistence": "runtime"
      },
      "name": "AgendaListCalendarOrbital",
      "pages": [
        {
          "name": "AgendaListCalendarPage",
          "path": "/calendarevents/agenda",
          "traits": [
            {
              "ref": "AgendaListCalendar"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      {
                        "align": "center",
                        "children": [
                          {
                            "name": "list",
                            "type": "icon"
                          },
                          {
                            "content": "Agenda",
                            "type": "typography",
                            "variant": "h2"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "sm",
                        "type": "stack"
                      },
                      {
                        "onSelect": "SELECT_DAY",
                        "selected": "@entity.selectedRange",
                        "type": "date-range-selector"
                      }
                    ],
                    "direction": "horizontal",
                    "gap": "md",
                    "justify": "between",
                    "type": "stack"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "entity": "@payload.data",
                    "fields": [],
                    "gap": "md",
                    "groupBy": "date",
                    "renderItem": [
                      "fn",
                      "item",
                      {
                        "children": [
                          {
                            "align": "start",
                            "children": [
                              {
                                "align": "center",
                                "children": [
                                  {
                                    "color": "muted",
                                    "content": "@config.timeBinding",
                                    "type": "typography",
                                    "variant": "overline"
                                  },
                                  {
                                    "color": "muted",
                                    "name": "clock",
                                    "size": "sm",
                                    "type": "icon"
                                  }
                                ],
                                "className": "w-16 shrink-0",
                                "direction": "vertical",
                                "gap": "xs",
                                "type": "stack"
                              },
                              {
                                "orientation": "vertical",
                                "type": "divider"
                              },
                              {
                                "children": [
                                  {
                                    "align": "center",
                                    "children": [
                                      {
                                        "className": "truncate",
                                        "content": "@config.titleBinding",
                                        "type": "typography",
                                        "variant": "h4",
                                        "weight": "medium"
                                      },
                                      {
                                        "label": "@config.badgeBinding",
                                        "size": "sm",
                                        "type": "badge",
                                        "variant": "default"
                                      }
                                    ],
                                    "direction": "horizontal",
                                    "gap": "sm",
                                    "justify": "between",
                                    "type": "stack"
                                  },
                                  {
                                    "className": "truncate",
                                    "color": "muted",
                                    "content": "@config.descriptionBinding",
                                    "type": "typography",
                                    "variant": "body2"
                                  }
                                ],
                                "className": "flex-1 min-w-0",
                                "direction": "vertical",
                                "gap": "xs",
                                "type": "stack"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "md",
                            "type": "stack"
                          }
                        ],
                        "look": "flat-bordered",
                        "padding": "md",
                        "type": "card"
                      }
                    ],
                    "type": "data-list",
                    "variant": "default"
                  }
                ],
                "className": "w-full p-card-md",
                "direction": "vertical",
                "gap": "lg",
                "type": "stack"
              },
              "type": "unknown"
            }
          },
          "linkedEntity": "AgendaListEvent",
          "name": "AgendaListCalendar",
          "ref": "Calendar.traits.CalendarEventCalendar"
        }
      ],
      "uses": [
        {
          "as": "Calendar",
          "from": "std/behaviors/std-calendar"
        }
      ]
    }
  ],
  "version": "1.2.0"
}