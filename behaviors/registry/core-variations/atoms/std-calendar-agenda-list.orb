{
  "name": "std-calendar-agenda-list",
  "version": "1.1.2",
  "description": "Day-grouped agenda — events organized by date with overline day headers (Today, Tomorrow, Mon Jun 5) and a time marker per event. Inherits std-calendar's fetch + SELECT_DAY state machine; only bodyContent differs from std-calendar's month-grid and std-calendar-week-timeline's 7-col timeline. For appointment queues, class-roster schedules, court-deadline lists where users scan a vertical chronological flow grouped by day.",
  "orbitals": [
    {
      "name": "AgendaListCalendarOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        }
      ],
      "entity": {
        "name": "AgendaListEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "dateGroup",
            "type": "string",
            "default": ""
          },
          {
            "name": "selectedRange",
            "type": "string",
            "default": "month"
          }
        ]
      },
      "traits": [
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "AgendaListCalendar",
          "linkedEntity": "AgendaListEvent",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "type": "stack",
              "children": [
                {
                  "children": [
                    {
                      "direction": "horizontal",
                      "align": "center",
                      "gap": "sm",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "list"
                        },
                        {
                          "content": "Agenda",
                          "variant": "h2",
                          "type": "typography"
                        }
                      ]
                    },
                    {
                      "onSelect": "SELECT_DAY",
                      "type": "date-range-selector",
                      "selected": "@entity.selectedRange"
                    }
                  ],
                  "justify": "between",
                  "direction": "horizontal",
                  "gap": "md",
                  "align": "center",
                  "type": "stack"
                },
                {
                  "type": "divider"
                },
                {
                  "variant": "default",
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "type": "card",
                      "look": "flat-bordered",
                      "children": [
                        {
                          "type": "stack",
                          "align": "start",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "overline",
                                  "type": "typography",
                                  "content": "@config.timeBinding"
                                },
                                {
                                  "type": "icon",
                                  "size": "sm",
                                  "name": "clock",
                                  "color": "muted"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs",
                              "align": "center",
                              "className": "w-16 shrink-0",
                              "type": "stack"
                            },
                            {
                              "type": "divider",
                              "orientation": "vertical"
                            },
                            {
                              "type": "stack",
                              "className": "flex-1 min-w-0",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "className": "truncate",
                                      "type": "typography",
                                      "content": "@config.titleBinding",
                                      "variant": "h4",
                                      "weight": "medium"
                                    },
                                    {
                                      "label": "@config.badgeBinding",
                                      "size": "sm",
                                      "type": "badge",
                                      "variant": "default"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "align": "center",
                                  "direction": "horizontal",
                                  "justify": "between"
                                },
                                {
                                  "content": "@config.descriptionBinding",
                                  "variant": "body2",
                                  "type": "typography",
                                  "color": "muted",
                                  "className": "truncate"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs"
                            }
                          ]
                        }
                      ],
                      "padding": "md"
                    }
                  ],
                  "groupBy": "dateGroup",
                  "type": "data-list",
                  "entity": "@payload.data",
                  "gap": "md",
                  "fields": []
                }
              ],
              "className": "w-full p-card-md",
              "gap": "lg"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "AgendaListCalendarPage",
          "path": "/calendarevents/agenda",
          "traits": [
            {
              "ref": "AgendaListCalendar"
            }
          ]
        }
      ]
    }
  ]
}