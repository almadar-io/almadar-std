{
  "name": "std-step-flow-stepper-horizontal",
  "version": "1.0.0",
  "description": "Chrome-only horizontal stepper indicator — numbered badges with labels and connectors. No form body. Pure step navigation.",
  "orbitals": [
    {
      "name": "StepperHorizontalOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-step-flow",
          "as": "StepFlow"
        }
      ],
      "entity": {
        "name": "StepperHorizontalView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "StepFlow.traits.StepFlowReview",
          "name": "StepperHorizontalReview",
          "linkedEntity": "StepperHorizontalView",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "gap": "sm",
                  "fields": [],
                  "type": "data-list",
                  "entity": "@entity.wizardSteps",
                  "renderItem": [
                    "fn",
                    "step",
                    {
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "icon": "@step.icon",
                          "type": "button",
                          "variant": "ghost",
                          "disabled": "@step.isPending",
                          "label": "",
                          "actionPayload": {
                            "id": "@entity.id",
                            "stepKey": "@step.key"
                          },
                          "action": "ADVANCE"
                        },
                        {
                          "children": [
                            {
                              "variant": "@step.badgeVariant",
                              "type": "badge",
                              "label": "@step.indexLabel"
                            },
                            {
                              "variant": "caption",
                              "content": "@step.label",
                              "color": "@step.labelColor",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider",
                          "className": "flex-1 min-w-spacing-xl"
                        }
                      ],
                      "direction": "horizontal",
                      "align": "center"
                    }
                  ]
                }
              ],
              "gap": "sm",
              "direction": "horizontal",
              "className": "max-w-4xl mx-auto pt-section w-full justify-between",
              "type": "stack",
              "align": "center"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "StepperHorizontalPage",
          "path": "/stepper-horizontal",
          "traits": [
            {
              "ref": "StepperHorizontalReview"
            }
          ]
        }
      ]
    }
  ]
}