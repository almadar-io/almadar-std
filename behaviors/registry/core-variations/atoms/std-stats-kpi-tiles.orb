{
  "description": "KPI tiles — Stripe-dashboard style. 3–4 large numeric tiles arranged in a horizontal grid: huge typography number, label below, optional change indicator and sparkline hint. For trading dashboards, finance trackers, ecommerce metrics, payment volume. Same StatsItemStats trait, same aggregation pipeline, same listens as std-stats — only the bodyContent tree differs.",
  "name": "std-stats-kpi-tiles",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "An array of statistical cards displayed within the tile.",
            "items": {
              "properties": {
                "clickEvent": {
                  "name": "clickEvent",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string",
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "max": {
                  "name": "max",
                  "required": false,
                  "type": "number"
                },
                "prefix": {
                  "name": "prefix",
                  "required": false,
                  "type": "string"
                },
                "sparklineData": {
                  "items": {
                    "type": "number"
                  },
                  "name": "sparklineData",
                  "required": false,
                  "type": "array"
                },
                "suffix": {
                  "name": "suffix",
                  "required": false,
                  "type": "string"
                },
                "target": {
                  "name": "target",
                  "required": false,
                  "type": "number"
                },
                "trend": {
                  "name": "trend",
                  "required": false,
                  "type": "number"
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "required": false,
                  "type": "string",
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "required": false,
                  "type": "string",
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "value": {
                  "name": "value",
                  "required": false,
                  "type": "number"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string",
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                }
              },
              "type": "object"
            },
            "name": "cards",
            "synonyms": "items, data, elements",
            "type": "array"
          }
        ],
        "name": "KpiTileStats",
        "persistence": "runtime"
      },
      "name": "KpiTilesStatsOrbital",
      "pages": [
        {
          "name": "KpiTilesStatsPage",
          "path": "/kpi-tiles",
          "traits": [
            {
              "ref": "KpiTileStatsItemStats"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "default": {
                "className": "w-full",
                "entity": "@entity.cards",
                "fields": [],
                "gap": "lg",
                "minCardWidth": 220.0,
                "renderItem": [
                  "fn",
                  "card",
                  {
                    "children": [
                      {
                        "align": "center",
                        "children": [
                          {
                            "className": "uppercase tracking-wide",
                            "color": "muted",
                            "content": "@card.label",
                            "type": "typography",
                            "variant": "caption",
                            "weight": "medium"
                          },
                          {
                            "color": "muted",
                            "name": "@card.icon",
                            "size": "sm",
                            "type": "icon"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "xs",
                        "justify": "between",
                        "type": "stack"
                      },
                      {
                        "align": "baseline",
                        "children": [
                          {
                            "color": "muted",
                            "content": "@card.prefix",
                            "type": "typography",
                            "variant": "caption"
                          },
                          {
                            "className": "text-4xl font-bold tracking-tight",
                            "type": "animated-counter",
                            "value": "@card.value"
                          },
                          {
                            "color": "muted",
                            "content": "@card.suffix",
                            "type": "typography",
                            "variant": "caption"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "xs",
                        "type": "stack"
                      },
                      {
                        "align": "center",
                        "children": [
                          {
                            "showValue": true,
                            "size": "sm",
                            "type": "trend-indicator",
                            "value": "@card.trend"
                          },
                          {
                            "className": "flex-1",
                            "color": "auto",
                            "data": "@card.sparklineData",
                            "fill": true,
                            "height": 24.0,
                            "type": "sparkline"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "sm",
                        "type": "stack"
                      }
                    ],
                    "className": "rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-card-lg shadow-elevation-sm hover:shadow-elevation-md transition-shadow",
                    "direction": "vertical",
                    "gap": "sm",
                    "type": "stack"
                  }
                ],
                "type": "data-grid"
              },
              "type": "unknown"
            },
            "metrics": {
              "default": [
                {
                  "format": "currency",
                  "icon": "dollar-sign",
                  "label": "Revenue",
                  "prefix": "$",
                  "sparklineData": [
                    42000.0,
                    45000.0,
                    43500.0,
                    48000.0,
                    52000.0,
                    50500.0,
                    58000.0,
                    61000.0,
                    59000.0,
                    64200.0,
                    67800.0,
                    72400.0
                  ],
                  "trend": 12.4,
                  "trendFormat": "percent",
                  "trendPolarity": "higher-is-better",
                  "value": 72400.0,
                  "variant": "success"
                },
                {
                  "format": "number",
                  "icon": "users",
                  "label": "Active Users",
                  "sparklineData": [
                    2800.0,
                    2950.0,
                    2900.0,
                    3100.0,
                    3050.0,
                    3200.0,
                    3180.0,
                    3240.0
                  ],
                  "trend": 8.1,
                  "trendFormat": "percent",
                  "trendPolarity": "higher-is-better",
                  "value": 3240.0,
                  "variant": "primary"
                },
                {
                  "format": "percent",
                  "icon": "trending-up",
                  "label": "Conversion",
                  "sparklineData": [
                    5.2,
                    5.0,
                    4.8,
                    4.9,
                    4.6,
                    4.7,
                    4.5,
                    4.7
                  ],
                  "suffix": "%",
                  "trend": -1.2,
                  "trendFormat": "percent",
                  "trendPolarity": "higher-is-better",
                  "value": 4.7,
                  "variant": "info"
                },
                {
                  "format": "percent",
                  "icon": "trending-down",
                  "label": "Churn",
                  "sparklineData": [
                    2.3,
                    2.1,
                    2.2,
                    2.0,
                    1.9,
                    2.0,
                    1.8,
                    1.9
                  ],
                  "suffix": "%",
                  "trend": -0.4,
                  "trendFormat": "percent",
                  "trendPolarity": "lower-is-better",
                  "value": 1.9,
                  "variant": "warning"
                }
              ],
              "type": "unknown"
            }
          },
          "linkedEntity": "KpiTileStats",
          "name": "KpiTileStatsItemStats",
          "ref": "Stats.traits.StatsItemStats"
        }
      ],
      "uses": [
        {
          "as": "Stats",
          "from": "std/behaviors/std-stats"
        }
      ]
    }
  ],
  "version": "1.2.0"
}