{
  "name": "std-stats-kpi-tiles",
  "version": "1.2.0",
  "description": "KPI tiles — Stripe-dashboard style. 3–4 large numeric tiles arranged in a horizontal grid: huge typography number, label below, optional change indicator and sparkline hint. For trading dashboards, finance trackers, ecommerce metrics, payment volume. Same StatsItemStats trait, same aggregation pipeline, same listens as std-stats — only the bodyContent tree differs.",
  "orbitals": [
    {
      "name": "KpiTilesStatsOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "KpiTileStats",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false,
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": false
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false,
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false,
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                }
              }
            },
            "description": "An array of statistical cards displayed within the tile.",
            "synonyms": "items, data, elements"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "KpiTileStatsItemStats",
          "linkedEntity": "KpiTileStats",
          "config": {
            "bodyContent": {
              "className": "w-full",
              "gap": "lg",
              "type": "data-grid",
              "fields": [],
              "renderItem": [
                "fn",
                "card",
                {
                  "type": "stack",
                  "gap": "sm",
                  "direction": "vertical",
                  "className": "rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-card-lg shadow-elevation-sm hover:shadow-elevation-md transition-shadow",
                  "children": [
                    {
                      "children": [
                        {
                          "color": "muted",
                          "content": "@card.label",
                          "variant": "caption",
                          "type": "typography",
                          "weight": "medium",
                          "className": "uppercase tracking-wide"
                        },
                        {
                          "type": "icon",
                          "size": "sm",
                          "name": "@card.icon",
                          "color": "muted"
                        }
                      ],
                      "justify": "between",
                      "gap": "xs",
                      "type": "stack",
                      "align": "center",
                      "direction": "horizontal"
                    },
                    {
                      "type": "stack",
                      "align": "baseline",
                      "children": [
                        {
                          "content": "@card.prefix",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "className": "text-4xl font-bold tracking-tight",
                          "value": "@card.value",
                          "type": "animated-counter"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "@card.suffix"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "xs"
                    },
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "showValue": true,
                          "value": "@card.trend",
                          "size": "sm",
                          "type": "trend-indicator"
                        },
                        {
                          "height": 24.0,
                          "className": "flex-1",
                          "color": "auto",
                          "fill": true,
                          "data": "@card.sparklineData",
                          "type": "sparkline"
                        }
                      ]
                    }
                  ]
                }
              ],
              "entity": "@entity.cards",
              "minCardWidth": 220.0
            },
            "metrics": [
              {
                "trendPolarity": "higher-is-better",
                "prefix": "$",
                "format": "currency",
                "value": 72400.0,
                "variant": "success",
                "label": "Revenue",
                "icon": "dollar-sign",
                "sparklineData": [
                  42000.0,
                  45000.0,
                  43500.0,
                  48000.0,
                  52000.0,
                  50500.0,
                  58000.0,
                  61000.0,
                  59000.0,
                  64200.0,
                  67800.0,
                  72400.0
                ],
                "trend": 12.4,
                "trendFormat": "percent"
              },
              {
                "trendFormat": "percent",
                "label": "Active Users",
                "sparklineData": [
                  2800.0,
                  2950.0,
                  2900.0,
                  3100.0,
                  3050.0,
                  3200.0,
                  3180.0,
                  3240.0
                ],
                "icon": "users",
                "trend": 8.1,
                "format": "number",
                "value": 3240.0,
                "trendPolarity": "higher-is-better",
                "variant": "primary"
              },
              {
                "format": "percent",
                "suffix": "%",
                "icon": "trending-up",
                "variant": "info",
                "trend": -1.2,
                "value": 4.7,
                "sparklineData": [
                  5.2,
                  5.0,
                  4.8,
                  4.9,
                  4.6,
                  4.7,
                  4.5,
                  4.7
                ],
                "trendPolarity": "higher-is-better",
                "label": "Conversion",
                "trendFormat": "percent"
              },
              {
                "icon": "trending-down",
                "label": "Churn",
                "value": 1.9,
                "trendFormat": "percent",
                "suffix": "%",
                "trend": -0.4,
                "trendPolarity": "lower-is-better",
                "variant": "warning",
                "sparklineData": [
                  2.3,
                  2.1,
                  2.2,
                  2.0,
                  1.9,
                  2.0,
                  1.8,
                  1.9
                ],
                "format": "percent"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "KpiTilesStatsPage",
          "path": "/kpi-tiles",
          "traits": [
            {
              "ref": "KpiTileStatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
