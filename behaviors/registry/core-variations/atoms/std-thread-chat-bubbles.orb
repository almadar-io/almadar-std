{
  "name": "std-thread-chat-bubbles",
  "version": "1.0.3",
  "description": "Chat-bubbles thread — iMessage/WhatsApp DM style: two-party back-and-forth with sender-vs-receiver bubble alignment and tint.",
  "orbitals": [
    {
      "name": "ChatBubblesThreadOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "ChatBubblesPost",
        "collection": "chatbubblesposts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string",
            "default": "them",
            "values": [
              "me",
              "them"
            ]
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientId",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replies",
            "type": "relation",
            "relation": {
              "entity": "ChatBubblesPost",
              "cardinality": "many"
            }
          },
          {
            "name": "focusedRow",
            "type": "object",
            "default": {}
          }
        ]
      },
      "traits": [
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "ChatBubblesThread",
          "linkedEntity": "ChatBubblesPost",
          "config": {
            "recipientName": "Alex Rivera",
            "bodyContent": {
              "type": "stack",
              "gap": "none",
              "className": "w-full px-card-md py-section h-full",
              "children": [
                {
                  "children": [
                    {
                      "name": "@config.recipientName",
                      "type": "avatar",
                      "size": "md"
                    },
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "className": "flex-1",
                      "children": [
                        {
                          "weight": "medium",
                          "type": "typography",
                          "content": "@config.recipientName",
                          "variant": "body"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Active now"
                        }
                      ],
                      "gap": "xs"
                    }
                  ],
                  "align": "center",
                  "type": "stack",
                  "gap": "sm",
                  "className": "pb-md border-b border-[var(--color-border)]",
                  "direction": "horizontal"
                },
                {
                  "senderField": "authorId",
                  "type": "data-list",
                  "className": "flex-1 overflow-y-auto py-md",
                  "gap": "sm",
                  "currentUser": "me",
                  "fields": [
                    {
                      "name": "content",
                      "variant": "body"
                    },
                    {
                      "format": "date",
                      "name": "createdAt"
                    }
                  ],
                  "entity": "@payload.data",
                  "variant": "message"
                },
                {
                  "children": [
                    {
                      "inputType": "text",
                      "action": "EDIT_REPLY",
                      "type": "input",
                      "placeholder": "Message…"
                    },
                    {
                      "variant": "primary",
                      "action": "SUBMIT_REPLY",
                      "type": "button",
                      "label": "Send",
                      "icon": "send"
                    }
                  ],
                  "type": "stack",
                  "direction": "horizontal",
                  "align": "center",
                  "className": "mt-md border-t border-[var(--color-border)] pt-md",
                  "gap": "sm"
                }
              ],
              "direction": "vertical"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "ChatBubblesThreadPage",
          "path": "/chat-thread",
          "traits": [
            {
              "ref": "ChatBubblesThread"
            }
          ]
        }
      ]
    }
  ]
}