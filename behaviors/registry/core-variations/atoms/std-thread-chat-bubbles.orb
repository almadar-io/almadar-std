{
  "name": "std-thread-chat-bubbles",
  "version": "1.0.0",
  "description": "Chat-bubbles thread — iMessage/WhatsApp DM style: two-party back-and-forth with sender-vs-receiver bubble alignment and tint.",
  "orbitals": [
    {
      "name": "ChatBubblesThreadOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "ChatBubblesPost",
        "collection": "chatbubblesposts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientId",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "ChatBubblesThread",
          "linkedEntity": "ChatBubblesPost",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "className": "max-w-2xl mx-auto px-card-md py-section h-full",
              "gap": "none",
              "type": "stack",
              "children": [
                {
                  "className": "pb-md border-b border-[var(--color-border)]",
                  "children": [
                    {
                      "type": "avatar",
                      "size": "md",
                      "name": "Alex Rivera"
                    },
                    {
                      "children": [
                        {
                          "content": "Alex Rivera",
                          "type": "typography",
                          "weight": "medium",
                          "variant": "body"
                        },
                        {
                          "content": "Active now",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "className": "flex-1",
                      "direction": "vertical",
                      "gap": "xs"
                    }
                  ],
                  "gap": "sm",
                  "align": "center",
                  "direction": "horizontal",
                  "type": "stack"
                },
                {
                  "fields": [],
                  "gap": "sm",
                  "variant": "message",
                  "className": "flex-1 overflow-y-auto py-md",
                  "senderField": "authorId",
                  "type": "data-list",
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "className": "@item.isMe ? 'w-full flex-row-reverse' : 'w-full flex-row'",
                      "type": "stack",
                      "align": "end",
                      "children": [
                        {
                          "type": "avatar",
                          "className": "@item.isMe ? 'invisible' : 'visible'",
                          "name": "@item.authorName",
                          "size": "sm"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "card",
                              "look": "@item.isMe ? 'filled' : 'flat-bordered'",
                              "children": {
                                "type": "typography",
                                "content": "@item.content",
                                "variant": "body"
                              },
                              "padding": "sm",
                              "className": "@item.isMe ? 'rounded-lg rounded-br-sm bg-[var(--color-primary)] text-[var(--color-primary-foreground)] shadow-sm' : 'rounded-lg rounded-bl-sm bg-[var(--color-muted)] text-[var(--color-foreground)] shadow-sm'"
                            },
                            {
                              "content": "@item.createdAt",
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography"
                            }
                          ],
                          "gap": "xs",
                          "className": "@item.isMe ? 'max-w-[70%] items-end' : 'max-w-[70%] items-start'",
                          "direction": "vertical"
                        }
                      ]
                    }
                  ],
                  "currentUser": "me",
                  "entity": "@payload.data"
                },
                {
                  "children": [
                    {
                      "action": "EDIT_REPLY",
                      "inputType": "text",
                      "placeholder": "Message…",
                      "type": "input"
                    },
                    {
                      "variant": "primary",
                      "type": "button",
                      "label": "Send",
                      "icon": "send",
                      "action": "SUBMIT_REPLY"
                    }
                  ],
                  "type": "stack",
                  "direction": "horizontal",
                  "gap": "sm",
                  "className": "mt-md border-t border-[var(--color-border)] pt-md",
                  "align": "center"
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "ChatBubblesThreadPage",
          "path": "/chat-thread",
          "traits": [
            {
              "ref": "ChatBubblesThread"
            }
          ]
        }
      ]
    }
  ]
}