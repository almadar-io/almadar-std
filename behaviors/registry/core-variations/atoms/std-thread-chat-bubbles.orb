{
  "description": "Chat-bubbles thread — iMessage/WhatsApp DM style: two-party back-and-forth with sender-vs-receiver bubble alignment and tint.",
  "name": "std-thread-chat-bubbles",
  "orbitals": [
    {
      "entity": {
        "collection": "chatbubblesposts",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Reference to the preceding message in the conversation.",
            "name": "parentId",
            "synonyms": "previous, predecessor, parent",
            "type": "string"
          },
          {
            "description": "Identifier for the initial message in the conversation.",
            "name": "threadRootId",
            "required": true,
            "synonyms": "rootId, originalId, startingMessageId",
            "type": "string"
          },
          {
            "default": "them",
            "description": "Identifies the user who created the message.",
            "name": "authorId",
            "synonyms": "user, sender, creator",
            "type": "string",
            "values": [
              "me",
              "them"
            ]
          },
          {
            "description": "The name of the user who created the post.",
            "name": "authorName",
            "required": true,
            "synonyms": "username, user, creator, poster",
            "type": "string"
          },
          {
            "description": "Identifier of the message recipient.",
            "name": "recipientId",
            "synonyms": "receiver, target, addressee",
            "type": "string"
          },
          {
            "description": "The text content of the message.",
            "name": "content",
            "required": true,
            "synonyms": "message, text, body",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": 0.0,
            "description": "The number of votes or ratings associated with this item.",
            "name": "voteCount",
            "synonyms": "rating, score, likes, upvotes",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The number of replies to this post.",
            "name": "replyCount",
            "synonyms": "count, number of replies, responses",
            "type": "number"
          },
          {
            "description": "A list of child posts in a conversation thread.",
            "name": "replies",
            "relation": {
              "cardinality": "many",
              "entity": "ChatBubblesPost"
            },
            "synonyms": "child posts, responses, replies, sub-messages",
            "type": "relation"
          },
          {
            "default": {},
            "description": "The currently selected or active row within the chat thread.",
            "name": "focusedRow",
            "synonyms": "selection, active, current",
            "type": "object"
          }
        ],
        "name": "ChatBubblesPost",
        "persistence": "persistent"
      },
      "name": "ChatBubblesThreadOrbital",
      "pages": [
        {
          "name": "ChatBubblesThreadPage",
          "path": "/chat-thread",
          "traits": [
            {
              "ref": "ChatBubblesThread"
            },
            {
              "ref": "Avatar1"
            },
            {
              "ref": "Typography1"
            },
            {
              "ref": "Typography2"
            },
            {
              "ref": "DataList1"
            },
            {
              "ref": "FormSection1"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "name": {
              "default": "@config.recipientName",
              "type": "unknown"
            },
            "size": {
              "default": "md",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "Avatar1",
          "ref": "Avatar.traits.AvatarRender"
        },
        {
          "config": {
            "content": {
              "default": "@config.recipientName",
              "type": "unknown"
            },
            "variant": {
              "default": "body",
              "type": "unknown"
            },
            "weight": {
              "default": "medium",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "Typography1",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "color": {
              "default": "muted",
              "type": "unknown"
            },
            "content": {
              "default": "Active now",
              "type": "unknown"
            },
            "variant": {
              "default": "caption",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "Typography2",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "className": {
              "default": "flex-1 overflow-y-auto py-md",
              "type": "unknown"
            },
            "currentUser": {
              "default": "me",
              "type": "unknown"
            },
            "entity": {
              "default": "@payload.data",
              "type": "unknown"
            },
            "fields": {
              "default": [
                {
                  "name": "content",
                  "variant": "body"
                },
                {
                  "format": "date",
                  "name": "createdAt"
                }
              ],
              "type": "unknown"
            },
            "gap": {
              "default": "sm",
              "type": "unknown"
            },
            "senderField": {
              "default": "authorId",
              "type": "unknown"
            },
            "variant": {
              "default": "message",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "DataList1",
          "ref": "DataList.traits.DataListRender"
        },
        {
          "config": {
            "entity": {
              "default": "@entity",
              "type": "unknown"
            },
            "fields": {
              "default": [
                "content"
              ],
              "type": "unknown"
            },
            "mode": {
              "default": "edit",
              "type": "unknown"
            },
            "submitEvent": {
              "default": "REPLY",
              "type": "unknown"
            },
            "submitLabel": {
              "default": "Send",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "FormSection1",
          "ref": "FormSection.traits.FormSectionRender"
        },
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      "@trait.Avatar1",
                      {
                        "children": [
                          "@trait.Typography1",
                          "@trait.Typography2"
                        ],
                        "className": "flex-1",
                        "direction": "vertical",
                        "gap": "xs",
                        "type": "stack"
                      }
                    ],
                    "className": "pb-md border-b border-[var(--color-border)]",
                    "direction": "horizontal",
                    "gap": "sm",
                    "type": "stack"
                  },
                  "@trait.DataList1",
                  {
                    "children": [
                      "@trait.FormSection1"
                    ],
                    "className": "mt-md border-t border-[var(--color-border)] pt-md",
                    "direction": "vertical",
                    "gap": "sm",
                    "type": "stack"
                  }
                ],
                "className": "w-full px-card-md py-section h-full",
                "direction": "vertical",
                "gap": "none",
                "type": "stack"
              },
              "type": "unknown"
            },
            "recipientName": {
              "default": "Alex Rivera",
              "type": "unknown"
            }
          },
          "linkedEntity": "ChatBubblesPost",
          "name": "ChatBubblesThread",
          "ref": "Thread.traits.ThreadPostBrowse"
        }
      ],
      "uses": [
        {
          "as": "Thread",
          "from": "std/behaviors/std-thread"
        },
        {
          "as": "Avatar",
          "from": "std/behaviors/ui-avatar"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "DataList",
          "from": "std/behaviors/ui-data-list"
        },
        {
          "as": "FormSection",
          "from": "std/behaviors/ui-form-section"
        }
      ]
    }
  ],
  "version": "1.0.3"
}