{
  "description": "Donut chart view. Embeds std-graphs with the donut chartType — pie with a hollow centre that frees up space for a centered total/label. Reads better than pie when slices are similarly sized.",
  "name": "std-graphs-donut",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "Data points used to render the chart.",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "chartData",
            "synonyms": "data, values, series",
            "type": "array"
          }
        ],
        "name": "DonutGraphItem",
        "persistence": "runtime"
      },
      "name": "DonutGraphItemOrbital",
      "pages": [
        {
          "name": "DonutGraphPage",
          "path": "/donut-graph",
          "traits": [
            {
              "ref": "DonutGraphItemGraph"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "chartType": {
              "default": "donut",
              "type": "unknown"
            }
          },
          "linkedEntity": "DonutGraphItem",
          "name": "DonutGraphItemGraph",
          "ref": "Graph.traits.GraphItemGraph"
        }
      ],
      "uses": [
        {
          "as": "Graph",
          "from": "std/behaviors/std-graphs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}