{
  "name": "std-browse-command-palette",
  "version": "1.0.0",
  "description": "Command-palette browse — keyboard-first search-driven UX inspired by Linear Cmd+K and Raycast. Full-width search input at the top of the viewport; typing emits REFETCH_QUERY on every keystroke; results render as a tight data-list of compact rows with kbd hints. Same BrowseItemBrowse trait, same state machine, same emits/listens as std-browse — only the bodyContent tree differs.",
  "orbitals": [
    {
      "name": "CommandPaletteBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "CommandPaletteItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "CommandPaletteBrowse",
          "linkedEntity": "CommandPaletteItem",
          "config": {
            "bodyContent": {
              "gap": "none",
              "children": [
                {
                  "action": "REFETCH_QUERY",
                  "placeholder": "Type to search…",
                  "className": "text-lg",
                  "type": "input",
                  "inputType": "search"
                },
                {
                  "align": "center",
                  "gap": "sm",
                  "direction": "horizontal",
                  "className": "px-card-md py-2 border-b border-[var(--color-border)]",
                  "type": "stack",
                  "children": [
                    {
                      "className": "px-1.5 py-0.5 border rounded font-mono",
                      "content": "↑↓",
                      "type": "typography",
                      "variant": "caption"
                    },
                    {
                      "content": "Navigate",
                      "type": "typography",
                      "color": "muted",
                      "variant": "caption"
                    },
                    {
                      "type": "typography",
                      "className": "px-1.5 py-0.5 border rounded font-mono",
                      "content": "↵",
                      "variant": "caption"
                    },
                    {
                      "content": "Select",
                      "type": "typography",
                      "variant": "caption",
                      "color": "muted"
                    },
                    {
                      "className": "px-1.5 py-0.5 border rounded font-mono",
                      "type": "typography",
                      "variant": "caption",
                      "content": "esc"
                    },
                    {
                      "color": "muted",
                      "variant": "caption",
                      "content": "Close",
                      "type": "typography"
                    }
                  ]
                },
                {
                  "entity": "@payload.data",
                  "fields": [],
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "file"
                        },
                        {
                          "type": "stack",
                          "className": "flex-1 min-w-0",
                          "direction": "vertical",
                          "gap": "xs",
                          "children": [
                            {
                              "content": "@item.name",
                              "variant": "body",
                              "type": "typography",
                              "weight": "medium",
                              "className": "truncate"
                            },
                            {
                              "variant": "caption",
                              "type": "typography",
                              "color": "muted",
                              "content": "@item.description",
                              "className": "truncate"
                            }
                          ]
                        },
                        {
                          "label": "@item.status",
                          "type": "badge",
                          "variant": "default"
                        },
                        {
                          "className": "px-1.5 py-0.5 border rounded font-mono",
                          "type": "typography",
                          "content": "↵",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "md",
                      "className": "px-card-md py-3 hover:bg-muted cursor-pointer"
                    }
                  ],
                  "selectable": true,
                  "gap": "none",
                  "type": "data-list"
                }
              ],
              "direction": "vertical",
              "className": "max-w-2xl mx-auto pt-section",
              "type": "stack"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "CommandPalettePage",
          "path": "/cmd-browse",
          "traits": [
            {
              "ref": "CommandPaletteBrowse"
            }
          ]
        }
      ]
    }
  ]
}