{
  "name": "std-browse-command-palette",
  "version": "1.0.1",
  "description": "Command-palette browse — VS Code/Linear/Raycast floating overlay with search input header, tight result list, and kbd hint chips.",
  "orbitals": [
    {
      "name": "CommandPaletteBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "CommandPaletteItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "The item's identifier or display text.",
            "synonyms": "title, label, identifier"
          },
          {
            "name": "description",
            "type": "string",
            "description": "A brief explanation of the item's content or function.",
            "synonyms": "text, details, explanation, notes"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Indicates the current operational state of the item.",
            "synonyms": "state, condition, enabled"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "CommandPaletteBrowse",
          "linkedEntity": "CommandPaletteItem",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "className": "pt-card-md px-card-md w-full",
              "gap": "lg",
              "type": "stack",
              "children": [
                {
                  "look": "elevated",
                  "className": "w-full max-w-2xl",
                  "padding": "md",
                  "children": [
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "className": "text-muted-foreground",
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "action": "REFETCH_QUERY",
                              "inputType": "search",
                              "type": "input",
                              "className": "flex-1",
                              "placeholder": "@config.searchPlaceholder"
                            },
                            {
                              "label": "ESC",
                              "type": "badge",
                              "variant": "neutral",
                              "size": "sm"
                            }
                          ],
                          "direction": "horizontal",
                          "className": "px-card-md py-3",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "none",
                          "type": "data-list",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "align": "center",
                              "className": "px-3 py-2 rounded-sm cursor-pointer hover:bg-muted/50 transition-colors",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file"
                                },
                                {
                                  "type": "stack",
                                  "className": "flex-1 min-w-0",
                                  "direction": "vertical",
                                  "gap": "none",
                                  "children": [
                                    {
                                      "weight": "medium",
                                      "content": "@config.titleBinding",
                                      "className": "truncate",
                                      "type": "typography",
                                      "variant": "body"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "caption",
                                      "className": "truncate",
                                      "content": "@config.descriptionBinding",
                                      "color": "muted"
                                    }
                                  ]
                                },
                                {
                                  "size": "sm",
                                  "type": "badge",
                                  "label": "@config.badgeBinding",
                                  "variant": "neutral"
                                },
                                {
                                  "label": "↵",
                                  "size": "sm",
                                  "type": "badge",
                                  "variant": "neutral"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ],
                          "className": "max-h-96 overflow-y-auto p-1"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "badge",
                              "label": "↑↓",
                              "size": "sm",
                              "variant": "neutral"
                            },
                            {
                              "variant": "caption",
                              "type": "typography",
                              "color": "muted",
                              "content": "Navigate"
                            },
                            {
                              "variant": "neutral",
                              "type": "badge",
                              "label": "↵",
                              "size": "sm"
                            },
                            {
                              "color": "muted",
                              "type": "typography",
                              "content": "Select",
                              "variant": "caption"
                            },
                            {
                              "className": "ml-auto",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "neutral",
                                  "label": "⌘K",
                                  "type": "badge",
                                  "size": "sm"
                                },
                                {
                                  "content": "Toggle",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "className": "px-card-md py-2 bg-[var(--color-surface-muted)]"
                        }
                      ],
                      "gap": "none"
                    }
                  ],
                  "type": "card"
                }
              ],
              "align": "center"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "CommandPalettePage",
          "path": "/cmd-browse",
          "traits": [
            {
              "ref": "CommandPaletteBrowse"
            }
          ]
        }
      ]
    }
  ]
}
