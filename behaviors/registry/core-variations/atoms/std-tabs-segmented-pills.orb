{
  "description": "Segmented-pills tabs — iOS-style segmented control: pill-shaped tabs sit in a single rounded background bar, no underline, active tab carries a filled background. Compact and modern; ideal for settings UIs and mode-switchers. Same TabsItemTabs trait, state machine, emits/listens as std-tabs — only the bodyContent tree differs.",
  "name": "std-tabs-segmented-pills",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "",
            "description": "Index of the currently selected tab.",
            "name": "activeTab",
            "synonyms": "selectedIndex, selectedIndex, currentTab",
            "type": "string"
          },
          {
            "default": [],
            "description": "A collection of tab specifications defining the available options.",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "items",
            "synonyms": "tabs, options, choices, entries",
            "type": "array"
          }
        ],
        "name": "SegmentedPillsTabsItem",
        "persistence": "runtime"
      },
      "name": "SegmentedPillsTabsOrbital",
      "pages": [
        {
          "name": "SegmentedPillsTabsPage",
          "path": "/segmented-tabs",
          "traits": [
            {
              "ref": "SegmentedPillsTabs"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "bodyContent": {
              "align": "center",
              "children": [
                {
                  "activeTab": "@entity.activeTab",
                  "className": "gap-1",
                  "items": [
                    {
                      "id": "tab1",
                      "label": "Tab 1"
                    },
                    {
                      "id": "tab2",
                      "label": "Tab 2"
                    },
                    {
                      "id": "tab3",
                      "label": "Tab 3"
                    }
                  ],
                  "orientation": "horizontal",
                  "tabChangeEvent": "TAB_CHANGED",
                  "type": "tabs",
                  "variant": "pills"
                }
              ],
              "className": "inline-flex p-1 rounded-pill bg-muted",
              "direction": "horizontal",
              "gap": "none",
              "type": "stack"
            }
          },
          "linkedEntity": "SegmentedPillsTabsItem",
          "name": "SegmentedPillsTabs",
          "ref": "Tabs.traits.TabsItemTabs"
        }
      ],
      "uses": [
        {
          "as": "Tabs",
          "from": "std/behaviors/std-tabs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}