{
  "description": "Minimal chrome. Embeds std-app-layout with minimal layout pattern + a placeholder content trait so the main slot has visible content.",
  "name": "std-app-layout-minimal",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MinimalLayoutData",
        "persistence": "runtime"
      },
      "name": "MinimalLayoutOrbital",
      "pages": [
        {
          "name": "MinimalLayoutPage",
          "path": "/minimal-layout",
          "traits": [
            {
              "ref": "MinimalLayout"
            },
            {
              "ref": "MinimalContent"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "linkedEntity": "MinimalLayoutData",
          "name": "MinimalContent",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "showing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Override the contentTrait config to fill this area with your own trait.",
                      "icon": "layout",
                      "title": "Minimal Layout",
                      "type": "empty-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "showing",
                "to": "showing"
              }
            ]
          }
        },
        {
          "config": {
            "appName": {
              "default": "Minimal Demo",
              "type": "unknown"
            },
            "contentTrait": {
              "default": "@trait.MinimalContent",
              "type": "unknown"
            },
            "layoutMode": {
              "default": "minimal",
              "type": "unknown"
            },
            "navItems": {
              "default": [
                {
                  "href": "/",
                  "icon": "home",
                  "label": "Home"
                },
                {
                  "href": "/contacts",
                  "icon": "users",
                  "label": "Contacts"
                },
                {
                  "href": "/tasks",
                  "icon": "check-square",
                  "label": "Tasks"
                },
                {
                  "href": "/settings",
                  "icon": "settings",
                  "label": "Settings"
                }
              ],
              "type": "unknown"
            }
          },
          "linkedEntity": "MinimalLayoutData",
          "name": "MinimalLayout",
          "ref": "AppLayout.traits.AppLayout"
        }
      ],
      "uses": [
        {
          "as": "AppLayout",
          "from": "std/behaviors/std-app-layout"
        }
      ]
    }
  ],
  "version": "1.1.0"
}