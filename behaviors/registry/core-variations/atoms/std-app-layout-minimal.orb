{
  "description": "Minimal chrome. Embeds std-app-layout with minimal layout pattern + a placeholder content trait so the main slot has visible content.",
  "name": "std-app-layout-minimal",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "MinimalLayoutData",
        "persistence": "runtime"
      },
      "name": "MinimalLayoutOrbital",
      "pages": [
        {
          "name": "MinimalLayoutPage",
          "path": "/minimal-layout",
          "traits": [
            {
              "ref": "MinimalLayout"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "icon": {
              "default": "layout",
              "type": "unknown"
            },
            "message": {
              "default": "Override the contentTrait config to fill this area with your own trait.",
              "type": "unknown"
            },
            "title": {
              "default": "Minimal Layout",
              "type": "unknown"
            }
          },
          "linkedEntity": "MinimalLayoutData",
          "name": "MinimalEmptyState",
          "ref": "EmptyState.traits.EmptyStateRender"
        },
        {
          "config": {
            "appName": {
              "default": "Minimal Demo",
              "type": "unknown"
            },
            "contentTrait": {
              "default": "@trait.MinimalEmptyState",
              "type": "unknown"
            },
            "layoutMode": {
              "default": "minimal",
              "type": "unknown"
            },
            "navItems": {
              "default": [
                {
                  "href": "/",
                  "icon": "home",
                  "label": "Home"
                },
                {
                  "href": "/contacts",
                  "icon": "users",
                  "label": "Contacts"
                },
                {
                  "href": "/tasks",
                  "icon": "check-square",
                  "label": "Tasks"
                },
                {
                  "href": "/settings",
                  "icon": "settings",
                  "label": "Settings"
                }
              ],
              "type": "unknown"
            }
          },
          "linkedEntity": "MinimalLayoutData",
          "name": "MinimalLayout",
          "ref": "AppLayout.traits.AppLayout"
        }
      ],
      "uses": [
        {
          "as": "AppLayout",
          "from": "std/behaviors/std-app-layout"
        },
        {
          "as": "EmptyState",
          "from": "std/behaviors/ui-empty-state"
        }
      ]
    }
  ],
  "version": "1.1.0"
}