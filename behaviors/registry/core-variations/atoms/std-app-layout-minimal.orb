{
  "name": "std-app-layout-minimal",
  "version": "1.1.0",
  "description": "Minimal chrome. Embeds std-app-layout with minimal layout pattern + a placeholder content trait so the main slot has visible content.",
  "orbitals": [
    {
      "name": "MinimalLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppLayout"
        }
      ],
      "entity": {
        "name": "MinimalLayoutData",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "MinimalContent",
          "category": "interaction",
          "linkedEntity": "MinimalLayoutData",
          "stateMachine": {
            "states": [
              {
                "name": "showing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "showing",
                "to": "showing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Override the contentTrait config to fill this area with your own trait.",
                      "type": "empty-state",
                      "icon": "layout",
                      "title": "Minimal Layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "AppLayout.traits.AppLayout",
          "name": "MinimalLayout",
          "linkedEntity": "MinimalLayoutData",
          "config": {
            "appName": "Minimal Demo",
            "layoutMode": "minimal",
            "navItems": [
              {
                "href": "/",
                "icon": "home",
                "label": "Home"
              },
              {
                "icon": "users",
                "label": "Contacts",
                "href": "/contacts"
              },
              {
                "label": "Tasks",
                "href": "/tasks",
                "icon": "check-square"
              },
              {
                "label": "Settings",
                "href": "/settings",
                "icon": "settings"
              }
            ],
            "contentTrait": "@trait.MinimalContent"
          }
        }
      ],
      "pages": [
        {
          "name": "MinimalLayoutPage",
          "path": "/minimal-layout",
          "traits": [
            {
              "ref": "MinimalLayout"
            },
            {
              "ref": "MinimalContent"
            }
          ]
        }
      ]
    }
  ]
}
