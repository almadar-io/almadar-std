{
  "name": "std-display-hero-banner",
  "version": "2.0.0",
  "description": "Hero marquee — centered headline + lead + single primary CTA on a gradient backdrop card. Landing-page above-the-fold.",
  "orbitals": [
    {
      "name": "HeroBannerDisplayOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-display",
          "as": "Display"
        }
      ],
      "entity": {
        "name": "HeroPromo",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eyebrow",
            "type": "string",
            "default": "Announcing"
          },
          {
            "name": "headline",
            "type": "string",
            "required": true
          },
          {
            "name": "lead",
            "type": "string"
          },
          {
            "name": "ctaLabel",
            "type": "string",
            "default": "Get started"
          },
          {
            "name": "ctaEvent",
            "type": "string",
            "default": "PRIMARY_CTA"
          }
        ]
      },
      "traits": [
        {
          "ref": "Display.traits.DisplayItemDisplay",
          "name": "HeroBannerDisplay",
          "linkedEntity": "HeroPromo",
          "config": {
            "bodyContent": {
              "className": "w-full max-w-5xl mx-auto rounded-xl bg-gradient-to-br from-[var(--color-surface)] via-[var(--color-background)] to-[var(--color-muted)]",
              "align": "center",
              "children": [
                {
                  "type": "card",
                  "padding": "lg",
                  "look": "elevated",
                  "children": [
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "badge",
                          "label": "@entity.eyebrow",
                          "variant": "neutral",
                          "size": "sm"
                        },
                        {
                          "variant": "h1",
                          "content": "@entity.headline",
                          "weight": "bold",
                          "className": "tracking-tight text-balance max-w-3xl",
                          "type": "typography"
                        },
                        {
                          "content": "@entity.lead",
                          "variant": "body",
                          "className": "text-lg max-w-2xl leading-relaxed",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "action": "@entity.ctaEvent",
                          "size": "lg",
                          "type": "button",
                          "label": "@entity.ctaLabel",
                          "variant": "primary"
                        }
                      ],
                      "className": "text-center py-section px-card-md",
                      "gap": "xl",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                }
              ],
              "type": "stack",
              "direction": "vertical"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "HeroBannerDisplayPage",
          "path": "/hero-display",
          "traits": [
            {
              "ref": "HeroBannerDisplay"
            }
          ]
        }
      ]
    }
  ]
}