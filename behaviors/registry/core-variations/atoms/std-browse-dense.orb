{
  "name": "std-browse-dense",
  "version": "1.0.0",
  "description": "Spreadsheet-style dense browse — sortable column-row table, sticky header, monospaced numerics, tight 8px row padding.",
  "orbitals": [
    {
      "name": "DenseBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "DenseRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "change",
            "type": "string"
          },
          {
            "name": "volume",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "ok",
            "values": [
              "ok",
              "warn",
              "error"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DenseBrowse",
          "linkedEntity": "DenseRow",
          "config": {
            "bodyContent": {
              "children": [
                {
                  "gap": "sm",
                  "align": "center",
                  "children": [
                    {
                      "type": "icon",
                      "name": "search"
                    },
                    {
                      "type": "input",
                      "placeholder": "Filter records…",
                      "inputType": "search",
                      "action": "REFETCH_QUERY"
                    }
                  ],
                  "type": "stack",
                  "direction": "horizontal",
                  "className": "max-w-md"
                },
                {
                  "type": "stack",
                  "gap": "none",
                  "className": "rounded-md border border-[var(--color-border)] overflow-hidden bg-[var(--color-surface)]",
                  "direction": "vertical",
                  "children": [
                    {
                      "columns": [
                        {
                          "width": "w-28",
                          "label": "ID",
                          "field": "id",
                          "align": "left",
                          "className": "font-mono text-[var(--color-text-muted)] truncate",
                          "header": "ID",
                          "key": "id"
                        },
                        {
                          "key": "name",
                          "field": "name",
                          "header": "NAME",
                          "weight": "medium",
                          "label": "Name",
                          "className": "truncate",
                          "width": "flex-1 min-w-[10rem]",
                          "align": "left"
                        },
                        {
                          "field": "description",
                          "label": "Detail",
                          "align": "left",
                          "header": "DETAIL",
                          "width": "flex-1 min-w-[12rem]",
                          "className": "text-[var(--color-text-muted)] truncate",
                          "key": "description"
                        },
                        {
                          "className": "font-mono tabular-nums",
                          "label": "Value",
                          "field": "value",
                          "header": "VALUE",
                          "key": "value",
                          "width": "w-28",
                          "align": "right"
                        },
                        {
                          "label": "Change",
                          "align": "right",
                          "field": "change",
                          "className": "font-mono tabular-nums",
                          "header": "CHANGE",
                          "key": "change",
                          "width": "w-24"
                        },
                        {
                          "label": "Volume",
                          "field": "volume",
                          "header": "VOLUME",
                          "width": "w-24",
                          "align": "right",
                          "className": "font-mono tabular-nums text-[var(--color-text-muted)]",
                          "key": "volume"
                        },
                        {
                          "width": "w-24",
                          "field": "status",
                          "header": "STATUS",
                          "label": "Status",
                          "align": "center",
                          "key": "status"
                        },
                        {
                          "field": "createdAt",
                          "align": "right",
                          "header": "CREATED",
                          "key": "createdAt",
                          "width": "w-32",
                          "label": "Created",
                          "className": "font-mono tabular-nums text-[var(--color-text-muted)] truncate"
                        }
                      ],
                      "selectable": true,
                      "entity": "@payload.data",
                      "type": "table",
                      "className": "w-full text-sm [&_thead]:sticky [&_thead]:top-0 [&_thead]:z-10 [&_thead]:bg-[var(--color-surface-muted)] [&_thead]:text-[var(--color-text-muted)] [&_thead]:uppercase [&_thead]:text-xs [&_thead]:font-semibold [&_thead]:tracking-wide [&_thead]:border-b [&_thead]:border-[var(--color-border)] [&_tbody_tr]:border-b [&_tbody_tr]:border-[var(--color-border)] [&_tbody_tr:last-child]:border-b-0 [&_tbody_tr:hover]:bg-[var(--color-surface-muted)] [&_td]:px-3 [&_td]:py-2 [&_th]:px-3 [&_th]:py-2",
                      "emptyMessage": "No records"
                    }
                  ]
                }
              ],
              "gap": "sm",
              "className": "p-card-md",
              "direction": "vertical",
              "type": "stack"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "DenseBrowsePage",
          "path": "/dense-browse",
          "traits": [
            {
              "ref": "DenseBrowse"
            }
          ]
        }
      ]
    }
  ]
}