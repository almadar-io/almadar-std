{
  "name": "std-browse-dense",
  "version": "1.2.0",
  "description": "Spreadsheet-style dense browse — column-row data-table molecule with sticky header, monospaced numerics, status badges, tight row padding.",
  "orbitals": [
    {
      "name": "DenseBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "DenseRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "change",
            "type": "string"
          },
          {
            "name": "volume",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "ok",
            "values": [
              "ok",
              "warn",
              "error"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DenseBrowse",
          "linkedEntity": "DenseRow",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "className": "p-card-md",
              "children": [
                {
                  "align": "center",
                  "type": "stack",
                  "direction": "horizontal",
                  "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                  "children": [
                    {
                      "type": "icon",
                      "name": "search",
                      "className": "text-muted-foreground"
                    },
                    {
                      "className": "flex-1",
                      "inputType": "search",
                      "type": "input",
                      "placeholder": "@config.searchPlaceholder",
                      "action": "REFETCH_QUERY"
                    }
                  ],
                  "gap": "sm"
                },
                {
                  "renderItem": [
                    "fn",
                    "f",
                    {
                      "options": "@f.options",
                      "className": "min-w-[10rem]",
                      "placeholder": "@f.label",
                      "action": "REFETCH_FILTER",
                      "type": "select",
                      "actionPayload": {
                        "field": "@f.field"
                      }
                    }
                  ],
                  "type": "data-list",
                  "gap": "sm",
                  "entity": "@config.filters",
                  "fields": []
                },
                {
                  "direction": "vertical",
                  "type": "stack",
                  "className": "rounded-lg border border-[var(--color-border)] overflow-x-auto bg-[var(--color-card)] shadow-sm",
                  "gap": "none",
                  "children": [
                    {
                      "selectable": true,
                      "maxInlineActions": "@config.maxInlineActions",
                      "look": "dense",
                      "pageSize": "@config.displayPageSize",
                      "entity": "@payload.data",
                      "type": "table-view",
                      "columns": "@config.columns",
                      "itemActions": "@config.itemActions",
                      "emptyMessage": "No records"
                    }
                  ]
                }
              ],
              "gap": "sm",
              "type": "stack"
            },
            "columns": [
              {
                "field": "id",
                "header": "ID",
                "key": "id",
                "width": "7rem",
                "align": "left",
                "className": " text-[var(--color-text-muted)]"
              },
              {
                "header": "Name",
                "field": "name",
                "width": "minmax(10rem, 1.5fr)",
                "weight": "medium",
                "key": "name",
                "align": "left"
              },
              {
                "field": "description",
                "header": "Detail",
                "className": "text-[var(--color-text-muted)]",
                "key": "description",
                "width": "minmax(12rem, 2fr)",
                "align": "left"
              },
              {
                "align": "right",
                "key": "value",
                "width": "6rem",
                "field": "value",
                "className": "",
                "header": "Value"
              },
              {
                "className": "",
                "header": "Change",
                "width": "6rem",
                "key": "change",
                "field": "change",
                "align": "right"
              },
              {
                "className": " text-[var(--color-text-muted)]",
                "key": "volume",
                "align": "right",
                "field": "volume",
                "header": "Volume",
                "width": "6rem"
              },
              {
                "width": "6rem",
                "format": "badge",
                "key": "status",
                "field": "status",
                "header": "Status",
                "align": "center"
              },
              {
                "field": "createdAt",
                "key": "createdAt",
                "width": "9rem",
                "align": "right",
                "header": "Created",
                "className": " text-[var(--color-text-muted)]",
                "format": "date"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "DenseBrowsePage",
          "path": "/dense-browse",
          "traits": [
            {
              "ref": "DenseBrowse"
            }
          ]
        }
      ]
    }
  ]
}