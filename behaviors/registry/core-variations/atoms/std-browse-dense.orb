{
  "name": "std-browse-dense",
  "version": "1.1.2",
  "description": "Spreadsheet-style dense browse — column-row data-table molecule with sticky header, monospaced numerics, status badges, tight row padding.",
  "orbitals": [
    {
      "name": "DenseBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "DenseRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "change",
            "type": "string"
          },
          {
            "name": "volume",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "ok",
            "values": [
              "ok",
              "warn",
              "error"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DenseBrowse",
          "linkedEntity": "DenseRow",
          "config": {
            "bodyContent": {
              "type": "stack",
              "gap": "sm",
              "direction": "vertical",
              "className": "p-card-md",
              "children": [
                {
                  "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                  "type": "stack",
                  "gap": "sm",
                  "align": "center",
                  "direction": "horizontal",
                  "children": [
                    {
                      "type": "icon",
                      "className": "text-muted-foreground",
                      "name": "search"
                    },
                    {
                      "placeholder": "Filter records…",
                      "className": "flex-1",
                      "inputType": "search",
                      "action": "REFETCH_QUERY",
                      "type": "input"
                    }
                  ]
                },
                {
                  "direction": "vertical",
                  "children": [
                    {
                      "look": "dense",
                      "selectable": true,
                      "type": "table-view",
                      "emptyMessage": "No records",
                      "columns": [
                        {
                          "width": "7rem",
                          "field": "id",
                          "header": "ID",
                          "className": "font-mono text-[var(--color-text-muted)]",
                          "key": "id",
                          "align": "left"
                        },
                        {
                          "weight": "medium",
                          "field": "name",
                          "key": "name",
                          "width": "minmax(10rem, 1.5fr)",
                          "align": "left",
                          "header": "Name"
                        },
                        {
                          "width": "minmax(12rem, 2fr)",
                          "key": "description",
                          "field": "description",
                          "align": "left",
                          "className": "text-[var(--color-text-muted)]",
                          "header": "Detail"
                        },
                        {
                          "key": "value",
                          "width": "6rem",
                          "align": "right",
                          "field": "value",
                          "header": "Value",
                          "className": "font-mono tabular-nums"
                        },
                        {
                          "width": "6rem",
                          "align": "right",
                          "key": "change",
                          "field": "change",
                          "className": "font-mono tabular-nums",
                          "header": "Change"
                        },
                        {
                          "width": "6rem",
                          "header": "Volume",
                          "align": "right",
                          "key": "volume",
                          "className": "font-mono tabular-nums text-[var(--color-text-muted)]",
                          "field": "volume"
                        },
                        {
                          "header": "Status",
                          "format": "badge",
                          "key": "status",
                          "field": "status",
                          "align": "center",
                          "width": "6rem"
                        },
                        {
                          "key": "createdAt",
                          "field": "createdAt",
                          "header": "Created",
                          "align": "right",
                          "width": "9rem",
                          "className": "font-mono tabular-nums text-[var(--color-text-muted)]",
                          "format": "date"
                        }
                      ],
                      "entity": "@payload.data"
                    }
                  ],
                  "type": "stack",
                  "gap": "none",
                  "className": "rounded-lg border border-[var(--color-border)] overflow-x-auto bg-[var(--color-card)] shadow-sm"
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "DenseBrowsePage",
          "path": "/dense-browse",
          "traits": [
            {
              "ref": "DenseBrowse"
            }
          ]
        }
      ]
    }
  ]
}