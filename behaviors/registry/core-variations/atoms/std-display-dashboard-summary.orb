{
  "name": "std-display-dashboard-summary",
  "version": "1.1.0",
  "description": "Executive dashboard — 4 KPI tiles, status pill strip, primary line-chart panel below. Same trait as std-display.",
  "orbitals": [
    {
      "name": "DashboardSummaryDisplayOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-display",
          "as": "Display"
        }
      ],
      "entity": {
        "name": "SummaryRecord",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "subtitle",
            "type": "string"
          },
          {
            "name": "period",
            "type": "string",
            "default": "Last 30 days"
          },
          {
            "name": "tiles",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "value": {
                  "name": "value",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                }
              }
            }
          },
          {
            "name": "statuses",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "tone": {
                  "name": "tone",
                  "type": "string",
                  "required": false,
                  "values": [
                    "success",
                    "warning",
                    "error",
                    "info",
                    "default"
                  ]
                }
              }
            }
          },
          {
            "name": "chartTitle",
            "type": "string",
            "default": "Performance"
          },
          {
            "name": "chartSubtitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "name": "date",
                  "type": "string",
                  "required": true
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": true
                }
              }
            }
          },
          {
            "name": "filterEvent",
            "type": "string",
            "default": "OPEN_FILTER"
          }
        ]
      },
      "traits": [
        {
          "ref": "Display.traits.DisplayItemDisplay",
          "name": "DashboardSummaryDisplay",
          "linkedEntity": "SummaryRecord",
          "config": {
            "bodyContent": {
              "className": "w-full max-w-6xl mx-auto px-card-md py-card-md",
              "children": [
                {
                  "className": "pb-card-sm",
                  "type": "stack",
                  "direction": "horizontal",
                  "gap": "md",
                  "justify": "between",
                  "align": "center",
                  "children": [
                    {
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h3",
                          "content": "@entity.title",
                          "weight": "semibold",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "@entity.period",
                          "color": "muted"
                        }
                      ],
                      "gap": "xs",
                      "direction": "vertical"
                    },
                    {
                      "size": "sm",
                      "variant": "ghost",
                      "icon": "filter",
                      "action": "@entity.filterEvent",
                      "type": "button",
                      "label": "Filter"
                    }
                  ]
                },
                {
                  "className": "w-full",
                  "children": [
                    {
                      "type": "data-list",
                      "entity": "@entity.tiles",
                      "gap": "sm",
                      "fields": [],
                      "renderItem": [
                        "fn",
                        "tile",
                        {
                          "type": "card",
                          "variant": "elevated",
                          "className": "rounded-lg shadow-elevation-sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "justify": "between",
                                  "gap": "xs",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "variant": "overline",
                                      "className": "uppercase tracking-wide",
                                      "type": "typography",
                                      "color": "muted",
                                      "weight": "semibold",
                                      "content": "@tile.label"
                                    },
                                    {
                                      "color": "muted",
                                      "type": "icon",
                                      "size": "sm",
                                      "name": "@tile.icon"
                                    }
                                  ],
                                  "align": "center",
                                  "direction": "horizontal"
                                },
                                {
                                  "content": "@tile.value",
                                  "weight": "semibold",
                                  "variant": "h2",
                                  "type": "typography",
                                  "className": "tabular-nums"
                                },
                                {
                                  "value": "@tile.trend",
                                  "size": "sm",
                                  "type": "trend-indicator",
                                  "showValue": true
                                }
                              ],
                              "gap": "xs",
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ],
                          "padding": "md"
                        }
                      ]
                    }
                  ],
                  "cols": 4.0,
                  "type": "simple-grid",
                  "gap": "sm"
                },
                {
                  "className": "flex-wrap",
                  "gap": "xs",
                  "children": [
                    {
                      "type": "data-list",
                      "fields": [],
                      "renderItem": [
                        "fn",
                        "pill",
                        {
                          "type": "badge",
                          "label": "@pill.label",
                          "variant": "@pill.tone",
                          "size": "sm"
                        }
                      ],
                      "gap": "sm",
                      "entity": "@entity.statuses"
                    }
                  ],
                  "type": "stack",
                  "direction": "horizontal"
                },
                {
                  "type": "divider"
                },
                {
                  "direction": "vertical",
                  "gap": "none",
                  "type": "stack",
                  "className": "rounded-lg shadow-elevation-sm w-full",
                  "children": [
                    {
                      "type": "card",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "baseline",
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "weight": "semibold",
                                      "variant": "h4",
                                      "content": "@entity.chartTitle",
                                      "type": "typography"
                                    },
                                    {
                                      "content": "@entity.chartSubtitle",
                                      "color": "muted",
                                      "type": "typography",
                                      "variant": "caption"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "xs"
                                },
                                {
                                  "label": "@entity.period",
                                  "type": "badge",
                                  "size": "sm",
                                  "variant": "default"
                                }
                              ]
                            },
                            {
                              "showLegend": false,
                              "chartType": "line",
                              "height": 280.0,
                              "type": "chart",
                              "data": "@entity.chartData"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "vertical"
                        }
                      ],
                      "padding": "lg",
                      "variant": "elevated"
                    }
                  ]
                }
              ],
              "type": "stack",
              "gap": "sm",
              "direction": "vertical"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "DashboardSummaryDisplayPage",
          "path": "/dashboard-summary-display",
          "traits": [
            {
              "ref": "DashboardSummaryDisplay"
            }
          ]
        }
      ]
    }
  ]
}