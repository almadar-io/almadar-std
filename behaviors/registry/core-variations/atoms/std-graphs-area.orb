{
  "description": "Area chart view. Embeds std-graphs with area chart pattern override.",
  "name": "std-graphs-area",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "Data points used to render the chart.",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "chartData",
            "synonyms": "data, values, series",
            "type": "array"
          }
        ],
        "name": "AreaGraphItem",
        "persistence": "runtime"
      },
      "name": "AreaGraphItemOrbital",
      "pages": [
        {
          "name": "AreaGraphPage",
          "path": "/area-graph",
          "traits": [
            {
              "ref": "AreaGraphItemGraph"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "chartType": "area"
          },
          "linkedEntity": "AreaGraphItem",
          "name": "AreaGraphItemGraph",
          "ref": "Graph.traits.GraphItemGraph"
        }
      ],
      "uses": [
        {
          "as": "Graph",
          "from": "std/behaviors/std-graphs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}