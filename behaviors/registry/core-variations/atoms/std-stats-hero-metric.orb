{
  "name": "std-stats-hero-metric",
  "version": "1.2.0",
  "description": "Hero metric — one elevated card, one oversize number. The headline KPI for executive landing pages and finance hero dashboards.",
  "orbitals": [
    {
      "name": "HeroMetricStatsOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "HeroMetricStats",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false,
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": false
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false,
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false,
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "A collection of statistical cards displayed together.",
            "synonyms": "statistics, data, visualizations, reports"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "HeroMetricStatsItemStats",
          "linkedEntity": "HeroMetricStats",
          "config": {
            "metrics": [
              {
                "icon": "dollar-sign",
                "value": 128400.0,
                "variant": "success",
                "format": "currency",
                "label": "Monthly Recurring Revenue",
                "trendPolarity": "higher-is-better",
                "trend": 12.5,
                "prefix": "$",
                "trendFormat": "percent",
                "sparklineData": [
                  86000.0,
                  91000.0,
                  89500.0,
                  97000.0,
                  104000.0,
                  101500.0,
                  110000.0,
                  116000.0,
                  119500.0,
                  123000.0,
                  126200.0,
                  128400.0
                ]
              }
            ],
            "bodyContent": {
              "type": "data-list",
              "gap": "none",
              "entity": "@entity.cards",
              "renderItem": [
                "fn",
                "card",
                {
                  "children": [
                    {
                      "padding": "lg",
                      "type": "card",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "@card.icon",
                                  "type": "icon",
                                  "size": "md",
                                  "color": "muted"
                                },
                                {
                                  "className": "uppercase tracking-widest",
                                  "color": "muted",
                                  "variant": "overline",
                                  "weight": "bold",
                                  "type": "typography",
                                  "content": "@card.label"
                                }
                              ],
                              "align": "center",
                              "justify": "center"
                            },
                            {
                              "children": [
                                {
                                  "variant": "h2",
                                  "weight": "normal",
                                  "content": "@card.prefix",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "animated-counter",
                                  "className": "text-7xl md:text-8xl font-bold tracking-tighter tabular-nums text-[var(--color-foreground)]",
                                  "value": "@card.value"
                                },
                                {
                                  "weight": "normal",
                                  "content": "@card.suffix",
                                  "variant": "h2",
                                  "color": "muted",
                                  "type": "typography"
                                }
                              ],
                              "className": "py-section",
                              "direction": "horizontal",
                              "gap": "xs",
                              "align": "baseline",
                              "justify": "center",
                              "type": "stack"
                            },
                            {
                              "size": "md",
                              "showValue": true,
                              "value": "@card.trend",
                              "type": "trend-indicator"
                            }
                          ],
                          "className": "relative z-10 w-full max-w-2xl mx-auto text-center",
                          "align": "center",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "height": 96.0,
                          "fill": true,
                          "data": "@card.sparklineData",
                          "strokeWidth": 1.0,
                          "type": "sparkline",
                          "className": "absolute inset-x-0 bottom-0 w-full opacity-10 pointer-events-none",
                          "color": "auto"
                        }
                      ],
                      "look": "elevated"
                    }
                  ],
                  "direction": "vertical",
                  "gap": "none",
                  "className": "relative w-full rounded-xl shadow-lg overflow-hidden",
                  "type": "stack"
                }
              ],
              "fields": []
            }
          }
        }
      ],
      "pages": [
        {
          "name": "HeroMetricStatsPage",
          "path": "/hero-metric",
          "traits": [
            {
              "ref": "HeroMetricStatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
