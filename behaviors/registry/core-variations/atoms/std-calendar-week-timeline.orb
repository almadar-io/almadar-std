{
  "description": "Week-timeline calendar — events grouped by weekday in a 7-column timeline. The visible window normalizes to the payload's actual date range, so events stack into whichever day-of-week they fall on. Same CalendarEventCalendar trait, same state machine as std-calendar — only bodyContent differs. For weekly schedule views (fitness class week, healthcare appointment week).",
  "name": "std-calendar-week-timeline",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A user-friendly identifier for the event.",
            "name": "title",
            "required": true,
            "synonyms": "title, label, eventName, name",
            "type": "string"
          },
          {
            "description": "A textual explanation of the event.",
            "name": "description",
            "synonyms": "details, notes, explanation, summary",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the event.",
            "name": "status",
            "synonyms": "state, condition, flag",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "default": "",
            "intrinsic": true,
            "name": "date",
            "type": "datetime"
          },
          {
            "default": "",
            "description": "The time of day the event occurs.",
            "name": "startTime",
            "synonyms": "hour, start time, scheduled time, time, start",
            "type": "string"
          },
          {
            "default": 60.0,
            "description": "The length of time for the event, typically in minutes.",
            "name": "duration",
            "synonyms": "length, time, span",
            "type": "number"
          },
          {
            "default": "",
            "description": "The day of the week this event occurs on.",
            "name": "weekday",
            "synonyms": "day, dayOfWeek",
            "type": "string"
          },
          {
            "default": "week",
            "intrinsic": true,
            "name": "selectedRange",
            "type": "string"
          }
        ],
        "name": "WeekTimelineEvent",
        "persistence": "runtime"
      },
      "name": "WeekTimelineCalendarOrbital",
      "pages": [
        {
          "name": "WeekTimelineCalendarPage",
          "path": "/calendarevents/week",
          "traits": [
            {
              "ref": "WeekTimelineCalendar"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "name": {
              "default": "calendar",
              "type": "unknown"
            }
          },
          "linkedEntity": "WeekTimelineEvent",
          "name": "CalendarIcon",
          "ref": "Icon.traits.IconRender"
        },
        {
          "config": {
            "content": {
              "default": "Week",
              "type": "unknown"
            },
            "variant": {
              "default": "h2",
              "type": "unknown"
            }
          },
          "linkedEntity": "WeekTimelineEvent",
          "name": "WeekTypography",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "onSelect": {
              "default": "SELECT_DAY",
              "type": "unknown"
            },
            "selected": {
              "default": "@entity.selectedRange",
              "type": "unknown"
            }
          },
          "linkedEntity": "WeekTimelineEvent",
          "name": "WeekDateRangeSelector",
          "ref": "DateRangeSelector.traits.DateRangeSelectorRender"
        },
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      {
                        "align": "center",
                        "children": [
                          "@trait.CalendarIcon",
                          "@trait.WeekTypography"
                        ],
                        "direction": "horizontal",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "@trait.WeekDateRangeSelector"
                    ],
                    "direction": "horizontal",
                    "gap": "md",
                    "justify": "between",
                    "type": "stack"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "className": "w-full",
                    "dayWindow": 7.0,
                    "events": "@payload.data",
                    "type": "calendar-grid"
                  }
                ],
                "direction": "vertical",
                "gap": "md",
                "type": "stack"
              },
              "type": "unknown"
            }
          },
          "linkedEntity": "WeekTimelineEvent",
          "name": "WeekTimelineCalendar",
          "ref": "Calendar.traits.CalendarEventCalendar"
        }
      ],
      "uses": [
        {
          "as": "Calendar",
          "from": "std/behaviors/std-calendar"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "DateRangeSelector",
          "from": "std/behaviors/ui-date-range-selector"
        }
      ]
    }
  ],
  "version": "1.2.0"
}