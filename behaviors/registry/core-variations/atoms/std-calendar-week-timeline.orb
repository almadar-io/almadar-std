{
  "name": "std-calendar-week-timeline",
  "version": "1.2.0",
  "description": "Week-timeline calendar — events grouped by weekday in a 7-column timeline. The visible window normalizes to the payload's actual date range, so events stack into whichever day-of-week they fall on. Same CalendarEventCalendar trait, same state machine as std-calendar — only bodyContent differs. For weekly schedule views (fitness class week, healthcare appointment week).",
  "orbitals": [
    {
      "name": "WeekTimelineCalendarOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        }
      ],
      "entity": {
        "name": "WeekTimelineEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "A user-friendly identifier for the event.",
            "synonyms": "title, label, eventName"
          },
          {
            "name": "description",
            "type": "string",
            "description": "A textual explanation of the event.",
            "synonyms": "details, notes, explanation, summary"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Indicates the current operational state of the event.",
            "synonyms": "state, condition, flag"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "datetime",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "time",
            "type": "string",
            "default": "",
            "description": "The time of day the event occurs.",
            "synonyms": "hour, start time, scheduled time"
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0,
            "description": "The length of time for the event, typically in minutes.",
            "synonyms": "length, time, span"
          },
          {
            "name": "weekday",
            "type": "string",
            "default": "",
            "description": "The day of the week this event occurs on.",
            "synonyms": "day, dayOfWeek"
          },
          {
            "name": "selectedRange",
            "type": "string",
            "default": "week",
            "intrinsic": true
          }
        ]
      },
      "traits": [
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "WeekTimelineCalendar",
          "linkedEntity": "WeekTimelineEvent",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "children": [
                {
                  "align": "center",
                  "gap": "md",
                  "type": "stack",
                  "justify": "between",
                  "children": [
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "type": "icon",
                          "name": "calendar"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Week"
                        }
                      ],
                      "direction": "horizontal"
                    },
                    {
                      "selected": "@entity.selectedRange",
                      "onSelect": "SELECT_DAY",
                      "type": "date-range-selector"
                    }
                  ],
                  "direction": "horizontal"
                },
                {
                  "type": "divider"
                },
                {
                  "dayWindow": 7.0,
                  "type": "calendar-grid",
                  "className": "w-full",
                  "events": "@payload.data"
                }
              ],
              "gap": "md",
              "type": "stack"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "WeekTimelineCalendarPage",
          "path": "/calendarevents/week",
          "traits": [
            {
              "ref": "WeekTimelineCalendar"
            }
          ]
        }
      ]
    }
  ]
}
