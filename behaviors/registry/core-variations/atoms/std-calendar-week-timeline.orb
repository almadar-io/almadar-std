{
  "name": "std-calendar-week-timeline",
  "version": "1.1.3",
  "description": "Week-timeline calendar — events grouped by weekday in a 7-column timeline. The visible window normalizes to the payload's actual date range, so events stack into whichever day-of-week they fall on. Same CalendarEventCalendar trait, same state machine as std-calendar — only bodyContent differs. For weekly schedule views (fitness class week, healthcare appointment week).",
  "orbitals": [
    {
      "name": "WeekTimelineCalendarOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        }
      ],
      "entity": {
        "name": "WeekTimelineEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "weekday",
            "type": "string",
            "default": ""
          },
          {
            "name": "selectedRange",
            "type": "string",
            "default": "week"
          }
        ]
      },
      "traits": [
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "WeekTimelineCalendar",
          "linkedEntity": "WeekTimelineEvent",
          "config": {
            "bodyContent": {
              "direction": "vertical",
              "type": "stack",
              "gap": "md",
              "children": [
                {
                  "children": [
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "align": "center",
                      "children": [
                        {
                          "name": "calendar",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Week",
                          "variant": "h2"
                        }
                      ],
                      "gap": "sm"
                    },
                    {
                      "selected": "@entity.selectedRange",
                      "type": "date-range-selector",
                      "onSelect": "SELECT_DAY"
                    }
                  ],
                  "gap": "md",
                  "direction": "horizontal",
                  "type": "stack",
                  "align": "center",
                  "justify": "between"
                },
                {
                  "type": "divider"
                },
                {
                  "groupBy": "weekday",
                  "fields": [],
                  "renderItem": [
                    "fn",
                    "item",
                    {
                      "shadow": "sm",
                      "type": "card",
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "xs",
                          "children": [
                            {
                              "align": "center",
                              "justify": "between",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "weight": "medium",
                                  "type": "typography",
                                  "content": "@item.time"
                                },
                                {
                                  "size": "sm",
                                  "label": "@item.status",
                                  "variant": "default",
                                  "type": "badge"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            },
                            {
                              "variant": "body2",
                              "content": "@item.name",
                              "className": "truncate",
                              "weight": "medium",
                              "type": "typography"
                            },
                            {
                              "variant": "caption",
                              "content": "@item.description",
                              "color": "muted",
                              "type": "typography",
                              "className": "truncate"
                            }
                          ]
                        }
                      ],
                      "padding": "sm",
                      "look": "flat-bordered"
                    }
                  ],
                  "entity": "@payload.data",
                  "type": "data-list",
                  "gap": "md",
                  "variant": "default"
                }
              ]
            }
          }
        }
      ],
      "pages": [
        {
          "name": "WeekTimelineCalendarPage",
          "path": "/calendarevents/week",
          "traits": [
            {
              "ref": "WeekTimelineCalendar"
            }
          ]
        }
      ]
    }
  ]
}