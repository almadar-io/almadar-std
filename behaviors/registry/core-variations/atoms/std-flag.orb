{
  "name": "std-flag",
  "version": "2.0.0",
  "description": "std-flag — user content-report form. A std-form-advanced variation bound to a Flag entity (reason + details): the form persists the report and emits FlagSubmitted for cross-trait moderation listeners. Stays importable so a consumer orbital gains the Flag entity + report form via `uses` alongside its own primary entity.",
  "orbitals": [
    {
      "name": "FlagOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-form-advanced",
          "as": "FormAdvanced"
        }
      ],
      "entity": {
        "name": "Flag",
        "collection": "flags",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "default": "",
            "description": "Unique identifier of the resource being flagged.",
            "synonyms": "reference, identifier, key"
          },
          {
            "name": "targetType",
            "type": "string",
            "default": "",
            "description": "Specifies the type of the target being flagged.",
            "synonyms": "type, kind, category"
          },
          {
            "name": "reportedBy",
            "type": "string",
            "default": "",
            "description": "The user who submitted the report.",
            "synonyms": "reporter, submitter, user"
          },
          {
            "name": "reason",
            "type": "string",
            "default": "spam",
            "values": [
              "spam",
              "abuse",
              "off-topic",
              "misinformation",
              "nsfw",
              "other"
            ],
            "description": "The justification for flagging content.",
            "synonyms": "category, type, cause, rationale"
          },
          {
            "name": "notes",
            "type": "string",
            "default": "",
            "description": "Additional textual information or comments.",
            "synonyms": "comment, remark, details, explanation"
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "FormAdvanced.traits.FormEntryFormAdvanced",
          "name": "FlagReport",
          "linkedEntity": "Flag",
          "config": {
            "fields": [
              {
                "name": "reason",
                "type": "enum",
                "label": "Reason",
                "values": [
                  "spam",
                  "abuse",
                  "off-topic",
                  "misinformation",
                  "nsfw",
                  "other"
                ]
              },
              {
                "type": "textarea",
                "name": "notes",
                "label": "Details"
              }
            ],
            "title": "Report content",
            "icon": "flag"
          }
        }
      ],
      "pages": [
        {
          "name": "FlagReportPage",
          "path": "/flags/report",
          "traits": [
            {
              "ref": "FlagReport"
            }
          ]
        }
      ]
    }
  ]
}
