{
  "description": "Bottom-navigation chrome. Embeds std-app-layout with bottomnav layout pattern.",
  "name": "std-app-layout-bottomnav",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "BottomnavLayoutData",
        "persistence": "runtime"
      },
      "name": "BottomnavLayoutOrbital",
      "pages": [
        {
          "name": "BottomnavLayoutPage",
          "path": "/bottomnav-layout",
          "traits": [
            {
              "ref": "BottomnavLayout"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "appName": "Bottomnav Demo",
            "layoutMode": "bottomnav",
            "navItems": [
              {
                "href": "/",
                "icon": "home",
                "label": "Home"
              },
              {
                "href": "/contacts",
                "icon": "users",
                "label": "Contacts"
              },
              {
                "href": "/tasks",
                "icon": "check-square",
                "label": "Tasks"
              },
              {
                "href": "/settings",
                "icon": "settings",
                "label": "Settings"
              }
            ]
          },
          "linkedEntity": "BottomnavLayoutData",
          "name": "BottomnavLayout",
          "ref": "AppLayout.traits.AppLayout"
        }
      ],
      "uses": [
        {
          "as": "AppLayout",
          "from": "std/behaviors/std-app-layout"
        }
      ]
    }
  ],
  "version": "1.0.0"
}