{
  "description": "Top-navigation chrome. Embeds std-app-layout with topnav layout pattern.",
  "name": "std-app-layout-topnav",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TopnavLayoutData",
        "persistence": "runtime"
      },
      "name": "TopnavLayoutOrbital",
      "pages": [
        {
          "name": "TopnavLayoutPage",
          "path": "/topnav-layout",
          "traits": [
            {
              "ref": "TopnavLayout"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "appName": {
              "default": "Topnav Demo",
              "type": "unknown"
            },
            "layoutMode": {
              "default": "topnav",
              "type": "unknown"
            },
            "navItems": {
              "default": [
                {
                  "href": "/",
                  "icon": "home",
                  "label": "Home"
                },
                {
                  "href": "/contacts",
                  "icon": "users",
                  "label": "Contacts"
                },
                {
                  "href": "/tasks",
                  "icon": "check-square",
                  "label": "Tasks"
                },
                {
                  "href": "/settings",
                  "icon": "settings",
                  "label": "Settings"
                }
              ],
              "type": "unknown"
            }
          },
          "linkedEntity": "TopnavLayoutData",
          "name": "TopnavLayout",
          "ref": "AppLayout.traits.AppLayout"
        }
      ],
      "uses": [
        {
          "as": "AppLayout",
          "from": "std/behaviors/std-app-layout"
        }
      ]
    }
  ],
  "version": "1.0.0"
}