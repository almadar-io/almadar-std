{
  "name": "std-graphs-pie",
  "version": "1.0.0",
  "description": "Pie chart view. Embeds std-graphs with the pie chartType — categorical share-of-total. Best when you have ≤6 categories that sum to a meaningful whole.",
  "orbitals": [
    {
      "name": "PieGraphItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graph"
        }
      ],
      "entity": {
        "name": "PieGraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": true
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "ref": "Graph.traits.GraphItemGraph",
          "name": "PieGraphItemGraph",
          "linkedEntity": "PieGraphItem",
          "config": {
            "chartType": "pie"
          }
        }
      ],
      "pages": [
        {
          "name": "PieGraphPage",
          "path": "/pie-graph",
          "traits": [
            {
              "ref": "PieGraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}