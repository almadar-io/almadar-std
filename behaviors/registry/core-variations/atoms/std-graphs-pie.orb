{
  "description": "Pie chart view. Embeds std-graphs with the pie chartType — categorical share-of-total. Best when you have ≤6 categories that sum to a meaningful whole.",
  "name": "std-graphs-pie",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": [],
            "description": "Data points used to render the chart.",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "chartData",
            "synonyms": "data, values, series",
            "type": "array"
          }
        ],
        "name": "PieGraphItem",
        "persistence": "runtime"
      },
      "name": "PieGraphItemOrbital",
      "pages": [
        {
          "name": "PieGraphPage",
          "path": "/pie-graph",
          "traits": [
            {
              "ref": "PieGraphItemGraph"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "chartType": {
              "default": "pie",
              "type": "unknown"
            }
          },
          "linkedEntity": "PieGraphItem",
          "name": "PieGraphItemGraph",
          "ref": "Graph.traits.GraphItemGraph"
        }
      ],
      "uses": [
        {
          "as": "Graph",
          "from": "std/behaviors/std-graphs"
        }
      ]
    }
  ],
  "version": "1.0.0"
}