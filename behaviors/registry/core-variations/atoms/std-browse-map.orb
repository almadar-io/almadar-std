{
  "description": "Map browse — geo pin map: rows with lat/lng render as markers on a map-view, with a compact list beneath. For fleet vehicles, field technicians, store locations, delivery routes — anything with coordinates. Same BrowseItemBrowse trait + state machine as std-browse; only the bodyContent differs (a map instead of a grid).",
  "name": "std-browse-map",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A descriptive label for the row.",
            "name": "name",
            "required": true,
            "synonyms": "title, label, identifier",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the row.",
            "name": "status",
            "synonyms": "state, condition, enabled, disabled",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "default": 0.0,
            "description": "Represents the latitude coordinate.",
            "name": "lat",
            "synonyms": "latitude, y-coordinate, north-south position",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "The longitude coordinate of a location.",
            "name": "lng",
            "synonyms": "longitude, x, horizontal position",
            "type": "number"
          },
          {
            "default": "",
            "description": "The textual location associated with the coordinate data.",
            "name": "address",
            "synonyms": "location, place, addressString",
            "type": "string"
          },
          {
            "default": "",
            "name": "createdAt",
            "type": "string"
          }
        ],
        "name": "MapRow",
        "persistence": "runtime"
      },
      "name": "MapBrowseOrbital",
      "pages": [
        {
          "name": "MapBrowsePage",
          "path": "/map-browse",
          "traits": [
            {
              "ref": "MapBrowse"
            },
            {
              "ref": "Icon1"
            },
            {
              "ref": "Input1"
            },
            {
              "ref": "MapView1"
            },
            {
              "ref": "DataList1"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "className": {
              "default": "text-muted-foreground",
              "type": "unknown"
            },
            "name": {
              "default": "search",
              "type": "unknown"
            }
          },
          "linkedEntity": "MapRow",
          "name": "Icon1",
          "ref": "Icon.traits.IconRender"
        },
        {
          "config": {
            "action": {
              "default": "REFETCH_QUERY",
              "type": "unknown"
            },
            "className": {
              "default": "flex-1",
              "type": "unknown"
            },
            "inputType": {
              "default": "search",
              "type": "unknown"
            },
            "placeholder": {
              "default": "@config.searchPlaceholder",
              "type": "unknown"
            }
          },
          "linkedEntity": "MapRow",
          "name": "Input1",
          "ref": "Input.traits.InputRender"
        },
        {
          "config": {
            "className": {
              "default": "w-full rounded-lg overflow-hidden border border-[var(--color-border)]",
              "type": "unknown"
            },
            "height": {
              "default": "440px",
              "type": "unknown"
            },
            "markers": {
              "default": "@payload.data",
              "type": "unknown"
            }
          },
          "linkedEntity": "MapRow",
          "name": "MapView1",
          "ref": "MapView.traits.MapViewRender"
        },
        {
          "config": {
            "entity": {
              "default": "@payload.data",
              "type": "unknown"
            },
            "fields": {
              "default": "@config.fields",
              "type": "unknown"
            },
            "gap": {
              "default": "sm",
              "type": "unknown"
            },
            "itemActions": {
              "default": "@config.itemActions",
              "type": "unknown"
            },
            "look": {
              "default": "@config.tableLook",
              "type": "unknown"
            }
          },
          "linkedEntity": "MapRow",
          "name": "DataList1",
          "ref": "DataList.traits.DataListRender"
        },
        {
          "config": {
            "bodyContent": {
              "default": {
                "children": [
                  {
                    "align": "center",
                    "children": [
                      "@trait.Icon1",
                      "@trait.Input1"
                    ],
                    "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                    "direction": "horizontal",
                    "gap": "sm",
                    "type": "stack"
                  },
                  "@trait.MapView1",
                  "@trait.DataList1"
                ],
                "className": "p-card-md",
                "direction": "vertical",
                "gap": "md",
                "type": "stack"
              },
              "type": "unknown"
            },
            "fields": {
              "default": [
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "h4"
                },
                {
                  "label": "Address",
                  "name": "address",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                }
              ],
              "type": "unknown"
            },
            "tableLook": {
              "default": "spacious",
              "type": "unknown"
            }
          },
          "linkedEntity": "MapRow",
          "name": "MapBrowse",
          "ref": "Browse.traits.BrowseItemBrowse"
        }
      ],
      "uses": [
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Input",
          "from": "std/behaviors/ui-input"
        },
        {
          "as": "MapView",
          "from": "std/behaviors/ui-map-view"
        },
        {
          "as": "DataList",
          "from": "std/behaviors/ui-data-list"
        }
      ]
    }
  ],
  "version": "1.0.0"
}