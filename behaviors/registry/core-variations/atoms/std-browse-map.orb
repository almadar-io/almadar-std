{
  "name": "std-browse-map",
  "version": "1.0.0",
  "description": "Map browse — geo pin map: rows with lat/lng render as markers on a map-view, with a compact list beneath. For fleet vehicles, field technicians, store locations, delivery routes — anything with coordinates. Same BrowseItemBrowse trait + state machine as std-browse; only the bodyContent differs (a map instead of a grid).",
  "orbitals": [
    {
      "name": "MapBrowseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "MapRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "A descriptive label for the row.",
            "synonyms": "title, label, identifier"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Indicates the current operational state of the row.",
            "synonyms": "state, condition, enabled, disabled"
          },
          {
            "name": "lat",
            "type": "number",
            "default": 0.0,
            "description": "Represents the latitude coordinate.",
            "synonyms": "latitude, y-coordinate, north-south position"
          },
          {
            "name": "lng",
            "type": "number",
            "default": 0.0,
            "description": "The longitude coordinate of a location.",
            "synonyms": "longitude, x, horizontal position"
          },
          {
            "name": "address",
            "type": "string",
            "default": "",
            "description": "The textual location associated with the coordinate data.",
            "synonyms": "location, place, addressString"
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "MapBrowse",
          "linkedEntity": "MapRow",
          "config": {
            "fields": [
              {
                "name": "name",
                "label": "Name",
                "variant": "h4"
              },
              {
                "name": "address",
                "variant": "caption",
                "label": "Address"
              },
              {
                "variant": "badge",
                "label": "Status",
                "name": "status"
              }
            ],
            "tableLook": "spacious",
            "bodyContent": {
              "direction": "vertical",
              "className": "p-card-md",
              "children": [
                {
                  "align": "center",
                  "type": "stack",
                  "gap": "sm",
                  "children": [
                    {
                      "className": "text-muted-foreground",
                      "name": "search",
                      "type": "icon"
                    },
                    {
                      "type": "input",
                      "action": "REFETCH_QUERY",
                      "inputType": "search",
                      "className": "flex-1",
                      "placeholder": "@config.searchPlaceholder"
                    }
                  ],
                  "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm",
                  "direction": "horizontal"
                },
                {
                  "markers": "@payload.data",
                  "height": "440px",
                  "className": "w-full rounded-lg overflow-hidden border border-[var(--color-border)]",
                  "type": "map-view"
                },
                {
                  "type": "data-list",
                  "entity": "@payload.data",
                  "gap": "sm",
                  "fields": "@config.fields",
                  "itemActions": "@config.itemActions",
                  "look": "@config.tableLook"
                }
              ],
              "type": "stack",
              "gap": "md"
            }
          }
        }
      ],
      "pages": [
        {
          "name": "MapBrowsePage",
          "path": "/map-browse",
          "traits": [
            {
              "ref": "MapBrowse"
            }
          ]
        }
      ]
    }
  ]
}
