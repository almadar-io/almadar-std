{
  "name": "std-logic-training",
  "version": "1.0.0",
  "description": "std-logic-training as a Function",
  "orbitals": [
    {
      "name": "DebugChallengeOrbital",
      "entity": {
        "name": "DebugChallenge",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "bugType",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "solved",
            "type": "boolean",
            "default": false
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "DebugChallengeDebuggerGame",
          "category": "interaction",
          "linkedEntity": "DebugChallenge",
          "emits": [
            {
              "event": "DebugChallengeLoaded",
              "description": "Fired when DebugChallenge finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "bugType",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "solved",
                  "type": "boolean"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DebugChallengeLoadFailed",
              "description": "Fired when DebugChallenge fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "DebugChallengeLoaded",
                "name": "DebugChallenge loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "bugType",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "solved",
                    "type": "boolean"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "DebugChallengeLoadFailed",
                "name": "DebugChallenge load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DebugChallenge",
                    {
                      "emit": {
                        "success": "DebugChallengeLoaded",
                        "failure": "DebugChallengeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Logic Training",
                      "type": "game-shell",
                      "children": [
                        {
                          "title": "Debug Challenge",
                          "menuItems": [
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start"
                            }
                          ],
                          "type": "game-menu"
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "game-hud",
                              "stats": [
                                {
                                  "value": "@entity.score",
                                  "label": "Score"
                                },
                                {
                                  "value": "@entity.level",
                                  "label": "Level"
                                }
                              ]
                            },
                            {
                              "entity": "DebugChallenge",
                              "type": "debugger-board",
                              "completeEvent": "COMPLETE"
                            }
                          ]
                        }
                      ],
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "title": "Well Done!",
                          "type": "game-over-screen",
                          "menuItems": [
                            {
                              "label": "Play Again",
                              "event": "RESTART",
                              "variant": "primary"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Logic Training",
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-menu",
                          "menuItems": [
                            {
                              "label": "Start",
                              "event": "START",
                              "variant": "primary"
                            }
                          ],
                          "title": "Debug Challenge"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DebuggerPage",
          "path": "/debugger",
          "traits": [
            {
              "ref": "DebugChallengeDebuggerGame"
            }
          ]
        }
      ]
    },
    {
      "name": "NegotiateChallengeOrbital",
      "entity": {
        "name": "NegotiateChallenge",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "scenario",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "outcome",
            "type": "string"
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "NegotiateChallengeNegotiatorGame",
          "category": "interaction",
          "linkedEntity": "NegotiateChallenge",
          "emits": [
            {
              "event": "NegotiateChallengeLoaded",
              "description": "Fired when NegotiateChallenge finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "scenario",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "outcome",
                  "type": "string"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "NegotiateChallengeLoadFailed",
              "description": "Fired when NegotiateChallenge fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "NegotiateChallengeLoaded",
                "name": "NegotiateChallenge loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "scenario",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "outcome",
                    "type": "string"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "NegotiateChallengeLoadFailed",
                "name": "NegotiateChallenge load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NegotiateChallenge",
                    {
                      "emit": {
                        "failure": "NegotiateChallengeLoadFailed",
                        "success": "NegotiateChallengeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Logic Training",
                      "children": [
                        {
                          "menuItems": [
                            {
                              "event": "START",
                              "label": "Start",
                              "variant": "primary"
                            }
                          ],
                          "type": "game-menu",
                          "title": "Negotiate Challenge"
                        }
                      ],
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Logic Training",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "game-hud",
                              "stats": [
                                {
                                  "label": "Score",
                                  "value": "@entity.score"
                                },
                                {
                                  "label": "Level",
                                  "value": "@entity.level"
                                }
                              ]
                            },
                            {
                              "entity": "NegotiateChallenge",
                              "completeEvent": "COMPLETE",
                              "type": "negotiator-board"
                            }
                          ],
                          "gap": "md"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "title": "Well Done!",
                          "menuItems": [
                            {
                              "label": "Play Again",
                              "event": "RESTART",
                              "variant": "primary"
                            }
                          ],
                          "type": "game-over-screen"
                        }
                      ],
                      "appName": "Logic Training",
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "game-menu",
                          "title": "Negotiate Challenge",
                          "menuItems": [
                            {
                              "variant": "primary",
                              "label": "Start",
                              "event": "START"
                            }
                          ]
                        }
                      ],
                      "showTopBar": true,
                      "appName": "Logic Training"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Negotiator",
          "path": "/negotiator",
          "traits": [
            {
              "ref": "NegotiateChallengeNegotiatorGame"
            }
          ]
        }
      ]
    },
    {
      "name": "TrainingScoreOrbital",
      "entity": {
        "name": "TrainingScore",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "playerName",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "required": true,
            "default": 0.0
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "completedAt",
            "type": "string"
          },
          {
            "name": "highScore",
            "type": "number"
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "TrainingScoreScoreBoard",
          "category": "interaction",
          "linkedEntity": "TrainingScore",
          "emits": [
            {
              "event": "TrainingScoreLoaded",
              "description": "Fired when TrainingScore finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "playerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "score",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "category",
                  "type": "string"
                },
                {
                  "name": "completedAt",
                  "type": "string"
                },
                {
                  "name": "highScore",
                  "type": "number"
                },
                {
                  "name": "combo",
                  "type": "number"
                },
                {
                  "name": "multiplier",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TrainingScoreLoadFailed",
              "description": "Fired when TrainingScore fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_SCORE",
                "name": "Add Score",
                "payload": [
                  {
                    "name": "points",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMBO",
                "name": "Combo",
                "payload": [
                  {
                    "name": "multiplier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "TrainingScoreLoaded",
                "name": "TrainingScore loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "playerName",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "score",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "category",
                    "type": "string"
                  },
                  {
                    "name": "completedAt",
                    "type": "string"
                  },
                  {
                    "name": "highScore",
                    "type": "number"
                  },
                  {
                    "name": "combo",
                    "type": "number"
                  },
                  {
                    "name": "multiplier",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TrainingScoreLoadFailed",
                "name": "TrainingScore load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TrainingScore",
                    {
                      "emit": {
                        "failure": "TrainingScoreLoadFailed",
                        "success": "TrainingScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore",
                          "type": "score-board",
                          "combo": "@entity.combo",
                          "level": "@entity.level"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "score-board",
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "combo": "@entity.combo"
                        }
                      ],
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "children": [
                        {
                          "type": "score-board",
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level",
                          "score": "@entity.score"
                        }
                      ],
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "children": [
                        {
                          "highScore": "@entity.highScore",
                          "type": "score-board",
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level",
                          "score": "@entity.score"
                        }
                      ],
                      "appName": "Logic Training"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Scores",
          "path": "/scores",
          "traits": [
            {
              "ref": "TrainingScoreScoreBoard"
            }
          ]
        }
      ]
    }
  ]
}
