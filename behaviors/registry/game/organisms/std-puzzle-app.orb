                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Puzzle App",
                      "children": [
                        {
                          "score": "@entity.score",
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level",
                          "type": "score-board",
                          "combo": "@entity.combo",
                          "highScore": "@entity.highScore"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Scores",
          "path": "/scores",
          "traits": [
            {
              "ref": "PuzzleScoreScoreBoard"
            }
          ]
        }
      ]
    }
  ]
}