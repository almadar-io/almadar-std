{
  "name": "std-combat",
  "version": "1.0.0",
  "description": "std-combat as a Function",
  "orbitals": [
    {
      "name": "CombatantOrbital",
      "entity": {
        "name": "Combatant",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "hp",
            "type": "number",
            "default": 100.0
          },
          {
            "name": "attack",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "defense",
            "type": "number",
            "default": 5.0
          }
        ]
      },
      "traits": [
        {
          "name": "CombatantCombat",
          "category": "interaction",
          "linkedEntity": "Combatant",
          "emits": [
            {
              "event": "CombatantLoaded",
              "description": "Fired when Combatant finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "hp",
                  "type": "number"
                },
                {
                  "name": "attack",
                  "type": "number"
                },
                {
                  "name": "defense",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CombatantLoadFailed",
              "description": "Fired when Combatant fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "attacking"
              },
              {
                "name": "cooldown"
              },
              {
                "name": "defeated"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ATTACK",
                "name": "Attack",
                "payload": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HIT",
                "name": "Hit",
                "payload": [
                  {
                    "name": "damage",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "DEFEAT",
                "name": "Defeat"
              },
              {
                "key": "COOLDOWN_END",
                "name": "Cooldown End"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "CombatantLoaded",
                "name": "Combatant loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "hp",
                    "type": "number"
                  },
                  {
                    "name": "attack",
                    "type": "number"
                  },
                  {
                    "name": "defense",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "CombatantLoadFailed",
                "name": "Combatant load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Combatant",
                    {
                      "emit": {
                        "failure": "CombatantLoadFailed",
                        "success": "CombatantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "label": "Attack",
                          "action": "ATTACK",
                          "variant": "primary",
                          "icon": "swords",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "attacking",
                "event": "ATTACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "stats": [
                            {
                              "value": "@entity.hp",
                              "label": "HP"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ],
                          "position": "top",
                          "type": "game-hud"
                        },
                        {
                          "variant": "secondary",
                          "type": "button",
                          "action": "HIT",
                          "icon": "clock",
                          "label": "Cooldown End"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "cooldown",
                "event": "HIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ],
                          "position": "top",
                          "type": "game-hud"
                        },
                        {
                          "type": "badge",
                          "label": "Cooling down..."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-over-screen",
                          "variant": "defeat",
                          "title": "Defeated"
                        },
                        {
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "ghost",
                          "label": "Reset",
                          "action": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "ready",
                "event": "COOLDOWN_END",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "value": "@entity.attack",
                              "label": "Attack"
                            },
                            {
                              "value": "@entity.defense",
                              "label": "Defense"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "label": "Attack",
                          "variant": "primary",
                          "type": "button",
                          "icon": "swords",
                          "action": "ATTACK"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "variant": "defeat",
                          "title": "Defeated",
                          "type": "game-over-screen"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost",
                          "label": "Reset",
                          "action": "RESET"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "defeated",
                "to": "ready",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "game-hud",
                          "position": "top",
                          "stats": [
                            {
                              "value": "@entity.hp",
                              "label": "HP"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "value": "@entity.defense",
                              "label": "Defense"
                            }
                          ]
                        },
                        {
                          "icon": "swords",
                          "variant": "primary",
                          "label": "Attack",
                          "type": "button",
                          "action": "ATTACK"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CombatantPage",
          "path": "/combatants",
          "traits": [
            {
              "ref": "CombatantCombat"
            }
          ]
        }
      ]
    }
  ]
}