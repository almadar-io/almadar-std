{
  "name": "std-overworld",
  "version": "1.0.0",
  "description": "std-overworld as a Function",
  "orbitals": [
    {
      "name": "WorldRegionOrbital",
      "entity": {
        "name": "WorldRegion",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WorldRegionNavigation",
          "category": "interaction",
          "linkedEntity": "WorldRegion",
          "emits": [
            {
              "event": "WorldRegionLoaded",
              "description": "Fired when WorldRegion finishes loading; payload.data holds the regions",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[WorldRegion]"
                }
              ]
            },
            {
              "event": "WorldRegionLoadFailed",
              "description": "Fired when WorldRegion fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "exploring"
              },
              {
                "name": "transitioning"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WorldRegionLoaded",
                "name": "WorldRegion loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[WorldRegion]"
                  }
                ]
              },
              {
                "key": "WorldRegionLoadFailed",
                "name": "WorldRegion load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TRAVEL",
                "name": "Travel",
                "payload": [
                  {
                    "name": "zoneId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARRIVE",
                "name": "Arrive",
                "payload": [
                  {
                    "name": "zoneId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "failure": "WorldRegionLoadFailed",
                        "success": "WorldRegionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading map…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "exploring",
                "event": "WorldRegionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "map"
                                },
                                {
                                  "content": "World Map",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "status-dot",
                              "status": "online",
                              "pulse": false,
                              "label": "Exploring"
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "map-view",
                          "height": "200px",
                          "markers": [],
                          "zoom": 10.0
                        },
                        {
                          "fields": [],
                          "itemActions": [
                            {
                              "label": "Travel",
                              "event": "TRAVEL"
                            }
                          ],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "map-pin"
                                        },
                                        {
                                          "variant": "h4",
                                          "content": "@item.name",
                                          "type": "typography"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "align": "center",
                                      "type": "stack",
                                      "gap": "sm"
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ],
                                  "justify": "between",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "@item.status"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WorldRegionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load map",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "exploring",
                "to": "transitioning",
                "event": "TRAVEL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "loader"
                            },
                            {
                              "variant": "h2",
                              "content": "Traveling...",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "content": "Traveling to the destination region.",
                          "variant": "body"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "transitioning",
                "to": "loading",
                "event": "ARRIVE",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "failure": "WorldRegionLoadFailed",
                        "success": "WorldRegionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "failure": "WorldRegionLoadFailed",
                        "success": "WorldRegionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WorldRegionPage",
          "path": "/worldregions",
          "traits": [
            {
              "ref": "WorldRegionNavigation"
            }
          ]
        }
      ]
    }
  ]
}
