{
  "name": "std-gameflow",
  "version": "1.0.0",
  "description": "std-gameflow as a Function",
  "orbitals": [
    {
      "name": "GameSessionOrbital",
      "entity": {
        "name": "GameSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "GameSessionGameflow",
          "category": "interaction",
          "linkedEntity": "GameSession",
          "emits": [
            {
              "event": "GameSessionLoaded",
              "description": "Fired when GameSession finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "GameSessionLoadFailed",
              "description": "Fired when GameSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "GameSessionLoaded",
                "name": "GameSession loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "GameSessionLoadFailed",
                "name": "GameSession load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "GameSessionLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.description"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.createdAt"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@payload.score"
                  ],
                  [
                    "set",
                    "@entity.level",
                    "@payload.level"
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameSession",
                    {
                      "emit": {
                        "failure": "GameSessionLoadFailed",
                        "success": "GameSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "GameSession",
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "event": "START",
                          "label": "Start Game",
                          "variant": "primary"
                        }
                      ],
                      "subtitle": "Main Menu"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ],
                      "type": "game-hud"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "variant": "primary",
                          "label": "Resume",
                          "event": "RESUME"
                        },
                        {
                          "variant": "ghost",
                          "event": "RESTART",
                          "label": "Quit"
                        }
                      ],
                      "title": "Paused"
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Game Over",
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ],
                      "menuItems": [
                        {
                          "variant": "primary",
                          "event": "RESTART",
                          "label": "Play Again"
                        },
                        {
                          "label": "Main Menu",
                          "event": "RESTART",
                          "variant": "secondary"
                        }
                      ],
                      "type": "game-over-screen"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-hud",
                      "stats": [
                        {
                          "value": "@entity.score",
                          "label": "Score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ],
                      "type": "game-hud"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "GameSession",
                      "menuItems": [
                        {
                          "label": "Start Game",
                          "variant": "primary",
                          "event": "START"
                        }
                      ],
                      "type": "game-menu",
                      "subtitle": "Main Menu"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Main Menu",
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start Game"
                        }
                      ],
                      "type": "game-menu",
                      "title": "GameSession"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameSessionPage",
          "path": "/gamesessions",
          "traits": [
            {
              "ref": "GameSessionGameflow"
            }
          ]
        }
      ]
    }
  ]
}