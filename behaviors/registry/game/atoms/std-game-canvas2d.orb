{
  "name": "std-game-canvas2d",
  "version": "1.0.0",
  "description": "std-game-canvas2d as a Function",
  "orbitals": [
    {
      "name": "GameCanvas2dOrbital",
      "entity": {
        "name": "GameCanvas2d",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "GameCanvas2dGameCanvas2d",
          "category": "interaction",
          "linkedEntity": "GameCanvas2d",
          "emits": [
            {
              "event": "GameCanvas2dLoaded",
              "description": "Fired when GameCanvas2d finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GameCanvas2dLoadFailed",
              "description": "Fired when GameCanvas2d fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "rendering"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "GameCanvas2dLoaded",
                "name": "GameCanvas2d loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GameCanvas2dLoadFailed",
                "name": "GameCanvas2d load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameCanvas2d",
                    {
                      "emit": {
                        "failure": "GameCanvas2dLoadFailed",
                        "success": "GameCanvas2dLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "monitor"
                            },
                            {
                              "variant": "h3",
                              "content": "GameCanvas2d Canvas",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "typography",
                          "content": "800x600 @ 60fps",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "width": 800.0,
                          "fps": 60.0,
                          "type": "game-canvas-2d",
                          "height": 600.0
                        },
                        {
                          "variant": "primary",
                          "icon": "play",
                          "type": "button",
                          "action": "START",
                          "label": "Start"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "rendering",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "monitor"
                            },
                            {
                              "type": "typography",
                              "content": "GameCanvas2d Canvas",
                              "variant": "h3"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "width": 800.0,
                          "fps": 60.0,
                          "type": "game-canvas-2d",
                          "height": 600.0
                        },
                        {
                          "type": "button",
                          "label": "Stop",
                          "action": "STOP",
                          "variant": "ghost",
                          "icon": "square"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "rendering",
                "to": "rendering",
                "event": "TICK"
              },
              {
                "from": "rendering",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "monitor",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "GameCanvas2d Canvas"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "content": "800x600 @ 60fps",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "type": "game-canvas-2d",
                          "width": 800.0,
                          "height": 600.0,
                          "fps": 60.0
                        },
                        {
                          "type": "button",
                          "action": "START",
                          "label": "Start",
                          "icon": "play",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameCanvas2dCanvas2dPage",
          "path": "/gamecanvas2ds",
          "traits": [
            {
              "ref": "GameCanvas2dGameCanvas2d"
            }
          ]
        }
      ]
    }
  ]
}