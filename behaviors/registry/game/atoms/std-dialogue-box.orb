{
  "name": "std-dialogue-box",
  "version": "1.0.0",
  "description": "std-dialogue-box as a Function",
  "orbitals": [
    {
      "name": "DialogueNodeOrbital",
      "entity": {
        "name": "DialogueNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "speaker",
            "type": "string",
            "default": "Narrator"
          },
          {
            "name": "text",
            "type": "string",
            "default": "Welcome, adventurer. Your journey begins here."
          }
        ]
      },
      "traits": [
        {
          "name": "DialogueNodeDialogue",
          "category": "interaction",
          "linkedEntity": "DialogueNode",
          "emits": [
            {
              "event": "DialogueNodeLoaded",
              "description": "Fired when DialogueNode finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "speaker",
                  "type": "string"
                },
                {
                  "name": "text",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DialogueNodeLoadFailed",
              "description": "Fired when DialogueNode fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "talking",
                "isInitial": true
              },
              {
                "name": "idle"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADVANCE",
                "name": "Advance"
              },
              {
                "key": "CHOICE",
                "name": "Choice",
                "payload": [
                  {
                    "name": "choiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "START_DIALOGUE",
                "name": "Start Dialogue"
              },
              {
                "key": "DialogueNodeLoaded",
                "name": "DialogueNode loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "speaker",
                    "type": "string"
                  },
                  {
                    "name": "text",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DialogueNodeLoadFailed",
                "name": "DialogueNode load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "talking",
                "to": "talking",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "success": "DialogueNodeLoaded",
                        "failure": "DialogueNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "set",
                    "@entity.speaker",
                    "Narrator"
                  ],
                  [
                    "set",
                    "@entity.text",
                    "Welcome, adventurer. Your journey begins here."
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "position": "bottom",
                      "type": "dialogue-box",
                      "dialogue": {
                        "text": "@entity.text",
                        "speaker": "@entity.speaker"
                      },
                      "typewriterSpeed": 30.0
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "talking",
                "event": "ADVANCE",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "success": "DialogueNodeLoaded",
                        "failure": "DialogueNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "dialogue": {
                        "text": "@entity.text",
                        "speaker": "@entity.speaker"
                      },
                      "position": "bottom",
                      "typewriterSpeed": 30.0,
                      "type": "dialogue-box"
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "talking",
                "event": "CHOICE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "typewriterSpeed": 30.0,
                      "dialogue": {
                        "speaker": "@entity.speaker",
                        "text": "@entity.text"
                      },
                      "type": "dialogue-box",
                      "position": "bottom"
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "idle",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Dialogue complete",
                          "variant": "caption"
                        },
                        {
                          "icon": "message-circle",
                          "label": "New Dialogue",
                          "type": "button",
                          "action": "START_DIALOGUE",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "talking",
                "event": "START_DIALOGUE",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "failure": "DialogueNodeLoadFailed",
                        "success": "DialogueNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "dialogue": {
                        "speaker": "@entity.speaker",
                        "text": "@entity.text"
                      },
                      "position": "bottom",
                      "type": "dialogue-box",
                      "typewriterSpeed": 30.0
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DialogueNodeDialoguePage",
          "path": "/dialoguenodes",
          "traits": [
            {
              "ref": "DialogueNodeDialogue"
            }
          ]
        }
      ]
    }
  ]
}