{
  "name": "std-quest",
  "version": "1.0.0",
  "description": "std-quest as a Function",
  "orbitals": [
    {
      "name": "QuestLogOrbital",
      "entity": {
        "name": "QuestLog",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "complete",
              "failed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "activeId",
            "type": "string",
            "default": ""
          },
          {
            "name": "activeName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "QuestLogTracking",
          "category": "interaction",
          "linkedEntity": "QuestLog",
          "emits": [
            {
              "event": "QuestLogLoaded",
              "description": "Fired when QuestLog finishes loading; payload.data holds the quests",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[QuestLog]"
                }
              ]
            },
            {
              "event": "QuestLogLoadFailed",
              "description": "Fired when QuestLog fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestLogUpdated",
              "description": "Fired when a quest is updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestLogUpdateFailed",
              "description": "Fired when updating a quest fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "available"
              },
              {
                "name": "active"
              },
              {
                "name": "progressing"
              },
              {
                "name": "complete"
              },
              {
                "name": "failed"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "QuestLogLoaded",
                "name": "QuestLog loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[QuestLog]"
                  }
                ]
              },
              {
                "key": "QuestLogLoadFailed",
                "name": "QuestLog load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACCEPT",
                "name": "Accept",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "QuestLog"
                  }
                ]
              },
              {
                "key": "PROGRESS",
                "name": "Progress"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAIL",
                "name": "Fail"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "QuestLogUpdated",
                "name": "QuestLog updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "QuestLogUpdateFailed",
                "name": "QuestLog update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading quests…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "available",
                "event": "QuestLogLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "flag"
                                },
                                {
                                  "type": "typography",
                                  "content": "QuestLogs Board",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "entity": "@payload.data",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "gap": "sm",
                                      "align": "center",
                                      "direction": "horizontal",
                                      "children": [
                                        {
                                          "name": "flag",
                                          "type": "icon"
                                        },
                                        {
                                          "content": "@item.name",
                                          "variant": "h4",
                                          "type": "typography"
                                        }
                                      ]
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ],
                                  "justify": "between"
                                },
                                {
                                  "variant": "caption",
                                  "content": "@item.status",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "itemActions": [
                            {
                              "label": "Accept",
                              "event": "ACCEPT"
                            }
                          ],
                          "type": "data-list",
                          "groupBy": "status"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "QuestLogLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load quests",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "available",
                "to": "active",
                "event": "ACCEPT",
                "effects": [
                  [
                    "set",
                    "@entity.activeId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.activeName",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@entity.activeName",
                          "variant": "h2"
                        },
                        {
                          "type": "progress-bar",
                          "value": 50.0,
                          "showPercentage": true
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "PROGRESS",
                              "label": "Progress"
                            },
                            {
                              "variant": "success",
                              "label": "Complete",
                              "action": "COMPLETE",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "label": "Fail",
                              "action": "FAIL",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "progressing",
                "event": "PROGRESS",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "status": "active",
                      "id": "@entity.activeId"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@entity.activeName",
                          "variant": "h2"
                        },
                        {
                          "showPercentage": true,
                          "type": "progress-bar",
                          "value": 75.0
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "success",
                              "action": "COMPLETE",
                              "label": "Complete",
                              "type": "button"
                            },
                            {
                              "label": "Fail",
                              "type": "button",
                              "action": "FAIL",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "status": "complete",
                      "id": "@entity.activeId"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Quest Complete"
                        },
                        {
                          "type": "alert",
                          "message": "Congratulations! The quest has been completed.",
                          "variant": "success"
                        },
                        {
                          "icon": "arrow-left",
                          "type": "button",
                          "label": "View Quests",
                          "action": "RESET",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "id": "@entity.activeId",
                      "status": "failed"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "variant": "h2",
                          "content": "Quest Failed",
                          "type": "typography"
                        },
                        {
                          "message": "The quest was not completed. You can try again.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "label": "View Quests",
                          "type": "button",
                          "action": "RESET",
                          "variant": "primary",
                          "icon": "arrow-left"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "progressing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "status": "complete",
                      "id": "@entity.activeId"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Quest Complete"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Congratulations! The quest has been completed."
                        },
                        {
                          "label": "View Quests",
                          "variant": "primary",
                          "type": "button",
                          "action": "RESET",
                          "icon": "arrow-left"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "progressing",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "status": "failed",
                      "id": "@entity.activeId"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Quest Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "message": "The quest was not completed. You can try again.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "icon": "arrow-left",
                          "action": "RESET",
                          "label": "View Quests"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "loading",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "failed",
                "to": "loading",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "failure": "QuestLogLoadFailed",
                        "success": "QuestLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "QuestLogPage",
          "path": "/questlogs",
          "traits": [
            {
              "ref": "QuestLogTracking"
            }
          ]
        }
      ]
    }
  ]
}
