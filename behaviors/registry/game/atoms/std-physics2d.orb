{
  "name": "std-physics2d",
  "version": "1.0.0",
  "description": "std-physics2d as a Function",
  "orbitals": [
    {
      "name": "PhysicsBodyOrbital",
      "entity": {
        "name": "PhysicsBody",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "x",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "vx",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "vy",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "forceX",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "forceY",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "physicsStatus",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "PhysicsBodyPhysics",
          "category": "interaction",
          "linkedEntity": "PhysicsBody",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "simulating"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "APPLY_FORCE",
                "name": "Apply Force",
                "payloadSchema": [
                  {
                    "name": "forceX",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "forceY",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "STOP",
                "name": "Stop"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "preset": "spring",
                          "height": 400.0,
                          "speed": 1.0,
                          "width": 800.0,
                          "running": false,
                          "type": "simulation-canvas"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "action": "START",
                          "icon": "play",
                          "label": "Start"
                        }
                      ],
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "simulating",
                "event": "START",
                "effects": [
                  [
                    "set",
                    "@entity.physicsStatus",
                    "simulating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "simulation-canvas",
                          "running": true,
                          "preset": "spring",
                          "height": 400.0,
                          "speed": 1.0,
                          "width": 800.0
                        },
                        {
                          "children": [
                            {
                              "variant": "secondary",
                              "label": "Apply Force",
                              "type": "button",
                              "action": "APPLY_FORCE",
                              "icon": "move"
                            },
                            {
                              "variant": "ghost",
                              "type": "button",
                              "icon": "square",
                              "action": "STOP",
                              "label": "Stop"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "TICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "preset": "spring",
                          "height": 400.0,
                          "width": 800.0,
                          "running": true,
                          "speed": 1.0,
                          "type": "simulation-canvas"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "APPLY_FORCE",
                              "label": "Apply Force",
                              "variant": "secondary",
                              "icon": "move"
                            },
                            {
                              "type": "button",
                              "action": "STOP",
                              "variant": "ghost",
                              "icon": "square",
                              "label": "Stop"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "APPLY_FORCE",
                "effects": [
                  [
                    "set",
                    "@entity.forceX",
                    "@payload.forceX"
                  ],
                  [
                    "set",
                    "@entity.forceY",
                    "@payload.forceY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "simulation-canvas",
                          "speed": 1.0,
                          "preset": "spring",
                          "height": 400.0,
                          "width": 800.0,
                          "running": true
                        },
                        {
                          "children": [
                            {
                              "action": "APPLY_FORCE",
                              "icon": "move",
                              "label": "Apply Force",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "label": "Stop",
                              "icon": "square",
                              "type": "button",
                              "action": "STOP",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "set",
                    "@entity.physicsStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "simulation-canvas",
                          "preset": "spring",
                          "running": false,
                          "speed": 1.0,
                          "height": 400.0,
                          "width": 800.0
                        },
                        {
                          "type": "button",
                          "action": "START",
                          "icon": "play",
                          "variant": "primary",
                          "label": "Start"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "speed": 1.0,
                          "width": 800.0,
                          "preset": "spring",
                          "type": "simulation-canvas",
                          "height": 400.0,
                          "running": true
                        },
                        {
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Apply Force",
                              "icon": "move",
                              "action": "APPLY_FORCE",
                              "variant": "secondary"
                            },
                            {
                              "action": "STOP",
                              "type": "button",
                              "label": "Stop",
                              "icon": "square",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PhysicsBodyPhysicsPage",
          "path": "/physicsbodys/physics",
          "traits": [
            {
              "ref": "PhysicsBodyPhysics"
            }
          ]
        }
      ]
    }
  ]
}