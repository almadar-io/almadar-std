{
  "name": "std-generic-app",
  "version": "1.0.0",
  "description": "Generic fallback app: 8 reusable orbital factories (Contact, Item, Activity, Task, CalendarEvent, Widget, FeedPost, Note) under shared AppShell chrome. Picked by orbital-agent when no domain-specific organism is a confident match — agent maps prompt nouns to orbitals and supplies entity/title overrides via standard factory params.",
  "orbitals": [
    {
      "name": "ContactOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Contact",
        "collection": "contacts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "company",
            "type": "string",
            "default": ""
          },
          {
            "name": "role",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ContactAppLayout",
          "config": {
            "contentTrait": "@trait.ContactCatalog",
            "searchEvent": "CONTACT_SEARCH",
            "notifications": [],
            "notificationClickEvent": "CONTACT_NOTIFICATIONS_OPEN",
            "appName": "App",
            "navItems": [
              {
                "href": "/contacts",
                "icon": "users",
                "label": "Contacts"
              },
              {
                "icon": "package",
                "label": "Items",
                "href": "/items"
              },
              {
                "icon": "activity",
                "label": "Activities",
                "href": "/activities"
              },
              {
                "href": "/tasks",
                "label": "Tasks",
                "icon": "check-square"
              },
              {
                "href": "/calendar",
                "icon": "calendar",
                "label": "Calendar"
              },
              {
                "href": "/widgets",
                "icon": "layout-dashboard",
                "label": "Dashboard"
              },
              {
                "href": "/feed",
                "icon": "rss",
                "label": "Feed"
              },
              {
                "label": "Notes",
                "icon": "file-text",
                "href": "/notes"
              }
            ]
          },
          "events": {
            "SEARCH": "CONTACT_SEARCH",
            "NOTIFY_CLICK": "CONTACT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ContactCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CONTACT_SEARCH",
              "triggers": "CONTACT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              }
            },
            {
              "event": "CONTACT_NOTIFICATIONS_OPEN",
              "triggers": "CONTACT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CONTACT_SEARCH",
                "name": "Contact Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONTACT_NOTIFICATIONS_OPEN",
                "name": "Contact Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "users"
                                },
                                {
                                  "content": "Contacts",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "label": "New Contact",
                              "variant": "primary",
                              "icon": "plus",
                              "type": "button",
                              "action": "CREATE"
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            "@trait.ContactSearch",
                            "@trait.ContactFilter"
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ContactBrowseList"
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CONTACT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CONTACT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-8",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "No notifications",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ContactSearch",
          "config": {
            "placeholder": "Search contacts…",
            "event": "CONTACT_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ContactFilter",
          "config": {
            "filters": [
              {
                "options": [],
                "field": "company",
                "label": "Company",
                "filterType": "select"
              }
            ],
            "event": "CONTACT_FILTER"
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ContactBrowseList",
          "linkedEntity": "Contact",
          "config": {
            "cols": 1.0,
            "fields": [
              {
                "name": "name",
                "variant": "h3",
                "icon": "user"
              },
              {
                "variant": "body",
                "name": "email"
              },
              {
                "name": "phone",
                "variant": "caption"
              },
              {
                "name": "company",
                "variant": "badge"
              },
              {
                "variant": "caption",
                "name": "role"
              }
            ],
            "gap": "sm",
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "ContactSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "ContactFilter"
              }
            },
            {
              "event": "CONTACT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            },
            {
              "event": "CONTACT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            },
            {
              "event": "CONTACT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactCreate",
          "linkedEntity": "Contact",
          "config": {
            "mode": "create",
            "title": "New Contact",
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ],
            "icon": "plus-circle"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ContactCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactEdit",
          "linkedEntity": "Contact",
          "config": {
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ],
            "icon": "edit",
            "title": "Edit Contact",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactView",
          "linkedEntity": "Contact",
          "config": {
            "title": "View Contact",
            "icon": "eye",
            "mode": "edit",
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ContactDelete",
          "linkedEntity": "Contact",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Contact",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "name": "ContactPersistor",
          "category": "lifecycle",
          "linkedEntity": "Contact",
          "emits": [
            {
              "event": "CONTACT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CONTACT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CONTACT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ContactCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ContactEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONTACT_CREATED",
                "name": "Contact Created"
              },
              {
                "key": "CONTACT_UPDATED",
                "name": "Contact Updated"
              },
              {
                "key": "CONTACT_DELETED",
                "name": "Contact Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Contact",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CONTACT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ContactsPage",
          "path": "/contacts",
          "traits": [
            {
              "ref": "ContactAppLayout"
            },
            {
              "ref": "ContactCatalog"
            },
            {
              "ref": "ContactSearch"
            },
            {
              "ref": "ContactFilter"
            },
            {
              "ref": "ContactBrowseList"
            },
            {
              "ref": "ContactCreate"
            },
            {
              "ref": "ContactEdit"
            },
            {
              "ref": "ContactView"
            },
            {
              "ref": "ContactDelete"
            },
            {
              "ref": "ContactPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Item",
        "collection": "items",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "sku",
            "type": "string",
            "default": ""
          },
          {
            "name": "price",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "quantity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ItemAppLayout",
          "config": {
            "navItems": [
              {
                "label": "Contacts",
                "href": "/contacts",
                "icon": "users"
              },
              {
                "label": "Items",
                "href": "/items",
                "icon": "package"
              },
              {
                "href": "/activities",
                "icon": "activity",
                "label": "Activities"
              },
              {
                "label": "Tasks",
                "href": "/tasks",
                "icon": "check-square"
              },
              {
                "label": "Calendar",
                "icon": "calendar",
                "href": "/calendar"
              },
              {
                "href": "/widgets",
                "icon": "layout-dashboard",
                "label": "Dashboard"
              },
              {
                "icon": "rss",
                "label": "Feed",
                "href": "/feed"
              },
              {
                "label": "Notes",
                "icon": "file-text",
                "href": "/notes"
              }
            ],
            "searchEvent": "ITEM_SEARCH",
            "notifications": [],
            "appName": "App",
            "contentTrait": "@trait.ItemCatalog",
            "notificationClickEvent": "ITEM_NOTIFICATIONS_OPEN"
          },
          "events": {
            "NOTIFY_CLICK": "ITEM_NOTIFICATIONS_OPEN",
            "SEARCH": "ITEM_SEARCH"
          }
        },
        {
          "name": "ItemCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_SEARCH",
              "triggers": "ITEM_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ItemAppLayout"
              }
            },
            {
              "event": "ITEM_NOTIFICATIONS_OPEN",
              "triggers": "ITEM_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ItemAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEM_SEARCH",
                "name": "Item Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ITEM_NOTIFICATIONS_OPEN",
                "name": "Item Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "package"
                                },
                                {
                                  "type": "typography",
                                  "content": "Items",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "icon": "plus",
                              "label": "New Item"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            "@trait.ItemSearch",
                            "@trait.ItemFilter"
                          ]
                        },
                        "@trait.ItemBrowseList"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ITEM_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ITEM_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "No notifications",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "action": "INIT",
                          "label": "Back",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ItemSearch",
          "config": {
