        {
          "category": "lifecycle",
          "emits": [
            {
              "description": "A new feed item has been created.",
              "event": "FEED_CREATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "posted, published, added",
              "tier": "essential"
            },
            {
              "description": "Signals that the feed data has been refreshed or modified.",
              "event": "FEED_UPDATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "refresh, update, new, changed",
              "tier": "customization"
            },
            {
              "description": "Signals a feed item has been removed.",
              "event": "FEED_DELETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "removed, purged, archived",
              "tier": "customization"
            }
          ],
          "linkedEntity": "FeedPost",
          "listens": [
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "FeedCreate"
              },
              "triggers": "DO_CREATE"
            },
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "FeedEdit"
              },
              "triggers": "DO_UPDATE"
            },
            {
              "event": "CONFIRM_DELETE",
              "source": {
                "kind": "trait",
                "trait": "FeedDelete"
              },
              "triggers": "DO_DELETE"
            }
          ],
          "name": "FeedPersistor",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Initiates the creation of a new record.",
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "new, add, generate, initialize",
                "tier": "essential"
              },
              {
                "description": "Indicates data has been modified and requires synchronization.",
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "refresh, sync, changed, modified",
                "tier": "essential"
              },
              {
                "description": "Initiates the removal of a record.",
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "remove, discard, erase",
                "tier": "essential"
              },
              {
                "description": "A new feed item has been created.",
                "key": "FEED_CREATED",
                "name": "Feed Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "posted, published, added",
                "tier": "essential"
              },
              {
                "description": "Signals that the feed data has been refreshed or modified.",
                "key": "FEED_UPDATED",
                "name": "Feed Updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "refresh, update, new, changed",
                "tier": "customization"
              },
              {
                "description": "Signals a feed item has been removed.",
                "key": "FEED_DELETED",
                "name": "Feed Deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "removed, purged, archived",
                "tier": "customization"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "FeedPost",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "FEED_CREATED"
                      }
                    }
                  ]
                ],
                "event": "DO_CREATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "FeedPost",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "FEED_UPDATED"
                      }
                    }
                  ]
                ],
                "event": "DO_UPDATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "FeedPost",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "FEED_DELETED"
                      }
                    }
                  ]
                ],
                "event": "DO_DELETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
