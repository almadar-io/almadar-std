{
  "description": "Generic fallback app: 8 reusable orbital factories (Contact, Item, Activity, Task, CalendarEvent, Widget, FeedPost, Note) under shared AppShell chrome. Picked by orbital-agent when no domain-specific organism is a confident match — agent maps prompt nouns to orbitals and supplies entity/title overrides via standard factory params.",
  "name": "std-generic-app",
  "orbitals": [
    {
      "entity": {
        "collection": "contacts",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The identifier or label for the contact.",
            "name": "name",
            "required": true,
            "synonyms": "label, identifier, designation",
            "type": "string"
          },
          {
            "default": "",
            "description": "The electronic mail address for contact.",
            "name": "email",
            "synonyms": "email address, mail, contact email",
            "type": "string"
          },
          {
            "default": "",
            "description": "The phone number associated with the entity.",
            "name": "phone",
            "synonyms": "telephone, number, contact number",
            "type": "string"
          },
          {
            "default": "",
            "description": "The organization or business associated with the contact.",
            "name": "company",
            "synonyms": "organization, employer, business",
            "type": "string"
          },
          {
            "default": "",
            "description": "The function or position of this entity within a relationship.",
            "name": "role",
            "synonyms": "function, position, relationship, type",
            "type": "string"
          },
          {
            "default": "",
            "description": "Free-form text providing additional information.",
            "name": "notes",
            "synonyms": "comments, remarks, details, information",
            "type": "string"
          },
          {
            "default": "",
            "description": "A unique identifier awaiting confirmation or processing.",
            "name": "pendingId",
            "synonyms": "tempId, provisionalId, draftId",
            "type": "string"
          }
        ],
        "name": "Contact",
        "persistence": "persistent"
      },
      "name": "ContactOrbital",
      "pages": [
        {
          "name": "ContactsPage",
          "path": "/contacts",
          "traits": [
            {
              "ref": "ContactAppLayout"
            },
            {
              "ref": "ContactCatalog"
            },
            {
              "ref": "ContactSearch"
            },
            {
              "ref": "ContactFilter"
            },
            {
              "ref": "ContactBrowseList"
            },
            {
              "ref": "ContactCreate"
            },
            {
              "ref": "ContactEdit"
            },
            {
              "ref": "ContactView"
            },
            {
              "ref": "ContactDelete"
            },
            {
              "ref": "ContactPersistor"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "appName": "App",
            "contentTrait": "@trait.ContactCatalog",
            "navItems": [
              {
                "href": "/contacts",
                "icon": "users",
                "label": "Contacts"
              },
              {
                "href": "/items",
                "icon": "package",
                "label": "Items"
              },
              {
                "href": "/activities",
                "icon": "activity",
                "label": "Activities"
              },
              {
                "href": "/tasks",
                "icon": "check-square",
                "label": "Tasks"
              },
              {
                "href": "/calendar",
                "icon": "calendar",
                "label": "Calendar"
              },
              {
                "href": "/widgets",
                "icon": "layout-dashboard",
                "label": "Dashboard"
              },
              {
                "href": "/feed",
                "icon": "rss",
                "label": "Feed"
              },
              {
                "href": "/notes",
                "icon": "file-text",
                "label": "Notes"
              }
            ],
            "notificationClickEvent": "CONTACT_NOTIFICATIONS_OPEN",
            "notifications": [],
            "searchEvent": "CONTACT_SEARCH"
          },
          "events": {
            "NOTIFY_CLICK": "CONTACT_NOTIFICATIONS_OPEN",
            "SEARCH": "CONTACT_SEARCH"
          },
          "name": "ContactAppLayout",
          "ref": "AppShell.traits.AppLayout"
        },
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Signals the creation of a new record.",
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "new, add, initialize, generate",
              "tier": "essential"
            }
          ],
          "listens": [
            {
              "event": "CONTACT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              },
              "triggers": "CONTACT_SEARCH"
            },
            {
              "event": "CONTACT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              },
              "triggers": "CONTACT_NOTIFICATIONS_OPEN"
            }
          ],
          "name": "ContactCatalog",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Triggers a search for contacts.",
                "key": "CONTACT_SEARCH",
                "name": "Contact Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "synonyms": "find, query, lookup, search",
                "tier": "essential"
              },
              {
                "description": "Indicates new contact notifications are available.",
                "key": "CONTACT_NOTIFICATIONS_OPEN",
                "name": "Contact Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "alerts, updates, reminders, news",
                "tier": "customization"
              },
              {
                "description": "Signals the creation of a new record.",
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ],
                "synonyms": "new, add, initialize, generate",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "users",
                                  "type": "icon"
                                },
                                {
                                  "content": "Contacts",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "action": "CREATE",
                              "icon": "plus",
                              "label": "New Contact",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "children": [
                            "@trait.ContactSearch",
                            "@trait.ContactFilter"
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ContactBrowseList"
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "composing",
                "to": "composing"
              },
              {
                "event": "CONTACT_SEARCH",
                "from": "composing",
                "to": "composing"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "action": "INIT",
                          "label": "Back",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "className": "py-8",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "CONTACT_NOTIFICATIONS_OPEN",
                "from": "composing",
                "to": "composing"
              }
            ]
          }
        },
        {
          "config": {
            "event": "CONTACT_SEARCH",
            "placeholder": "Search contacts…"
          },
          "name": "ContactSearch",
          "ref": "Search.traits.SearchResultSearch"
        },
        {
          "config": {
            "event": "CONTACT_FILTER",
            "filters": [
              {
                "field": "company",
                "filterType": "select",
                "label": "Company",
                "options": []
              }
            ]
          },
          "name": "ContactFilter",
          "ref": "Filter.traits.FilterTargetFilter"
        },
        {
          "config": {
            "cols": 1.0,
            "fields": [
              {
                "icon": "user",
                "name": "name",
                "variant": "h3"
              },
              {
                "name": "email",
                "variant": "body"
              },
              {
                "name": "phone",
                "variant": "caption"
              },
              {
                "name": "company",
                "variant": "badge"
              },
              {
                "name": "role",
                "variant": "caption"
              }
            ],
            "gap": "sm",
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ]
          },
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ContactSearch"
              },
              "triggers": "REFETCH_QUERY"
            },
            {
              "event": "FILTER",
              "source": {
                "kind": "trait",
                "trait": "ContactFilter"
              },
              "triggers": "REFETCH_FILTER"
            },
            {
              "event": "CONTACT_CREATED",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              },
              "triggers": "INIT"
            },
            {
              "event": "CONTACT_UPDATED",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              },
              "triggers": "INIT"
            },
            {
              "event": "CONTACT_DELETED",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              },
              "triggers": "INIT"
            }
          ],
          "name": "ContactBrowseList",
          "ref": "Browse.traits.BrowseItemBrowse"
        },
        {
          "config": {
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ],
            "icon": "plus-circle",
            "mode": "create",
            "title": "New Contact"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ContactCatalog"
              },
              "triggers": "CREATE"
            }
          ],
          "name": "ContactCreate",
          "ref": "Modal.traits.ModalRecordModal"
        },
        {
          "config": {
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ],
            "icon": "edit",
            "mode": "edit",
            "title": "Edit Contact"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              },
              "triggers": "EDIT"
            }
          ],
          "name": "ContactEdit",
          "ref": "Modal.traits.ModalRecordModal"
        },
        {
          "config": {
            "fields": [
              "name",
              "email",
              "phone",
              "company",
              "role",
              "notes"
            ],
            "icon": "eye",
            "mode": "edit",
            "title": "View Contact"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              },
              "triggers": "VIEW"
            }
          ],
          "name": "ContactView",
          "ref": "Modal.traits.ModalRecordModal"
        },
        {
          "config": {
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete",
            "icon": "alert-triangle",
            "title": "Delete Contact"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              },
              "triggers": "DELETE"
            }
          ],
          "name": "ContactDelete",
          "ref": "Confirmation.traits.ConfirmActionConfirmation"
        },
        {
          "category": "lifecycle",
          "emits": [
            {
              "description": "Signals the creation of a new contact record.",
              "event": "CONTACT_CREATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "new contact, add contact, contact added",
              "tier": "essential"
            },
            {
              "description": "Signals that a contact's details have been modified.",
              "event": "CONTACT_UPDATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "modified, changed, refreshed",
              "tier": "essential"
            },
            {
              "description": "Signals a contact record has been removed.",
              "event": "CONTACT_DELETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "removed, purged, archived",
              "tier": "essential"
            }
          ],
          "linkedEntity": "Contact",
          "listens": [
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "ContactCreate"
              },
              "triggers": "DO_CREATE"
            },
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "ContactEdit"
              },
              "triggers": "DO_UPDATE"
            },
            {
              "event": "CONFIRM_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactDelete"
              },
              "triggers": "DO_DELETE"
            }
          ],
          "name": "ContactPersistor",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Initiates the creation of a new record.",
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "new, add, generate, initiate",
                "tier": "essential"
              },
              {
                "description": "Indicates data has been modified and needs to be refreshed.",
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "refresh, reload, update, sync",
                "tier": "essential"
              },
              {
                "description": "Initiates the removal of a record.",
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "remove, discard, purge",
                "tier": "essential"
              },
              {
                "description": "Signals the creation of a new contact record.",
                "key": "CONTACT_CREATED",
                "name": "Contact Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "new contact, add contact, contact added",
                "tier": "essential"
              },
              {
                "description": "Signals that a contact's details have been modified.",
                "key": "CONTACT_UPDATED",
                "name": "Contact Updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "modified, changed, refreshed",
                "tier": "essential"
              },
              {
                "description": "Signals a contact record has been removed.",
                "key": "CONTACT_DELETED",
                "name": "Contact Deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "removed, purged, archived",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_CREATED"
                      }
                    }
                  ]
                ],
                "event": "DO_CREATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_UPDATED"
                      }
                    }
                  ]
                ],
                "event": "DO_UPDATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Contact",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CONTACT_DELETED"
                      }
                    }
                  ]
                ],
                "event": "DO_DELETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "AppShell",
          "from": "std/behaviors/std-app-layout"
        },
        {
          "as": "Modal",
          "from": "std/behaviors/std-modal"
        },
        {
          "as": "Confirmation",
          "from": "std/behaviors/std-confirmation"
        },
        {
          "as": "Search",
          "from": "std/behaviors/std-search"
        },
        {
          "as": "Filter",
          "from": "std/behaviors/std-filter"
        },
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        }
      ]
    },
    {
      "entity": {
        "collection": "items",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
