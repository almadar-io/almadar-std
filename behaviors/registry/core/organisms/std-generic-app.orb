              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "CalendarCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CalendarEdit",
          "linkedEntity": "ScheduledEvent",
          "config": {
            "mode": "edit",
            "fields": [
              "title",
              "startTime",
              "endTime",
              "location",
              "attendees",
              "description"
            ],
            "title": "Edit Event",
            "icon": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "CalendarBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CalendarDelete",
          "linkedEntity": "ScheduledEvent",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Event",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "CalendarBrowseList"
              }
            }
          ]
        },
        {
          "name": "CalendarPersistor",
          "category": "lifecycle",
          "linkedEntity": "CalendarEvent",
          "emits": [
            {
              "event": "CAL_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CAL_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CAL_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CalendarCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "CalendarEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CalendarDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CAL_CREATED",
                "name": "Cal Created"
              },
              {
                "key": "CAL_UPDATED",
                "name": "Cal Updated"
              },
              {
                "key": "CAL_DELETED",
                "name": "Cal Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ScheduledEvent",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CAL_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "ScheduledEvent",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CAL_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ScheduledEvent",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CAL_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CalendarPage",
          "path": "/calendar",
          "traits": [
            {
              "ref": "CalendarAppLayout"
            },
            {
              "ref": "CalendarCatalog"
            },
            {
              "ref": "CalendarView"
            },
            {
              "ref": "CalendarBrowseList"
            },
            {
              "ref": "CalendarCreate"
            },
            {
              "ref": "CalendarEdit"
            },
            {
              "ref": "CalendarDelete"
            },
            {
              "ref": "CalendarPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "WidgetOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
