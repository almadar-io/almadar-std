      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "FeedAppLayout",
          "config": {
            "notifications": [],
            "contentTrait": "@trait.FeedCatalog",
            "searchEvent": "FEED_SEARCH",
            "notificationClickEvent": "FEED_NOTIFICATIONS_OPEN",
            "appName": "App",
