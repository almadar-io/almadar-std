              {
                "icon": "package",
                "href": "/items",
                "label": "Items"
              },
              {
                "label": "Activities",
                "href": "/activities",
                "icon": "activity"
              },
              {
                "icon": "check-square",
                "label": "Tasks",
                "href": "/tasks"
              },
              {
                "icon": "calendar",
                "href": "/calendar",
                "label": "Calendar"
              },
              {
                "label": "Dashboard",
                "href": "/widgets",
                "icon": "layout-dashboard"
              },
              {
                "label": "Feed",
                "icon": "rss",
                "href": "/feed"
              },
              {
                "href": "/notes",
                "icon": "file-text",
                "label": "Notes"
              }
