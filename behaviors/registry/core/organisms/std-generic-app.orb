          },
          {
            "default": "",
            "description": "A textual explanation or summary of the item.",
            "name": "description",
            "synonyms": "summary, details, explanation, about",
            "type": "string"
          },
          {
            "default": "",
            "description": "Unique identifier for a product or item.",
