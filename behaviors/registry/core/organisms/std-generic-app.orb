              "ref": "ItemSearch"
            },
            {
              "ref": "ItemFilter"
            },
            {
              "ref": "ItemBrowseList"
            },
            {
              "ref": "ItemCreate"
            },
            {
              "ref": "ItemEdit"
            },
            {
              "ref": "ItemView"
            },
            {
              "ref": "ItemDelete"
            },
            {
              "ref": "ItemPersistor"
            }
          ]
        }
      ]
    },
