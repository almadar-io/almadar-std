              "event": "FEED_SEARCH",
              "triggers": "FEED_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "FeedAppLayout"
              }
            },
            {
              "event": "FEED_NOTIFICATIONS_OPEN",
              "triggers": "FEED_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "FeedAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FEED_SEARCH",
                "name": "Feed Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FEED_NOTIFICATIONS_OPEN",
                "name": "Feed Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "rss"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Feed"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "label": "New Post",
                              "icon": "plus",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.FeedBrowseList",
                        "@trait.FeedPagination"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "FEED_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "FEED_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "label": "Back",
                          "type": "button",
                          "action": "INIT",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Pagination.traits.PagedItemPagination",
          "name": "FeedPagination",
          "config": {
            "pageSize": 10.0
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "FeedBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "FeedBrowseList",
          "linkedEntity": "FeedPost",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "name": "title",
                "variant": "h3",
                "icon": "rss"
              },
              {
                "variant": "body",
                "name": "body"
              },
              {
                "name": "author",
                "variant": "caption"
              },
              {
                "format": "date",
                "variant": "caption",
                "name": "postedAt"
              },
              {
                "name": "tags",
                "variant": "badge"
              }
            ],
            "cols": 1.0,
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "variant": "ghost",
                "label": "Edit",
                "event": "EDIT"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ]
          },
          "listens": [
            {
              "event": "FEED_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "FeedPersistor"
              }
            },
            {
              "event": "FEED_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "FeedPersistor"
              }
            },
            {
              "event": "FEED_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "FeedPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "FeedCreate",
          "linkedEntity": "FeedPost",
          "config": {
            "title": "New Post",
            "fields": [
              "title",
              "body",
              "author",
              "postedAt",
              "tags"
            ],
            "icon": "plus-circle",
