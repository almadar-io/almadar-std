                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "modified, changed, altered, updated",
                "tier": "customization"
              },
              {
                "description": "Initiates the removal of a record.",
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "remove, discard, erase",
                "tier": "essential"
              },
              {
                "description": "A new note has been created.",
                "key": "NOTE_CREATED",
                "name": "Note Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "new, added, recorded",
                "tier": "essential"
              },
              {
                "description": "Signals that a note has been modified and saved.",
                "key": "NOTE_UPDATED",
                "name": "Note Updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "modified, changed, updated",
                "tier": "essential"
              },
              {
                "description": "Signals a note has been removed.",
                "key": "NOTE_DELETED",
                "name": "Note Deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "removed, purged, discarded",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "Note",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "NOTE_CREATED"
                      }
                    }
                  ]
                ],
                "event": "DO_CREATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "Note",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "NOTE_UPDATED"
                      }
                    }
                  ]
                ],
                "event": "DO_UPDATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Note",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "NOTE_DELETED"
                      }
                    }
                  ]
                ],
                "event": "DO_DELETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "AppShell",
          "from": "std/behaviors/std-app-layout"
        },
        {
          "as": "Modal",
          "from": "std/behaviors/std-modal"
        },
        {
          "as": "Confirmation",
          "from": "std/behaviors/std-confirmation"
        },
        {
          "as": "Search",
          "from": "std/behaviors/std-search"
        },
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        }
      ]
    }
  ],
  "version": "1.0.0"
}