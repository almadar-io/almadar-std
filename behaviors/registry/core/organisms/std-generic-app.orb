            "appName": "App",
            "navItems": [
              {
                "label": "Contacts",
                "href": "/contacts",
                "icon": "users"
              },
              {
                "href": "/items",
                "icon": "package",
                "label": "Items"
              },
              {
                "label": "Activities",
                "icon": "activity",
                "href": "/activities"
              },
              {
                "label": "Tasks",
                "href": "/tasks",
                "icon": "check-square"
              },
              {
                "label": "Calendar",
                "href": "/calendar",
                "icon": "calendar"
              },
              {
                "href": "/widgets",
                "label": "Dashboard",
                "icon": "layout-dashboard"
              },
              {
                "label": "Feed",
                "href": "/feed",
                "icon": "rss"
              },
              {
                "href": "/notes",
                "label": "Notes",
                "icon": "file-text"
              }
            ],
            "notificationClickEvent": "WIDGET_NOTIFICATIONS_OPEN"
