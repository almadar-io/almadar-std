        },
        {
          "category": "lifecycle",
          "emits": [
            {
              "description": "Signals a new activity has been created.",
              "event": "ACTIVITY_CREATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "new, added, generated",
              "tier": "essential"
            },
            {
              "description": "Signals that an activity has been modified and saved.",
              "event": "ACTIVITY_UPDATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "modified, changed, updated, refreshed",
              "tier": "essential"
            },
            {
              "description": "Signals that an activity record has been removed.",
              "event": "ACTIVITY_DELETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "removed, purged, discarded",
              "tier": "essential"
            }
          ],
          "linkedEntity": "Activity",
          "listens": [
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "ActivityEdit"
              },
              "triggers": "DO_UPDATE"
            },
            {
              "event": "CONFIRM_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ActivityDelete"
              },
              "triggers": "DO_DELETE"
            }
          ],
          "name": "ActivityPersistor",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates data has been modified and should be synchronized.",
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "refresh, sync, change, modify",
                "tier": "essential"
              },
              {
                "description": "Initiates the removal of a record.",
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "remove, discard, erase",
                "tier": "essential"
              },
              {
                "description": "Signals a new activity has been created.",
                "key": "ACTIVITY_CREATED",
                "name": "Activity Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "new, added, generated",
                "tier": "essential"
              },
              {
                "description": "Signals that an activity has been modified and saved.",
                "key": "ACTIVITY_UPDATED",
                "name": "Activity Updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "modified, changed, updated, refreshed",
                "tier": "essential"
              },
              {
                "description": "Signals that an activity record has been removed.",
                "key": "ACTIVITY_DELETED",
                "name": "Activity Deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "removed, purged, discarded",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "Activity",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ACTIVITY_UPDATED"
                      }
                    }
                  ]
                ],
                "event": "DO_UPDATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Activity",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ACTIVITY_DELETED"
                      }
                    }
                  ]
                ],
                "event": "DO_DELETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
