        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        }
      ],
      "entity": {
        "name": "Widget",
        "collection": "widgets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "default": "metric"
          },
          {
            "name": "dataSource",
            "type": "string",
            "default": ""
          },
          {
            "name": "value",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "label",
            "type": "string",
            "default": ""
          },
          {
            "name": "refreshInterval",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "WidgetAppLayout",
          "config": {
            "contentTrait": "@trait.WidgetCatalog",
