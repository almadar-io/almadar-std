        },
        {
          "category": "lifecycle",
          "emits": [
            {
              "description": "A new widget has been generated or added.",
              "event": "WIDGET_CREATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "new, added, generated, created",
              "tier": "essential"
            },
            {
              "description": "Signals a widget's data or appearance has been modified.",
              "event": "WIDGET_UPDATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "refresh, change, update",
              "tier": "customization"
            },
            {
              "description": "Signals a widget has been removed.",
              "event": "WIDGET_DELETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "removed, discarded, purged",
              "tier": "customization"
            }
          ],
          "linkedEntity": "Widget",
          "listens": [
            {
              "event": "SAVE",
              "source": {
                "kind": "trait",
                "trait": "WidgetEdit"
              },
              "triggers": "DO_UPDATE"
            },
            {
              "event": "CONFIRM_DELETE",
              "source": {
                "kind": "trait",
                "trait": "WidgetDelete"
              },
              "triggers": "DO_DELETE"
            }
          ],
          "name": "WidgetPersistor",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates data has been modified and needs to be refreshed.",
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "required": true,
                    "type": "object"
                  }
                ],
                "synonyms": "refresh, reload, update, sync",
                "tier": "essential"
              },
              {
                "description": "Initiates the removal of a record.",
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "remove, discard, erase",
                "tier": "essential"
              },
              {
                "description": "A new widget has been generated or added.",
                "key": "WIDGET_CREATED",
                "name": "Widget Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "new, added, generated, created",
                "tier": "essential"
              },
              {
                "description": "Signals a widget's data or appearance has been modified.",
                "key": "WIDGET_UPDATED",
                "name": "Widget Updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "refresh, change, update",
                "tier": "customization"
              },
              {
                "description": "Signals a widget has been removed.",
                "key": "WIDGET_DELETED",
                "name": "Widget Deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "removed, discarded, purged",
                "tier": "customization"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "update",
                    "Widget",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "WIDGET_UPDATED"
                      }
                    }
                  ]
                ],
                "event": "DO_UPDATE",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Widget",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "WIDGET_DELETED"
                      }
                    }
                  ]
                ],
                "event": "DO_DELETE",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
