              {
                "name": "description",
                "variant": "body"
              },
              {
                "name": "sku",
                "variant": "caption"
              },
              {
                "format": "currency",
                "variant": "badge",
                "name": "price"
              },
              {
                "name": "quantity",
                "variant": "badge"
              },
              {
                "name": "category",
                "variant": "caption"
              }
            ]
