                "trait": "ItemFilter"
              }
            },
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ItemPersistor"
              }
            },
            {
              "event": "ITEM_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ItemPersistor"
              }
            },
            {
