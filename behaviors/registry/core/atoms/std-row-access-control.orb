{
  "name": "std-row-access-control",
  "version": "1.0.0",
  "description": "std-row-access-control — row-level access control gate. Listens for `RowsLoaded` (rename via traitOverrides.events to the consumer's load event), filters `@payload.data` by `@user.id` (when `ownerField` is set) and/or `@user.role` (when `visibleRoles` is non-empty), re-emits `RowsFiltered` for downstream consumers (rename to wire into the UI atom's listen). Composable via `extraTraits` to interpose between a data fetch and a list/grid UI.",
  "orbitals": [
    {
      "name": "RowAccessControlOrbital",
      "entity": {
        "name": "RowAccessGateView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "filteredData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object"
            }
          },
          {
            "name": "inputCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "outputCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "accessDenied",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "RowAccessGate",
          "category": "lifecycle",
          "capabilities": [
            "access",
            "privacy"
          ],
          "linkedEntity": "RowAccessGateView",
          "emits": [
            {
              "event": "RowsFiltered",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                },
                {
                  "name": "filteredCount",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "RowsLoaded",
                "name": "Rows loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "RowsFiltered",
                "name": "Rows filtered",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "filteredCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "RowsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.inputCount",
                    [
                      "array/len",
                      "@payload.data"
                    ]
                  ],
                  [
                    "set",
                    "@entity.accessDenied",
                    [
                      "and",
                      [
                        "not",
                        [
                          "=",
                          [
                            "array/len",
                            "@config.visibleRoles"
                          ],
                          0.0
                        ]
                      ],
                      [
                        "not",
                        [
                          "array/includes",
                          "@config.visibleRoles",
                          "@user.role"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.filteredData",
                    [
                      "if",
                      "@entity.accessDenied",
                      [],
                      [
                        "if",
                        [
                          "not",
                          [
                            "=",
                            "@config.ownerField",
                            ""
                          ]
                        ],
                        [
                          "array/filter",
                          "@payload.data",
                          [
                            "fn",
                            "row",
                            [
                              "=",
                              [
                                "object/get",
                                "@row",
                                "@config.ownerField"
                              ],
                              "@user.id"
                            ]
                          ]
                        ],
                        "@payload.data"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.outputCount",
                    [
                      "array/len",
                      "@entity.filteredData"
                    ]
                  ],
                  [
                    "emit",
                    "RowsFiltered",
                    {
                      "data": "@entity.filteredData",
                      "filteredCount": "@entity.outputCount"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "visibleRoles": {
              "type": "[string]",
              "default": [],
              "label": "Allowed roles",
              "description": "Roles permitted to see any row (empty = no role gate)",
              "items": {
                "type": "string"
              }
            },
            "ownerField": {
              "type": "string",
              "default": "",
              "label": "Owner field",
              "description": "Row field holding the owning user id (blank disables owner filter)"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RowAccessControlPage",
          "path": "/row-access-control",
          "traits": [
            {
              "ref": "RowAccessGate"
            }
          ]
        }
      ]
    }
  ]
}