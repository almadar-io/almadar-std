{
  "name": "std-gallery",
  "version": "1.0.0",
  "description": "std-gallery — image gallery primitive. Browses GalleryItems in a media-gallery grid; opens a lightbox modal for full-size viewing.",
  "orbitals": [
    {
      "name": "GalleryItemOrbital",
      "entity": {
        "name": "GalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string",
            "default": "https://picsum.photos/seed/gallery/800/600"
          }
        ]
      },
      "traits": [
        {
          "name": "GalleryItemGallery",
          "entityRebindable": true,
          "entityContract": {
            "provides": [
              "description",
              "imageUrl",
              "name"
            ]
          },
          "category": "interaction",
          "linkedEntity": "GalleryItem",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE"
            },
            {
              "event": "GalleryItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GalleryItem]"
                }
              ]
            },
            {
              "event": "GalleryItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GalleryItemLoaded",
                "name": "GalleryItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GalleryItem]"
                  }
                ]
              },
              {
                "key": "GalleryItemLoadFailed",
                "name": "GalleryItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "GalleryItem"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "success": "GalleryItemLoaded",
                        "failure": "GalleryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading gallery…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "GalleryItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "image",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "media-gallery"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "GalleryItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "lightbox",
                      "currentIndex": 0.0,
                      "closeAction": "CLOSE",
                      "isOpen": true,
                      "images": [
                        {
                          "src": "@entity.imageUrl",
                          "caption": "@entity.name",
                          "alt": "@entity.name"
                        }
                      ],
                      "showCounter": true
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "success": "GalleryItemLoaded",
                        "failure": "GalleryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading gallery…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "success": "GalleryItemLoaded",
                        "failure": "GalleryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Gallery",
              "label": "Section title",
              "description": "Heading shown above the image gallery",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "GalleryItemGalleryPage",
          "path": "/galleryitems/gallery",
          "traits": [
            {
              "ref": "GalleryItemGallery"
            }
          ]
        }
      ]
    }
  ]
}