{
  "name": "std-gallery",
  "version": "1.0.0",
  "description": "std-gallery as a Function",
  "orbitals": [
    {
      "name": "GalleryItemOrbital",
      "entity": {
        "name": "GalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string",
            "default": "https://picsum.photos/seed/gallery/800/600"
          }
        ]
      },
      "traits": [
        {
          "name": "GalleryItemGallery",
          "category": "interaction",
          "linkedEntity": "GalleryItem",
          "emits": [
            {
              "event": "GalleryItemLoaded",
              "description": "Fired when GalleryItem finishes loading; payload.data holds the gallery",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GalleryItem]"
                }
              ]
            },
            {
              "event": "GalleryItemLoadFailed",
              "description": "Fired when GalleryItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GalleryItemLoaded",
                "name": "GalleryItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GalleryItem]"
                  }
                ]
              },
              {
                "key": "GalleryItemLoadFailed",
                "name": "GalleryItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "GalleryItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "image",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "GalleryItems Gallery",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "type": "typography",
                              "content": "Click any image to view full size",
                              "color": "muted",
                              "variant": "caption"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "imageField": "imageUrl",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "gap": "md",
                          "itemActions": [
                            {
                              "label": "View",
                              "icon": "maximize",
                              "event": "VIEW"
                            }
                          ],
                          "cols": 3.0,
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "h4",
                              "name": "name"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "GalleryItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to load",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "action": "INIT",
                          "label": "Retry",
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "images": [
                        {
                          "src": "https://picsum.photos/seed/gallery1/800/600",
                          "alt": "Image",
                          "caption": "Image"
                        }
                      ],
                      "closeAction": "CLOSE",
                      "currentIndex": 0.0,
                      "type": "lightbox",
                      "showCounter": true,
                      "isOpen": true
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "GalleryItemGalleryPage",
          "path": "/galleryitems/gallery",
          "traits": [
            {
              "ref": "GalleryItemGallery"
            }
          ]
        }
      ]
    }
  ]
}