                                  "content": "Transaction complete",
                                  "type": "typography",
                                  "align": "center"
                                },
                                {
                                  "type": "typography",
                                  "content": "@config.transactionAmount",
                                  "variant": "h1",
                                  "align": "center"
                                },
                                {
                                  "color": "muted",
                                  "align": "center",
                                  "content": "Funds have been released to the seller.",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "content": "Activity",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "fields": [
                            "title",
                            "description",
                            "timestamp",
                            "status"
                          ],
                          "type": "timeline",
                          "entity": "@entity.audit"
                        },
                        {
                          "label": "Start a new transaction",
                          "type": "button",
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "variant": "secondary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "funded",
                "to": "capturing_dispute",
                "event": "OPEN_DISPUTE",
                "effects": [
                  [
                    "set",
                    "@entity.reason",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "icon": "arrow-left",
                              "type": "button",
                              "variant": "ghost",
                              "action": "CANCEL_REASON"
                            },
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Open a dispute",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Describe the issue so all parties and the escrow officer can review. Funds will remain in escrow until the dispute is resolved.",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "mode": "edit",
                                  "entity": "@entity",
                                  "fields": "@config.reasonFields",
                                  "type": "form-section",
                                  "submitEvent": "SUBMIT_DISPUTE",
                                  "cancelEvent": "CANCEL_REASON",
                                  "submitLabel": "Submit dispute"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "released",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "fetch",
                    "MultiPartyView",
                    {
                      "emit": {
                        "success": "FlowLoaded",
                        "failure": "FlowLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Starting new transaction…"
                    }
                  ]
                ]
              },
              {
                "from": "disputed",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "fetch",
                    "MultiPartyView",
                    {
                      "emit": {
                        "success": "FlowLoaded",
                        "failure": "FlowLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Starting new transaction…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "cancelled",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "fetch",
                    "MultiPartyView",
                    {
                      "emit": {
                        "success": "FlowLoaded",
                        "failure": "FlowLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Starting new transaction…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MultiPartyView",
                    {
                      "emit": {
                        "failure": "FlowLoadFailed",
                        "success": "FlowLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "releaseLabel": {
              "type": "string",
              "default": "Release funds",
              "label": "Release button",
              "description": "Label on the final-release primary button"
            },
            "disputeLabel": {
              "type": "string",
              "default": "Open dispute",
              "label": "Dispute button",
              "description": "Label on the open-dispute escape-hatch button"
            },
            "title": {
              "type": "string",
              "default": "Escrow transaction",
              "label": "Page title",
              "description": "Heading shown above the transaction view"
            },
            "transactionAmount": {
              "type": "string",
              "default": "$28,500",
              "label": "Amount",
              "description": "Formatted amount held in escrow"
            },
            "transactionReference": {
              "type": "string",
              "default": "TXN-A8B2C-2024-001",
              "label": "Reference",
              "description": "External identifier shown in the summary"
            },
            "disputeIcon": {
              "type": "string",
              "default": "alert-triangle",
              "label": "Dispute icon",
              "description": "Icon next to the dispute button"
            },
            "releaseIcon": {
              "type": "string",
              "default": "unlock",
              "label": "Release icon",
              "description": "Icon next to the release button"
            },
            "transactionSubject": {
              "type": "string",
              "default": "Sale of 2024 Honda CR-V",
              "label": "Subject",
              "description": "Short description of what is being transacted"
            },
            "parties": {
              "type": "[object]",
              "default": [
                {
                  "description": "Funds the transaction and confirms receipt of the vehicle.",
                  "stepLabel": "Step 1 of 2",
                  "actionDescription": "Authorize $28,500 to be held in escrow until delivery is confirmed.",
                  "actionLabel": "Confirm payment",
                  "icon": "user",
                  "id": "buyer",
                  "actionIcon": "credit-card",
                  "actor": "Alice Chen",
                  "title": "Buyer"
                },
                {
                  "actionIcon": "package",
                  "id": "seller",
                  "actor": "Bob's Auto Sales LLC",
                  "actionLabel": "Confirm shipment",
                  "stepLabel": "Step 2 of 2",
                  "icon": "user-check",
                  "description": "Ships the vehicle and uploads delivery proof.",
                  "title": "Seller",
                  "actionDescription": "Mark the vehicle as shipped. Funds will release after the buyer confirms receipt."
                }
              ],
              "label": "Parties",
              "description": "Ordered participants with role, actor name, and required action",
              "items": {
                "type": "object"
              }
            },
            "cancelLabel": {
              "type": "string",
              "default": "Cancel transaction",
              "label": "Cancel button",
              "description": "Label on the cancel-transaction escape-hatch button"
            },
            "cancelIcon": {
              "type": "string",
              "default": "x",
              "label": "Cancel icon",
              "description": "Icon next to the cancel button"
            },
            "reasonFields": {
              "type": "[string]",
              "default": [
                "reason"
              ],
              "label": "Reason fields",
              "description": "Form fields shown when capturing a dispute or cancel reason",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MultiPartyFlowPage",
          "path": "/multi-party-flow",
          "traits": [
            {
              "ref": "MultiPartyTransaction"
            }
          ]
        }
      ]
    }
  ]
}