{
  "name": "std-multi-party-flow",
  "version": "3.0.1",
  "description": "std-multi-party-flow — Escrow.com / DocuSign / Stripe Connect style multi-party transaction. Header + summary (subject/amount/reference) + named parties (avatar/role/actor) + stage progress + your-turn panel + activity feed + dispute/cancel escape hatches. Topology = loading / awaiting / capturing_dispute / capturing_cancel / funded / released / disputed / cancelled / error.",
  "orbitals": [
    {
      "name": "MultiPartyFlowOrbital",
      "entity": {
        "name": "MultiPartyView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "parties",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "actionLabel": {
                  "name": "actionLabel",
                  "type": "string",
                  "required": false
                },
                "actionIcon": {
                  "name": "actionIcon",
                  "type": "string",
                  "required": false
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "actor": {
                  "name": "actor",
                  "type": "string",
                  "required": false
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                }
              }
            }
          },
          {
            "name": "currentPartyIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalParties",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currentPartyId",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentPartyTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentPartyActor",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentPartyIcon",
            "type": "string",
            "default": "user"
          },
          {
            "name": "currentActionLabel",
            "type": "string",
            "default": "Confirm"
          },
          {
            "name": "currentActionIcon",
            "type": "string",
            "default": "check"
          },
          {
            "name": "currentActionDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepLabel",
            "type": "string",
            "default": "Step 1"
          },
          {
            "name": "audit",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "status": {
                  "name": "status",
                  "type": "string",
                  "required": false,
                  "values": [
                    "complete",
                    "active",
                    "pending",
                    "error"
                  ]
                },
                "timestamp": {
                  "name": "timestamp",
                  "type": "string",
                  "required": false
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "disputeReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "cancelReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MultiPartyTransaction",
          "category": "interaction",
          "capabilities": [
            "multi-party"
          ],
          "linkedEntity": "MultiPartyView",
          "emits": [
            {
              "event": "PARTY_CONFIRM",
              "payloadSchema": [
                {
                  "name": "partyKey",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OPEN_DISPUTE"
            },
            {
              "event": "CANCEL_TRANSACTION"
            },
            {
              "event": "SUBMIT_DISPUTE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "SUBMIT_CANCEL",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL_REASON"
            },
            {
              "event": "RELEASE"
            },
            {
              "event": "RESTART"
            },
            {
              "event": "FlowLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "FlowLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "awaiting"
              },
              {
                "name": "capturing_dispute"
              },
              {
                "name": "capturing_cancel"
              },
              {
                "name": "funded"
              },
              {
                "name": "released"
              },
              {
                "name": "disputed"
              },
              {
                "name": "cancelled"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FlowLoaded",
                "name": "Flow loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "FlowLoadFailed",
                "name": "Flow load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FlowSaved",
                "name": "Flow saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FlowSaveFailed",
                "name": "Flow save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PARTY_CONFIRM",
                "name": "Party Confirm",
                "payloadSchema": [
                  {
                    "name": "partyKey",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_DISPUTE",
                "name": "Open Dispute"
              },
              {
                "key": "CANCEL_TRANSACTION",
                "name": "Cancel Transaction"
              },
              {
                "key": "SUBMIT_DISPUTE",
                "name": "Submit Dispute",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL_REASON",
                "name": "Cancel Reason"
              },
              {
                "key": "SUBMIT_CANCEL",
                "name": "Submit Cancel",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "RELEASE",
                "name": "Release"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MultiPartyView",
                    {
                      "emit": {
                        "failure": "FlowLoadFailed",
                        "success": "FlowLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading transaction…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "awaiting",
                "event": "FlowLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.currentPartyIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalParties",
                    [
                      "array/len",
                      "@config.parties"
                    ]
                  ],
                  [
                    "set",
                    "@entity.parties",
                    [
                      "array/map",
                      "@config.parties",
                      [
                        "fn",
                        "party",
                        {
                          "icon": [
                            "object/get",
                            "@party",
                            "icon",
                            "user"
                          ],
                          "title": [
                            "object/get",
                            "@party",
                            "title"
                          ],
                          "actionLabel": [
                            "object/get",
                            "@party",
                            "actionLabel",
                            "Confirm"
                          ],
                          "actionIcon": [
                            "object/get",
                            "@party",
                            "actionIcon",
                            "check"
                          ],
                          "actor": [
                            "object/get",
                            "@party",
                            "actor",
                            ""
                          ],
                          "id": [
                            "object/get",
                            "@party",
                            "id"
                          ],
                          "description": [
                            "object/get",
                            "@party",
                            "description",
                            ""
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyId",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "id",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyTitle",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "title",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyActor",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "actor",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyIcon",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionLabel",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "actionLabel",
                      "Confirm"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionIcon",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "actionIcon",
                      "check"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionDescription",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "actionDescription",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@config.parties"
                      ],
                      "stepLabel",
                      "Step 1"
                    ]
                  ],
                  [
                    "set",
                    "@entity.audit",
                    [
                      {
                        "title": "Transaction opened",
                        "timestamp": "Just now",
                        "description": [
                          "str/concat",
                          "Reference ",
                          "@config.transactionReference"
                        ],
                        "id": "init",
                        "status": "complete"
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "Active",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "gap": "lg",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "direction": "vertical",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "content": "Amount in escrow",
                                          "color": "muted"
                                        },
                                        {
                                          "content": "@config.transactionAmount",
                                          "type": "typography",
                                          "variant": "h1"
                                        }
                                      ],
                                      "gap": "xs"
                                    },
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "variant": "caption",
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "Subject"
                                        },
                                        {
                                          "content": "@config.transactionSubject",
                                          "type": "typography",
                                          "variant": "h4"
                                        }
                                      ],
                                      "gap": "xs",
                                      "direction": "vertical"
                                    },
                                    {
                                      "direction": "vertical",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "color": "muted",
                                          "content": "Reference"
                                        },
                                        {
                                          "content": "@config.transactionReference",
                                          "variant": "body",
                                          "type": "typography"
                                        }
                                      ],
                                      "gap": "xs"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "content": "Parties",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "type": "data-list",
                          "gap": "sm",
                          "entity": "@entity.parties",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "party",
                            {
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "size": "lg",
                                      "name": "@party.icon"
                                    },
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "direction": "horizontal",
                                          "align": "center",
                                          "gap": "xs",
                                          "children": [
                                            {
                                              "variant": "h4",
                                              "type": "typography",
                                              "content": "@party.title"
                                            },
                                            {
                                              "type": "typography",
                                              "content": "·",
                                              "color": "muted"
                                            },
                                            {
                                              "type": "typography",
                                              "content": "@party.actor",
                                              "variant": "body"
                                            }
                                          ],
                                          "type": "stack"
                                        },
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "color": "muted",
                                          "content": "@party.description"
                                        }
                                      ],
                                      "gap": "xs",
                                      "direction": "vertical"
                                    }
                                  ],
                                  "gap": "md",
                                  "type": "stack"
                                }
                              ],
                              "type": "card"
                            }
                          ]
                        },
                        {
                          "variant": "h4",
                          "type": "typography",
                          "content": "Progress"
                        },
                        {
                          "currentStep": "@entity.currentPartyIndex",
                          "steps": "@entity.parties",
                          "type": "wizard-progress"
                        },
                        {
                          "type": "card",
                          "variant": "elevated",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "gap": "sm",
                                  "align": "center",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "name": "clock",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "color": "muted",
                                      "variant": "caption",
                                      "content": "@entity.currentStepLabel"
                                    },
                                    {
                                      "content": "·",
                                      "type": "typography",
                                      "color": "muted"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Waiting for",
                                      "variant": "caption",
                                      "color": "muted"
                                    },
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": "@entity.currentPartyActor",
                                      "weight": "bold"
                                    }
                                  ],
                                  "type": "stack"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.currentActionDescription"
                                },
                                {
                                  "icon": "@entity.currentActionIcon",
                                  "label": "@entity.currentActionLabel",
                                  "type": "button",
                                  "action": "PARTY_CONFIRM",
                                  "actionPayload": {
                                    "partyKey": "@entity.currentPartyId"
                                  },
                                  "variant": "primary"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "content": "Activity",
                          "variant": "h4",
                          "type": "typography"
                        },
                        {
                          "entity": "@entity.audit",
                          "type": "timeline",
                          "fields": [
                            "title",
                            "description",
                            "timestamp",
                            "status"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "action": "OPEN_DISPUTE",
                              "type": "button",
                              "variant": "danger",
                              "icon": "@config.disputeIcon",
                              "label": "@config.disputeLabel"
                            },
                            {
                              "label": "@config.cancelLabel",
                              "variant": "ghost",
                              "action": "CANCEL_TRANSACTION",
                              "type": "button",
                              "icon": "@config.cancelIcon"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FlowLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Failed to load",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "awaiting",
                "event": "FlowSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FlowSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "type": "error-state",
                      "title": "Save failed"
                    }
                  ]
                ]
              },
              {
                "from": "awaiting",
                "to": "awaiting",
                "event": "PARTY_CONFIRM",
                "guard": [
                  "not",
                  [
                    "=",
                    [
                      "+",
                      "@entity.currentPartyIndex",
                      1.0
                    ],
                    "@entity.totalParties"
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.audit",
                    [
                      "array/append",
                      "@entity.audit",
                      {
                        "description": [
                          "str/concat",
                          "@entity.currentPartyActor",
                          " completed: ",
                          "@entity.currentActionLabel"
                        ],
                        "timestamp": [
                          "time/now"
                        ],
                        "status": "complete",
                        "id": [
                          "str/concat",
                          "confirm-",
                          [
                            "object/get",
                            "@payload",
                            "partyKey",
                            ""
                          ]
                        ],
                        "title": [
                          "str/concat",
                          "@entity.currentPartyTitle",
                          " confirmed"
                        ]
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyIndex",
                    [
                      "+",
                      "@entity.currentPartyIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyId",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "id",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyTitle",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "title",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyActor",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "actor",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentPartyIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "actionLabel",
                      "Confirm"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "actionIcon",
                      "check"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentActionDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "actionDescription",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.parties",
                        "@entity.currentPartyIndex"
                      ],
                      "stepLabel",
                      "Step"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
