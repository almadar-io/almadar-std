{
  "name": "std-push",
  "version": "1.0.0",
  "description": "std-push as a Function",
  "orbitals": [
    {
      "name": "PushSubscriberOrbital",
      "entity": {
        "name": "PushSubscriber",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PushSubscriberIndicator",
          "category": "interaction",
          "linkedEntity": "PushSubscriber",
          "emits": [
            {
              "event": "PUSH_RECEIVED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PUSH_DISCONNECTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PushSubscriberLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PushSubscriberLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PushSubscriber]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "connecting"
              },
              {
                "name": "subscribed"
              },
              {
                "name": "reconnecting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PUSH_RECEIVED",
                "name": "Push Received",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PUSH_DISCONNECTED",
                "name": "Push Disconnected",
                "payloadSchema": [
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PushSubscriberLoadFailed",
                "name": "PushSubscriber load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PushSubscriberLoaded",
                "name": "PushSubscriber loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PushSubscriber]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "connecting",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PushSubscriber",
                    {
                      "emit": {
                        "success": "PushSubscriberLoaded",
                        "failure": "PushSubscriberLoadFailed"
                      }
                    }
                  ],
                  [
                    "os/watch-http",
                    "wss://push.example.com",
                    {
                      "emit": {
                        "on_message": "PUSH_RECEIVED",
                        "failure": "PUSH_DISCONNECTED"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Connecting…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "type": "stack",
                      "gap": "sm",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "connecting",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "color": "success",
                          "name": "wifi",
                          "type": "icon"
                        },
                        {
                          "content": "Connected",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "sm",
                      "align": "center",
                      "direction": "horizontal"
                    }
                  ]
                ]
              },
              {
                "from": "connecting",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "wifi-off",
                          "type": "icon",
                          "color": "warning"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Reconnecting…"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "subscribed",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "align": "center",
                      "children": [
                        {
                          "color": "success",
                          "type": "icon",
                          "name": "wifi"
                        },
                        {
                          "content": "Connected",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "subscribed",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "sm",
                      "align": "center",
                      "direction": "horizontal",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "color": "warning",
                          "name": "wifi-off"
                        },
                        {
                          "type": "typography",
                          "content": "Reconnecting…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "reconnecting",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "color": "success",
                          "type": "icon",
                          "name": "wifi"
                        },
                        {
                          "type": "typography",
                          "content": "Connected",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal"
                    }
                  ]
                ]
              },
              {
                "from": "reconnecting",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "wifi-off",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "content": "Disconnected",
                          "variant": "caption"
                        }
                      ],
                      "gap": "sm",
                      "direction": "horizontal",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Push",
          "path": "/push",
          "traits": [
            {
              "ref": "PushSubscriberIndicator"
            }
          ]
        }
      ]
    }
  ]
}