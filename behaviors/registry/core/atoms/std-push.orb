{
  "description": "std-push as a Function",
  "name": "std-push",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Current operational state of the subscriber.",
            "name": "status",
            "synonyms": "state, condition, mode",
            "type": "string"
          }
        ],
        "name": "PushSubscriber",
        "persistence": "runtime"
      },
      "name": "PushSubscriberOrbital",
      "pages": [
        {
          "name": "Push",
          "path": "/push",
          "traits": [
            {
              "ref": "PushSubscriberIndicator"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Data has been successfully received and processed.",
              "event": "PUSH_RECEIVED",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "received, updated, ingested",
              "tier": "domain"
            },
            {
              "description": "Indicates the push connection has been lost.",
              "event": "PUSH_DISCONNECTED",
              "payloadSchema": [
                {
                  "name": "reason",
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "disconnected, lost, dropped, offline",
              "tier": "internal"
            },
            {
              "description": "Indicates failure to load a subscriber.",
              "event": "PushSubscriberLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, failure, failed, problem",
              "tier": "internal"
            },
            {
              "description": "Signals successful initialization of a data subscription.",
              "event": "PushSubscriberLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PushSubscriber]"
                }
              ],
              "scope": "internal",
              "synonyms": "initialized, ready, connected",
              "tier": "domain"
            }
          ],
          "entityContract": {
            "provides": [
              "status"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "PushSubscriber",
          "name": "PushSubscriberIndicator",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Data has been successfully received and processed.",
                "key": "PUSH_RECEIVED",
                "name": "Push Received",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ],
                "synonyms": "received, updated, ingested",
                "tier": "domain"
              },
              {
                "description": "Indicates the push connection has been lost.",
                "key": "PUSH_DISCONNECTED",
                "name": "Push Disconnected",
                "payloadSchema": [
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ],
                "synonyms": "disconnected, lost, dropped, offline",
                "tier": "internal"
              },
              {
                "description": "Indicates failure to load a subscriber.",
                "key": "PushSubscriberLoadFailed",
                "name": "PushSubscriber load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, failed, problem",
                "tier": "internal"
              },
              {
                "description": "Signals successful initialization of a data subscription.",
                "key": "PushSubscriberLoaded",
                "name": "PushSubscriber loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PushSubscriber]"
                  }
                ],
                "synonyms": "initialized, ready, connected",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              },
              {
                "name": "connecting"
              },
              {
                "name": "subscribed"
              },
              {
                "name": "reconnecting"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "PushSubscriber",
                    {
                      "emit": {
                        "failure": "PushSubscriberLoadFailed",
                        "success": "PushSubscriberLoaded"
                      }
                    }
                  ],
                  [
                    "os/watch-http",
                    "wss://push.example.com",
                    {
                      "emit": {
                        "failure": "PUSH_DISCONNECTED",
                        "on_message": "PUSH_RECEIVED"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Connecting…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "connecting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "success",
                          "name": "wifi",
                          "type": "icon"
                        },
                        {
                          "content": "Connected",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_RECEIVED",
                "from": "connecting",
                "to": "subscribed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "warning",
                          "name": "wifi-off",
                          "type": "icon"
                        },
                        {
                          "content": "Reconnecting…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_DISCONNECTED",
                "from": "connecting",
                "to": "reconnecting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "success",
                          "name": "wifi",
                          "type": "icon"
                        },
                        {
                          "content": "Connected",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_RECEIVED",
                "from": "subscribed",
                "to": "subscribed"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "warning",
                          "name": "wifi-off",
                          "type": "icon"
                        },
                        {
                          "content": "Reconnecting…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_DISCONNECTED",
                "from": "subscribed",
                "to": "reconnecting"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "success",
                          "name": "wifi",
                          "type": "icon"
                        },
                        {
                          "content": "Connected",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_RECEIVED",
                "from": "reconnecting",
                "to": "subscribed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "wifi-off",
                          "type": "icon"
                        },
                        {
                          "content": "Disconnected",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PUSH_DISCONNECTED",
                "from": "reconnecting",
                "to": "reconnecting"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}