{
  "name": "std-selection",
  "version": "1.0.0",
  "description": "std-selection as a Function",
  "orbitals": [
    {
      "name": "SelectableItemOrbital",
      "entity": {
        "name": "SelectableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SelectableItemSelection",
          "category": "interaction",
          "linkedEntity": "SelectableItem",
          "emits": [
            {
              "event": "SelectableItemLoaded",
              "description": "Fired when SelectableItem finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SelectableItem]"
                }
              ]
            },
            {
              "event": "SelectableItemLoadFailed",
              "description": "Fired when SelectableItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "selecting"
              },
              {
                "name": "selected"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SelectableItemLoaded",
                "name": "SelectableItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SelectableItem]"
                  }
                ]
              },
              {
                "key": "SelectableItemLoadFailed",
                "name": "SelectableItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT",
                "name": "Select",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_SELECTION",
                "name": "Confirm Selection",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "success": "SelectableItemLoaded",
                        "failure": "SelectableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading…"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "SelectableItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-square"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "SelectableItems"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Choose a selectableitem to continue."
                        },
                        {
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "entity": "@payload.data",
                          "fields": [],
                          "itemActions": [
                            {
                              "icon": "check",
                              "event": "SELECT",
                              "label": "Select"
                            }
                          ],
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "label": "@item.name",
                                  "type": "checkbox"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SelectableItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "selecting",
                "event": "SELECT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "check-square",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "SelectableItems"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "md"
                            },
                            {
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "badge",
                                  "label": "Selecting"
                                },
                                {
                                  "label": "Clear",
                                  "action": "CLEAR",
                                  "variant": "ghost",
                                  "icon": "x",
                                  "type": "button"
                                }
                              ]
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "info",
                          "message": "@payload.id",
                          "type": "alert"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "check",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "label": "Confirm",
                              "type": "button",
                              "action": "CONFIRM_SELECTION"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "selected",
                "event": "CONFIRM_SELECTION",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Selection Confirmed"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "type": "badge",
                              "label": "Confirmed"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Selection confirmed successfully."
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "content": "Selected ID:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "content": "@payload.id",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Clear Selection",
                          "action": "CLEAR"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "loading",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "success": "SelectableItemLoaded",
                        "failure": "SelectableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "selected",
                "to": "loading",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SelectableItemSelectionPage",
          "path": "/selectableitems/selection",
          "traits": [
            {
              "ref": "SelectableItemSelection"
            }
          ]
        }
      ]
    }
  ]
}
