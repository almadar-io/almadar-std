{
  "name": "std-image-upload-multi",
  "version": "1.0.0",
  "description": "std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress. Owns an UploadedImage entity scoped by parentId/parentType so listings, marketplaces, restaurant menus, and vendor onboarding can all reuse the same upload contract.",
  "orbitals": [
    {
      "name": "UploadedImageOrbital",
      "entity": {
        "name": "UploadedImage",
        "collection": "uploadedimages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "url",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "sizeBytes",
            "type": "number"
          },
          {
            "name": "mimeType",
            "type": "string"
          },
          {
            "name": "width",
            "type": "number"
          },
          {
            "name": "height",
            "type": "number"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "parentType",
            "type": "string"
          },
          {
            "name": "uploadedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "UploadedImageUpload",
          "category": "interaction",
          "linkedEntity": "UploadedImage",
          "emits": [
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "files",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[UploadedImage]"
                }
              ]
            },
            {
              "event": "UploadedImageLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.url",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.sizeBytes",
                  "type": "number"
                },
                {
                  "name": "row.mimeType",
                  "type": "string"
                },
                {
                  "name": "row.width",
                  "type": "number"
                },
                {
                  "name": "row.height",
                  "type": "number"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.parentType",
                  "type": "string"
                },
                {
                  "name": "row.uploadedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageUploadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "uploading"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UploadedImageLoaded",
                "name": "UploadedImage loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[UploadedImage]"
                  }
                ]
              },
              {
                "key": "UploadedImageLoadFailed",
                "name": "UploadedImage load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "files",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleted",
                "name": "UploadedImage deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleteFailed",
                "name": "UploadedImage delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UploadedImageCreated",
                "name": "UploadedImage created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "UploadedImage"
                  }
                ]
              },
              {
                "key": "UploadedImageUploadFailed",
                "name": "UploadedImage upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading images…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "content": "@config.title",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "maxFiles": "@config.maxImages",
                          "description": "or click to browse",
                          "icon": "image-plus",
                          "maxSize": "@config.maxBytesPerImage",
                          "label": "Drop images here",
                          "accept": "@config.accept",
                          "action": "UPLOAD",
                          "type": "upload-drop-zone"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "media-gallery"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "UploadedImageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "UploadedImage",
                    "@payload.files",
                    {
                      "emit": {
                        "failure": "UploadedImageUploadFailed",
                        "success": "UploadedImageCreated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "content": "Uploading images…",
                          "variant": "h3"
                        },
                        {
                          "max": 100.0,
                          "progressType": "linear",
                          "value": 0.0,
                          "type": "progress-bar"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "UploadedImage",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "UploadedImageDeleted",
                        "failure": "UploadedImageDeleteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UploadedImageDeleted",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "UploadedImageDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "loading",
                "event": "UploadedImageCreated",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "color": "success"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Upload complete"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "UploadedImageUploadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "maxSize": "@config.maxBytesPerImage",
                          "icon": "image-plus",
                          "maxFiles": "@config.maxImages",
                          "label": "Drop images here",
                          "description": "or click to browse",
                          "action": "UPLOAD",
                          "accept": "@config.accept",
                          "type": "upload-drop-zone"
                        },
                        {
                          "type": "media-gallery",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Upload Images"
            },
            "accept": {
              "type": "string",
              "default": "image/*"
            },
            "maxImages": {
              "type": "number",
              "default": 10.0
            },
            "maxBytesPerImage": {
              "type": "number",
              "default": 10485760.0
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "UploadedImageUploadPage",
          "path": "/uploadedimages/upload",
          "traits": [
            {
              "ref": "UploadedImageUpload"
            }
          ]
        }
      ]
    }
  ]
}
