{
  "name": "std-image-upload-multi",
  "version": "1.0.0",
  "description": "std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress.",
  "orbitals": [
    {
      "name": "UploadedImageOrbital",
      "entity": {
        "name": "UploadedImage",
        "collection": "uploadedimages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "url",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "sizeBytes",
            "type": "number"
          },
          {
            "name": "mimeType",
            "type": "string"
          },
          {
            "name": "width",
            "type": "number"
          },
          {
            "name": "height",
            "type": "number"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "parentType",
            "type": "string"
          },
          {
            "name": "uploadedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "UploadedImageUpload",
          "category": "interaction",
          "linkedEntity": "UploadedImage",
          "emits": [
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "files",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[UploadedImage]"
                }
              ]
            },
            {
              "event": "UploadedImageLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.url",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.sizeBytes",
                  "type": "number"
                },
                {
                  "name": "row.mimeType",
                  "type": "string"
                },
                {
                  "name": "row.width",
                  "type": "number"
                },
                {
                  "name": "row.height",
                  "type": "number"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.parentType",
                  "type": "string"
                },
                {
                  "name": "row.uploadedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageUploadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "uploading"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UploadedImageLoaded",
                "name": "UploadedImage loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[UploadedImage]"
                  }
                ]
              },
              {
                "key": "UploadedImageLoadFailed",
                "name": "UploadedImage load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "files",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleted",
                "name": "UploadedImage deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleteFailed",
                "name": "UploadedImage delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UploadedImageCreated",
                "name": "UploadedImage created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "UploadedImage"
                  }
                ]
              },
              {
                "key": "UploadedImageUploadFailed",
                "name": "UploadedImage upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading images…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "image-plus"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "accept": "@config.accept",
                          "maxSize": "@config.maxBytesPerImage",
                          "maxFiles": "@config.maxImages",
                          "label": "Drop images here",
                          "description": "or click to browse",
                          "action": "UPLOAD",
                          "type": "upload-drop-zone",
                          "icon": "image-plus"
                        },
                        {
                          "type": "media-gallery",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "UploadedImageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "UploadedImage",
                    "@payload.files",
                    {
                      "emit": {
                        "success": "UploadedImageCreated",
                        "failure": "UploadedImageUploadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Uploading images…"
                        },
                        {
                          "max": 100.0,
                          "value": 0.0,
                          "progressType": "linear",
                          "type": "progress-bar"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "UploadedImage",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "UploadedImageDeleted",
                        "failure": "UploadedImageDeleteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UploadedImageDeleted",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "UploadedImageDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "loading",
                "event": "UploadedImageCreated",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "color": "success",
                          "name": "check-circle"
                        },
                        {
                          "type": "typography",
                          "content": "Upload complete",
                          "variant": "h3"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "UploadedImageUploadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "image-plus"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "accept": "@config.accept",
                          "type": "upload-drop-zone",
                          "maxSize": "@config.maxBytesPerImage",
                          "action": "UPLOAD",
                          "label": "Drop images here",
                          "maxFiles": "@config.maxImages",
                          "description": "or click to browse",
                          "icon": "image-plus"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "media-gallery"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "accept": {
              "type": "string",
              "default": "image/*",
              "label": "MIME filter",
              "description": "Browser accept filter for the file picker",
              "tier": "domain"
            },
            "maxBytesPerImage": {
              "type": "number",
              "default": 10485760.0,
              "label": "Size limit (bytes)",
              "description": "Per-image upload size cap",
              "tier": "domain"
            },
            "maxImages": {
              "type": "number",
              "default": 10.0,
              "label": "Max images",
              "description": "Maximum number of images accepted per upload batch",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Upload Images",
              "label": "Section title",
              "description": "Heading shown above the upload zone",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "UploadedImageUploadPage",
          "path": "/uploadedimages/upload",
          "traits": [
            {
              "ref": "UploadedImageUpload"
            }
          ]
        }
      ]
    }
  ]
}