{
  "name": "std-scatter",
  "version": "1.0.0",
  "description": "std-scatter — embeddable scatter / bubble chart atom. ITEMS_LOADED maps @payload.data into {x,y,label,size,color} points using configured fields (no aggregation step — distinct from std-graphs). Drop into a dashboard alongside std-stats / std-graphs for two-numeric correlation views.",
  "orbitals": [
    {
      "name": "ScatterItemOrbital",
      "entity": {
        "name": "ScatterItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "points",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "size": {
                  "name": "size",
                  "type": "number",
                  "required": false
                },
                "color": {
                  "name": "color",
                  "type": "string",
                  "required": false
                },
                "y": {
                  "name": "y",
                  "type": "number",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": false
                },
                "x": {
                  "name": "x",
                  "type": "number",
                  "required": true
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "ScatterItemPlot",
          "category": "interaction",
          "linkedEntity": "ScatterItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.points",
                    [
                      {
                        "color": "",
                        "x": 12.0,
                        "label": "A",
                        "y": 24.0,
                        "size": 8.0
                      },
                      {
                        "color": "",
                        "label": "B",
                        "x": 28.0,
                        "y": 42.0,
                        "size": 6.0
                      },
                      {
                        "x": 45.0,
                        "y": 18.0,
                        "label": "C",
                        "color": "",
                        "size": 10.0
                      },
                      {
                        "label": "D",
                        "x": 60.0,
                        "color": "",
                        "y": 55.0,
                        "size": 7.0
                      },
                      {
                        "label": "E",
                        "y": 38.0,
                        "x": 78.0,
                        "color": "",
                        "size": 9.0
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "drillEvent": "@config.drillEvent",
                      "type": "chart",
                      "scatterData": "@entity.points",
                      "title": "@config.title",
                      "subtitle": "@config.subtitle",
                      "chartType": "scatter"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.points",
                    [
                      "array/map",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        {
                          "x": [
                            "object/get",
                            "@row",
                            "@config.xField",
                            0.0
                          ],
                          "y": [
                            "object/get",
                            "@row",
                            "@config.yField",
                            0.0
                          ],
                          "label": [
                            "object/get",
                            "@row",
                            "@config.labelField",
                            ""
                          ],
                          "size": [
                            "object/get",
                            "@row",
                            "@config.sizeField",
                            5.0
                          ],
                          "color": [
                            "object/get",
                            "@row",
                            "@config.colorField",
                            ""
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "height": "@config.height",
                      "type": "chart",
                      "title": "@config.title",
                      "drillEvent": "@config.drillEvent",
                      "chartType": "scatter",
                      "scatterData": "@entity.points",
                      "subtitle": "@config.subtitle"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "colorField": {
              "type": "string",
              "default": "",
              "label": "Color field",
              "description": "Field used to color-code points (blank = single color)",
              "tier": "presentation"
            },
            "subtitle": {
              "type": "string",
              "default": "x vs y",
              "label": "Subtitle",
              "description": "Secondary line below the title",
              "tier": "presentation"
            },
            "height": {
              "type": "number",
              "default": 280.0,
              "label": "Chart height",
              "description": "Pixel height of the rendered scatter plot",
              "tier": "presentation"
            },
            "xField": {
              "type": "string",
              "default": "x",
              "label": "X-axis field",
              "description": "Entity field mapped to the horizontal axis",
              "tier": "presentation"
            },
            "yField": {
              "type": "string",
              "default": "y",
              "label": "Y-axis field",
              "description": "Entity field mapped to the vertical axis",
              "tier": "presentation"
            },
            "drillEvent": {
              "type": "string",
              "default": "",
              "label": "Drill event",
              "description": "Event emitted when the user clicks a data point",
              "tier": "internal"
            },
            "title": {
              "type": "string",
              "default": "Correlation",
              "label": "Title",
              "description": "Heading shown above the chart",
              "tier": "presentation"
            },
            "labelField": {
              "type": "string",
              "default": "",
              "label": "Label field",
              "description": "Field used as the point label tooltip (blank = none)",
              "tier": "presentation"
            },
            "sizeField": {
              "type": "string",
              "default": "",
              "label": "Size field",
              "description": "Numeric field that scales bubble size (blank = uniform)",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ScatterItemPlotPage",
          "path": "/scatteritems",
          "traits": [
            {
              "ref": "ScatterItemPlot"
            }
          ]
        }
      ]
    }
  ]
}