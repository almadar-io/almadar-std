{
  "description": "std-dashboard-grid-layout — dashboard-layout chrome mirroring Looker Studio / Power BI: top-right toolbar slots (export / share / settings — feed `headerActions`), horizontal filter row (date range, search, dropdown filters), divider, then 12 numbered tile slots in a responsive simple-grid below. Slots default to EmptyTile so callers only bind what they need via traitOverrides.",
  "name": "std-dashboard-grid-layout",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DashboardGridLayoutData",
        "persistence": "runtime"
      },
      "name": "DashboardGridLayoutOrbital",
      "pages": [
        {
          "name": "DashboardGridLayoutPage",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardGridLayout"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "linkedEntity": "DashboardGridLayoutData",
          "name": "EmptyTile",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        },
        {
          "category": "interaction",
          "config": {
            "appName": {
              "default": "Dashboard",
              "description": "Product name shown in the dashboard chrome",
              "label": "App name",
              "tier": "presentation",
              "type": "string"
            },
            "filter1Trait": {
              "default": "@trait.EmptyTile",
              "description": "First filter-row trait (typical use: date range picker)",
              "label": "Filter slot 1",
              "tier": "presentation",
              "type": "trait"
            },
            "filter2Trait": {
              "default": "@trait.EmptyTile",
              "description": "Second filter-row trait (typical use: search input)",
              "label": "Filter slot 2",
              "tier": "presentation",
              "type": "trait"
            },
            "filter3Trait": {
              "default": "@trait.EmptyTile",
              "description": "Third filter-row trait (typical use: dropdown filter)",
              "label": "Filter slot 3",
              "tier": "presentation",
              "type": "trait"
            },
            "filter4Trait": {
              "default": "@trait.EmptyTile",
              "description": "Fourth filter-row trait (typical use: secondary dropdown filter)",
              "label": "Filter slot 4",
              "tier": "presentation",
              "type": "trait"
            },
            "minTileWidth": {
              "default": 320.0,
              "description": "Minimum pixel width per tile before the grid re-flows",
              "label": "Tile min width",
              "tier": "presentation",
              "type": "number"
            },
            "navItems": {
              "default": [
                {
                  "href": "/dashboard",
                  "icon": "bar-chart-3",
                  "label": "Dashboard"
                }
              ],
              "description": "Top-level nav entries on the left rail",
              "items": {
                "properties": {
                  "badge": {
                    "name": "badge",
                    "required": false,
                    "type": "string"
                  },
                  "href": {
                    "name": "href",
                    "required": true,
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": true,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Sidebar links",
              "tier": "presentation",
              "type": "[NavItem]"
            },
            "tile10Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the tenth dashboard grid tile",
              "label": "Tile slot 10",
              "tier": "presentation",
              "type": "trait"
            },
            "tile11Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the eleventh dashboard grid tile",
              "label": "Tile slot 11",
              "tier": "presentation",
              "type": "trait"
            },
            "tile12Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the twelfth dashboard grid tile",
              "label": "Tile slot 12",
              "tier": "presentation",
              "type": "trait"
            },
            "tile1Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the first dashboard grid tile",
              "label": "Tile slot 1",
              "tier": "presentation",
              "type": "trait"
            },
            "tile2Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the second dashboard grid tile",
              "label": "Tile slot 2",
              "tier": "presentation",
              "type": "trait"
            },
            "tile3Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the third dashboard grid tile",
              "label": "Tile slot 3",
              "tier": "presentation",
              "type": "trait"
            },
            "tile4Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the fourth dashboard grid tile",
              "label": "Tile slot 4",
              "tier": "presentation",
              "type": "trait"
            },
            "tile5Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the fifth dashboard grid tile",
              "label": "Tile slot 5",
              "tier": "presentation",
              "type": "trait"
            },
            "tile6Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the sixth dashboard grid tile",
              "label": "Tile slot 6",
              "tier": "presentation",
              "type": "trait"
            },
            "tile7Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the seventh dashboard grid tile",
              "label": "Tile slot 7",
              "tier": "presentation",
              "type": "trait"
            },
            "tile8Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the eighth dashboard grid tile",
              "label": "Tile slot 8",
              "tier": "presentation",
              "type": "trait"
            },
            "tile9Trait": {
              "default": "@trait.EmptyTile",
              "description": "Trait rendered in the ninth dashboard grid tile",
              "label": "Tile slot 9",
              "tier": "presentation",
              "type": "trait"
            },
            "toolbar1Trait": {
              "default": "@trait.EmptyTile",
              "description": "First top-right toolbar trait (typical use: export action)",
              "label": "Toolbar slot 1",
              "tier": "presentation",
              "type": "trait"
            },
            "toolbar2Trait": {
              "default": "@trait.EmptyTile",
              "description": "Second top-right toolbar trait (typical use: share action)",
              "label": "Toolbar slot 2",
              "tier": "presentation",
              "type": "trait"
            },
            "toolbar3Trait": {
              "default": "@trait.EmptyTile",
              "description": "Third top-right toolbar trait (typical use: settings action)",
              "label": "Toolbar slot 3",
              "tier": "presentation",
              "type": "trait"
            }
          },
          "linkedEntity": "DashboardGridLayoutData",
          "name": "DashboardGridLayout",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "@config.appName",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                "@config.filter1Trait",
                                "@config.filter2Trait",
                                "@config.filter3Trait",
                                "@config.filter4Trait"
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "wrap": true
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                "@config.tile1Trait",
                                "@config.tile2Trait",
                                "@config.tile3Trait",
                                "@config.tile4Trait",
                                "@config.tile5Trait",
                                "@config.tile6Trait",
                                "@config.tile7Trait",
                                "@config.tile8Trait",
                                "@config.tile9Trait",
                                "@config.tile10Trait",
                                "@config.tile11Trait",
                                "@config.tile12Trait"
                              ],
                              "minChildWidth": "@config.minTileWidth",
                              "type": "simple-grid"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "headerActions": {
                        "align": "center",
                        "children": [
                          "@config.toolbar1Trait",
                          "@config.toolbar2Trait",
                          "@config.toolbar3Trait"
                        ],
                        "direction": "horizontal",
                        "gap": "sm",
                        "type": "stack"
                      },
                      "navItems": "@config.navItems",
                      "type": "dashboard-layout"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "composing",
                "to": "composing"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "5.0.1"
}