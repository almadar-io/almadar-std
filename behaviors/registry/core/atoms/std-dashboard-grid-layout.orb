{
  "name": "std-dashboard-grid-layout",
  "version": "4.0.0",
  "description": "std-dashboard-grid-layout — dashboard-layout chrome. Filter row at top (4 slots, horizontal toolbar), divider, then 12 numbered tile slots in a responsive simple-grid below. Slots default to EmptyTile so callers only bind what they need via traitOverrides. Filter row is for interactive toolbar traits (filters, date-range, search, export); tile grid is for data representation (KPIs, charts, tables).",
  "orbitals": [
    {
      "name": "DashboardGridLayoutOrbital",
      "entity": {
        "name": "DashboardGridLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EmptyTile",
          "category": "interaction",
          "linkedEntity": "DashboardGridLayoutState",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "DashboardGridLayout",
          "category": "interaction",
          "linkedEntity": "DashboardGridLayoutState",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "@config.appName",
                      "navItems": "@config.navItems",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "md",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                "@config.filter1Trait",
                                "@config.filter2Trait",
                                "@config.filter3Trait",
                                "@config.filter4Trait"
                              ],
                              "wrap": true,
                              "direction": "horizontal",
                              "align": "stretch",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                "@config.tile1Trait",
                                "@config.tile2Trait",
                                "@config.tile3Trait",
                                "@config.tile4Trait",
                                "@config.tile5Trait",
                                "@config.tile6Trait",
                                "@config.tile7Trait",
                                "@config.tile8Trait",
                                "@config.tile9Trait",
                                "@config.tile10Trait",
                                "@config.tile11Trait",
                                "@config.tile12Trait"
                              ],
                              "minChildWidth": "@config.minTileWidth",
                              "type": "simple-grid"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "minTileWidth": {
              "type": "number",
              "default": 320.0
            },
            "tile2Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "filter3Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile9Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile11Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "appName": {
              "type": "string",
              "default": "Dashboard"
            },
            "tile1Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile3Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile5Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile6Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile10Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "filter2Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile7Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "navItems": {
              "type": "[object]",
              "default": [
                {
                  "href": "/dashboard",
                  "icon": "bar-chart-3",
                  "label": "Dashboard"
                }
              ]
            },
            "tile12Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile8Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "filter4Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "tile4Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            },
            "filter1Trait": {
              "type": "trait",
              "default": "@trait.EmptyTile"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DashboardGridLayoutPage",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardGridLayout"
            }
          ]
        }
      ]
    }
  ]
}
