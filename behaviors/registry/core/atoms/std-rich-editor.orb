{
  "name": "std-rich-editor",
  "version": "1.0.0",
  "description": "std-rich-editor — wiki/CMS Notion-style block editor. Browses documents in `browsing`; opens the rich-block-editor on a selected row; persists block edits + publish status.",
  "orbitals": [
    {
      "name": "DocumentOrbital",
      "entity": {
        "name": "Document",
        "collection": "documents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "blocksJson",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": false
                },
                "content": {
                  "name": "content",
                  "type": "string",
                  "required": false
                },
                "type": {
                  "name": "type",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "kind",
            "type": "string",
            "default": "page",
            "values": [
              "page",
              "doc",
              "post"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived"
            ]
          },
          {
            "name": "version",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "updatedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DocumentEdit",
          "category": "interaction",
          "linkedEntity": "Document",
          "emits": [
            {
              "event": "OPEN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[BlockSpec]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "BLOCKS_CHANGE",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "SAVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DocumentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Document]"
                }
              ]
            },
            {
              "event": "DocumentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaved",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[BlockSpec]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentPublished",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[BlockSpec]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DocumentLoaded",
                "name": "Document loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Document]"
                  }
                ]
              },
              {
                "key": "DocumentSaved",
                "name": "Document saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentPublished",
                "name": "Document published",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentSaveFailed",
                "name": "Document save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DocumentLoadFailed",
                "name": "Document load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "BLOCKS_CHANGE",
                "name": "Blocks Change",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading documents…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DocumentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "file-text",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "@payload.data.length",
                              "label": "Total docs"
                            },
                            {
                              "label": "Drafts",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "icon": "edit-3",
                              "value": "12"
                            },
                            {
                              "label": "Published",
                              "value": "84",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "look": "@config.statLook"
                            },
                            {
                              "look": "@config.statLook",
                              "value": "9",
                              "icon": "archive",
                              "label": "Archived",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Open",
                              "event": "OPEN",
                              "icon": "edit"
                            },
                            {
                              "variant": "secondary",
                              "icon": "send",
                              "label": "Publish",
                              "event": "PUBLISH"
                            }
                          ],
                          "cols": 1.0,
                          "look": "@config.tableLook",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "caption",
                              "name": "title"
                            },
                            {
                              "label": "Kind",
                              "name": "kind",
                              "variant": "badge"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "variant": "caption",
                              "name": "version",
                              "label": "v"
                            },
                            {
                              "variant": "caption",
                              "name": "updatedAt",
                              "label": "Updated"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "DocumentSaved",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "DocumentPublished",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DocumentSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DocumentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "OPEN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "content": "@entity.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "secondary",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "rich-block-editor",
                          "showToolbar": true,
                          "initialBlocks": "@entity.blocksJson",
                          "changeEvent": "BLOCKS_CHANGE",
                          "placeholder": "Start writing…"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary",
                              "action": "SAVE",
                              "label": "Save",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary",
                              "label": "Publish",
                              "action": "PUBLISH"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Publishing document…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "BLOCKS_CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.blocks"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading documents…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SAVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "success": "DocumentSaved",
                        "failure": "DocumentSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Saving document…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "success": "DocumentPublished",
                        "failure": "DocumentSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Publishing document…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "title": {
              "type": "string",
              "default": "Documents",
              "label": "Section title",
              "description": "Heading shown above the document list",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DocumentEditPage",
          "path": "/documents/edit",
          "traits": [
            {
              "ref": "DocumentEdit"
            }
          ]
        }
      ]
    }
  ]
}