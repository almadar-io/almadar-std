{
  "name": "std-stats",
  "version": "2.0.0",
  "description": "std-stats — embeddable analytics-card atom. ITEMS_LOADED aggregates @payload.data per @config.metrics (count|sum|avg|min|max with optional filter, format, icon, max, target, trend) and renders one stat-display per entry. Drop into a dashboard alongside std-browse / std-search / std-filter.",
  "orbitals": [
    {
      "name": "StatsItemOrbital",
      "entity": {
        "name": "StatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "icon": {
                  "name": "icon",
                  "type": "string"
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string"
                },
                "max": {
                  "name": "max",
                  "type": "number"
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "target": {
                  "name": "target",
                  "type": "number"
                },
                "trend": {
                  "name": "trend",
                  "type": "number"
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "value": {
                  "name": "value",
                  "type": "number"
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "StatsItemStats",
          "category": "interaction",
          "linkedEntity": "StatsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0.0
                          ],
                          "value": 0.0,
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "label": "@card.label",
                          "icon": "@card.icon",
                          "value": "@card.value",
                          "type": "stat-display",
                          "format": "@card.format",
                          "variant": "@card.variant",
                          "max": "@card.max"
                        }
                      ],
                      "type": "data-grid",
                      "fields": [],
                      "entity": "@entity.cards"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0.0
                          ],
                          "value": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "array/filter",
                                "@payload.data",
                                [
                                  "object/get",
                                  "@metric",
                                  "filter",
                                  true
                                ]
                              ],
                              [
                                "object/get",
                                "@metric",
                                "field",
                                ""
                              ]
                            ],
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@metric",
                                  "aggregation",
                                  "count"
                                ],
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@metric",
                                    "aggregation",
                                    "count"
                                  ],
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "array/filter",
                                    "@payload.data",
                                    [
                                      "object/get",
                                      "@metric",
                                      "filter",
                                      true
                                    ]
                                  ],
                                  [
                                    "object/get",
                                    "@metric",
                                    "field",
                                    ""
                                  ]
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@metric",
                                      "aggregation",
                                      "count"
                                    ],
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ],
                                    [
                                      "object/get",
                                      "@metric",
                                      "field",
                                      ""
                                    ]
                                  ],
                                  [
                                    "array/len",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "fields": [],
                      "type": "data-list",
                      "entity": "@entity.cards",
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "max": "@card.max",
                          "trend": "@card.trend",
                          "label": "@card.label",
                          "prefix": "@card.prefix",
                          "value": "@card.value",
                          "trendPolarity": "@card.trendPolarity",
                          "format": "@card.format",
                          "variant": "@card.variant",
                          "type": "stat-display",
                          "suffix": "@card.suffix",
                          "target": "@card.target",
                          "icon": "@card.icon"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Summary"
            },
            "metrics": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "format": "number",
                  "icon": "list",
                  "label": "Total Items",
                  "aggregation": "count"
                },
                {
                  "variant": "success",
                  "label": "Active",
                  "format": "number",
                  "icon": "check-circle",
                  "aggregation": "count"
                },
                {
                  "variant": "info",
                  "format": "number",
                  "aggregation": "avg",
                  "field": "value",
                  "label": "Avg Value",
                  "icon": "trending-up"
                }
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsItemStatsPage",
          "path": "/statsitems",
          "traits": [
            {
              "ref": "StatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
