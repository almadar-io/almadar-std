{
  "name": "std-stats",
  "version": "3.1.0",
  "description": "std-stats — embeddable analytics-card atom. ITEMS_LOADED aggregates @payload.data per @config.metrics (count|sum|avg|min|max|variance with optional filter, baselineFilter, format, icon, max, target, trend, trendPolarity, sparkline) and renders one stat-display per entry. Variance metrics compute actual - baseline using `filter` + `baselineFilter` lambdas and report the signed delta as trend. clickEvent emits UI:{clickEvent} { metricLabel } when a card is clicked. Drop into a dashboard alongside std-browse / std-search / std-filter.",
  "orbitals": [
    {
      "name": "StatsItemOrbital",
      "entity": {
        "name": "StatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "required": false,
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "number"
                  }
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string",
                  "required": false
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string",
                  "required": false
                },
                "target": {
                  "name": "target",
                  "type": "number",
                  "required": false
                },
                "trend": {
                  "name": "trend",
                  "type": "number",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": false
                },
                "max": {
                  "name": "max",
                  "type": "number",
                  "required": false
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "required": false,
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string",
                  "required": false
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "required": false,
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                }
              }
            },
            "description": "A collection of statistical cards to display.",
            "synonyms": "statistics, items, displays"
          }
        ]
      },
      "traits": [
        {
          "name": "StatsItemStats",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "cards"
            ]
          },
          "category": "interaction",
          "linkedEntity": "StatsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "sparklineData": [
                            "object/get",
                            "@metric",
                            "sparklineData",
                            []
                          ],
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "trendFormat": [
                            "object/get",
                            "@metric",
                            "trendFormat",
                            "absolute"
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "clickEvent": [
                            "object/get",
                            "@metric",
                            "clickEvent",
                            ""
                          ],
                          "value": [
                            "object/get",
                            "@metric",
                            "value",
                            0.0
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0.0
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "trendFormat": [
                            "object/get",
                            "@metric",
                            "trendFormat",
                            "absolute"
                          ],
                          "trend": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "variance"
                            ],
                            [
                              "-",
                              [
                                "array/sum",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "array/sum",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "baselineFilter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ]
                            ],
                            [
                              "object/get",
                              "@metric",
                              "trend",
                              0.0
                            ]
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "sparklineData": [
                            "object/get",
                            "@metric",
                            "sparklineData",
                            []
                          ],
                          "clickEvent": [
                            "object/get",
                            "@metric",
                            "clickEvent",
                            ""
                          ],
                          "value": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "array/filter",
                                "@payload.data",
                                [
                                  "object/get",
                                  "@metric",
                                  "filter",
                                  true
                                ]
                              ],
                              [
                                "object/get",
                                "@metric",
                                "field",
                                ""
                              ]
                            ],
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@metric",
                                  "aggregation",
                                  "count"
                                ],
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@metric",
                                    "aggregation",
                                    "count"
                                  ],
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "array/filter",
                                    "@payload.data",
                                    [
                                      "object/get",
                                      "@metric",
                                      "filter",
                                      true
                                    ]
                                  ],
                                  [
                                    "object/get",
                                    "@metric",
                                    "field",
                                    ""
                                  ]
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@metric",
                                      "aggregation",
                                      "count"
                                    ],
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ],
                                    [
                                      "object/get",
                                      "@metric",
                                      "field",
                                      ""
                                    ]
                                  ],
                                  [
                                    "if",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@metric",
                                        "aggregation",
                                        "count"
                                      ],
                                      "variance"
                                    ],
                                    [
                                      "array/sum",
                                      [
                                        "array/filter",
                                        "@payload.data",
                                        [
                                          "object/get",
                                          "@metric",
                                          "filter",
                                          true
                                        ]
                                      ],
                                      [
                                        "object/get",
                                        "@metric",
                                        "field",
                                        ""
                                      ]
                                    ],
                                    [
                                      "array/len",
                                      [
                                        "array/filter",
                                        "@payload.data",
                                        [
                                          "object/get",
                                          "@metric",
                                          "filter",
                                          true
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              }
            ]
          },
          "config": {
            "viewPattern": {
              "type": "pattern",
              "default": "data-grid",
              "label": "Render pattern",
              "description": "UI pattern used to arrange the stat cards",
              "synonyms": "internal pattern selector. user prompts rarely target this directly",
              "tier": "internal"
            },
            "metrics": {
              "type": "[MetricSpec]",
              "default": [
                {
                  "format": "number",
                  "icon": "list",
                  "label": "Total Items",
                  "variant": "primary",
                  "aggregation": "count"
                },
                {
                  "label": "Active",
                  "aggregation": "count",
                  "icon": "check-circle",
                  "variant": "success",
                  "format": "number"
                },
                {
                  "label": "Avg Value",
                  "aggregation": "avg",
                  "variant": "info",
                  "format": "number",
                  "field": "value",
                  "icon": "trending-up"
                }
              ],
              "label": "Metrics",
              "description": "One stat card per entry; declares aggregation, format, and styling",
              "synonyms": "list of KPI cards / stat tiles / metric cards. each entry has label / value / format / icon / variant / aggregation. user phrases: 'replace metrics with X, Y, Z' -> rewrite array; 'add Revenue tile' -> append entry; 'change KPIs to X' -> rewrite array",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "value": {
                    "name": "value",
                    "type": "number",
                    "required": false
                  },
                  "suffix": {
                    "name": "suffix",
                    "type": "string",
                    "required": false
                  },
                  "trendPolarity": {
                    "name": "trendPolarity",
                    "type": "string",
                    "required": false,
                    "values": [
                      "higher-is-better",
                      "lower-is-better"
                    ]
                  },
                  "trendFormat": {
                    "name": "trendFormat",
                    "type": "string",
                    "required": false,
                    "values": [
                      "absolute",
                      "percent"
                    ]
                  },
                  "trend": {
                    "name": "trend",
                    "type": "number",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "primary",
                      "success",
                      "warning",
                      "error",
                      "info"
                    ]
                  },
                  "max": {
                    "name": "max",
                    "type": "number",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false,
                    "values": [
                      "number",
                      "currency",
                      "percent"
                    ]
                  },
                  "target": {
                    "name": "target",
                    "type": "number",
                    "required": false
                  },
                  "aggregation": {
                    "name": "aggregation",
                    "type": "string",
                    "required": false,
                    "values": [
                      "count",
                      "sum",
                      "avg",
                      "min",
                      "max",
                      "variance"
                    ]
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": false
                  },
                  "clickEvent": {
                    "name": "clickEvent",
                    "type": "string",
                    "required": false
                  },
                  "prefix": {
                    "name": "prefix",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "sparklineData": {
                    "name": "sparklineData",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "title": {
              "type": "string",
              "default": "Summary",
              "label": "Section title",
              "description": "Heading shown above the stat-card grid",
              "synonyms": "the section header text. user phrases: 'rename section to X' / 'title the KPIs X' / 'change section title to X' -> X",
              "tier": "presentation"
            },
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "entity": "@entity.cards",
                "renderItem": [
                  "fn",
                  "card",
                  {
                    "clickEvent": "@card.clickEvent",
                    "value": "@card.value",
                    "format": "@card.format",
                    "suffix": "@card.suffix",
                    "trendFormat": "@card.trendFormat",
                    "max": "@card.max",
                    "label": "@card.label",
                    "target": "@card.target",
                    "trend": "@card.trend",
                    "trendPolarity": "@card.trendPolarity",
                    "icon": "@card.icon",
                    "prefix": "@card.prefix",
                    "type": "stat-display",
                    "sparklineData": "@card.sparklineData",
                    "variant": "@card.variant",
                    "look": "@config.statLook"
                  }
                ],
                "fields": [],
                "type": "@config.viewPattern"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered after metrics aggregate. Default is the canonical data-grid call mapping @entity.cards through stat-display. Layer 3 variants override this with their own tree (hero numbers, sparkline rows, tile splashes) to deliver entirely different KPI UX while inheriting the same trait, state machine, aggregation pipeline, and listens.",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsItemStatsPage",
          "path": "/statsitems",
          "traits": [
            {
              "ref": "StatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
