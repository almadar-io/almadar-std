{
  "name": "std-stats",
  "version": "3.0.0",
  "description": "std-stats — embeddable analytics-card atom. ITEMS_LOADED aggregates @payload.data per @config.metrics (count|sum|avg|min|max|variance with optional filter, baselineFilter, format, icon, max, target, trend, trendPolarity, sparkline) and renders one stat-display per entry. Variance metrics compute actual - baseline using `filter` + `baselineFilter` lambdas and report the signed delta as trend. clickEvent emits UI:{clickEvent} { metricLabel } when a card is clicked. Drop into a dashboard alongside std-browse / std-search / std-filter.",
  "orbitals": [
    {
      "name": "StatsItemOrbital",
      "entity": {
        "name": "StatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "suffix": {
                  "name": "suffix",
                  "type": "string"
                },
                "trend": {
                  "name": "trend",
                  "type": "number"
                },
                "max": {
                  "name": "max",
                  "type": "number"
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "trendFormat": {
                  "name": "trendFormat",
                  "type": "string",
                  "values": [
                    "absolute",
                    "percent"
                  ]
                },
                "icon": {
                  "name": "icon",
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "type": "number"
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string"
                },
                "target": {
                  "name": "target",
                  "type": "number"
                },
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "sparklineData": {
                  "name": "sparklineData",
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "clickEvent": {
                  "name": "clickEvent",
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "StatsItemStats",
          "category": "interaction",
          "linkedEntity": "StatsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "trendFormat": [
                            "object/get",
                            "@metric",
                            "trendFormat",
                            "absolute"
                          ],
                          "clickEvent": [
                            "object/get",
                            "@metric",
                            "clickEvent",
                            ""
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0.0
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "sparklineData": [
                            "object/get",
                            "@metric",
                            "sparklineData",
                            []
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ],
                          "value": [
                            "object/get",
                            "@metric",
                            "value",
                            0.0
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity.cards",
                      "fields": [],
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "sparklineData": "@card.sparklineData",
                          "type": "stat-display",
                          "icon": "@card.icon",
                          "trendPolarity": "@card.trendPolarity",
                          "format": "@card.format",
                          "value": "@card.value",
                          "max": "@card.max",
                          "clickEvent": "@card.clickEvent",
                          "variant": "@card.variant",
                          "label": "@card.label",
                          "trendFormat": "@card.trendFormat"
                        }
                      ],
                      "type": "@config.viewPattern"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      "@config.metrics",
                      [
                        "fn",
                        "metric",
                        {
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "sparklineData": [
                            "object/get",
                            "@metric",
                            "sparklineData",
                            []
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0.0
                          ],
                          "trendFormat": [
                            "object/get",
                            "@metric",
                            "trendFormat",
                            "absolute"
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0.0
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "clickEvent": [
                            "object/get",
                            "@metric",
                            "clickEvent",
                            ""
                          ],
                          "trend": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "variance"
                            ],
                            [
                              "-",
                              [
                                "array/sum",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "array/sum",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "baselineFilter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ]
                            ],
                            [
                              "object/get",
                              "@metric",
                              "trend",
                              0.0
                            ]
                          ],
                          "value": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "array/filter",
                                "@payload.data",
                                [
                                  "object/get",
                                  "@metric",
                                  "filter",
                                  true
                                ]
                              ],
                              [
                                "object/get",
                                "@metric",
                                "field",
                                ""
                              ]
                            ],
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@metric",
                                  "aggregation",
                                  "count"
                                ],
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@metric",
                                    "aggregation",
                                    "count"
                                  ],
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "array/filter",
                                    "@payload.data",
                                    [
                                      "object/get",
                                      "@metric",
                                      "filter",
                                      true
                                    ]
                                  ],
                                  [
                                    "object/get",
                                    "@metric",
                                    "field",
                                    ""
                                  ]
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@metric",
                                      "aggregation",
                                      "count"
                                    ],
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ],
                                    [
                                      "object/get",
                                      "@metric",
                                      "field",
                                      ""
                                    ]
                                  ],
                                  [
                                    "if",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@metric",
                                        "aggregation",
                                        "count"
                                      ],
                                      "variance"
                                    ],
                                    [
                                      "array/sum",
                                      [
                                        "array/filter",
                                        "@payload.data",
                                        [
                                          "object/get",
                                          "@metric",
                                          "filter",
                                          true
                                        ]
                                      ],
                                      [
                                        "object/get",
                                        "@metric",
                                        "field",
                                        ""
                                      ]
                                    ],
                                    [
                                      "array/len",
                                      [
                                        "array/filter",
                                        "@payload.data",
                                        [
                                          "object/get",
                                          "@metric",
                                          "filter",
                                          true
                                        ]
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "@entity.cards",
                      "fields": [],
                      "type": "@config.viewPattern",
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "trendPolarity": "@card.trendPolarity",
                          "icon": "@card.icon",
                          "format": "@card.format",
                          "prefix": "@card.prefix",
                          "trend": "@card.trend",
                          "sparklineData": "@card.sparklineData",
                          "variant": "@card.variant",
                          "trendFormat": "@card.trendFormat",
                          "type": "stat-display",
                          "clickEvent": "@card.clickEvent",
                          "max": "@card.max",
                          "value": "@card.value",
                          "target": "@card.target",
                          "label": "@card.label",
                          "suffix": "@card.suffix"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "metrics": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "aggregation": "count",
                  "label": "Total Items",
                  "format": "number",
                  "icon": "list"
                },
                {
                  "label": "Active",
                  "variant": "success",
                  "icon": "check-circle",
                  "format": "number",
                  "aggregation": "count"
                },
                {
                  "field": "value",
                  "icon": "trending-up",
                  "format": "number",
                  "aggregation": "avg",
                  "label": "Avg Value",
                  "variant": "info"
                }
              ],
              "label": "Metrics",
              "description": "One stat card per entry; declares aggregation, format, and styling",
              "synonyms": "list of KPI cards / stat tiles / metric cards. each entry has label / value / format / icon / variant / aggregation. user phrases: 'replace metrics with X, Y, Z' -> rewrite array; 'add Revenue tile' -> append entry; 'change KPIs to X' -> rewrite array"
            },
            "title": {
              "type": "string",
              "default": "Summary",
              "label": "Section title",
              "description": "Heading shown above the stat-card grid",
              "synonyms": "the section header text. user phrases: 'rename section to X' / 'title the KPIs X' / 'change section title to X' -> X"
            },
            "viewPattern": {
              "type": "pattern",
              "default": "data-grid",
              "label": "Render pattern",
              "description": "UI pattern used to arrange the stat cards",
              "synonyms": "internal pattern selector. user prompts rarely target this directly"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsItemStatsPage",
          "path": "/statsitems",
          "traits": [
            {
              "ref": "StatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
