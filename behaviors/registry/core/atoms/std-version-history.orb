{
  "name": "std-version-history",
  "version": "1.0.0",
  "description": "std-version-history — wiki/CMS revision history with diff + rollback. Owns a Revision entity (one row per saved version of a document); browses revisions in a data-grid, opens a side-by-side version-diff for any two picks, and persists a rollback by re-saving the chosen revision's content as a new update on the source document.",
  "orbitals": [
    {
      "name": "RevisionOrbital",
      "entity": {
        "name": "Revision",
        "collection": "revisions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "documentId",
            "type": "string",
            "required": true
          },
          {
            "name": "documentType",
            "type": "string",
            "required": true
          },
          {
            "name": "versionNumber",
            "type": "number",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "authorName",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "summary",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RevisionManage",
          "category": "interaction",
          "linkedEntity": "Revision",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "revisionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.authorName",
                  "type": "string"
                },
                {
                  "name": "row.content",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPARE",
              "payloadSchema": [
                {
                  "name": "beforeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "afterId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "beforeRow.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "beforeRow.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "beforeRow.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "beforeRow.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "beforeRow.authorId",
                  "type": "string"
                },
                {
                  "name": "beforeRow.authorName",
                  "type": "string"
                },
                {
                  "name": "beforeRow.content",
                  "type": "string"
                },
                {
                  "name": "beforeRow.summary",
                  "type": "string"
                },
                {
                  "name": "beforeRow.createdAt",
                  "type": "string"
                },
                {
                  "name": "afterRow.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "afterRow.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "afterRow.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "afterRow.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "afterRow.authorId",
                  "type": "string"
                },
                {
                  "name": "afterRow.authorName",
                  "type": "string"
                },
                {
                  "name": "afterRow.content",
                  "type": "string"
                },
                {
                  "name": "afterRow.summary",
                  "type": "string"
                },
                {
                  "name": "afterRow.createdAt",
                  "type": "string"
                },
                {
                  "name": "revisions",
                  "type": "[Revision]"
                }
              ]
            },
            {
              "event": "ROLLBACK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "revisionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.authorName",
                  "type": "string"
                },
                {
                  "name": "row.content",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RevisionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Revision]"
                }
              ]
            },
            {
              "event": "RevisionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RevisionRolledBack",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.authorName",
                  "type": "string"
                },
                {
                  "name": "row.content",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RevisionRollbackFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "comparing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RevisionLoaded",
                "name": "Revision loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Revision]"
                  }
                ]
              },
              {
                "key": "RevisionLoadFailed",
                "name": "Revision load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "revisionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Revision"
                  }
                ]
              },
              {
                "key": "COMPARE",
                "name": "Compare",
                "payloadSchema": [
                  {
                    "name": "beforeId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "afterId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "beforeRow",
                    "type": "Revision"
                  },
                  {
                    "name": "afterRow",
                    "type": "Revision"
                  },
                  {
                    "name": "revisions",
                    "type": "[Revision]"
                  }
                ]
              },
              {
                "key": "ROLLBACK",
                "name": "Rollback",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "revisionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Revision"
                  }
                ]
              },
              {
                "key": "RevisionRolledBack",
                "name": "Revision rolled back",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Revision"
                  }
                ]
              },
              {
                "key": "RevisionRollbackFailed",
                "name": "Revision rollback failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading version history…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RevisionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "history",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "secondary",
                              "icon": "eye"
                            },
                            {
                              "label": "Compare",
                              "event": "COMPARE",
                              "icon": "git-compare",
                              "variant": "secondary"
                            },
                            {
                              "label": "Rollback",
                              "variant": "primary",
                              "icon": "rotate-ccw",
                              "event": "ROLLBACK"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "badge",
                              "label": "Version",
                              "name": "versionNumber"
                            },
                            {
                              "label": "Author",
                              "variant": "caption",
                              "name": "authorName"
                            },
                            {
                              "variant": "caption",
                              "name": "summary",
                              "label": "Summary"
                            },
                            {
                              "label": "Saved",
                              "variant": "caption",
                              "name": "createdAt"
                            }
                          ],
                          "cols": 1.0,
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RevisionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentType",
                    "@payload.row.documentType"
                  ],
                  [
                    "set",
                    "@entity.versionNumber",
                    "@payload.row.versionNumber"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.authorName",
                    "@payload.row.authorName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.row.content"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.row.summary"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.summary"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "content": "@entity.authorName",
                              "variant": "caption",
                              "type": "typography",
                              "color": "muted"
                            },
                            {
                              "content": "@entity.createdAt",
                              "variant": "caption",
                              "color": "muted",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.content"
                        },
                        {
                          "label": "Back",
                          "variant": "secondary",
                          "type": "button",
                          "action": "INIT",
                          "icon": "arrow-left"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "comparing",
                "event": "COMPARE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.afterRow.id"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.afterRow.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentType",
                    "@payload.afterRow.documentType"
                  ],
                  [
                    "set",
                    "@entity.versionNumber",
                    "@payload.afterRow.versionNumber"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.afterRow.authorId"
                  ],
                  [
                    "set",
                    "@entity.authorName",
                    "@payload.afterRow.authorName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.afterRow.content"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.afterRow.summary"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.afterRow.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-compare"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Compare versions"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "version-diff",
                          "afterId": "@payload.afterId",
                          "view": "side-by-side",
                          "revisions": "@payload.revisions",
                          "onRevert": "ROLLBACK",
                          "beforeId": "@payload.beforeId"
                        },
                        {
                          "action": "INIT",
                          "icon": "arrow-left",
                          "type": "button",
                          "label": "Back",
                          "variant": "secondary"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ROLLBACK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentType",
                    "@payload.row.documentType"
                  ],
                  [
                    "set",
                    "@entity.versionNumber",
                    "@payload.row.versionNumber"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.authorName",
                    "@payload.row.authorName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.row.content"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.row.summary"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Revision",
                    "@entity",
                    {
                      "emit": {
                        "success": "RevisionRolledBack",
                        "failure": "RevisionRollbackFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RevisionRolledBack",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "success": "RevisionLoaded",
                        "failure": "RevisionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RevisionRollbackFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "comparing",
                "to": "browsing",
                "event": "ROLLBACK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentType",
                    "@payload.row.documentType"
                  ],
                  [
                    "set",
                    "@entity.versionNumber",
                    "@payload.row.versionNumber"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.authorName",
                    "@payload.row.authorName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.row.content"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.row.summary"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Revision",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RevisionRollbackFailed",
                        "success": "RevisionRolledBack"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "comparing",
                "to": "loading",
                "event": "RevisionRolledBack",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "comparing",
                "to": "comparing",
                "event": "RevisionRollbackFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "success": "RevisionLoaded",
                        "failure": "RevisionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Version History"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RevisionManagePage",
          "path": "/revisions/manage",
          "traits": [
            {
              "ref": "RevisionManage"
            }
          ]
        }
      ]
    }
  ]
}
