{
  "name": "std-version-history",
  "version": "1.0.0",
  "description": "std-version-history — wiki/CMS revision history with diff + rollback. Browses revisions; opens detail in `viewing_single`; compares two revisions in `comparing` with intrinsic version-diff; persists rollback.",
  "orbitals": [
    {
      "name": "RevisionOrbital",
      "entity": {
        "name": "Revision",
        "collection": "revisions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "documentId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the associated document.",
            "synonyms": "reference, identifier, source"
          },
          {
            "name": "documentType",
            "type": "string",
            "required": true,
            "description": "Specifies the kind of document this revision belongs to.",
            "synonyms": "type, kind, category"
          },
          {
            "name": "versionNumber",
            "type": "number",
            "required": true,
            "description": "A sequential identifier representing the revision's order.",
            "synonyms": "sequence, order, iteration"
          },
          {
            "name": "authorId",
            "type": "string",
            "description": "Unique identifier for the user who made the change.",
            "synonyms": "user identifier, creator, contributor"
          },
          {
            "name": "authorName",
            "type": "string",
            "description": "The name of the user who made the change.",
            "synonyms": "user, contributor, owner"
          },
          {
            "name": "content",
            "type": "string",
            "description": "The textual data of the revision.",
            "synonyms": "text, body, data, value"
          },
          {
            "name": "summary",
            "type": "string",
            "description": "A brief explanation of the revision's changes.",
            "synonyms": "description, note, comment, explanation"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RevisionManage",
          "category": "interaction",
          "linkedEntity": "Revision",
          "emits": [
            {
              "event": "OPEN_REVISION",
              "description": "Signals a revision has been selected for viewing.",
              "synonyms": "select, choose, display",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.authorName",
                  "type": "string"
                },
                {
                  "name": "row.content",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW",
              "description": "Indicates the view has been closed or dismissed.",
              "synonyms": "dismiss, hide, close",
              "tier": "essential"
            },
            {
              "event": "COMPARE",
              "description": "Signals a request to compare two versions.",
              "synonyms": "compare, diff, contrast",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "beforeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "afterId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "revisions",
                  "type": "[Revision]"
                }
              ]
            },
            {
              "event": "ROLLBACK",
              "description": "Indicates a revision has been successfully reverted.",
              "synonyms": "reverted, undone, restored",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RevisionLoaded",
              "description": "Signals a revision has been successfully retrieved and is ready.",
              "synonyms": "loaded, fetched, retrieved, available",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Revision]"
                }
              ]
            },
            {
              "event": "RevisionLoadFailed",
              "description": "Indicates a failure to load revision data.",
              "synonyms": "error, fail, problem, unsuccessful",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RevisionRolledBack",
              "description": "Indicates a revision has been successfully restored to a previous state.",
              "synonyms": "restored, reverted, undone",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.versionNumber",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.authorName",
                  "type": "string"
                },
                {
                  "name": "row.content",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RevisionRollbackFailed",
              "description": "Indicates that a revision rollback operation was unsuccessful.",
              "synonyms": "rollback failed, revert error, undo failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "comparing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RevisionLoaded",
                "name": "Revision loaded",
                "description": "Signals a revision has been successfully retrieved and is ready.",
                "synonyms": "loaded, fetched, retrieved, available",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Revision]"
                  }
                ]
              },
              {
                "key": "RevisionRolledBack",
                "name": "Revision rolled back",
                "description": "Indicates a revision has been successfully restored to a previous state.",
                "synonyms": "restored, reverted, undone",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Revision"
                  }
                ]
              },
              {
                "key": "RevisionRollbackFailed",
                "name": "Revision rollback failed",
                "description": "Indicates that a revision rollback operation was unsuccessful.",
                "synonyms": "rollback failed, revert error, undo failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RevisionLoadFailed",
                "name": "Revision load failed",
                "description": "Indicates a failure to load revision data.",
                "synonyms": "error, fail, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_REVISION",
                "name": "Open Revision",
                "description": "Signals a revision has been selected for viewing.",
                "synonyms": "select, choose, display",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Revision"
                  }
                ]
              },
              {
                "key": "ROLLBACK",
                "name": "Rollback",
                "description": "Indicates a revision has been successfully reverted.",
                "synonyms": "reverted, undone, restored",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View",
                "description": "Indicates the view has been closed or dismissed.",
                "synonyms": "dismiss, hide, close",
                "tier": "essential"
              },
              {
                "key": "COMPARE",
                "name": "Compare",
                "description": "Signals a request to compare two versions.",
                "synonyms": "compare, diff, contrast",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "beforeId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "afterId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "revisions",
                    "type": "[Revision]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading version history…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RevisionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "history"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "label": "Total revisions",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "icon": "history"
                            },
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Authors",
                              "icon": "users",
                              "value": "6"
                            },
                            {
                              "type": "stat-display",
                              "icon": "save",
                              "look": "@config.statLook",
                              "label": "Saves this week",
                              "value": "14"
                            },
                            {
                              "label": "Rollbacks",
                              "value": "2",
                              "type": "stat-display",
                              "icon": "rotate-ccw",
                              "look": "@config.statLook"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "look": "@config.tableLook",
                          "gap": "sm",
                          "fields": [
                            {
                              "variant": "badge",
                              "name": "versionNumber",
                              "label": "Version"
                            },
                            {
                              "label": "Author",
                              "name": "authorName",
                              "variant": "caption"
                            },
                            {
                              "name": "summary",
                              "variant": "caption",
                              "label": "Summary"
                            },
                            {
                              "label": "Saved",
                              "variant": "caption",
                              "name": "createdAt"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "arrow-right",
                              "event": "OPEN_REVISION",
                              "label": "Open",
                              "variant": "primary"
                            },
                            {
                              "event": "ROLLBACK",
                              "label": "Rollback",
                              "icon": "rotate-ccw",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "RevisionRolledBack",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RevisionRollbackFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RevisionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_REVISION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.documentType",
                    "@payload.row.documentType"
                  ],
                  [
                    "set",
                    "@entity.versionNumber",
                    "@payload.row.versionNumber"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.authorName",
                    "@payload.row.authorName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.row.content"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.row.summary"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.summary"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.versionNumber"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Author",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.authorName",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Saved"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.createdAt"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Content"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.content",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Version",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "@entity.versionNumber",
                              "icon": "tag"
                            },
                            {
                              "label": "Document",
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "value": "@entity.documentId",
                              "icon": "file"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.documentType",
                              "icon": "layers",
                              "label": "Type",
                              "look": "@config.statLook"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Compare",
                              "variant": "secondary",
                              "action": "COMPARE"
                            },
                            {
                              "variant": "danger",
                              "action": "ROLLBACK",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Rollback"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ROLLBACK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "persist",
                    "update",
                    "Revision",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RevisionRollbackFailed",
                        "success": "RevisionRolledBack"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Rolling back…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading version history…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "comparing",
                "event": "COMPARE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "git-compare",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Compare versions",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "revisions": "@payload.revisions",
                          "beforeId": "@payload.beforeId",
                          "afterId": "@payload.afterId",
                          "type": "version-diff",
                          "onRevert": "ROLLBACK",
                          "view": "side-by-side"
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Rollback",
                              "action": "ROLLBACK",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ROLLBACK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "persist",
                    "update",
                    "Revision",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RevisionRollbackFailed",
                        "success": "RevisionRolledBack"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Rolling back…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "comparing",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "failure": "RevisionLoadFailed",
                        "success": "RevisionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading version history…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "comparing",
                "to": "loading",
                "event": "ROLLBACK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "persist",
                    "update",
                    "Revision",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RevisionRollbackFailed",
                        "success": "RevisionRolledBack"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Rolling back…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Revision",
                    {
                      "emit": {
                        "success": "RevisionLoaded",
                        "failure": "RevisionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Version History",
              "label": "Section title",
              "description": "Heading shown above the revision list",
              "tier": "presentation"
            },
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RevisionManagePage",
          "path": "/revisions/manage",
          "traits": [
            {
              "ref": "RevisionManage"
            }
          ]
        }
      ]
    }
  ]
}
