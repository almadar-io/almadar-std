{
  "name": "std-pagination",
  "version": "1.0.0",
  "description": "std-pagination as a Function — single primitive: pagination control.\nThe Pagination UI component emits `{page}` for page changes; the atom's\nPAGE event payload matches that shape. ITEMS_LOADED accepts an upstream\ndata-loaded event payload `{data : [object]}` and derives totalPages =\nceil(len(data) / pageSize). Molecules wire e.g.\n`FilteredItemBrowse.BrowseItemLoaded -> ITEMS_LOADED` to keep the\npagination control in lockstep with the data hub. The PagedItem entity\npersists currentPage and the derived totalPages so reads from\n@entity.totalPages reflect the latest row count.",
  "orbitals": [
    {
      "name": "PagedItemOrbital",
      "entity": {
        "name": "PagedItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "currentPage",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "totalPages",
            "type": "number",
            "default": 1.0
          }
        ]
      },
      "traits": [
        {
          "name": "PagedItemPagination",
          "category": "interaction",
          "linkedEntity": "PagedItem",
          "emits": [
            {
              "event": "PAGE",
              "payloadSchema": [
                {
                  "name": "page",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "PagedItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PagedItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PagedItemLoaded",
                "name": "PagedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PagedItem]"
                  }
                ]
              },
              {
                "key": "PAGE",
                "name": "Page",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.totalPages",
                    1.0
                  ],
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "totalPages": "@entity.totalPages",
                      "pageChangeEvent": "@config.event",
                      "showPageSize": false,
                      "currentPage": "@entity.currentPage"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PagedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "pageChangeEvent": "@config.event",
                      "showPageSize": false,
                      "totalPages": "@entity.totalPages",
                      "currentPage": "@entity.currentPage"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    "@payload.page"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "totalPages": "@entity.totalPages",
                      "type": "pagination",
                      "pageChangeEvent": "@config.event",
                      "currentPage": "@entity.currentPage",
                      "showPageSize": false
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.totalPages",
                    [
                      "math/ceil",
                      [
                        "/",
                        "@payload.totalCount",
                        "@config.pageSize"
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "pageChangeEvent": "@config.event",
                      "showPageSize": false,
                      "currentPage": "@entity.currentPage",
                      "totalPages": "@entity.totalPages",
                      "type": "pagination"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "PAGE"
            },
            "pageSize": {
              "type": "number",
              "default": 10.0
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPagination"
            }
          ]
        }
      ]
    }
  ]
}
